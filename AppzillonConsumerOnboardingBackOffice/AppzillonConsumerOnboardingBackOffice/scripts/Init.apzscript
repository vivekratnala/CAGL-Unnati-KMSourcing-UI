window.getAppVersion = () => {
    var json = {};
json.id = "APPVERSION";
json.callBack = versionCallback;
json.appId = apz.appId;
apz.ns.getAppVersion(json);
}
let versionCallback = param => {
  window.APP_VERSION = "V"+param.appVersion;  
}
