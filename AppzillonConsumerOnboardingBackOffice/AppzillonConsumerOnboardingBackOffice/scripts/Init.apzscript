setOrientation = function() { //TO SET THE MOBILE APP TO WORK ALWAYS IN PORTRAIT MODE
    var json = {};
    json.orientation = "PORTRAIT";
    apz.ns.setOrientation(json);
}
if (apz.deviceType !== "WEB") {
    setOrientation();
}
Array.prototype.show = function() {
  $.map(this, function(item){
        $('#' + apz.currAppId + '__' + apz.childScr + '__' + item).removeClass('sno');
})
}
Array.prototype.hide = function() {
  $.map(this, function(item){
        $('#' + apz.currAppId + '__' + apz.childScr + '__' + item).addClass('sno');
})
}
Array.prototype.unique = function() {
    return Array.from(new Set(this));
}

