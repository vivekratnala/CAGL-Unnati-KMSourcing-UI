                        noOfRoomsInHouse.push({
                            val: b.key,
                            desc: b.value
                        });
                    });
                    noOfRoomsInHouse.unshift({
                        "val": '-1',
                        "desc": ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
                    });
                }
                if (n.lovName === "CAOTHER" && Object.keys(JSON.parse(response[m].lovDtls))[4] === "modeOfSavings") {
                    $.each(JSON.parse(response[m].lovDtls)["modeOfSavings"], function (a, b) {
                        modeOfSavings.push(b.value);
                    });
                    modeOfSavings.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                }
                if (n.lovName === "CAOTHER" && Object.keys(JSON.parse(response[m].lovDtls))[7] === "noOfTwowheelerOwned") {
                    $.each(JSON.parse(response[m].lovDtls)["noOfTwowheelerOwned"], function (a, b) {
                        noOfTwowheelerOwned.push({
                            val: b.key,
                            desc: b.value
                        });
                    });
                    noOfTwowheelerOwned.unshift({
                        "val": '-1',
                        "desc": ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
                    });
                }
                if (n.lovName === "CAOTHER" && Object.keys(JSON.parse(response[m].lovDtls))[8] === "noOfSmartphones") {
                    $.each(JSON.parse(response[m].lovDtls)["noOfSmartphones"], function (a, b) {
                        noOfSmartphones.push({
                            val: b.key,
                            desc: b.value
                        });
                    });
                    noOfSmartphones.unshift({
                        "val": '-1',
                        "desc": ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
                    });
                }
                if (n.lovName === "CAOTHER" && Object.keys(JSON.parse(response[m].lovDtls))[9] === "agriLandHolding") {
                    $.each(JSON.parse(response[m].lovDtls)["agriLandHolding"], function (a, b) {
                        agriLandHolding.push({
                            val: b.key,
                            desc: b.value
                        });
                    });
                    agriLandHolding.unshift({
                        "val": '-1',
                        "desc": ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
                    });
                }
                if (n.lovName === "CAOTHER" && Object.keys(JSON.parse(response[m].lovDtls))[10] === "RelationshipWithApplicant") {
                    $.each(JSON.parse(response[m].lovDtls)["RelationshipWithApplicant"], function (a, b) {
                        RelationshipWithApplicant.push(b.value);
                    });
                    RelationshipWithApplicant.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                }
                if (n.lovName === "CAOTHER" && Object.keys(JSON.parse(response[m].lovDtls))[10] === "noOfFamilyMembers") {
                    $.each(JSON.parse(response[m].lovDtls)["noOfFamilyMembers"], function (a, b) {
                        noOfFamilyMembers.push({
                            val: b.key,
                            desc: b.value
                        });
                    });
                    noOfFamilyMembers.unshift({
                        "val": '-1',
                        "desc": ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
                    });
                }
                if (n.lovName === "CAOTHER" && Object.keys(JSON.parse(response[m].lovDtls))[11] === "noOfOtherEarningMembers") {
                    $.each(JSON.parse(response[m].lovDtls)["noOfOtherEarningMembers"], function (a, b) {
                        noOfOtherEarningMembers.push({
                            val: b.key,
                            desc: b.value
                        });
                    });
                    noOfOtherEarningMembers.unshift({
                        "val": '-1',
                        "desc": ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
                    });
