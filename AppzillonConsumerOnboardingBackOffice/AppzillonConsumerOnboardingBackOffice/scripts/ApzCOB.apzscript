    //discard application service callback
    discardApplicationCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = "";
                if (gApzCOB.mainProductGroupCode === "CASA") {
                    response = params.res.APZCBO__DiscardApplication_Res.apiResponse.ResponseBody.responseObj;
                } else if (gApzCOB.mainProductGroupCode === "DEPOSIT") {
                    response = params.res.APZCBO__DepositDiscardApplication_Res.apiResponse.ResponseBody.responseObj;
                } else if (gApzCOB.mainProductGroupCode === "CARDS") {
                    response = params.res.APZCBO__DiscardCardApplication_Res.apiResponse.ResponseBody.responseObj;
                } else if (gApzCOB.mainProductGroupCode === "LOAN") {
                    response = params.res.APZCBO__LoanDiscardApplication_Res.apiResponse.ResponseBody.responseObj;
                }
                if (response !== "Invalid Details.") {
                    response = JSON.parse(response);
                    apz.app.BaseScreens.reInitializeVariablesFrDiscardAppln(response);
                    gApzCOB.productDetails.product = gApzCOB.product;
                    gApzCOB.productDetails.productCode = gApzCOB.productCode;
                    gApzCOB.productDetails.subProductName = gApzCOB.subProduct;
                } else {
                    ApzCOB.fnDisplayMsg(response, "E");
                }
            }
        } catch (e) {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    backNavigationCallBack: function (params) {
        if (!apz.isNull(params) && params.choice === true) {
            window.dontPaint = false;
            window.inSessionStoreEnabled = true; //if yes -> inSessionStoreEnabled = true;
        } else {
            window.dontPaint = true;
            if (inSessionStoreMasterEnabled) {
                window.inSessionStore = JSON.parse(JSON.stringify(beforeBack));
            }
            window.inSessionStoreEnabled = false; //if no -> inSessionStoreEnabled = false;
        }
        UPDATED_STAGES = UPDATED_STAGES.filter(
            (stage) => parseInt(stage.split("~")[1]) !== CURRENT_STAGE_NO);
        let prevStageName = STAGES.filter(
            (stage) => parseInt(stage.split("~")[1]) === PREV_STAGE_NO)[0].split("~")[0];
        let stageOccuranceCheck = UPDATED_STAGES.filter(
            (upStage) => upStage.split("~")[0] === prevStageName);
        if (stageOccuranceCheck.length > 1) {
            gApzCOB.currentApplicant = stageOccuranceCheck.length;
        } else {
            gApzCOB.currentApplicant = 1;
        }
        let isvalid = false;
        let stageBreak = false;
        window.backNav = true;
        window.revAndConf = false;
        $("#" + BaseScrId + "applnStatus").addClass("sno");
        for (let m = STAGES.length - 1; m >= 0; m--) {
            stageBreak = false;
            if (!stageBreak) {
                ConfigureScrJson.filter(function (i, k) {
                    if (Number(PREV_STAGE_NO) === parseInt(STAGES[m].split("~")[1].toUpperCase()) && i.confParamName === STAGES[m]
                        .split("~")[0].toUpperCase()) {
                        $("#" + BaseScrId + "baseScroll").removeClass("product-screen");
                        isvalid = apz.app.BaseScreens.checkScreenInMicroapp(i);
                        if (isvalid) {
                            if (window.inSessionStoreEnabled && !apz.isNull(ConfigureScrJson[CURRENT_STAGE_NO - 1].requestFunc)) {
                                apz.app.BaseScreens.storeUnsaved(ConfigureScrJson[CURRENT_STAGE_NO - 1].requestFunc);
                            } //Store unsaved data based on flag and if create request function is present
                            gApzCOB.userDetails.currentScreen = i.confParamName.concat("~N");
                            $("#" + BaseScrId + "STAGE" + currRow).addClass("sno");
                            $("#" + BaseScrId + "STAGE" + prevRow).removeClass("sno");
                            $("#" + BaseScrId + "headerRow").addClass("sno");
                            $("#" + BaseScrId + "footerbtnRow").addClass("sno");
                            $("#" + BaseScrId + "headerText").addClass("sno");
                            if (i.confParamName === "OCCUPATIONDETAILS" && gApzCOB.product !== "CARDS" && gApzCOB.product !==
                                "LOAN") {
                                if (addNomineeDetails === "N") {
                                    window.STAGE_NO = STAGE_NO - 1;
                                    stageBreak = true;
                                }
                            }
                            if (i.confParamName === "NOMINEEDETAILS") {
                                if (addNomineeDetails === "N") {
                                    window.PREV_STAGE_NO = PREV_STAGE_NO - 1;
                                    stageBreak = true;
                                    return;
                                }
                            }
                            $("#" + BaseScrId + "continue").removeClass("sno");
                            $("#" + BaseScrId + "Agree").addClass("sno");
                            $("#" + BaseScrId + "backIcon").addClass("sno");
                            if (
                                (gApzCOB.currentApplicant > 1 &&
                                    /*i.confParamName === "LOANDETAILS" ||*/
                                    i.confParamName === "CUSTVERIFICATIONDP") || (pinCodeVerified && i.confParamName ===
                                        "VALIDATEPINCODE")) {
                                window.STAGE_NO = STAGE_NO - 1;
                                window.CURRENT_STAGE_NO = STAGE_NO - 1;
                                window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                                window.baseRow = baseRow - 1;
                                window.currRow = baseRow - 1;
                                window.prevRow = currRow - 1;
                            } else if (otpVerified && i.confParamName === "ELIGIBLECARDSLIST") {
                                $("#" + BaseScrId + "STAGE1").html("");
                                $("#" + BaseScrId + "baseRow").removeClass("sno");
                                if (CURRENT_STAGE_NO !== 5) {
                                    ApzCOB.hideDivsOnConfStages();
                                    ApzCOB.CompletedAndInprogress();
                                }
                                $.each(apz.data.scrdata.APZCOB__IpaintSideBarMenus_Res, function (a, b) {
                                    if (parseInt(b.stageNo) === STAGE_NO) {
                                        $("#" + BaseScrId + "headerText").text(ApzCOB.getDescfromLitCode(b.stageNameLit));
                                        $("#" + BaseScrId + "headerText").text(ApzCOB.getDescfromLitCode(
                                            "LIT_COMM_GREETING_TXT_CONGRATULATIONSFORCARD"));
                                    }
                                });
                                $("#" + BaseScrId + "headerText").removeClass("sno");
                                $("#" + BaseScrId + "footerbtnRow").addClass("sno");
                                apz.app.BaseScreens.getDepositRequest(i);
                                ApzCOB.launchMicroApp(i.MicroAppID, i.ScreenID, BaseScrId + "STAGE" + prevRow, "");
                                apz.app.BaseScreens.configureFirstStage(PREV_STAGE_NO, i.confParamName, i.MicroAppID, i.ScreenID, i
                                    .Service);
                                window.baseRow = baseRow - 1;
                                window.currRow = baseRow - 1;
                                window.prevRow = currRow - 1 === 0 ? 1 : currRow - 1;
                            } else {
                                if (otpVerified && i.confParamName === "KYCVERIFICATION") {
                                    $("#Select__SelectProduct__subProducts").addClass("sno");
                                }
                                //ApzCOB.launchMicroApp(i.MicroAppID, i.ScreenID, BaseScrId + "STAGE" + prevRow, ""); before joint
                                $.each(i.Divs, function (a, b) {
                                    $("#" + i.MicroAppID + "__" + i.ScreenID + "__" + b).removeClass("sno");
                                });
                                $.each(apz.data.scrdata.APZCBO__IpaintSideBarMenus_Res, function (a, b) {
                                    if (parseInt(b.stageNo) === Number(PREV_STAGE_NO)) {
                                        $("#" + BaseScrId + "headerText").text(ApzCOB.getDescfromLitCode(b.stageNameLit));
                                    }
                                });
                                ApzCOB.launchMicroApp(i.MicroAppID, i.ScreenID, BaseScrId + "STAGE" + prevRow, "");
                                apz.app.BaseScreens.configureFirstStage(PREV_STAGE_NO, i.confParamName, i.MicroAppID, i.ScreenID, i
                                    .Service);
                                window.baseRow = baseRow - 1;
                                window.currRow = baseRow - 1;
                                window.prevRow = currRow - 1 === 0 ? 1 : currRow - 1;
                            }
                            if (i.confParamName === "SELECTPRODUCT") {
                                $("#" + BaseScrId + "footerbtnRow").addClass("sno");
                                $("#" + BaseScrId + "headerRow").addClass("sno");
                                $("#" + BaseScrId + "sidebarCol").addClass("sno");
                                $("body").addClass("ProductBase");
                            }
                            if (i.ScreenID === "FixedDeposit" || i.ScreenID === "RecDeposit") {
                                $("#" + BaseScrId + "headerViewProdCol").removeClass("sno");
                            } else {
                                $("#" + BaseScrId + "headerViewProdCol").addClass("sno");
                            }
                            return;
                        }
                    }
                });
            }
        }
        window.STAGE_NO = STAGE_NO - 1;
        window.CURRENT_STAGE_NO = STAGE_NO - 1;
        window.PREV_STAGE_NO = PREV_STAGE_NO - 1;
        /**SelfAssisted related Changes Starts***/
        if (!window.dashRevConf && STAGES[0].split("~")[0] === CURRENT_STAGE_NAME) {
            if (CURRENT_STAGE_NO <= 0) {
                apz.app.BaseScreens.createLeadfirstScreenBackLaunch();
            } else {
                window.CURRENT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split("~")[0];
            }
        } else {
            window.CURRENT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split("~")[0];
        }
        window.NEXT_STAGE_NAME = STAGES[STAGE_NO - 1].split("~")[0];
        /**SelfAssisted related Changes Ends***/
        ApzCOB.getStageInfo();
    },
    downloadApplicationAsperFlow: function () {
        if (selectedType === "DEPOSIT" && gApzCOB.ExistingCustomer) {
            ApzCOB.downloadApplicationDeposit();
        } else {
            ApzCOB.downloadApplication();
        }
    },
    //back navigation function
    backNavigation: function (params) {
        if (apz.isNull(params) || params.choice === true) {
            if ($(".country-list").is(":visible")) {
                return;
            }
            if ($("#" + BaseScrId + "faqmodel").is(":visible")) {
                ApzCOB.toggleModal(BaseScrId + "faqmodel");
                return;
            } //dont navigate back if country dropdown is open
            if (CURRENT_STAGE_NO > 0 && !apz.isNull(ConfigureScrJson[CURRENT_STAGE_NO - 1].requestFunc) && window
                .inSessionStoreMasterEnabled && window.allowedUnSave.indexOf(apz.currAppId) !== -1 && ApzCOB.isUnsaved() && !
                IS_DASHBOARD_VIEW_DATA) {
                ApzCOB.DispMsgWithCustomButtons(ApzCOB.getDescfromLitCode("LIT_UNSAVED_CONFIRM"), "C", ApzCOB.backNavigationCallBack, ApzCOB
                    .getDescfromLitCode("LIT_COMM_BTN_TXT_YES"), ApzCOB.getDescfromLitCode("LIT_COMM_BTN_TXT_NO")); //ask to save
            } else {
                if (IS_DASHBOARD_VIEW_DATA || UNATTENDED_SCREEN) {
                    apz.app.Login.OnClickMakerChecker("");
                } else if (UNATTENDED_DATA && CURRENT_STAGE_NO <= 3) {
                    ApzCOB.launchMicroApp("Dashbo", "DashboardViewAllApplication", "APZCBO__BaseScreens__BaseDIV", "");
                } else {
                    if (apz.currAppId === "Dashbo") {
                        if (apz.childScr === "ReviewConfirm") {
                            if (window.viewAllClicked) {
                                if (window.currentApplication === "InProgress") {
                                    apz.app.InProgress.viewAllInProgress();
                                } else if (window.currentApplication === "Rejected") {
                                    apz.app.Rejected.viewAllInProgress();
                                } else if (window.currentApplication === "AssignLead") {
                                    apz.app.AssignedLeads.viewAllInProgress();
                                } else if (window.currentApplication === "Approvals") {
                                    apz.app.Approvals.viewAllInProgress();
                                } else if (window.currentApplication === "Completed") {
                                    apz.app.Completed.viewAllInProgress();
                                } else if (window.currentApplication === "Pushback") {
                                    apz.app.PushBack.viewAllInProgress();
                                } else if (window.currentApplication === "PendingCreditAssesment") {
                                    apz.app.PendingCreditAssesment.viewAllInProgress();
                                }
                            } else {
                                if (window.currentApplication === "Rejected") {
                                    if ($("#" + rvwScrId + "RejectHistoryRow").is(":visible")) {
                                        $("#" + rvwScrId + "RejectHistoryRow").addClass("sno");
                                        $("#" + rvwScrId + "RejectReasonRow").removeClass("sno");
                                    } else {
                                        ApzCOB.launchMicroApp("Dashbo", "dashboard", gAppId + "__BaseScreens__BaseDIV", "");
                                    }
                                } else {
                                    if (window.itssearchrc) {
                                        window.itssearchrc = false;
                                        ApzCOB.launchMicroApp("Dashbo", "SearchApplication", "APZCBO__BaseScreens__BaseDIV", "");
                                    } else {
                                        ApzCOB.launchMicroApp("Dashbo", "dashboard", gAppId + "__BaseScreens__BaseDIV", "");
                                    }
                                }
                            }
                        } else if (apz.childScr === "viewallapplication" || apz.childScr === "SearchApplication" || apz.childScr ===
                            "DashboardViewAllApplication") {
                            ApzCOB.launchMicroApp("Dashbo", "dashboard", gAppId + "__BaseScreens__BaseDIV", "");
                        }
                    } else {
                        if (CURRENT_STAGE_NAME === "SELECTPRODUCT") {
                            if (window.selectedDashboProduct === "ALL") {
                                if ($("#Select__SelectProduct__product").is(":visible")) {
                                    ApzCOB.launchMicroApp("Dashbo", "dashboard", gAppId + "__BaseScreens__BaseDIV", "");
                                } else {
                                    apz.app.SelectProduct.backNavigation();
                                }
                            } else {
                                ApzCOB.launchMicroApp("Dashbo", "dashboard", gAppId + "__BaseScreens__BaseDIV", "");
                            }
                        } else if (CURRENT_STAGE_NAME === "ELIGIBLECARDSLIST") {
                            if ($("#" + SelProdScrId + "productDetails").is(":visible")) {
                                apz.app.SelectProduct.backNavigation();
                            } else {
                                ApzCOB.backNavigationCallBack();
                            }
                        } else {
                            if (CURRENT_STAGE_NAME === "UPLOADDOCUMENTS" && parseInt(PREV_STAGE_NO) === 8) {
                                window.backNav = true;
                                ApzCOB.checkCoAppAdditionalDetailsForHomeMaker();
                            } else {
                                ApzCOB.backNavigationCallBack();
                            }
                        }
                    }
                }
            }
        }
        ApzCOB.updateStepperStage();
    },
    isUnsaved: function () {
        //Check if there is any unsaved data
        let isModified = false;
        let curFuncToExe = ConfigureScrJson.filter(function (e, i) {
            return (e.MicroAppID === apz.currAppId && window.allowedUnSave.indexOf(apz.currAppId) !== -1);
        })[0].requestFunc.split(".");
        window.afterBack = window[curFuncToExe[0]][curFuncToExe[1]][curFuncToExe[2]][
            curFuncToExe[3]
        ]("captureAfter");
        if (!apz.isObjectEmpty(beforeBack) && beforeBack[appReqNodeMapping[apz.currAppId][0]] !== undefined) {
            appReqNodeMapping[apz.currAppId].filter(function (e, i) {
                if (e === "addressDetailsWrapperList") {
                    if (JSON.stringify(afterBack[e][0].addressDetailsList[0].payload) !== JSON.stringify(beforeBack[e][0]
                        .addressDetailsList[0].payload)) {
                        isModified = true;
                        return;
                    }
                }
            });
            appReqNodeMapping[apz.currAppId].filter(function (e, i) {
                if (e === "customerDetailsList") {
                    if (afterBack[e][0].customerName !== beforeBack[e][0].customerName || afterBack[e][0].mobileNumber !== beforeBack[
                        e][0].mobileNumber) {
                        isModified = true;
                    }
                    if (JSON.stringify(afterBack[e][0].payload) !== JSON.stringify(beforeBack[e][0].payload)) {
                        isModified = true;
                        return;
                    }
                } else if (e === "occupationDetailsWrapperList") {
                    if (JSON.stringify(afterBack[e][0].occupationDetails.payload) !== JSON.stringify(beforeBack[e][0]
                        .occupationDetails.payload)) {
                        isModified = true;
                        return;
                    }
                } else if (e === "bankingFacilityList") {
                    if (JSON.stringify(afterBack[e][0].payload) !== JSON.stringify(beforeBack[e][0].payload)) {
                        isModified = true;
                        return;
                    }
                }
            });
        } else {
            isModified = true;
        }
        return isModified;
    },
    //function to generate random based on timestamp
    generateRandomNumber: function () {
        const array = new Uint32Array(1);
        window.crypto.getRandomValues(array);
        const randomNum = (array[0] % 90000) + 10000;
        const timestamp = Date.now().toString();
        return randomNum.toString() + timestamp;
    },
    //function to get the mandatory fields that are required to pass for check application service
    MandatoryFieldsVerifyAppln: function () {
        window.mobileNode = false;
        window.nidInpNode = false;
        window.panNode = false;
        window.emailNode = false;
        if (CURRENT_STAGE_NAME === "CUSTVERIFICATION") {
            ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CASA")["CUSTVERIFICATION"].forEach(function (el) {
                if (el.split("~")[0] === "MobileNo" && el.split("~")[1] === "Y" && el.split("~")[2] === "M") {
                    window.mobileNode = true;
                } else if (el.split("~")[0] === "NIDInput" && el.split("~")[1] === "Y" && el.split("~")[2] === "M") {
                    window.nidInpNode = true;
                } else if (el.split("~")[0] === "PANInput" && el.split("~")[1] === "Y" && el.split("~")[2] === "M") {
                    window.panNode = true;
                } else if (el.split("~")[0] === "Email" && el.split("~")[1] === "Y" && el.split("~")[2] === "M") {
                    window.emailNode = true;
                }
            });
        } else if (CURRENT_STAGE_NAME === "KYCVERIFICATION") {
            //do nothing
        } else if (CURRENT_STAGE_NAME === "CUSTOMERDETAILS") {
            ApzCOB.GetCommonCodes("CUSTOMERDETAILS", "COMM")["CUSTOMERDETAILS"].forEach(function (el) {
                if (el.split("~")[0] === "MobileNo" && el.split("~")[1] === "Y" && el.split("~")[2] === "M") {
                    window.mobileNode = true;
                } else if (el.split("~")[0] === "PanNo" && el.split("~")[1] === "Y" && el.split("~")[2] === "M") {
                    window.panNode = true;
                } else if (el.split("~")[0] === "Email" && el.split("~")[1] === "Y" && el.split("~")[2] === "M") {
                    window.emailNode = true;
                }
            });
        }
    },
    //Verify application Service to check weather the appliction exists or not based on mobile Number
    VerifyApplication: function () {
        if (!changeSubProduct) {
            ApzCOB.MandatoryFieldsVerifyAppln();
        }
        var req = {
            apiRequest: {
                interfaceName: "VerifyApplication",
                appId: gAppId,
                requestObj: {
                    mobileNumber: window.mobileNode && !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails.mobileNum : null,
                    nationalId: window.nidInpNode && !apz.isNull(gApzCOB.userDetails.nationalId) ? gApzCOB.userDetails.nationalId : null,
                    pan: window.panNode && !apz.isNull(gApzCOB.userDetails.panNum) ? gApzCOB.userDetails.panNum.toUpperCase() : null,
                    emailId: window.emailNode && !apz.isNull(gApzCOB.userDetails.email) ? gApzCOB.userDetails.email : null,
                    // 'productCode': gApzCOB.productCode,
                    appId: gAppId,
                    mainProductGroupCode: gApzCOB.product,
                    productGroupCode: "CASA",
                    branchCode: !apz.isNull(gApzCOB.userDetails.branchCode) ? gApzCOB.userDetails.branchCode : "",
                },
            },
        };
        ApzCOB.serverBuildParam(gAppId, "verifyApplication", "N", "N", req, false, ApzCOB.VerifyApplicationCB);
    },
    //Verify application Service to check weather the appliction exists or not based on mobile Number
    DepositVerifyApplication: function () {
        let req = {
            apiRequest: {
                interfaceName: "DepositVerifyApplication",
                appId: gAppId,
                requestObj: {
                    //  "mobileNumber": window.mobileNode && !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails.mobileNum : null,
                    appId: gAppId,
                    customerId: gApzCOB.userDetails.customerId,
                    mainProductGroupCode: gApzCOB.product,
                    productGroupCode: "DEPOSIT",
                },
            },
        };
        ApzCOB.serverBuildParam(gAppId, "DepositVerifyApplication", "N", "N", req, false, ApzCOB.VerifyApplicationCB);
    },
    //Verify application Service to check weather the appliction exists or not based on mobile Number
    CardVerifyApplication: function () {
        if (!changeSubProduct) {
            ApzCOB.MandatoryFieldsVerifyAppln();
        }
        gApzCOB.currentApplicant = 1;
        gApzCOB.noOfApplicants = 1;
        let req = {
            apiRequest: {
                interfaceName: "CardVerifyApplication",
                appId: gAppId,
                requestObj: {
                    isExistingCustomer: apz.isNull(gApzCOB.ExistingCustomer) ? "N" : gApzCOB.ExistingCustomer ? "Y" : "N",
                    mobileNumber: window.mobileNode && !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails.mobileNum : null,
                    nationalId: window.nidInpNode && !apz.isNull(gApzCOB.userDetails.nationalId) ? gApzCOB.userDetails.nationalId : null,
                    pan: window.panNode && !apz.isNull(gApzCOB.userDetails.panNum) ? gApzCOB.userDetails.panNum.toUpperCase() : null,
                    emailId: window.emailNode && !apz.isNull(gApzCOB.userDetails.email) ? gApzCOB.userDetails.email : null,
                    appId: gAppId,
                    mainProductGroupCode: gApzCOB.product,
                    productGroupCode: "CARDS",
                },
            },
        };
        ApzCOB.serverBuildParam(gAppId, "CardVerifyApplication", "N", "N", req, false, ApzCOB.VerifyApplicationCB);
    },
    //Verify application Service to check weather the appliction exists or not based on mobile Number
    LoanVerifyApplication: function () {
        gApzCOB.noOfApplicants = 1;
        let req = {
            apiRequest: {
                interfaceName: "LoanVerifyApplication",
                appId: gAppId,
                requestObj: {
                    appId: gAppId,
                    customerId: gApzCOB.userDetails.customerId,
                    mainProductGroupCode: gApzCOB.product,
                    productGroupCode: "LOAN",
                },
            },
        };
        ApzCOB.serverBuildParam(gAppId, "LoanVerifyApplication", "N", "N", req, false, ApzCOB.VerifyApplicationCB);
    },
    //VerifyApplication Service Callback
    VerifyApplicationCB: function (params) {
        apz.stopLoader();
        window.approvedApplication = false;
        let ifaceName = ApzCOB.GetInterfaceResMap(params);
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                if (!apz.isNull(params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode)) {
                    window.pendingApplication = false;
                    $("#" + BaseScrId + "startApplnRow").addClass("sno");
                    if (gApzCOB.product === "CASA") {
                        if (changeSubProduct) {
                            ApzCOB.discardApplication();
                        } else {
                            if (window.modifyReject) {
                                ApzCOB.ModifyRejectedApplication();
                            } else {
                                ApzCOB.createApplication();
                            }
                        }
                    } else if (gApzCOB.product === "DEPOSIT") {
                        if (gApzCOB.ExistingCustomer) {
                            if (changeSubProduct) {
                                ApzCOB.depositDiscardApplication();
                                return;
                            }
                            ApzCOB.FetchCustomerDetails();
                        } else {
                            if (gApzCOB.product === "CARDS") {
                                apz.app.BaseScreens.NonExistingCustomerFlow();
                            } else {
                                ApzCOB.toggleModal(BaseScrId + "newCustomerModal");
                                $("#" + BaseScrId + "depositInformation").removeClass("sno");
                                $("#" + BaseScrId + "loanInformation").addClass("sno");
                            }
                        }
                    } else if (gApzCOB.product === "CARDS") {
                        if (gApzCOB.ExistingCustomer) {
                            if (changeSubProduct) {
                                ApzCOB.discardApplication();
                            }
                            ApzCOB.FetchCustomerDetailsForcards();
                        } else {
                            apz.app.BaseScreens.NonExistingCustomerFlow();
                        }
                    } else if (gApzCOB.product === "LOAN") {
                        if (gApzCOB.ExistingCustomer) {
                            if (changeSubProduct) {
                                ApzCOB.loanDiscardApplication();
                                return;
                            }
                            ApzCOB.FetchCustomerDetailsforLoan();
                        } else {
                            ApzCOB.toggleModal(BaseScrId + "newCustomerModal");
                            $("#" + BaseScrId + "depositInformation").addClass("sno");
                            $("#" + BaseScrId + "loanInformation").removeClass("sno");
                        }
                    }
                }
            } else {
                let response = params.res[ifaceName].apiResponse.ResponseBody.responseObj;
                if (params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode === "IV108") {
                    window.pendingApplication = true;
                    if (JSON.parse(response)["inProgress"].length > 0) {
                        for (var i = 0; i < JSON.parse(response)["inProgress"].length; i++) {
                            if (!apz.isNull(JSON.parse(response)["inProgress"][i].split("~")[4]) && JSON.parse(response)["inProgress"][i]
                                .split("~")[4] !== "null") {
                                if (JSON.parse(response)["inProgress"][i].split("~")[5] === "CASA") {
                                    gApzCOB.userDetails.applicationId = JSON.parse(response)["inProgress"][i].split("~")[0];
                                    gApzCOB.userDetails.versionNum = JSON.parse(response)["inProgress"][i].split("~")[2];
                                    gApzCOB.product = JSON.parse(response)["inProgress"][i].split("~")[5];
                                    gApzCOB.productCode = JSON.parse(response)["inProgress"][i].split("~")[6];
                                    gApzCOB.userDetails.relatedApplicationId = JSON.parse(response)["inProgress"][i].split("~")[4];
                                }
                            } else {
                                gApzCOB.userDetails.applicationId = JSON.parse(response)["inProgress"][i].split("~")[0];
                                gApzCOB.userDetails.versionNum = JSON.parse(response)["inProgress"][i].split("~")[2];
                            }
                        }
                    }
                    if (gApzCOB.product === "CASA") {
                        if (changeSubProduct) {
                            ApzCOB.discardApplication();
                        } else {
                            ApzCOB.FetchApplication();
                        }
                    } else if (gApzCOB.product === "DEPOSIT") {
                        if (gApzCOB.ExistingCustomer) {
                            if (changeSubProduct) {
                                ApzCOB.depositDiscardApplication();
                                return;
                            }
                            ApzCOB.FetchCustomerDetails();
                        } else {
                            ApzCOB.FetchApplication();
                        }
                    } else if (gApzCOB.product === "CARDS") {
                        if (gApzCOB.ExistingCustomer) {
                            if (changeSubProduct) {
                                ApzCOB.depositDiscardApplication();
                                return;
                            }
                            ApzCOB.FetchCustomerDetailsForcards();
                        } else {
                            ApzCOB.CardsFetchApplication();
                        }
                    } else if (gApzCOB.product === "LOAN") {
                        if (gApzCOB.ExistingCustomer) {
                            if (changeSubProduct) {
                                ApzCOB.loanDiscardApplication();
                                return;
                            }
                            ApzCOB.FetchCustomerDetailsforLoan();
                        } else {
                            ApzCOB.FetchApplication();
                        }
                    }
                } else if (params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode === "IV109") {
                    window.approvedApplication = true;
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ALERT_TXT_YOUHAVEACC"), "I", apz.app.BaseScreens.launchDashBoard);
                } else if (params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode === "IV115") {
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_INFO_TXT_APPLICATIONISINPROCESS"), "E", apz.app.BaseScreens
                        .launchDashBoard);
                } else {
                    apz.stopLoader();
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    //Pushback Fetch Application Service
    PushBackFetchApplication: function (curApplicantId) {
        window.dontReloadRC = false;
        let applnId = !apz.isNull(gApzCOB.requestNodes.applicationMaster) && !apz.isNull(gApzCOB.requestNodes.applicationMaster
            .relatedApplicationId) ? gApzCOB.requestNodes.applicationMaster.relatedApplicationId : gApzCOB.userDetails.applicationId;
        let req = {
            apiRequest: {
                interfaceName: "SendbackDataFetch",
                appId: gAppId,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                requestObj: {
                    applicationId: applnId,
                    workitemNumber: gApzCOB.userDetails.workitemNo,
                    versionNo: gApzCOB.userDetails.versionNum,
                },
            },
        };
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "SendbackDataFetch", "N", "N", req, false, ApzCOB.FetchApplicationCB);
        }, 1000);
    },
    //Renewal FetchApplication
    FetchApplicationRenewal: function (curApplicantId) {
        let applnId = gApzCOB.userDetails.applicationId ?? "";
        let req = {
            apiRequest: {
                interfaceName: "",
                appId: gAppId,
                requestObj: {
                    applicationId: applnId,
                    userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id.trim(),
                    appId: gApzCOB.userDetails.appId,
                    versionNum: gApzCOB.userDetails.versionNum,
                },
            },
        };
        if (typeof curApplicantId === "number" && Number(gApzCOB.noOfApplicants) > 1) {
            req.apiRequest.requestObj.custDtlId = curApplicantId;
            if (!apz.isObjectEmpty(gApzCOB.requestNodes.loanDetails)) {
                window.newloanDetails = gApzCOB.requestNodes.loanDetails;
            }
        }
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "FetchApplication", "N", "N", req, false, ApzCOB.FetchApplicationRenewalCB);
        }, 1000);
    },
    //Renewal FetchApplicationService Callback
    FetchApplicationRenewalCB: function (params) {
        window.IS_APPLICANT_CB_EXPIRED = false;
        window.IS_CO_APPLICANT_CB_EXPIRED = false;
        apz.stopLoader();
        let errMsg = "";
        if (!apz.isNull(params.resFull.appzillonBody.APZCBO__SendbackDataFetch_Res)) {
            if (!apz.isNull(params.resFull.appzillonBody.APZCBO__SendbackDataFetch_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = "Fetch Application Data Service Failed." + "<br/>" + params.resFull.appzillonBody.APZCBO__SendbackDataFetch_Res.apiResponse.ResponseHeader.ResponseMessage;
            }
        } else if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
            if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseMessage;
            }
        } else {
            errMsg = "Fetch Application Data Service Failed";
        }
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                //var ifaceName = ApzCOB.GetInterfaceResMap(params);
                let response = "";
                let intaceResp = "";
                if (params.ifaceName === "SendbackDataFetch") {
                    intaceResp = params.res.APZCBO__SendbackDataFetch_Res.apiResponse.ResponseBody.responseObj;
                } else if (params.ifaceName === "FetchApplication") {
                    intaceResp = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
                }
                if (gApzCOB.product === "DEPOSIT") {
                    if (gApzCOB.ExistingCustomer) {
                        response = JSON.parse(params.res.APZCBO__DepositFetchApplication_Res.apiResponse.ResponseBody.responseObj);
                    } else {
                        response = JSON.parse(params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj);
                    }
                } else if (gApzCOB.product === "CARDS") {
                    response = JSON.parse(params.res.APZCBO__CardFetchApplication_Res.apiResponse.ResponseBody.responseObj);
                } else if (gApzCOB.product === "LOAN") {
                    if (gApzCOB.ExistingCustomer) {
                        response = JSON.parse(params.res.APZCBO__LoanFetchApplication_Res.apiResponse.ResponseBody.responseObj);
                    } else {
                        response = JSON.parse(intaceResp);
                    }
                } else {
                    response = JSON.parse(intaceResp);
                }
                //BRE CB Changes
                if (response.applicationMaster.currentStageNo === 3) {
                    if (apz.isNull(response.loanDetails)) {
                        window.cbWrapperData = response.cibilDetailsWrapperList || [];
                        response.cibilDetailsWrapperList = [];
                    }
                }
                if (!apz.isNull(response.cibilDetailsWrapperList) && response.cibilDetailsWrapperList.length > 0) {
                    response.cibilDetailsWrapperList.map((cibil) => {
                        let cbDatObj = cibil.cibilDetails.cbDate;
                        let cbDateFormatted = `${cbDatObj.year}-${cbDatObj.month}-${cbDatObj.day}`;
                        cibil.cibilDetails.cbDate = ApzCOB.dateformatter(cbDateFormatted, "Y-m-d");
                    });
                }
                window.applnRes = response;
                window.auditDtls = response.applicationTimelineDtl;
                window.pendingApplication = true;
                gApzCOB.requestNodes = [];
                gApzCOB.requestNodes = response;
                if (response.applicationMaster.productGroupCode === "LOAN") {
                    window.LoanInProgressProductCode = response.applicationMaster.productCode;
                    window.LoanInProgressProductGroupCode = response.applicationMaster.productGroupCode;
                    let ApplStatus = response.applicationMaster.applicationStatus;
                    if (ApplStatus === "INPROGRESS" || ApplStatus === "INPUTINPROGRESS" || ApplStatus === "PUSHBACK" || (ApplStatus ==
                        "PENDING" && gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "BM")) {
                        if (leads.length > 0) {
                            let selectedLeadInfo = leads.filter(function (item) {
                                return (item.map.customerId == response.applicationMaster.searchCode2);
                            });
                            if (selectedLeadInfo.length > 0) {
                                gApzCOB.selLeadDtls = selectedLeadInfo[0].map;
                            } else {
                                ApzCOB.setselLeadDtls();
                            }
                        } else {
                            if (apz.isObjectEmpty(inSessionStore)) {
                                ApzCOB.setselLeadDtls();
                            }
                        }
                    }
                }
                if (apz.isObjectEmpty(inSessionStore) || ISPUSHBACKPPL || !dontReloadRC) {
                    inSessionStore = {
                        ...gApzCOB.requestNodes,
                    };
                    if (inSessionStore.applicationDocumentsWrapperList.length > 0) {
                        ApzCOB.handleDocumentsSessionStore();
                    }
                }
                ApzCOB.checkIsRejectApplication();
                if (params.ifaceName === "SendbackDataFetch") {
                    if (!apz.isNull(gApzCOB.requestNodes.actionHist) && !apz.isNull(gApzCOB.requestNodes.actionHist[0])) {
                        window.PUSHBACK_ACTION_HISTORY = gApzCOB.requestNodes.actionHist;
                    }
                }
                if (!apz.isNull(response.applnWfDefinitionList)) {
                    gApzCOB.applnWorkFlowRes = response.applnWfDefinitionList;
                }
                if (window.editappln && apz.currAppId !== "RevCof") {
                    gApzCOB.currentApplicant = 1;
                }
                apz.app.BaseScreens.parseJsonFetchResponse();
                apz.app.BaseScreens.updatePrimaryDetails();
                apz.app.BaseScreens.fetchAadhaarDetails();
                if (apz.isNull(gLovs)) {
                    ApzCOB.FetchLov();
                }
                if (!window.editappln && !window.dontupdateCurrAppln && apz.childScr !== "ReviewConfirm") {
                    if (gApzCOB.applicationType === JointAccount && window.pendingApplication) {
                        if (gApzCOB.requestNodes.applicationMaster.applicantsCount > gApzCOB.requestNodes.customerDetailsList.length &&
                            gApzCOB.requestNodes.applicationMaster.currentScreenId === STAGES[STAGES.length - 1].split("~")[0]) {
                            gApzCOB.currentApplicant = gApzCOB.requestNodes.customerDetailsList.length + 1;
                        } else {
                            gApzCOB.currentApplicant = gApzCOB.requestNodes.customerDetailsList.length;
                        }
                    } else {
                        gApzCOB.currentApplicant = "1"; //gApzCOB.requestNodes.customerDetailsList.length;
                    }
                }
                let indexVal = STAGES.findIndex(function (el) {
                    if (!apz.isNull(gApzCOB.requestNodes.applicationMaster.currentStageNo)) {
                        return (parseInt(el.split("~")[1]) === gApzCOB.requestNodes.applicationMaster.currentStageNo);
                    }
                });
                indexVal = indexVal + 2;
                window.STAGE_NO = indexVal;
                window.CURRENT_STAGE_NO = STAGE_NO - 1;
                window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                window.baseRow = indexVal;
                window.currRow = baseRow - 1;
                window.prevRow = currRow - 1 === -1 ? 0 : currRow - 1;
                $("#" + BaseScrId + "startApplnRow").addClass("sno");
                if (indexVal > 3 && indexVal <= 11) {
                    ApzCOB.inProgresssStageMapping(indexVal, gApzCOB.requestNodes.applicationMaster.currentScreenId);
                }
                ApzCOB.LaunchConfiguredScreens();
                $("#" + BaseScrId + "menulist").removeClass("sno");
                $("#" + BaseScrId + "dashBoardList").addClass("sno");
                $(`#${BaseScrId}RefNumDiv`).removeClass("sno");
                $(`#${BaseScrId}RefNum`).text(ApzCOB.getDescfromLitCode("LIT_COMM_TXT_REF_NUM") + gApzCOB.userDetails.applicationId);
                $("#APZCBO__BaseScreens__sidebarController").addClass("sno");
                $(BaseScroll).addClass(SecondaryProduct);
                $("#" + BaseScrId + "homeicon").removeClass("sno");
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(errMsg, "E");
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    //Fetch Application Service
    FetchApplication: function (curApplicantId, callBackFn) {
        //Commented for Renewal flow
        /*var applnId = !apz.isNull(gApzCOB.requestNodes.applicationMaster) && !apz.isNull(gApzCOB.requestNodes.applicationMaster

                .relatedApplicationId) ? gApzCOB.requestNodes.applicationMaster.relatedApplicationId : gApzCOB.userDetails.applicationId*/
        let applnId = gApzCOB.userDetails.applicationId;
        let req = {
            apiRequest: {
                interfaceName: "",
                appId: gAppId,
                requestObj: {
                    applicationId: applnId,
                    userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                    //  "applicationId": "16202346089849322",
