                secondaryKyc = [],
                maritalStatus = [],
                resOwnership = [],
                resYr = [],
                resMn = [],
                loanPurpose = [],
                loanSubPurpose = [],
                disbursementMode = [],
                frequencyOfRepayment = [],
                nomineeRel = [],
                retirementAge = [],
                natureOfEmp = [],
                typeOfEmp = [],
                loanDtls = [],
                earningMembersDtls = [],
                ifscCodes = [],
                currentresidenceproof = [],
                occupations = [],
                typbssEmpent = [],
                bssAddrProof = [],
                empProof = [],
                bssPerOwn = [],
                freqOfInc = [],
                othSrcInc = [],
                accTypes = [],
                agriculture = [],
                animalHusbandry = [],
                manufacturing = [],
                production = [],
                serviceSector = [],
                trading = [],
                transportation = [],
                loanTenureMonths = [],
                religion = [],
                caste = [],
                education = [],
                language = [],
                loanSubPurpose = [],
                stateAndlanguage = [],
                states = [],
                rateOfInteres = [],
                businessActivity = [],
                KendraMeetingDays = [],
                currentAddressProofDocMap = [],
                businessAddressProofDocMap = [],
                employmentProofDocMap = [],
                docMaxAndMand = [],
                DASHBOARD_TABS = [],
                BRE_MAPPING = [],
                cbCallType = [],
                DASHBOARD_CONFIG = [],
                AADHAR_CONFIG = [],
                houseOwnership = [],
                typeOfHouse = [],
                modeOfSavings = [],
                noOfRoomsInHouse = [],
                typeOfRoof = [],
                noOfTwowheelerOwned = [],
                noOfSmartphones = [],
                businessLocation = [],
                buffaloYield = [],
                TypeOfBussiness = [],
                NoOfBuffalo = [],
                KbusinessTenure = [],
                CowYield = [],
                KbusinessLocation = [],
                KTypeOfShops = [],
                NoOfCows = [],
                businessTenure = [],
                KTypeOfBussiness = [],
                TbusinessLocation = [],
                TNumOfMachine = [],
                TType = [],
                TbusDimFac = [],
                TTypeoFMach = [],
                TTypeOfBussiness = [],
                TbusinessTenure = [],
                TNumOfTail = [],
                KOccupancy = [],
                KConversionMetric = [],
                OtherTypeOfBussiness = [],
                OtherbusinessTenure = [],
                KMarketClassification = [],
                agriLandHolding = [],
                OtherFamilyMemebersIncome = [],
                OtherFamilyIncomeInfo = [],
                AgritypeOfAgricultureLand = [],
                AgrilandInAcres = [],
                AgriCropType = [],
                SalMonth = [],
                SalYears = [],
                SalNatureOfEmP = [],
                SalModeOfsal = [],
                IncomeselectBuildingType = [],
                RelationshipWithApplicant = [],
                noOfFamilyMembers = [],
                noOfOtherEarningMembers = [],
                AgricultureCropType = [],
                RPC_STAGES = [],
                DASHBOARDORDER = [];
            SANCTION_MATRIX = [];
            let lovDtlsParsed;
            $.each(response, function (m, n) {
                if (n.lovName === "OCCUPATIONDETAILS" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "Occupation") {
                    $.each(JSON.parse(response[m].lovDtls)["Occupation"], function (a, b) {
                        occupationType.push(b.value);
                    });
                    occupationType.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                }
                if (n.lovName === "RPC_REPORT" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "RPC_REPORT") {
                    RPC_REPORTS_LOV = JSON.parse(response[m].lovDtls)["RPC_REPORT"];
                    RPC_REPORTS_Options = Object.keys(RPC_REPORTS_LOV);
                }
                if (n.lovName === "OCCUPATIONDETAILS" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "Designation") {
                    $.each(JSON.parse(response[m].lovDtls)["Designation"], function (a, b) {
                        designation.push(b.value);
                    });
                    designation.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                }
                if (n.lovName === "CUSTOMERDETAILS" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "Applicant Relationship") {
                    $.each(JSON.parse(response[m].lovDtls)["Applicant Relationship"], function (a, b) {
                        relations.push(b);
                    });
                    relations.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                }
                if (n.lovName === "SERVICES" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "Cheque Leaves") {
                    $.each(JSON.parse(response[m].lovDtls)["Cheque Leaves"], function (a, b) {
                        noOfLeaves.push(b.value);
                    });
                }
                if (n.lovName === "CUSTOMERDETAILS" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "Address Type") {
                    $.each(JSON.parse(response[m].lovDtls)["Address Type"], function (a, b) {
                        addressType.push(b.value);
                    });
                }
                if (n.lovName === "INCOME_OTHER_FAMILY_MEMBERS_INFO") {
                    lovDtlsParsed = JSON.parse(gLovs[m].lovDtls);
                    if (lovDtlsParsed.hasOwnProperty("noOfFamilyMembers")) {
                        $.each(lovDtlsParsed["noOfFamilyMembers"], function (a, b) {
                            OtherFamilyMemebersIncome.push(a);
                        });
                        OtherFamilyMemebersIncome.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                    if (lovDtlsParsed.hasOwnProperty("noOfOtherEarningMembers")) {
                        $.each(lovDtlsParsed["noOfOtherEarningMembers"], function (a, b) {
                            OtherFamilyIncomeInfo.push(a);
                        });
                        OtherFamilyIncomeInfo.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                }
                if (n.lovName === "INCOME_RENTAL") {
                    lovDtlsParsed = JSON.parse(gLovs[m].lovDtls);
                    if (lovDtlsParsed.hasOwnProperty("selectBuildingType")) {
                        $.each(lovDtlsParsed["selectBuildingType"], function (a, b) {
                            IncomeselectBuildingType.push(b.value);
                        });
                        IncomeselectBuildingType.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                }
                if (n.lovName === "INCOME_AGRICULTURE") {
                    lovDtlsParsed = JSON.parse(gLovs[m].lovDtls);
                    if (lovDtlsParsed.hasOwnProperty("typeOfAgricultureLand")) {
                        $.each(lovDtlsParsed["typeOfAgricultureLand"], function (a, b) {
                            AgritypeOfAgricultureLand.push(b.value);
                        });
                        AgritypeOfAgricultureLand.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                    if (lovDtlsParsed.hasOwnProperty("landInAcres")) {
                        $.each(lovDtlsParsed["landInAcres"], function (a, b) {
                            AgrilandInAcres.push({
                                val: b.key,
                                desc: b.value
                            });
                        });
                        AgrilandInAcres.unshift({
                            "val": '-1',
                            "desc": ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
                        });
                    }
                    if (lovDtlsParsed.hasOwnProperty("cropTypes")) {
                        $.each(lovDtlsParsed["cropTypes"], function (a, b) {
                            AgriCropType.push(b.value);
                        });
                        AgriCropType.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                }
                if (n.lovName === "AGRICULTURE") {
                    $.each(JSON.parse(response[m].lovDtls), function (a, b) {
                        AgricultureCropType.push({
                            val: b,
                            desc: a
                        });
                    });
                    AgricultureCropType.unshift({
                        "val": '-1',
                        "desc": ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
                    });
                }
                if (n.lovName === "INCOME_SALARY") {
                    lovDtlsParsed = JSON.parse(gLovs[m].lovDtls);
                    if (lovDtlsParsed.hasOwnProperty("tenureOfEmploymentYears")) {
                        $.each(lovDtlsParsed["tenureOfEmploymentYears"], function (a, b) {
                            SalYears.push(b.value);
                        });
                        SalYears.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                    if (lovDtlsParsed.hasOwnProperty("tenureOfEmploymentMonths")) {
                        $.each(lovDtlsParsed["tenureOfEmploymentMonths"], function (a, b) {
                            SalMonth.push(b.value);
                        });
                        SalMonth.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                    if (lovDtlsParsed.hasOwnProperty("natureOfEmployment")) {
                        $.each(lovDtlsParsed["natureOfEmployment"], function (a, b) {
                            SalNatureOfEmP.push(b.value);
                        });
                        SalNatureOfEmP.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                    if (lovDtlsParsed.hasOwnProperty("modeOfSalary")) {
                        $.each(lovDtlsParsed["modeOfSalary"], function (a, b) {
                            SalModeOfsal.push(b.value);
                        });
                        SalModeOfsal.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                }
                if (n.lovName === "DAIRY") {
                    lovDtlsParsed = JSON.parse(gLovs[m].lovDtls);
                    if (lovDtlsParsed.hasOwnProperty("Business_Location")) {
                        $.each(lovDtlsParsed["Business_Location"], function (a, b) {
                            businessLocation.push(a);
                        });
                        businessLocation.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                    if (lovDtlsParsed.hasOwnProperty("Buffalo Yield")) {
                        $.each(lovDtlsParsed["Buffalo Yield"], function (a, b) {
                            buffaloYield.push(a);
                        });
                        buffaloYield.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                    if (lovDtlsParsed.hasOwnProperty("Cow Yield")) {
                        $.each(lovDtlsParsed["Cow Yield"], function (a, b) {
                            CowYield.push(a);
                        });
                        CowYield.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
                    if (lovDtlsParsed.hasOwnProperty("NoOfCows")) {
                        $.each(lovDtlsParsed["NoOfCows"], function (a, b) {
                            NoOfCows.push(a);
                        });
                        NoOfCows.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                    }
