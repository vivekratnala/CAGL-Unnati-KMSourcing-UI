    //Fetch states Service Callback
    FetchStatesCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = JSON.parse(params.res.APZCBO__FetchStates_Res.apiResponse.ResponseBody.responseObj);
                gStates = response;
                States = [];
                $.each(gStates, function (a, b) {
                    let obj = {};
                    obj.val = b.stateCode;
                    obj.desc = b.stateName;
                    States.push(obj);
                });
                States.unshift({
                    val: "-1",
                    desc: ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"),
                });
                if (!apz.isNull(window.populatedropdownScrID)) {
                    ApzCOB.stateDropDown(window.populatedropdownScrID, "state");
                    ApzCOB.citydropDown(window.populatedropdownScrID, "state", "city");
                    if (CURRENT_STAGE_NAME === "NOMINEEDETAILS") {
                        ApzCOB.stateDropDown(window.populatedropdownScrID, "grdState");
                        ApzCOB.citydropDown(window.populatedropdownScrID, "grdState", "grdCity");
                    }
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    stateDropDown: function (screenId, stateId) {
        apz.populateDropdown(document.getElementById(screenId + stateId), States);
    },
    // To Fetch Cities
    FetchCities: function (stateCode, screenId, cityId) {
        let req = {
