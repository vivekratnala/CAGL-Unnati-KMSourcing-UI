    dbStageVerificationService: function (currentStage) {
        let {
            loginResponse
        } = gApzCOB.LoggedInUserDetails || {};
        let req = {
            "apiRequest": {
                "appId": gAppId,
                "userId": loginResponse?.userDet?.id || "",
                "interfaceName": "UploadDBKITLoanData",
                "requestObj": {
                    "appId": gAppId,
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "versionNum": 1,
                    "stageId": currentStage?.toString(),
                    "customerType": "Applicant",
                    "requestType": "VERIFY",
                    // "udhyamRegId": "123",
                    // "udhyamStatus": "initiated",
                    // "remarks": "testing",
                    // "query": []
                }
            }
        }
        if (applicationStatus === 'DBPUSHBACK' && apz.childScr === 'DocExecutionManual') {
            req.apiRequest.requestObj.queries = apz.app.DocExecutionManual.getQueryDocResp();
            req.apiRequest.requestObj.reuploadedDocs = apz.app.DocExecutionManual.getReuploadedDocs();
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "UploadDBKITLoanData", "N", "N", req, false, ApzCOB.dbStageVerificationServiceCB);
    },
    dbStageVerificationServiceCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.updateInsessionData(params);
                if (applicationStatus === 'DBPUSHBACK' && apz.childScr === 'DocExecutionManual') {
                    remarks = $(`#${scrId}dbKitComment`).val();
                    ApzCOB.closeCommonModal('newCommonConfModal');
                    apz.app.DBbase.Stagemoment('', 'SUBMIT', remarks);
                    // Stage moment
                    return;
                }
                ApzCOB.dbKitSideMenuStatusCheck();
                let currentStage = params.req.apiRequest.requestObj.stageId;
                let nextStageId = Number(currentStage) + 1;
                if (applicationStatus === 'DBPUSHBACK' && nextStageId == 4) nextStageId += 1;
                const hypLinkId = Object.keys(DBKIT_STAGES).find(key => DBKIT_STAGES[key].id === nextStageId);
                $(`#${DbbaseScrId + hypLinkId}_hyp`).click();
            }
        } catch (error) {
            ApzCOB.showCommonErrRPCModal();
        }
    },
    dbKitSideMenuStatusCheck: function () {
        if (apz.isObjectEmpty(inSessionStore) || !Array.isArray(inSessionStore.dbKitVerifiedStage) || apz.isNull(inSessionStore
            .dbKitStatDetails)) {
            return [];
        }
        let verifiedStageResp = inSessionStore.dbKitVerifiedStage;
        let verifiedStages = ApzCOB.getVerifiedStageInfo(verifiedStageResp);
        let updatedStatus = [];
        verifiedDate = '';
        Object.values(DBKIT_STAGES).forEach(dbStage => {
            let isVerified = verifiedStages.some(stage => stage.stageID === dbStage.id);
            let hyperlinkId = Object.keys(DBKIT_STAGES).find(key => DBKIT_STAGES[key].id === dbStage.id);
            if (isVerified) {
                apz.app.DBbase.addCompleteStatus(`${DbbaseScrId + hyperlinkId}_hyp`);
                if (dbStage.id === 3) {
                    apz.app.DBbase.updateUdyamSidebarStatus();
                }
            } else {
                apz.app.DBbase.clearIcons(`${DbbaseScrId + hyperlinkId}_hyp`)
            }
        });
    },
