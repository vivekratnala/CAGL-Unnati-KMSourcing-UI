    RpcDBQuerySave: function (lArr, callback) {
        let lcallBack = ApzCOB.RpcDBQuerySaveCB;
        let querylreqType = '';
        let stageId = '';
        let queries = lArr;
        let approvedDocs = inSessionStore.approvedDocs;
        if (apz.currAppId === "DBkitG") {
            querylreqType = "Query"
            lcallBack = callback;
            stageId = DBKIT_STAGES[apz.childScr].id?.toString();
        } else {
            stageId = RPCDBVerify_STAGES[apz.childScr]?.id?.toString();
            if (RPCDBVerify_STAGES[apz.childScr].id === 4) {
                querylreqType = "Verify";
                if (callback == 'Approve') {
                    approvedDocs = [...approvedDocs, currentDoc];
                    queries = inSessionStore.dbVerificationQueries.filter(item => item.split('^')[0] != currentDoc);
                } else {
                    approvedDocs = approvedDocs.filter(item => item != currentDoc);
                }
            } else {
                querylreqType = "Query"
            }
        }
        let {
            loginResponse
        } = gApzCOB.LoggedInUserDetails || {};
        let req = {
            apiRequest: {
                requestObj: {},
                // requestType: "Edit",
                userId: loginResponse?.userDet?.id || "",
                appId: gAppId,
                interfaceName: "UploadDBKITLoanData",
            },
        };
        currentApplicationData = structuredClone ? structuredClone(inSessionStore) : JSON.parse(JSON.stringify(inSessionStore));
        let {
            createTs,
            updateTs,
            applicationDate,
            lockTs,
            ...filteredData
        } = currentApplicationData.applicationMaster;
        req.apiRequest.requestObj = {
            ...req.apiRequest.requestObj,
            appId: currentApplicationData?.appId,
            applicationId: currentApplicationData?.applicationId,
            versionNum: currentApplicationData.applicationMaster.versionNum,
            stageId: stageId,
            requestType: querylreqType,
            customerType: "Applicant",
            queries,
        };
        if (apz.currAppId === "RPCDBV" && RPCDBVerify_STAGES?.[apz.childScr]?.id === 4) {
            req.apiRequest.requestObj.approvedDocs = approvedDocs;
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "UploadDBKITLoanData", "N", "N", req, false, lcallBack);
    },
