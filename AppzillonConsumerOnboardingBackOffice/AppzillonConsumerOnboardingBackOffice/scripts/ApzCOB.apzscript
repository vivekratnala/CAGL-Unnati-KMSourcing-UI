    //delete documents Service
    deleteDocument: function (selectedType, type, pthis, docId, callBackFn) {
        if (!apz.isNull(pthis)) {
            window.deleteRowNo = $(pthis).attr("rowno");
        }
        window.FileSideBrowseId = type;
        if (selectedScrId === "UploadDocuments") {
            let lselCat = !apz.isNull(selCat) ? selCat : "";
            window.tempFileArr = apz.app.UploadDocuments.getTypeBasedDoc(selType, SELECTED_DOC_APP_ID);
        } else if (selectedScrId === "KYCVerification") {
            window.tempFileArr = apz.app.KYCVerification.selectedFileData(selectedType);
        } else if (apz.childScr === "EmploymentDetails") {
            window.tempFileArr = apz.app.EmploymentDetails.selectedFileData("");
        } else if (apz.childScr === "LoanDetails") {
            window.tempFileArr = apz.app.LoanDetails.selectedFileData("");
        } else if (apz.childScr === 'Saloandetails' || apz.currAppId === 'DBkitG' || apz.childScr === 'CaotherDetails' || apz.childScr ===
            'CaIncomeDetails' || apz.childScr === 'LUCDetails' || apz.childScr === 'AadhaarDetails' || apz.childScr === 'Kmbase' || apz.childScr === 'documentCapture') {
            window.tempFileArr = ApzCOB.getDocDetailsById(docId);
        }
        let callBackFunc = callBackFn || ApzCOB.deleteDocumentCB;
        let applnId = (gApzCOB.mainProductGroupCode === "DEPOSIT" || gApzCOB.mainProductGroupCode === "LOAN") && !gApzCOB.ExistingCustomer ?
            gApzCOB.relatedApplicationId : gApzCOB.userDetails.applicationId;
        let req = {
            apiRequest: {
                interfaceName: "",
                requestObj: {
                    appDocId: tempFileArr[0]["appDocId"],
                    versionNum: gApzCOB.userDetails.versionNum,
                    applicationId: gApzCOB.userDetails.applicationId,
                    appId: gApzCOB.userDetails.appId,
                    filePath: "/".concat(gApzCOB.userDetails.appId).concat("/").concat(gApzCOB.product).concat("/").concat(gApzCOB
                        .userDetails.applicationId).concat("/"),
                    fileName: apz.isNull(tempFileArr[0]["filename"]) ? tempFileArr[0].payload["documentFileName"] : tempFileArr[0][
                        "filename"
                    ],
                    //"fileLocation": "/home/jboss711/jboss-eap-7.3_OnboardingBase/fileUpload/".concat(tempFileArr[0]["filelocation"]),
                },
            },
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "DeleteDocument", "N", "N", req, false, callBackFunc);
    },
    getDocDetailsById: function (docId) {
        let tempFileArr = [];
        if (!apz.isNull(docId)) {
            let documentObj = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.find(doc => doc.appDocId === docId);
            if (!apz.isObjectEmpty(documentObj)) {
                tempFileArr.push(documentObj);
                return tempFileArr;
            } else {
                throw new Error();
            }
        }
    },
    //Delete documents callback
    deleteDocumentCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                if (selectedScrId === "UploadDocuments") {
                    apz.app.UploadDocuments.updateModifiedFiles(tempFileArr);
                    if (IS_ADITIONAL_DOC_OPERATION) {
                        apz.app.UploadDocuments.LoadFileNamesForOtherDoc();
                    }
                } else if (selectedScrId === "KYCVerification") {
                    apz.app.KYCVerification.updateModifiedFiles(tempFileArr);
                    if (!window.manualDelete) {
                        apz.app.KYCVerification.displayFileName();
                        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_DOC_DELETE_SUCCESS"), "I");
                    }
                } else if (apz.childScr === "EmploymentDetails") {
                    apz.app.EmploymentDetails.deleteBnkDoc(tempFileArr);
                } else if (apz.childScr === "LoanDetails") {
                    apz.app.LoanDetails.deleteBnkDoc();
                }
            } else {
                ApzCOB.fnDisplayMsg("Delete Document Failed.! Please try again", "E");
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    //Assign Application Service
    AssignApplication: function (pthis) {
        apz.startLoader();
        apz.app.BaseScreens.stageBasedOnAction(pthis);
        let req = {
            apiRequest: {
                interfaceName: "",
                appId: gAppId,
                requestObj: {
                    applicationId: gApzCOB.userDetails.applicationId,
                    userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                    appId: gApzCOB.userDetails.appId,
                    versionNum: gApzCOB.userDetails.versionNum,
                    workflow: {
                        currentRole: gApzCOB.workflow.currentRole,
                        action: gApzCOB.workflow.action,
                        workflowId: gApzCOB.workflow.workflowId,
                        stage: gApzCOB.workflow.stage,
                    },
                },
            },
        };
        ApzCOB.serverBuildParam(gAppId, "AssignApplication", "N", "N", req, false, ApzCOB.AssignApplicationCB);
    },
    //AssignApplicationService Callback
    AssignApplicationCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_SUCC_TXT_APPLICATIONASSIGNEDSUCC"), "S", apz.app.Dashboard
                    .LaunchDashboardCB);
                apz.app.BaseScreens.fetchRole("");
            }
