    getFullDate: function (ldata, year, month, day, hour, minute, second) {
        let ldate;
        if (typeof ldata === "object") {
            let dateStr = "" + year + "/" + month + "/" + day;
            let timeStr = "" + hour + ":" + minute + ":" + second;
            ldate = new Date(dateStr + " " + timeStr).$format("d M Y H:m:s");
        }
        return ldate;
    },
    fnValidateAppSecToken: function (pCallBack) {
        let jsonobj = {
            id: "PLGN_GET_APPTOKEN",
            callBack: pCallBack,
        };
        apz.ns.isAppTokenSet(jsonobj);
    },
    appSecTokenCB: function (params) {
        if (params.hasOwnProperty("appTokenStatus") && params.appTokenStatus === "Y") {
            window.isAppTokenSet = "Y";
            ApzCOB.CommonCodeParams();
            ApzCOB.MBbackPressedEvent();
            apz.app.BaseScreens.contactus();
            apz.app.BaseScreens.paintApplicatonTypes();
        } else {
            setTimeout(function () {
                ++isAppTokenCounter;
                ApzCOB.fnValidateAppSecToken(ApzCOB.appSecTokenCB);
            }, 200);
        }
    },
    downloadFileFromserverforcards: function () {
        let filepth = "";
        let json = {
            destinationPath: "",
            filePath: gAppId.concat("/").concat(gApzCOB.userDetails.applicationId),
            sessionReq: "N", //Y or N
        };
        if (gApzCOB.requestNodes.cardDetails.theme === "N") {
            filepth = "APZCOB".concat("/").concat(gApzCOB.product).concat("/").concat("DefaultImages");
        } else {
            filepth = gAppId.concat("/").concat(gApzCOB.product).concat("/").concat(gApzCOB.userDetails.applicationId);
        }
        json.destinationPath = "image";
        json.fileName = gApzCOB.requestNodes.cardDetails.customTheme;
        json.base64 = "Y";
        json.filePath = filepth;
        json.id = "";
        json.callBack = downloadFileFromserverCBforcards;
        apz.ns.downloadFile(json);
    },
    /**** Callback function will be called only if bsae64 image is requested *********/
    downloadFileFromserverCBforcards: function (params) {
        //finalimgdataforc = []
        if (!apz.isNull(params.base64)) {
            let obj = {
                image: params.base64,
                // "docname": allDocTypes[docCallBackCounter]
            };
            apz.data.scrdata.CardSe__IpaintFileUpload_Res = {};
            apz.data.scrdata.CardSe__IpaintFileUpload_Res.fileDetails = [];
            let obj12 = {
                fieldID: "",
                filename: gApzCOB.requestNodes.cardDetails.customTheme,
                filetype: "image/png",
                fname: gApzCOB.requestNodes.cardDetails.customTheme,
                imgSrc: params.base64,
            };
            apz.data.scrdata.CardSe__IpaintFileUpload_Res.fileDetails.push(obj12);
            apz.data.loadData("IpaintFileUpload", "CardSe");
            let imageData = apz.data.scrdata.CardSe__IpaintFileUpload_Res.fileDetails;
            apz.data.scrdata.APZCBO__IPaintSuccImage_Res = [];
            if (!apz.isNull(imageData)) {
                let obj2 = {};
                obj2.image = imageData[0].imgSrc;
                apz.data.scrdata.APZCBO__IPaintSuccImage_Res.push(obj2);
                apz.data.loadData("IPaintSuccImage", gAppId);
            } else {
                let obj1 = {};
                obj1.image = SelectedCardThemeName;
                apz.data.scrdata.APZCBO__IPaintSuccImage_Res.push(obj1);
                apz.data.loadData("IPaintSuccImage", gAppId);
            }
            $("#APZCBO__BaseScreens__personname").text(gApzCOB.requestNodes.cardDetails.nameOnCard);
            $("#APZCBO__BaseScreens__cardname").text(gApzCOB.requestNodes.cardDetails.cardName);
            apz.setElmValue(BaseScrId + "SelectedCreditCard", gApzCOB.requestNodes.cardDetails.cardName);
            apz.setElmValue(BaseScrId + "refNo", gApzCOB.userDetails.applicationId);
        } else {
            //do nothing
        }
    },
    backPressPart: function () {
        $("#" + gAppId + "__PreLogin_BaseScreen__mob_footerbackbtnColumn").trigger("onclick"); //prelogin screens
        //var lastScr = ApzCOB.getprevscrPageBC();
        if (apz.currAppId === "Dashbo") {
            $("#" + gAppId + "__PostLogin_BaseScreen__backButtonColumn").trigger("onclick", ApzCOB.logout());
        } //postlogin screens
        else if (apz.currAppId === "Login") {
            apz.app.Login.backpressed();
        } else if (apz.currAppId === "PLFeat") {
            apz.app.PreLogin_BaseScreen.preloginback();
        } else if (apz.currAppId === "Authen" && apz.isFunction(apz.app[apz.childScr].backNavigation)) {
            apz.app[apz.childScr].backNavigation();
        } else {
            apz.app[apz.childScr].backNavigation();
        }
    },
    sameCommonAddr: function () {
        if (window.sameCommAddress) {
            if ($("#" + PerDetScrId + "city").is(":visible")) {
                apz.setElmValue(PerDetScrId + "city", apz.getElmValue(PerDetScrId + "pCity"));
                $("#" + PerDetScrId + "city").val(pCity);
                $("#" + PerDetScrId + "AddPermanentToggle").prop("checked", true);
            }
        }
    },
    loadCityDropDown: function () {
        let a = gApzCOB.requestNodes["addressDetailsWrapperList"][0].addressDetailsList[0].payload.addressList[0];
        apz.app.PersonalDetails.getStateCityValueforDropdown();
        if (a.city !== "") {
            apz.setElmValue(PerDetScrId + "pCity", cityVal[cityDesc.indexOf(a.city)]);
        }
    },
    loadMenuList: function () {
        for (let i = 0; i < $("#" + BaseScrId + "menulist ul").children().length; i++) {
            if (!$("#" + BaseScrId + "menulist_row_" + i).hasClass("completed")) {
                if (PARALLEL_FLOW_STAGE_NO.includes(CURRENT_STAGE_NO)) {
                    if (gApzCOB.currentApplicant > 1) {
                        if (i <= CURRENT_STAGE_NO) {
                            $("#" + BaseScrId + "menulist_row_" + i).addClass("completed");
                            $("#" + BaseScrId + "menulist_row_" + i).removeClass("progress");
                        }
                        if (STAGE_NO === parseInt($("#APZCBO__IpaintSideBarMenus__o__APZCBO__IpaintSideBarMenus_Res__stageNo_" + i).text())) {
                            $("#" + BaseScrId + "menulist_row_" + i).addClass("progress");
                            $("#" + BaseScrId + "menulist_row_" + i).removeClass("completed");
                        }
                    }
                } else {
                    if (i <= CURRENT_STAGE_NO) {
                        $("#" + BaseScrId + "menulist_row_" + i).addClass("completed");
                        $("#" + BaseScrId + "menulist_row_" + i).removeClass("progress");
                    }
                    if (STAGE_NO === parseInt($("#APZCBO__IpaintSideBarMenus__o__APZCBO__IpaintSideBarMenus_Res__stageNo_" + i).text())) {
                        $("#" + BaseScrId + "menulist_row_" + i).addClass("progress");
                        $("#" + BaseScrId + "menulist_row_" + i).removeClass("completed");
                    }
                }
            }
        }
    },
    loadCreatLoanPart: function () {
        if (gApzCOB.CobCallCBS === "Y") {
            $("#" + BaseScrId + "DepositAccount").removeClass("sno");
        } else {
            $("#" + BaseScrId + "DepositAccount").addClass("sno");
        }
        $("#" + BaseScrId + "sucText").text(gApzCOB.CobCallCBS === "N" ? ApzCOB.getDescfromLitCode(
            "LIT_COMM_SUCCESS_TXT_APPSUBSUCCESSBANKPROCESS") : ApzCOB.getDescfromLitCode("LIT_APPLN_SUC_MSG"));
        return;
    },
    restrictWhiteSpace: function (pthis) {
        let fieldId = document.getElementById(pthis.id);
        fieldId.addEventListener("input", () => {
            fieldId.value = fieldId.value ? fieldId.value?.replace(/^\s+/, '') : "";
        });
    },
    restrictBeyondMaxlength: function (pthis) {
        let idValue = $(`#${pthis.id}`).val();
        if (idValue.length > pthis.maxLength) {
            $(`#${pthis.id}`).val(idValue.slice(0, pthis.maxLength));
        }
    },
    validateVoterIdOnKeyup: function (pthis) {
        pthis.value = pthis.value.replace(/[^a-zA-Z0-9/]/g, '');
    },
    validateVoterid: function (pthis) {
        var inputvalues = pthis.value?.trim().toUpperCase();
        var regex = /^[A-Z]{3}[0-9]{7}$/;
        return regex.test(inputvalues);
    },
    fnvalidatePan: function (pthis) {
        let panNo = pthis.value.toUpperCase();
        if (pan(panNo) == false) {
            pthis.value = "";
        }
    },
    UpdateApplicantscount: function () {
        let req = {
            apiRequest: {
                appId: gAppId,
                requestObj: {
                    applicationId: gApzCOB.userDetails.applicationId,
                    applicantsCount: gApzCOB.noOfApplicants,
                    appId: gAppId,
                    versionNum: gApzCOB.userDetails.versionNum,
                },
            },
        };
        ApzCOB.serverBuildParam(gAppId, "UpdateApplicantscount", "N", "N", req, false, ApzCOB.UpdateApplicantscountCB);
    },
    UpdateApplicantscountCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.LaunchConfiguredScreens();
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    fetchpincodeDtls: function (param, type, callBackFn) {
        if (!pincodeRegex.test(param)) {
            ApzCOB.fnDisplayMsg("Please provide valid pincode!", "E");
            return;
        }
        window.pincodetype = type;
        window.validPinCode = false;
        let callback = callBackFn || ApzCOB.fetchpincodeCB;
        let req = {
            apiRequest: {
                interfaceName: "fetchpincode",
                appId: gAppId,
                requestObj: {
                    pinCode: param,
                },
            },
        };
        ApzCOB.serverBuildParam(gAppId, "fetchpincode", "N", "N", req, false, callback);
    },
    fetchpincodeCB: function (params) {
        apz.stopLoader();
        if (ApzCOB.handleServiceCallBacks(params)) {
            if (params.res.APZCBO__fetchpincode_Res.apiResponse.ResponseHeader.ResponseCode == "0") {
                let pincode_Detls = JSON.parse(JSON.parse(params.res.APZCBO__fetchpincode_Res.apiResponse.ResponseBody.responseObj)
                    .pinCodeDetails);
                window.validPinCode = true;
                if (["ResidenceAddressProofRPC", "SecondaryKYCRPC", "BusinessAddressProofRPC"].includes(pincodetype)) {
                    apz.app[RPC_CURRENT_STAGE].paint_pincode(pincode_Detls);
                } else if (window.pincodetype === "per") {
                    apz.app.PersonalDetails.paint_pincode(pincode_Detls);
                } else if (window.pincodetype === "emp") {
                    apz.app.EmploymentDetails.paint_pincode(pincode_Detls);
                } else if (window.pincodetype === "addPre" || window.pincodetype === "addPerm" || window.pincodetype === "ocr") {
                    apz.app.Kmbase.paint_pincode(pincode_Detls, window.pincodetype);
                }
            }
        } else {
            let parmObj = {
                city: "",
                district: "",
                state: "",
                country: "",
                area: ""
            };
            window.validPinCode = false;
            let paramsResp = params?.res?.APZCBO__fetchpincode_Res?.apiResponse?.ResponseHeader
            if (paramsResp?.ResponseCode == "1" && paramsResp?.ResponseMessage) {
                ApzCOB.showCommonErrRPCModal(paramsResp?.ResponseMessage);
            }
            if (["ResidenceAddressProofRPC", "SecondaryKYCRPC", "BusinessAddressProofRPC"].includes(pincodetype)) {
                $(`#RPC__${RPC_CURRENT_STAGE}__pinCodeInput`).val('');
                apz.app[RPC_CURRENT_STAGE].paint_pincode(parmObj);
                ApzCOB.showInputErrMsg($(`#RPC__${RPC_CURRENT_STAGE}__pinCodeInput`)[0]);
            } else if (window.pincodetype == "per") {
                apz.app.PersonalDetails.paint_pincode(parmObj);
            } else if (window.pincodetype == "emp") {
                apz.app.EmploymentDetails.paint_pincode(parmObj);
            } else if (window.pincodetype === "aadPre") {
                apz.app.AddressDetails.paint_pincode(pincode_Detls);
            }
        }
    },
    getGeoCordinates: function () {
        // Using this to capture the user address co-ordinates
        navigator.geolocation.getCurrentPosition(ApzCOB.getGeoCordinatesSuccess, ApzCOB.getGeoCordinatesFail);
        ApzCOB.showLoader();
    },
    getGeoCordinatesSuccess: function (pos) {
        ApzCOB.hideLoader();
        window.currentGeoCords = pos.coords;
        if (!apz.isNull(window.currentGeoCords)) {
            $("#" + coOrdinateInputTag).val(`${window.currentGeoCords.latitude} N, ${window.currentGeoCords.longitude} E`);
            ApzCOB.removeErrMessgae(coOrdinateInputTag, "element");
        }
    },
    getGeoCordinatesFail: function (err) {
        ApzCOB.hideLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    },
    getGeoCordinatesMobile: function () {
        let gps = {};
        gps.id = "LOCATEUSER";
        gps.callBack = ApzCOB.getGeoCordinatesMobileCB;
        apz.ns.getLocation(gps);
        ApzCOB.showLoader();
    },
    getGeoCordinatesMobileCB: function (params) {
        ApzCOB.hideLoader();
        window.currentGeoCords = params;
        if (!apz.isNull(window.currentGeoCords)) {
            $("#" + coOrdinateInputTag).val(`${window.currentGeoCords.latitude} N, ${window.currentGeoCords.longitude} E`);
            ApzCOB.removeErrMessgae(coOrdinateInputTag, "element");
        }
    },
    getToggleOnClickEventObj: function (screenId) {
        let toggleButtons = $("#scr__" + screenId + "main").find(".grb.full-drop:not(.sno) .toggleForm");
        let evntList = [];
        toggleButtons.each((i, toggleItem) => {
            let eventObj = {};
            eventObj.toggleID = toggleItem.id;
            eventObj.toggleOnclick = $("#" + toggleItem.id).attr("onclick");
            evntList.push(eventObj);
            if (i > 1) {
                $("#" + toggleItem.id).removeAttr("onclick");
            }
        });
        window.toggleEvents = evntList;
    },
    addEventToNextToggle: function (currentIndex) {
        let nextToggleIndex = parseInt(currentIndex) + 1;
        if (!apz.isNull(window.toggleEvents[nextToggleIndex])) {
            let nextToggleList = window.toggleEvents[nextToggleIndex];
            $("#" + nextToggleList.toggleID).attr("onClick", nextToggleList.toggleOnclick);
        }
    },
    fnformValidator: function (screenId, formId) {
        window.errorCount = 0;
        let validationStatus;
        let form = "",
            form_validator_check = {};
        form = $(`#${screenId + formId}`).find(".input-field:not(.sno) input");
        for (let n = 0; n < form.length; n++) {
            form_validator_check = {
                [form[n]["id"]]: {
                    verify: nullcheck,
                    dropDown,
                    radiogroup,
                },
            };
            validationStatus = ApzCOB.validateInputFields(form, n, form_validator_check);
        }
        return validationStatus;
    },
    addErrMessage: function (fieldsItem, feildType) {
        if (feildType === "array") {
            $.map(fieldsItem, function (field) {
                $("#" + field).addClass("err");
                $("#" + field).parent().addClass("err");
                if ($("#" + field).closest("ul").next().hasClass("err-msg")) {
                    $("#" + field).closest("ul").next().removeClass("sno");
                } else {
                    $("#" + field).closest("ul").next().next().removeClass("sno");
                }
            });
        } else if (feildType === "element") {
            $("#" + fieldsItem).addClass("err");
            $("#" + fieldsItem).parent().addClass("err");
            if ($("#" + fieldsItem).closest("ul").next().hasClass("err-msg")) {
                $("#" + fieldsItem).closest("ul").next().removeClass("sno");
            } else {
                $("#" + fieldsItem).closest("ul").next().next().removeClass("sno");
            }
        }
    },
    removeErrMessgae: function (fieldsItem, feildType) {
        if (feildType === "array") {
            $.map(fieldsItem, function (field) {
                $("#" + field).removeClass("err");
                $("#" + field).parent().removeClass("err");
                if ($("#" + field).closest("ul").next().hasClass("err-msg")) {
                    $("#" + field).closest("ul").next().addClass("sno");
                } else {
                    $("#" + field).closest("ul").next().next().addClass("sno");
                }
            });
        } else if (feildType === "element") {
            $("#" + fieldsItem).removeClass("err");
            $("#" + fieldsItem).parent().removeClass("err");
            if ($("#" + fieldsItem).closest("ul").next().hasClass("err-msg")) {
                $("#" + fieldsItem).closest("ul").next().addClass("sno");
            } else {
                $("#" + fieldsItem).closest("ul").next().next().addClass("sno");
            }
        }
    },
    KycDedupeCheck: function (primaryKycID, callback) {
        window.isRPC = isRPCLogin;
        let callbackFn = callback || ApzCOB.KycDedupeCheckCB;
        let customerType = isRPC ? (custType === 'Applicant' ? 1 : 2) : gApzCOB.currentApplicant;
        let applicationID = isRPC ? inSessionStore?.applicationMaster?.applicationId : gApzCOB.requestNodes?.applicationId || "";
        let customerId = isRPC ? inSessionStore?.applicationMaster?.memberId : gApzCOB.selLeadDtls?.customerId;
        let kycObj = {
            kycType: "voter",
            kycId: primaryKycID,
            customerType,
            applicationId: applicationID,
            customerId: Number(customerId),
        };
        let req = {
            apiRequest: {
                interfaceName: "DedupeVoterID",
                requestObj: kycObj,
            },
        };
        ApzCOB.showLoader();
        ApzCOB.serverBuildParam(gAppId, "DedupeVoterID", "N", "N", req, false, callbackFn);
    },
    KycDedupeCheckCB: function (params) {
        let responseObj = {};
        if (!apz.isNull(params.res.APZCBO__DedupeVoterID_Res.apiResponse)) {
            responseObj = params.res.APZCBO__DedupeVoterID_Res.apiResponse.ResponseHeader;
        }
        try {
            ApzCOB.hideLoader();
            if (ApzCOB.handleServiceCallBacks(params)) {
                if (gApzCOB.currentApplicant <= 1) {
                    if (IS_ALTERNATE_DEDUPE) {
                        ALTERNATE_DEDUPE_STATUS = true;
                    } else {
                        PRIMARY_DEDUPE_STATUS = true;
                    }
                } else {
                    if (IS_CO_APPLICANT_ALTERNATE_DEDUPE) {
                        CO_APPLICANT_ALTERNATE_DEDUPE_STATUS = true;
                    } else {
                        CO_APPLICANT_PRIMARY_DEDUPE_STATUS = true;
                    }
                }
            } else {
                if (gApzCOB.currentApplicant <= 1) {
                    if (IS_ALTERNATE_DEDUPE) {
                        ALTERNATE_DEDUPE_STATUS = false;
                    } else {
                        PRIMARY_DEDUPE_STATUS = false;
                    }
                } else {
                    if (IS_CO_APPLICANT_ALTERNATE_DEDUPE) {
                        CO_APPLICANT_ALTERNATE_DEDUPE_STATUS = false;
                    } else {
                        CO_APPLICANT_PRIMARY_DEDUPE_STATUS = false;
                    }
                }
            }
        } catch (e) {
            ApzCOB.hideLoader();
            ApzCOB.fnDisplayMsg(responseObj.ResponseMessage, "E");
        }
        if (gApzCOB.currentApplicant <= 1) {
            let rejectMsg = ". " + ApzCOB.getDescfromLitCode("LIT_COMM_APPLICANT_CONF_TXT_DEDUPE_FAILED_DO_WANT_TO_CONTINUE");
            if (!IS_ALTERNATE_DEDUPE) {
                if (!PRIMARY_DEDUPE_STATUS) {
                    ApzCOB.fnDisplayMsg(responseObj.ResponseMessage + rejectMsg, "C", apz.app.PersonalDetails
                        .dedupeServiceConfirmApplicantCB);
                    return;
                }
            } else {
                if (!ALTERNATE_DEDUPE_STATUS) {
                    ApzCOB.fnDisplayMsg(responseObj.ResponseMessage + rejectMsg, "C", apz.app.PersonalDetails
                        .dedupeServiceConfirmApplicantCB);
                }
            }
            if (IS_ALTERNATE_DEDUPE && ALTERNATE_DEDUPE_STATUS) {
                let kycObj = {};
                kycObj.kycType = "voter";
                kycObj.kycId = $("#" + altVoterIdTag).val().trim();
                ApzCOB.kycVerificationCheck(kycObj);
            } else if (IS_APPLICANT_PRIMARY_DEDUPE && PRIMARY_DEDUPE_STATUS) {
                let kycObj = {};
                kycObj.kycType = "voter";
                kycObj.kycId = $("#" + PerDetScrId + "voterId").val().trim();
                ApzCOB.kycVerificationCheck(kycObj);
            }
        } else {
            let coAppDedupeStatus = true;
            if (!IS_CO_APPLICANT_ALTERNATE_DEDUPE) {
                if (!CO_APPLICANT_PRIMARY_DEDUPE_STATUS) {
                    coAppDedupeStatus = false;
                }
            } else {
                if (!CO_APPLICANT_ALTERNATE_DEDUPE_STATUS) {
                    coAppDedupeStatus = false;
                }
            }
            if (!coAppDedupeStatus) {
                window.RejectReason = `Co-Applicant(C0${CO_APP_ADDED_COUNT}) Dedupe Check Failed.`;
                if (CO_APP_ADDED_COUNT >= gApzCOB.noOfApplicants) {
                    ApzCOB.toggleModal(PerDetScrId + "dedupeCheckReject");
                } else {
                    $("#" + PerDetScrId + "dedupeRejectLabel").text(responseObj.ResponseMessage);
                    ApzCOB.toggleModal(PerDetScrId + "dedupeRejectOrAddmodel");
                }
            }
            if (IS_CO_APPLICANT_ALTERNATE_DEDUPE && CO_APPLICANT_ALTERNATE_DEDUPE_STATUS) {
                let kycObj = {};
                kycObj.kycType = "voter";
                kycObj.kycId = $("#" + altVoterIdTag).val().trim();
                ApzCOB.kycVerificationCheck(kycObj);
            } else if (IS_CO_APPLICANT_PRIMARY_DEDUPE && CO_APPLICANT_PRIMARY_DEDUPE_STATUS) {
                let kycObj = {};
                kycObj.kycType = "voter";
                kycObj.kycId = $("#" + PerDetScrId + "voterId").val().trim();
                ApzCOB.kycVerificationCheck(kycObj);
            }
        }
    },
    bankAccountDedupeCheck: function () {
        let bankAccNo = '';
        window.isRPC = isRPCLogin;
        let appAccNo = ApzCOB.getPayloadDatafromWrapper("accountNumber", 'Applicant', 'bankDetailsWrapperList');
        if ($('#DBkitG__eNach__accountNumber').next('.err').length == 1) {
            return;
        }
        if (!isRPC && apz.currAppId !== 'DBkitG') {
            bankAccNo = $('#' + EmpDetscrId + `accNumber`).val();
        } else if (isRPC) {
            bankAccNo = $(`#RPC__BankAccountProofRPC__accountNumberInput`).val();
            if (apz.isNull(bankAccNo)) {
                ApzCOB.fnDisplayMsg("Please Enter Account number", "E");
                $(`#${bankScrnId}rpcverifyAccount`).addClass('sno');
                return;
            }
        } else if (apz.currAppId == 'DBkitG') {
            bankAccNo = $(`#DBkitG__eNach__accountNumber`).val();
            if (apz.isNull(bankAccNo)) {
                ApzCOB.fnDisplayMsg("Please Enter Account number", "E");
                $("#" + DBkitG__eNach__ + "verifyACC").addClass('sno');
                return;
            }
            if (appAccNo == bankAccNo) {
                ApzCOB.fnDisplayMsg("Applicant and co-applicant account numbers should not be the same.", "E");
                $('#DBkitG__eNach__accountNumber').val('');
                $("#" + DBkitG__eNach__ + "verifyACC").addClass('sno');
                return;
            }
        }
        let callbackFn = ApzCOB.bankAccountDedupeCheckCB;
        // let customerType = (custType === 'Applicant') ? 1 : 2;
        let customerType = 1;
        let applicationID = gApzCOB.requestNodes?.applicationId || inSessionStore?.applicationMaster?.applicationId || "";
        let customerId = inSessionStore?.applicationMaster?.memberId || gApzCOB.selLeadDtls?.customerId;
        let kycObj = {
            kycType: "bankAcc",
            kycId: bankAccNo,
            customerType,
            applicationId: applicationID,
            customerId: Number(customerId),
        };
        let req = {
            apiRequest: {
                interfaceName: "DedupeVoterID",
                requestObj: kycObj,
            },
        };
        ApzCOB.showLoader();
        ApzCOB.serverBuildParam(gAppId, "DedupeVoterID", "N", "N", req, false, callbackFn);
    },
    bankAccountDedupeCheckCB: function (params) {
        apz.stopLoader();
        let responseObj = {};
        if (!apz.isNull(params.res.APZCBO__DedupeVoterID_Res.apiResponse)) {
            responseObj = params.res.APZCBO__DedupeVoterID_Res.apiResponse.ResponseHeader;
        }
        try {
            ApzCOB.hideLoader();
            window.dedupeAccerrMsg = responseObj;
            window.bankDeduperes = JSON.parse(JSON.parse(params.res.APZCBO__DedupeVoterID_Res.apiResponse.ResponseBody.responseObj).responseObj);
            window.coAppverified = false;
            if (ApzCOB.handleServiceCallBacks(params)) {
                if (responseObj.ResponseCode == 0) {
                    if (!isRPC && apz.currAppId !== 'DBkitG') {
                        $("#" + EmpDetscrId + "verifyAccount").addClass("sno");
                        $("#" + EmpDetscrId + "accountVerified_ul").removeClass("sno");
                        window.accisVerified = true;
                        window.accIsvalid = 'Verified';
                        window.rejectverifiedflag = true;
                        window.accvalidationCheck = true;
                        ApzCOB.removeDisableToInput('APZCBO__BaseScreens__continue');
                    } else if (isRPC) {
                        $(`#RPC__${RPC_CURRENT_STAGE}__rpcverifyAccount`).addClass("sno");
                        $(`#RPC__${RPC_CURRENT_STAGE}__rpcaccountVerified`).removeClass("sno");
                        $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).removeClass('sno');
                        $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('suc');
                        window.accIsvalid = 'Verified';
                        if ($(`#RPC__${RPC_CURRENT_STAGE}__editBankDetailsInput_option_1`).is(":checked")) {
                            $("#RPC__RPCFooter__el_btn_2").attr("disabled", false);
                            $("#RPC__RPCFooter__el_btn_2").removeClass("disabled");
                        }
                    } else if (apz.currAppId == 'DBkitG') {
                        $("#" + scrId + "verifyACC").addClass('sno');
                        $("#" + scrId + "bankACCVerified").removeClass("sno");
                        $("#" + scrId + "verifiedAcc").removeClass('sno');
                        $("#" + scrId + "verifiedAcc").addClass('suc');
                        window.coAppaccStatus = 'Verified';
                        window.coAppverified = 'true';
                    }
                } else if (responseObj.ResponseCode !== 0) {
                    if (!isRPC && apz.currAppId !== 'DBkitG') {
                        $("#" + EmpDetscrId + "verifyAccount").addClass("sno");
                        $("#" + EmpDetscrId + "invaildAccount_ul").removeClass("sno");
                        window.accisVerified = false;
                        window.accIsvalid = 'Failed';
                        window.rejectverifiedflag = false;
                        window.accvalidationCheck = false;
                        // $("#APZCBO__BaseScreens__continue").attr("disabled", true);
                        ApzCOB.addDisableToInput('APZCBO__BaseScreens__continue');
                    } else if (isRPC) {
                        $(`#RPC__${RPC_CURRENT_STAGE}__rpcverifyAccount`).addClass("sno");
                        $(`#RPC__${RPC_CURRENT_STAGE}__rpcinvaildAccount`).removeClass("sno");
                        $(`#RPC__${RPC_CURRENT_STAGE}__invalidAcc`).removeClass('sno');
                        $(`#RPC__${RPC_CURRENT_STAGE}__invalidAcc`).addClass('failed');
                        window.accIsvalid = 'Failed';
                        if ($(`#RPC__${RPC_CURRENT_STAGE}__editBankDetailsInput_option_1`).is(":checked")) {
                            $("#RPC__RPCFooter__el_btn_2").attr("disabled", true);
                            $("#RPC__RPCFooter__el_btn_2").addClass("disabled");
                        }
                    } else if (apz.currAppId == 'DBkitG') {
                        $("#" + scrId + "verifyACC").addClass('sno');
                        $("#" + scrId + "InvaildBankACC").removeClass("sno");
                        $("#" + scrId + "invalidAcc").removeClass('sno');
                        $("#" + scrId + "invalidAcc").addClass('failed');
                        window.coAppaccStatus = 'Failed';
                        window.coAppverified = 'true';
                    }
                }
            }
        } catch (e) {
            ApzCOB.hideLoader();
            if (params.res.APZCBO__DedupeVoterID_Res.status == 500) {
                ApzCOB.fnDisplayMsg(params.res.APZCBO__DedupeVoterID_Res.error, "E");
            } else {
                ApzCOB.dedupeAccfailure(dedupeAccerrMsg);
            }
        }
    },
    dedupeAccfailure: function (errmsg) {
        if (errmsg.hasOwnProperty("ErrorCode")) {
            if (!isRPC && apz.currAppId !== 'DBkitG') {
                $("#" + EmpDetscrId + "rejectLabel").text(errmsg.ResponseMessage + 'Do you want to reject this application?');
                ApzCOB.toggleModal(EmpDetscrId + "rejectmodel");
            } else if (isRPC) {
                let confrmTxt = `${errmsg.ResponseMessage}. <br/> Would you like to reject the application?`;
                let popUpObj = {};
                popUpObj.text = confrmTxt;
                popUpObj.Btn1 = {
                    "text": "Yes",
                    "onClick": "apz.app.RPCFooter.approveReject(this,'REJECTED')"
                }
                popUpObj.Btn2 = {
                    "text": "No",
                    "onClick": "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()"
                }
                ApzCOB.showRpcModals(popUpObj, "confirmation");
            } else if (apz.currAppId == 'DBkitG') {
                let confrmTxt = `${errmsg.ResponseMessage}. <br/> Would you like to reject the application?`;
                let popUpObj = {};
                popUpObj.text = confrmTxt;
                popUpObj.Btn1 = {
                    "text": "Yes",
                    "onClick": "apz.app.DBbase.Stagemoment(this,'REJECTED')"
                }
                popUpObj.Btn2 = {
                    "text": "No",
                    "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`)"
                }
                ApzCOB.showNewCommonConfirmationModal(popUpObj);
            }
        } else {
            ApzCOB.fnDisplayMsg(errmsg.ResponseMessage, "E");
            if (isRPC) {
                $("#RPC__RPCFooter__el_btn_2").attr("disabled", true);
                $("#RPC__RPCFooter__el_btn_2").addClass("disabled");
            }
        }
    },
    validateEachInputField: function (element) {
        let inputValue = $("#" + element).val().trim();
        let isValid;
        let parentDiv = $("#" + element).parent().get(0);
        if (parentDiv.tagName === "DIV") {
            let checkDropdown = dropDown(inputValue);
            if (checkDropdown > 0) {
                isValid = false;
                $("#" + parentDiv.id).addClass("err");
                $("#" + parentDiv.id).closest("ul").next().removeClass("sno");
            } else {
                isValid = true;
                $("#" + parentDiv.id).removeClass("err");
                $("#" + parentDiv.id).closest("ul").next().addClass("sno");
            }
        } else if (parentDiv.tagName === "SPAN") {
            if (apz.isNull(inputValue)) {
                isValid = false;
                $("#" + element).addClass("err");
                $("#" + element).closest("ul").next().removeClass("sno");
            } else {
                isValid = true;
                $("#" + element).removeClass("err");
                $("#" + element).closest("ul").next().addClass("sno");
            }
        }
        return isValid;
    },
    kycVerificationCheck: function (kycObj, callBack) {
        let callBackFn = callBack || ApzCOB.kycVerificationCheckCB;
        let req = {
            apiRequest: {
                interfaceName: "ValidateVoterID",
                requestObj: kycObj,
            },
        };
        ApzCOB.showLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "ValidateVoterID", "N", "N", req, false, callBackFn);
        }, 1000);
    },
    kycVerificationCheckCB: function (params) {
        ApzCOB.hideLoader();
        ApzCOB.removeErrMessgae(PerDetScrId + "nameasKYC", "element");
        let errMsg = "";
        if (!apz.isNull(params.resFull.appzillonBody.APZCBO__ValidateVoterID_Res)) {
            if (!apz.isNull(params.resFull.appzillonBody.APZCBO__ValidateVoterID_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = ApzCOB.getDescfromLitCode("LIT_KYC_VERIFICATION_SERVICE_FAILED") + "<br/>" + params.resFull.appzillonBody
                    .APZCBO__ValidateVoterID_Res.apiResponse.ResponseHeader.ResponseMessage;
            }
        } else {
            errMsg = ApzCOB.getDescfromLitCode("LIT_KYC_VERIFICATION_SERVICE_FAILED");
        }
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let responseObj = JSON.parse(params.res.APZCBO__ValidateVoterID_Res.apiResponse.ResponseBody.responseObj);
                if (responseObj.hasOwnProperty("result_code") && responseObj.result_code === 101) {
                    if (window.kycVerificationType === "primary") {
                        if (gApzCOB.currentApplicant <= 1) {
                            PRIMARY_KYC_VERIFICATION = true;
                        } else {
                            CO_APPLICANT_PRIMARY_KYC_VERIFICATION = true;
                        }
                        $(`#${PerDetScrId}nameasKYC`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}nameasKYC`, responseObj.result.name ?? ""));
                        $("#" + PerDetScrId + "primaryKycVerifyBtn_ul").addClass("sno");
                        $("#" + PerDetScrId + "primaryKycFailedTxt_ul").addClass("sno");
                        $("#" + PerDetScrId + "primaryKycVerifiedTxt_ul").removeClass("sno");
                        ApzCOB.removeFieldMandatory(altVoterIdTag);
                    } else if (window.kycVerificationType === "alternate") {
                        if (gApzCOB.currentApplicant <= 1) {
                            ALTERNATE_KYC_VERIFICATION = true;
                        } else {
                            CO_APPLICANT_ALTERNATE_KYC_VERIFICATION = true;
                        }
                        $(`#${PerDetScrId}nameasKYC`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}nameasKYC`, responseObj.result.name ?? ""));
                        $("#" + PerDetScrId + "altVoterVerifyBtn_ul").addClass("sno");
                        $("#" + PerDetScrId + "altVoterFailTxt_ul").addClass("sno");
                        $("#" + PerDetScrId + "altVoterVerifiedTxt_ul").removeClass("sno");
                    } else {
                        if (gApzCOB.currentApplicant <= 1) {
                            SECONDARY_KYC_VERIFICATION = true;
                        } else {
                            CO_APPLICANT_SECONDARY_KYC_VERIFICATION = true;
                        }
                        $("#" + PerDetScrId + "secondaryKycVerifyBtn_ul").addClass("sno");
                        $("#" + PerDetScrId + "secondaryKycFailTxt_ul").addClass("sno");
                        $("#" + PerDetScrId + "secondaryKycVerifiedTxt_ul").removeClass("sno");
                    }
                } else {
                    let invalidKyc = false;
                    if (responseObj.hasOwnProperty("error")) {
                        if (responseObj.error.message === ApzCOB.getDescfromLitCode("LIT_EPICNUMBER")) {
                            invalidKyc = true;
                        } else {
                            invalidKyc = false;
                        }
                    } else {
                        invalidKyc = true;
                    }
                    if (invalidKyc) {
                        if (window.kycVerificationType === "primary") {
                            if (gApzCOB.currentApplicant <= 1) {
                                window.PRIMARY_KYC_VERIFICATION = false;
                                window.IS_APP_PRIMARY_CHECK_FAILED = true;
                            } else {
                                window.CO_APPLICANT_PRIMARY_KYC_VERIFICATION = false;
                                window.IS_COAPP_PRIMARY_CHECK_FAILED = true;
                            }
                            $("#" + PerDetScrId + "nameasKYC").val("");
                            $("#" + PerDetScrId + "primaryKycVerifyBtn_ul").addClass("sno");
                            $("#" + PerDetScrId + "primaryKycVerifiedTxt_ul").addClass("sno");
                            $("#" + PerDetScrId + "primaryKycFailedTxt_ul").removeClass("sno");
                            ApzCOB.addFieldMandatory(altVoterIdTag);
                        } else if (window.kycVerificationType === "alternate") {
                            if (gApzCOB.currentApplicant <= 1) {
                                window.ALTERNATE_KYC_VERIFICATION = false;
                                window.IS_APP_ALTERNATE_CHECK_FAILED = true;
                            } else {
                                window.CO_APPLICANT_ALTERNATE_KYC_VERIFICATION = false;
                                window.IS_COAPP_ALTERNATE_CHECK_FAILED = true;
                            }
                            $("#" + PerDetScrId + "altVoterVerifyBtn_ul").addClass("sno");
                            $("#" + PerDetScrId + "altVoterVerifiedTxt_ul").addClass("sno");
                            $("#" + PerDetScrId + "altVoterFailTxt_ul").removeClass("sno");
                        } else {
                            if (gApzCOB.currentApplicant <= 1) {
                                window.SECONDARY_KYC_VERIFICATION = false;
                            } else {
                                window.CO_APPLICANT_SECONDARY_KYC_VERIFICATION = false;
                            }
                            $("#" + PerDetScrId + "secondaryKycVerifyBtn_ul").addClass("sno");
                            $("#" + PerDetScrId + "secondaryKycVerifiedTxt_ul").addClass("sno");
                            $("#" + PerDetScrId + "secondaryKycFailTxt_ul").removeClass("sno");
                        }
                        if (gApzCOB.currentApplicant <= 1) {
                            if (IS_APP_PRIMARY_CHECK_FAILED && IS_APP_ALTERNATE_CHECK_FAILED) {
                                window.RejectReason = "Applicant KYC Verification Failed.";
                                if (apz.isNull(gApzCOB.requestNodes.applicationId)) {
                                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_CONF_TXT_APP_KYC_VERIFICATION_FAILED_REJ_CONFRM"),
                                        "E", ApzCOB.applicantKycFailedRejectService);
                                } else {
                                    $("#" + PerDetScrId + "rejectLabel").text(ApzCOB.getDescfromLitCode(
                                        "LIT_COMM_CONF_TXT_APP_KYC_VERIFICATION_FAILED_REJ_CONFRM"));
                                    ApzCOB.toggleModal(PerDetScrId + "rejectmodel");
                                }
                            } else {
                                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_INVALID_KYC_ID"), "E");
                            }
                        } else {
                            if (IS_COAPP_PRIMARY_CHECK_FAILED && IS_COAPP_ALTERNATE_CHECK_FAILED) {
                                window.RejectReason = `Co-Applicant(C0${CO_APP_ADDED_COUNT}) KYC Verification Failed.`;
                                if (CO_APP_ADDED_COUNT >= gApzCOB.noOfApplicants) {
                                    $("#" + PerDetScrId + "rejectLabel").text(ApzCOB.getDescfromLitCode(
                                        "LIT_COMM_CONF_TXT_CO_APP_KYC_VERIFICATION_FAILED_REJ_CONFRM"));
                                    ApzCOB.toggleModal(PerDetScrId + "rejectmodel");
                                } else {
                                    $("#" + PerDetScrId + "dedupeRejectLabel").text(ApzCOB.getDescfromLitCode(
                                        "LIT_COMM_CONF_TXT_PRIMARY_ALTERNATE_VERIFICATION_FAILED"));
                                    ApzCOB.toggleModal(PerDetScrId + "dedupeRejectOrAddmodel");
                                }
                            } else {
                                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_INVALID_KYC_ID"), "E");
                            }
                        }
                    } else {
                        errMsg = ApzCOB.getDescfromLitCode("LIT_KYC_VERIFICATION_SERVICE_FAILED");
                        if (responseObj.hasOwnProperty("errorDescription")) {
                            errMsg = errMsg + "<br>" + responseObj.errorDescription;
                        } else if (responseObj.error.hasOwnProperty("message")) {
                            errMsg = errMsg + "<br>" + responseObj.error.message;
                        }
                        ApzCOB.fnDisplayMsg(errMsg, "E");
                    }
                }
            } else {
                ApzCOB.hideLoader();
                ApzCOB.fnDisplayMsg(errMsg, "E");
            }
        } catch (e) {
            ApzCOB.hideLoader();
            ApzCOB.fnDisplayMsg(errMsg, "E");
        }
    },
    getKycVerificationType: function (kycType) {
        let verificationKycType = "";
        switch (kycType) {
            case "Voter ID":
                verificationKycType = "voter";
                break;
            case "PAN":
                verificationKycType = "pan";
                break;
            case "Driving Licence":
                verificationKycType = "drivingLicense";
                break;
            case "Passport number":
                verificationKycType = "passport";
                break;
            default:
                break;
        }
        return verificationKycType;
    },
    addFieldMandatory: function (elementIds) {
        if (Array.isArray(elementIds)) {
            elementIds.forEach((elem) => {
                const $el = $("#" + elem);
                if ($el.attr("type") === "radio") {
                    $el.parents().eq(6).find("label.pri").eq(0).addClass("req");
                    $el.parents().eq(1).addClass("mand");
                } else {
                    $el.addClass("mand");
                    $el.parents().eq(5).find("label.pri").eq(0).addClass("req");
                }
            });
        } else {
            if ($("#" + elementIds).attr("type") === "radio") {
                $("#" + elementIds).parents().eq(6).find("label.pri").eq(0).addClass("req");
                $("#" + elementIds).parents().eq(1).addClass("mand");
            } else {
                $("#" + elementIds).parents().eq(5).find("label.pri").eq(0).addClass("req");
                $("#" + elementIds).addClass("mand");
            }
        }
    },
    removeFieldMandatory: function (elementIds) {
        if (Array.isArray(elementIds)) {
            elementIds.forEach((elem) => {
                const $el = $("#" + elem);
                $el.removeClass("mand");
                $el.parents().eq(5).find("label.pri").eq(0).removeClass("req");
                $el.parents().eq(5).find(".err-msg").addClass("sno");
                $el.removeClass("err");
            });
        } else {
            $("#" + elementIds).removeClass("mand");
            $("#" + elementIds).parents().eq(5).find("label.pri").eq(0).removeClass("req");
            $("#" + elementIds).parents().eq(5).find(".err-msg").addClass("sno");
            $("#" + elementIds).removeClass("err");
        }
    },
    AddOrRemoveDisableFields: function (elements, setType) {
        elements.map((elem) => {
            $(`#${elem}`).attr("disabled", setType);
            $(`#${elem}`).parent().attr("disabled", setType);
            if (setType == true) {
                $(`#${elem}`).addClass("disabled");
                $(`#${elem}`).attr("readonly");
                $(`#${elem}`).parent().addClass("select-disabled");
            } else {
                $(`#${elem}`).removeClass("disabled");
                $(`#${elem}`).removeAttr("readonly");
                $(`#${elem}`).parent().removeClass("select-disabled");
            }
        });
    },
    getAge: function (dob) {
        let dobVal = dob.split("/").reverse().join("-").replaceAll("/", "-");
        let today = new Date();
        let dobValDate = new Date(dobVal);
        let age = today.getFullYear() - dobValDate.getFullYear();
        let month = today.getMonth() - dobValDate.getMonth();
        if (month < 0 || (month === 0 && today.getDate() < dobValDate.getDate())) {
            age--;
        }
        return age === -1 ? 0 : age;
    },
    dobValidation: function (pthis) {
        let age = $(pthis).val();
        minAge = apz.isNull(minAge) ? 22 : minAge;
        maxAge = apz.isNull(maxAge) ? 60 : maxAge;
        let msg = `Please select valid age(min:${minAge},max:${maxAge})`;
        if (!(parseInt(age) >= minAge && parseInt(age) < maxAge)) {
            $(pthis).val("");
            if (isRPCLogin) {
                $('#RPC__PrimaryKycRPC__dobInput').val('')
                ApzCOB.showRpcModals({
                    text: msg,
                    Btn1: {
                        text: "OK",
                        onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
                    }
                }, "Error");
            } else {
                window.age = true;
                ApzCOB.fnDisplayMsg(msg, "E");
            }
        } else {
            window.age = false;
        }
    },
    removeFormInputDisable: function (formId) {
        let formArray = $("#" + formId).find(".input-field:not(.sno) input");
        formArray.map((element, elemId) => {
            $("#" + elemId.id).removeAttr("disabled");
            $("#" + elemId.id).removeClass("disabled");
            $("#" + elemId.id).removeAttr("readonly");
            $("#" + elemId.id).parent().removeAttr("disabled");
            $("#" + elemId.id).parent().removeClass("select-disabled");
        });
    },
    showLoader: function () {
        $("#apzloader").removeClass("sno");
    },
    hideLoader: function () {
        $("#apzloader").addClass("sno");
    },
    validateSecondaryKycIfEntered: function () {
        let secKycType = dropDown($("#" + secondaryKycTypeTagId).val());
        let secKycID = $("#" + secondaryKycIdTag).val();
        let valid = false;
        if (secKycType === 0 || !apz.isNull(secKycID)) {
            if (gApzCOB.currentApplicant <= 1) {
                if (SECONDARY_KYC_VERIFICATION) {
                    valid = true;
                }
            } else {
                if (CO_APPLICANT_SECONDARY_KYC_VERIFICATION) {
                    valid = true;
                }
            }
        } else {
            valid = true;
        }
        if (!valid) {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_SEC_KYC_ENTERED_NOT_VERIFIED"), "E");
        }
        return valid;
    },
    validateAlterVoterIfEntered: function () {
        let alterVoterID = $("#" + PerDetScrId + "altVoterId").val().trim();
        let valid = false;
        if (!apz.isNull(alterVoterID)) {
            if (gApzCOB.currentApplicant <= 1) {
                if (ALTERNATE_KYC_VERIFICATION) {
                    valid = true;
                }
            } else {
                if (CO_APPLICANT_ALTERNATE_KYC_VERIFICATION) {
                    valid = true;
                }
            }
        } else {
            valid = true;
        }
        if (!valid) {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_ALT_VOTER_ENTERED_NOT_VERIFIED"), "E");
        }
        return valid;
    },
    getStageInfo: function () {
        let stageData = {};
        stageData.STAGE_NO = STAGE_NO;
        stageData.PREV_STAGE_NO = PREV_STAGE_NO;
        stageData.CURRENT_STAGE_NO = CURRENT_STAGE_NO;
        stageData.CURRENT_STAGE_NAME = CURRENT_STAGE_NAME;
        stageData.currRow = currRow;
        stageData.baseRow = baseRow;
        stageData.prevRow = prevRow;
        console.log(stageData);
    },
    updateStepperStage: function () {
        $(".left-menu-stepper .wrapped").removeClass("inprogress");
        $(".left-menu-stepper .wrapped").removeClass("completed");
        let stagesMenuArray = [];
        $("#APZCBO__BaseScreens__menuStepper").find(".step-number-row").map((step, id) => {
            let stepperId = $(id).attr("id").split("APZCBO__BaseScreens__stepper")[1].split("_row")[0];
            stagesMenuArray.push(stepperId);
        });
        if (CURRENT_STAGE_NO >= 3 && CURRENT_STAGE_NO <= 11) {
            inprogressArray[0] = CURRENT_STAGE_NO;
            completeArray.forEach((completeID) => {
                const $row = $("#APZCBO__BaseScreens__stepper" + completeID + "_row").parent().parent();
                $row.removeClass("inprogress").addClass("completed");
            });
            inprogressArray.forEach((inProgId) => {
                const $row = $("#APZCBO__BaseScreens__stepper" + inProgId + "_row").parent().parent();
                $row.removeClass("completed").addClass("inprogress");
            });
            $("#sidebar").removeClass("sno");
        } else {
            $("#sidebar").addClass("sno");
        }
    },
    dropDownOnChange: function (pthis) {
        let inputID = pthis.id;
        $("#" + inputID + "_div").find("li").removeClass("is-selected hilt");
        $("#" + inputID + '_div li[data-value="' + $("#" + inputID).val() + '"]').addClass("is-selected hilt");
    },
    addDisableToInput: function (inputID) {
        $("#" + inputID).attr("disabled", true);
        $("#" + inputID).addClass("disabled");
        $("#" + inputID).attr("readonly");
        $("#" + inputID).parent().attr("disabled", true);
        $("#" + inputID).parent().addClass("select-disabled");
    },
    removeDisableToInput: function (inputID) {
        $("#" + inputID).attr("disabled", false);
        $("#" + inputID).removeClass("disabled");
        if (!$("#" + inputID).parent().hasClass("etb-slct")) {
            $("#" + inputID).removeAttr("readonly");
        }
        $("#" + inputID).parent().attr("disabled", false);
        $("#" + inputID).parent().removeClass("select-disabled");
    },
    hideDropDownArrow: function (elementID) {
        $("#" + screenId + elementID + "_span").addClass("sno");
    },
    fnGetImageSize: function (base6gString) {
        const binaryString = atob(base6gString);
        const fileSizeInBytes = binaryString.length;
        const fileSizeInKilobytes = fileSizeInBytes / 1024;
        const fileSizeInMegabytes = fileSizeInKilobytes / 1024;
        let ImageSize = parseInt(fileSizeInKilobytes);
        return ImageSize;
    },
    inProgresssStageMapping: function (nextStageId, currentScreen) {
        IS_SERVICE_CALLBACK = false;
        let currentStageNo = "";
        if (!apz.isNull(gApzCOB.requestNodes.applicationMaster.currentStageNo)) {
            currentStageNo = gApzCOB.requestNodes.applicationMaster.currentStageNo;
            STAGES.map((stage) => {
                if (parseInt(stage.split("~")[1]) <= currentStageNo) {
                    UPDATED_STAGES.push(stage);
                }
            });
            UPDATED_STAGES.map((upStage) => {
                if (parseInt(upStage.split("~")[1]) >= 3) {
                    completeArray.push(upStage.split("~")[1]);
                }
            });
            let nextStageName = STAGES.filter(
                (stage) => parseInt(stage.split("~")[1]) === STAGE_NO)[0].split("~")[0];
            let stageOccuranceCheck = UPDATED_STAGES.filter(
                (upStage) => upStage.split("~")[0] === nextStageName);
            if (stageOccuranceCheck.length > 0) {
                if (gApzCOB.currentApplicant < gApzCOB.noOfApplicants) {
                    gApzCOB.currentApplicant++;
                }
            } else {
                gApzCOB.currentApplicant = 1;
            }
        }
    },
    gettheRequestData: function (screenName) {
        let applicationResponse = inSessionStore;
        let result = 1;
        if (!apz.isNull(applicationResponse)) {
            switch (screenName) {
                case "CUSTOMERDETAILS":
                    result = applicationResponse.customerDetailsList.length;
                    break;
                case "LOANDETAILS":
                    if (!apz.isNull(applicationResponse.cibilDetailsWrapperList)) {
                        result = applicationResponse.cibilDetailsWrapperList.length;
                    }
                    break;
                case "OCCUPATIONDETAILS":
                    result = applicationResponse.occupationDetailsWrapperList.length;
                    break;
                case "UPLOADDOCUMENTS":
                    let customerIds = [];
                    if (applicationResponse.applicationDocumentsWrapperList[0].applicationDocumentsList.length > 0) {
                        applicationResponse.applicationDocumentsWrapperList[0].applicationDocumentsList.map(
                            (docs) => {
                                if (!customerIds.includes(docs.custDtlId)) {
                                    customerIds.push(docs.custDtlId);
                                }
                            });
                        result = customerIds.length;
                    }
                    break;
                default:
                    break;
            }
        }
        return result;
    },
    handleDocumentsSessionStore: function () {
        if (!apz.isNull(inSessionStore.customerDetailsList)) {
            let applicantData = inSessionStore.customerDetailsList.filter(
                (inCust) => inCust.customerType === "Applicant");
            let applicantID = "";
            if (applicantData.length > 0) {
                applicantID = applicantData[0].custDtlId;
            }
            let CoApplicantData = inSessionStore.customerDetailsList.filter(
                (inCust) => inCust.customerType !== "Applicant");
            let CoApplicantID = "";
            if (CoApplicantData.length > 0) {
                CoApplicantID = CoApplicantData[0].custDtlId;
            }
            let applicantDocList = [];
            let CoApplicantDocList = [];
            if (inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.length > 0) {
                let documentsData = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
                let applicantDocList = documentsData.filter(
                    (doc) => doc.custDtlId === applicantID);
                if (!apz.isNull(CoApplicantID)) {
                    CoApplicantDocList = documentsData.filter(
                        (doc) => doc.custDtlId === CoApplicantID);
                }
                window.inSessionStore.applicationDocumentsWrapperListSess = [];
                if (applicantDocList.length > 0) {
                    window.inSessionStore.applicationDocumentsWrapperListSess[0] = ApzCOB.createDocumentCustSession(applicantDocList);
                }
                if (CoApplicantDocList.length > 0) {
                    window.inSessionStore.applicationDocumentsWrapperListSess[1] = ApzCOB.createDocumentCustSession(CoApplicantDocList);
                }
            }
        }
    },
    createDocumentCustSession: function (docsArray) {
        window.documentProofSessionObj = {};
        let docEmptyArray = [];
        if (!apz.isNull(docMaxAndMand)) {
            if (docMaxAndMand.length > 0) {
                docMaxAndMand.forEach((docMax) => {
                    let emptyArray = [];
                    window.documentProofSessionObj[docMax.key] = emptyArray;
                });
            }
        }
        let docs = docsArray;
        for (let i = 0; i < docs.length; i++) {
            let docPayload = JSON.parse(docs[i]["payload"]);
            if (docPayload.screenId === "UploadDocuments") {
                let newDocType = ApzCOB.docOldNewMapping(docPayload);
                if (!apz.isNull(newDocType)) {
                    var localObj = {
                        filename: docPayload.documentFileName,
                        filetype: docPayload.documentFormat,
                        filelocation: docPayload.documentLoc,
                        docType: newDocType,
                        docSide: docPayload.docSide,
                        docName: docPayload.documentName,
                        appDocId: docs[i]["appDocId"],
                        isAdiDoc: docPayload.isAdiDoc,
                        docLevel: !apz.isNull(docPayload.docLevel) ? parseInt(docPayload.docLevel) : documentProofSessionObj[newDocType]
                            .length + 1,
                        longitude: !apz.isNull(docPayload.longitude) ? docPayload.longitude : "",
                        latitude: !apz.isNull(docPayload.latitude) ? docPayload.latitude : "",
                        uploadedTs: !apz.isNull(docPayload.uploadedTs) ? docPayload.uploadedTs : "",
                    };
                    documentProofSessionObj[newDocType].push(localObj);
                }
                documentProofSessionObj[newDocType]?.sort(
                    (doc1, doc2) => doc1.docLevel - doc2.docLevel);
            }
        }
        return documentProofSessionObj;
    },
    fetchExistingLoans: function (reqObj) {
        let req = {
            apiRequest: {
                interfaceName: "FetchExistingLoan",
                requestObj: reqObj,
            },
        };
        ApzCOB.showLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "GetExistingLoan", "N", "N", req, false, ApzCOB.fetchExistingLoansCB);
        }, 1000);
    },
    fetchExistingLoansCB: function (params) {
        ApzCOB.hideLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let apiResponseOj = JSON.parse(params.res.APZCBO__GetExistingLoan_Res.apiResponse.ResponseBody.responseObj);
                loanDtls = [];
                let exitingLoanList = JSON.parse(apiResponseOj.responseObj);
                if (exitingLoanList.length > 0) {
                    exitingLoanList.map((exLoan) => {
                        let exObj = {};
                        exObj.loanType = exLoan.existingLoanName;
                        exObj.loanId = exLoan.existingLoanId;
                        exObj.outstandingAmt = exLoan.outstandingAmount;
                        loanDtls.push(exObj);
                    });
                }
                let GrameenLoan = loanDtls.filter(function (e) {
                    return (e.loanType.toUpperCase() === "GRAMEEN UNNATI LOAN" || e.loanType.toUpperCase() === "GL.GRM.UNNATI.LN");
                });
                //Sourcing changes
                if (apz.currAppId === "KmSourc") {
                    apz.app.Kmbase.paintLoanDetails();
                    ApzCOB.hideLoader();
                }
                //Renewal changes
                else if (GrameenLoan.length > 0) {
                    if (ApplicationType === "NEW") {
                        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_GRAMEEN_LOAN_EXIST_ERR") + gApzCOB.selLeadDtls.customerId,
                            "E");
                    } else {
                        ApzCOB.LaunchConfiguredScreens();
                    }
                } else {
                    ApzCOB.LaunchConfiguredScreens();
                }
            } else {
                ApzCOB.hideLoader();
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_EXISTING_LOAN_SERVICE_FAIL"), "E");
            }
        } catch (e) {
            ApzCOB.hideLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_EXISTING_LOAN_SERVICE_FAIL"), "E");
        }
    },
    OtpSmsService: function (mobileNo) {
        if (apz.currAppId === 'KmSourc') {
            branchState = apz.isNull(gApzCOB.selLeadDtls.glBranchState) ? '' : gApzCOB.selLeadDtls.glBranchState?.toUpperCase();
            otpLanguage = language.find(el => el.key?.split('~')?.[1]?.toUpperCase() == branchState)?.value ?? "";
            custName = gApzCOB.selLeadDtls.fullName ?? "";
        } else {
            $("#" + screenId + "otp").val("");
            if (!apz.isNull(inSessionStore.loanDetails)) {
                otpLanguage = inSessionStore.loanDetails.payload.language;
            } else {
                otpLanguage = $("#" + screenId + "language").val() !== PleaseSelect ? $("#" + screenId + "language").val() : "";
            }
            custType = gApzCOB.currentApplicant > 1 ? "Co-App" : "Applicant";
            custName = ApzCOB.getPayloadDatafromWrapper('customerName', custType, 'customerDetailsList');
        }
        let req = {
            apiRequest: {
                interfaceName: "GenOtp",
                workflowId: "GenerateOtp",
                appId: apz.appId,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                userName: gApzCOB.LoggedInUserDetails.loginResponse.userDet.name,
                requestObj: {
                    payload: {},
                    actionType: "otp",
                    language: otpLanguage,
                    mobileNo: mobileNo,
                    custName: custName ?? "",
                    otp: "",
                    validTill: "",
                },
            },
        };
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "WorkFlowService", "N", "N", req, false, ApzCOB.OtpSmsServiceCB);
        }, 1000);
    },
    OtpSmsServiceCB: function (params) {
        apz.stopLoader();
        if (ApzCOB.handleServiceCallBacks(params)) {
            let requestObj = params.req.apiRequest.requestObj;
            let otpResponse = JSON.parse(params.res.APZCBO__WorkFlowService_Res.apiResponse.ResponseBody.responseObj);
            if (otpResponse.Status.toLocaleLowerCase() === "success") {
                if (!apz.isNull(otpResponse.otp)) {
                    $("#" + screenId + "otpText_txtcnt").text(otpResponse.otp);
                }
                window.otpCount++;
                window.OTP_ATTEMPT_LEFT = otpResponse.otpResendCount;
                window.OTP_REF = otpResponse.RefNo;
                $(`#${screenId}el_txt_29`).text(ApzCOB.getDescfromLitCode("LIT_LOANDETAILS_LBL_OTP_IS_SENT_TO") + requestObj.mobileNo.substr(
                    6, 10));
                $("#" + screenId + "loanAvaDesc_ul").removeClass("sno");
                $("#" + screenId + "otpDiv").removeClass("sno");
                $("#" + screenId + "uploadConsentDiv").addClass("sno");
                $("#" + screenId + "timerDiv").removeClass("sno");
                $("#" + screenId + "sendOtpBtn_ul").addClass("sno");
                $("#" + screenId + "check_ul").removeClass("sno");
            } else {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_OTP_SERVICE_FAILED"), "E");
            }
        } else {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    verfyOtpService: function (otp) {
        let req = {
            apiRequest: {
                interfaceName: "ValOtp",
                workflowId: "ValidateOtp",
                appId: apz.appId,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                userName: gApzCOB.LoggedInUserDetails.loginResponse.userDet.name,
                requestObj: {
                    RefNo: OTP_REF,
                    otp: otp,
                    payload: {},
                },
            },
        };
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "WorkFlowService", "N", "N", req, false, ApzCOB.verfyOtpServiceCB);
        }, 1000);
    },
    verfyOtpServiceCB: function (params) {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let otpVerifyResp = JSON.parse(params.res.APZCBO__WorkFlowService_Res.apiResponse.ResponseBody.responseObj);
            if (otpVerifyResp.Status.toLocaleLowerCase() === "success" && otpVerifyResp.OTPValServiceResponse.status === "Y") {
                if (gApzCOB.currentApplicant <= 1) {
                    window.APPLICANT_OTP_VARIFIED = true;
                } else {
                    window.CO_APPLICANT_OTP_VARIFIED = true;
                }
                if (apz.childScr === 'CBcheck') {
                    apz.stopLoader();
                    apz.app.CBcheck.otpVerifiedSuccess();
                } else {
                    apz.startLoader();
                    ApzCOB.callCBService();
                } // Calling CB based on Type
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_INVALID_OTP"), "E");
            }
        } else {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_INVALID_OTP"), "E");
        }
    },
    callCBService: function () {
        if (!apz.isNull(CBCALLTYPEFLAG)) {
            window.CBCALLTYPEFLAG === "IRE" ? ApzCOB.CbHighmarkService() : ApzCOB.BRECbService();
        }
    },
    getCbAddressRequest: function (custDtlId) {
        let addressReq = [],
            custID;
        if (apz.isNull(custDtlId)) {
            custID = gApzCOB.currentApplicant <= 1 ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId;
        } else {
            custID = custDtlId;
        }
        let stateCodeList = language.map((state) => state.key);
        let custAddressData = [];
        if (!apz.isNull(inSessionStore.addressDetailsWrapperList)) {
            custAddressData = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.filter((custAdd) => parseInt(custAdd
                .custDtlId) === parseInt(custID) && custAdd.addressType === "Personal");
            if (custAddressData.length > 0) {
                let custAddressObj = custAddressData[0].payload.addressList;
                if (custAddressObj.length > 0) {
                    custAddressObj.map((addr) => {
                        if (addr.addressType === "Present" || addr.addressType === "Permanent") {
                            let addrObj = {};
                            if (CBCALLTYPEFLAG === "IRE") {
                                let fecthStateCodeArray = stateCodeList.filter((stateCode) => stateCode.split("~")[1]
                                    .toLocaleLowerCase() === addr.state.toLocaleLowerCase());
                                let currentStateCode = addr.state;
                                if (fecthStateCodeArray.length > 0) {
                                    currentStateCode = fecthStateCodeArray[0].split("~")[0];
                                }
                                addrObj.addressLine1 = addr.addressLine1;
                                addrObj.addressLine2 = addr.addressLine2;
                                addrObj.addressLine3 = addr.addressLine3;
                                addrObj.pincode = addr.pinCode;
                                addrObj.city = addr.city;
                                addrObj.state = currentStateCode;
                                addrObj.type = addr.addressType === "Present" ? "Current" : addr.addressType;
                            } else if (CBCALLTYPEFLAG === "BRE") {
                                addrObj.addrType = ApzCOB.breFieldsMapping("addressType", addr.addressType);
                                addrObj.addrLine1 = `${addr.addressLine1} ${addr.addressLine2}`; //CR-143
                                addrObj.city = addr.city;
                                addrObj.state = ApzCOB.breFieldsMapping("state", addr.state);
                                addrObj.district = addr.district;
                                addrObj.pinCode = addr.pinCode;
                                if (addr.addressType === "Present") {
                                    window.glBranchState = addr.state;
                                }
                            }
                            if (!(addr.addressType === "Permanent" && addr.addressSameAs.includes("Y"))) {
                                addressReq.push(addrObj);
                            }
                        }
                    });
                }
            }
        }
        return addressReq;
    },
    // getKYC Ids
    getKYCIdsRequest: function (custType) {
        let KYCIds = [];
        let custData = inSessionStore.customerDetailsList.filter((custData) => custData.customerType === custType);
        if (!apz.isNull(custData) && custData.length > 0) {
            let custPayload = custData[0].payload;
            if (!apz.isNull(custPayload.primaryKycId) && !apz.isNull(custPayload.primaryKycIdValStatus) && custPayload
                .primaryKycIdValStatus === "Verified") {
                let ljson = {
                    docType: "VOTER-ID",
                    docId: custPayload.primaryKycId
                };
                KYCIds.push(ljson);
            }
            if (!apz.isNull(custPayload.alternateVoterId) && !apz.isNull(custPayload.alternateVoterIdValStatus) && custPayload
                .alternateVoterIdValStatus === "Verified") {
                let ljson = {
                    docType: "VOTER-ID",
                    docId: custPayload.alternateVoterId
                };
                KYCIds.push(ljson);
            }
            if (!apz.isNull(custPayload.secondaryKycId) && !apz.isNull(custPayload.secondaryKycIdValStatus) && custPayload
                .secondaryKycIdValStatus === "Verified") {
                let docTypeSelected = "";
                switch (custPayload.secondaryKycType) {
                    case "PAN":
                        docTypeSelected = "PAN";
                        break;
                    case "Driving Licence":
                        docTypeSelected = "DRIVING-LICENCE";
                        break;
                    case "Passport number":
                        docTypeSelected = "PASSPORT";
                        break;
                }
                let ljson = {
                    docType: docTypeSelected,
                    docId: custPayload.secondaryKycId,
                };
                KYCIds.push(ljson);
            }
        }
        return KYCIds;
    },
    breFieldsMapping: function (type, value) {
        let lvalue = "";
        lvalue = BRE_MAPPING[type].filter((el) => el.Description.toUpperCase() === value.toUpperCase());
        if (!apz.isNull(lvalue) && lvalue.length > 0) {
            lvalue = lvalue[0].Code;
        } else {
            lvalue = "";
        }
        return lvalue;
    },
    // BRE CBService
    BRECbService: function () {
        window.CBCALLTYPEFLAG = 'BRE';
        let CurrenCustType = '';
        let coAppDetailsObj = "",
            coAppData = [],
            depName = "",
            coApp_flag = 0,
            kycId, custDtlPayload, loanAMount, frequency, income, activation_date, branch = "", kendraId = "", branchId = "",
            term = "",
            applicantIncome = "", currentStage = "", caglOs = "";
        let loanData = {};
        let loanDataPayload = {};
        if (!apz.isNull(inSessionStore.loanDetails)) {
            loanData = inSessionStore.loanDetails;
            if (typeof (inSessionStore.loanDetails.payload) === 'object') {
                loanDataPayload = inSessionStore.loanDetails.payload;
            } else {
                loanDataPayload = JSON.parse(inSessionStore.loanDetails.payload)
            }
        }
        if (isRPCLogin) {
            CurrenCustType = 2;
            gApzCOB.currentApplicant = CurrenCustType;
            if (!apz.isNull(inSessionStore.loanDetails)) {
                loanAMount = loanData?.loanAmount;
                frequency = loanDataPayload?.frequencyOfRepayment;
                term = loanData?.tenure;
            }
        } else {
            CurrenCustType = gApzCOB.currentApplicant;
            if (Number(CurrenCustType) === 1) {
                window.custType = 'Applicant';
                loanAMount = !apz.isNull($("#" + screenId + "loanAmount").val()) ? $("#" + screenId + "loanAmount").val() : "";
                frequency = !apz.isNull($("#" + screenId + "freqOfRepayment").val()) ? $("#" + screenId + "freqOfRepayment").val() : "";
                term = !apz.isNull($("#" + screenId + "loanTenureYr").val()) ? $("#" + screenId + "loanTenureYr").val()?.split(' ')?.[0] : '';
            } else {
                window.custType = 'Co-App';
            }
        }
        let currentIndex = inSessionStore.customerDetailsList.findIndex((custData) => custData.custDtlId === gApzCOB.userDetails.custDtlId);
        let custDetailsObj = !apz.isNull(currentIndex) && currentIndex >= 0 ? inSessionStore.customerDetailsList[currentIndex] : "";
        let loanType = "GRAMEEN UNNATI LOAN"; //'GRAMEEN UNNATI RENEWAL LOAN'
        activation_date = gApzCOB?.selLeadDtls?.activationDate ?? "";
        if (apz.isNull(activation_date)) {
            activation_date = inSessionStore?.leadDetails?.activationDate || inSessionStore?.renewalLeadDetails?.activationDate || '';
        }
        if (apz.isNull(activation_date) || (typeof activation_date === "undefined")) {
            ApzCOB.fnDisplayMsg("Activation date is empty!", "E");
            return;
        }
        income = ApzCOB.getOccupation("Income");
        applicantIncome = ApzCOB.getOccupation("Income", "applicant");
        if (!apz.isNull(custDetailsObj)) {
            custDtlPayload = custDetailsObj.payload;
            kycId = custDtlPayload.primaryKycIdValStatus === "Verified" ? custDtlPayload.primaryKycId : custDtlPayload
                .alternateVoterIdValStatus === "Verified" ? custDtlPayload.alternateVoterId : "";
            if (custDtlPayload.maritalStatus?.toUpperCase() === "MARRIED") {
                depName = custDtlPayload.spouseName;
            } else {
                depName = custDtlPayload.fathersName;
            }
        }
        if (CurrenCustType > 1) {
            let currentIndex = inSessionStore.customerDetailsList.findIndex(
                (custData) => custData.custDtlId === gApzCOB.userDetails.CoApplicantCustomerId);
            coAppDetailsObj = !apz.isNull(currentIndex) && currentIndex >= 0 ? inSessionStore.customerDetailsList[currentIndex] : "";
            if (!apz.isNull(inSessionStore.loanDetails)) {
                loanAMount = loanData?.loanAmount;
                frequency = loanDataPayload?.frequencyOfRepayment;
                term = loanData?.tenure;
            }
        }
        coAppData = [];
        if (CurrenCustType > 1 && !apz.isNull(coAppDetailsObj)) {
            let ljson = {};
            ljson.applicantType = "H";
            ljson.relationtype = coAppDetailsObj.payload.relationShipWithApplicant;
            ljson.address = ApzCOB.getCbAddressRequest(gApzCOB.userDetails.CoApplicantCustomerId);
            ljson.document = ApzCOB.getKYCIdsRequest("Co-App");
            ljson.custName = depName = coAppDetailsObj.customerName;
            ljson.gender = ApzCOB.breFieldsMapping("gender", coAppDetailsObj.payload.gender); //"2" coAppDetailsObj.payload.gender
            ljson.phone = coAppDetailsObj.mobileNumber;
            ljson.dob = coAppDetailsObj.payload.dob;
            ljson.earning_flag = "ABC"; //Static
            coAppData.push(ljson);
            coApp_flag = 1;
            income = (parseInt(applicantIncome) + parseInt(income))?.toString();
        }
        window.glBranchState = '';
        kendraId = inSessionStore?.applicationMaster?.kendraId || "";
        branchId = inSessionStore?.applicationMaster?.branchId || "";
        if (apz.isNull(kendraId) || apz.isNull(branchId)) {
            kendraId = inSessionStore?.leadDetails?.kendraId || inSessionStore?.renewalLeadDetails?.kendraId || "";
            branchId = inSessionStore?.leadDetails?.glBranchId || inSessionStore?.renewalLeadDetails?.glBranchId || "";
            if (apz.isNull(kendraId) || apz.isNull(branchId)) {
                kendraId = gApzCOB?.selLeadDtls?.kendraId || "";
                branchId = gApzCOB?.selLeadDtls?.glBranchId || "";
            }
        }
        if (LoggedInUserDetails?.loginResponse?.addInfo1 === 'KM' && typeof inSessionStore?.applicationMaster?.applicationStatus === 'undefined') {
            inSessionStore.applicationMaster = { ...inSessionStore.applicationMaster };
            inSessionStore.applicationMaster.applicationStatus = 'INPROGRESS';
        }
        currentStage = `${inSessionStore.applicationMaster?.applicationStatus} | ${inSessionStore.applicationMaster?.applicationStatus}`;
        caglOs = gApzCOB?.selLeadDtls?.caglOs || inSessionStore?.leadDetails?.caglOs || inSessionStore?.renewalLeadDetails?.caglOs || '';
        let req = {
            apiRequest: {
                appId: apz.appId,
                interfaceName: "BRECBCheck",
                requestObj: {
                    values: {
                        input: {
                            values: {
                                input: {
                                    roi_type: 0, //Static
                                    Coapp_flag: coApp_flag,
                                    applicant: {
                                        applicantType: "P",
                                        address: ApzCOB.getCbAddressRequest(gApzCOB.userDetails.custDtlId),
                                        document: ApzCOB.getKYCIdsRequest("Applicant"),
                                        depType: "F", //?? based on maritalsts-Married-10,oth-1
                                        depName: depName, //Spouse or FName for Appli else Co-App Name
                                        categoryId: "1", //??
                                        productCode: "CCR", //??
                                        dob: custDtlPayload.dob,
                                        durationOfAgreement: "12", //Static
                                        bankProductId: "01", //??
                                        custName: custDetailsObj.customerName,
                                        gender: ApzCOB.breFieldsMapping("gender", custDtlPayload.gender), //"2"
                                        phone: custDetailsObj.mobileNumber,
                                        loanType: ApzCOB.breFieldsMapping("loanType", loanType), //"2"
                                        appId: gApzCOB.userDetails.applicationId, //??
                                        losIndicator: "1", //??
                                        losIndex: "LOS", //??
                                        slNo: "1", //??
                                        loanAmount: ApzCOB.fn_unFormatAmount(loanAMount.toString()), // String
                                        term: ApzCOB.breFieldsMapping('term', term.toString()), //?? Tenure Months/Years 2
                                        applied_frequency: frequency,
                                        email: "", //Appl Email ID
                                        maritalStatus: ApzCOB.breFieldsMapping("maritalStatus", custDtlPayload.maritalStatus),
                                        kendra: kendraId,
                                        branch: branchId,
                                        stateBranch: ApzCOB.breFieldsMapping("state", window.glBranchState ?? ""),
                                        custId: inSessionStore?.applicationMaster?.memberId ?? gApzCOB.selLeadDtls.customerId,
                                        source: "OTHERS", //Source Of Income not available during service hit
                                        enquiryType: "A", //Previously "H" Static
                                        loanId: gApzCOB.userDetails.applicationId,
                                        DigiAgil_DFA_Flag: "Unnati",
                                        hh_annual_income: income,
                                        earning_flag: "ABC", //Static
                                        loan_product_type: "ABC", //??
                                        activation_date: activation_date,
                                        product_code: "GL.GRM.UNNATI.LN", // For Renewal?
                                        Q1: "", //??
                                        Q2: "",
                                        Q3: "",
                                        Q4: "",
                                        Q5: "",
                                        Q6: "",
                                        Q7: "",
                                        Q8: "",
                                        Q9: "",
                                        Q10: "",
                                        Q11: "",
                                        Q12: "",
                                        Q13: "",
                                        Q14: "",
                                        Q15: "",
                                        Q16: "",
                                        Q17: "",
                                        Q18: "",
                                        Q19: "",
                                        Q20: "",
                                        Q21: "",
                                        Q22: "",
                                        Q23: "",
                                        Q24: "",
                                        Q25: "",
                                        Q26: "",
                                        Q27: "",
                                        Q28: "",
                                        Field_Assessed_Income_of_customer: income, //??
                                        Income_Assessment_Flag: "1", //??
                                    },
                                    household_member: coAppData,
                                    App_Insurance_flag: "No",
                                    Coapp_Insurance_flag: "No",
                                    Joint_Insurance_flag: "No",
                                    App_Insurance_amt: 0,
                                    Coapp_Insurance_amt: 0,
                                    Joint_Insurance_amt: 0,
                                    currentStage: currentStage,
                                    caglOs: caglOs
                                }
                            }
                        }
                    }
                }
            }
        };
        apz.startLoader();
        if (isRPCLogin) {
            let customerType = custType === 'Applicant' ? custType : 'Co-Applicant';
            let waitingText = `Calling BRE service.! Please wait`
            let popUpObj = {};
            popUpObj.text = waitingText;
            popUpObj.Btn1 = {
                "text": "",
                "onClick": ""
            }
            popUpObj.Btn2 = {
                "text": "",
                "onClick": ""
            }
            ApzCOB.showRpcModals(popUpObj, "confirmation");
        }
        if (activation_date && (typeof activation_date === 'object')) {
            const dateObj = activation_date;
            const formattedDate = `${dateObj.year}-${String(dateObj.month).padStart(2, '0')}-${String(dateObj.day).padStart(2, '0')}`;
            req.apiRequest.requestObj.values.input.values.input.applicant.activation_date = formattedDate;
        }
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "BRECBCheck", "N", "N", req, false, ApzCOB.BRECbServiceCB);
        }, 1000);
    },
