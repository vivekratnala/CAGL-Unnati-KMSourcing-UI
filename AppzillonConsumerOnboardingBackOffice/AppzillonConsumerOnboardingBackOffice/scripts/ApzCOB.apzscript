            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = JSON.parse(params.res.APZCBO__FetchCities_Res.apiResponse.ResponseBody.responseObj);
                gCities = response;
            }
            Cities = [];
            $.each(gCities, function (c, d) {
