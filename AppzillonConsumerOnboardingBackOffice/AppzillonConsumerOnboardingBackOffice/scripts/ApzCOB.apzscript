    getStageEditedFields: function () {
        if (apz.isObjectEmpty(inSessionStore) || apz.isNull(inSessionStore.rpcStatDetails)) {
            return [];
        }
        let currentType = custType === "Applicant" ? "A" : "C";
        let currentStageData = inSessionStore.rpcStatDetails.find(stage => Number(stage.stageID) === Number(RPC_CURRENT_STAGE_NO) && stage
            .custType.toUpperCase() === currentType);
        return currentStageData?.editedFields || [];
    },
    addActiveToCurrentStage: function () {
        var menuBarListID = '#RPC__RPCSidebar__menuBarList';
        let currentStageID = RPC_STAGES[RPC_CURRENT_STAGE].id;
        $(`${menuBarListID} .sid-ttl`).removeClass('activeLink');
        $(`${menuBarListID} .sid-ttl[stage-id=${currentStageID}]`).addClass('activeLink');
    },
    footerBasedOnStage: function () {
        $("#RPC__RPCFooter__sc_row_1").toggleClass("sno", RPC_CURRENT_STAGE_NO === 2);
        $("#RPC__RPCFooter__sc_row_2").toggleClass("sno", RPC_CURRENT_STAGE_NO !== 2);
    },
    newFnCheckMaxMinLengthOnBlur: function (pthis) {
        let lVALIDFLAG = true;
        var minlength = pthis.minLength;
        var maxlength = pthis.maxLength;
        if (maxlength === -1 || minlength === -1) {
            return lVALIDFLAG;
        }
        var value = pthis.value.trim();
        let $input = $(pthis);
        if (RPC_CURRENT_STAGE_NO === 8) {
            if (pthis.id === reEnterInputId) acclengthErr = true;
            if (pthis.id === ifscInputId) ifsclengthErr = true;
        } else if ([2, 4, 7].includes(RPC_CURRENT_STAGE_NO)) {
            if (pthis.id === `RPC__${RPC_CURRENT_STAGE}__pinCodeInput`) pinlengthErr = true;
        } else if ((pthis.id?.toLowerCase())?.includes('ifsc')) {
            ifsclengthErr = true;
        } else if ((pthis.id?.toLowerCase())?.includes('accountnum')) {
            acclengthErr = true;
        }
        $input.next(".err").remove();
        if (pthis.id === `RPC__${RPC_CURRENT_STAGE}__mobileNumberInput`) moblengthErr = true;
        if (!apz.isNull(value) && (value.length < minlength || value.length > maxlength)) {
            lVALIDFLAG = false;
            if (RPC_CURRENT_STAGE_NO === 8 || apz.currAppId === 'DBkitG') {
                if (acclengthErr) acclengthErr = false;
                if (ifsclengthErr) ifsclengthErr = false;
            } else if ([2, 4, 7].includes(RPC_CURRENT_STAGE_NO)) {
                if (typeof pinlengthErr !== 'undefined') {
                    pinlengthErr = validPinCode = false;
                }
            }
            if (pthis.id === `RPC__${RPC_CURRENT_STAGE}__mobileNumberInput`) moblengthErr = false;
            $input.next(".err").remove();
            lengthValidationErr = `<span class='err' style='color: red; font-size: 12px;'>Please enter minimum:${minlength} & maximum:${maxlength} characters.!</span>`
            $(lengthValidationErr).insertAfter($input); // fieldValidationErr
            /*if (apz.isNull($('#DBkitG__eNach__ifsc').val())) {
                $("#" + scrId + "verifyACC").addClass('sno');
            }*/
        }
        return lVALIDFLAG;
    },
    /* showRpcModals: function(propObj, modalType) {
            let RpcModalId = "RPC__RpcStageScreen__";
            if (modalType === "confirmation") {
                $(`#${RpcModalId}confirmationText_txtcnt`).html(propObj.text);
                if (!apz.isNull(propObj.Btn1.text) || !apz.isNull(propObj.Btn2.text)) {
                    $(`#${RpcModalId}confrmBtn1_txtcnt`).html(propObj.Btn1.text ? propObj.Btn1.text : "Yes");
                    $(`#${RpcModalId}confrmBtn2_txtcnt`).html(propObj.Btn2.text ? propObj.Btn2.text : "No");
                    $(`#${RpcModalId}confrmBtn1`).attr("onclick", propObj.Btn1.onClick);
                    $(`#${RpcModalId}confrmBtn2`).attr("onclick", propObj.Btn2.onClick);
                    $(`#${RpcModalId}conFormation_mdl .suc-btns`).removeClass('sno');
                } else {
                    $(`#${RpcModalId}conFormation_mdl .suc-btns`).addClass('sno');
                }
                ApzCOB.toggleModal(`${RpcModalId}conFormation_mdl`);
            } else if (modalType === "Error") {
                let currentScreenId = '';
                if (!apz.isNull(RPC_CURRENT_STAGE)) {
                    currentScreenId = RpcModalId;
                } else {
                    currentScreenId = scrId;
                }
                $(`#${currentScreenId}errorText_txtcnt`).html(propObj.text);
                $(`#${currentScreenId}errorBtn1`).attr("onclick", propObj.Btn1.onClick);
                ApzCOB.toggleModal(`${currentScreenId}RpcError_modal`);
            } else if (modalType === "Success") {
                RpcModalId = "APZCBO__BaseScreens__"
                $(`#${RpcModalId}sendBack_accNumumber_txtcnt`).html(propObj.text);
                $(`#${RpcModalId}succBtn`).attr("onclick", propObj.Btn.onClick);
                ApzCOB.toggleModal(`${RpcModalId}RpcfooterSucc_modal`);
            }
        },*/
    showRpcModals: function (propObj, modalType) {
        let currScrId = "";
        if (apz.childScr == "CaotherDetails") {
            currScrId = "CrdAss__CaotherDetails__";
        } else if (apz.childScr == "Saloandetails" || apz.childScr === 'SanctionSuc') {
            currScrId = "Sanct__DeviationSanctBase__";
        } else if (apz.childScr == 'CaIncomeDetails') {
            currScrId = "CrdAss__Cabase__";
        } else if (apz.childScr == 'LUCDetails') {
            currScrId = 'Luc__LUCDetails__'
        } else if (apz.childScr == 'AadhaarDetails' || apz.childScr == "documentCapture") {
            currScrId = 'KmSourc__Kmbase__';
        } else {
            currScrId = 'RPC__RpcStageScreen__';
        }
        // let RpcModalId = "RPC__RpcStageScreen__";
        if (modalType === "confirmation") {
            $(`#${currScrId}confirmationText_txtcnt`).html(propObj.text);
            if (!apz.isNull(propObj.Btn1.text) || !apz.isNull(propObj.Btn2.text)) {
                $(`#${currScrId}confrmBtn1_txtcnt`).html(propObj.Btn1.text ? propObj.Btn1.text : "Yes");
                $(`#${currScrId}confrmBtn2_txtcnt`).html(propObj.Btn2.text ? propObj.Btn2.text : "No");
                $(`#${currScrId}confrmBtn1`).attr("onclick", propObj.Btn1.onClick);
                $(`#${currScrId}confrmBtn2`).attr("onclick", propObj.Btn2.onClick);
                $(`#${currScrId}conFormation_mdl .suc-btns`).removeClass('sno');
            } else {
                $(`#${currScrId}conFormation_mdl .suc-btns`).addClass('sno');
            }
            // ApzCOB.toggleModal(`${currScrId}conFormation_mdl`);
            if (apz.childScr == 'CaIncomeDetails') {
                ApzCOB.toggleModal(`${currScrId}CaConformation_modal`);
            } else {
                ApzCOB.toggleModal(`${currScrId}conFormation_mdl`);
            }
        } else if (modalType === "Error") {
            let currentScreenId = '';
            if (apz.childScr == "Saloandetails" || apz.childScr === 'SanctionSuc') {
                currentScreenId = currScrId;
            } else if (apz.childScr == "CaotherDetails") {
                currentScreenId = currScrId;
            } else if (apz.childScr == "CaIncomeDetails") {
                currentScreenId = currScrId;
            } else if (apz.childScr == "AadhaarDetails" || apz.childScr == "documentCapture") {
                currentScreenId = currScrId;
            } else {
                if (!apz.isNull(RPC_CURRENT_STAGE)) {
                    currentScreenId = currScrId;
                } else {
                    currentScreenId = scrId;
                }
            }
            $(`#${currentScreenId}errorText_txtcnt`).html(propObj.text);
            $(`#${currentScreenId}errorBtn1`).attr("onclick", propObj.Btn1.onClick);
            if (apz.childScr == "Saloandetails" || apz.childScr === 'SanctionSuc') {
                ApzCOB.toggleModal(`${currentScreenId}SA_Error_modal`);
            } else if (apz.childScr == "CaotherDetails") {
                ApzCOB.toggleModal(`${currentScreenId}CA_Error_modal`);
            } else if (apz.childScr == "CaIncomeDetails") {
                ApzCOB.toggleModal(`${currentScreenId}CaError_modal`);
            } else if (apz.childScr == "AadhaarDetails" || apz.childScr == "documentCapture") {
                ApzCOB.toggleModal(`${currentScreenId}AA_Error_modal`);
            } else {
                ApzCOB.toggleModal(`${currentScreenId}RpcError_modal`);
            }
        } else if (modalType === "Success") {
            let currentScreenId = '';
            if (apz.childScr == "Saloandetails" || apz.childScr == "CaotherDetails" || apz.childScr == "CaIncomeDetails" || apz.childScr === 'LUCDetails' || apz.childScr == "AadhaarDetails" || apz.childScr == "documentCapture") {
                currentScreenId = currScrId;
                $(`#${currentScreenId}successText_txtcnt`).html(propObj.text);
                $(`#${currentScreenId}succBtn_txtcnt`).text(propObj.Btn1.text);
                $(`#${currentScreenId}succBtn`).attr("onclick", propObj.Btn1.onClick);
                // ApzCOB.toggleModal(`${currentScreenId}Succ_modal`);/
                if (apz.childScr == 'CaIncomeDetails') {
                    ApzCOB.toggleModal(`${currentScreenId}CaSucc_modal`);
                } else {
                    ApzCOB.toggleModal(`${currentScreenId}Succ_modal`);
                }
            } else {
                RpcModalId = "APZCBO__BaseScreens__"
                $(`#${RpcModalId}sendBack_accNumumber_txtcnt`).html(propObj.text);
                $(`#${RpcModalId}succBtn`).attr("onclick", propObj.Btn.onClick);
                ApzCOB.toggleModal(`${RpcModalId}RpcfooterSucc_modal`);
            }
        }
    },
    showCommonErrRPCModal: function (lerrMsg) {
        ApzCOB.showRpcModals({
            text: lerrMsg ? lerrMsg : technicalErrMsg,
            Btn1: {
                text: "OK",
                onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
            }
        }, "Error");
    },
    getPennyCheckData: function () {
        window.exceptionDoc = [], window.IS_RPCEDITCHECK = false, window.IS_ACCOUNTNUMBER_EDITED = false;
        custDetailID = ApzCOB.getCustDetailID('Applicant');
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        pennyStatus = inSessionStore?.bankDetailsWrapperList?.[currIndex]?.bankDetails?.payload?.pennyCheckStatus?.toUpperCase() === 'PASS' ?
            true : false;
        exceptionDoc = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.filter(({
            custDtlId,
            payload
        }) => {
            return custDtlId === custDetailID && payload.documentType === 'PennyExceptionDoc'
        });
        IS_RPCEDITCHECK = inSessionStore?.bankDetailsWrapperList?.[currIndex].bankDetails?.payload?.rpcEditCheck ?? false;
        IS_ACCOUNTNUMBER_EDITED = inSessionStore?.rpcStatDetails?.some(item => item?.stageID === 8 && item?.editedFields?.some(field => [
            "reEnterAccountNumber", "accountNumber"
        ].includes(field)));
    },
    validateBankAccountProofStage: function () {
        if (pennyStatus || (!pennyStatus && pennyApprovalUpload)) {
            return true;
        } else if (!pennyStatus && (!pennyApprovalUpload && ApzCOB.checkIsQueryExist())) {
            return true;
        } else {
            lerrMsg = (!pennyStatus && !pennyApprovalUpload) ? 'Penny check failed! Please raise an exception.' :
                'Complete Penny Check before accepting.';
            ApzCOB.showRpcModals({
                text: lerrMsg ? lerrMsg : technicalErrMsg,
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
                }
            }, "Error");
            return false;
        }
    },
    checkIsQueryExist: function () {
        let subStageID = custType === 'Applicant' ? 'A' : 'C';
        let isExist = false;
        if (apz.isObjectEmpty(inSessionStore) || !inSessionStore.hasOwnProperty('rpcStatDetails')) return;
        let statDetails = inSessionStore?.rpcStatDetails;
        let curStageObj = {};
        if (statDetails.length > 0) {
            curStageObj = statDetails.find(stat => stat.stageID === RPC_CURRENT_STAGE_NO && stat.custType === subStageID);
            if (apz.isNull(curStageObj) || !curStageObj.hasOwnProperty('query')) return;
            if (curStageObj.query.length > 0) {
                isExist = true;
            }
        }
        return isExist;
    },
    rpcVerifyStages: function () {
        if (gApzCOB.selectedRole == 'RPC_Maker' && $("#RPC__BankAccountProofRPC__pennyCheckBtnId").is(":enabled") && $(`.fieldEditedTag`).is(':visible')) {
            ApzCOB.fnDisplayMsg("Please complete the penny check.", "E");
            return;
        }
        let isQueryExist = ApzCOB.checkIsQueryExist();
        let isValid = true;
        if (!isQueryExist) {
            isValid = ApzCOB.validateRPCStageFormFields();
        }
        if (isValid) {
            if (RPC_CURRENT_STAGE_NO === 1) {
                let cbValid = ApzCOB.checkCBStatusPass();
                if (!cbValid) {
                    rejectRsn = ApzCOB.getPayloadDatafromWrapper('rejectionReason', 'Co-App', 'cibilDetailsWrapperList') || '';
                    retry_Attempts = ApzCOB.getPayloadDatafromWrapper('retryAttempts', 'Co-App', 'cibilDetailsWrapperList') || '';
                    let irisMsg = ApzCOB.getPayloadDatafromWrapper('irisMessage', 'Co-App', 'cibilDetailsWrapperList') || '';
                    let customerType = custType === 'Applicant' ? custType : 'Co-Applicant';
                    if (!retry_Attempts || retry_Attempts === 0) {
                        let errMsgBRE = `CB retrigger limit exceeded. Reject the application.<br/>Reject reason: ${window.rejectRsn ?? '-'}.`;
                        if (irisMsg?.includes('success')) {
                            errMsgBRE = `BRE CB failed!. Reject the application.<br/>Reject reason: ${window.rejectRsn ?? '-'}.`;
                        }
                        popUpObj = {
                            text: `${customerType} CB retrigger limit exceeded.Reject the application.<br/>Reject reason: ${window.rejectRsn ?? '-'}.`,
                            Btn: {
                                text: "Ok",
                                onClick: `ApzCOB.closeCommonModal('newCommonErrModal'); apz.app.RPCFooter.approveReject(this,'REJECTED','${customerType} CB Decision Failed.Reason: ${window.rejectRsn || "-"}')`
                            }
                        };
                        ApzCOB.showNewCommonErrorModal(popUpObj);
                        apz.stopLoader();
                        return;
                    } else {
                        let errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Remaining retry attempts: ${retry_Attempts}.<br/>Do you want to rehit BRE?`
                        if (irisMsg?.includes('bureauError') && !irisMsg?.includes('roll')) {
                            errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Do you want to rehit BRE?`
                        }
                        popUpObj = {
                            text: errMsgBRE,
                            Btn1: {
                                text: "Yes",
                                onClick: "ApzCOB.closeCommonModal(`newCommonConfModal`); ApzCOB.BRECbService()"
                            },
                            Btn2: {
                                text: "No",
                                onClick: "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()"
                            }
                        }
                    }
                    /*let confrmTxt = `${customerType} CB failed.! Reason: ${rejectRsn}<br/> Would you like to reject the application?`
                    let popUpObj = {};
                    popUpObj.text = confrmTxt;
                    popUpObj.Btn1 = {
                        "text": "Yes",
                        "onClick": `apz.app.RPCFooter.approveReject(this,'REJECTED', '${customerType} CB failed.! Reason: ${rejectRsn}')`
                    }
                    popUpObj.Btn2 = {
                        "text": "No",
                        "onClick": "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()"
                    }*/
                    ApzCOB.showRpcModals(popUpObj, "confirmation");
                    return;
                }
            } else if (RPC_CURRENT_STAGE_NO === 8 && gApzCOB.selectedRole === 'RPC_Maker') {
                let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
                let bankPayload = inSessionStore.bankDetailsWrapperList[currIndex]?.bankDetails?.payload;
                editBankTag = bankPayload?.editBankDetails === 'Yes';
                if (editBankTag) {
                    if (bankPayload?.rpcEditCheck) {
                        if (bankPayload?.pennyCheckStatus === '' || typeof bankPayload?.pennyCheckStatus === 'undefined') {
                            ApzCOB.showCommonErrRPCModal('Complete Penny Check before accepting.');
                            return;
                        } else if (!ApzCOB.validateBankAccountProofStage()) {
                            return;
                        }
                    }
                }
            }
            let {
                loginResponse
            } = gApzCOB.LoggedInUserDetails || {};
            let req = {
                apiRequest: {
                    requestObj: {},
                    userId: loginResponse?.userDet?.id || "",
                    appId: gAppId,
                    interfaceName: "UploadRPCLoanData",
                },
            };
            currentApplicationData = structuredClone ? structuredClone(inSessionStore) : JSON.parse(JSON.stringify(inSessionStore));
            req.apiRequest.requestObj = {
                ...req.apiRequest.requestObj,
                appId: currentApplicationData?.appId,
                applicationId: currentApplicationData?.applicationId,
                versionNum: currentApplicationData.applicationMaster.versionNum,
                stageId: RPC_CURRENT_STAGE_NO?.toString(),
                requestType: "StageVerification",
                customerType: custType ?? "Co-App"
            };
            if (RPC_CURRENT_STAGE_NO === 3) {
                //   req.apiRequest.requestObj.customerType = "Applicant";
            }
            apz.startLoader();
            ApzCOB.serverBuildParam(gAppId, "UploadRPCLoanData", "N", "N", req, false, ApzCOB.rpcVerifyStagesCB);
        } else {
            const popUpObj = {
                text: 'Please fill the mandatory fields.!',
                Btn1: {
                    text: "OK",
                    onClick: 'apz.app.RpcStageScreen.closeRPCErrMdl()'
                }
            };
            ApzCOB.showRpcModals(popUpObj, "Error");
        }
    },
    rpcVerifyStagesCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.updateInsessionData(params);
                ApzCOB.updateSideMenuStatusTags();
                apz.app.RPCFooter.updateQueriesWithLatestDateTime();
                ApzCOB.moveToNextStageOnVerification();
            }
        } catch (error) {
            ApzCOB.showCommonErrRPCModal();
        }
    },
    rpcDBVerifyStages: function () {
        RPC_DB_CURRENT_STAGE_NO = RPCDBVerify_STAGES[apz.childScr].id;
        //let isQueryExist = ApzCOB.checkIsQueryExist();
        var reqTyp = '';
        let isValid = true;
        //approvedDocs = [];
        queries = [];
        var result = {
            approvedDocs: [],
            queries: []
        };
        if (isValid) {
            var dbVerifyscrnQueries = '';
            if (RPC_DB_CURRENT_STAGE_NO === 1) {
                dbVerifyscrnQueries = window.sanctionDtlsQueries;
            } else if (RPC_DB_CURRENT_STAGE_NO === 2) {
                dbVerifyscrnQueries = window.eNachQueries;
            } else if (RPC_DB_CURRENT_STAGE_NO === 3) {
                dbVerifyscrnQueries = window.udyamQueries;
            }
            if (RPC_DB_CURRENT_STAGE_NO === 1 || RPC_DB_CURRENT_STAGE_NO === 2 || RPC_DB_CURRENT_STAGE_NO === 3) {
                if (dbVerifyscrnQueries.length == 0) {
                    queries = [];
                    reqTyp = "Verify";
                } else {
                    dbVerifyscrnQueries.forEach(reason => {
                        if (reason.split("_")[0] === 'oth') {
                            var reasonCode = reason.split("_")[0] + '?' + reason.split("_")[1].split('?')[1]
                        } else {
                            var reasonCode = reason.split("_")[0];
                        }
                        result.queries.push(`${reasonCode}`);
                    });
                    queries = result.queries;
                    reqTyp = "query";
                }
            }
            if (RPC_DB_CURRENT_STAGE_NO === 4) {
                /*for (var [doc, reasons] of Object.entries(window.docQuery)) {
                    reasons.forEach(reason => {
                        if (reason === "Approved") {
                            result.approvedDocs.push(doc);
                        } else {
                            if (reason.split("_")[0] === 'oth') {
                                var reasonCode = reason.split("_")[0] + '?' + reason.split("_")[1].split('?')[1]
                            } else {
                                var reasonCode = reason.split("_")[0];
                            }
                            result.queries.push(`${doc}^${reasonCode}^${docQueryTs}`);
                        }
                    });
                }
                const categoriesInList2 = new Set(result.queries.map(item => item.split('^')[0]));
                let filteredList1 = window.dbVerificationQueries.filter(item => !categoriesInList2.has(item.split('^')[0]));
                let filteredList2 = window.approvedDocs.filter(item => !categoriesInList2.has(item.split('^')[0]));
                var approvedTs = new Set([...filteredList2,...result.approvedDocs]);
                var queriesTs =new Set([...filteredList1,...result.queries]);*/
                //approvedDocs = [...approvedTs];
                queries = [...window.dbVerificationQueries];
                //approvedDocs = result.approvedDocs;
                //queries = result.queries;
                reqTyp = "Verify";
                window.reuploadedDocs = [];
            }
            let {
                loginResponse
            } = gApzCOB.LoggedInUserDetails || {};
            let req = {
                apiRequest: {
                    requestObj: {},
                    userId: loginResponse?.userDet?.id || "",
                    appId: gAppId,
                    interfaceName: "UploadDBKITLoanData",
                },
            };
            currentApplicationData = structuredClone ? structuredClone(inSessionStore) : JSON.parse(JSON.stringify(inSessionStore));
            req.apiRequest.requestObj = {
                ...req.apiRequest.requestObj,
                appId: currentApplicationData?.appId,
                applicationId: currentApplicationData?.applicationId,
                versionNum: currentApplicationData.applicationMaster.versionNum,
                stageId: RPCDBVerify_STAGES[apz.childScr].id.toString(),
                requestType: reqTyp,
                customerType: "Applicant",
                approvedDocs,
                queries
            };
            if (RPC_DB_CURRENT_STAGE_NO === 4) {
                req.apiRequest.requestObj.reuploadedDocs = [];
            }
            ApzCOB.addDisableToInput('RPCDBV__RPCDBVerify__AccpetNextbtn');
            popUpObj = {
                text: "Processing Data! Please wait...",
                Btn1: { text: "", onClick: "" },
                Btn2: { text: "", onClick: "" }
            };
            ApzCOB.showNewCommonConfirmationModal(popUpObj);
            setTimeout(() => {
                // apz.startLoader();
                ApzCOB.serverBuildParam(gAppId, "UploadDBKITLoanData", "N", "N", req, false, ApzCOB.rpcDBVerifyStagesCB);
            }, 1000);
        } else {
            const popUpObj = {
                text: 'Please fill the mandatory fields.!',
                Btn1: {
                    text: "OK",
                    onClick: 'apz.app.RpcStageScreen.closeRPCErrMdl()'
                }
            };
            ApzCOB.showRpcModals(popUpObj, "Error");
        }
    },
    rpcDBVerifyStagesCB: function (params) {
        // apz.stopLoader();
        ApzCOB.removeDisableToInput('RPCDBV__RPCDBVerify__AccpetNextbtn');
        if ($('#APZCBO__BaseScreens__newCommonConfModal').hasClass('in')) {
            ApzCOB.toggleModal(`${BaseScrId}newCommonConfModal`);
        }
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.updateInsessionData(params);
                ApzCOB.updateSideMenuStatusTags();
                //apz.app.RPCFooter.updateQueriesWithLatestDateTime();
                //ApzCOB.moveToNextStageOnVerification();
                if ((RPCDBVerify_STAGES[apz.childScr].id == 1 && window.sanctionDtlsQueries.length !== 0) || (RPCDBVerify_STAGES[apz.childScr].id == 2 && window.eNachQueries.length !== 0) || (RPCDBVerify_STAGES[apz.childScr].id == 3 && window.udyamQueries.length !== 0) || (RPCDBVerify_STAGES[apz.childScr].id == 4 && inSessionStore.dbVerificationQueries.length !== 0)) {
                    apz.app.RPCDBVerify.addErrorStatus(`${DBVerifyscrId}stage_${RPCDBVerify_STAGES[apz.childScr].id}`);
                } else {
                    apz.app.RPCDBVerify.addCompleteStatus(`${DBVerifyscrId}stage_${RPCDBVerify_STAGES[apz.childScr].id}`);
                }
                apz.app.RPCDBVerify.nextBtn();
            }
        } catch (error) {
            ApzCOB.showCommonErrRPCModal();
        }
    },
    previewModal: function () {
        window.previousScreenId = apz.childScr;
        window.previousMicroAppId = apz.currAppId;
        if (RPC_ALL_STAGE_QUERIES.length === 0 || RPC_ALL_STAGE_FIELDS.length === 0) ApzCOB.fetchRpcStageFields("ReviewConfirm");
        window.isRpcPreviewEnabled = true;
        let previewrow = BaseScrId + "preview_row";
        $(`#${previewrow}`).html('');
        if (isRpcDashboardPreview) {
            window.rpcStepperStatus = [];
            window.presentStageFromPreview = 'NewDashBoard';
            ApzCOB.launchMicroApp("RPC", "ReviewConfirm", previewrow, "");
        } else {
            isRpcPreview = true;
            window.presentStageFromPreview = RPC_CURRENT_STAGE;
            ApzCOB.launchSubScreen("ReviewConfirm", previewrow, "");
        }
        // ApzCOB.toggleModal(BaseScrId + "preview_modal");
        // $("#APZCBO__BaseScreens__preview_row_apz_1").addClass("sno");
        // $("#APZCBO__BaseScreens__preview_row_apz_2").removeClass("sno ssp");
    },
    RPCDBpreviewModal: function () {
        window.isRpcPreviewEnabled = true;
        var previewrow = BaseScrId + "preview_row";
        $(`#${previewrow}`).html('');
        window.presentStageFromPreview = 'NewDashBoard';
        ApzCOB.launchMicroApp("RPCDBV", "RPCDBVerify", previewrow, "");
    },
    updateInsessionData: function (params) {
        var ifaceName = ApzCOB.GetInterfaceResMap(params);
        var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
        gApzCOB.requestNodes = [];
        gApzCOB.requestNodes = response;
        if (!apz.isNull(response.applnWfDefinitionList)) {
            gApzCOB.applnWorkFlowRes = response.applnWfDefinitionList;
        }
        inSessionStore = {};
        inSessionStore = structuredClone(gApzCOB.requestNodes);
        if (inSessionStore.applicationDocumentsWrapperList.length > 0) {
            ApzCOB.handleDocumentsSessionStore();
        }
        if (apz.childScr === 'UploadDocuments') {
            if (!apz.isNull(response.cibilDetailsWrapperList) && response.cibilDetailsWrapperList.length > 0) {
                response.cibilDetailsWrapperList.map((cibil) => {
                    let cbDatObj = cibil.cibilDetails.cbDate;
                    let cbDateFormatted = `${cbDatObj.year}-${cbDatObj.month}-${cbDatObj.day}`;
                    cibil.cibilDetails.cbDate = ApzCOB.dateformatter(cbDateFormatted, "Y-m-d");
                });
            }
            apz.app.BaseScreens.parseJsonFetchResponse();
            apz.app.BaseScreens.updatePrimaryDetails();
        } else {
            ApzCOB.userDetailsData();
        }
        apz.app.BaseScreens.parseJsonRPCFetchResponse();
        if (inSessionStore.hasOwnProperty("approvedDocs")) window.approvedDocs = [...inSessionStore.approvedDocs];
        if (inSessionStore.hasOwnProperty("dbVerificationQueries")) window.dbVerificationQueries = [...inSessionStore.dbVerificationQueries];
        if (inSessionStore.hasOwnProperty("reuploadedDocs")) window.reuploadedDocs = [...inSessionStore.reuploadedDocs];
        if (inSessionStore.hasOwnProperty("documentList")) window.documentList = [...inSessionStore.documentList];
        if (gApzCOB.selectedRole == 'RPC_DB_verification' && data.isRework === 'true') {
            let allStages = '';
            let setStages = '';
            allStages = ['1_A', '2_A', '3_A', '4_A'];
            var storeStagets = new Date().toISOString().slice(0, 23);
            if (window.dbVerificationQueries.length == '0') {
                setStages = allStages;
            } else {
                setStages = allStages.filter(stage => stage !== '4_A');
            }
            var amberdStages = inSessionStore?.dbKitStatDetails?.map(item => item.stageID);
            var setSuccessstage = setStages?.filter(stage => {
                const stageNum = parseInt(stage?.split('_')[0], 10);
                return !amberdStages?.includes(stageNum);
            });
            updatedsuccStages = setSuccessstage?.map(stage => `${stage}_${storeStagets}`);
            if (inSessionStore.hasOwnProperty("dbKitVerifiedStage")) inSessionStore.dbKitVerifiedStage = window.updatedsuccStages;
        }
        if (ApplicationType === 'RENEWAL' && !isRenewalPopupEnabled) {
            CO_APP_ADDED_COUNT = 2;
        } //Co-App Freeze
    },
    getOccupationSubMenuID: function (stageId, subMenus, subMenuIndex) {
        let subMenuId = 0;
        let subMenuOcc = subMenus[subMenuIndex];
        if (subMenus.length > 1) {
            subMenuId = subMenuIndex + 1;
        } else {
            let occCustType = ApzCOB.setApplicantTypeBasedOnOcc(subMenuOcc, true);
            if (occCustType === 'Applicant') {
                subMenuId = 1;
            } else {
                subMenuId = 2;
            }
        }
        return subMenuId;
    },
    updateSideMenuStatusTags: function () {
        if (apz.isObjectEmpty(inSessionStore) || !Array.isArray(inSessionStore.verifiedStage) || apz.isNull(inSessionStore.rpcStatDetails)) {
            return [];
        }
        let verifiedStageResp = inSessionStore.verifiedStage;
        let rpcStats = inSessionStore.rpcStatDetails;
        let verifiedStages = ApzCOB.getVerifiedStageInfo(verifiedStageResp);
        ApzCOB.fetchRpcOccupationTabs();
        let updatedStatus = [];
        verifiedDate = '';
        Object.values(RPC_STAGES).forEach(rpcStage => {
            if (rpcStage.id !== 10) {
                let subMenus = rpcStage.subMenu;
                if (subMenus.length > 0) {
                    subMenus.forEach((subMenu, index) => {
                        let subMenuID = ([6, 7].includes(rpcStage.id)) ? ApzCOB.getOccupationSubMenuID(rpcStage.id, subMenus,
                            index) : (subMenu === "Applicant" ? 1 : 2);
                        let subMenuLetter = ([6, 7].includes(rpcStage.id)) ? (subMenuID === 1 ? 'A' : 'C') : (subMenu ===
                            "Applicant" ? 'A' : 'C');
                        let statData = rpcStats.find(stat => stat.stageID === rpcStage.id && stat.custType ===
                            subMenuLetter) || {};
                        verifiedDate = ApzCOB.getDateTimeByType(verifiedStageResp, `${rpcStage.id}_${subMenuLetter}`);
                        let isVerified = verifiedStages.some(stage => stage.stageID === rpcStage.id && stage.subStage
                            .includes(subMenuID));
                        let isQueryExist = isVerified && Array.isArray(statData.query) && statData.query.length > 0;
                        let isEdited = !isVerified && ((Array.isArray(statData.query) && statData.query.length > 0) || (Array
                            .isArray(statData.editedFields) && statData.editedFields.length > 0));
                        updatedStatus.push({
                            stageID: rpcStage.id,
                            subMenu: subMenuID,
                            isVerified,
                            isEdited,
                            isQueryExist,
                            verifiedDate
                        });
                    });
                } else {
                    let subMenuLetter = '';
                    let subMenuID = "";
                    if (rpcStage.id === 3) {
                        subMenuLetter = 'C';
                        subMenuID = 2;
                    } else {
                        subMenuLetter = 'A';
                        subMenuID = 1;
                    }
                    let statData = rpcStats.find(stat => stat.stageID === rpcStage.id && stat.custType === subMenuLetter) || {};
                    verifiedDate = ApzCOB.getDateTimeByType(verifiedStageResp, `${rpcStage.id}_${subMenuLetter}`);
                    let isVerified = verifiedStages.some(stage => stage.stageID === rpcStage.id && stage.subStage.includes(
                        subMenuID));
                    let isQueryExist = isVerified && Array.isArray(statData.query) && statData.query.length > 0;
                    let isEdited = !isVerified && ((Array.isArray(statData.query) && statData.query.length > 0) || (Array.isArray(
                        statData.editedFields) && statData.editedFields.length > 0));
                    updatedStatus.push({
                        stageID: rpcStage.id,
                        subMenu: subMenuID,
                        isVerified,
                        isEdited,
                        isQueryExist,
                        verifiedDate
                    });
                }
            }
        });
        window.rpcStepperStatus = updatedStatus;
        // if (inSessionStore.applicationMaster.applicationStatus === 'RPCPUSHBACK') {
        window.rpcStepperStatus = ApzCOB.updateRPCSendbackStatus();
        // }
        ApzCOB.updateRpcStepper();
    },
    getDateTimeByType: function (array, type) {
        const entry = array.find(item => item.startsWith(type));
        if (!entry) return null;
        const dateTimeStr = entry.split('_')[2];
        let formattedDateTime = '';
        if (dateTimeStr.includes("T")) {
            formattedDateTime = ApzCOB.dateformatter(dateTimeStr, "date", "d/m/Y").split('.')[0] ?? dateTimeStr;
        }
        return formattedDateTime;
    },
    getVerifiedStageInfo: function (stages) {
        let result = [];
        let stageMap = new Map();
        stages.forEach(item => {
            let [stage, subStage] = item.split("_");
            let stageID = parseInt(stage, 10);
            let subStageValue = subStage === 'A' ? 1 : 2;
            if (stageID === 3) {
                subStageValue = 2;
            }
            if (!stageMap.has(stageID)) {
                stageMap.set(stageID, {
                    stageID,
                    subStage: []
                });
            }
            if (!stageMap.get(stageID).subStage.includes(subStageValue)) {
                stageMap.get(stageID).subStage.push(subStageValue);
            }
        });
        result = Array.from(stageMap.values());
        return result;
    },
    updateRpcStepper: function () {
        const mainStageId = 'RPC__RPCSidebar__menuBarList_row_-1_';
        const subStageId = 'RPC__RPCSidebar__subMenuItem_';
        if (!rpcStepperStatus.length) return;
        rpcStepperStatus.forEach(step => {
            const cssClassMap = {
                isEdited: 'war',
                isQueryExist: 'err',
                isVerified: 'active'
            };
            let cssClass = Object.keys(cssClassMap).find(key => step[key]) ? cssClassMap[Object.keys(cssClassMap).find(key => step[
                key])] : '';
            let sendBackStages = ApzCOB.checkIfRPCSendback();
            if (sendBackStages) {
                if (sendBackStages.has(`${step.stageID}_${step.subMenu}`) && !step.isVerified) {
                    cssClass = 'war'
                } else if (cssClass.includes('war')) {
                    if (step.isVerified && step.isQueryExist) {
                        cssClass = 'err'
                    } else {
                        cssClass = 'active';
                    }
                }
            }
            const mainStepElement = $(`#${mainStageId}${step.stageID} .mainStage a.mainMenu`);
            const stepElement = $(`#${mainStageId}${step.stageID} #${subStageId}${step.subMenu} a.subMenulink`);
            mainStepElement.removeClass("war err active");
            stepElement.removeClass("war err active");
            $(`#${mainStageId}${step.stageID}`).removeClass('pl20');
            if (stepElement.length) {
                stepElement.addClass(cssClass);
            }
            if (mainStepElement.length) {
                mainStepElement.addClass(cssClass);
                if (!apz.isNull(cssClass)) $(`#${mainStageId}${step.stageID}`).addClass('pl20');
            }
        });
    },
    updateRPCSendbackStatus: function () {
        let editedKeys = '';
        editedKeys = ApzCOB.checkIfRPCSendback();
        if (!editedKeys) return rpcStepperStatus;
        function isStageVerified(stageID, subMenu) {
            verifiedStgData = inSessionStore.verifiedStage?.find(el => el.split('_')[0] === stageID && custTypeToSubMenu[el.split('_')[1]].toString() === subMenu);
            return apz.isNull(verifiedStgData) ? false : true;
        }
        function checkQueryExists(stageID, subMenu) {
            queryData = inSessionStore.rpcStatDetails?.find(el => el.stageID === stageID && custTypeToSubMenu[el.custType] === subMenu && el.query.length > 0);
            return (apz.isNull(queryData)) ? false : true;
        }
        const updatedStepperStatus = rpcStepperStatus.map(entry => {
            isStgVerified = isStageVerified(entry.stageID.toString(), entry.subMenu.toString())
            const key = `${entry.stageID}_${entry.subMenu}`;
            return {
                ...entry,
                isVerified: !isStgVerified ? !editedKeys.has(key) : isStgVerified,
                isQueryExist: checkQueryExists(entry.stageID, entry.subMenu)
            };
        });
        return updatedStepperStatus;
    },
    checkIfRPCSendback: function () {
        let editedKeys = '';
        let lastTimeline = inSessionStore.applicationTimelineDtl[inSessionStore.applicationTimelineDtl.length - 1];
        let lastSecondTimeline = inSessionStore.applicationTimelineDtl?.[inSessionStore.applicationTimelineDtl.length - 2];
        if (lastTimeline.actionTaken === "RPC Pushback By" && lastTimeline.stage === "RPC Checker" && lastTimeline.hasOwnProperty("rpcStatRemaks")) {
            editedKeys = new Set(lastTimeline.rpcStatRemaks.filter(item => item.query.length > 0).map(item =>
                `${item.stageID}_${custTypeToSubMenu[item.custType]}`));
        } else if (lastTimeline.actionTaken === "Submitted By" && lastTimeline.stage.includes("KM") && lastTimeline.hasOwnProperty("remarks")) {
            if (lastTimeline.remarks.includes(`"response":`)) {
                let lastSendbackTM = inSessionStore.applicationTimelineDtl[inSessionStore.applicationTimelineDtl.length - 2];
                if (lastSendbackTM.stage.includes('RPC') && lastSendbackTM.hasOwnProperty("rpcStatRemaks")) {
                    editedKeys = new Set(lastSendbackTM.rpcStatRemaks.filter(item => item.query.length > 0).map(item =>
                        `${item.stageID}_${custTypeToSubMenu[item.custType]}`));
                }
            }
        } else if (lastSecondTimeline?.actionTaken === "RPC Pushback By" && lastSecondTimeline?.stage === "RPC Checker" && lastSecondTimeline?.hasOwnProperty("rpcStatRemaks")) {
            editedKeys = new Set(lastSecondTimeline.rpcStatRemaks.filter(item => item.query.length > 0).map(item =>
                `${item.stageID}_${custTypeToSubMenu[item.custType]}`));
        }
        return (editedKeys && editedKeys?.size === 0) ? false : editedKeys;
    },
    moveToNextStageOnVerification: function () {
        const subStageId = `RPC__${RPC_CURRENT_STAGE}__rpcStageSubmenuItem_`;
        if (!rpcStepperStatus.length) return;
        let currentSubStage = custType === 'Applicant' ? 1 : 2;
        let currentStageDetails = rpcStepperStatus.filter(rpc => rpc.stageID === RPC_CURRENT_STAGE_NO);
        let nextSubStage = currentSubStage === 1 ? 2 : 1;
        let checkNextSubStageExist = currentStageDetails.filter(stage => stage.subMenu === nextSubStage);
        let navigateToSubMenu = false;
        if (checkNextSubStageExist.length > 0) {
            let isNextStageVrified = checkNextSubStageExist?.[0]?.isVerified;
            if (!isNextStageVrified) {
                navigateToSubMenu = true;
            }
        }
        if (navigateToSubMenu) {
            $(`#${subStageId}${nextSubStage}`).click();
        } else {
            let isValid = ApzCOB.checkNextSideMenuVisible()
            if (isValid) {
                apz.app.RPCSidebar.navigateToStage(RPC_CURRENT_STAGE_NO)
            }
        }
    },
    checkNextSideMenuVisible: function () {
        let rpcSideMenuTag = 'RPC__RPCSidebar__menuBarList_row_-1_';
        if (RPC_CURRENT_STAGE_NO !== 10) {
            ++RPC_CURRENT_STAGE_NO;
        }
        if ($(`#${rpcSideMenuTag}${RPC_CURRENT_STAGE_NO}`).hasClass('sno')) {
            ApzCOB.checkNextSideMenuVisible();
        }
        return true;
    },
    paintingQuery: function () {
        let applType = "";
        let currApplicantQueries = [];
        let finalQueries = [];
        applType = (custType === 'Applicant') ? "A" : "C";
        currApplicantQueries = JSON.parse(RPC_CURRENT_STAGE_FIELDS?.[0]?.queries)?.[custType];
        let queryDtls = inSessionStore?.rpcStatDetails?.filter(item => item.stageID === RPC_CURRENT_STAGE_NO && item.custType === applType);
        if (queryDtls?.length > 0) {
            const queryIds = [];
            const matchingValues = [];
            queryDtls[0].query.forEach(q => {
                if (q.startsWith("oth?")) {
                    let customValue = q.split('?')[1];
                    matchingValues.push({
                        query: customValue
                    });
                } else {
                    queryIds.push(q.includes('?') ? q.split('?')[0] : q);
                }
            });
            matchingValues.push(...currApplicantQueries.filter(item => queryIds.includes(item.id)).map(item => ({
                query: item.value
            })));
            finalQueries = matchingValues.map((item, index) => {
                return {
                    query: (index + 1) + '. ' + item.query
                };
            });
            return finalQueries;
        } else {
            return [];
        }
    },
    paintingQueryReviewConfm: function (applType, stageId) {
        // let applType = "";
        let currApplicantQueries = [];
        let finalQueries = [];
        // applType = (custType === 'Applicant') ? "A" : "C";
        currApplicantQueries = RPC_ALL_STAGE_QUERIES.find(query => query.stageID === stageId && query.custType === applType)
        // currApplicantQueries = JSON.parse(RPC_ALL_STAGE_QUERIES?.[0]?.queries)?.[custType];
        let queryDtls = inSessionStore?.rpcStatDetails?.filter(item => item.stageID === stageId && item.custType === applType);
        if (queryDtls?.length > 0) {
            const queryIds = [];
            const matchingValues = [];
            queryDtls[0].query.forEach(q => {
                if (q.startsWith("oth?")) {
                    let customValue = q.split('?')[1];
                    matchingValues.push({
                        query: customValue
                    });
                } else {
                    queryIds.push(q.includes('?') ? q.split('?')[0] : q);
                }
            });
            if (!apz.isObjectEmpty(currApplicantQueries)) {
                matchingValues.push(...currApplicantQueries.query.filter(item => queryIds.includes(item.id)).map(item => ({
                    query: item.value
                })));
            }
            if (matchingValues.length > 0) {
                finalQueries = matchingValues.map((item, index) => {
                    return {
                        query: (index + 1) + '. ' + item.query
                    };
                });
                let revCnfrmScrId = 'RPC__ReviewConfirm__';
                let subMenuId = applType === 'A' ? 1 : 2;
                let verifiedDate = rpcStepperStatus.find(ver => ver.stageID === stageId && ver.subMenu === subMenuId)?.verifiedDate;
                if (!apz.isNull(verifiedDate)) {
                    let subStageId = subMenuId;
                    if ([3, 4, 5, 8].includes(stageId)) {
                        subStageId = 0;
                    }
                    $(`#${revCnfrmScrId}RpcStage_${stageId} #${revCnfrmScrId}RPC_SubStage_${subStageId} .revCnfrmQueryText label.flb.pri`)
                        .text(`Query (${verifiedDate})`);
                }
            } else {
                $(queryStageID).parent().addClass("sno");
            }
            return finalQueries;
        } else {
            return [];
        }
    },
    RpcBRECallBack: function () {
        apz.app.RpcStageScreen.closeRPCConfirmarionMdl();
        const cbStatus = custType === 'Applicant' ? APPLICANT_CIBIL_STATUS : CO_APPLICANT_CIBIL_STATUS;
        let customerType = custType === 'Applicant' ? custType : 'Co-Applicant';
        let popUpObj = cbStatus ? {
            text: `CB Pass for the details.!`,
            Btn: {
                text: "Ok",
                onClick: "apz.app.RpcStageScreen.closeSuccessModal()",
            }
        } : {
            text: `The CB check has failed.<br/>Reject reason: ${cibilDtls?.rejectionReason || '-'}.<br/> Would you like to reject the application?`,
            Btn1: {
                text: "Yes",
                onClick: `ApzCOB.closeCommonModal('newCommonConfModal'); apz.app.RPCFooter.approveReject(this,'REJECTED','${customerType} CB Decision Failed.Reason: ${cibilDtls?.rejectionReason || "-"}')`
            },
            Btn2: {
                text: "No",
                onClick: "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()"
            }
        };
        if (!cbStatus) {
            if (!retry_Attempts || retry_Attempts === 0) {
                let errMsgBRE = `CB retrigger limit exceeded.Reject the application.<br/>Reject reason: ${cibilDtls?.rejectionReason ?? '-'}.`;
                if (cibilDtls?.irisMessage?.includes('success')) {
                    errMsgBRE = `CB check failed!.Reject the application.<br/>Reject reason: ${cibilDtls?.rejectionReason ?? '-'}.`
                }
                popUpObj = {
                    text: errMsgBRE,
                    Btn: {
                        text: "Ok",
                        onClick: `ApzCOB.closeCommonModal('newCommonErrModal'); apz.app.RPCFooter.approveReject(this,'REJECTED','CB Decision Failed.Reason: ${cibilDtls?.rejectionReason || "-"}')`
                    }
                };
                ApzCOB.showNewCommonErrorModal(popUpObj);
                apz.stopLoader();
                return;
            } else {
                let errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Remaining retry attempts: ${retry_Attempts}.<br/>Do you want to rehit BRE?`
                if (cibilDtls?.irisMessage?.includes('bureauError') && !cibilDtls?.irisMessage?.includes('roll')) {
                    errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Do you want to rehit BRE?`
                }
                popUpObj = {
                    text: errMsgBRE,
                    Btn1: {
                        text: "Yes",
                        onClick: "ApzCOB.closeCommonModal(`newCommonConfModal`); ApzCOB.BRECbService()"
                    },
                    Btn2: {
                        text: "No",
                        onClick: "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()"
                    }
                }
            }
        }
        apz.stopLoader();
        ApzCOB.showRpcModals(popUpObj, cbStatus ? "Success" : "confirmation");
        // ApzCOB.handleCancelButtonClick();
        if (RPC_CURRENT_STAGE === 'ReviewConfirm') {
            apz.app.ReviewConfirm.loadRevConfScr();
            apz.app.onShown_ReviewConfirm();
        }
    },
    checkCBStatusPass: function () {
        let valid = false;
        if (custType === 'Applicant' && !isRPCLogin) {
            if (APPLICANT_CIBIL_STATUS === "PASS") {
                valid = true;
            }
        } else {
            if (CO_APPLICANT_CIBIL_STATUS === "PASS") {
                valid = true;
            }
        }
        return valid;
    },
    capitalize: function (str) {
        return str.charAt(0).toUpperCase() + str.slice(1).toLowerCase();
    },
    scrollToStart: function (elemId) {
        const div = document.getElementById(elemId);
        if (div) {
            div.scrollLeft = 0;
            div.scrollTop = 0;
        }
    },
    checkRpcPushbackEditable: function () {
        ApzCOB.getTimeLineDtls();
    },
    getTimeLineDtls: function () {
        let rpcStats = [];
        let rpcPushbackQueries = [];
        let activeSubMenu = custType === 'Applicant' ? 'A' : 'C';
        if (inSessionStore?.applicationMaster?.applicationStatus === "RPCPUSHBACK" && gApzCOB.selectedRole === 'RPC_Maker') {
            const timelineDetails = inSessionStore?.applicationTimelineDtl;
            if (timelineDetails?.length > 0) {
                rpcPushbackQueries = timelineDetails[timelineDetails.length - 1].rpcStatRemaks || [];
            }
            rpcStats = rpcPushbackQueries.filter(timeDtl => timeDtl.stageID === RPC_CURRENT_STAGE_NO && timeDtl.custType === activeSubMenu);
            if (rpcStats.length > 0) {
                $('.rpcEditBtn').removeClass('sno');
            } else {
                $('.rpcEditBtn').addClass('sno');
            }
        }
        return rpcStats;
    },
    chekPushbackQueries: function (rpcStatics) {
        let rpcStats = ApzCOB.getTimeLineDtls();
        if (!apz.isNull(rpcStatics)) {
            rpcStats = rpcStatics;
        }
        let finalQueries = [];
        if (rpcStats.length > 0) {
            const queries = rpcStats[0]?.query || [];
            if (queries.length > 0) {
                let stageQueries = JSON.parse(RPC_CURRENT_STAGE_FIELDS[0].queries)?.[custType] || [];
                if (stageQueries.length > 0 || RPC_CURRENT_STAGE_NO === 9) {
                    const queryIds = queries.map(q => (q.includes('?') ? q.split('?')[0] : q));
                    const matchingValues = queries.filter(q => q.startsWith("oth?")).map(q => ({
                        query: q.split('?')[1]
                    }));
                    matchingValues.push(...stageQueries.filter(item => queryIds.includes(item.id)).map(item => ({
                        query: item.value
                    })));
                    finalQueries = matchingValues.map((item, index) => ({
                        query: `${index + 1}. ${item.query}`
                    }));
                }
            }
        }
        return finalQueries;
    },
    convertDateFormat: function (dateStr, toFormat) {
        let parsedDate;
        if (/^\d{2}\/\d{2}\/\d{4}$/.test(dateStr)) {
            let [day, month, year] = dateStr.split("/");
            parsedDate = new Date(`${year}-${month}-${day}`);
        } else if (/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) {
            parsedDate = new Date(dateStr);
        } else {
            return ""; //Invalid Date Format
        }
        if (isNaN(parsedDate.getTime())) {
            return "";
        }
        let year = parsedDate.getFullYear();
        let month = String(parsedDate.getMonth() + 1).padStart(2, '0');
        let day = String(parsedDate.getDate()).padStart(2, '0');
        switch (toFormat.toLowerCase()) {
            case "dd/mm/yyyy":
                return `${day}/${month}/${year}`;
            case "yyyy-mm-dd":
                return `${year}-${month}-${day}`;
            default:
                return "";
        }
    },
    showInputErrMsg: function (pthis) {
        $(pthis).next('.err').remove();
        let parentID = (pthis.id).replace('Input', '');
        $(`#${parentID}`).addClass('err-inpt');
        $(fieldValidationErr).insertAfter(pthis);
    },
    getStageStatus: function (stageId, subStageId) {
        const cssClassMap = {
            isEdited: 'icon-sideprg',
            isQueryExist: 'icon-fail-filled',
            isVerified: 'icon-success-filled'
        };
        let cssClass = '';
        if ([3, 4, 5, 8].includes(stageId) && subStageId.length === 0) {
            if (stageId === 3) {
                subStageId = 2;
            } else {
                subStageId = 1;
            }
        }
        if (apz.isNull(rpcStepperStatus) || rpcStepperStatus.length === 0) return;
        let curStageStatus = rpcStepperStatus.find(stage => stage.stageID === stageId && stage.subMenu === subStageId);
        if (!apz.isObjectEmpty(curStageStatus)) {
            cssClass = Object.keys(cssClassMap).find(key => curStageStatus[key]) ? cssClassMap[Object.keys(cssClassMap).find(key =>
                curStageStatus[key])] : '';
            let sendBackStages = ApzCOB.checkIfRPCSendback();
            if (sendBackStages) {
                if (sendBackStages.has(`${stageId}_${subStageId}`) && !curStageStatus.isVerified) {
                    cssClass = cssClassMap['isEdited'];
                } else if (cssClass.includes('icon-sideprg')) {
                    if (curStageStatus.isVerified && curStageStatus.isQueryExist) {
                        cssClass = cssClassMap['isQueryExist'];
                    } else {
                        cssClass = cssClassMap['isVerified'];
                    }
                }
            }
        }
        return cssClass;
    },
    mapAddrTypeforStageId: function (stageNo) {
        switch (stageNo) {
            case 7:
                addrType = "Occupation", subAddrType = "Office";
                break;
            case 5:
            case 4:
                addrType = "Personal", subAddrType = "Present";
                break;
            case 2:
                addrType = 'Personal', subAddrType = 'SecondaryKyc';
                break;
        }
    },
    insDataHandling: function (scrid, custType, insFieldIds) {
        var applInsData = inSessionStore.insuranceDetailsWrapperList.filter(el => el.insuranceDetails.custDtlId === ApzCOB.getCustDetailID(
            'Applicant'));
        var applInsReq = applInsData?.[0]?.insuranceDetails?.payload?.insuranceReqd?.toUpperCase();
        var coAppInsReq = applInsData[0]?.insuranceDetails?.payload?.coApplicantInsurance?.toUpperCase();
        if (['Y'].includes(applInsReq) || ['Y'].includes(coAppInsReq)) {
            if (scrid === "RPC__OtherInformationRPC__") {
                $(`#${scrid}insuranceReqdInput_option_Yes`).prop('checked', true);
                $(`#${scrid}coApplicantInsuranceInput_option_Yes`).prop('checked', true);
            } else {
                if (insObj?.applInsId) $(`${insObj.applInsId} `).text(['Y', 'YES'].includes(applInsReq) ? 'Yes' : 'No');
                if (insObj?.coApplInsId) $(`${insObj?.coApplInsId}`).text(['Y', 'YES'].includes(coAppInsReq) ? 'Yes' : 'No');
            }
        }
        if (['Y', 'YES'].includes(applInsReq) && ['Y', 'YES'].includes(coAppInsReq)) return;
        if (['N', 'NO'].includes(applInsReq) || (custType !== 'Applicant' && ['N', 'NO'].includes(coAppInsReq))) {
            if (scrid === "RPC__OtherInformationRPC__") {
                $(`#${scrid}coApplicantInsuranceInput_option_No`).prop('checked', true);
                insFields.forEach(el => $(`#${scrid + el}`).addClass('sno'));
            } else {
                if (insObj?.applInsId) $(`${insObj.applInsId}`).text(['N', 'NO'].includes(applInsReq) ? 'No' : 'Yes');
                if (insObj?.coApplInsId) $(`${insObj?.coApplInsId}`).text('No');
                insFieldIds.forEach(el => $(`${el}`).addClass('sno'));
            }
            return;
        }
    },
    formatToTwoDigits: function (num) {
        return num.toString().padStart(2, '0');
    },
    formatIndianRupees: function (amtVal) {
        if (typeof amtVal === 'string') {
            amtVal = amtVal.replace(/₹/g, '').trim();
            if (!amtVal.includes(',')) amtVal = parseInt(amtVal) || 0;
        }
        return amtVal ? '₹ ' + amtVal.toLocaleString('en-IN') : '₹ 0';
    },
    unformatIndianRupees: function (formattedValue) {
        return parseInt(formattedValue.replace(/[^0-9]/g, ''), 10) || 0;
    },
    caDownloadDocument: function (imgid) {
        let custType;
        if (imgid.split("__")[2] === 'A') {
            custType = 'Applicant';
        } else if (imgid.split("__")[2] === 'C') {
            custType = 'Co-App';
        }
        if (apz.currAppId === 'Luc') {
            custType = 'Applicant';
        }
        var request = {};
        var params = {};
        request.applicationId = inSessionStore.applicationId;
        request.applicantType = custType;
        request.documentType = $('#' + imgid).attr("documentName");
        params.callBackObj = this;
        params.buildReq = "N";
        params.paintResp = "N";
        params.req = request;
        params.appId = gAppId;
        params.ifaceName = "MergeAndDownloadPDF";
        params.async = true;
        params.callBack = ApzCOB.caDownloadDocumentCB;
        apz.startLoader();
        apz.server.callServer(params);
    },
    caDownloadDocumentCB: function (params) {
        apz.stopLoader();
        if (ApzCOB.handleServiceCallBacks(params)) {
            try {
                let response = params.res.APZCBO__MergeAndDownloadPDF_Res.apiResponse.ResponseBody.responseObj;
                const base64Response = JSON.parse(response);
                ApzCOB.convertBase64ToPDF(base64Response.base64, params.req.documentType);
            } catch (e) {
                // ApzCOB.showRpcModals({
                //     text: technicalErrMsg,
                //     Btn1: {
                //         text: "OK",
                //         onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
                //     }
                // }, "Error");
            }
        } else {
            // ApzCOB.showRpcModals({
            //     text: technicalErrMsg,
            //     Btn1: {
            //         text: "OK",
            //         onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
            //     }
            // }, "Error");
        }
    },
    showCaModals: function (propObj, modalType) {
        let CaModalId = "CrdAss__Cabase__";
        if (modalType === "confirmation") {
            $(`#${CaModalId}confirmationText_txtcnt`).html(propObj.text);
            if (!apz.isNull(propObj.Btn1.text) || !apz.isNull(propObj.Btn2.text)) {
                $(`#${CaModalId}confrmBtn1_txtcnt`).html(propObj.Btn1.text ? propObj.Btn1.text : "Yes");
                $(`#${CaModalId}confrmBtn2_txtcnt`).html(propObj.Btn2.text ? propObj.Btn2.text : "No");
                $(`#${CaModalId}confrmBtn1`).attr("onclick", propObj.Btn1.onClick);
                $(`#${CaModalId}confrmBtn2`).attr("onclick", propObj.Btn2.onClick);
                $(`#${CaModalId}conFormation_mdl .suc-btns`).removeClass('sno');
            } else {
                $(`#${CaModalId}conFormation_mdl .suc-btns`).addClass('sno');
            }
            ApzCOB.toggleModal(`${CaModalId}CaConformation_modal`);
        } else if (modalType === "Error") {
            $(`#${CaModalId}errorText_txtcnt`).html(propObj.text);
            $(`#${CaModalId}errorBtn1`).attr("onclick", propObj.Btn1.onClick);
            ApzCOB.toggleModal(`${CaModalId}CaError_modal`);
        } else if (modalType === "Success") {
            $(`#${CaModalId}successText_txtcnt`).html(propObj.text);
            $(`#${CaModalId}succBtn`).attr("onclick", propObj.Btn.onClick);
            ApzCOB.toggleModal(`${CaModalId}CaSucc_modal`);
        }
    },
    to24HourFormat: function (timeStr) {
        let [time, modifier] = timeStr.split(' ');
        let [hours, minutes, seconds] = time.split(':');
        if (modifier === "PM" && hours !== "12") {
            hours = String(Number(hours) + 12);
        } else if (modifier === "AM" && hours === "12") {
            hours = "00";
        }
        return `${hours}:${minutes}:${seconds}`;
    },
    formattedTime: function (timeStampVal) {
        if (!timeStampVal) return '';
        let [ldate, time, modifier] = timeStampVal.split(' ');
        let newTime = modifier === 'PM' ? ApzCOB.to24HourFormat(time + ' ' + modifier) : time;
        let lDateTime = `${ldate}T${newTime}`;
        return ApzCOB.dateformatter(lDateTime, "date", "d/m/Y") || '';
    },
    intializeGuillotine: function (picture) {
        picture.guillotine({
            width: 300,
            height: 300
        });
        ApzCOB.imageAction('fit'); //Resize to normal
    },
    imageAction: function (gaction, pid) {
        if (pid) {
            picture = $(`#${pid}`);
        }
        //gaction('rotateLeft','zoomIn','zoomOut','fit')
        gaction = (gaction === "rotateLeft") ? "rotateRight" : gaction;
        if ($('#APZCBO__BaseScreens__compareModal').is(':visible')) {
            $('.compare-active img').guillotine(gaction);
        } else {
