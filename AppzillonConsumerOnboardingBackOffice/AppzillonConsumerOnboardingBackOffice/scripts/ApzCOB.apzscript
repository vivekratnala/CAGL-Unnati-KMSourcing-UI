    documentAutoSaveCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                if (apz.childScr == "UploadDocuments") {
                    ApzCOB.updateInsessionData(params);
                    var responseObj = JSON.parse(params.res.APZCBO__UploadRPCLoanData_Res.apiResponse.ResponseBody.responseObj);
                    window.latestAppDocId = responseObj.applicationDocumentsWrapperList[0].applicationDocumentsList['length'] - 1;
                    appDocID = responseObj.applicationDocumentsWrapperList[0].applicationDocumentsList[latestAppDocId].appDocId;
                    window.storelatitude = JSON.parse(responseObj.applicationDocumentsWrapperList[0].applicationDocumentsList[latestAppDocId].payload).latitude;
                    window.storelongitude = JSON.parse(responseObj.applicationDocumentsWrapperList[0].applicationDocumentsList[latestAppDocId].payload).longitude;
                    apz.app.UploadDocuments.StoreAppDocID(appDocID, storelatitude, storelongitude);
                    apz.app.UploadDocuments.displayFileNameNew();
                }
            }
        } catch (error) {
            ApzCOB.fnDisplayMsg("Document Upload Failed.Please Try Again.!", "E");
        }
    },
    comparemodal: function (pthis) {
        $(".compare-active").removeClass("compare-active");
        isCompare = true;
        window.selectedDocLevel = pthis.textContent;
        selectedDocLevel = selectedDocLevel.replace(/ /g, "_").toUpperCase();
        if (selectedDocLevel === 'ADDRESS_PROOF') {
            addrType = 'Personal'; subAddrType = 'Present';
            residenceAsKYC = ApzCOB.getPayloadDatafromWrapper('currentAddressProof', 'Applicant', 'addressDetailsWrapperList')
            if (/voter|kyc/.test(residenceAsKYC.toLowerCase())) selectedDocLevel = 'PRIMARY_KYC';
        } else if (selectedDocLevel === 'BUSINESS_ADDRESS_PROOF') {
            addrType = 'Occupation'; subAddrType = 'Office';
            let businessAsKYC = ApzCOB.getPayloadDatafromWrapper('businessAddressProof', custType, 'occupationDetailsWrapperList');
            if (/voter|kyc/.test(businessAsKYC.toLowerCase())) selectedDocLevel = 'PRIMARY_KYC';
        }
        pcount = 0;
        rpcCompareRightIndex = 0;
        rpcCompareLeftIndex = 0;
        let fileNameFromSD = ApzCOB.getFileName(pcount);
        if (fileNameFromSD) {
            window.ImageLocationDetails = {
                latitude: window.stageDocuments[pcount].payload.latitude || "",
                longitude: window.stageDocuments[pcount].payload.longitude || "",
                uploadedTs: window.stageDocuments[pcount].payload.uploadedTs || "",
                documentFileName: window.stageDocuments[pcount].payload.documentFileName || ""
            };
            ApzCOB.downloadFileFromServer(fileNameFromSD, ApzCOB.leftImagePaintCB);
        } else {
            ApzCOB.showCommonErrRPCModal("Selected file is not present");
        }
    },
    filteredDocument: function () {
        let docArray = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
        window.selectedFileName = null;
        window.filteredDocumentArray = [];
        var custId = ApzCOB.getCustDetailID(custType);
        if (selectedDocLevel === 'ADDRESS_PROOF') {
            addrType = 'Personal'; subAddrType = 'Present';
            residenceAsKYC = ApzCOB.getPayloadDatafromWrapper('currentAddressProof', 'Applicant', 'addressDetailsWrapperList')
            if (/voter|kyc/.test(residenceAsKYC.toLowerCase())) selectedDocLevel = 'PRIMARY_KYC';
        } else if (selectedDocLevel === 'BUSINESS_ADDRESS_PROOF') {
            addrType = 'Occupation'; subAddrType = 'Office';
            bussAddrTag = ApzCOB.getPayloadDatafromWrapper('addressSameAs', custType, 'addressDetailsWrapperList') === "Present";
            let businessAsKYC = ApzCOB.getPayloadDatafromWrapper('businessAddressProof', custType, 'occupationDetailsWrapperList');
            if (/voter|kyc/.test(businessAsKYC.toLowerCase())) {
                selectedDocLevel = 'PRIMARY_KYC';
            } else if (bussAddrTag) {
                selectedDocLevel = 'ADDRESS_PROOF';
            }
        }
        if (selectedDocLevel === 'BANK_ACCOUNT_PROOF') {
            custId = ApzCOB.getCustDetailID('Applicant');
        }
        let selectedDocTypeArray = [];
        selectedDocTypeArray = docArray.filter(doc => doc.payload.documentType === selectedDocLevel);
        let panStatusVal = ApzCOB.getPayloadDatafromWrapper('panNumberStatus', custType, 'customerDetailsList') === 'Verified';
        if (selectedDocLevel === 'PRIMARY_KYC' && panStatusVal) {
            selectedDocTypeArray = docArray.filter(doc => doc.payload.documentType === selectedDocLevel || doc.payload.documentType === 'PAN_NUMBER_PHOTO');
        }
        if (selectedDocLevel === 'ADDITIONAL_DOCUMENTS') {
            selectedDocTypeArray = docArray.filter(doc => doc.payload.isAdiDoc === 'Y');
        }
        let custDocTyeArray = selectedDocTypeArray.filter(custDoc => custDoc.custDtlId === custId);
        filteredDocumentArray = custDocTyeArray ? structuredClone(custDocTyeArray) : [];
        if (filteredDocumentArray.length > 0) {
            selectedFileName = filteredDocumentArray[0].payload.documentFileName;
            window.ImageLocationDetails = {
                latitude: filteredDocumentArray[0].payload.latitude || "",
                longitude: filteredDocumentArray[0].payload.longitude || "",
                uploadedTs: filteredDocumentArray[0].payload.uploadedTs || "",
                documentFileName: filteredDocumentArray[0].payload.documentFileName || ""
            };
        }
        return selectedFileName;
    },
