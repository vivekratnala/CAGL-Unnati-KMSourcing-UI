    initiateeNachRegistration: function (custType, accNum, bankCode, enachType) {
        req = {
            apiRequest: {
                interfaceName: "RppService",
                appId: gAppId,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                requestObj: {
                    applicationId: gApzCOB.userDetails.applicationId,
                    applicantType: custType,
                    accountNumber: accNum,
                    additionalField2: bankCode,
                    enachType: enachType
                }
            }
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "RppService", "N", "N", req, false, ApzCOB.initiateeNachRegistrationCB);
    },
    initiateeNachRegistrationCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let responseObj = JSON.parse(params.res.APZCBO__RppService_Res.apiResponse.ResponseBody?.responseObj);
                let eNachRespObj = JSON.parse(responseObj?.responseObj);
                window.eNachReqId = eNachRespObj?.enachReqId;
                window.custType = eNachRespObj?.customerType;
                ApzCOB.launchURL(eNachRespObj?.urlString);
                apz.app.eNach.updateENachRespinSessionStore(eNachRespObj);
                if (custType === 'Co-App') {
                    inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.filter(el => el.documentType !== 'DBBankUpdate');
                }
                ApzCOB.checkTransactionStatus(eNachReqId, custType);
            } else {
                errMsg = '';
                if (params?.res?.APZCBO__RppService_Res?.apiResponse?.ResponseHeader?.ResponseMessage) {
                    errMsg = params?.res?.APZCBO__RppService_Res?.apiResponse?.ResponseHeader?.ResponseMessage;
                }
                ApzCOB.showNewCommonErrorModal(errMsg);
            }
        } catch (e) {
            ApzCOB.showNewCommonErrorModal();
        }
    },
    checkTransactionStatus: function (paynimoReqId, custType, retry) {
        if (apz.isNull(retry)) retry = '';
        req = {
            apiRequest: {
                interfaceName: "TransactionStatus",
                appId: gAppId,
                requestObj: {
                    applicationId: gApzCOB.userDetails.applicationId,
                    paynimoRequestId: paynimoReqId,
                    applicantType: custType,
                    retry: retry
                }
            }
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "TransactionStatus", "N", "N", req, false, ApzCOB.checkTransactionStatusCB);
    },
    checkTransactionStatusCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let responseObj = JSON.parse(params.res.APZCBO__TransactionStatus_Res.apiResponse.ResponseBody.responseObj);
                let transresponseObj = JSON.parse(responseObj?.responseObj);
                apz.app.eNach.updateENachRespinSessionStore(transresponseObj);
                if (params.req.apiRequest.requestObj.retry === 'No') {
                    apz.stopLoader();
                    let ApplresDesc = (ApzCOB.getPayloadDatafromWrapper("resDesc", "Applicant", "enachDetails") || '').toLowerCase();
                    let CoAppresDesc = (ApzCOB.getPayloadDatafromWrapper("resDesc", "Co-App", "enachDetails") || '').toLowerCase();
                    if (custType === 'Applicant' && !apz.isNull(CoAppresDesc) && CoAppresDesc === 'pending' && window.firstStatusCall !== 'Co-App') {
                        window.firstStatusCall = 'Co-App';
                        coAppEnachData.enachReqId = ApzCOB.getPayloadDatafromWrapper("enachReqId", "Co-App", "enachDetails");
                        ApzCOB.checkTransactionStatus(coAppEnachData.enachReqId, 'Co-App', 'No');
                        return;
                    } else if (custType === 'Co-App' && !apz.isNull(ApplresDesc) && ApplresDesc === 'pending' && window.firstStatusCall !== 'Applicant') {
                        window.firstStatusCall = 'Applicant';
                        appEnachData.enachReqId = ApzCOB.getPayloadDatafromWrapper("enachReqId", "Applicant", "enachDetails");
                        ApzCOB.checkTransactionStatus(appEnachData.enachReqId, appEnachData.customerType, 'No');
                        return;
                    } else {
                        apz.app.eNach.painteNachScenarios();
                        return;
                    }
                }
                if (transresponseObj?.resDesc?.toLowerCase() === 'pending' && params.req.apiRequest.requestObj.retry !== 'No') {
                    apz.startLoader();
                    currRetryAttempts = (transresponseObj.customerType === 'Applicant') ? ++AppRetryAttempts : ++CoAppRetryAttempts;
                    if (currRetryAttempts <= eNachRetryAttempts) {
                        setTimeout(() => {
                            ApzCOB.checkTransactionStatus(transresponseObj.enachReqId, transresponseObj.customerType);
                        }, eNachTimeoutInSec * 1000);
                    } else {
                        apz.stopLoader();
                        errMsg = 'Exceeded maximum number of retry attempts! Please try again later.';
                        ApzCOB.showNewCommonErrorModal(errMsg);
                        apz.app.eNach.paintFailureScenario(transresponseObj.customerType);
                    }
                } else if (transresponseObj?.resDesc?.toLowerCase() === 'failed') {
                    apz.stopLoader();
                    apz.app.eNach.paintFailureScenario(transresponseObj.customerType);
                } else if (transresponseObj?.resDesc?.toLowerCase() === 'success' || transresponseObj?.resDesc?.toLowerCase() ===
                    'initiated') {
                    // handle success scenario
                    apz.stopLoader();
                    apz.app.eNach.paintSuccessScenario(transresponseObj.customerType);
                }
            } else {
                errMsg = 'Transaction status service failed.' //Paint from resp
                ApzCOB.showNewCommonErrorModal(errMsg);
            }
        } catch (e) {
            ApzCOB.showNewCommonErrorModal();
        }
    },
    stageBasedOnAction: function (pthis, gaction) {
        var clickedAction = "";
        //if (LoggedInUserDetails.loginResponse.addInfo1 == 'BM') {
        if (!apz.isNull(gaction)) {
            if (gaction === 'SUBMIT') {
                clickedAction = "SUBMIT";
            } else if (gaction === "REJECTED") {
                clickedAction = "REJECT";
            } else if (gaction === 'PUSHBACK') {
                clickedAction = 'PUSHBACK';
            } else if (gaction === 'DBCAPUSHBACK') {
                clickedAction = 'DBCAPUSHBACK';
            } else if (gaction === 'DBSANCTIONPUSHBACK') {
                clickedAction = 'DBSANCTIONPUSHBACK';
            } else if (gaction === 'BANKUPDATEPUSHBACK') {
                clickedAction = 'BANKUPDATEPUSHBACK';
            }
        }
        //}
        if (!apz.isNull(gApzCOB.applnWorkFlowRes)) {
            gApzCOB.applnWorkFlowRes.filter(function (laction) {
                laction.action.split(',').filter(function (s) {
                    if (laction.appId === gAppId && clickedAction.split(" ").join("") === s.toLocaleUpperCase()) {
                        gApzCOB.workflow.currentRole = laction.currentRole;
                        gApzCOB.workflow.action = laction.action;
                        gApzCOB.workflow.workflowId = laction.workFlowId;
                        gApzCOB.workflow.stage = laction.fromStageId;
                    }
                });
            });
        };
    },
    setDocValues: function (browseId) {
        if (browseId === 'browseDBKITDOCS' || browseId === 'BrowseDocsManual') {
            window.allowedTypes = {
                "pdf": "pdf"
            };
            let docType = DisbursementDocs[parseInt($('#DBkitG__DocExecutionManual__docsList .active').attr("rowNo"))]?.docType;
            if (uploadDocType === 'ReUpload') {
                docType = selectedReuploadDoc.docType;
            } else if (applicationStatus === 'DBPUSHBACK' && APPROVED_DOCS.length > 0) {
                docType = APPROVED_DOCS[parseInt($('#DBkitG__DocExecutionManual__docsList .active').attr("rowNo"))]?.docType;
            }
            fileSizeLimit = DBKITDOCSIZEMAP?.[0]?.[docType] || dbkitmaxDocUploadSize;
            if (currApplLanguage === "Malayalam" || currApplLanguage === "Odia") {
                fileSizeLimit = 5000;
            }
            /*if (["LOAN_APPLICATION", "LOAN_AGREEMENT"].includes(docType)) {
                fileSizeLimit = 6144;
            }*/
        } else if (['browseDBBankDoc', 'AppBrowseFile'].includes(browseId)) {
            fileSizeLimit = dbkitmaxDocUploadSize;
        }
    },
    browsefile: function (fileObj, browseId, ldocType) {
        dragNdrop = true;
        let groupCode = inSessionStore.applicationMaster.productGroupCode;
        window.allowedTypes = gAllowedFileTypes;
        window.fileSizeLimit = maxDocUploadSize;
        ApzCOB.setDocValues(browseId);
        FileSideBrowseId = browseId;
        var fileExtenName = fileObj.value?.split('.')?.pop();
        let sizeInBytes = fileSizeLimit * 1024;
        if (!Object.values(allowedTypes).includes(fileExtenName?.toLocaleLowerCase()) || fileObj.files[0].size > sizeInBytes) {
            const formatted = `(${Object.keys(allowedTypes).map(t => `${t}`).join(', ')})`;
            ApzCOB.showNewCommonErrorModal(`Upload a valid File ${formatted} under ${ApzCOB.formatSize(sizeInBytes)}.`);
            $('#DBkitG__DocExecutionManual__browseDBKITDOCS').val(''); //empty browse data
            return;
        }
        filesObj = fileObj;
        var fileToUpload = fileObj.files;
        localFileObj = {};
        localFileObj.filename = fileToUpload[0].name;
        localFileObj.filetype = fileToUpload[0].type;
        localFileObj.filePath = `${apz.appId}/${groupCode}/${gApzCOB.userDetails.applicationId}`;
        localFileObj.documentLoc = localFileObj.filelocation = `${apz.appId}/${localFileObj.filename}`;
        localFileObj.docType = ldocType;
        // localFileObj.documentName = docName;
        localFileObj.fieldID = fileObj.id;
        localFileObj.srcScreen = "UPLOADDOCS";
        localFileObj.productGroupCode = groupCode;
        localFileObj.isExistingCustomer = 'N';
        localFileObj.documentFileName = localFileObj.documentFormat = localFileObj.filename;
        localFileObj.docSize = fileObj.files[0].size;
        ApzCOB.fileReader(fileObj, ldocType);
        $(fileObj).val('');
    },
    fileReader: function (fileObj, ldocType) {
        var FR = new FileReader();
        FR.readAsDataURL(fileObj.files[0]);
        FR.onload = function (e) {
            encodedImage = "";
            encodedImage = e.target.result.substr(e.target.result.indexOf(',') + 1, e.target.result.length);
            if (!apz.isNull(encodedImage)) {
                localFileObj.imgSrc = encodedImage;
                localFileObj.base64Value = encodedImage;
                document.getElementById(localFileObj.fieldID).value = "";
                if (ldocType === "DBKITDOCS") {
                    let docType = '';
                    let process = '';
                    let mergeFlag = 'N';
                    if (DB_CURRENT_STAGE_NO === 4) {
                        if (currApplLanguage === "Malayalam" || currApplLanguage === "Odia") {
                            docType = 'DBKIT';
                            process = 'SINGLE_DOC';
                            mergeFlag = 'Y';
                        } else {
                            docType = DisbursementDocs[parseInt($('#DBkitG__DocExecutionManual__docsList .active').attr("rowNo"))]?.docType;
                            process = 'Manual';
                        }
                    } else {
                        docType = DisbursementDocs[parseInt($('#DBkitG__DocExecutionManual__docsList .active').attr("rowNo"))]?.docType;
                        process = 'Manual';
                    }
                    if (uploadDocType === 'ReUpload') {
                        docType = selectedReuploadDoc.docType;
                    } else if (applicationStatus === 'DBPUSHBACK' && APPROVED_DOCS.length > 0) {
                        docType = APPROVED_DOCS[parseInt($('#DBkitG__DocExecutionManual__docsList .active').attr("rowNo"))]?.docType;
                    }
                    ApzCOB.DBDocGenerateAndDownload(encodedImage, process, docType, 'English', mergeFlag, '', localFileObj.docSize);
                } else {
                    ApzCOB.exceptionFileUpload(localFileObj, ldocType);
                }
            }
        }
    },
    DBDocGenerateAndDownload: function (base64, generatetype, docType, language, mergeFlag, cbFn, docSize) {
        /*if (generatetype === 'Generated' && inSessionStore.applicationMaster.applicationStatus !== 'SANCTIONED') {
            return;
        }*/
        let isReuploadFlag = (applicationStatus === "DBPUSHBACK") ? 'Y' : 'N';
        mergeFlag = mergeFlag || 'N';
        docSize = docSize || '';
        let callBackFn = cbFn || ApzCOB.DBDocGenerateAndDownloadCB;
        req = {
            apiRequest: {
                requestObj: {
                    "appId": gAppId, // remove later
                    "base64Value": base64,
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "productGroupCode": inSessionStore.applicationMaster.productCode, //"1002", "1001"
                    "documentLanguage": language, // English, Kannada, Hindi, Marathi, Tamil. First letter caps
                    "documentGenerationType": generatetype, //Manual, Generated, Esign, Delete, Fetch
                    "documentType": docType, //"SanctionLetter" First letter caps
                    "userId": LoggedInUserDetails?.loginResponse?.addInfo1,
                    "mergeDocument": mergeFlag,
                    "docSize": docSize,
                    "isReupload": isReuploadFlag
                }
            }
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "DbKitDocGenerationAndDownload", "N", "N", req, false, callBackFn);
    },
    welcomeKitGenrateCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                var ifaceName = ApzCOB.GetInterfaceResMap(params);
                let responseObj = params.res[ifaceName].apiResponse.ResponseBody.responseObj;
                let parsedResp = JSON.parse(responseObj);
                let State = inSessionStore.leadDetails?.glBranchState || inSessionStore.renewalLeadDetails?.glBranchState;
                let match = language.find(item => item.key.toLowerCase().includes(State.toLowerCase()));
                window.leadLanguage = match ? match.value : '';
                if (leadLanguage === "Malayalam" || leadLanguage === "Odia") {
                    let convertedBase64 = parsedResp.mergedBase64;
                    convertedBase64 = convertedBase64.replace(/\n/g, "");
                    convertedBase64 = convertedBase64.replace(/\r/g, "");
                    let decodedHtml = convertedBase64;
                    let dialog = `<div id="pdfDialog" style="position:absolute; left:-9999px; visibility:visible;"></div>`;
                    $("div[id=pdfDialog]").remove();
                    $(document.body).append(dialog);
                    $("#pdfDialog").html(decodedHtml);
                    (async () => {
                        apz.startLoader();
                        const pages = document.querySelectorAll(".jrPage");
                        if (pages.length === 0) {
                            convertedBase64 = parsedResp.mergedBase64;
                            console.log("No '.jrPage' elements found");
                            apz.stopLoader();
                            return;
                        }
                        const opt = {
                            margin: [5, 5, 5, 5],
                            filename: "download.pdf",
                            image: {
                                type: "jpeg",
                                quality: 1.0
                            },
                            html2canvas: {
                                scale: 1.5,
                                useCORS: true,
                                logging: false,
                            },
                            jsPDF: {
                                unit: "mm",
                                format: "a4",
                                orientation: "portrait",
                                compress: true,
                            },
                        };
                        const {
                            jsPDF
                        } = window.jspdf;
                        const pdf = new jsPDF(opt.jsPDF);
                        for (let i = 0; i < pages.length; i++) {
                            if (i !== 0) pdf.addPage();
                            const canvas = await html2canvas(pages[i], opt.html2canvas);
                            const imgData = canvas.toDataURL("image/jpeg", 1.0);
                            const pageWidth = pdf.internal.pageSize.getWidth();
                            const pageHeight = pdf.internal.pageSize.getHeight();
                            pdf.addImage(imgData, "JPEG", 0, 0, pageWidth, pageHeight);
                        }
                        //pdf.save(opt.filename);
                        const pdfBase64 = pdf.output("datauristring");
                        convertedBase64 = pdfBase64.split(",")[1];
                        apz.stopLoader();
                        apz.app.WelcomeKit.viewWelcomeKitDoc(convertedBase64);
                    })();
                } else {
                    apz.stopLoader();
                    apz.app.WelcomeKit.viewWelcomeKitDoc(parsedResp.mergedBase64);
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.closeCommonModal(`newCommonConfModal`);
            ApzCOB.showNewCommonErrorModal();
        }
    },
    DBDocGenerateAndDownloadCB: function (params) {
        try {
            apz.stopLoader();
            if (ApzCOB.handleServiceCallBacks(params)) {
                var ifaceName = ApzCOB.GetInterfaceResMap(params);
                responseObj = params.res[ifaceName].apiResponse.ResponseBody.responseObj;
                if (typeof responseObj === 'string' && responseObj.includes('written')) {
                    let gRowNo = '', docType = '';
                    if (DB_CURRENT_STAGE_NO === 4) {
                        if (currApplLanguage === "Malayalam" || currApplLanguage === "Odia") {
                            ApzCOB.showNewCommonSuccessModal('Document uploaded successfully!');
                            apz.app.DBbase.nextBtnEnableDisable('enable');
                            return;
                        }
                    } else if (specificLang === true) {
                        specificLang = false;
                        return;
                    } else if (DB_CURRENT_STAGE_NO === 1 && (leadLanguage === "Malayalam" || leadLanguage === "Odia")) {
                        return;
                    } else {
                        ApzCOB.showNewCommonSuccessModal('Document uploaded successfully!');
                    }
                    if (uploadDocType === 'ReUpload') {
                        docType = selectedReuploadDoc.docType;
                        gRowNo = paintQueries.findIndex(el => el.docType === docType);
                    } else {
                        gRowNo = parseInt($(`#${scrId}docsList .active`).attr("rowNo"));
                        docType = apz.data.scrdata.DBkitG__IpaintFilesList_Res[gRowNo]?.docType;
                    }
                    let docIndex = documentList.findIndex(el => el.docType === docType);
                    const selDocData = DisbursementDocs.find(u => u.docType === docType);
                    if (docIndex === -1) {
                        const newDoc = {
                            order: selDocData?.id,
                            base64: encodedImage,
                            isReupload: 'N',
                            docType: selDocData?.docType,
                        };
                        documentList.push(newDoc);
                        inSessionStore.documentList.push({
                            ...newDoc
                        });
                    } else if (!apz.isNull(documentList[docIndex])) {
                        documentList[docIndex].base64 = encodedImage;
                        inSessionStore.documentList[docIndex].base64 = encodedImage;
                    }
                    docIndex = documentList.findIndex(el => el.docType === docType);
                    if (applicationStatus === 'DBPUSHBACK' && !apz.isNull(documentList[docIndex])) {
                        documentList[docIndex].isReupload = 'Y';
                        inSessionStore.documentList[docIndex].isReupload = "Y";
                    }
                    if (uploadDocType !== 'ReUpload') {
                        $(`#${scrId}docsList .active`).removeClass("active");
                        $(`#${scrId}docsList_row_${gRowNo}`).addClass('uploaded');
                        $(`#${scrId}docsList .srb.pri.wrapped`).each((index, item) => {
                            if (!$(`#${item.id}`).hasClass('uploaded')) {
                                $(`#${scrId}docsList .active`).removeClass('active');
                                $(`#${item.id}`).addClass('active');
                                return false;
                            }
                        })
                        $(`#${filesIntfId}size_${gRowNo}_txtcnt`).text((localFileObj.docSize / 1024)?.toFixed(0) + 'kb');
                    } else {
                        $(`#${scrId}queryDocumentsList .active`).removeClass("active");
                        $(`#${scrId}queryDocumentsList_row_${gRowNo}`).addClass('uploaded');
                        $(`#${scrId}queryDocumentsList .srb.pri.wrapped`).each((index, item) => {
                            if (!$(`#${item.id}`).hasClass('uploaded')) {
                                $(`#${scrId}queryDocumentsList .active`).removeClass('active');
                                $(`#${item.id}`).addClass('active');
                                return false;
                            }
                        })
                        $(`#DBkitG__DocExecutionManual__reUploadDoc_${gRowNo}`).parent().addClass('sno');
                        $(`#${queryFilesIntfId}size_${gRowNo}_txtcnt`).text((localFileObj.docSize / 1024)?.toFixed(0) + 'kb');
                        $(`#${scrId}tickMarkIcn_${gRowNo}`).parent().removeClass('sno');
                    }
                } else if (responseObj.includes('mergedBase64')) {
                    window.mergedBase64 = JSON.parse(responseObj)?.mergedBase64;
                    if (currApplLanguage === "Malayalam" || currApplLanguage === "Odia") {
                        let trimmed = mergedBase64.trim();
                        if (trimmed.startsWith("<!DOCTYPE") || trimmed.startsWith("<html") || trimmed.startsWith("<body")) {
                            mergedBase64 = mergedBase64.replace(/\n/g, "");
                            mergedBase64 = mergedBase64.replace(/\r/g, "");
                            mergedBase64 = mergedBase64.replace(/<hr\b[^>]*>/gi, '');
                            mergedBase64 = mergedBase64.replace(/<hr\s*\/>/gi, '');
                            mergedBase64 = mergedBase64.replace(/\swidth\s*=\s*["']50%["']/gi, '');
                            mergedBase64 = mergedBase64.replace(/(<td[^>]*style=["'][^"']*)width\s*:\s*50%[;]?([^"']*["'][^>]*>)/gi,
                                (_, before, after) => before + after);
                            let customStyle = `<style>
                                                        .jrPage {
                                                                    page-break-after: always !important;
                                                                    width: 100% !important;
                                                                }
                                                        .jrPage tbody tr td > img {
                                                                    width: 100% !important;
                                                                }
                                                </style>`;
                            if (mergedBase64.includes("</head>")) {
                                mergedBase64 = mergedBase64.replace("</head>", `${customStyle}</head>`);
                            } else if (mergedBase64.includes("</body>")) {
                                mergedBase64 = mergedBase64.replace("</body>", `${customStyle}</body>`);
                            } else {
                                mergedBase64 = customStyle + mergedBase64;
                            }
                            const blob = new Blob([mergedBase64], {
                                type: "text/html"
                            });
                            const url = URL.createObjectURL(blob);
                            let btn = document.getElementById('openInTabBtn');
                            if (!btn) {
                                btn = document.createElement('button');
                                btn.id = 'openInTabBtn';
                            }
                            btn.onclick = () => window.open(url, '_blank');
                            btn.click();
                            $('#DBkitG__DocExecutionUnnati__downloadDocForManualBtn_ul').addClass('sno');
                            $('#DBkitG__DocExecutionUnnati__manualUpload_ul').removeClass('sno');
                            apz.app.DocExecutionUnnati.paintData(mergedBase64);
                        } else {
                            apz.app.DocExecutionUnnati.paintData(mergedBase64);
                        }
                    } else {
                        apz.app.DocExecutionUnnati.paintData(mergedBase64);
                    }
                } else if (responseObj.includes('order')) {
                    window.parsedRespObj = JSON.parse(responseObj);
                    if (apz.currAppId === 'RPCDBV') {
                        window.documentList = JSON.parse(responseObj);
                        apz.app.RPCDBVerify.paintfileListdata();
                        if (apz.childScr == 'RPCDBDocExecutionUnnati') {
                            apz.app.RPCDBDocExecutionUnnati.paintDocData();
                        } else if (apz.childScr == 'RPCDBReviewCnf') {
                            apz.app.RPCDBReviewCnf.paintdocs();
                        }
                    } else {
                        apz.app.DocExecutionUnnati.manualProcessDownloadDocCB(parsedRespObj);
                    }
                } else if (typeof responseObj === 'string' && responseObj.includes('deleted')) {
                    let docIndex = documentList.findIndex(doc => doc.docType === docType);
                    // if (isqueryDoc) {
                    //     docType = paintQueries.find(el => el.docType === docType)?.docType;
                    // } else if (applicationStatus === 'DBPUSHBACK' && APPROVED_DOCS.length > 0) {
                    //     docType = documentList.find(el => el.docType === docType)?.docType;
                    //     docIndex = documentList.findIndex(el => el.docType === docType);
                    // }
                    documentList[docIndex].base64 = "";
                    inSessionStore.documentList[docIndex].base64 = "";
                    if (isqueryDoc) {
                        docIndex = paintQueries.findIndex(el => el.docType === docType);
                        $(`#${scrId}queryDocumentsList_row_${docIndex}`).removeClass('uploaded');
                        $(`#${scrId}queryDocumentsList .active`).removeClass('active');
                        $(`#${scrId}queryDocumentsList_row_${docIndex}`).addClass('active');
                        $(`#DBkitG__DocExecutionManual__reUploadDoc_${docIndex}`).parent().removeClass('sno');
                        $(`#${scrId}tickMarkIcn_${docIndex}`).parent().addClass('sno');
                    } else {
                        docIndex = apz.data.scrdata.DBkitG__IpaintFilesList_Res.findIndex(doc => doc.docType === docType);
                        $(`#${scrId}docsList_row_${docIndex}`).removeClass('uploaded');
                        $(`#${scrId}docsList .active`).removeClass('active');
                        $(`#${scrId}docsList_row_${docIndex}`).addClass('active');
                    }
                    ApzCOB.closeCommonModal(`newCommonConfModal`);
                    ApzCOB.showNewCommonSuccessModal('Document deleted successfully!');
                }
                uploadDocType = '';
                isqueryDoc = '';
                selectedReuploadDoc = {};
            } else {
                //handle fail scenario
                ApzCOB.closeCommonModal(`newCommonConfModal`);
                ApzCOB.showNewCommonErrorModal("Document operation failed!.");
            }
            apz.stopLoader();
        } catch (e) {
            apz.stopLoader();
            ApzCOB.closeCommonModal(`newCommonConfModal`);
            ApzCOB.showNewCommonErrorModal();
        }
    },
