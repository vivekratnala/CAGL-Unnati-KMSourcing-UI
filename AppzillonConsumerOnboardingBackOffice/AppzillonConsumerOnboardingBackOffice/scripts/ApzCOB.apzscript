        var lurl = url;
        if (!apz.isNull(lurl)) {
            if (apz.deviceType === 'WEB') {
                window.open(lurl);
            } else {
                var json = {
                    "url": lurl
                };
                json.callBack = ApzCOB.launchURLCB;
                apz.ns.openUrl(json);
            }
        } else {
            // ("url not defined : " + url);
        }
    },
