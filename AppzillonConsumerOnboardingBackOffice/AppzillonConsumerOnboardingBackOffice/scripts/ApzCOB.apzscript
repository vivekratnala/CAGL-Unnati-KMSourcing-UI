                    $("#" + BaseScrId + "CardBankCallInfoTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_INFO_TXT_BANKCALLDAYS"));
                    $("#" + BaseScrId + "CardRefNumber").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_REFNUMBER"));
                    $("#" + BaseScrId + "CardDownloadAknldBtnTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_DOWNLOADAKNLMT"));
                    $("#" + BaseScrId + "CardCloseBtntxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_CLOSE"));
                    $("#" + BaseScrId + "CardMoreInfoTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_MOREINFO_TXT_MOREINFOCALL"));
                    if (pendingApplication) {
                        downloadFileFromserverforcards();
                    } else {
                        let imageData = apz.data.scrdata.CardSe__IpaintFileUpload_Res.fileDetails;
                        apz.data.scrdata.APZCBO__IPaintSuccImage_Res = [];
                        if (!apz.isNull(imageData)) {
                            let obj = {};
                            obj.image = imageData[0].imgSrc;
                            apz.data.scrdata.APZCBO__IPaintSuccImage_Res.push(obj);
                            apz.data.loadData("IPaintSuccImage", gAppId);
                        } else {
                            let obj1 = {};
                            obj1.image = SelectedCardThemeName;
                            apz.data.scrdata.APZCBO__IPaintSuccImage_Res.push(obj1);
                            apz.data.loadData("IPaintSuccImage", gAppId);
                        }
                        $("#APZCBO__BaseScreens__cardname_txtcnt").text(gApzCOB.subProduct);
                        $("#APZCBO__BaseScreens__personname_txtcnt").text(gApzCOB.userDetails.NameOnCard);
                        apz.setElmValue(BaseScrId + "SelectedCreditCard", gApzCOB.subProduct);
                        apz.setElmValue(BaseScrId + "refNo", gApzCOB.userDetails.applicationId);
                    }
                } else {
                    if (existingAccount) {
                        apz.app.BaseScreens.getCommomCodeBasedOnProduct();
                    }
                    gApzCOB.productDetails.product = gApzCOB.product;
                    gApzCOB.productDetails.productCode = gApzCOB.productCode;
                    gApzCOB.productDetails.subProductName = gApzCOB.subProduct;
                    ApzCOB.LaunchConfiguredScreens();
                }
            } else {
                apz.stopLoader();
                if (!apz.isNull(params.res.APZCBO__applyCreditCard_Res)) {
                    if (!apz.isNull(params.res.APZCBO__applyCreditCard_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                        ApzCOB.fnDisplayMsg(params.res.APZCBO__applyCreditCard_Res.apiResponse.ResponseHeader.ResponseMessage, "E", apz.app
                            .BaseScreens.launchCustVerification);
                    }
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    // create loan Service
    createLoan: function () {
        let req = {};
        let isvalid = false,
            flagVal = false;
        let intfName = "CreateLoan";
        if (apz.childScr === "EmploymentDetails" && gApzCOB.currentApplicant == 1 && accIsvalid !== 'Verified') {
            ApzCOB.fnDisplayMsg("Please Verify Bank Account", "E");
            return;
        }
        req.apiRequest = {};
        req.apiRequest.requestObj = {};
        if (!apz.isNull(gApzCOB.requestNodes.applnWfDefinitionList) && gApzCOB.requestNodes.applnWfDefinitionList.length > 0) {
            gApzCOB.requestNodes.applnWfDefinitionList = [];
        }
        gApzCOB.product = "LOAN";
        gApzCOB.mainProductGroupCode = 'LOAN';
        if (gApzCOB?.selLeadDtls?.oldPid || inSessionStore?.renewalLeadDetails?.oldPid) {
            gApzCOB.productCode = '1002';
            gApzCOB.SelectedProductName = productCodeBasedName[gApzCOB.productCode];
            ApplicationType = "RENEWAL";
        }
        if (ApzCOB.validateConfFields()) {
            if (CURRENT_STAGE_NO <= STAGES.length) {
                STAGES.forEach(function (m, n) {
                    ConfigureScrJson.forEach(function (i, k) {
                        if (Number(CURRENT_STAGE_NO) === parseInt(m.split("~")[1].toUpperCase()) && i.confParamName === m
                            .split("~")[0].toUpperCase()) {
                            isvalid = apz.app.BaseScreens.checkScreenInMicroapp(i);
                            if (isvalid && !apz.isNull(i.requestFunc)) {
                                if (!apz.isNull(gApzCOB.userDetails.applicationId)) {
                                    apz.app.BaseScreens.updatePrimaryDetails();
                                    if (!apz.app.BaseScreens.checkDtlIds()) {
                                        flagVal = true;
                                        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
                                        return;
                                    }
                                }
                                let curScopeFunc = i.requestFunc.split(".");
                                req.apiRequest.requestObj = window[curScopeFunc[0]][curScopeFunc[1]][curScopeFunc[2]][
                                    curScopeFunc[3]
                                ]();
                            }
                            req.apiRequest.userId = gApzCOB.LoggedInUserDetails.loginResponse.userDet.id;
                            req.apiRequest.appId = gAppId;
                            req.apiRequest.interfaceName = "";
                            req.apiRequest.requestObj.appId = gApzCOB.userDetails.appId;
                            req.apiRequest.requestObj.applicationId = !apz.isNull(gApzCOB.relatedApplicationId) ? gApzCOB
                                .relatedApplicationId : gApzCOB.userDetails.applicationId;
                            req.apiRequest.requestObj.versionNum = window.versionNum;
                            req.apiRequest.requestObj.isExistingCustomer = "";
                            let secondaryKycType = "",
                                secondaryKycId = "",
                                alternateVoterId = "";
                            if (!apz.isNull(inSessionStore.customerDetailsList)) {
                                let applicantCustomerData = inSessionStore.customerDetailsList.filter((cust) => {
                                    return cust.customerType === "Applicant";
                                })[0];
                                if (!apz.isNull(applicantCustomerData)) {
                                    secondaryKycType = applicantCustomerData.payload.secondaryKycType;
                                    secondaryKycId = applicantCustomerData.payload.secondaryKycId;
                                    alternateVoterId = applicantCustomerData.payload.alternateVoterId;
                                }
                            }
                            req.apiRequest.requestObj.applicationMaster = {
                                applicationType: "online",
                                createdBy: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                                currentScreenId: gApzCOB.userDetails.currentScreen,
                                currentStageNo: CURRENT_STAGE_NO,
                                custDtlId: gApzCOB.userDetails.custDtlId,
                                addressDtlsId: gApzCOB.userDetails.addressDtlsId,
                                customerId: gApzCOB.userDetails.customerId,
                                declarationFlag: gApzCOB.userDetails.declarationFlag,
                                mobileNumber: !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails
                                    .mobileNum : null,
                                productCode: apz.isNull(gApzCOB.productCode) ? '1009' : gApzCOB.productCode,
                                productGroupCode: gApzCOB.product,
                                searchCode1: gApzCOB.selLeadDtls.kendraId,
                                searchCode2: gApzCOB.selLeadDtls.customerId,
                                custDtlSlNum: gApzCOB.currentApplicant,
                                applicantsCount: gApzCOB.noOfApplicants,
                                mainProductGroupCode: gApzCOB.mainProductGroupCode,
                                kendraId: gApzCOB.selLeadDtls.kendraId,
                                kendraName: gApzCOB.selLeadDtls.kendraName,
                                branchId: gApzCOB.selLeadDtls.glBranchId,
                                branchName: gApzCOB.selLeadDtls.glBranchName,
                                memberId: gApzCOB.selLeadDtls.customerId,
                                primaryKycType: "Voter ID",
                                primaryKycId: gApzCOB.selLeadDtls.primaryKyc,
                                secondaryKycType: secondaryKycType,
                                secondaryKycId: secondaryKycId,
                                workitemNo: gApzCOB.selLeadDtls.pid,
                                alternateVoterId: alternateVoterId,
                            };
                            if (CURRENT_STAGE_NO === 11) {
                                req.apiRequest.requestObj.applicationMaster.custDtlSlNum = gApzCOB.noOfApplicants;
                                if (gApzCOB.currentApplicant !== Number(gApzCOB.noOfApplicants)) {
                                    gApzCOB.currentApplicant = Number(gApzCOB.noOfApplicants);
                                }
                            }
                            if (gApzCOB.currentApplicant > 1) {
                                req.apiRequest.requestObj.applicationMaster.custDtlId = apz.isNull(gApzCOB.userDetails
                                    .CoApplicantCustomerId) ? "" : gApzCOB.userDetails.CoApplicantCustomerId;
                                req.apiRequest.requestObj.applicationMaster.addressDtlsId = apz.isNull(gApzCOB.userDetails
                                    .CoApplicantAddressDtlsId) ? "" : parseInt(gApzCOB.userDetails
                                        .CoApplicantAddressDtlsId);
                            }
                            if (!apz.isNull(gApzCOB.userDetails.pinCode) && apz.isNull(gApzCOB.userDetails.applicationId)) {
                                gApzCOB["requestNodes"]["bankingFacilityList"] = [];
                                req.apiRequest.requestObj.bankingFacilityList = [{
                                    bankFacilityId: gApzCOB.userDetails.bankFacilityId,
                                    payload: {
                                        branchName: gApzCOB.userDetails.branchName,
                                        branchAddress: gApzCOB.userDetails.branchAddress,
                                        branchCode: gApzCOB.userDetails.branchCode,
                                    },
                                },];
                                gApzCOB["requestNodes"]["bankingFacilityList"] = req.apiRequest.requestObj
                                    .bankingFacilityList;
                            }
                            if (apz.isNull(gApzCOB.userDetails.applicationId)) {
                                req.apiRequest.requestObj.workflow = {
                                    currentRole: "",
                                };
                            } else {
                                if (gApzCOB.currentApplicant == gApzCOB.noOfApplicants && NEXT_STAGE_NAME ===
                                    "ACCOUNTCREATION") {
                                    apz.app.BaseScreens.stageBasedOnAction();
                                    req.apiRequest.requestObj.workflow = {
                                        currentRole: gApzCOB.workflow.currentRole,
                                        action: gApzCOB.workflow.action,
                                        workflowId: gApzCOB.workflow.workflowId,
                                        stage: gApzCOB.workflow.stage,
                                    };
                                    if (ApplicationType === "RENEWAL") {
                                        intfName = "ApproveRenewalApplication";
                                    }
                                }
                            }
                        }
                    });
                });
                if (apz.isNull(req.apiRequest.requestObj) || flagVal) {
                    return;
                }
                let pushbackAddressed = true;
                if (CURRENT_SCREEN_QUERIES.length > 0) {
                    let sourcingRemark = $(`#${BaseScrId}sourcingRemarks`).val();
                    if (!apz.isNull(sourcingRemark)) {
                        const custType = gApzCOB.currentApplicant === 1 ? 'Applicant' : 'Co-APP';
                        let currentStage = screenMap[apz.childScr];
                        SOURCING_SENDBACK_QUERIES[currentStage][custType].response = sourcingRemark;
                        let sourcingObj = ApzCOB.prepareSourcingQueryReq();
                        req.apiRequest.requestObj.queryResponse = structuredClone(sourcingObj);
                    } else {
                        ApzCOB.fnDisplayMsg("Please enter sourcing response for sendback queries", "E");
                        pushbackAddressed = false;
                    }
                }
                if (pushbackAddressed) {
                    $("#" + BaseScrId + "continue").attr("disabled", true);
                    apz.startLoader();
                    setTimeout(() => {
                        ApzCOB.serverBuildParam(gAppId, intfName, "N", "N", req, false, ApzCOB.createLoanCB);
                    }, 1000);
                }
            }
        }
    },
    // create loan Service call back
    createLoanCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                window.clickList = false;
                window.dontReloadRC = false;
                window.IS_DASHBOARD_VIEW_DATA = false;
                window.UNATTENDED_SCREEN = false;
                let response = JSON.parse(params.res[params.apzIfaceName + "_Res"].apiResponse.ResponseBody.responseObj);
                if (response?.hasOwnProperty("applicationId")) {
                    gApzCOB.userDetails.applicationId = response.applicationId;
                }
                ApzCOB.responseNodeUpdate(response);
                if (ISPUSHBACKPPL || IS_BM_DOC_EDIT || IS_CB_RETRIGGER) {
                    ApzCOB.pushBackNavigationOnBack();
                } else {
                    if (!apz.isNull(response.applnWfDefinitionList)) {
                        gApzCOB.applnWorkFlowRes = response.applnWfDefinitionList;
                    }
                    if (Number(CURRENT_STAGE_NO) === STAGES.length || (window.NEXT_STAGE_NAME === "ACCOUNTCREATION" && Number(
                        CURRENT_STAGE_NO) === STAGES.length - 1)) {
                        apz.stopLoader();
                        if (gApzCOB.currentApplicant !== Number(gApzCOB.noOfApplicants)) {
                            gApzCOB.currentApplicant = Number(gApzCOB.noOfApplicants);
                        }
                        if (Number(gApzCOB.noOfApplicants) > 1 && gApzCOB.currentApplicant < Number(gApzCOB.noOfApplicants) && gApzCOB
                            .currentApplicant - 1 !== Number(gApzCOB.noOfApplicants) && gApzCOB.applicationType === JointAccount && isdone !==
                            Number(gApzCOB.noOfApplicants) && ((gApzCOB.currentApplicant === 1 && gApzCOB.noOfApplicants > 1) || (gApzCOB
                                .mainProductGroupCode === "LOAN" && gApzCOB.LoanCallCBS !== "N"))) {
                            window.Secoundperson = true;
                            isdone++;
                            gApzCOB.currentApplicant = gApzCOB.currentApplicant + 1;
                            ApzCOB.LaunchConfiguredScreens();
                        } else {
                            ApzCOB.toggleModal(BaseScrId + "LoanSuccessModal");
                            $("#" + BaseScrId + "LoanSuccTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_SUCC_TXT_APPSUBMITTEDSUCC"));
                            $("#" + BaseScrId + "LoanBankCall").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_INFO_TXT_BANKCALLDAYS"));
                            $("#" + BaseScrId + "LoanRefNumber").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_REFNUMBER"));
                            $("#" + BaseScrId + "LoanDownloadAknldBtnTxt").text(ApzCOB.getDescfromLitCode(
                                "LIT_REVCONF_BTN_TXT_DOWNLOADAKNLMT"));
                            $("#" + BaseScrId + "LoanCloseBtnTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_CLOSE"));
                            $("#" + BaseScrId + "LoanMoreInfotxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_MOREINFO_TXT_MOREINFOCALL"));
                            $("#" + BaseScrId + "applicationRefID_txtcnt").text(response.applicationId);
                            $(`#${BaseScrId}referenceNumber`).text(gApzCOB.userDetails.applicationId);
                            //Newgen Id Added
                            $(`#${BaseScrId}NewgenWorkIdLbl`).text(ApzCOB.getDescfromLitCode("LIT_COMM_LBL_TXT_NEWGEN_WORKID"));
                            $(`#${BaseScrId}NewgenWorkId`).text(apz.isNull(gApzCOB.selLeadDtls.pid) ? "" : gApzCOB.selLeadDtls.pid);
                            let declFlag = inSessionStore?.applicationMaster?.declarationFlag;
                            if (declFlag !== 'I') {
                                $("#APZCBO__BaseScreens__sc_row_179").removeClass("sno");
                            } else {
                                $("#APZCBO__BaseScreens__sc_row_179").addClass("sno");
                            }
                            ApzCOB.loadCreatLoanPart();
                        }
                    } else {
                        if ($("#" + BaseScrId + "newCustomerModal").is(":visible")) {
                            $("#" + BaseScrId + "newCustomerModal_close").trigger("click");
                            let JointSupported = "";
                            let AccountHolderForLoan = "";
                            for (let i = 0; i < gApzCOB.CommonCodes.length; i++) {
                                if (gApzCOB.CommonCodes[i].paramName === "LOANCASAJTACC") {
                                    JointSupported = gApzCOB.CommonCodes[i].paramValue.split("~")[0];
                                    AccountHolderForLoan = gApzCOB.CommonCodes[i].paramValue.split("~")[1];
                                }
                                if (gApzCOB.CommonCodes[i].paramName === "DEFAULTCASAPRODUCTCODELN") {
                                    gApzCOB.productCode = gApzCOB.CommonCodes[i].paramValue;
                                }
                            }
                            if (JointSupported === "Y") {
                                gApzCOB.NoOfJointHolder = AccountHolderForLoan;
                                apz.app.BaseScreens.defaultApplicationType();
                                ApzCOB.toggleModal(BaseScrId + "applicationTypeModal");
                                $("#" + BaseScrId + "continueBtn").attr("onclick", "").unbind("click");
                                $("#" + BaseScrId + "continueBtn").attr("onclick", "ApzCOB.UpdateApplicantscount()");
                                apz.stopLoader();
                                return;
                            }
                        }
                        if (STAGE_NO > 3) {
                            if (!completeArray.includes(CURRENT_STAGE_NO)) {
                                completeArray.push(CURRENT_STAGE_NO);
                            }
                        }
                        IS_SERVICE_CALLBACK = true;
                        let nextStageName = STAGES.filter(
                            (stage) => parseInt(stage.split("~")[1]) === STAGE_NO)[0].split("~")[0];
                        let stageOccuranceCheck = UPDATED_STAGES.filter(
                            (upStage) => upStage.split("~")[0] === nextStageName);
                        if (stageOccuranceCheck.length > 0) {
                            if (gApzCOB.currentApplicant < gApzCOB.noOfApplicants) {
                                gApzCOB.currentApplicant++;
                            }
                        } else {
                            gApzCOB.currentApplicant = 1;
                        }
                        $("#APZCBO__BaseScreens__baseScroll").find(".stageDiv").map((stage, stageDiv) => $(stageDiv).find(
                            "div:not(.gcb-col12)").eq(0).remove());
                        if (CURRENT_STAGE_NAME === "OCCUPATIONDETAILS" && parseInt(STAGE_NO) === 8) {
                            window.backNav = false;
                            ApzCOB.checkCoAppAdditionalDetailsForHomeMaker();
                        } else {
                            // RenewalCode
                            if (CURRENT_STAGE_NO === 3 && ApplicationType === "RENEWAL" && !backNav) {
                                UPDATED_STAGES = [];
                                ApzCOB.FetchApplicationRenewal(); //
                            } else {
                                ApzCOB.LaunchConfiguredScreens();
                                $("#" + BaseScrId + "continue").attr("disabled", false);
                            }
                        }
                    }
                }
            } else {
                apz.stopLoader();
                let errMsg = ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL");
                if (params?.res?.APZCBO__CreateLoan_Res.apiResponse?.ResponseBody?.responseObj) {
                    errMsg = params?.res?.APZCBO__CreateLoan_Res.apiResponse?.ResponseBody?.responseObj;
                }
                ApzCOB.fnDisplayMsg(errMsg, "E");
                $("#" + BaseScrId + "continue").attr("disabled", false);
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
            $("#" + BaseScrId + "continue").attr("disabled", false);
        }
    },
    //to set the response value to global variable
    responseNodeUpdate: function (param) {
        Object.getOwnPropertyNames(param).forEach(function (k) {
            switch (k) {
                case "applicationId":
                    gApzCOB.userDetails.applicationId = apz.isNull(gApzCOB.relatedApplicationId) ? param.applicationId : gApzCOB
                        .userDetails.applicationId;
                    break;
                case "versionNum":
                    gApzCOB.userDetails.versionNum = window.versionNum;
                    break;
                case "customerId":
                    gApzCOB.userDetails.customerId = param.customerId;
                    break;
                case "crsDetailsList":
                    if (param.crsDetailsList.length > 0) {
                        gApzCOB.userDetails.crsDtlsId = param.crsDetailsList[0];
                    }
                    break;
                case "custDtlId":
                    let getIndex = "";
                    if (gApzCOB.currentApplicant <= 1) {
                        if (apz.isNull(gApzCOB.userDetails.custDtlId)) {
                            gApzCOB.userDetails.custDtlId = parseInt(param.custDtlId);
                            getIndex = inSessionStore.customerDetailsList.findIndex(
                                (cust) => cust.customerType === "Applicant");
                        }
                    } else {
                        if (apz.isNull(gApzCOB.userDetails.CoApplicantCustomerId)) {
                            gApzCOB.userDetails.CoApplicantCustomerId = parseInt(param.custDtlId);
                            getIndex = inSessionStore.customerDetailsList.findIndex(
                                (cust) => cust.customerType !== "Applicant");
                        }
                    }
                    if (!apz.isNull(getIndex) && getIndex >= 0) {
                        inSessionStore.customerDetailsList[getIndex].custDtlId = parseInt(param.custDtlId);
                        inSessionStore.addressDetailsWrapperList[0].addressDetailsList[gApzCOB.currentApplicant - 1].custDtlId =
                            parseInt(param.custDtlId);
                    }
                    break;
                case "depositDtlId":
                    gApzCOB.userDetails.depositDtlsId = param.depositDtlId;
                    break;
                case "loanDtlId":
                    gApzCOB.userDetails.loanDtlsId = parseInt(param.loanDtlId);
                    break;
                case "cardDtlId":
                    gApzCOB.userDetails.ccDtlId = param.cardDtlId;
                    break;
                case "eligibleCardsList":
                    gApzCOB.userDetails.eligibleCardsList = param.eligibleCardsList;
                    gApzCOB.userDetails.allCardInfo = param;
                    break;
                case "fatcaDetailsList":
                    if (param.fatcaDetailsList.length > 0) {
                        gApzCOB.userDetails.fatcaDtlsId = param.fatcaDetailsList[0];
                    }
                    break;
                case "addressList":
                    if (param.addressList.length > 0) {
                        if (CURRENT_STAGE_NAME === "CUSTOMERDETAILS") {
                            let getAddressIndex = "";
                            let indexID = parseInt(param.addressList.map(function (i) {
                                return i;
                            })[0]);
                            if (gApzCOB.currentApplicant <= 1) {
                                gApzCOB.userDetails.addressDtlsId = [];
                                gApzCOB.userDetails.addressDtlsId = indexID;
                                if (!apz.isNull(gApzCOB.userDetails.custDtlId)) {
                                    getAddressIndex = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(
                                        (address) => address.addressType === "Personal" && parseInt(address.custDtlId) ===
                                            parseInt(gApzCOB.userDetails.custDtlId));
                                } else {
                                    getAddressIndex = gApzCOB.currentApplicant - 1;
                                }
                            } else {
                                gApzCOB.userDetails.CoApplicantAddressDtlsId = [];
                                gApzCOB.userDetails.CoApplicantAddressDtlsId = indexID;
                                if (!apz.isNull(gApzCOB.userDetails.CoApplicantCustomerId)) {
                                    getAddressIndex = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(
                                        (address) => address.addressType === "Personal" && parseInt(address.custDtlId) ===
                                            parseInt(gApzCOB.userDetails.CoApplicantCustomerId));
                                } else {
                                    getAddressIndex = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(
                                        (address) => address.addressType === "Personal" && parseInt(address.custDtlId) !==
                                            parseInt(gApzCOB.userDetails.custDtlId));
                                }
                            }
                            if (getAddressIndex >= 0) {
                                inSessionStore.addressDetailsWrapperList[0].addressDetailsList[getAddressIndex].addressDtlsId =
                                    indexID;
                            }
                        } else if (CURRENT_STAGE_NAME === "OCCUPATIONDETAILS") {
                            let getIndex = "";
                            let indexID = parseInt(param.addressList.map(function (i) {
                                return i;
                            })[0]);
                            if (gApzCOB.currentApplicant <= 1) {
                                gApzCOB.userDetails.occAddressDtlsId = [];
                                gApzCOB.userDetails.occAddressDtlsId = indexID;
                                getIndex = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(
                                    (address) => address.addressType === "Occupation" && parseInt(address.custDtlId) === parseInt(
                                        gApzCOB.userDetails.custDtlId));
                            } else {
                                gApzCOB.userDetails.CoApOccAddressDtlsId = [];
                                gApzCOB.userDetails.CoApOccAddressDtlsId = indexID;
                                getIndex = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(
                                    (address) => address.addressType === "Occupation" && parseInt(address.custDtlId) === parseInt(
                                        gApzCOB.userDetails.CoApplicantCustomerId));
                            }
                            if (getIndex >= 0) {
                                inSessionStore.addressDetailsWrapperList[0].addressDetailsList[getIndex].addressDtlsId = indexID;
                            }
                        } else if (CURRENT_STAGE_NAME === "NOMINEEDETAILS") {
                            gApzCOB.userDetails.nomineeAddressDtlsId = param.addressList[0];
                            NOMINEE_ADDRESS.filter(function (q) {
                                if (apz.isNull(q.addressDetailsList[0]["addressDtlsId"])) {
                                    q.addressDetailsList[0]["addressDtlsId"] = gApzCOB.userDetails.nomineeAddressDtlsId;
                                }
                            });
                        }
                    }
                    break;
                case "nomineeList":
                    if (param.nomineeList.length > 0) {
                        if (CURRENT_STAGE_NAME === "NOMINEEDETAILS" || CURRENT_STAGE_NAME === "NOMINEEDETAILSDP") {
                            gApzCOB.userDetails.nomineeDtlsId = param.nomineeList[0];
                            gApzCOB.requestNodes.nomineeDetailsWrapperList[0]["nomineeDetailsList"][0]["nomineeDtlsId"] = gApzCOB
                                .userDetails.nomineeDtlsId;
                            NOMINEE_ADDRESS.filter(function (r) {
                                if (apz.isNull(r.addressDetailsList[0]["uniqueId"])) {
                                    r.addressDetailsList[0]["uniqueId"] = gApzCOB.userDetails.nomineeDtlsId;
                                }
                            });
                        }
                    }
                    break;
                case "occupationList":
                    if (param.occupationList.length > 0) {
                        let getIndex = "";
                        if (gApzCOB.currentApplicant <= 1) {
                            gApzCOB.userDetails.occptDtlId = parseInt(param.occupationList[0]);
                            getIndex = inSessionStore.occupationDetailsWrapperList.findIndex(
                                (occ) => parseInt(occ.occupationDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));
                        } else {
                            gApzCOB.userDetails.coAppOccptDtlId = parseInt(param.occupationList[0]);
                            getIndex = inSessionStore.occupationDetailsWrapperList.findIndex(
                                (occ) => parseInt(occ.occupationDetails.custDtlId) === parseInt(gApzCOB.userDetails
                                    .CoApplicantCustomerId));
                        }
                        if (getIndex >= 0) {
                            inSessionStore.occupationDetailsWrapperList[getIndex].occupationDetails.occptDtlId = parseInt(param
                                .occupationList[0]);
                        }
                    }
                    break;
                case "bankFacilityList":
                    if (param.bankFacilityList.length > 0) {
                        gApzCOB.userDetails.bankFacilityId = param.bankFacilityList[0];
                    }
                    break;
                case "documentList":
                    if (param.documentList.length > 0) {
                        let p = 0;
                        let data = gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"];
                        data.forEach(function (i, k1) {
                            if (apz.isNull(i.appDocId)) {
                                if (selectedScrId === "UploadDocuments" && i.payload.screenId === "UploadDocuments") {
                                    apz.app.UploadDocuments.updateAppDocId(i.payload.docSide, param.documentList[p]);
                                    finalDocsArr[p]["appDocId"] = param.documentList[p];
                                } else if (selectedScrId === "KYCVerification" && i.payload.screenId === "KYCVerification") {
                                    apz.app.KYCVerification.selectedFileData(i.payload.docSide, param.documentList[p]);
                                }
                                gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"][k1][
                                    "appDocId"
                                ] = param.documentList[p];
                                p = p + 1;
                                if (selectedScrId === "UploadDocuments" && i.payload.screenId === "UploadDocuments") {
                                    apz.app.UploadDocuments.updateModifiedFiles(gApzCOB.requestNodes
                                        .applicationDocumentsWrapperList[0]["applicationDocumentsList"][k1], "UPDATE");
                                } else if (selectedScrId === "KYCVerification" && i.payload.screenId === "KYCVerification") {
                                    apz.app.KYCVerification.updateModifiedFiles(gApzCOB.requestNodes
                                        .applicationDocumentsWrapperList[0]["applicationDocumentsList"][k1], "UPDATE");
                                }
                            }
                            // }
                        });
                    }
                    break;
                case "casaCustomerIdentification":
                    //deposit new customer default creation response
                    gApzCOB.userDetails.applicationId = param.casaCustomerIdentification.applicationId;
                    gApzCOB.relatedApplicationId = param.applicationId;
                    gApzCOB.userDetails.versionNum = param.casaCustomerIdentification.versionNum;
                    gApzCOB.userDetails.custDtlId = param.casaCustomerIdentification.custDtlId;
                    gApzCOB.product = ApzCOB.GetCommonCodes("DEFAULTCASAPRODUCTGRPCODE");
                    gApzCOB.productCode = ApzCOB.GetCommonCodes("DEFAULTCASAPRODUCTCODE");
                    gApzCOB.userDetails.bankFacilityId = param.casaCustomerIdentification.bankFacilityList.toString();
                    break;
                case "existisingLoanDtlId":
                    gApzCOB.userDetails.existisingLoanDtlId = [];
                    if (param.existisingLoanDtlId.length > 0) {
                        gApzCOB.userDetails.existisingLoanDtlId = param.existisingLoanDtlId.map(function (i) {
                            return i;
                        });
                    }
                    break;
                case "loanDtlIds":
                    gApzCOB.userDetails.existingLoanId = [];
                    if (param.loanDtlIds.length > 0) {
                        gApzCOB.userDetails.existingLoanId = param.loanDtlIds.map(function (i) {
                            return i;
                        });
                    }
                    break;
                case "cbtlList":
                    if (param.cbtlList.length > 0) {
                        if (gApzCOB.currentApplicant <= 1) {
                            gApzCOB.userDetails.cbDtlsId = parseInt(param.cbtlList[0]);
                        } else {
                            gApzCOB.userDetails.coApplicantCbDtlsId = parseInt(param.cbtlList[0]);
                        }
                        let currentIndex = inSessionStore.cibilDetailsWrapperList.findIndex(
                            (insData) => insData.cibilDetails.custDtlId === (gApzCOB.currentApplicant > 1 ? gApzCOB.userDetails
                                .CoApplicantCustomerId : gApzCOB.userDetails.custDtlId));
                        if (currentIndex >= 0) {
                            window.inSessionStore.cibilDetailsWrapperList[currentIndex].cibilDetails.cbDtlId = parseInt(param
                                .cbtlList[0]);
                        }
                    }
                    break;
                case "bankList":
                    if (param.bankList.length > 0) {
                        gApzCOB.userDetails.bankDtlsId = parseInt(param.bankList[0]);
                        // Set bankDtlId
                        let currentIndex = inSessionStore.bankDetailsWrapperList.findIndex(
                            (insData) => insData.bankDetails.custDtlId === (gApzCOB.currentApplicant > 1 ? gApzCOB.userDetails
                                .CoApplicantCustomerId : gApzCOB.userDetails.custDtlId));
                        if (currentIndex >= 0) {
                            inSessionStore.bankDetailsWrapperList[currentIndex].bankDetails.bankDtlId = parseInt(param.bankList[0]);
                        }
                    }
                    break;
                case "insuranceList":
                    if (param.insuranceList.length > 0) {
                        if (gApzCOB.currentApplicant <= 1) {
                            gApzCOB.userDetails.insuranceDtlsId = parseInt(param.insuranceList[0]);
                        } else {
                            gApzCOB.userDetails.coAppInsuranceDtlsId = parseInt(param.insuranceList[0]);
                        }
                        let currentIndex = inSessionStore.insuranceDetailsWrapperList.findIndex(
                            (insData) => insData.insuranceDetails.custDtlId === (gApzCOB.currentApplicant > 1 ? gApzCOB
                                .userDetails.CoApplicantCustomerId : gApzCOB.userDetails.custDtlId));
                        if (currentIndex >= 0) {
                            if (apz.isNull(window.inSessionStore.insuranceDetailsWrapperList[currentIndex].insuranceDetails
                                .insuranceDtlId)) {
                                window.inSessionStore.insuranceDetailsWrapperList[currentIndex].insuranceDetails.insuranceDtlId =
                                    parseInt(param.insuranceList[0]);
                            } else {
                                let data = window.inSessionStore.insuranceDetailsWrapperList;
                                data.forEach(function (i, k) {
                                    if (parseInt(data[k].insuranceDetails.insuranceDtlId) === parseInt(param.insuranceList[
                                        0])) {
                                        window.inSessionStore.insuranceDetailsWrapperList[k].insuranceDetails.insuranceDtlId =
                                            parseInt(param.insuranceList[0]);
                                    }
                                });
                            }
                        }
                    }
                    break;
                default:
                    break;
            }
        });
    },
    discardApplication: function () {
        if (!changeSubProduct) {
            ApzCOB.MandatoryFieldsVerifyAppln();
        }
        let data;
        let req = {};
        req.apiRequest = {};
        req.apiRequest.requestObj = {};
        if (ApzCOB.validateConfFields()) {
            if (CURRENT_STAGE_NO <= STAGES.length) {
                STAGES.forEach(function (m, n) {
                    ConfigureScrJson.forEach(function (i, k) {
                        if (Number(CURRENT_STAGE_NO) === parseInt(m.split("~")[1].toUpperCase()) && i.confParamName === m
                            .split("~")[0].toUpperCase()) {
                            if (!apz.isNull(i.requestFunc)) {
                                let curScopeFunc = i.requestFunc.split(".");
                                req.apiRequest.requestObj = window[curScopeFunc[0]][curScopeFunc[1]][curScopeFunc[2]][
                                    curScopeFunc[3]
                                ]();
                            }
                            req.apiRequest.appId = gAppId;
                            req.apiRequest.userId = gApzCOB.LoggedInUserDetails.loginResponse.userDet.id;
                            req.apiRequest.requestObj.appId = gAppId;
                            req.apiRequest.requestObj.applicationId = gApzCOB.userDetails.applicationId;
                            req.apiRequest.requestObj.versionNum = gApzCOB.userDetails.versionNum;
                            req.apiRequest.requestObj.applicationMaster = {
                                createdBy: gApzCOB.userDetails.userName,
                                accNumber: "",
                                custDtlId: gApzCOB.userDetails.custDtlId,
                                applicationType: "online",
                                kycType: gApzCOB.userDetails.kycFlag,
                                declarationFlag: gApzCOB.userDetails.declarationFlag,
                                applicationStatus: "",
                                //  "mobileNumber": !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails.mobileNum : null,
                                //   "nationalId": !apz.isNull(gApzCOB.userDetails.nationalId) ? gApzCOB.userDetails.nationalId : null,
                                //    "pan": !apz.isNull(gApzCOB.userDetails.panNum) ? gApzCOB.userDetails.panNum : null,
                                //   "emailId": gApzCOB.userDetails.email,
                                mobileNumber: window.mobileNode && !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB
                                    .userDetails.mobileNum : null,
                                nationalId: window.nidInpNode && !apz.isNull(gApzCOB.userDetails.nationalId) ? gApzCOB
                                    .userDetails.nationalId : null,
                                pan: window.panNode && !apz.isNull(gApzCOB.userDetails.panNum) ? gApzCOB.userDetails
                                    .panNum.toUpperCase() : null,
                                emailId: window.emailNode && !apz.isNull(gApzCOB.userDetails.email) ? gApzCOB.userDetails
                                    .email : null,
                                productGroupCode: gApzCOB.product,
                                productCode: gApzCOB.productCode,
                                searchCode1: "",
                                searchCode2: "",
                                leadId: "",
                                //"emailId": gApzCOB.userDetails.email,
                                currentScreenId: gApzCOB.userDetails.currentScreen,
                                custDtlSlNum: gApzCOB.currentApplicant,
                                applicantsCount: gApzCOB.noOfApplicants,
                            };
                            if (!apz.isNull(gApzCOB.userDetails.pinCode)) {
                                gApzCOB["requestNodes"]["bankingFacilityList"] = [];
                                req.apiRequest.requestObj.bankingFacilityList = [{
                                    //  "appId": gAppId,
                                    bankFacilityId: "",
                                    payload: {
                                        branchName: gApzCOB.userDetails.branchName,
                                        branchAddress: gApzCOB.userDetails.branchAddress,
                                        branchCode: gApzCOB.userDetails.branchCode,
                                    },
                                },];
                                gApzCOB["requestNodes"]["bankingFacilityList"] = req.apiRequest.requestObj
                                    .bankingFacilityList;
                            }
                            if (NEXT_STAGE_NAME === "ACCOUNTCREATION") {
                                apz.app.BaseScreens.stageBasedOnAction();
                                req.apiRequest.requestObj.workflow = {
                                    currentRole: gApzCOB.workflow.currentRole,
                                    action: gApzCOB.workflow.action,
                                    workflowId: gApzCOB.workflow.workflowId,
                                    stage: gApzCOB.workflow.stage,
                                };
                            } else {
                                req.apiRequest.requestObj.workflow = {
                                    currentRole: "",
                                };
                            }
                        }
                    });
                });
                apz.startLoader();
                ApzCOB.serverBuildParam(gAppId, "DiscardApplication", "N", "N", req, false, ApzCOB.discardApplicationCB);
            }
        }
    },
    depositDiscardApplication: function () {
