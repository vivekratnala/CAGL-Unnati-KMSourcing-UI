    RpcQuerySaveCB: function (params) {
        ApzCOB.toggleModal(BaseScrId + "queryModal");
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.updateInsessionData(params);
                ApzCOB.updateSideMenuStatusTags();
                const queryRow = `RPC__${RPC_CURRENT_STAGE}__queriesRow`;
                $(`#${queryRow}`).html('');
                stageQueries = ApzCOB.paintingQuery();
                pushbackQuery = ApzCOB.chekPushbackQueries();
                if (stageQueries.length > 0 || pushbackQuery.length > 0) {
                    ApzCOB.launchSubScreen("RPC_Query", queryRow, "");
