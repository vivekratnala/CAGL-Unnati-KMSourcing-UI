                if (n.lovName === "KM_STAGES" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "KMSTAGES") {
                    $.each(JSON.parse(response[m].lovDtls)["KMSTAGES"], function (a, b) {
                        KM_STAGES.push(b);
                    });
                }
                if (n.lovName === "DASHBOARD_TABS" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "DASHBOARD_TABS") {
                    $.each(JSON.parse(response[m].lovDtls)["DASHBOARD_TABS"], function (a, b) {
                        DASHBOARD_TABS.push(b);
                    });
                }
                // BRE Lovs Added
                if (n.lovName === "BRE_MAPPING" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "BRE Mapping") {
                    BRE_MAPPING = JSON.parse(response[m].lovDtls)["BRE Mapping"];
                }
                if (n.lovName === "CB_CALL_TYPE" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "CB Call Type") {
                    cbCallType = JSON.parse(response[m].lovDtls)["CB Call Type"];
                }
                if (n.lovName === "DASHBOARD_CONF" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "DASHBOARD") {
                    DASHBOARD_CONFIG = JSON.parse(response[m].lovDtls)["DASHBOARD"];
                }
                if (n.lovName === "AADHAR_CONF" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "AADHAR") {
                    AADHAR_CONFIG = JSON.parse(response[m].lovDtls)["AADHAR"];
                }
                if (n.lovName === "RPC_STEPPER_DATA" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "RPCStepperData") {
                    RPC_STAGES = JSON.parse(response[m].lovDtls)["RPCStepperData"];
                }
                if (n.lovName === "DISBDOCLANGUAGES" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "DBDOCLanguages") {
                    window.disbDocLanguages = [];
                    $.each(JSON.parse(response[m].lovDtls)["DBDOCLanguages"], function (a, b) {
                        disbDocLanguages.push(b.value);
                    });
                    disbDocLanguages = disbDocLanguages.unique();
                }
                if (n.lovName === "UDYAM_FAILED_REASONS" && Object.keys(JSON.parse(response[m].lovDtls))[0] ===
                    "Udyam Failed Reasons") {
                    window.udyamFailedReasons = [];
                    $.each(JSON.parse(response[m].lovDtls)["Udyam Failed Reasons"], function (a, b) {
                        udyamFailedReasons.push(b);
                    });
                }
                if (n.lovName === "SANCTION_MATRIX" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "SANCTION_MATRIX") {
                    SANCTION_MATRIX = JSON.parse(response[m].lovDtls)["SANCTION_MATRIX"];
                }
                if (n.lovName === "DBKITDOCSIZEMAP" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "DBKITDOCSIZEMAP") {
                    DBKITDOCSIZEMAP = [];
                    $.each(JSON.parse(response[m].lovDtls)["DBKITDOCSIZEMAP"], function (a, b) {
                        DBKITDOCSIZEMAP.push(b);
                    });
                }
                if (n.lovName === "DisbursementDocs" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "DisbursementDocs") {
                    window.DisbursementDocs = JSON.parse(response[m].lovDtls)['DisbursementDocs'];
                }
                if (n.lovName === "DASHBOARDORDER" && Object.keys(JSON.parse(response[m].lovDtls))[0] === "DASHBOARDORDER") {
                    DASHBOARDORDER = JSON.parse(response[m].lovDtls)['DASHBOARDORDER'];
                }
            });
            if (apz.isObjectEmpty(apz.data.scrdata.Dashbo__PaintLoanProducts_Res) || (!apz.isNull(apz.data.scrdata
                .Dashbo__PaintLoanProducts_Res.LoanProducts) && apz.data.scrdata.Dashbo__PaintLoanProducts_Res.LoanProducts.length ===
                0)) {
                if (!apz.isNull(apz.app.Dashboard.PaintDashboardTabs)) {
                    apz.app.Dashboard.PaintDashboardTabs();
                }
            }
        }
        if (window.iscustomLoginCB) {
            window.iscustomLoginCB = false;
            const userDetails = gApzCOB.LoggedInUserDetails;
            window.loginResponse = userDetails?.loginResponse;
            const dashboardResponse = userDetails?.DashboardObj?.apiResponse?.APZCBO__FetchRole?.apiResponse;
            if (loginResponse?.addInfo1 === 'HOM') {
                apz.app.Login.OnClickMakerChecker();
                return;
            }
            if (["KM", "BM", "BCM", "ACM", "AM", "DM", "RM", "HOM"].includes(loginResponse?.addInfo1)) {
                if (!apz.isObjectEmpty(userDetails?.DashboardObj?.apiResponse)) {
                    if (dashboardResponse?.ResponseHeader?.ResponseCode === "0") {
                        let roleresp = JSON.parse(dashboardResponse?.ResponseBody?.responseObj);
                        window.NEW_DASHBOARD_DATA = structuredClone(roleresp);
                        window.FetchRole = roleresp.map.roleAccessMap;
                        window.dataCountDashboard = roleresp.map.DashboardCounts;
                        gApzCOB.FetchRole = window.FetchRole;
                        window.currentRole = roleresp.map.roleAccessMap.roleId;
                        gApzCOB.workflow.currentRole = window.currentRole;
                        status1 = roleresp.map["allowedStatus"];
                        leads = roleresp.map["leadDtls"]?.myArrayList || [];
                        window.FilteredLeads = apz.app.BaseScreens.sortLeads(roleresp.map["fliteredLeadDtls"]?.myArrayList || []);
                        if (["KM", "BM"].includes(loginResponse?.addInfo1)) {
                            ApzCOB.LaunchRoleDashboard(roleresp);
                        } else {
                            apz.app.Login.OnClickMakerChecker();
                        }
                    } else {
                        throw new Error();
                    }
                } else {
                    throw new Error();
                }
            } else {
                gApzCOB.selectedRole = 'RPC_Maker';
                let para = {};
                para.value = "RPC Maker";
                apz.app.BaseScreens.roleSwitch(para);
            }
        }
    },
    showCountrycodeFlag: function (screenId, fieldId) {
        $("#" + screenId + fieldId).intlTelInput({
            autoHideDialCode: false,
            autoPlaceholder: "off",
            nationalMode: false,
            preferredCountries: [
                ApzCOB.GetCommonCodes("COUNTRYCODE", "COMM").COUNTRYCODE[0].preferredCountries,
            ] /*prefcountries*/,
            utilsScript: "utils.js",
        });
        if (ApzCOB.GetCommonCodes("COUNTRYCODE", "COMM").COUNTRYCODE[0].enabled !== "Y") {
            $("#" + screenId + fieldId).prop("readonly", true);
        }
    },
    //to format the amount onblur
    formatamount: function (pthis) {
        let x = $("#" + pthis.id).val();
        x = x.toString();
        let lastThree = x.substring(x.length - 3);
        let otherNumbers = x.substring(0, x.length - 3);
        if (otherNumbers !== "") {
            lastThree = "," + lastThree;
            let res = otherNumbers.replace(/\B(?=(\d{2}){1,10}(?!\d))/g, ",") + lastThree;
            $("#" + pthis.id).val(res);
        }
    },
    // to unformat the amount on focus
    unformatamount: function (pthis) {
        let x = $("#" + pthis.id).val();
        x = x.replaceAll(",", "");
        $("#" + pthis.id).val(x);
    },
    //on click of edit icon in review & confirm screen will redirect to the particular screen
    editlaunch: function (param, scrBaseRow, dashRevConf, currentStageNo) {
        apz.startLoader();
        window.revAndConf = true;
        window.dashRevConf = dashRevConf;
        try {
            $("div[id^=" + "'" + BaseScrId + "STAGE" + "'" + "]").addClass("sno");
            $.each(ConfigureScrJson, function (i, k) {
                if (k.confParamName === param) {
                    if (dashRevConf) {
                        $("#" + BaseScrId + "BaseDIV").addClass("sno");
                        $("#" + BaseScrId + "footerbtnRow").removeClass("sno");
                        $("#" + BaseScrId + "applnStatus").addClass("sno");
                        if (apz.isNull(gStates)) {
                            ApzCOB.FetchStates();
                        }
                        if (apz.isNull(gLovs)) {
                            ApzCOB.FetchLov();
                        }
                    }
                    gApzCOB.userDetails.currentScreen = k.confParamName.concat("~N");
                    STAGES.filter(function (el) {
                        if (parseInt(el.split("~")[1]) === currentStageNo) {
                            window.CURRENT_STAGE_NAME = el.split("~")[0];
                            window.STAGE_NO = parseInt(el.split("~")[1]) + 1;
                            window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                            window.baseRow = parseInt(el.split("~")[1]) + 1;
                            window.currRow = baseRow - 1;
                            window.prevRow = currRow - 1;
                            $("#" + BaseScrId + "STAGE" + currRow).removeClass("sno");
                            if (gApzCOB.mainProductGroupCode === "DEPOSIT") {
                                apz.app.BaseScreens.launchMicroApp(k);
                            } else {
                                ApzCOB.launchMicroApp(k.MicroAppID, k.ScreenID, BaseScrId + "STAGE" + currRow, "");
                            }
                        }
                        if (!completeArray.includes(parseInt(el.split("~")[1]))) {
                            completeArray.push(parseInt(el.split("~")[1]));
                        }
                    });
                    $.each(apz.data.scrdata.APZCBO__IpaintSideBarMenus_Res, function (a, b) {
                        if (parseInt(b.stageNo) === CURRENT_STAGE_NO) {
                            $("#" + BaseScrId + "headerText").text(b.stageName);
                        }
                    });
                    $("#APZCBO__BaseScreens__baseScroll").find(".stageDiv").map((stage, stageDiv) => $(stageDiv).find(
                        "div:not(.gcb-col12)").eq(0).remove());
                    $("#APZCBO__BaseScreens__sidebarController").addClass("sno");
                    $(BaseScroll).addClass(SecondaryProduct);
                    $("#" + BaseScrId + "homeicon").removeClass("sno");
                    ApzCOB.updateStepperStage();
                }
            });
            // apz.stopLoader()
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    //Default Mobile Back function with callBack
    MBbackPressedEvent: function () {
        if (apz.deviceType !== "WEB") {
            let json = {
                backButtonEvent: "on",
            };
            json.callBack = ApzCOB.MBbackPressedEventCB;
            json.id = "EventID";
            apz.ns.detectEvents(json);
        }
    },
    MBbackPressedEventCB: function (params) {
        return false;
    },
    //Fetch products Service
    FetchProducts: function () {
        let req = {
            appId: gAppId,
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "FetchProducts", "N", "N", req, false, ApzCOB.FetchProductsCB);
    },
    //Fetch products Service Callback
    FetchProductsCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = JSON.parse(params.res.APZCBO__FetchProducts_Res.apiResponse.ResponseBody.responseObj);
                apz.data.scrdata.Select__IpaintProduct_Res = {};
                apz.data.scrdata.Select__IpaintProduct_Res = response;
                apz.data.loadData("IpaintProduct", apz.currAppId);
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    //Fetch subproducts Service
    FetchProductsDetails: function (groupCode) {
        let req = {
            apiRequest: {
                requestObj: {
                    productGroupCode: groupCode,
                },
            },
        };
        ApzCOB.serverBuildParam(gAppId, "FetchProductDetails", "N", "N", req, false, ApzCOB.FetchProductsDetailsCB);
    },
    //Fetch subproducts Service callback
    FetchProductsDetailsCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                window.tempArr = [];
                window.prodArr = [];
                apz.data.scrdata.Select__IpaintProductDetails_Res = {};
                let response = JSON.parse(params.res.APZCBO__FetchProductDetails_Res.apiResponse.ResponseBody.responseObj);
                if (window.itssearch) {
                    window.itssearch = false;
                    if (response.length > 0) {
                        for (let i = 0; i < response.length; i++) {
                            tempArr.push(response[i].productName);
                            prodArr.push(response[i]);
                            if (i !== 0) {
                                prodArr[i].productName = " " + response[i].productName;
                            }
                        }
                        apz.populateDropdown(document.getElementById(BaseScrId + "subproductdrop"), ApzCOB.formatDropDownforArray(tempArr));
                        apz.stopLoader();
                    } else {
                        if ($("#APZCBO__BaseScreens__productdrop").val() === "INSURANCE" || $("#APZCBO__BaseScreens__productdrop").val() ===
                            "INVESTMENT") {
                            apz.stopLoader();
                            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_INFO_TXT_FEATURECOMINGSOON"), "I");
                        } else {
                            apz.stopLoader();
                            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
                        }
                    }
                } else {
                    if (response.length > 0) {
                        if (!window.editappln && window.currentApplication !== "InProgress") {
                            $("#" + SelProdScrId + "ProductDetailsRow").removeClass("sno");
                            $("#" + SelProdScrId + "NoRecordsFound").addClass("sno");
                            response.forEach(function (i1, k) {
                                Object.entries(JSON.parse(response[k]["productFeatures"])).forEach(function (m, n) {
                                    let obj = {};
                                    obj.key = Object.entries(JSON.parse(response[k]["productFeatures"]))[n][0];
                                    obj.value = Object.entries(JSON.parse(response[k]["productFeatures"]))[n][1];
                                    tempArr.push(obj);
                                });
                                if (k > 0) {
                                    if ($("#" + SelProdScrId + "ProductDetailsRow").children().length < response.length + 1) {
                                        $("#" + SelProdScrId + "accountTypeCol").clone().appendTo("#" + SelProdScrId +
                                            "ProductDetailsRow");
                                    }
                                }
                                $("#" + SelProdScrId + "accountTypeLabel").text(i1.productName);
                            });
                        } else {
                            response.map(function (data, index) {
                                let listValue = {};
                                let compValue = {};
                                let prodName = {};
                                let featureList = Object.values(JSON.parse(response[index].productFeatures));
                                listValue.productName = data.productName;
                                listValue.productCode = data.productCode;
                                listValue.productType = data.productType;
                                listValue.value = data.productDesc.split("~");
                                Object.getOwnPropertyNames(CommSelectProduct).forEach(function (el) {
                                    if (el.split("~")[0] === data.productGroupCode) {
                                        CommSelectProduct[el].forEach(function (k) {
                                            if (k.split("~")[0] === data.productName) {
                                                listValue.Image = k.split("~")[1];
                                                prodName.Image = k.split("~")[1];
                                            }
                                        });
                                    }
                                });
                                listValue.feature = JSON.parse(response[index].productFeatures);
                                if (listValue) {
                                    listValue.key = Object.keys(listValue.feature);
                                    tempArr.push(listValue);
                                    let featureData = featureList.map(function (desc, i2) {
                                        let feature = desc;
                                        return feature;
                                    });
                                    compValue.name = listValue.productName;
                                    compValue.description = featureData;
                                    prodName.prodName = listValue.productName;
                                    prodArr.push(prodName);
                                }
                            });
                        }
                        // Paint Product in Select Product based on ApplicationType
                        tempArr = tempArr.filter(
                            (ele) => ele.productType.toUpperCase() === ApplicationType.toUpperCase());
                        gApzCOB.SelectedProductName = tempArr[0].productName.toUpperCase();
                        if (tempArr.length > 0) {
                            window.prodArr = prodArr.filter(
                                (ele) => ele.prodName.toUpperCase() === gApzCOB.SelectedProductName);
                        }
                        apz.data.scrdata.Select__IpaintProductDetails_Res = {
                            data: tempArr,
                            products: prodArr,
                        };
                        if (!apz.isNull(apz.data.scrdata.Select__IpaintProductDetails_Res.data) && apz.data.scrdata
                            .Select__IpaintProductDetails_Res.data.length > 0) {
                            if (gApzCOB.mainProductGroupCode === "DEPOSIT" || gApzCOB.mainProductGroupCode === "LOAN") {
                                apz.data.scrdata.Select__IpaintProductDetails_Res.data.findIndex(function (el) {
                                    if (!gApzCOB.ExistingCustomer) {
                                        if (
                                            (!apz.isNull(gApzCOB.requestNodes.depositDetails) && gApzCOB.requestNodes.depositDetails
                                                .productCode === el.productCode) || (!apz.isNull(gApzCOB.requestNodes.loanDetails) &&
                                                    gApzCOB.requestNodes.loanDetails.productCode === el.productCode)) {
                                            gApzCOB.subProduct = el.productName;
                                        }
                                    } else {
                                        if (!apz.isNull(gApzCOB.requestNodes.applicationMaster) && gApzCOB.requestNodes
                                            .applicationMaster.productCode === el.productCode) {
                                            gApzCOB.subProduct = el.productName;
                                        }
                                    }
                                });
                                ApzCOB.getProductData();
                            }
                        }
                        apz.data.loadData("IpaintProductDetails", apz.currAppId);
                    } else {
                        $("#" + SelProdScrId + "ProductDetailsRow").addClass("sno");
                        $("#" + SelProdScrId + "NoRecordsFound").removeClass("sno");
                    }
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    //Hide and show fields based on CommonCode Configuration
    ConfigureFields: function (fieldMapArray, paramName, paramArrName, subArray, codeType) {
        if (apz.isNull(codeType)) {
            codeType = "COMM";
        }
        let CONFCODE = ApzCOB.GetCommonCodes(paramName, codeType)[paramArrName];
        if (!apz.isNull(subArray)) {
            CONFCODE = CONFCODE[subArray];
        }
        fieldMapArray.forEach(function (e, i) {
            CONFCODE.forEach(function (elm, ind) {
                //  e.fieldName.forEach(function(a, b) {
                if (typeof elm === "object") {
                    Object.getOwnPropertyNames(elm).forEach(function (el) {
                        ApzCOB.ConfigureFieldsObjectType(e, el);
                    });
                } else {
                    ApzCOB.ConfigureFieldsNonObjectType(e, elm);
                }
                // })
            });
        });
    },
    //function to configure fields for object type
    ConfigureFieldsObjectType: function (e, el) {
        if (e.fieldName === el.split("~")[0]) {
            e.fieldDivId.forEach(function (m, n) {
                if (el.split("~")[1] === "Y") {
                    $("#" + e.fieldId).removeClass("mand");
                    if (el.split("~")[2] === "M") {
                        if (!apz.isNull(e.fieldId)) {
                            e.fieldId.forEach(function (s, t) {
                                for (let i = 0; i < $("#" + s).parents().eq(5).find("label").length; i++) {
                                    if (!apz.isNull($("#" + s).parents().eq(5).find("label")[i + 1]) && $("#" + s).parents()
                                        .eq(5).find("label")[i + 1].id.split("_grp_lbl")[0] === s) {
                                        if ($("#" + s).parents().eq(5).find("label").eq(i).hasClass("ett-labl")) {
                                            $("#" + s).parents().eq(5).find("label").eq(i).addClass("req");
                                        } else {
                                            $("#" + s).parents().eq(5).find("label").eq(i - 1).addClass("req");
                                        }
                                    }
                                }
                                if ($("#" + s).hasClass("hasDatepicker")) {
                                    $("#" + s).parents().eq(7).find("label").eq(1).addClass("req");
                                }
                                $("#" + s).addClass("req");
                                $("#" + s).addClass("mand");
                            });
                        }
                    }
                    $("#" + m).removeClass("sno");
                } else {
                    $("#" + m).addClass("sno");
                }
            });
        }
    },
    //function to configure fields for non object type
    ConfigureFieldsNonObjectType: function (e, elm) {
        if (e.fieldName === elm.split("~")[0]) {
            e.fieldDivId.forEach(function (m, n) {
                if (elm.split("~")[1] === "Y") {
                    $("#" + e.fieldId).removeClass("mand");
                    if (elm.split("~")[2] === "M") {
                        if (!apz.isNull(e.fieldId)) {
                            e.fieldId.forEach(function (s, t) {
                                for (let i = 0; i < $("#" + s).parents().eq(5).find("label").length; i++) {
                                    if (!apz.isNull($("#" + s).parents().eq(5).find("label")[i + 1]) && $("#" + s).parents()
                                        .eq(5).find("label")[i + 1].id.split("_grp_lbl")[0] === s) {
                                        if ($("#" + s).parents().eq(5).find("label").eq(i).hasClass("ett-labl")) {
                                            $("#" + s).parents().eq(5).find("label").eq(i).addClass("req");
                                        } else {
                                            $("#" + s).parents().eq(5).find("label").eq(i - 1).addClass("req");
                                        }
                                    }
                                }
                                if ($("#" + s).hasClass("hasDatepicker")) {
                                    $("#" + s).parents().eq(7).find("label").eq(1).addClass("req");
                                }
                                $("#" + s).addClass("mand");
                            });
                        }
                    }
                    $("#" + m).removeClass("sno");
                } else {
                    if (!apz.isNull(e.nomineefieldId)) {
                        e.nomineefieldId.forEach(function (s, t) {
                            for (let i = 0; i <= apz.data.scrdata.NomDet__FetchNominee_Res.length; i++) {
                                let nomineeRowId = "#RevCof__ReviewConfirm__nomineeListRow_row_" + i;
                                if (elm.split("~")[1] === "Y") {
                                    $("#" + s + i).removeClass("sno");
                                    $(nomineeRowId + " " + "#" + e.nomineefieldColId).removeClass("sno");
                                } else {
                                    $("#" + s + i).addClass("sno");
                                    $(nomineeRowId + " " + "#" + e.nomineefieldColId).addClass("sno");
                                }
                            }
                        });
                    }
                    $("#" + m).addClass("sno");
                }
            });
        }
    },
    //hide main header if all the fields of main row are hidden
    hideHeader: function (fieldMapArray) {
        let ishide = true;
        fieldMapArray.forEach(function (e, i) {
            e.fieldId.forEach(function (p, n) {
                if (!$("#" + p).hasClass("sno")) {
                    ishide = false;
                    return;
                }
            });
            if (ishide) {
                $("#" + e.headerId).addClass("sno");
            }
        });
    },
    //toggle dropdown Modal
    toggleDropdownModal: function (modalId) {
        ApzCOB.toggleModal(modalId);
    },
    //paint the selected value from modal
    OnchangetoggleDropdownValue: function (pthis, inputId, modalId) {
        let data = $("#" + pthis.id).text();
        $("#" + inputId).val(data);
        ApzCOB.toggleDropdownModal(modalId);
    },
    //launch the screens based on common code configuration
    LaunchConfiguredScreens: function () {
        let isvalid = false;
        let stageBreak = false;
        window.backNav = false;
        $("#" + BaseScrId + "applnStatus").addClass("sno");
        $("#" + BaseScrId + "sidebaricon").removeClass("sno");
        let condition = onApplicationLoad ? true : !onApplicationLoad && !apz.isNull(gApzCOB.applicationType) ? true : false;
        let totalDivs = $(BaseDivId + BaseScrId + "" + "STAGE" + '"]').length;
        if (window.revAndConf) {
            window.STAGE_NO = revConfSTAGENO;
            window.CURRENT_STAGE_NO = STAGE_NO - 1;
            window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
            window.baseRow = revConfBaseRow;
            window.currRow = baseRow - 1;
            window.prevRow = currRow - 1;
        }
        if (NEXT_STAGE_NAME === "ACCOUNTCREATION" && !revAndConf) {
            $("#" + BaseScrId + "STAGE" + baseRow).removeClass("sno");
            $("#" + BaseScrId + "STAGE" + currRow).addClass("sno");
            window.STAGE_NO = STAGE_NO + 1;
            window.CURRENT_STAGE_NO = STAGE_NO - 1;
            window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
            window.baseRow = baseRow + 1;
            window.currRow = baseRow - 1;
            window.prevRow = currRow - 1;
        }
        if (ConfigureScrJson.filter(function (x, y) {
            return STAGES[0].split("~")[0] === x.confParamName;
        })[0].MicroAppID === apz.currAppId) {
            STAGES.filter(function (m, n) {
                if (m.split("~")[0].toUpperCase() === "SELECTPRODUCT") {
                    if (CURRENT_STAGE_NO > parseInt(m.split("~")[1].toUpperCase())) {
                        //do nothing
                    } else {
                        window.STAGE_NO = 2;
                        window.CURRENT_STAGE_NO = 1;
                        window.PREV_STAGE_NO = 0;
                        window.baseRow = 2;
                        window.currRow = 1;
                        window.prevRow = 0;
                    }
                }
            });
        }
        if (!apz.isNull(STAGES)) {
            STAGES.filter(function (m, n) {
                stageBreak = false;
                ConfigureScrJson.filter(function (i, k) {
                    if (!stageBreak) {
                        if (STAGE_NO === parseInt(m.split("~")[1].toUpperCase()) && baseRow <= totalDivs && i
                            .confParamName === m.split("~")[0].toUpperCase()) {
                            isvalid = apz.app.BaseScreens.checkScreenInMicroapp(i);
                            $("#" + BaseScrId + "baseScroll").removeClass("product-screen");
                            if (otpVerified && (NEXT_STAGE_NAME !== "SELECTPRODUCT" || NEXT_STAGE_NAME !==
                                "VALIDATEPINCODE" || NEXT_STAGE_NAME !== "CUSTVERIFICATION")) {
                                $("#APZCBO__BaseScreens__sidebarController").removeClass("sno");
                            }
                            if (isvalid && apz.app.BaseScreens.toggleApplicationType(STAGE_NO, gApzCOB.userDetails
                                .currentScreen.split("~")[0])) {
                                $("#" + BaseScrId + "applicationTypeModal").modal("hide");
                                if (!apz.isNull(ApzCOB.getDescfromLitCode(i.displayName))) {
                                    if ($("#" + BaseScrId + "menulist li:contains(" + ApzCOB.getDescfromLitCode(i
                                        .displayName) + ")").hasClass("completed")) {
                                        gApzCOB.userDetails.currentScreen = i.confParamName.concat("~N");
                                    } else {
                                        gApzCOB.userDetails.currentScreen = i.confParamName.concat("~Y");
                                    }
                                }
                                $("#" + BaseScrId + "headerRow").addClass("sno");
                                $("#" + BaseScrId + "footerbtnRow").addClass("sno");
                                $("#" + BaseScrId + "headerText").addClass("sno");
                                $("#" + BaseScrId + "phoneicon").addClass("sno");
                                $("#" + BaseScrId + "messageicon").addClass("sno");
                                $("#" + BaseScrId + "poptext").addClass("sno");
                                $("#" + BaseScrId + "baseRow").removeClass("start-menu");
                                //hide bac button for new customer function first stage
                                if (apz.currAppId === "KYCVer") {
                                    if ($("#" + KYCVerfScrId + "uidaiModal").is(":visible")) {
                                        $("#" + KYCVerfScrId + "uidaiModal").modal("hide");
                                    }
                                }
                                if (i.confParamName === "NOMINEEDETAILS") {
                                    if (addNomineeDetails === "N") {
                                        window.PREV_STAGE_NO = STAGE_NO - 1;
                                        window.STAGE_NO = STAGE_NO + 1;
                                        stageBreak = true;
                                        return;
                                    }
                                }
                                $("#" + BaseScrId + "backIcon").addClass("sno");
                                $("#" + BaseScrId + "continue").removeClass("sno");
                                $("#" + BaseScrId + "Agree").addClass("sno");
                                $("#" + BaseScrId + "sidebarCol").removeClass("sno");
                                if (NEXT_STAGE_NAME === "SELECTPRODUCT" || NEXT_STAGE_NAME === "VALIDATEPINCODE" ||
                                    NEXT_STAGE_NAME === "CUSTVERIFICATION") {
                                    $("#" + BaseScrId + "sidebarCol").addClass("sno");
                                }
                                $("#" + BaseScrId + "STAGE" + baseRow).removeClass("sno");
                                $("#" + BaseScrId + "STAGE" + currRow).addClass("sno");
                                /**SelfAssisted related Changes Starts***/
                                $("#" + BaseScrId + "landingRowHeader").removeClass("sno");
                                if (i.confParamName === "SELECTPRODUCT" && n === 0) {
                                    if (!apz.isNull(gApzCOB.requestNodes.applicationMaster) && !apz.isNull(gApzCOB
                                        .requestNodes.applicationMaster.productCode)) {
                                        window.STAGE_NO = STAGE_NO + 1;
                                        window.CURRENT_STAGE_NO = STAGE_NO - 1;
                                        window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                                        window.baseRow = baseRow + 1;
                                        window.currRow = baseRow - 1;
                                        window.prevRow = currRow - 1;
                                        return;
                                    }
                                }
                                /**SelfAssisted related Changes Ends***/
                                if (i.confParamName === "KYCVERIFICATION" && n === 0) {
                                    $("#" + BaseScrId + "sidebarCol").addClass("sno");
                                }
                                if (i.confParamName === "SELECTPRODUCT") {
                                    $("#" + BaseScrId + "continue").addClass("sno");
                                }
                                if (
                                    (otpVerified && i.confParamName === "CUSTVERIFICATION") || (gApzCOB.userDetails
                                        .versionNum > 1 && i.confParamName === "CUSTVERIFICATION") || ((i.confParamName ===
                                            "CUSTVERIFICATION" || i.confParamName === "VALIDATEPINCODE") && window.editappln)) {
                                    window.STAGE_NO = STAGE_NO + 1;
                                    window.CURRENT_STAGE_NO = STAGE_NO - 1;
                                    window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                                    window.baseRow = baseRow + 1;
                                    window.currRow = baseRow - 1;
                                    window.prevRow = currRow - 1;
                                    return;
                                }
                                if (window.PinCodeToggle && pinCodeVerified && CURRENT_STAGE_NAME === "VALIDATEPINCODE") {
                                    ApzCOB.toggleModal(ResiDenPinCDScrId + "ResidentialPinCodeModal");
                                    window.PinCodeToggle = false;
                                }
                                if (otpVerified && i.confParamName === "ELIGIBLECARDSLIST") {
                                    $("#" + BaseScrId + "STAGE1").html("");
                                    $("#" + BaseScrId + "baseRow").removeClass("sno");
                                    ApzCOB.hideDivsOnConfStages();
                                    ApzCOB.CompletedAndInprogress();
                                    $.each(apz.data.scrdata.APZCBO__IpaintSideBarMenus_Res, function (a, b) {
                                        if (parseInt(b.stageNo) === STAGE_NO) {
                                            $("#" + BaseScrId + "headerText").text(ApzCOB.getDescfromLitCode(b
                                                .stageNameLit));
                                            $("#" + BaseScrId + "headerText").text(ApzCOB.getDescfromLitCode(
                                                "LIT_COMM_GREETING_TXT_CONGRATULATIONSFORCARD"));
                                        }
                                    });
                                    $("#" + BaseScrId + "headerRow").removeClass("sno");
                                    $("#" + BaseScrId + "headerText").removeClass("sno");
                                    apz.app.BaseScreens.getDepositRequest(i);
                                    apz.app.BaseScreens.launchMicroApp(i);
                                    apz.app.BaseScreens.configureFirstStage(STAGE_NO, i.confParamName, i.MicroAppID, i
                                        .ScreenID, i.Service);
                                    $("input").attr("autocomplete", "off");
                                    window.baseRow = baseRow + 1;
                                    window.currRow = baseRow - 1;
                                    window.prevRow = currRow - 1 === 0 ? 1 : currRow - 1;
                                    UPDATED_STAGES.push(m);
                                } else {
                                    $("#" + BaseScrId + "baseRow").removeClass("sno");
                                    ApzCOB.hideDivsOnConfStages();
                                    ApzCOB.CompletedAndInprogress();
                                    $.each(apz.data.scrdata.APZCBO__IpaintSideBarMenus_Res, function (a, b) {
                                        if (parseInt(b.stageNo) === STAGE_NO) {
                                            $("#" + BaseScrId + "headerText").text(b.stageName);
                                        }
                                        $("#" + BaseScrId + "sidebarCol").removeClass("sno");
                                        if (gApzCOB.product === "DEPOSIT") {
                                            if (i.confParamName === "CUSTVERIFICATIONDP") {
                                                $("#" + BaseScrId + "sidebarCol").addClass("sno");
                                            }
                                        }
                                    });
                                    if (i.ScreenID === "FixedDeposit" || i.ScreenID === "RecDeposit") {
                                        $("#" + BaseScrId + "viewIntHpl").removeClass("sno");
                                        $("#" + BaseScrId + "viewProdHpl").removeClass("sno");
                                    } else {
                                        $("#" + BaseScrId + "headerRow").removeClass("sno");
                                        $("#" + BaseScrId + "viewIntHpl").addClass("sno");
                                        $("#" + BaseScrId + "viewProdHpl").addClass("sno");
                                    }
                                    apz.app.BaseScreens.getDepositRequest(i);
                                    apz.app.BaseScreens.launchMicroApp(i);
                                    apz.app.BaseScreens.configureFirstStage(STAGE_NO, i.confParamName, i.MicroAppID, i
                                        .ScreenID, i.Service);
                                    $("input").attr("autocomplete", "off");
                                    window.baseRow = baseRow + 1;
                                    window.currRow = baseRow - 1;
                                    window.prevRow = currRow - 1 === -1 ? 0 : currRow - 1;
                                    UPDATED_STAGES.push(m);
                                }
                                return;
                            }
                        }
                    }
                });
                return;
            });
            if (condition) {
                window.CURRENT_STAGE_NO = STAGE_NO;
                window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                window.STAGE_NO = STAGE_NO + 1;
                if (window.revAndConf) {
                    window.revAndConf = false;
                    window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                }
                window.CURRENT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split("~")[0];
                if (!apz.isNull(STAGES[CURRENT_STAGE_NO])) {
                    window.NEXT_STAGE_NAME = STAGES[CURRENT_STAGE_NO].split("~")[0];
                } else {
                    window.NEXT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split("~")[0];
                }
            }
            apz.stopLoader();
        }
        ApzCOB.getStageInfo();
        ApzCOB.updateStepperStage();
    },
    //hiding previous divs based on screens when its processing to next stage
    hideDivsOnConfStages: function () {
        $("#" + BaseScrId + "BaseDIV").addClass("sno");
        STAGES.forEach(function (m, n) {
            ConfigureScrJson.forEach(function (i, k) {
                if (STAGE_NO !== parseInt(m.split("~")[1].toUpperCase())) {
                    $.each(i.Divs, function (a, b) {
                        $("#" + i.MicroAppID + "__" + i.ScreenID + "__" + b).addClass("sno");
                    });
                }
            });
        });
    },
    //Adding css class for highlighting the completed and in-progress stages for sidebar menu
    CompletedAndInprogress: function () {
        if (!apz.isNull(gApzCOB.requestNodes.applicationMaster) && gApzCOB.requestNodes.applicationMaster.applicationStatus === "REJECTED") {
            if ($("#" + BaseScrId + "menulist ul").children().eq(0).find("p").text() === "Product Selection") {
                $("#" + BaseScrId + "menulist_row_" + 0).addClass("completed");
                $("#" + BaseScrId + "menulist_row_" + 1).addClass("progress");
            } else {
                $("#" + BaseScrId + "menulist_row_" + 0).addClass("progress");
            }
        } else {
            ApzCOB.loadMenuList();
        }
    },
    //validating the fields based on screens.
    validateConfFields: function () {
        let isValid = true;
        if (gApzCOB.demoMode === "N") {
            window.errorCount = 0;
            STAGES.forEach(function (m, n) {
                ConfigureScrJson.forEach(function (i, k) {
                    if (Number(CURRENT_STAGE_NO) === parseInt(m.split("~")[1].toUpperCase()) && i.confParamName === m.split(
                        "~")[0].toUpperCase()) {
                        window.isCUSTOMERDETAILS = i.confParamName;
                        if (!apz.isNull(i.FormValidator)) {
                            $.each(i.FormValidator, function (a, b) {
                                if (!$("#" + i.MicroAppID + "__" + i.ScreenID + "__" + b).parents(".full-drop")
                                    .hasClass("sno")) {
                                    let form = "",
                                        form_validator_check = {};
                                    form = $("#" + i.MicroAppID + "__" + i.ScreenID + "__" + b).find(
                                        ".input-field:not(.sno) input");
                                    for (let n1 = 0; n1 < form.length; n1++) {
                                        form_validator_check = {
                                            [form[n1]["id"]]: {
                                                verify: nullcheck,
                                                dropDown,
                                                radiogroup,
                                            },
                                        };
                                        isValid = ApzCOB.validateInputFields(form, n1, form_validator_check);
                                    }
                                }
                            });
                        } else if (i.confParamName === "INITIALFUND") {
                            isValid = apz.app.InitialFundRD.validateAccountSel();
                        } else if (i.confParamName === "AUTOPAYMI") {
                            isValid = apz.app.AutoPayMI.validateFields();
                        } else if (i.confParamName === "DEPOSITDETAILS") {
                            if (recurringDepEnabled === "N") {
                                isValid = apz.app.FixedDeposit.validateFields();
                            } else {
                                isValid = apz.app.RecDeposit.validateFields();
                            }
                        } else if (i.confParamName === "EMIDETAILS") {
                            isValid = apz.app.EMIDetails.validateFields();
                        } else if (i.confParamName === "CREDITDETAILS") {
                            isValid = apz.app.CreditDetails.validateFields();
                        } else {
                            isValid = true;
                        }
                    }
                });
            });
        }
        if (isCUSTOMERDETAILS === "CUSTOMERDETAILS" && isValid === true) {
            apz.app.PersonalDetails.verifyPan();
            if (window.isValid) {
                isValid = true;
            } else {
                isValid = false;
            }
        }
        return isValid;
    },
    //Create application service to insert data to the respective tables stage by stage
    createApplication: function () {
        if (gApzCOB.applicationType === JointAccount && gApzCOB.noOfApplicants < window.jointAppliCount) {
            ApzCOB.LaunchConfiguredScreens();
        }
        let data;
        let isvalid = false;
        let req = {};
        req.apiRequest = {};
        req.apiRequest.requestObj = {};
        if (!apz.isNull(gApzCOB.requestNodes.applnWfDefinitionList) && gApzCOB.requestNodes.applnWfDefinitionList.length > 0) {
            gApzCOB.requestNodes.applnWfDefinitionList = [];
        }
        if (ApzCOB.validateConfFields()) {
            if (CURRENT_STAGE_NO <= STAGES.length) {
                STAGES.forEach(function (m, n) {
                    ConfigureScrJson.forEach(function (i, k) {
                        if (Number(CURRENT_STAGE_NO) === parseInt(m.split("~")[1].toUpperCase()) && i.confParamName === m
                            .split("~")[0].toUpperCase()) {
                            isvalid = apz.app.BaseScreens.checkScreenInMicroapp(i);
                            if (isvalid && !apz.isNull(i.requestFunc)) {
                                let curScopeFunc = i.requestFunc.split(".");
                                req.apiRequest.requestObj = window[curScopeFunc[0]][curScopeFunc[1]][curScopeFunc[2]][
                                    curScopeFunc[3]
                                ]();
                            }
                            /**SelfAssisted related Changes Starts***/
                            req.apiRequest.userId = gApzCOB.LoggedInUserDetails.loginResponse.userDet.id;
                            req.apiRequest.appId = gAppId;
                            req.apiRequest.interfaceName = "CreateApplication";
                            /**SelfAssisted related Changes Ends***/
                            req.apiRequest.requestObj.appId = gApzCOB.userDetails.appId;
                            req.apiRequest.requestObj.applicationId = gApzCOB.userDetails.applicationId;
                            req.apiRequest.requestObj.versionNum = window.versionNum;
                            req.apiRequest.requestObj.isExistingCustomer = apz.isNull(gApzCOB.ExistingCustomer) ? "N" :
                                gApzCOB.ExistingCustomer ? "Y" : "N";
                            req.apiRequest.requestObj.applicationMaster = {
                                createdBy: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                                custDtlId: gApzCOB.userDetails.custDtlId,
                                applicationType: "online",
                                kycType: gApzCOB.userDetails.kycFlag,
                                declarationFlag: gApzCOB.userDetails.declarationFlag,
                                // "applicationStatus": "",
                                mobileNumber: !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails
                                    .mobileNum : null,
                                nationalId: !apz.isNull(gApzCOB.userDetails.nationalId) ? gApzCOB.userDetails
                                    .nationalId : null,
                                pan: !apz.isNull(gApzCOB.userDetails.panNum) ? gApzCOB.userDetails.panNum
                                    .toUpperCase() : null,
                                productCode: gApzCOB.productCode,
                                productGroupCode: gApzCOB.product,
                                //"searchCode1": "",
                                //"searchCode2": "",
                                leadId: "",
                                emailId: gApzCOB.userDetails.email,
                                currentScreenId: gApzCOB.userDetails.currentScreen,
                                relatedApplicationId: gApzCOB.relatedApplicationId,
                                custDtlSlNum: gApzCOB
                                    .currentApplicant, //needs to be changed to gApzCOB.currentApplicant on merging joint account code
                                applicantsCount: gApzCOB.noOfApplicants,
                                mainProductGroupCode: gApzCOB.mainProductGroupCode,
                                /*"isExistingCustomer": apz.isNull(gApzCOB.ExistingCustomer) ? "" : gApzCOB.ExistingCustomer ?

                                                    'Y' : 'N'*/
                            };
                            if (!apz.isNull(gApzCOB.userDetails.pinCode) && apz.isNull(gApzCOB.userDetails.applicationId)) {
                                gApzCOB["requestNodes"]["bankingFacilityList"] = [];
                                req.apiRequest.requestObj.bankingFacilityList = [{
                                    //  "appId": gAppId,
                                    bankFacilityId: gApzCOB.userDetails.bankFacilityId,
                                    payload: {
                                        branchName: gApzCOB.userDetails.branchName,
                                        branchAddress: gApzCOB.userDetails.branchAddress,
                                        branchCode: gApzCOB.userDetails.branchCode,
                                    },
                                },];
                                gApzCOB["requestNodes"]["bankingFacilityList"] = req.apiRequest.requestObj
                                    .bankingFacilityList;
                            }
                            if (apz.isNull(gApzCOB.userDetails.applicationId)) {
                                req.apiRequest.requestObj.workflow = {
                                    currentRole: gApzCOB.currentRole,
                                };
                            } else {
                                apz.app.BaseScreens.stageBasedOnAction();
                                req.apiRequest.requestObj.workflow = {
                                    currentRole: gApzCOB.workflow.currentRole,
                                    action: gApzCOB.workflow.action,
                                    workflowId: gApzCOB.workflow.workflowId,
                                    stage: gApzCOB.workflow.stage,
                                };
                            }
                            if (!apz.isNull(req.apiRequest.requestObj.applnWfDefinitionList)) {
                                delete req.apiRequest.requestObj.applnWfDefinitionList;
                            }
                        }
                    });
                });
                apz.startLoader();
                if (gApzCOB.applicationType === JointAccount) {
                    req.apiRequest.requestObj.applicationMaster.applicantsCount = gApzCOB.noOfApplicants;
                }
                ApzCOB.serverBuildParam(gAppId, "CreateApplication", "N", "N", req, false, ApzCOB.createApplicationCB);
            }
        }
    },
    //create application service callback
    createApplicationCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = JSON.parse(params.res.APZCBO__CreateApplication_Res.apiResponse.ResponseBody.responseObj);
                window.JointFlow = false;
                ApzCOB.responseNodeUpdate(response);
                if (!apz.isNull(response.applnWfDefinitionList)) {
                    gApzCOB.applnWorkFlowRes = response.applnWfDefinitionList;
                }
                if (apz.childScr === "NomineeDetails") {
                    if (gaction === "ADD" || gaction === "EDIT") {
                        window.newNominee = true;
                        if ($("#" + nomineeScrId + "NomineeModal").is(":visible")) {
                            ApzCOB.attachOnclickEvent(
                                [].concat($("#" + nomineeScrId + "NomineeModal_close")), "");
                            ApzCOB.toggleModal(nomineeScrId + "NomineeModal");
                            let nomineeLen = gApzCOB.requestNodes.nomineeDetailsWrapperList.length;
                            gApzCOB.requestNodes.nomineeDetailsWrapperList[nomineeLen - 1]["nomineeDetailsList"][0]["nomineeDtlsId"] = gApzCOB
                                .userDetails.nomineeDtlsId;
                            gApzCOB.userDetails.nomineeDtlsId = "";
                            apz.app.NomineeDetails.checkNominee();
                            apz.app.NomineeDetails.clearForm();
                        }
                    } else if (gaction === "") {
                        ApzCOB.LaunchConfiguredScreens();
                    }
                } else if (Number(CURRENT_STAGE_NO) === STAGES.length || (window.NEXT_STAGE_NAME === "ACCOUNTCREATION" && Number(
                    CURRENT_STAGE_NO) === STAGES.length - 1)) {
                    apz.stopLoader();
                    if (Number(gApzCOB.noOfApplicants) > 1 && gApzCOB.currentApplicant < Number(gApzCOB.noOfApplicants) && gApzCOB
                        .currentApplicant - 1 !== Number(gApzCOB.noOfApplicants) && gApzCOB.applicationType === JointAccount && isdone !==
                        Number(gApzCOB.noOfApplicants) && ((gApzCOB.currentApplicant === 1 && gApzCOB.noOfApplicants > 1) || (gApzCOB
                            .mainProductGroupCode === "LOAN" && gApzCOB.LoanCallCBS !== "N"))) {
                        window.Secoundperson = true;
                        isdone++;
                        gApzCOB.currentApplicant = gApzCOB.currentApplicant + 1;
                        ApzCOB.LaunchConfiguredScreens();
                    } else {
                        window.reviewConfirmJoint = false;
                        if (selectedType === "LOAN") {
                            ApzCOB.toggleModal(BaseScrId + "NewLoanSuccessModal");
                            $("#" + BaseScrId + "NewLoanCongratsTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_SUCC_TXT_CONGRATS"));
                            $("#" + BaseScrId + "NewLoanSuccTxt").text(ApzCOB.getDescfromLitCode(
                                "LIT_REVCONF_SUCC_TXT_LOANACCOUNTCREATEDSUCC"));
                            $("#" + BaseScrId + "NewLoanRefNumberLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_REFNUMBER"));
                            $("#" + BaseScrId + "NewLoanAmountLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_LOANDTLS_LOAN_AMT"));
                            $("#" + BaseScrId + "NewLoanDownloadBtnTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_DOWNLOAD"));
                            $("#" + BaseScrId + "NewLoanOkBtntxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_OK"));
                            $("#" + BaseScrId + "loanRefNum").text(gApzCOB.userDetails.applicationId);
                            $("#" + BaseScrId + "loanAmount").text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(
                                gApzCOB.requestNodes.loanDetails.loanAmount));
                            return;
                        } else {
                            ApzCOB.toggleModal(BaseScrId + "successModal");
                            $("#" + BaseScrId + "congrtzText").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_SUCC_TXT_CONGRATS"));
                            $("#" + BaseScrId + "sucText").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_SUCC_TXT_YOURACCOUNTCREATEDSUCC"));
                            $("#" + BaseScrId + "CIFNumberLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_CIFNUMBER"));
                            $("#" + BaseScrId + "AccountNumberLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_ACCOUNTNUMBER"));
                            $("#" + BaseScrId + "CustomerNameLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_CUSTOMERNAME"));
                            $("#" + BaseScrId + "ApplicationIDLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_APPLICATIONID"));
                            $("#" + BaseScrId + "RegisterInternetMobileBankingTxt").text(ApzCOB.getDescfromLitCode(
                                "LIT_REVCONF_INFO_TXT_REGISTERINTERNETMOBILEBANKING"));
                            $("#" + BaseScrId + "DownloadButtonTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_DOWNLOAD"));
                            $("#" + BaseScrId + "OkBtnTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_OK"));
                            $("#" + BaseScrId + "fundButtonRow").addClass("sno");
                            $("#" + BaseScrId + "fundSuccText").addClass("sno");
                            if (gApzCOB.CobCallCBS === "Y") {
                                gApzCOB.userDetails.accNumber = response.accNumber;
                                gApzCOB.userDetails.cifNum = response.customerId;
                                $("#" + BaseScrId + "approveRow").removeClass("sno");
                                $("#" + BaseScrId + "createRow").addClass("sno");
                                $("#" + BaseScrId + "regTxtRow").removeClass("sno");
                                $("#" + BaseScrId + "fndYAccCol").removeClass("sno");
                                $("#" + BaseScrId + "accNum").text(gApzCOB.userDetails.accNumber);
                                $("#" + BaseScrId + "cifNum").text(gApzCOB.userDetails.cifNum);
                                if (gApzCOB.fundAccount === "Y") {
                                    $("#" + BaseScrId + "cobNRow").addClass("sno");
                                    if (
                                        (gApzCOB.product === "CASA" || gApzCOB.product === "DEPOSIT") && !apz.isNull(gApzCOB
                                            .relatedApplicationId) && !apz.isNull(gApzCOB.ExistingCustomer) && !gApzCOB.ExistingCustomer) {
                                        $("#" + BaseScrId + "cobYRow").addClass("sno");
                                        $("#" + BaseScrId + "depositRow").removeClass("sno");
                                        $("#" + BaseScrId + "sucText").text(ApzCOB.getDescfromLitCode(
                                            "LIT_COMM_SUCC_TXT_YOURACCCREATEDSUCC"));
                                        $("#" + BaseScrId + "infoMsg").text(ApzCOB.getDescfromLitCode("LIT_ACC_ACTIVATION"));
                                    } else {
                                        $("#" + BaseScrId + "cobYRow").removeClass("sno");
                                    }
                                } else {
                                    $("#" + BaseScrId + "cobNRow").removeClass("sno");
                                    $("#" + BaseScrId + "cobNRowDownload").removeClass("sno");
                                    $("#" + BaseScrId + "cobYRow,#" + BaseScrId + "cobNRowFund").addClass("sno");
                                }
                                $("#" + BaseScrId + "headerTextRow").removeClass("sno");
                            } else {
                                $("#" + BaseScrId + "nofund").removeClass("sno");
                                $("#" + BaseScrId + "fund").addClass("sno");
                                $("#" + BaseScrId + "approveRow").addClass("sno");
                                $("#" + BaseScrId + "regTxtRow").addClass("sno");
                                $("#" + BaseScrId + "fndYAccCol").addClass("sno");
                                $("#" + BaseScrId + "createRow").removeClass("sno");
                                $("#" + BaseScrId + "custName").text(window.customerNamess);
                                $("#" + BaseScrId + "applnId").text(gApzCOB.userDetails.applicationId);
                                $("#" + BaseScrId + "cobNRowDownload").removeClass("sno");
                                $("#" + BaseScrId + "cobYRow,#" + BaseScrId + "cobNRowFund").addClass("sno");
                                $("#" + BaseScrId + "cobNRow").removeClass("sno");
                                $("#" + BaseScrId + "headerTextRow").addClass("sno");
                            }
                            $("#" + BaseScrId + "sucText").text(gApzCOB.CobCallCBS === "N" ? ApzCOB.getDescfromLitCode(
                                "LIT_COMM_SUCCESS_TXT_APPSUBSUCCESSBANKPROCESS") : ApzCOB.getDescfromLitCode("LIT_ACC_CREATED_SUCC"));
                            if (
                                (gApzCOB.product === "CASA" || gApzCOB.product === "DEPOSIT") && !apz.isNull(gApzCOB.relatedApplicationId) &&
                                !apz.isNull(gApzCOB.ExistingCustomer) && !gApzCOB.ExistingCustomer) {
                                $("#" + BaseScrId + "cobNRow").addClass("sno");
                                $("#" + BaseScrId + "cobYRow").addClass("sno");
                                $("#" + BaseScrId + "depositRow").removeClass("sno");
                                $("#" + BaseScrId + "sucText").text(ApzCOB.getDescfromLitCode("LIT_COMM_SUCC_TXT_YOURACCCREATEDSUCC"));
                                $("#" + BaseScrId + "infoMsg").text(ApzCOB.getDescfromLitCode("LIT_ACC_ACTIVATION"));
                            }
                        }
                    }
                    return;
                } else {
                    if (existingAccount) {
                        apz.app.BaseScreens.getCommomCodeBasedOnProduct();
                    }
                    gApzCOB.productDetails.product = gApzCOB.product;
                    gApzCOB.productDetails.productCode = gApzCOB.productCode;
                    gApzCOB.productDetails.subProductName = gApzCOB.subProduct;
                    ApzCOB.LaunchConfiguredScreens();
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
        window.scroll(0, 0);
    },
    createDeposit: function () {
        let data;
        let isvalid = false;
        let req = {};
        req.apiRequest = {};
        req.apiRequest.requestObj = {};
        if (!apz.isNull(gApzCOB.requestNodes.applnWfDefinitionList) && gApzCOB.requestNodes.applnWfDefinitionList.length > 0) {
            gApzCOB.requestNodes.applnWfDefinitionList = [];
        }
        if (ApzCOB.validateConfFields()) {
            if (CURRENT_STAGE_NO <= STAGES.length) {
                STAGES.forEach(function (m, n) {
                    ConfigureScrJson.forEach(function (i, k) {
                        if (Number(CURRENT_STAGE_NO) === parseInt(m.split("~")[1].toUpperCase()) && i.confParamName === m
                            .split("~")[0].toUpperCase()) {
                            isvalid = apz.app.BaseScreens.checkScreenInMicroapp(i);
                            if (isvalid && !apz.isNull(i.requestFunc)) {
                                let curScopeFunc = i.requestFunc.split(".");
                                req.apiRequest.requestObj = window[curScopeFunc[0]][curScopeFunc[1]][curScopeFunc[2]][
                                    curScopeFunc[3]
                                ]();
                            }
                            if (gApzCOB.userDetails.existingCustomer === "N") {
                                if (Object.entries(DEPOSIT_OBJ).length !== 0) {
                                    gApzCOB["requestNodes"]["depositDetails"] = DEPOSIT_OBJ;
                                    req.apiRequest.requestObj.depositDetails = gApzCOB["requestNodes"]["depositDetails"];
                                }
                            }
                            req.apiRequest.userId = gApzCOB.LoggedInUserDetails.loginResponse.userDet.id;
                            req.apiRequest.appId = gAppId;
                            req.apiRequest.interfaceName = "PopulateCustomerDetails";
                            req.apiRequest.requestObj.appId = gApzCOB.userDetails.appId;
                            if (gApzCOB.mainProductGroupCode === "DEPOSIT" || gApzCOB.mainProductGroupCode === "LOAN" || !
                                gApzCOB.ExistingCustomer) {
                                req.apiRequest.requestObj.applicationId = gApzCOB.relatedApplicationId;
                            } else {
                                req.apiRequest.requestObj.applicationId = gApzCOB.userDetails.applicationId;
                            }
                            req.apiRequest.requestObj.applicationId = !apz.isNull(gApzCOB.relatedApplicationId) ? gApzCOB
                                .relatedApplicationId : gApzCOB.userDetails.applicationId;
                            req.apiRequest.requestObj.versionNum = window.versionNum;
                            req.apiRequest.requestObj.isExistingCustomer = apz.isNull(gApzCOB.ExistingCustomer) ? "" : gApzCOB
                                .ExistingCustomer ? "Y" : "N";
                            req.apiRequest.requestObj.applicationMaster = {
                                isRd: recurringDepEnabled,
                                applicationType: "online",
                                createdBy: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                                currentScreenId: gApzCOB.userDetails.currentScreen,
                                customerId: gApzCOB.userDetails.customerId,
                                declarationFlag: gApzCOB.userDetails.declarationFlag,
                                emailId: gApzCOB.userDetails.email,
                                mobileNumber: !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails
                                    .mobileNum : null,
                                productCode: gApzCOB.productCode,
                                productGroupCode: gApzCOB.product,
                                searchCode1: gApzCOB.userDetails.branchCode,
                                applicantsCount: 1,
                                mainProductGroupCode: gApzCOB.mainProductGroupCode,
                            };
                            if (!apz.isNull(gApzCOB.userDetails.pinCode) && apz.isNull(gApzCOB.userDetails.applicationId)) {
                                gApzCOB["requestNodes"]["bankingFacilityList"] = [];
                                req.apiRequest.requestObj.bankingFacilityList = [{
                                    //  "appId": gAppId,
                                    bankFacilityId: gApzCOB.userDetails.bankFacilityId,
                                    payload: {
                                        branchName: gApzCOB.userDetails.branchName,
                                        branchAddress: gApzCOB.userDetails.branchAddress,
                                        branchCode: gApzCOB.userDetails.branchCode,
                                    },
                                },];
                                gApzCOB["requestNodes"]["bankingFacilityList"] = req.apiRequest.requestObj
                                    .bankingFacilityList;
                            }
                            if (apz.isNull(gApzCOB.userDetails.applicationId)) {
                                req.apiRequest.requestObj.workflow = {
                                    currentRole: "",
                                };
                            } else {
                                if (NEXT_STAGE_NAME === "ACCOUNTCREATION") {
                                    apz.app.BaseScreens.stageBasedOnAction();
                                    req.apiRequest.requestObj.workflow = {
                                        currentRole: gApzCOB.workflow.currentRole,
                                        action: gApzCOB.workflow.action,
                                        workflowId: gApzCOB.workflow.workflowId,
                                        stage: gApzCOB.workflow.stage,
                                    };
                                }
                            }
                        }
                    });
                });
                apz.startLoader();
                ApzCOB.serverBuildParam(gAppId, "CreateDeposit", "N", "N", req, false, ApzCOB.createDepositCB);
            }
        }
    },
    //create application service callback
    createDepositCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = JSON.parse(params.res.APZCBO__CreateDeposit_Res.apiResponse.ResponseBody.responseObj);
                ApzCOB.responseNodeUpdate(response);
                if (!apz.isNull(response.applnWfDefinitionList)) {
                    gApzCOB.applnWorkFlowRes = response.applnWfDefinitionList;
                }
                apz.app.BaseScreens.setDepositCompletedStage();
                if (apz.childScr === "NomineeDetails") {
                    if (newNominee || gaction === "ADD" || gaction === "EDIT") {
                        if ($("#" + nomineeScrId + "NomineeModal").is(":visible")) {
                            ApzCOB.attachOnclickEvent(
                                [].concat($("#" + nomineeScrId + "NomineeModal_close")), "");
                            ApzCOB.toggleModal(nomineeScrId + "NomineeModal");
                            let nomineeLen = gApzCOB.requestNodes.nomineeDetailsWrapperList.length;
                            gApzCOB.requestNodes.nomineeDetailsWrapperList[nomineeLen - 1]["nomineeDetailsList"][0]["nomineeDtlsId"] = gApzCOB
                                .userDetails.nomineeDtlsId;
                            gApzCOB.userDetails.nomineeDtlsId = "";
                            apz.app.NomineeDetails.checkNominee();
                            apz.app.NomineeDetails.clearForm();
                            window.newNominee = false;
                        } else {
                            ApzCOB.LaunchConfiguredScreens();
                        }
                    } else if (gaction === "") {
                        ApzCOB.LaunchConfiguredScreens();
                    }
                    gApzCOB.nomineeStageUpdated = true;
                } else if (Number(CURRENT_STAGE_NO) === STAGES.length || (window.NEXT_STAGE_NAME === "ACCOUNTCREATION" && Number(
                    CURRENT_STAGE_NO) === STAGES.length - 1)) {
                    apz.stopLoader();
                    ApzCOB.toggleModal(BaseScrId + "depositSucModal");
                    $("#" + BaseScrId + "DipCongrats").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_SUCC_TXT_CONGRATS"));
                    $("#" + BaseScrId + "sucscreentextdeposit").text(ApzCOB.getDescfromLitCode(
                        "LIT_REVCONF_SUCC_TXT_YOURACCOUNTCREATEDSUCC"));
                    $("#" + BaseScrId + "DipAmountLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_DEPOSITAMOUNT"));
                    $("#" + BaseScrId + "DipMaturityDateLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_MATURITYDATE"));
                    $("#" + BaseScrId + "DipAccLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_DEPOSITACCOUNT"));
                    $("#" + BaseScrId + "DipAutoDebitAccLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_AUTDEBITACCOUNT"));
                    $("#" + BaseScrId + "AutoDebitDateLabel").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_AUTODEBITDATE"));
                    $("#" + BaseScrId + "DipOkBtnTxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_OK"));
                    $("#" + BaseScrId + "DipDownloadBtntxt").text(ApzCOB.getDescfromLitCode("LIT_REVCONF_BTN_TXT_DOWNLOAD"));
                    $("#" + BaseScrId + "sucDepAmt").text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(DEPOSIT_OBJ
                        .depositAmount));
                    $("#" + BaseScrId + "sucMatDate").text(ApzCOB.dateformatter(DEPOSIT_OBJ.maturityDate, "d M Y"));
                    $("#" + BaseScrId + "sucDepAcc").text(DEPOSIT_OBJ.payoutAccount);
                    $("#" + BaseScrId + "sucscreentextdeposit").text(gApzCOB.CobCallCBS === "N" ? ApzCOB.getDescfromLitCode(
                        "LIT_COMM_SUCCESS_TXT_APPSUBSUCCESSBANKPROCESS") : ApzCOB.getDescfromLitCode("LIT_ACC_CREATED_SUCC"));
                    if (recurringDepEnabled && DEPOSIT_OBJ.autopayEnabled === "Y") {
                        $("#" + BaseScrId + "sucDebitAcc").text(DEPOSIT_OBJ.autopaySrcAccount);
                        $("#" + BaseScrId + "sucAutoDebitDate").text(DEPOSIT_OBJ.autopayDate);
                    } else {
                        $("#" + BaseScrId + "autoPayDetails").addClass("sno");
                        $("#" + BaseScrId + "depositSucForm").removeClass("single-col");
                    }
                    if (gApzCOB.CobCallCBS === "Y") {
                        $("#" + BaseScrId + "DepositAccount").removeClass("sno");
                    } else {
                        $("#" + BaseScrId + "DepositAccount").addClass("sno");
                    }
                    $("#" + BaseScrId + "sucText").text(gApzCOB.CobCallCBS === "N" ?
                        "Application Submitted Successfully. A bank representitive will process your application" : ApzCOB
                            .getDescfromLitCode("LIT_APPLN_SUC_MSG"));
                    return;
                } else {
                    if ($("#" + BaseScrId + "newCustomerModal").is(":visible")) {
                        $("#" + BaseScrId + "newCustomerModal_close").trigger("click");
                    }
                    ApzCOB.LaunchConfiguredScreens();
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
