    BRECbServiceCB: function (params) {
        window.CBBASE64 = "";
        window.CB_HIGHMARK_REPORT_LINK = "";
        let errMsg = "";
        if (!apz.isNull(params.resFull.appzillonBody.APZCBO__BRECBCheck_Res.apiResponse)) {
            if (!apz.isNull(params.resFull.appzillonBody.APZCBO__BRECBCheck_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = params.resFull.appzillonBody.APZCBO__BRECBCheck_Res.apiResponse.ResponseHeader.ResponseMessage;
            }
        } else {
            errMsg = ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_CB_CHECK_SERVICE_FAILED");
        }
        if (ApzCOB.handleServiceCallBacks(params)) {
            if (!isRPCLogin) {
                apz.stopLoader();
            } else {
                apz.startLoader();
            }
            let responseObj = JSON.parse(params.res.APZCBO__BRECBCheck_Res.apiResponse.ResponseBody.responseObj);
            let cbResponseObj = JSON.parse(responseObj.responseObj.payloadColumn);
            // Store cbDtlId
            if (gApzCOB.currentApplicant > 1) {
                gApzCOB.userDetails.coApplicantCbDtlsId = responseObj.responseObj.cbDtlId;
            } else {
                gApzCOB.userDetails.cbDtlsId = responseObj.responseObj.cbDtlId;
            }
            if (!apz.isNull(cbResponseObj.finalDecision)) {
                let cbScore = 0;
                if (!apz.isNull(cbResponseObj.cbScore) && parseInt(cbResponseObj.cbScore) !== 0) {
                    cbScore = parseInt(cbResponseObj.cbScore);
                }
                if (!cbResponseObj.finalDecision.toLowerCase().includes("approve")) {
                    cbResponseObj.eligibleAmt = "0";
                }
                cibilDtls.overdueAmt = cbResponseObj.overdueAmt ?? "";
                cibilDtls.bureauName = cbResponseObj.bureauName ?? "";
                cibilDtls.cbScore = cbScore ?? "";
                cibilDtls.totIndebtness = cbResponseObj.totIndebtness ?? "";
                cibilDtls.maxDpdInLastMonths = cbResponseObj.caglDpdFlag ?? "";
                cibilDtls.writtenOff = cibilDtls.writenoffAmt = cbResponseObj.writeOffAmt ?? "";
                cibilDtls.finalDecision = cbResponseObj.finalDecision ?? "";
                cibilDtls.eligibleAmt = !apz.isNull(cbResponseObj.eligibleAmt) ? ApzCOB.fn_FormatAmount(cbResponseObj.eligibleAmt) : "0";
                cibilDtls.foir = cbResponseObj.foir ?? "";
                cibilDtls.cgpDpd = cbResponseObj.caglDpdFlag ?? "";
                cibilDtls.cbLoanId = window.CB_LOAN_ID = cbResponseObj.cbLoanId ?? ""; //"A0117168063485601902"
                cibilDtls.appliedLoanCode = cbResponseObj.appliedLoanCode ?? ""; //"GL.GRM.UNNATI.LN"
                cibilDtls.approvedLoanEMI = cbResponseObj.approvedLoanEMI ?? ""; //"3844.96"
                cibilDtls.caglUnnatiFlag = cbResponseObj.caglUnnatiFlag ?? ""; //"Unnati DPD Flag : 0 | PASS"
                cibilDtls.cbRetrigger = cbResponseObj.cbRetrigger ?? ""; //false
                cibilDtls.eir = cbResponseObj.eir ?? ""; //"0%"
                cibilDtls.eligibleEMI = cbResponseObj.eligibleEMI ?? ""; //"Eligible EMI : 20000"
                cibilDtls.finalTenure = cbResponseObj.finalTenure ?? ""; //"36"
                cibilDtls.flowResponse = cbResponseObj.flowResponse ?? ""; //"Approved with Preclosure"
                cibilDtls.irisMessage = cbResponseObj.irisMessage ?? ""; //"success"
                cibilDtls.kycId = cbResponseObj.kycId ?? ""; //"UFJ2416998"
                cibilDtls.memberId = cbResponseObj.memberId ?? ""; //"587725"
                cibilDtls.otsFlag = cbResponseObj.otsFlag ?? ""; //"No"
                cibilDtls.writeoffSuitFiledFlag = cbResponseObj.writeoffSuitFiledFlag ?? ""; //"Applicant Writeoff_Suit filed Flag : NO"
                cibilDtls.individualIndebtness = cbResponseObj.individualIndebtness ?? "";
                cibilDtls.rejectionReason = cbResponseObj?.rejectionReason ?? "";
                cibilDtls.retryAttempts = cbResponseObj?.retryAttempts ?? "";
                cibilDtls.roi = cbResponseObj?.roi ?? '';
                if (responseObj.hasOwnProperty("base64")) {
                    if (!apz.isNull(responseObj.base64)) {
                        window.CBBASE64 = responseObj.base64;
                    }
                }
                window.IS_CB_CALLBACK = true;
                window.retry_Attempts = cbResponseObj?.retryAttempts;
                window.rejectRsn = cbResponseObj?.rejectionReason;
                if (gApzCOB.currentApplicant <= 1 || (isRPCLogin && custType === 'Applicant')) {
                    gApzCOB.userDetails.cbDtlsId = parseInt(responseObj.responseObj.cbDtlId);
                    window.APPLICANT_CIBIL_STATUS = cbResponseObj.finalDecision.toLowerCase().includes("approve") ? true : false;
                } else {
                    gApzCOB.userDetails.coApplicantCbDtlsId = parseInt(responseObj.responseObj.cbDtlId);
                    window.CO_APPLICANT_CIBIL_STATUS = cbResponseObj.finalDecision.toLowerCase().includes("approve") ? true : false;
                }
                if (!isRPCLogin) {
                    if (screenId === window.CBcheckScr) {
                        apz.app.CBcheck.handleCBCheckScreenUI(cbResponseObj, responseObj);
                    } else {
                        apz.app.LoanDetails.paintCibilDetails();
                        ["cibilCheckDetailsList", "sc_row_97_row", "sc_row_54"].show();
                        ["otpDiv", "uploadConsentDiv", "timerDiv", "sc_row_90", "sc_row_69_row", "check_ul", "sendOtpBtn_ul",].hide();
                        $("#" + screenId + "el_btn_2_0").attr("disabled", false);
                        apz.app.LoanDetails.continueBtn();
                    }
                } else {
                    let coAppIndex = inSessionStore.cibilDetailsWrapperList.findIndex(el => el.cibilDetails.custDtlId === ApzCOB.getCustDetailID(
                        'Co-App')) ?? -1;
                    if (coAppIndex >= 0) {
                        inSessionStore.cibilDetailsWrapperList[coAppIndex].cibilDetails.cbStatus = cbResponseObj.finalDecision?.toLowerCase()
                            ?.includes("approve") ? 'PASS' : 'FAIL';
                        inSessionStore.cibilDetailsWrapperList[coAppIndex].cibilDetails.payload = cbResponseObj;
                    }
                    ApzCOB.RpcBRECallBack();
                    if (RPC_CURRENT_STAGE === 'BusinessAddressProofRPC') {
                        if ($(`#${bussAddrPrfScrId}addressSameAsInput_option_Present`).is(":checked")) {
                            $('.rpcEditBtn').removeClass('sno');
                            $(`#${bussAddrPrfScrId}editIconLbl_li`).removeClass('sno');
                        }
                    }
                }
            } else {
                apz.stopLoader();
                if (!isRPCLogin) {
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_CB_CHECK_SERVICE_FAILED"), "E");
                } else {
                    let CB_ERR_MESSAGE = 'BRE Service failed.Please try Again.!';
                    ApzCOB.showRpcModals({
                        text: CB_ERR_MESSAGE,
                        Btn1: {
                            text: "OK",
                            onClick: "ApzCOB.BRECbService()"
                        }
                    }, "Error");
                }
            }
        } else {
            if (isRPCLogin && $(`#RPC__RpcStageScreen__conFormation_mdl`).is(':visible')) apz.app.RpcStageScreen.closeRPCConfirmarionMdl();
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(errMsg, "E");
        }
    },
    CBretriggermdl: function () {
        if (apz.isNull(retry_Attempts)) {
            retry_Attempts = 5; //hardcoded for now
        }
        let errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Remaining retry attempts: ${retry_Attempts}.<br/>Do you want to rehit BRE?`
        if (cibilDtls?.irisMessage?.includes('bureauError') && !cibilDtls?.irisMessage?.includes('roll')) {
            errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Do you want to rehit BRE?`
        }
        if (LoggedInUserDetails?.loginResponse?.addInfo1 === 'KM') {
            $(`#${screenId}retryBtnRetry`).attr('onclick', 'ApzCOB.cbRetryAttempts()');
            $(`#${screenId}retryBtnNo`).attr('onclick', 'ApzCOB.toggleModal(`${screenId}retryAttemptsModal`)');
            $(`#${screenId}retryAttemptsText`).html(errMsgBRE);
            ApzCOB.toggleModal(`${screenId}retryAttemptsModal`);
        } else {
            ApzCOB.toggleModal(`${BaseScrId}cbRetrymdl`);
            $("#APZCBO__BaseScreens__cbfailuremsg").html(errMsgBRE);
        }
    },
    cbRetryAttempts: function (val) {
        $('#APZCBO__BaseScreens__cbRetrymdl_close').click();
        $('#Loan__LoanDetails__retryAttemptsModal_close').click();
        $('#LoanRE__LoanDetails__retryAttemptsModal_close').click();
        ApzCOB.BRECbService();
    },
    downloadBRECbReport: function (lcustDtlId) {
        let custDetailID = '',
            customerId = '';
        if (!apz.isNull(lcustDtlId)) {
            custDetailID = lcustDtlId;
            customerId = inSessionStore.applicationMaster.memberId
        } else {
            custDetailID = gApzCOB.currentApplicant > 1 ? gApzCOB.userDetails.CoApplicantCustomerId : gApzCOB.userDetails.custDtlId;
            customerId = gApzCOB.userDetails.cgCustId
        }
        let currentIndex = inSessionStore.customerDetailsList.findIndex((custData) => custData.custDtlId === custDetailID);
        let custDetailsObj = currentIndex >= 0 ? inSessionStore.customerDetailsList[currentIndex] : "";
        let kycId = custDetailsObj.payload.primaryKycIdValStatus === "Verified" ? custDetailsObj.payload.primaryKycId : custDetailsObj.payload
            .alternateVoterIdValStatus === "Verified" ? custDetailsObj.payload.alternateVoterId : "";
        let req = {
            apiRequest: {
                interfaceName: "BRECBReport",
                appId: gAppId,
                loanId: CB_LOAN_ID,
                requestObj: {
                    customer_id: customerId,
                    user_id: kycId, //kyc docId
                }
            }
        };
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "BRECBReport", "N", "N", req, false, ApzCOB.downloadBRECbReportCB);
        }, 1000);
    },
    downloadBRECbReportCB: function (params) {
        if (apz.childScr === 'Saloandetails' || apz.childScr === 'SanctionSuc') {
            apz.app.DeviationSanctBase.sanctionReportDownloadCB(params);
        } else if (apz.currAppId === "DBkitG") {
            apz.app.DBbase.downloadFilesCB(params);
        } else if (apz.childScr === "PreviewApplicantDetails") {
            apz.app.commonPreview.downloadFilesCB(params);
        } else {
            let b64Data = "";
            let errMsg = "";
            if (apz.childScr === 'CaInPrincipleDecision' && !apz.isNull(params?.res?.APZCBO__GenerateAndDownloadReport_Res?.apiResponse)) {
                if (!apz.isNull(params.res.APZCBO__GenerateAndDownloadReport_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                    errMsg = params.res.APZCBO__GenerateAndDownloadReport_Res.apiResponse.ResponseHeader.ResponseMessage;
                }
            } else if (!apz.isNull(params.res.APZCBO__BRECBReport_Res.apiResponse)) {
                if (!apz.isNull(params.res.APZCBO__BRECBReport_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                    errMsg = params.res.APZCBO__BRECBReport_Res.apiResponse.ResponseHeader.ResponseMessage;
                }
            } else {
                errMsg = ApzCOB.getDescfromLitCode("LIT_FETCH_CB_REPORT_FAILED");
            }
            try {
                if (ApzCOB.handleServiceCallBacks(params)) {
                    apz.stopLoader();
                    let ifaceName = ApzCOB.GetInterfaceResMap(params);
                    let response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
                    if (response.hasOwnProperty("base64")) {
                        window.CBBASE64 = b64Data = response.base64;
                        ApzCOB.convertBase64ToPDF(b64Data, CB_LOAN_ID);
                    } else {
                        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_CB_REPORT_NOT_FOUND"), "E", "");
                    }
                } else {
                    apz.stopLoader();
                    ApzCOB.fnDisplayMsg(errMsg, "E", "");
                }
            } catch (e) {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(errMsg, "E", "");
            }
        }
    },
    CbHighmarkService: function () {
        let currentIndex = inSessionStore.customerDetailsList.findIndex((custData) => custData.custDtlId === (gApzCOB.currentApplicant > 1 ?
            gApzCOB.userDetails.CoApplicantCustomerId : gApzCOB.userDetails.custDtlId));
        let custDetailsObj = currentIndex >= 0 ? inSessionStore.customerDetailsList[currentIndex] : "";
        let loanAMount = "";
        loanAMount = $("#" + screenId + "loanAmount").val();
        let motherName = !apz.isNull(gApzCOB.selLeadDtls.motherName) ? gApzCOB.selLeadDtls.motherName : "";
        let applicantCbLoanId = "";
        let coApplicantCbLoanId = "";
        let kycId = custDetailsObj.payload.primaryKycIdValStatus === "Verified" ? custDetailsObj.payload.primaryKycId : custDetailsObj.payload
            .alternateVoterIdValStatus === "Verified" ? custDetailsObj.payload.alternateVoterId : "";
        if (gApzCOB.currentApplicant > 1) {
            let appCbData = inSessionStore.cibilDetailsWrapperList.filter((appCB) => parseInt(appCB.cibilDetails.custDtlId) === parseInt(
                gApzCOB.userDetails.custDtlId));
            if (appCbData.length > 0) {
                applicantCbLoanId = appCbData[0].cibilDetails.payload.cbLoanId.substr(3);
            }
            coApplicantCbLoanId = "C0" + CO_APP_ADDED_COUNT + applicantCbLoanId;
        }
        let req = {
            apiRequest: {
                appId: apz.appId,
                interfaceName: "HighmarkCheck",
                requestObj: {
                    applicationId: gApzCOB.userDetails.applicationId,
                    secondaryKycType: custDetailsObj.payload.secondaryKycType,
                    lastName: gApzCOB.selLeadDtls.lastName,
                    fathersName: custDetailsObj.payload.fathersName,
                    gender: custDetailsObj.payload.gender,
                    kendra: gApzCOB.selLeadDtls.kendraId,
                    addressDetails: ApzCOB.getCbAddressRequest(),
                    mobileNo: !apz.isNull(custDetailsObj.mobileNumber) ? custDetailsObj.mobileNumber : "",
                    branch: gApzCOB.selLeadDtls.branchName,
                    loanAmount: ApzCOB.fn_unFormatAmount(loanAMount),
                    primaryKycId: kycId,
                    firstName: custDetailsObj.customerName,
                    customerType: gApzCOB.currentApplicant <= 1 ? "Applicant" : "Co-Applicant",
                    dob: ApzCOB.dateformatter(custDetailsObj.payload.dob, "d/m/Y"),
                    mothersName: motherName,
                    branchState: "KA",
                    secondaryKycId: custDetailsObj.payload.secondaryKycId,
                    loanPurpose: $("#" + screenId + "purpOfLoan").val() === PleaseSelect ? "" : $("#" + screenId + "purpOfLoan").val(),
                    middleName: gApzCOB.selLeadDtls.middleName,
                    spouseName: custDetailsObj.payload.spouseName,
                    ifsc: gApzCOB.selLeadDtls.ifscCode,
                    age: custDetailsObj.payload.age,
                    maritalStatus: custDetailsObj.payload.maritalStatus,
                    customerId: gApzCOB.selLeadDtls.customerId,
                    cbLoanId: coApplicantCbLoanId,
                }
            }
        };
        if (gApzCOB.currentApplicant > 1) {
            req.apiRequest.lastName = "";
            req.apiRequest.middleName = "";
        }
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "HighMarkService", "N", "N", req, false, ApzCOB.CbHighmarkServiceCB);
        }, 1000);
    },
    CbHighmarkServiceCB: function (params) {
        let errMsg = "";
        if (!apz.isNull(params.resFull.appzillonBody.APZCBO__HighMarkService_Res.apiResponse)) {
            if (!apz.isNull(params.resFull.appzillonBody.APZCBO__HighMarkService_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = params.resFull.appzillonBody.APZCBO__HighMarkService_Res.apiResponse.ResponseHeader.ResponseMessage;
            }
        } else {
            errMsg = ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_CB_CHECK_SERVICE_FAILED");
        }
        if (ApzCOB.handleServiceCallBacks(params)) {
            let responseObj = JSON.parse(params.res.APZCBO__HighMarkService_Res.apiResponse.ResponseBody.responseObj);
            let cbResponseObj = JSON.parse(responseObj.responseObj);
            if (cbResponseObj["REQUEST-RESPONSE"].STATUS.toLocaleLowerCase() === "success") {
                window.CB_HIGHMARK_REPORT_LINK = cbResponseObj.reportUrl.replaceAll("&amp;", "&");
                let cbCallBackReq = {
                    apiRequest: {
                        interfaceName: "HighmarkCallback",
                        applicationId: gApzCOB.userDetails.applicationId,
                        memberId: gApzCOB.selLeadDtls.customerId,
                        appId: apz.appId,
                        requestObj: {
                            loanId: cbResponseObj.loanId,
                            statusCode: gApzCOB.currentApplicant <= 1 ? "0" : "1",
                            caglOs: gApzCOB.selLeadDtls.caglOs
                        }
                    }
                };
                window.CB_LOAN_ID = cbResponseObj.loanId;
                apz.startLoader();
                setTimeout(() => {
                    if (ApplicationType === "NEW") {
                        ApzCOB.cbHighmarkCallBAckService(cbCallBackReq, "HighMarkServiceCB");
                    } else {
                        cbCallBackReq.apiRequest.interfaceName = "HighmarkRenewalCallback";
                        ApzCOB.cbHighmarkCallBAckService(cbCallBackReq, "HighMarkRenewalServiceCB");
                    }
                }, cbTimeOutSec * 1000);
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(errMsg, "E");
            }
        } else {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(errMsg, "E");
        }
    },
    cbHighmarkCallBAckService: function (reqObj, intfName) {
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, intfName, "N", "N", reqObj, false, ApzCOB.cbHighmarkCallBAckServiceCB);
        }, 1000);
    },
    cbHighmarkCallBAckServiceCB: function (params) {
        let errMsg = "";
        if (!apz.isNull(params.apzIfaceName)) {
            if (!apz.isNull(params.resFull.appzillonBody[params.apzIfaceName + "_Res"].apiResponse)) {
                if (!apz.isNull(params.resFull.appzillonBody[params.apzIfaceName + "_Res"].apiResponse.ResponseHeader.ResponseMessage)) {
                    errMsg = params.resFull.appzillonBody[params.apzIfaceName + "_Res"].apiResponse.ResponseHeader.ResponseMessage;
                }
            } else {
                errMsg = ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_CB_CHECK_SERVICE_FAILED");
            }
            if (ApzCOB.handleServiceCallBacks(params)) {
                try {
                    apz.stopLoader();
                    let response = JSON.parse(JSON.parse(params.res[params.apzIfaceName + "_Res"].apiResponse.ResponseBody.responseObj)
                        .responseObj);
                    let responseObj = JSON.parse(response.payloadColumn);
                    if (!apz.isNull(responseObj.finalDecision)) {
                        let cbScore = 0;
                        if (!apz.isNull(responseObj.cbScore) && parseInt(responseObj.cbScore) != 0) {
                            if (responseObj.cbScore.split("|").length > 0) {
                                let cb = responseObj.cbScore.split("|")[0];
                                if (cb.split(":").length > 0) {
                                    cbScore = !apz.isNull(cb.split(":")[1]) ? parseInt(cb.split(":")[1]) : 0;
                                }
                            }
                        }
                        cibilDtls = {};
                        cibilDtls.overdueAmt = responseObj.overdueAmt;
                        cibilDtls.bureauName = responseObj.bureauName; //Previously "Highmark"
                        cibilDtls.hitNohit = responseObj.hitNohit;
                        cibilDtls.cbScore = cbScore;
                        cibilDtls.totIndebtness = responseObj.totIndebtness;
                        cibilDtls.NoParInLastMonths = responseObj.NoParInLastMonths;
                        cibilDtls.maxDpdInLastMonths = responseObj.maxDpdInLastMonths;
                        cibilDtls.writtenOff = responseObj.writeOffAmt;
                        cibilDtls.overlapWithMMFL = responseObj.overlapWithMmfl;
                        cibilDtls.finalDecision = responseObj.finalDecision;
                        cibilDtls.eligibleAmt = !apz.isNull(responseObj.eligibleAmt) ? ApzCOB.fn_FormatAmount(responseObj.eligibleAmt) : "0";
                        cibilDtls.foir = responseObj.foir;
                        cibilDtls.cgpDpd = responseObj.cgpDpd;
                        cibilDtls.cbReport = CB_HIGHMARK_REPORT_LINK;
                        cibilDtls.cbLoanId = CB_LOAN_ID;
                        window.IS_CB_CALLBACK = true;
                        apz.app.LoanDetails.paintCibilDetails();
                        if (gApzCOB.currentApplicant <= 1) {
                            gApzCOB.userDetails.cbDtlsId = parseInt(response.cbDtlId);
                            window.APPLICANT_CIBIL_STATUS = responseObj.finalDecision.toLocaleLowerCase() === "pass" ? true : false;
                        } else {
                            gApzCOB.userDetails.coApplicantCbDtlsId = parseInt(response.cbDtlId);
                            window.CO_APPLICANT_CIBIL_STATUS = responseObj.finalDecision.toLocaleLowerCase() === "pass" ? true : false;
                        }
                        ["cibilCheckDetailsList", "sc_row_97_row", "sc_row_54"].show();
                        ["otpDiv", "uploadConsentDiv", "timerDiv", "sc_row_90", "sc_row_69_row", "check_ul", "sendOtpBtn_ul",].hide();
                        $("#" + screenId + "el_btn_2_0").attr("disabled", false);
                        apz.app.LoanDetails.continueBtn();
                    } else {
                        apz.stopLoader();
                        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_CB_CHECK_SERVICE_FAILED"), "E");
                    }
                } catch (e) {
                    apz.stopLoader();
                    ApzCOB.fnDisplayMsg(errMsg, "E");
                }
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(errMsg, "E");
            }
        } else {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(errMsg, "E");
        }
    },
    validateApplicationDedupe: function () {
        let customerTypeVal = "";
        if (apz.isNull(gApzCOB.currentApplicant)) {
            customerTypeVal = 1;
        } else {
            customerTypeVal = gApzCOB.currentApplicant;
        }
        let req = {
            apiRequest: {
                appId: "APZCOB",
                interfaceName: "NewgenWipDedupe",
                requestObj: {
                    customerId: gApzCOB.selLeadDtls.customerId,
                    customerType: customerTypeVal,
                    primaryKycId: gApzCOB.selLeadDtls.primaryKyc,
                    pid: gApzCOB.selLeadDtls.pid
                }
            }
        };
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "ApplicationDedupe", "N", "N", req, false, ApzCOB.validateApplicationDedupeCB);
        }, 1000);
    },
    validateApplicationDedupeCB: function (params) {
        let responseObj = params.res.APZCBO__ApplicationDedupe_Res.apiResponse.ResponseHeader;
        if (ApzCOB.handleServiceCallBacks(params)) {
            try {
                if (responseObj.ResponseCode === "0") {
                    let JointSupported = "";
                    let AccountHolderForLoan = "";
                    for (let i = 0; i < gApzCOB.CommonCodes.length; i++) {
                        if (gApzCOB.CommonCodes[i].paramName === "LOANCASAJTACC") {
                            JointSupported = gApzCOB.CommonCodes[i].paramValue.split("~")[0];
                            AccountHolderForLoan = gApzCOB.CommonCodes[i].paramValue.split("~")[1];
                        }
                    }
                    if (JointSupported === "Y") {
                        gApzCOB.NoOfJointHolder = AccountHolderForLoan;
                        apz.app.BaseScreens.paintApplicatonTypes();
                        apz.app.BaseScreens.defaultApplicationType();
                        ApzCOB.toggleModal(BaseScrId + "applicationTypeModal");
                        $("#" + BaseScrId + "continueBtn").attr("onclick", "").unbind("click");
                        $("#" + BaseScrId + "continueBtn").attr("onclick", "apz.app.ApplicationList.onClickJointContinue()");
                        apz.stopLoader();
                        return;
                    } else {
                        gApzCOB.applicationType = JointAccount;
                        gApzCOB.currentApplicant = 1;
                        gApzCOB.noOfApplicants = 2;
                    }
                    let reqObj = {};
                    reqObj.memberId = gApzCOB.selLeadDtls.customerId;
                    ApzCOB.fetchExistingLoans(reqObj);
                }
            } catch (e) {
                ApzCOB.hideLoader();
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
            }
        } else {
            ApzCOB.hideLoader();
            ApzCOB.fnDisplayMsg(responseObj.ResponseMessage, "E");
        }
    },
    commonApplicationReject: function (pthis, gaction) {
        apz.startLoader();
        apz.app.BaseScreens.stageBasedOnAction(pthis, gaction);
        window.approveRejectAction = gaction;
        if (!apz.isNull(gApzCOB.requestNodes.customerDetailsList)) {
            if (gApzCOB.requestNodes.customerDetailsList.length > 0) {
                gApzCOB.requestNodes.customerDetailsList.map((cust) => {
                    if (cust.customerType === "Applicant") {
                        gApzCOB.userDetails.custDtlId = cust.custDtlId;
                    } else {
                        gApzCOB.userDetails.CoApplicantCustomerId = cust.custDtlId;
                    }
                });
            }
        }
        var req = {
            apiRequest: {
                interfaceName: "",
                appId: gAppId,
                requestObj: {
                    appId: gApzCOB.userDetails.appId,
                    status: approveRejectAction,
                    userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                    applicationId: gApzCOB.userDetails.applicationId,
                    versionNum: gApzCOB.userDetails.versionNum,
                    custDtlId: gApzCOB.userDetails.custDtlId,
                    remarks: RejectReason,
                    workflow: {
                        currentRole: gApzCOB.workflow.currentRole,
                        action: gApzCOB.workflow.action,
                        workflowId: gApzCOB.workflow.workflowId,
                        stage: gApzCOB.workflow.stage
                    }
                }
            }
        };
        ApzCOB.serverBuildParam("Dashbo", "ApproveRejectApplication", "N", "N", req, false, ApzCOB.commonApplicationRejectCB);
    },
    getProductData: function () {
        ProductData = apz.data.scrdata.Select__IpaintProductDetails_Res.data.filter(function (el) {
            return (el.productName.toUpperCase() == (ApplicationType === "RENEWAL" ? "GRAMEEN UNNATI RENEWAL LOAN" :
                "GRAMEEN UNNATI LOAN"));
        });
        let prodFeatures;
        if (ProductData[0].hasOwnProperty("productFeatures")) {
            prodFeatures = JSON.parse(ProductData[0].productFeatures);
        } else {
            prodFeatures = ProductData[0].feature;
        }
        minAnnualIncome = number(prodFeatures["Min Annual Income~Y"])[0];
        maxAnnualIncome = number(prodFeatures["Max Annual Income~Y"])[0];
        vintageYears = number(prodFeatures["Vintage Years~Y"])[0];
        minAge = number(prodFeatures["Min Age~Y"])[0];
        maxAge = number(prodFeatures["Max Age~Y"])[0];
        cbTimeOutSec = parseInt(prodFeatures["CB Timeout Sec~Y"]);
        maxDocUploadSize = JSON.parse(prodFeatures["Max Doc Upload Size"]);
        let obj = {};
        Object.entries(prodFeatures).forEach(function (p) {
            obj[p[0].split("~")[0]] = p[1];
        });
        let limitList = obj;
        ApzCOB.setLoanLimitList(limitList);
        upDocsData = ApzCOB.GetCommonCodes("UPLOADDOCS", "LOAN_ETB")["UPLOADDOCS"];
        upDocsData["TYPES"].forEach(function (el) {
            const [ext, flag] = el.split('~');
            if (flag === "Y") {
                window.gAllowedFileTypes[ext] = ext.toLowerCase();
            }
        });
        window.UdyamRegUrl = prodFeatures?.['UdyamRegUrl~Y'];
        window.eNachTimeoutInSec = parseInt(prodFeatures?.['eNachTimeoutInSec~Y'] ?? '1');
        eNachRetryAttempts = parseInt(prodFeatures["eNachRetryAttempts~Y"]);
        dbkitmaxDocUploadSize = JSON.parse(prodFeatures["DBKIT Max Doc Upload Size"]);
        window.isRenewalPopupEnabled = prodFeatures?.["isRenewalPopupEnabled"];
        window.isViewAccessEnabled = prodFeatures?.["isViewAccessEnabled"];
    },
    setLoanLimitList: function (limitList) {
        fdMonth = limitList["Max Value(Tenure In Months)"];
        fdMonthMin = limitList["Min Value(Tenure In Months)"];
        fdMonthMax = limitList["Max Value(Tenure In Months)"];
        fdYearMin = limitList["Min Value(Tenure In Years)"];
        fdYearMax = limitList["Max Value(Tenure In Years)"];
        fdDayMin = limitList["Min Value(Tenure In Days)"];
        fdDayMax = limitList["Max Value(Tenure In Days)"];
        fdInterestMin = "6.00";
        fdInterestMax = limitList["Interest Rate"];
        fdAmountMin = ApzCOB.fn_unFormatAmount(limitList["Min Loan Amount"]);
        fdAmountMax = ApzCOB.fn_unFormatAmount(limitList["Max Loan Amount"]);
        fdDefaultLoanAmount = ApzCOB.fn_unFormatAmount(limitList["Default Loan Amount"]);
        fdMonthman = limitList["Tenure In Months Mandatory"];
        fdYearMan = limitList["Tenure In Years Mandatory"];
    },
    copyToClipboard: function (copyText) {
        const el = document.createElement("textarea");
        el.value = copyText;
        document.body.appendChild(el);
        el.select();
        document.execCommand("copy");
        document.body.removeChild(el);
    },
    //Approve Reject Service Callback
    commonApplicationRejectCB: function (params) {
        let errMsg = "";
        if (!apz.isNull(params.res.Dashbo__ApproveRejectApplication_Res.apiResponse)) {
            if (!apz.isNull(params.res.Dashbo__ApproveRejectApplication_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = params.res.Dashbo__ApproveRejectApplication_Res.apiResponse.ResponseHeader.ResponseMessage;
            }
        } else {
            errMsg = ApzCOB.getDescfromLitCode("LIT_COMM_APPLICATION_REJECTION_FAILED");
        }
        let currentScreenID = CURRENT_STAGE_NAME === "CUSTOMERDETAILS" ? PerDetScrId : screenId;
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let ifaceName = ApzCOB.GetInterfaceResMap(params);
                let response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
                if (approveRejectAction === "REJECTED") {
                    //$('#' + BaseScrId + 'sucText').text(ApzCOB.getDescfromLitCode("LIT_APPLICATION_REJECTED"));
                    ApzCOB.toggleModal(currentScreenID + "rejectmodel");
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COB_APPLICATION_REJECTED"), "S", ApzCOB
                        .commonApplicationRejectLaunchDashboardCB);
                }
                // apz.app.BaseScreens.fetchRole();
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("errMsg"), "E", apz.app.LoanDetails.handleCbFailureCBReject);
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("errMsg"), "E", apz.app.LoanDetails.handleCbFailureCBReject);
        }
        apz.stopLoader();
    },
    commonApplicationRejectLaunchDashboardCB: function (params) {
        if (params.choice === true) {
            $("#" + BaseScrId + "footerbtnRow").addClass("sno");
            $("#" + BaseScrId + "BaseDIV").removeClass("sno");
            ApzCOB.launchMicroApp("Dashbo", "dashboard", "APZCBO__BaseScreens__BaseDIV", "");
        }
    },
    applicantKycFailedRejectService: function () {
        let req = {};
        req.apiRequest = {};
        req.apiRequest.requestObj = {};
        if (!apz.isNull(gApzCOB.requestNodes.applnWfDefinitionList) && gApzCOB.requestNodes.applnWfDefinitionList.length > 0) {
            gApzCOB.requestNodes.applnWfDefinitionList = [];
        }
        window.REJECT_REQUEST_CALL = true;
        req.apiRequest.requestObj = apz.app.PersonalDetails.createRequest();
        req.apiRequest.userId = gApzCOB.LoggedInUserDetails.loginResponse.userDet.id;
        req.apiRequest.appId = gAppId;
        req.apiRequest.interfaceName = "";
        req.apiRequest.requestObj.appId = gApzCOB.userDetails.appId;
        req.apiRequest.requestObj.applicationId = !apz.isNull(gApzCOB.relatedApplicationId) ? gApzCOB.relatedApplicationId : gApzCOB
            .userDetails.applicationId;
        req.apiRequest.requestObj.versionNum = gApzCOB.userDetails.versionNum;
        req.apiRequest.requestObj.isExistingCustomer = apz.isNull(gApzCOB.ExistingCustomer) ? "" : gApzCOB.ExistingCustomer ? "Y" : "N";
        let secondaryKycType = "",
            secondaryKycId = "",
            alternateVoterId = "";
        if (!apz.isNull(inSessionStore.customerDetailsList)) {
            let applicantCustomerData = inSessionStore.customerDetailsList.filter(
                (cust) => {
                    return cust.customerType === "Applicant";
                })[0];
            if (!apz.isNull(applicantCustomerData)) {
                secondaryKycType = applicantCustomerData.payload.secondaryKycType;
                secondaryKycId = applicantCustomerData.payload.secondaryKycId;
                alternateVoterId = applicantCustomerData.payload.alternateVoterId;
            }
        }
        req.apiRequest.requestObj.applicationMaster = {
            applicationType: "online",
            createdBy: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
            currentScreenId: gApzCOB.userDetails.currentScreen,
            currentStageNo: CURRENT_STAGE_NO,
            custDtlId: gApzCOB.userDetails.custDtlId,
            addressDtlsId: gApzCOB.userDetails.addressDtlsId,
            customerId: gApzCOB.userDetails.customerId,
            declarationFlag: gApzCOB.userDetails.declarationFlag,
            mobileNumber: !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails.mobileNum : null,
            productCode: apz.isNull(gApzCOB.productCode) ? '1009' : gApzCOB.productCode,
            productGroupCode: gApzCOB.product,
            searchCode1: gApzCOB.selLeadDtls.kendraId,
            searchCode2: gApzCOB.selLeadDtls.customerId,
            custDtlSlNum: gApzCOB.currentApplicant,
            applicantsCount: gApzCOB.noOfApplicants,
            mainProductGroupCode: gApzCOB.mainProductGroupCode,
            kendraId: gApzCOB.selLeadDtls.kendraId,
            kendraName: gApzCOB.selLeadDtls.kendraName,
            branchId: gApzCOB.selLeadDtls.glBranchId,
            branchName: gApzCOB.selLeadDtls.glBranchName,
            memberId: gApzCOB.selLeadDtls.customerId,
            primaryKycType: "Voter ID",
            primaryKycId: gApzCOB.selLeadDtls.primaryKyc,
            secondaryKycType: secondaryKycType,
            secondaryKycId: secondaryKycId,
            workitemNo: gApzCOB.selLeadDtls.pid,
            alternateVoterId: alternateVoterId,
            remarks: RejectReason,
        };
        req.apiRequest.requestObj.workflow = {
            currentRole: "",
        };
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "ApplyRejectApplication", "N", "N", req, false, ApzCOB.applicantKycFailedRejectServiceCB);
        }, 1000);
    },
    applicantKycFailedRejectServiceCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COB_APPLICATION_REJECTED"), "S", ApzCOB
                    .commonApplicationRejectLaunchDashboardCB);
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_REJECTION_FAILED_TRY_AGAIN"), "E", ApzCOB
                    .applicantKycFailedRejectService);
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_REJECTION_FAILED_TRY_AGAIN"), "E", Apz.applicantKycFailedRejectService);
        }
    },
    pushBackNavigationOnBack: function () {
        CURRENT_STAGE_NO = "";
        window.clickList = true;
        ApzCOB.FetchApplication(growNo);
    },
    getStageNoForEdit: function (stageName) {
        let stageData = STAGES.filter((sta) => sta.split("~")[0] === stageName);
        let currentStageNo = "";
        if (stageData.length > 0) {
            if (gApzCOB.currentApplicant <= 1) {
                currentStageNo = stageData[0].split("~")[1];
            } else {
                currentStageNo = stageData[1].split("~")[1];
            }
        }
        return currentStageNo;
    },
    checkCoAppAdditionalDetailsForHomeMaker: function () {
        let isValid = false;
        if (!apz.isNull(inSessionStore) && !apz.isNull(inSessionStore.customerDetailsList) && !apz.isNull(inSessionStore
            .insuranceDetailsWrapperList)) {
            let coAppCustData = inSessionStore.customerDetailsList.filter(
                (cust) => cust.customerType === "Co-App");
            if (coAppCustData.length > 0) {
                let coAppOccupation = coAppCustData[0].payload.occupation;
                if (coAppOccupation === "Homemaker") {
                    if (inSessionStore.insuranceDetailsWrapperList.length > 0) {
                        let AppInsuranceData = inSessionStore.insuranceDetailsWrapperList.filter(
                            (custIns) => custIns.insuranceDetails.payload.insuredName === "Applicant");
                        if (AppInsuranceData.length > 0) {
                            let coAppInsReq = AppInsuranceData[0].insuranceDetails.payload.coApplicantInsurance;
                            if (coAppInsReq === "No") {
                                isValid = true;
                                gApzCOB.currentApplicant = 1;
                                if (!backNav) {
                                    window.CURRENT_STAGE_NO = STAGE_NO;
                                    window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                                    window.STAGE_NO = STAGE_NO + 1;
                                    window.baseRow = STAGE_NO;
                                    window.currRow = baseRow - 1;
                                    window.prevRow = currRow - 1 === -1 ? 0 : currRow - 1;
                                    window.CURRENT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split("~")[0];
                                    if (!apz.isNull(STAGES[CURRENT_STAGE_NO])) {
                                        window.NEXT_STAGE_NAME = STAGES[CURRENT_STAGE_NO].split("~")[0];
                                    } else {
                                        window.NEXT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split("~")[0];
                                    }
                                    if (!completeArray.includes(CURRENT_STAGE_NO)) {
                                        completeArray.push(CURRENT_STAGE_NO);
                                    }
                                    ApzCOB.LaunchConfiguredScreens();
                                } else {
                                    window.CURRENT_STAGE_NO = CURRENT_STAGE_NO - 1;
                                    window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
                                    window.STAGE_NO = CURRENT_STAGE_NO + 1;
                                    window.baseRow = STAGE_NO;
                                    window.currRow = baseRow;
                                    window.prevRow = currRow - 2 === -1 ? 0 : currRow - 2;
                                    window.CURRENT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split("~")[0];
                                    if (!apz.isNull(STAGES[CURRENT_STAGE_NO])) {
                                        window.NEXT_STAGE_NAME = STAGES[CURRENT_STAGE_NO].split("~")[0];
                                    } else {
                                        window.NEXT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split("~")[0];
                                    }
                                    if (!completeArray.includes(CURRENT_STAGE_NO)) {
                                        completeArray.push(CURRENT_STAGE_NO);
                                    }
                                    ApzCOB.backNavigationCallBack();
                                }
                            } else {
                                isValid = true;
                                if (!backNav) {
                                    ApzCOB.LaunchConfiguredScreens();
                                } else {
                                    ApzCOB.backNavigationCallBack();
                                }
                            }
                        }
                    }
                } else {
                    isValid = true;
                    if (!backNav) {
                        ApzCOB.LaunchConfiguredScreens();
                    } else {
                        ApzCOB.backNavigationCallBack();
                    }
                }
            }
        }
        if (!isValid) {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_SOMETHING_WENT_WRONG"), "E");
        }
    },
    checkMobileNumberExist: function (pthis, mobType) {
        window.currMobField = pthis.id;
        let mobileNumber = $(pthis).val().trim();
        let validate = false;
        let customerType = '';
        if (!isRPCLogin) {
            validate = ApzCOB.chexkExistInCurrentScreen(mobileNumber, mobType);
            customerType = gApzCOB.currentApplicant <= 1 ? "Applicant" : 'Co-App';
        } else {
            validate = true;
            customerType = custType;
        }
        if (isRPCLogin && !moblengthErr) {
            ApzCOB.showInputErrMsg(pthis);
            return;
        }
        if (!apz.isNull(mobileNumber)) {
            if (validate) {
                let mobileDedupe = true;
                let mobDedupeErrMsg = "";
                /*Swaroop Raj R_(Co-Applicant Dedup check 27/10/2025)*/
                /* if (!apz.isNull(inSessionStore.customerDetailsList)) {
                    if (customerType === 'Applicant') {
                        let checkCoAppExist = inSessionStore.customerDetailsList.filter((custData) => custData.customerType !== "Applicant");
                        if (checkCoAppExist.length > 0) {
                            if (mobileNumber === checkCoAppExist[0].mobileNumber || mobileNumber === checkCoAppExist[0].payload.secMobileNo) {
                                mobDedupeErrMsg = "Entered number already exist in Co-Applicant Details";
                                mobileDedupe = false;
                            }
                        }
                    } else {
                        let applicantData = inSessionStore.customerDetailsList.filter((custData) => custData.customerType === "Applicant");
                        if (applicantData.length > 0) {
                            if (mobileNumber === applicantData[0].mobileNumber || mobileNumber === applicantData[0].payload.secMobileNo) {
                                mobDedupeErrMsg = "Entered number already exist in Applicant Details";
                                mobileDedupe = false;
                            }
                        }
                    }
                } */
                // declaring the flag first - used to track if Co-Applicant has same mobile number as Applicant
                let isSameAsApplicant = false;
                // New logic - Allow same mobile number but detect if Co-Applicant uses the same as Applicant
                if (!apz.isNull(inSessionStore.customerDetailsList)) {
                    if (customerType !== 'Applicant') {
                        let applicantData = inSessionStore.customerDetailsList.filter((custData) => custData.customerType === "Applicant");
                        if (applicantData.length > 0) {
                            let applicantMobile = applicantData[0].mobileNumber;
                            let applicantSecMobile = applicantData[0].payload.secMobileNo;
                            if (mobileNumber === applicantMobile || mobileNumber === applicantSecMobile) {
                                isSameAsApplicant = true; // same number found
                            }
                        }
                    }
                }
                //------------------------------------------------------------------------------------------------------------------------------------------------               
                if (!mobileDedupe) {
                    if (isRPCLogin) {
                        ApzCOB.showRpcModals({
                            text: mobDedupeErrMsg,
                            Btn1: {
                                text: "OK",
                                onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
                            }
                        }, "Error");
                    } else {
                        ApzCOB.fnDisplayMsg(mobDedupeErrMsg, "E");
                    }
                    $(pthis).val("");
                } else {
                    if (IS_MOBILE_DEDUPE_REQ && !isSameAsApplicant) { //here modified if condition 
                        ApzCOB.MobileNoDedupeCheck(mobileNumber);
                    }
                }
            } else {
                $(pthis).val("");
            }
        }
    },
    chexkExistInCurrentScreen: function (mobileNo, type) {
        let isValid = true;
        let errMsg = "";
        if (type === "primary") {
            let secondaryMobile = $("#" + PerDetScrId + "sec_mobile").val().trim();
            if (!apz.isNull(mobileNo)) {
                if (mobileNo === secondaryMobile) {
                    isValid = false;
                    errMsg = "Entered number already exist in Secondary Mobile No";
                } else {
                    isValid = true;
                    errMsg = "";
                }
            }
        } else {
            let primaryMobile;
            if (typeof CBcheckScr !== 'undefined' && PerDetScrId === CBcheckScr) {
                primaryMobile = $("#" + CBcheckScr + "primaryMobile").val().trim();
            } else {
                primaryMobile = $("#" + paintKYCId + "mobNum").val().trim();
            }

            if (!apz.isNull(mobileNo)) {
                if (mobileNo === primaryMobile) {
                    isValid = false;
                    errMsg = "Entered number already exist in Primary Mobile No";
                } else {
                    isValid = true;
                    errMsg = "";
                }
            }
        }
        if (!isValid) {
            ApzCOB.fnDisplayMsg(errMsg, "E");
        }
        return isValid;
    },
    checkVoterExist: function (pthis, kycType) {
        let customerType = '';
        if (isRPCLogin) {
            customerType = custType;
        } else {
            customerType = gApzCOB.currentApplicant <= 1 ? 'Applicant' : 'Co-App';
        }
        let voterID = $(pthis).val().trim();
        let validate = ApzCOB.checkVoterIdExistInCurrentScreen(voterID, kycType);
        if (apz.isNull(gApzCOB.currentApplicant)) {
            gApzCOB.currentApplicant = coustmerTypValue;
        }
        if (!apz.isNull(voterID)) {
            if (validate) {
                let kycDedupe = true;
                let votDedupeErrMsg = "";
                if (!apz.isNull(inSessionStore.customerDetailsList)) {
                    if (customerType === 'Applicant') {
                        let checkCoAppExist = inSessionStore.customerDetailsList.filter(
                            (custData) => custData.customerType !== "Applicant");
                        if (checkCoAppExist.length > 0) {
                            if (typeof (checkCoAppExist[0].payload) === 'string') {
                                checkCoAppExist[0].payload = JSON.parse(checkCoAppExist[0]?.payload)
                            }
                            if (voterID.toUpperCase() === checkCoAppExist[0].payload.primaryKycId.toUpperCase() || voterID.toUpperCase() ===
                                checkCoAppExist[0].payload.alternateVoterId.toUpperCase()) {
                                votDedupeErrMsg = "Entered Voter Id already exist in Co-Applicant Details";
                                kycDedupe = false;
                            }
                        }
                    } else {
                        let applicantData = inSessionStore.customerDetailsList.filter(
                            (custData) => custData.customerType === "Applicant");
                        if (applicantData.length > 0) {
                            if (typeof (applicantData[0].payload) === 'string') {
                                applicantData[0].payload = JSON.parse(applicantData[0]?.payload)
                            }
                            if (voterID.toUpperCase() === applicantData[0].payload.primaryKycId.toUpperCase() || voterID.toUpperCase() ===
                                applicantData[0].payload.alternateVoterId.toUpperCase()) {
                                votDedupeErrMsg = "Entered Voter Id already exist in Applicant Details";
                                kycDedupe = false;
                            }
                        }
                    }
                }
                if (!kycDedupe) {
                    if (isRPCLogin) {
                        const popUpObj = {
                            text: votDedupeErrMsg,
                            Btn1: {
                                text: "OK",
                                onClick: 'apz.app.RpcStageScreen.closeRPCErrMdl()'
                            }
                        };
                        ApzCOB.showRpcModals(popUpObj, "Error");
                    } else {
                        ApzCOB.fnDisplayMsg(votDedupeErrMsg, "E");
                    }
                    $(pthis).val("");
                    $('#' + primaryKycScrId + 'verifyAlternateVoter').addClass('sno');
                }
            } else {
                $(pthis).val("");
                $('#' + primaryKycScrId + 'verifyAlternateVoter').addClass('sno');
            }
        }
    },
    checkVoterIdExistInCurrentScreen: function (kycId, type) {
        let isValid = true;
        let errMsg = "";
        if (RPC_CURRENT_STAGE === 'PrimaryKycRPC') {
            if (type === "primary") {
                let primarykyc = $(`#RPC__${RPC_CURRENT_STAGE}__alternateVoterIdInput`).val().trim();
                if (!apz.isNull(kycId)) {
                    if (kycId.toUpperCase() === primarykyc.toUpperCase()) {
                        isValid = false;
                        errMsg = "Entered Primary KYC Number already exist in Alternate Voter Id";
                    } else {
                        isValid = true;
                        errMsg = "";
                    }
                }
            } else {
                let altKyc = $(`#RPC__${RPC_CURRENT_STAGE}__primaryKycIdInput`).val().trim();
                if (!apz.isNull(kycId)) {
                    if (kycId.toUpperCase() === altKyc.toUpperCase()) {
                        isValid = false;
                        errMsg = "Entered Alternate Voter Id already exist in Primary KYC Number";
                    } else {
                        isValid = true;
                        errMsg = "";
                    }
                }
            }
        } else {
            if (type === "primary") {
                let altKyc = $("#" + PerDetScrId + "altVoterId").val().trim();
                if (!apz.isNull(kycId)) {
                    if (kycId.toUpperCase() === altKyc.toUpperCase()) {
                        isValid = false;
                        errMsg = "Entered Primary KYC Number already exist in Alternate Voter Id";
                    } else {
                        isValid = true;
                        errMsg = "";
                    }
                }
            } else {
                let primarykyc = $("#" + PerDetScrId + "voterId").val().trim();
                if (!apz.isNull(kycId)) {
                    if (kycId.toUpperCase() === primarykyc.toUpperCase()) {
                        isValid = false;
                        errMsg = "Entered Alternate Voter Id already exist in Primary KYC Number";
                    } else {
                        isValid = true;
                        errMsg = "";
                    }
                }
            }
        }
        if (!isValid) {
            if (isRPCLogin) {
                const popUpObj = {
                    text: errMsg,
                    Btn1: {
                        text: "OK",
                        onClick: 'apz.app.RpcStageScreen.closeRPCErrMdl()'
                    }
                };
                ApzCOB.showRpcModals(popUpObj, "Error");
            } else {
                ApzCOB.fnDisplayMsg(errMsg, "E");
            }
        }
        return isValid;
    },
    downloadDocFileFromserver: function (fileName) {
        var json = {};
        json.destinationPath = "docs";
        json.sessionReq = "N";
        json.fileName = fileName;
        json.base64 = "Y";
        json.filePath = gApzCOB.requestNodes.appId.concat("/").concat(gApzCOB.product).concat("/").concat(gApzCOB.userDetails.applicationId);
        json.id = "";
        json.callBack = ApzCOB.downloadDocFileFromserverCB;
        apz.startLoader();
        apz.ns.downloadFile(json);
    },
    downloadDocFileFromserverCB: function (param) {
        apz.stopLoader();
        if (apz.childScr === "EmploymentDetails") {
            localFileObj.imgSrc = param.base64;
            apz.app.EmploymentDetails.displayFileName();
        }
    },
    docOldNewMapping: function (oldDocPayload) {
        let docTypeSelected = "";
        let newDocType = "";
        let docTypes = [];
        docMaxAndMand.forEach((docs) => docTypes.push(docs.key));
        switch (oldDocPayload.documentType) {
            case "IdentityProof":
                docTypeSelected = "PRIMARY_KYC";
                break;
            case "bankAccProof":
                docTypeSelected = "BANK_ACCOUNT_PROOF";
                break;
            case "OtherDocs":
                if (oldDocPayload.docCategory === "AddrProof" || oldDocPayload.docCategory === "Address Proof") {
                    docTypeSelected = "ADDRESS_PROOF";
                } else if (oldDocPayload.docCategory === "bussAddrProof" || oldDocPayload.docCategory === "Business Address Proof") {
                    docTypeSelected = "BUSINESS_ADDRESS_PROOF";
                } else if (oldDocPayload.docCategory === "Business Photographs") {
                    if (oldDocPayload.documentName === "Business Premise Photo") {
                        docTypeSelected = "BUSINESS_PREMISE_PHOTO";
                    } else if (oldDocPayload.documentName === "Residence Premise Photo") {
                        docTypeSelected = "RESIDENCE_PREMISE_PHOTO";
                    } else if (oldDocPayload.documentName === "Customer Photograph") {
                        docTypeSelected = "CUSTOMER_PHOTOGRAPH";
                    }
                } else if (oldDocPayload.docCategory === "photoProof") {
                    if (oldDocPayload.documentName === "Business Premise Photo") {
                        docTypeSelected = "BUSINESS_PREMISE_PHOTO";
                    } else if (oldDocPayload.documentName === "Residence Premise Photo") {
                        docTypeSelected = "RESIDENCE_PREMISE_PHOTO";
                    } else if (oldDocPayload.documentName === "Customer Photograph") {
                        docTypeSelected = "CUSTOMER_PHOTOGRAPH";
                    }
                } else if (oldDocPayload.docCategory === "relationshipProof") {
                    docTypeSelected = "RELATIONSHIP_PROOF";
                } else if (oldDocPayload.docCategory === "empProof" || oldDocPayload.docCategory === "Employment Proof") {
                    docTypeSelected = "EMPLOYMENT_PROOF";
                } else if (oldDocPayload.docCategory === "SecKycProof") {
                    docTypeSelected = "SECONDARY_KYC";
                } else if (oldDocPayload.docCategory === "Bank Account Proof") {
                    docTypeSelected = "BANK_ACCOUNT_PROOF";
                } else {
                    docTypeSelected = oldDocPayload.documentName;
                }
                break;
            default:
                docTypeSelected = oldDocPayload.documentType;
                break;
        }
        if (docTypes.includes(docTypeSelected)) {
            newDocType = docTypeSelected;
        } else if (docTypes.includes(docTypeSelected.toLocaleUpperCase().replaceAll(" ", "_"))) {
            newDocType = docTypeSelected.toLocaleUpperCase().replaceAll(" ", "_");
        } else if (docTypes.includes(oldDocPayload?.docCategory?.toLocaleUpperCase()?.replaceAll(" ", "_"))) {
            newDocType = oldDocPayload?.docCategory?.toLocaleUpperCase()?.replaceAll(" ", "_");
        } else {
            newDocType = "";
        }
        return newDocType;
    },
    getOccupation: function (Income, applicant) {
        if (apz.isNull(gApzCOB.currentApplicant)) {
            gApzCOB.currentApplicant = custType === 'Applicant' ? 1 : 2;
        }
        let custId = gApzCOB.currentApplicant <= 1 ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId;
        if (!apz.isNull(applicant)) {
            custId = gApzCOB.userDetails.custDtlId;
        }
        let occupation = "",
            income = "";
        if (!apz.isNull(inSessionStore)) {
            let custData = inSessionStore.customerDetailsList.filter((cust) => parseInt(cust.custDtlId) === parseInt(custId));
            if (custData.length > 0) {
                if (!apz.isNull(Income)) {
                    let custPayload = {};
                    if (typeof (custData?.[0]?.payload) === 'object') {
                        custPayload = custData?.[0]?.payload;
                    } else {
                        custPayload = JSON.parse(custData?.[0]?.payload);
                    }
                    income = !apz.isNull(custPayload?.annualIncome) ? custPayload?.annualIncome : "";
                    if (apz.isNull(income)) {
                        if (!apz.isNull(inSessionStore.occupationDetailsWrapperList) && inSessionStore.occupationDetailsWrapperList.length >
                            0) {
                            const occData = inSessionStore.occupationDetailsWrapperList.filter((el) => el.occupationDetails.custDtlId === custId);
                            if (!apz.isNull(occData) && occData.length > 0) {
                                income = !apz.isNull(occData[0].occupationDetails.payload.annualIncome) ? occData[0].occupationDetails.payload
                                    .annualIncome : "";
                            }
                        }
                    }
                } else {
                    occupation = custData[0].payload.occupation;
                }
            }
        }
        return Income ? income : occupation;
    },
    commonRegex: function (ValPattern, inputVal) {
        let inputIdval = inputVal;
        let result = false;
        let pattern = ValPattern;
        let amtRegex = new RegExp(pattern);
        result = amtRegex.test(inputIdval);
        return result;
    },
    MobileNoDedupeCheck: function (mobNo) {
        let isApplicant = '';
        if (typeof custType !== 'undefined') isApplicant = custType === "Applicant";
        let mobObj = {
            kycType: "mobileNo",
            kycId: mobNo,
            customerType: isRPCLogin ? (isApplicant ? 1 : 2) : gApzCOB.currentApplicant,
            customerId: isRPCLogin ? (isApplicant ? parseInt(gApzCOB.requestNodes?.applicationMaster?.memberId, 10) || "" : "") : (gApzCOB
                .currentApplicant <= 1 ? parseInt(gApzCOB.selLeadDtls?.customerId, 10) || "" : ""),
            applicationId: gApzCOB.requestNodes?.applicationId ?? ""
        };
        let req = {
            apiRequest: {
                interfaceName: "DedupeVoterID",
                requestObj: mobObj
            }
        };
        ApzCOB.showLoader();
        ApzCOB.serverBuildParam(gAppId, "DedupeVoterID", "N", "N", req, false, ApzCOB.MobileNoDedupeCheckCB);
    },
    MobileNoDedupeCheckCB: function (params) {
        let responseObj = {};
        if (!apz.isNull(params.res.APZCBO__DedupeVoterID_Res.apiResponse)) {
            responseObj = params.res.APZCBO__DedupeVoterID_Res.apiResponse.ResponseHeader;
        }
        let responseMessage = responseObj.ResponseMessage || "An error occurred.";
        ApzCOB.hideLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                return;
            }
        } catch (e) {
            // "Error in MobileNoDedupeCheckCB:"
        }
        if (isRPCLogin) {
            let confrmTxt = `${responseMessage}. <br/> Would you like to reject the application?`;
            let popUpObj = {};
            popUpObj.text = confrmTxt;
            popUpObj.Btn1 = {
                "text": "Yes",
                "onClick": "apz.app.RPCFooter.approveReject(this,'REJECTED')"
            }
            popUpObj.Btn2 = {
                "text": "No",
                "onClick": "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()"
            }
            ApzCOB.showRpcModals(popUpObj, "confirmation");
        } else {
            ApzCOB.fnDisplayMsg(responseMessage, "E");
        }
        $(`#${currMobField}`).val("");
    },
    ValidatePan: function (pthis) {
        const panRegex = /^[A-Z]{5}[0-9]{4}[A-Z]$/;
        let panNumber = $(pthis).val().toUpperCase();
        if (!apz.isNull(panNumber)) {
            if (panRegex.test(panNumber)) {
                $(pthis).parents(".error-block").find(".err-msg .errText span").text(ApzCOB.getDescfromLitCode("LIT_SEC_VOTER_ERR"));
                $(pthis).parents(".error-block").find(".err-msg").addClass("sno");
            } else {
                $(pthis).val("");
                $(pthis).parents(".error-block").find(".err-msg .errText  span").text(ApzCOB.getDescfromLitCode("LIT_PAN_ERROR_MESSAGE"));
                $(pthis).parents(".error-block").find(".err-msg").removeClass("sno");
            }
        }
    },
    ReInitiateFromCustData: function () {
        window.revAndConf = false;
        window.dashRevConf = false;
        window.IS_CB_RETRIGGER = false;
        window.STAGE_NO = 3;
        window.CURRENT_STAGE_NO = STAGE_NO - 1;
        window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
        window.baseRow = 3;
        window.currRow = baseRow - 1;
        window.prevRow = currRow - 1 === -1 ? 0 : currRow - 1;
        gApzCOB.currentApplicant = 1;
        ApzCOB.LaunchConfiguredScreens();
        $("#" + BaseScrId + "menulist").removeClass("sno");
        $("#" + BaseScrId + "dashBoardList").addClass("sno");
        $(`#${BaseScrId}RefNumDiv`).removeClass("sno");
        $(`#${BaseScrId}RefNum`).text(ApzCOB.getDescfromLitCode("LIT_COMM_TXT_REF_NUM") + gApzCOB.userDetails.applicationId);
        $("#APZCBO__BaseScreens__sidebarController").addClass("sno");
        $(BaseScroll).addClass(SecondaryProduct);
        $("#" + BaseScrId + "homeicon").removeClass("sno");
    },
    checkIsRejectApplication: function () {
        window.IS_REJECTED_APPLICATION = false;
        if (!apz.isNull(gApzCOB.requestNodes) && !apz.isNull(gApzCOB.requestNodes.applicationTimelineDtl)) {
            if (gApzCOB.requestNodes.applicationTimelineDtl.length > 0) {
                gApzCOB.requestNodes.applicationTimelineDtl.map((appTimeLine) => {
                    if (appTimeLine.actionTaken === "Rejected By") {
                        window.IS_REJECTED_APPLICATION = true;
                    }
                });
            }
        }
    },
    fetchAppVersion: function () {
        let request = {};
        let params = {};
        request.appID = gAppId;
        request.os = apz.deviceType;
        params.callBackObj = this;
        params.buildReq = "N";
        params.paintResp = "N";
        params.req = request;
        params.appId = gAppId;
        params.ifaceName = "AppVersion";
        params.async = true;
        params.callBack = ApzCOB.fetchAppVersionCB;
        apz.startLoader();
        apz.server.callServer(params);
    },
    fetchAppVersionCB: function (params) {
        apz.stopLoader();
        if (!apz.isNull(params.res.APZCBO__AppVersion_Res) && params.res.APZCBO__AppVersion_Res.length > 0) {
            let versionDetails = params.res.APZCBO__AppVersion_Res[0];
            let lcurrentVersion = versionDetails.app_version.replace("V", "").replace("v", "");
            let lappVersion = APP_VERSION.replace("V", "").replace("v", "");
            let lcArr = lcurrentVersion.split(".");
            let laArr = lappVersion.split(".");
            let lcurValid = true;
            if (lcArr.length === laArr.length) {
                for (let i = 0; i < laArr.length; i++) {
                    if (Number(laArr[i]) !== Number(lcArr[i])) {
                        lcurValid = false;
                        break;
                    }
                }
            } else {
                lcurValid = false;
            }
            if (lcurValid) {
                let customerID = $("#" + LoginScrId + "userName").val().toLocaleUpperCase();
                let password = $("#" + LoginScrId + "password").val();
                let loginform = $("#" + LoginScrId + "webloginform").find("input"),
                    loginform_validator_check = {
                        Login__Login__userName: {
                            verify: nullcheck,
                            message: "LIT_USERNAME_ERR",
                        },
                        Login__Login__password: {
                            verify: nullcheck,
                            message: "LIT_USERPASS_ERR",
                        },
                    };
                if (ApzCOB.validateInputFields(loginform, loginform_validator_check)) {
                    ApzCOB.login(customerID, password);
                }
            } else {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APP_VERSION_ERROR"), "E");
            }
        } else {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APP_VERSION_FETCH_FAILED"), "E");
        }
    },
    setselLeadDtls: function () {
        gApzCOB.selLeadDtls = {};
        let applicantData = [];
        if (!apz.isNull(gApzCOB.requestNodes)) {
            if (!apz.isNull(gApzCOB.requestNodes.customerDetailsList)) {
                if (gApzCOB.requestNodes.customerDetailsList.length > 0) {
                    applicantData = gApzCOB.requestNodes.customerDetailsList.filter(
                        (app) => app.customerType === "Applicant");
                }
            }
        }
        if (applicantData.length > 0) {
            let masterData = gApzCOB.requestNodes.applicationMaster;
            gApzCOB.selLeadDtls.customerId = masterData.searchCode2;
            gApzCOB.selLeadDtls.fullName = applicantData[0].customerName;
            gApzCOB.selLeadDtls.pid = masterData.workitemNo;
            gApzCOB.selLeadDtls.kendraId = masterData.kendraId;
            gApzCOB.selLeadDtls.kendraName = masterData.kendraName;
            gApzCOB.selLeadDtls.glBranchId = masterData.branchId;
            gApzCOB.selLeadDtls.glBranchName = masterData.branchName;
            gApzCOB.selLeadDtls.primaryKyc = masterData.primaryKycId;
            gApzCOB.selLeadDtls.occupation = JSON.parse(applicantData[0].payload).occupation ?? "";
            gApzCOB.selLeadDtls.lastName = JSON.parse(applicantData[0].payload).lastName ?? "";
            gApzCOB.selLeadDtls.middleName = JSON.parse(applicantData[0].payload).middleName ?? "";
            gApzCOB.selLeadDtls.motherName = "";
            gApzCOB.selLeadDtls.ifscCode = "";
            gApzCOB.selLeadDtls.caglOs = "";
            gApzCOB.selLeadDtls.glBranchState = "";
        }
    },
    getApplicantCustData: function () {
        let custData = [];
        if (!apz.isNull(inSessionStore)) {
            if (!apz.isNull(inSessionStore.customerDetailsList)) {
                if (inSessionStore.customerDetailsList.length > 0 && !apz.isNull(gApzCOB.userDetails.custDtlId)) {
                    custData = inSessionStore.customerDetailsList.filter((cust) => {
                        return (parseInt(cust.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));
                    });
                }
            }
        }
        return custData;
    },
    filterRelns: function (relArr) {
        let newRelations = relArr;
        if (gApzCOB.currentApplicant > 1 || apz.currAppId === "EmpDet") {
            let applicantData = ApzCOB.getApplicantCustData();
            if (applicantData.length > 0) {
                if (applicantData[0].payload.maritalStatus.toLocaleLowerCase() !== "married") {
                    newRelations = relArr.filter(
                        (rel) => rel.toLocaleLowerCase() !== "spouse");
                }
            }
        }
        return newRelations;
    },
    discardCoApplicant: function (obj) {
        let req = {
            apiRequest: {
                interfaceName: "DiscardCoApplicant",
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                appId: gAppId,
                requestObj: {
                    appId: gAppId,
                    applicationId: gApzCOB.userDetails.applicationId,
                    versionNum: gApzCOB.userDetails.versionNum,
                    custDtlId: gApzCOB.userDetails.CoApplicantCustomerId,
                    reason: obj.reason,
                    remarks: obj.remarks,
                },
            },
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "DiscardCoApplicant", "N", "N", req, false, ApzCOB.discardCoApplicantCB);
    },
    discardCoApplicantCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                response = params.res.APZCBO__DiscardCoApplicant_Res.apiResponse.ResponseBody.responseObj;
                if (response === "Success") {
                    //Deleting Co-App Data from inSessionStore
                    if (!apz.isNull(inSessionStore.customerDetailsList)) {
                        if (inSessionStore.customerDetailsList.length > 0) {
                            let custIndex = inSessionStore.customerDetailsList.findIndex(
                                (cust) => cust.custDtlId === gApzCOB.userDetails.CoApplicantCustomerId);
                            if (!apz.isNull(custIndex) && custIndex >= 0) {
                                inSessionStore.customerDetailsList.splice(custIndex, 1);
                            }
                        }
                        //Address Details
                        if (inSessionStore.addressDetailsWrapperList.length > 0) {
                            if (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.length > 0) {
                                inSessionStore.addressDetailsWrapperList[0].addressDetailsList.map(
                                    () => {
                                        let addressIndexCode = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(
                                            (item) => item.custDtlId === gApzCOB.userDetails.CoApplicantCustomerId && item
                                                .addressType === "Personal");
                                        if (!apz.isNull(addressIndexCode) && addressIndexCode >= 0) {
                                            inSessionStore.addressDetailsWrapperList[0].addressDetailsList.splice(addressIndexCode, 1);
                                            gApzCOB.userDetails.CoApplicantAddressDtlsId = "";
                                        }
                                        let occaddrIndexCode = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(
                                            (item) => item.custDtlId === gApzCOB.userDetails.CoApplicantCustomerId && item
                                                .addressType === "Occupation");
                                        if (!apz.isNull(occaddrIndexCode) && occaddrIndexCode >= 0) {
                                            inSessionStore.addressDetailsWrapperList[0].addressDetailsList.splice(occaddrIndexCode, 1);
                                            gApzCOB.userDetails.CoApOccAddressDtlsId = "";
                                        }
                                    });
                            }
                        }
                        //Cibil Details
                        if (!apz.isNull(inSessionStore.cibilDetailsWrapperList) && inSessionStore.cibilDetailsWrapperList.length > 0) {
                            let cbIndex = inSessionStore.cibilDetailsWrapperList.findIndex(
                                (item) => item.cibilDetails.custDtlId === gApzCOB.userDetails.CoApplicantCustomerId);
                            if (!apz.isNull(cbIndex) && cbIndex >= 0) {
                                inSessionStore.cibilDetailsWrapperList.splice(cbIndex, 1);
                                gApzCOB.userDetails.coApplicantCbDtlsId = "";
                            }
                        }
                        //Insurance Details
                        if (!apz.isNull(inSessionStore.insuranceDetailsWrapperList) && inSessionStore.insuranceDetailsWrapperList.length >
                            0) {
                            let insIndex = inSessionStore.insuranceDetailsWrapperList.findIndex(
                                (item) => item.insuranceDetails.custDtlId === gApzCOB.userDetails.CoApplicantCustomerId);
                            if (!apz.isNull(insIndex) && insIndex >= 0) {
                                inSessionStore.insuranceDetailsWrapperList.splice(insIndex, 1);
                                gApzCOB.userDetails.coAppInsuranceDtlsId = "";
                            }
                        }
                        //Occupation Details
                        if (!apz.isNull(inSessionStore.occupationDetailsWrapperList) && inSessionStore.occupationDetailsWrapperList.length >
                            0) {
                            let occIndex = inSessionStore.occupationDetailsWrapperList.findIndex(
                                (item) => item.occupationDetails.custDtlId === gApzCOB.userDetails.CoApplicantCustomerId);
                            if (!apz.isNull(occIndex) && occIndex >= 0) {
                                inSessionStore.occupationDetailsWrapperList.splice(occIndex, 1);
                                gApzCOB.userDetails.coAppOccptDtlId = "";
                            }
                        }
                        //Documents
                        if (!apz.isNull(inSessionStore.applicationDocumentsWrapperList) && inSessionStore.applicationDocumentsWrapperList
                            .length > 0) {
                            let docList = inSessionStore.applicationDocumentsWrapperList;
                            if (!apz.isNull(docList[0].applicationDocumentsList) && docList[0].applicationDocumentsList.length > 0) {
                                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = docList[0]
                                    .applicationDocumentsList.filter(
                                        (el) => el.custDtlId !== gApzCOB.userDetails.CoApplicantCustomerId);
                            }
                        }
                        gApzCOB.userDetails.CoApplicantCustomerId = "";
                    }
                    IS_CO_APPLICANT_PRIMARY_DEDUPE = null;
                    IS_CO_APPLICANT_SECONDARY_DEDUPE = null;
                    IS_CO_APPLICANT_ALTERNATE_DEDUPE = null;
                    CO_APPLICANT_PRIMARY_DEDUPE_STATUS = null;
                    CO_APPLICANT_SECONDARY_DEDUPE_STATUS = null;
                    CO_APPLICANT_ALTERNATE_DEDUPE_STATUS = null;
                    CO_APPLICANT_PRIMARY_KYC_VERIFICATION = null;
                    CO_APPLICANT_SECONDARY_KYC_VERIFICATION = null;
                    CO_APPLICANT_ALTERNATE_KYC_VERIFICATION = null;
                    window.IS_COAPP_PRIMARY_CHECK_FAILED = null;
                    window.IS_COAPP_ALTERNATE_CHECK_FAILED = null;
                    window.CO_APPLICANT_CIBIL_STATUS = "";
                    window.CO_APP_ADDED_COUNT++;
                    //customerIndex updation in applicant details.
                    let custIndex = inSessionStore.customerDetailsList.findIndex(
                        (el) => el.custDtlId === gApzCOB.userDetails.custDtlId);
                    if (!apz.isNull(custIndex) && custIndex >= 0) {
                        inSessionStore.customerDetailsList[custIndex].payload.customerIndex = CO_APP_ADDED_COUNT;
                    }
                    if (apz.currAppId === "PerDRE" || apz.currAppId === "PerDet") {
                        apz.app.PersonalDetails.clearCoAppFields();
                        if ($(`#${PerDetScrId}dedupeRejectOrAddmodel`).hasClass("in")) {
                            ApzCOB.toggleModal(PerDetScrId + "dedupeRejectOrAddmodel");
                        } else if ($(`#${PerDetScrId}CoAppReasonModal`).hasClass("in")) {
                            ApzCOB.toggleModal(PerDetScrId + "CoAppReasonModal");
                        } else if ($(`#${PerDetScrId}coAppAgeErrorModal`).hasClass("in")) {
                            ApzCOB.toggleModal(PerDetScrId + "coAppAgeErrorModal");
                        }
                    } else if (apz.currAppId === "LoanRE" || apz.currAppId === "Loan") {
                        //CB Fail Add Co-App Flow Changes
                        ApzCOB.backNavigation();
                        $("body").removeClass("modal-open");
                    }
                } else {
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_CO_ADD_FAILURE"), "E");
                }
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_CO_ADD_FAILURE"), "E");
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_CO_ADD_FAILURE"), "E");
        }
    },
    isObjEmpty: function (obj) {
        return Object.keys(obj).length === 0;
    },
    cloneDashboardDivs: function (selectElement, parentDiv, index) {
        const originalDiv = document.querySelector("#" + selectElement);
        if (selectElement.includes(' #')) {
            selectElement = selectElement.split(' #')[1];
        }
        let newId = "";
        if (originalDiv) {
            const clonedDiv = originalDiv.cloneNode(true);
            let selectElemtId = selectElement.split("_0")[0];
            newId = selectElemtId + "_" + index;
            clonedDiv.id = newId;
            parentDiv.append(clonedDiv);
        }
        return newId;
    },
