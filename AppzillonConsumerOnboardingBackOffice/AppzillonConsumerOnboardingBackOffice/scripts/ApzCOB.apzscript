    externalServiceErrorHandling: function (params, resnode) {
        if (params.status) {
            let objData = params.res[resnode];
            if (
                (apz.isNull(objData.ResponseHeader.CBSCode) || objData.ResponseHeader.CBSCode === "0") && !apz.isNull(objData.ResponseHeader
                    .ErrorCode)) {
                ApzCOB.launchMicroApp("Succes", "Transaction_Failed", gPostLoginBaseDiv, objData.ResponseHeader);
            }
        } else {
            ApzCOB.ServiceFailureMsg(params);
        }
    },
    interServiceErrorHandling: function (params, resnode) {
        if (params.status) {
            let objData = params.res[resnode];
            if (apz.isNull(objData.ResponseHeader.CBSCode) && !apz.isNull(objData.ResponseHeader.ErrorCode)) {
                ApzCOB.fnDisplayMsg(objData.ResponseHeader.ErrorMessage, "E", "");
            }
        } else {
            ApzCOB.ServiceFailureMsg(params);
        }
    },
    //new external service handling function
    handleServiceCallBacks: function (params) {
        try {
            if (!(params.status && apz.isNull(params.errors))) return false;
            const objData = params.res[Object.keys(params.res)[0]];
            const header = objData.apiResponse.ResponseHeader;
            const body = objData.apiResponse.ResponseBody;
            const responseObjStr = body?.responseObj;
            if (!header?.hasOwnProperty("ResponseCode")) return false;
            const code = header.ResponseCode;
            if (code === "0") {
                try {
                    if (responseObjStr) {
                        const responseObj = JSON.parse(responseObjStr);
                        if (responseObj.serviceStatusCode && responseObj.serviceStatusCode !== "0") {
                            return false;
                        }
                    }
                    return true;
                } catch (e) {
                    return true; // JSON parse failed, treat as success
                }
            }
            if (code === "1") return false;
            if (code === "IV112") {
                ApzCOB.DispMsgWithCustomButtons(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_OOPSSOMETHINGWENTWRONG"), "E", ApzCOB.ReloadApp,
                    ApzCOB.getDescfromLitCode("LIT_COMM_BTN_TXT_OK"));
                return;
            }
            // Fallback for other cases
            const responseObj = objData.apiResponse.responseObj;
            if (responseObj?.ResponseCode?.serviceStatusCode === "0") {
                return true;
            }
            if (!code || code !== "0") {
                return false;
            }
            return apz.isNull(code);
        } catch (e) {
            apz.stopLoader();
            return false;
        }
    },
    checkAuthenticationServiceErrorCallback: function (pdata) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
