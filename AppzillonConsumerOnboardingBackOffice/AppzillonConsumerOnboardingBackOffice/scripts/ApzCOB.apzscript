    // Login Common functionality
    login: function (customerId, password) {
        let params = {
            userId: customerId,
            pwd: password,
            callBack: ApzCOB.loginCallBack,
            scrsAccessType: "A",
            ifacesAccessType: "A",
            controlsAccessType: "A",
        };
        apz.startLoader();
        apz.server.login(params);
    },
    // Login Call back functionality
    loginCallBack: function (params) {
        try {
            if (!apz.isNull(params.res?.loginResponse)) {
                window.loginResponse = params.res.loginResponse;
                if (loginResponse.status) {
                    window.LoggedInUserDetails = params.res;
                    const userDet = loginResponse.userDet;
                    userDet.name = userDet?.name?.trim() || "";
                    loginResponse.addInfo1 = loginResponse?.addInfo1?.trim() || "";
                    userDet.id = userDet?.id?.trim() || "";
                    userDet.lastLogin = userDet?.lastLogin?.trim() || "";
                    userDet.privs.roles[0] = userDet?.privs?.roles[0]?.trim() || "";
                    LoggedInUserDetails.loginResponse.addInfo2 = LoggedInUserDetails.loginResponse.addInfo2?.replace(/ /g, '');
                    gApzCOB.LoggedInUserDetails = LoggedInUserDetails;
                    if (loginResponse?.addInfo1 === 'KM') {
                        if (!window.RT_REQ) {
                            if (apz.deviceType === "WEB") {
                                ApzCOB.fnDisplayMsg('Please use the TAB for this user.!', "E", '');
                                apz.stopLoader();
                                return;
                            }
                        }
                    } else if (['RPC', 'ACM', 'AM', 'RM', 'DM'].includes(loginResponse?.addInfo1) && apz.deviceType !== 'WEB') {
                        //removed BCM for ReAssessment
                        ApzCOB.fnDisplayMsg('Please use the WEB for this user.!', "E", '');
                        apz.stopLoader();
                        return;
                    }
                    ApzCOB.customlogincallback();
                } else {
                    apz.stopLoader();
                    $("#Login__Login__userName, #Login__Login__password").val("");
                    const attemptsLeft = loginResponse?.attemptsLeft ?? -1;
                    let errorMsg = "";
                    if (attemptsLeft > 0) {
                        errorMsg = `Please enter correct password. ${attemptsLeft + 1} attempts left`;
                    } else if (attemptsLeft === 0) {
                        errorMsg = "Your account gets locked out if you make one more wrong attempt";
                    } else {
                        errorMsg = "User is either Locked or Inactive. Please use forgot password option to unlock or contact Administrator.";
                    }
                    ApzCOB.fnDisplayMsg(errorMsg, "E", apz.app.Login.CancelCaptchalogin);
                }
            } else if (!apz.isNull(params.errors)) {
                apz.stopLoader();
                $("#Login__Login__userName, #Login__Login__password, #Login__Login__LoginCaptchaInput").val("");
                const errorCode = params.resFull?.appzillonErrors?.[0]?.errorCode;
                const errorMessage = params.errors?.[0]?.errorMessage;
                const errorMap = {
                    "APZ-SMS-EX-016": () => {
                        apz.app.Login.CancelCaptchalogin();
                        return errorMessage.split("-")[0];
                    },
                    "APZ-DM-040": "Please enter a valid registered User Name",
                    "APZ-DM-031": "Password has expired. Kindly reset the password.",
                    "APZ-DM-013": "User is either Locked or Inactive. Please use forgot password option to unlock or contact Administrator.",
                    "APZ-SMS-EX-005": "User is either Locked or Inactive. Please use forgot password option to unlock or contact Administrator."
                };
                const finalMessage = errorMap[errorCode] || errorMessage || ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL");
                ApzCOB.fnDisplayMsg(finalMessage, "E", apz.app.Login.RefreshImageCaptcha);
            }
        } catch (e) {
            apz.stopLoader();
            let errorMessage = params.errors?.[0]?.errorMessage || params.resFull?.appzillonErrors?.[0]?.errorMessage;
            if (!errorMessage) {
                errorMessage = ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL");
            }
            if (!["APZ-CNT-231", "APZ-CNT-232"].includes(params.resFull?.appzillonErrors?.[0]?.errorCode)) {
                ApzCOB.fnDisplayMsg(errorMessage, "E");
            }
        }
    },
    customlogincallback: function (params) {
        try {
            window.iscustomLoginCB = true;
            ApzCOB.FetchLov();
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    LaunchRoleDashboard: function (roleresp) {
        window.WidgetInProgress = [];
        window.WidgetSubmitted = [];
        window.WidgetApproved = [];
        window.WidgetPending = [];
        window.WidgetRejected = [];
        window.WidgetDeleted = [];
        window.WidgetPushBack = [];
        window.WidgetPendingCreditAssesment = [];
        gApzCOB.WidgetInProgress = [];
        gApzCOB.WidgetApproved = [];
        gApzCOB.WidgetPending = [];
        gApzCOB.WidgetRejected = [];
        gApzCOB.WidgetDeleted = [];
        gApzCOB.WidgetPushBack = [];
        gApzCOB.WidgetPendingCreditAssesment = [];
        try {
            roleresp.map?.["inprogress"]?.["myArrayList"]?.filter(function (el) {
                window.WidgetInProgress.push(el.map);
                gApzCOB.WidgetInProgress = window.WidgetInProgress;
            });
            roleresp.map?.["completed"]?.["myArrayList"]?.filter(function (el) {
                window.WidgetApproved.push(el.map);
                gApzCOB.WidgetApproved = window.WidgetApproved;
            });
            roleresp.map?.["pending"]?.["myArrayList"]?.filter(function (el) {
                window.WidgetPending.push(el.map);
                gApzCOB.WidgetPending = window.WidgetPending;
            });
            roleresp.map?.["rejected"]?.["myArrayList"]?.filter(function (el) {
                window.WidgetRejected.push(el.map);
                gApzCOB.WidgetRejected = window.WidgetRejected;
            });
            roleresp.map?.["deleted"]?.["myArrayList"]?.filter(function (el) {
                window.WidgetDeleted.push(el.map);
                gApzCOB.WidgetDeleted = window.WidgetDeleted;
            });
            roleresp.map?.["pushback"]?.["myArrayList"]?.filter(function (el) {
                window.WidgetPushBack.push(el.map);
                gApzCOB.WidgetPushBack = window.WidgetPushBack;
            });
            roleresp.map?.["pendingBCMPI"]?.["myArrayList"]?.filter(function (el) {
                window.WidgetPendingCreditAssesment.push(el.map);
                gApzCOB.WidgetPendingCreditAssesment = window.WidgetPendingCreditAssesment;
            });
            if (gApzCOB.FetchRole.accessPermission === "B") {
                //Showing maker checker only for Both role
                apz.stopLoader();
                $("#" + LoginScrId + "MakerCheckDIV").removeClass("sno");
                $("#" + LoginScrId + "LoginBody").addClass("sno");
            } else {
                //Hiding maker checker div for other roles
                if (apz.currAppId === "Login") {
                    apz.app.Login.OnClickMakerChecker();
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    GetCommonCodes: function (paramname, codetype) {
        //paramname - CM_CODE
        //codetype - CODE_TYPE
        //KrishnaChanges
        if (apz.isNull(codetype)) {
            codetype = "COMM";
        }
        let GetCommonCodes = "";
        for (const code of gApzCOB.CommonCodes) {
            if (paramname === code.paramName && code.codeType === codetype) {
                try {
                    GetCommonCodes = JSON.parse(code.paramValue);
                } catch (e) {
                    GetCommonCodes = code.paramValue;
                }
            }
        }
        return GetCommonCodes;
    },
