    getSourcingPushBackQuery: function () {
        let applicationStatus = inSessionStore?.applicationMaster?.applicationStatus || "";
        window.workflowQueries = [];
        window.sourcingQueryStageName = '';
        if (!apz.isNull(applicationStatus) && ['IPUSHBACK', 'CAPUSHBACK', 'REJECTED'].includes(applicationStatus)) {
            if (inSessionStore.applicationTimelineDtl.length > 0) {
                let lastWrkflwData = inSessionStore.applicationTimelineDtl[inSessionStore.applicationTimelineDtl.length - 1];
                if (lastWrkflwData.actionTaken.includes('Sent Back')) {
                    if ((lastWrkflwData.stage === "RPC Maker" || lastWrkflwData.stage === "RPC Checker") && gApzCOB.userDetails.applicationStatus === 'IPUSHBACK') {
                        if (lastWrkflwData.rpcStatRemaks.length > 0) {
                            workflowQueries = structuredClone(lastWrkflwData.rpcStatRemaks);
                        }
                        sourcingQueryStageName = 'RPC_PUSHBACK';
                        ApzCOB.fetchStageWiseQueries('RPC');
                    } else if (lastWrkflwData.stage === "Credit Assessment") {
                        if (!apz.isNull(lastWrkflwData.remarks)) {
                            let workflowQueriesPre = lastWrkflwData.remarks.split('|');
                            workflowQueries = workflowQueriesPre.map(item => {
                                const [stageID, query] = item.split('_');
                                return { stageID, query };
                            });
                        } else if (!apz.isNull(lastWrkflwData.rpcStatRemaks)) {
                            if (lastWrkflwData.rpcStatRemaks.length > 0) {
                                workflowQueries = structuredClone(lastWrkflwData.rpcStatRemaks);
                            }
                        }
                        sourcingQueryStageName = 'CA_PUSHBACK';
                        ApzCOB.fetchCAMaster();
                    }
                } else if (applicationStatus === 'REJECTED' || lastWrkflwData.actionTaken.includes('Rejected')) {
                    if (['Credit Assessment', 'Disbursement Kit', 'Sanction', 'Resanction'].includes(lastWrkflwData.stage)) {
                        ApzCOB.fetchQueryResponseFromAllStage(lastWrkflwData);
                    } else if (["RPC Maker"].includes(lastWrkflwData.stage)) {
                        let remarks = `${lastWrkflwData.stage} Reject. ${lastWrkflwData.remarks}`;
                        ApzCOB.paintRejectRemarks(remarks);
                    } else {
                        if (!apz.isNull(lastWrkflwData.remarks)) {
                            ApzCOB.paintRejectRemarks(lastWrkflwData.remarks);
                        }
                    }
                    $("#" + rvwScrId + "rejectedBy").text(`${lastWrkflwData.userId} / ${lastWrkflwData.timeStamp}`);
                }
            }
        }
    },
    fetchQueryResponseFromAllStage: function (stageData) {
        IS_VIEWLOG_FETCH = true;
        let actionType = stageData.actionTaken;
        let allQueries = [];
        switch (stageData.stage) {
            case "Disbursement Kit":
                if (DBKIT_MASTERDATA.length === 0) {
                    ApzCOB.FetchDBKITMasterData("ALL");
                };
                setTimeout(() => {
                    let action = actionType.includes('Rejected') ? 'rejectReasons' : 'queries';
                    if (!apz.isNull(stageData.remarks) && !stageData.remarks.includes('OTH')) {
                        let queriesRaised = stageData.remarks;
                        if (queriesRaised.includes('OTH') && queriesRaised.includes('?')) {
                            let remarkArray = queriesRaised.split('?');
                            if (remarkArray.length > 0) {
                                allQueries = remarkArray[1];
                            }
                        } else {
                            allQueries = queriesRaised;
                        }
                    } else if (!apz.isNull(stageData.rpcStatRemaks)) {
                        stageData.rpcStatRemaks.forEach(({ custType, query, stageID }) => {
                            const currentStage = DBKIT_MASTERDATA.find(dbData => dbData.id === stageID);
                            let currentQueries = [];
                            if (action === 'rejectReasons') {
                                currentQueries = JSON.parse(currentStage?.rejectReasons || '{}').rejectReason || [];
                            } else {
                                currentQueries = JSON.parse(currentStage?.queries || '{}').sendbackReason || [];
                            }
                            // stageData = structuredClone(currentQueries);
                            currentQueries.forEach(stageQuery => {
                                if (query.includes(stageQuery.id)) {
                                    allQueries.push(stageQuery.value);
                                }
                            });
                        });
                    } else if (stageData.remarks.includes('OTH')) {
                        queryArr = stageData.remarks.includes('OTH') ? stageData.remarks.split(',') : stageData.remarks;
                        allQueries = queryArr.map(code => {
                            const [qId, qType, qVal] = code.split("_");
                            stageReasons = DBKIT_MASTERDATA.find(f => f.id === parseInt(qId));
                            if (stageReasons?.rejectReasons) {
                                const rejectReasons = JSON.parse(stageReasons.rejectReasons)?.rejectReason || [];
                                const match = rejectReasons.find(r => r.id === qVal);
                                return match ? match.value : qVal.includes('OTH') ? qVal.split('OTH?')[1] : '';
                            }
                            return "";
                        });
                    }
                    if (actionType.includes('Rejected')) {
                        ApzCOB.paintRejectRemarks(allQueries);
                    }
                }, 4000);
                break;
            case "Resanction":
            case "Sanction":
                if (SANCTION_QUERIES.length === 0) {
                    ApzCOB.fetchSanctionQuery(['Sanction', 'Deviation', 'ReAssessment']);
                }
                setTimeout(() => {
                    apz.stopLoader();
                    if (!apz.isNull(stageData.remarks)) {
                        let queriesRaised = stageData.remarks;
                        let remarkArray = queriesRaised?.split('|');
                        if (stageData.remarks?.includes('CB FAILED')) {
                            allQueries = stageData.remarks;
                        } else if (remarkArray?.length > 0 && !stageData.remarks?.includes('CB FAILED')) {
                            sanctionStage = stageData.stage === "Pre Sanction" ? "ReAssessment" : stageData.stage === "Resanction" ? "Sanction" : stageData.stage;
                            sanctionEntry = SANCTION_QUERIES.find(sa => sa.stage_name.toLowerCase() === sanctionStage.toLowerCase());
                            stageQueries = [];
                            if (apz.isNull(sanctionEntry)) {
                                return;
                            }
                            stageQueries = JSON.parse(sanctionEntry.queries)?.REJECT?.queries || [];
                            remarkArray.forEach(query => {
                                const [queryCat, queryVal] = query.split('?');
                                if (queryCat !== 'OTH') {
                                    const currentCatData = stageQueries.find(q => Number(q.catID) === Number(queryCat));
                                    currentCatData?.queries?.forEach(q => {
                                        if (q.id === queryVal) {
                                            allQueries.push(q.value);
                                        }
                                        return "";
                                    });
                                } else {
                                    allQueries.push(queryVal || "");
                                }
                            });
                        }
                    }
                    if (actionType.includes('Rejected')) {
                        ApzCOB.paintRejectRemarks(allQueries);
                    }
                }, 4000);
                break;
            case 'Credit Assessment':
                if (CA_ALL_STAGE_FIELDS.length === 0) {
                    ApzCOB.fetchCAMaster();
                };
                setTimeout(() => {
                    let action = actionType.includes('Rejected') ? 'rejectReasons' : 'queries';
                    if (!apz.isNull(stageData.remarks)) {
                        let queriesRaised = stageData.remarks;
                        let remarkArray = queriesRaised?.split('|');
                        if (remarkArray?.length > 0 && !stageData.remarks?.includes('CB FAILED')) {
                            allQueries = remarkArray.map(code => {
                                const [stageIdStr, reasonId] = code.split("_");
                                const stageId = parseInt(stageIdStr, 10);
                                const stage = CA_ALL_STAGE_FIELDS.find(f => f.id === stageId);
                                if (stage?.rejectReasons) {
                                    const rejectReasons = JSON.parse(stage.rejectReasons)?.rejectReason || [];
                                    const match = rejectReasons.find(r => r.id === reasonId);
                                    return match ? match.value : reasonId.includes('oth') ? reasonId.split('oth?')[1] : '';
                                }
                                return "";
                            });
                        }
                        if (stageData.remarks?.includes('CB FAILED')) {
                            allQueries = stageData.remarks;
                        }
                    }
                    if (actionType.includes('Rejected')) {
                        ApzCOB.paintRejectRemarks(allQueries);
                    }
                }, 4000);
            default:
                break;
        }
    },
    paintRejectRemarks: function (allQueries) {
        const rejectRemark = $(`#${rvwScrId}rejectedRemarks_txtcnt`);
        if (Array.isArray(allQueries)) {
            if (allQueries.length > 0) {
                rejectRemark.html(allQueries.filter(msg => msg).map(msg => `• ${msg}`).join("<br>"));
                rejectRemark.parent().removeClass('sno');
            }
        } else if (typeof (allQueries) === 'string') {
            rejectRemark.html(allQueries);
            rejectRemark.parent().removeClass('sno');
        }
    },
    fetchCAMaster: function () {
        var req = {
            "stageId": "ALL"
        }
        ApzCOB.serverBuildParam(gAppId, "FetchBCMPIMasterData", "N", "N", req, false, ApzCOB.fetchCAMasterCB);
    },
    fetchCAMasterCB: function (params) {
        if (!IS_VIEWLOG_FETCH) {
            apz.stopLoader();
        }
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                var response = JSON.parse(params.res.APZCBO__FetchBCMPIMasterData_Res.apiResponse.ResponseBody.responseObj);
                CA_ALL_STAGE_FIELDS = response;
                if (!IS_VIEWLOG_FETCH) {
                    ApzCOB.prepareStageWiseQueryData();
                }
            } else { }
        } catch (e) {
            apz.stopLoader();
        }
    },
    fetchStageWiseQueries: function (stage) {
        var request = {};
        var params = {};
        var callbackFunc = ApzCOB.fetchStageWiseQueriesCB;
        if (stage === 'RPC') {
            RPC_ALLSTAGES = Object.values(RPC_STAGES).map(stage => stage.screenName);
            request.stage_name = RPC_ALLSTAGES;
        }
        params.callBackObj = this;
        params.buildReq = "N";
        params.paintResp = "N";
        params.req = request;
        params.appId = gAppId;
        params.ifaceName = "RPCStageFields";
        params.async = true;
        params.callBack = callbackFunc;
        apz.startLoader();
        apz.server.callServer(params);
    },
    fetchStageWiseQueriesCB: function (params) {
        if (!IS_VIEWLOG_FETCH) {
            apz.stopLoader();
        }
        try {
            if (!apz.isNull(params.res.APZCBO__RPCStageFields_Res) && params.res.APZCBO__RPCStageFields_Res.length > 0) {
                RPC_ALL_STAGE_FIELDS = params.res.APZCBO__RPCStageFields_Res.filter(stage => stage.stage_name !== "ReviewConfirm");
                RPC_ALL_STAGE_QUERIES = RPC_ALL_STAGE_FIELDS.flatMap(input => {
                    const parsedQueries = JSON.parse(input.queries);
                    return Object.entries(parsedQueries).map(([key, value]) => ({
                        stageID: input.id,
                        custType: key === "Applicant" ? "A" : key === "Co-App" ? "C" : key,
                        query: value
                    }));
                });
                if (!IS_VIEWLOG_FETCH) {
                    ApzCOB.prepareStageWiseQueryData();
                }
            }
        } catch (e) {
            ApzCOB.showCommonErrRPCModal();
        }
    },
    prepareStageWiseQueryData: function () {
        ApzCOB.initSourcingQuery();
        SOURCING_STAGES.forEach(stage => {
            const stageMappingObj = SOURCING_PUSHBACK_STAGE_MAPPING.find(mapping => mapping[stage]);
            const curStages = stageMappingObj?.[stage]?.[0]?.[sourcingQueryStageName] || [];
            if (sourcingQueryStageName === 'RPC_PUSHBACK') {
                curStages.forEach(rpcStage => {
                    const rpcRaisedQueries = workflowQueries.filter(query => query.stageID === rpcStage);
                    rpcRaisedQueries.forEach(rpcQuery => {
                        const queryDescription = RPC_ALL_STAGE_QUERIES.find(q => q.custType === rpcQuery.custType && q.stageID === rpcQuery.stageID);
                        if (!apz.isObjectEmpty(queryDescription)) {
                            const queryInfo = queryDescription.query || [];
                            const customerType = rpcQuery.custType === "A" ? "Applicant" : "Co-APP";
                            rpcQuery.query.forEach(indQuery => {
                                if (indQuery.includes('oth') && indQuery.includes('?')) {
                                    let queryVal = indQuery.split('?')[1] || '';
                                    SOURCING_SENDBACK_QUERIES?.[stage]?.[customerType]?.query.push(queryVal);
                                } else {
                                    const queryDesc = queryInfo.find(q => q.id === indQuery);
                                    if (queryDesc?.value) {
                                        SOURCING_SENDBACK_QUERIES?.[stage]?.[customerType]?.query.push(
                                            queryDesc.value);
                                    }
                                }
                            });
                        }
                    });
                });
            } else if (sourcingQueryStageName === 'CA_PUSHBACK') {
                // const customerType = rpcQuery.custType === "A" ? "Applicant" : "Co-APP";
                let customerType = "Applicant";
                curStages.forEach(cStage => {
                    const caRaisedQueries = workflowQueries.filter(query => Number(query.stageID) === Number(cStage));
                    caRaisedQueries.forEach(queries => {
                        let queryDescVal = '';
                        if (!Array.isArray(queries.query)) {
                            queryDescVal = queries.query.split('?')[1] || '';
                        }
                        if (apz.isNull(queryDescVal)) {
                            const queryDescription = CA_ALL_STAGE_FIELDS.find(q => Number(q.id) === Number(queries.stageID));
                            if (!apz.isObjectEmpty(queryDescription)) {
                                const queryInfo = queryDescription.queries || {};
                                const queryInfoParsed = JSON.parse(queryInfo).sendbackReason || [];
                                let queryDesc = {}
                                if (queries.stageID === 2 && queries.query.length > 0) {
                                    queries.query.forEach(qd => {
                                        const queryID = `${queries.custType}_${qd}`;
                                        if (queryID.includes('oth') && queryID.includes('?')) {
                                            queryDescVal = queryID.split('?')[1];
                                        } else {
                                            const queryDesc = queryInfoParsed.find(q => q.id === queryID);
                                            if (queryDesc?.value) {
                                                queryDescVal = queryDesc.value;
                                            }
                                        }
                                        if (!apz.isNull(queryDescVal)) {
                                            const customerType = (queries.custType === "C" || queries.custType === "R") ? "Co-APP" : "Applicant";
                                            SOURCING_SENDBACK_QUERIES?.[stage]?.[customerType]?.query.push(queryDescVal);
                                        }
                                    });
                                } else {
                                    queryDesc = queryInfoParsed.find(q => q.id === queries.query);
                                    if (queryDesc?.value) {
                                        queryDescVal = queryDesc?.value;
                                    }
                                    SOURCING_SENDBACK_QUERIES?.[stage]?.[customerType]?.query.push(queryDescVal);
                                }
                            }
                        }
                    });
                })
            }
        });
        if (!apz.isNull(inSessionStore?.sourcingQueryResponse)) {
            ApzCOB.prepareSourcingQueryRes();
        }
        apz.app.ReviewConfirm.handleSendbackInSourcing();
    },
    paintingSourcingQuery: function () {
        if (!apz.isNull(inSessionStore?.sourcingQueryResponse)) {
            ApzCOB.prepareSourcingQueryRes();
        }
        if (apz.childScr !== 'ReviewConfirm') {
            const custType = gApzCOB.currentApplicant === 1 ? 'Applicant' : 'Co-APP';
            let currentStage = screenMap[apz.childScr];
            let currentScreenData = SOURCING_SENDBACK_QUERIES[currentStage][custType];
            CURRENT_SCREEN_QUERIES = currentScreenData.query;
            if (CURRENT_SCREEN_QUERIES.length > 0) {
                const $container = $(`#${BaseScrId}sanctionQueriesCol`);
                if (!$container.length || !Array.isArray(CURRENT_SCREEN_QUERIES)) return;
                $container.empty();
                const $list = $('<ol></ol>');
                CURRENT_SCREEN_QUERIES.forEach(item => {
                    $('<li></li>').text(item).appendTo($list);
                });
                $container.append($list);
                $(`#${BaseScrId}sourcingRemarks`).val(currentScreenData.response);
                const lastWorkFlw = inSessionStore.applicationTimelineDtl?.at(-1);
                $('.queryHeader h4').text(
                    `Queries (${lastWorkFlw.stage} ${lastWorkFlw.actionTaken} - ${lastWorkFlw.userId} - ${lastWorkFlw.timeStamp})`)
                $(`#${BaseScrId}sourcingQueryRow,#${BaseScrId}sorcingRemarksSec`).removeClass('sno');
            } else {
                $(`#${BaseScrId}sourcingQueryRow,#${BaseScrId}sorcingRemarksSec`).addClass('sno');
            }
        } else {
            $(`#${BaseScrId}sourcingQueryRow,#${BaseScrId}sorcingRemarksSec`).addClass('sno');
        }
    },
    prepareSourcingQueryReq: function () {
        const outputObj = {};
        Object.keys(SOURCING_SENDBACK_QUERIES).forEach(stage => {
            outputObj[stage] = {};
            Object.keys(SOURCING_SENDBACK_QUERIES[stage]).forEach(role => {
                outputObj[stage][role] = {
                    response: SOURCING_SENDBACK_QUERIES[stage][role].response
                };
            });
        });
        return outputObj;
    },
    prepareSourcingQueryRes: function () {
        let respObj = JSON.parse(inSessionStore.sourcingQueryResponse.response);
        Object.keys(SOURCING_SENDBACK_QUERIES).forEach(stage => {
            Object.keys(SOURCING_SENDBACK_QUERIES[stage]).forEach(role => {
                SOURCING_SENDBACK_QUERIES[stage][role].response = respObj[stage]?.[role]?.response || "";
            });
        });
    },
    formatToTwoDecimal: function (amount) {
        let num = parseFloat(amount);
        if (isNaN(num)) return "0.00"; // fallback for invalid input
        return num.toFixed(2);
    },
    formatDateTimeObj: function (datetimeObj) {
        /*datetimeObj = {
          date: { year: 2025, month: 5, day: 15 },
          time: { hour: 16, minute: 38, second: 56, nano: 144000000 }
        };*/
        if (typeof datetimeObj !== 'object') return;
        const pad = (num) => String(num).padStart(2, '0');
        let formatted = '';
        if (datetimeObj.hasOwnProperty('time')) {
            formatted = `${pad(datetimeObj.date.day)}/${pad(datetimeObj.date.month)}/${datetimeObj.date.year} - ${pad(datetimeObj.time.hour)}:${pad(datetimeObj.time.minute)}:${pad(datetimeObj.time.second)}`;
        } else {
            if (!datetimeObj.hasOwnProperty('date')) {
                datetimeObj = {
                    date: datetimeObj
                }
            }
            formatted = `${datetimeObj.date.year}/${pad(datetimeObj.date.month)}/${pad(datetimeObj.date.day)}`;
        }
        return formatted; // Output: 15/05/2025 - 16:38:56
    },
    validateQueryResponses: function () {
        const errors = [];
        Object.entries(SOURCING_SENDBACK_QUERIES).forEach(([stage, roles]) => {
            Object.entries(roles).forEach(([role, details]) => {
                if (Array.isArray(details.query) && details.query.length > 0 && !details.response.trim()) {
                    errors.push(`${stage} - ${role}`);
                }
            });
        });
        return {
            isValid: errors.length === 0,
            errors
        };
    },
    getBase64FileSizeInBytes: function (base64String) {
        // Remove the Base64 prefix if present
        let cleanedBase64 = base64String.split(',')[1] || base64String;
        // Calculate the size in bytes
        let byteLength = Math.floor(
            (cleanedBase64.length * 3 / 4) - (cleanedBase64.endsWith('==') ? 2 : cleanedBase64.endsWith('=') ? 1 : 0));
        return byteLength;
    },
    downloadCurrImage: function (pictureId, paintFileName) {
        let gBase64 = $(`#${pictureId}`).attr('src');
        ApzCOB.convertBase64ToPNG(gBase64, paintFileName);
    },
    fetchSanctionQuery: function (stageType) {
        var request = {};
        var params = {};
        var callbackFunc = "";
        request.stage_name = stageType;
        callbackFunc = ApzCOB.fetchSanctionQueryCB;
        params.callBackObj = this;
        params.buildReq = "N";
        params.paintResp = "N";
        params.req = request;
        params.appId = gAppId;
        params.ifaceName = "RPCStageFields";
        params.async = true;
        params.callBack = callbackFunc;
        apz.startLoader();
        apz.server.callServer(params);
    },
    fetchSanctionQueryCB: function (params) {
        if (!IS_VIEWLOG_FETCH) {
            apz.stopLoader();
        }
        let queryCategories = params.res.APZCBO__RPCStageFields_Res;
        SANCTION_QUERIES = queryCategories;
    },
    applicationMasterData: function (param) {
        if (selectedTitle === 'Sourcing stage') {
            if (SELECTED_SUB_STATUS !== 'PENDING') {
                var resp = param;
                window.ISPUSHBACKPPL = false;
                window.viewAllClicked = false;
                window.pendingApplication = true;
                gApzCOB.userDetails.appId = resp.applicationMaster.appId;
                gApzCOB.userDetails.applicationId = resp.applicationMaster.applicationId;
                gApzCOB.userDetails.versionNum = resp.applicationMaster.versionNum;
                gApzCOB.userDetails.applicationStatus = resp.applicationMaster.applicationStatus;
                gApzCOB.userDetails.createdBy = resp.applicationMaster.createdBy;
                gApzCOB.mainProductGroupCode = resp.applicationMaster.productGroupCode;
                gApzCOB.product = resp.applicationMaster.productGroupCode;
                if (resp.applicationMaster.productCode === '1009') {
                    ApplicationType = "NEW";
                } else {
                    ApplicationType = "RENEWAL";
                }
                ApzCOB.getProductData();
                gApzCOB.ExistingCustomer = resp.applicationMaster.applicationType === 'ETB' ? true : false;
                gApzCOB.userDetails.customerId = resp.applicationMaster.memberId;
                gApzCOB.userDetails.workitemNo = resp.applicationMaster.workitemNo;
                if (['PUSHBACK', 'CAPUSHBACK', 'CA_PUSHBACK'].includes(SELECTED_SUB_STATUS)) {
                    gApzCOB.queueStatus = 'Push Back';
                    window.ISPUSHBACKPPL = true;
                } else if (SELECTED_SUB_STATUS === 'SUBMITTED') {
                    gApzCOB.queueStatus = 'Completed';
                } else if (SELECTED_SUB_STATUS === 'REJECTED') {
                    gApzCOB.queueStatus = 'Rejected';
                }
            }
        }
    },
    sanctionSMSService: function (mobileNo, smsType) {
        let language = "";
        if (!apz.isNull(inSessionStore.loanDetails)) {
            language = inSessionStore.loanDetails.payload.language;
        } else {
            language = $("#" + screenId + "language").val() !== PleaseSelect ? $("#" + screenId + "language").val() : "";
        }
        let applicantCustData = ApzCOB.getApplicantCustData() || [];
        let req = {
            apiRequest: {
                interfaceName: "GenOtp",
                workflowId: "GenerateOtp",
                appId: apz.appId,
                applicationId: gApzCOB.userDetails.applicationId,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                userName: gApzCOB.LoggedInUserDetails.loginResponse.userDet.name,
                requestObj: {
                    payload: {},
                    actionType: smsType,
                    language: language,
                    mobileNo: mobileNo,
                    custName: applicantCustData[0]?.customerName || "",
                    otp: "",
                    validTill: "",
                },
            },
        };
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "WorkFlowService", "N", "N", req, false, ApzCOB.sanctionSMSServiceCB);
        }, 1000);
    },
    sanctionSMSServiceCB: function (params) {
        apz.stopLoader();
        if (ApzCOB.handleServiceCallBacks(params)) { }
    },
    checkThousand: function (pthis) {
        let value = parseInt($(pthis).val(), 10);
        if (!isNaN(value)) {
            let rounded = Math.round(value / 1000) * 1000;
            $(pthis).val(rounded);
        }
    },
    getCBTriggerDate: function () {
        const cbDate = ApzCOB.getPayloadDatafromWrapper('cbDate', 'Co-App', 'cibilDetailsWrapperList');
        if (typeof cbDate !== 'object') return '';
        const date = new Date(cbDate.year, cbDate.month - 1, cbDate.day);
        date.setDate(date.getDate() - 1);
        const day = String(date.getDate()).padStart(2, '0');
        const month = String(date.getMonth() + 1).padStart(2, '0'); // Months are 0-based
        const year = date.getFullYear();
        return `${day}/${month}/${year}`;
    },
    revertRecommendedLoanAmount: function () {
        let BRETriggerLoanAmt = Number(ApzCOB.getPayloadDatafromWrapper('eligibleAmt', 'Co-App', 'cibilDetailsWrapperList') || 0);
        if (['CACOMPLETED', 'RESANCTION'].includes(inSessionStore?.applicationMaster?.applicationStatus)) {
            //call bre for sanction amt
            $(`#${screenMainId}sanLoanInput`).val(BRETriggerLoanAmt);
            apz.app.Saloandetails.changeSanctionLoanAmt();
        } else if (inSessionStore?.applicationMaster?.applicationStatus === 'RPCVERIFIED') {
            //call bre for bre amt
            if (CA_CURRENT_STAGE === "InPrincipleDecision") {
                $(`#CrdAss__CaInPrincipleDecision__recLnAmtVal`).val(BRETriggerLoanAmt);
                apz.app.CaInPrincipleDecision.updateLoanAmount();
            }
        }
    },
    isJSONString: function (str) {
        try {
            const parsed = JSON.parse(str);
            return typeof parsed === 'object' && parsed !== null;
        } catch (e) {
            return false;
        }
    },
    PanVerificationCheck: function (panObj, callBack) {
        let callBackFn = callBack || ApzCOB.panVerificationCheckCB;
        let req = {
            apiRequest: {
                interfaceName: "ValidateVoterID",
                requestObj: panObj,
            },
        };
        ApzCOB.showLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "ValidateVoterID", "N", "N", req, false, callBackFn);
        }, 100);
    },
    panVerificationCheckCB: function (params) {
        ApzCOB.hideLoader();
        if (!apz.isNull(params.resFull.appzillonBody.APZCBO__ValidateVoterID_Res)) {
            if (!apz.isNull(params.resFull.appzillonBody.APZCBO__ValidateVoterID_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = ApzCOB.getDescfromLitCode("LIT_KYC_VERIFICATION_SERVICE_FAILED") + "<br/>" + params.resFull.appzillonBody
                    .APZCBO__ValidateVoterID_Res.apiResponse.ResponseHeader.ResponseMessage;
            }
        } else {
            errMsg = ApzCOB.getDescfromLitCode("LIT_KYC_VERIFICATION_SERVICE_FAILED");
        }
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let responseObj = JSON.parse(params.res.APZCBO__ValidateVoterID_Res.apiResponse.ResponseBody.responseObj);
                if (responseObj.hasOwnProperty("result_code") && responseObj.result_code === 101) {
                    if (gApzCOB.currentApplicant <= 1) {
                        window.applicant_pancheck = true;
                    } else {
                        window.coapplicant_pancheck = true;
                    }
                    if (IS_REINITIATE_APPLICATION || IS_REJECTED_APPLICATION) {
                        window.REINITIATE_PAN_CHECKED = true;
                    } else {
                        window.REINITIATE_PAN_CHECKED = false;
                    }
                    $("#" + PerDetScrId + "el_txt_141_ul").removeClass("sno");
                    $("#" + PerDetScrId + "el_txt_142_ul").addClass("sno");
                    $("#" + PerDetScrId + "el_hpl_3_ul").addClass("sno");
                    ApzCOB.AddOrRemoveDisableFields([`${PerDetScrId}panNumberInp`], true);
                } else {
                    $("#" + PerDetScrId + "el_hpl_3_ul").addClass("sno");
                    $("#" + PerDetScrId + "el_txt_141_ul").addClass("sno");
                    $("#" + PerDetScrId + "el_txt_142_ul").removeClass("sno");
                    ApzCOB.AddOrRemoveDisableFields([`${PerDetScrId}panNumberInp`], false);
                }
            } else {
                // $("#" + PerDetScrId + "el_txt_142_ul").removeClass("sno");
                ApzCOB.hideLoader();
                ApzCOB.fnDisplayMsg(errMsg, "E");
            }
        } catch (e) {
            ApzCOB.hideLoader();
            ApzCOB.fnDisplayMsg(errMsg, "E");
        }
    },
    panVerificationCheckerr: function () {
        $("#" + PerDetScrId + "el_hpl_3_ul").removeClass("sno");
        $("#" + PerDetScrId + "el_txt_141_ul").addClass("sno");
        $("#" + PerDetScrId + "el_txt_142_ul").addClass("sno");
    },
    sortDocuments: function (data) {
        const sorted = data.sort((a, b) => {
            const typeA = a.documentType || a.payload?.documentType;
            const typeB = b.documentType || b.payload?.documentType;
            if (typeA === typeB) {
                const levelA = Number(a.docLevel || a.payload?.docLevel);
                const levelB = Number(b.docLevel || b.payload?.docLevel);
                return levelA - levelB;
            }
            return typeA.localeCompare(typeB);
        });
        return sorted;
    },
    setCoAppRenewalFlag: function () {
        let newPrimaryKyc = (ApzCOB.getPayloadDatafromWrapper('primaryKycId', 'Co-App', 'customerDetailsList') || '-').toUpperCase();
        let oldPrimaryKyc = (ApzCOB.getPayloadDatafromWrapper('coVoterIdNo', 'Co-App', 'renewalLeadDetails') || '-').toUpperCase();
        let newAltKyc = (ApzCOB.getPayloadDatafromWrapper('alternateVoterId', 'Co-App', 'customerDetailsList') || '').toUpperCase();
        let oldAltKyc = (ApzCOB.getPayloadDatafromWrapper('', 'Co-App', 'renewalLeadDetails') || '').toUpperCase();
        if (newPrimaryKyc === oldPrimaryKyc) {
            UpdateCoAppText = 'Update existing Co-Applicant details';
            document.querySelectorAll('#RPC__PrimaryKycRPC__isNewCustomerInput input').forEach(el => {
                const labelTitle = el.nextElementSibling?.title;
                if (labelTitle === UpdateCoAppText) {
                    $(el).prop('checked', true);
                    $(`#${el.id}_lbl_`).removeClass('sno');
                }
                ApzCOB.addDisableToInput(el.id);
            });
        }
    }
}
