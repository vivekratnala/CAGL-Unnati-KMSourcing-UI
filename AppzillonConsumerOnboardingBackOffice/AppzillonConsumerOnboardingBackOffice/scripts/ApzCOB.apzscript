                        LoggedInUserDetails?.loginResponse?.userDet?.id + " " + docQueryTs + ")");*/
                    apz.app.RPCDBDocExecutionUnnati.paintDocData();
                }
                const queryRow = `RPC__${RPCDBVerify_STAGES[apz.childScr].id}__queriesRow`;
                $(`#${queryRow}`).html('');
                /*stageQueries = ApzCOB.paintingQuery();
                pushbackQuery = ApzCOB.chekPushbackQueries();
                if (stageQueries.length > 0 || pushbackQuery.length > 0) {
                    ApzCOB.launchSubScreen("RPC_Query", queryRow, "");
