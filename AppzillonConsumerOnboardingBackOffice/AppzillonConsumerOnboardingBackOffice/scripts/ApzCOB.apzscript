            apz.populateDropdown(document.getElementById(params.req.fieldId), Cities);
            ApzCOB.sameCommonAddr();
            if (window.reviewConfirmJoint && !window.iscomplete) {
                if (!apz.isNull(gApzCOB.requestNodes["addressDetailsWrapperList"][0].addressDetailsList[0].payload.addressList[0]) && gApzCOB
                    .requestNodes["addressDetailsWrapperList"][0].addressDetailsList[0].payload.addressList[0].addressType === "Permanent") {
                    ApzCOB.loadCityDropDown();
                    if (!apz.isNull(gApzCOB.requestNodes["addressDetailsWrapperList"][0].addressDetailsList[0].payload.addressList[1])) {
                        let b = gApzCOB.requestNodes["addressDetailsWrapperList"][0].addressDetailsList[0].payload.addressList[1];
                        if (b.city !== "") {
                            apz.setElmValue(PerDetScrId + "city", cityVal[cityDesc.indexOf(b.city)]);
                        }
                    }
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    citydropDown: function (screenId, stateId, cityId) {
        let stateCode;
        let state = $("#" + BankFacScrId + "state");
        if (state.val() === ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")) {
            $("#" + BankFacScrId + "city").val(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
            $("#" + BankFacScrId + "branchAddressDiv").addClass("sno");
            $("#" + BankFacScrId + "branchNameRow").addClass("sno");
            $("#" + BankFacScrId + "button").addClass("sno");
            Cities = [];
            apz.populateDropdown(document.getElementById(screenId + cityId), Cities);
        }
        if (apz.childScr === "NomineeDetails") {
            if ($("#NomDet__NomineeDetails__grdState").val() === ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")) {
                $("#" + nomineeScrId + "grdCity").val(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                Cities = [];
                apz.populateDropdown(document.getElementById(screenId + cityId), Cities);
            }
            if ($("#NomDet__NomineeDetails__state").val() === ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")) {
                $("#" + nomineeScrId + "city").val(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
                Cities = [];
                apz.populateDropdown(document.getElementById(screenId + cityId), Cities);
            }
        }
        $.each(gStates, function (a, b) {
            if (b.stateName === $("#" + screenId + stateId).val()) {
                stateCode = b.stateCode;
            }
        });
        if (!apz.isNull(stateCode)) {
            ApzCOB.FetchCities(stateCode, screenId, cityId);
        }
    },
    //////////////////////////////////////////////////////////////////////////////////
    // To Fetch Branches
    FetchBranches: function (stateCode, cityCode, screenId, branchId) {
        let req = {
            fieldId: screenId + branchId,
            apiRequest: {
                interfaceName: "CobFetchBranches",
                appId: gAppId,
                requestObj: {
                    stateCode: stateCode,
                    cityCode: cityCode,
                },
            },
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "FetchBranches", "N", "N", req, false, ApzCOB.FetchBranchesCB);
    },
    //Fetch Branches Service Callback
    FetchBranchesCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = JSON.parse(params.res.APZCBO__FetchBranches_Res.apiResponse.ResponseBody.responseObj);
                gBranches = response;
            }
            Branches = [];
            $.each(gBranches, function (a, b) {
                let obj = {};
                obj.val = b.branchCode;
                obj.desc = b.branchName;
                obj.location = b.branchAddress;
                Branches.push(obj);
            });
            Branches.unshift({
                val: "-1",
                desc: ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"),
            });
            apz.populateDropdown(document.getElementById(params.req.fieldId), Branches);
            if (params.res.APZCBO__FetchBranches_Res.apiResponse.ResponseBody.responseObj !== "[]") {
                if ($("#" + BankFacScrId + "branch").val() === ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")) {
                    $("#" + BankFacScrId + "branchAddressDiv").addClass("sno");
                    $("#" + BankFacScrId + "button").addClass("sno");
                } else {
                    $("#" + BankFacScrId + "branchAddressDiv").removeClass("sno");
                    $("#" + BankFacScrId + "button").removeClass("sno");
                }
                $("#" + BankFacScrId + "branchNameRow").removeClass("sno");
            } else {
                $("#" + BankFacScrId + "branchNameRow").addClass("sno");
                $("#" + BankFacScrId + "branchAddressDiv").addClass("sno");
                $("#" + BankFacScrId + "button").addClass("sno");
                if ($(".dialog").length === 0) {
                    //Triggering twice in MB
                    ApzCOB.fnDisplayMsg("No Branches Found", "E");
                }
                //var state = $('#' + BankFacScrId + "state")
                //var city = $('#' + BankFacScrId + "city")
                ApzCOB.stateDropDown(BankFacScrId, "state");
                ApzCOB.citydropDown(BankFacScrId, "state", "city");
                apz.setElmValue(BankFacScrId + "state", "-1");
                $("#" + BankFacScrId + "city").val(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    branchedropDown: function (screenId, stateId, cityId, branchId) {
        let stateCode;
        let cityCode;
        let city = $("#" + BankFacScrId + "city");
        if (city.val() === ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")) {
            $("#" + BankFacScrId + "city").val(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
            $("#" + BankFacScrId + "branchAddressDiv").addClass("sno");
            $("#" + BankFacScrId + "branchNameRow").addClass("sno");
            $("#" + BankFacScrId + "button").addClass("sno");
        }
        $.each(gStates, function (a, b) {
            if (b.stateName === $("#" + screenId + stateId).val()) {
                stateCode = b.stateCode;
            }
        });
        $.each(gCities, function (a, b) {
            if (b.cityName === $("#" + screenId + cityId).val()) {
                cityCode = b.cityCode;
            }
        });
        if (!apz.isNull(stateCode) && !apz.isNull(cityCode)) {
            ApzCOB.FetchBranches(stateCode, cityCode, screenId, branchId);
        }
    },
    branchAddress: function (stateCode, cityCode, branchCode, pthis) {
        let state, city, branch;
        state = apz.getElmValue(BankFacScrId + "state");
        city = apz.getElmValue(BankFacScrId + "city");
        branch = apz.getElmValue(BankFacScrId + "branch");
        if (branch === "-1") {
            $("#" + BankFacScrId + "branchAddressDiv").addClass("sno");
            $("#" + BankFacScrId + "button").addClass("sno");
        } else {
            let req = {
                apiRequest: {
                    interfaceName: "CobFetchBranches",
                    appId: gAppId,
                    requestObj: {
                        stateCode: state,
                        cityCode: city,
                        branchCode: branch,
                    },
                },
            };
            apz.startLoader();
            ApzCOB.serverBuildParam(gAppId, "FetchBranches", "N", "N", req, true, ApzCOB.branchAddressCB);
            $("#" + BankFacScrId + "branchAddressDiv").removeClass("sno");
            $("#" + BankFacScrId + "button").removeClass("sno");
        }
    },
    branchAddressCB: function (params) {
        //Handels success/failure of branch details service
        let selBranchAddress;
        if (params.status) {
            let objectData = params.res.APZCBO__FetchBranches_Res.apiResponse;
            let responseHeader = objectData.ResponseHeader;
            if (apz.isNull(responseHeader.ResponseCode) && !apz.isNull(responseHeader.ErrorCode)) {
                ApzCOB.errorHandling(responseHeader);
            } else if (responseHeader.ResponseCode === "0" && !apz.isNull(responseHeader.ErrorCode)) {
                ApzCOB.errorHandling(responseHeader);
            } else if (responseHeader.ResponseCode === "0" && apz.isNull(responseHeader.ErrorCode)) {
                window.locationDetails = {};
                JSON.parse(objectData.ResponseBody.responseObj).filter(function (e, i) {
                    if (e.branchCode === apz.getElmValue(BankFacScrId + "branch")) {
                        gApzCOB.userDetails.branchCode = e.branchCode;
                        selBranchAddress = e.branchAddress;
                    }
                });
                let branchAddressHolder = "BnkFac__IpaintFetchBranches__o__BnkFac__IpaintFetchBranches_Res__branchAddress_txtcnt";
                $("#" + branchAddressHolder).text(selBranchAddress);
            } else {
                ApzCOB.errorHandling(objectData.ResponseHeader);
            }
        }
        apz.stopLoader();
    },
    getLocation: function () {
        ApzCOB.setMapData(locationDetails[0].latitude, locationDetails[0].longitude);
    },
    setMapData: function (latitude, longitude) {
        let req = {
            apiRequest: {
                interfaceName: "CobFetchBranches",
                appId: gAppId,
                requestObj: {
                    latitude: latitude,
                    longitude: longitude,
                },
            },
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "FetchBranches", "N", "N", req, true, ApzCOB.branchLocationDetailsCB);
    },
    branchLocationDetailsCB: function (params) {
        apz.stopLoader();
        if (params.status) {
            let plannedResultSet = JSON.parse(params.res.APZCBO__FetchBranches_Res.apiResponse.ResponseBody.responseObj);
            const BranchArr = plannedResultSet.filter(item => item.bankType === "BRANCH");
            const selectedBranch = BranchArr.find(item => item.location === $("#" + BankFacScrId + "branch").val());
            if (selectedBranch) {
                window.Address = selectedBranch.address;
            }
        }
    },
