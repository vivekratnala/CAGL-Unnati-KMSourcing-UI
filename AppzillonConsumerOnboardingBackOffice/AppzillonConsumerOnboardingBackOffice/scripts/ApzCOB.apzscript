                    versionNum: window.versionNum,
                },
            },
        };
        if (typeof curApplicantId === "number" && Number(gApzCOB.noOfApplicants) > 1) {
            req.apiRequest.requestObj.custDtlId = curApplicantId;
            if (!apz.isObjectEmpty(gApzCOB.requestNodes.loanDetails)) {
                window.newloanDetails = gApzCOB.requestNodes.loanDetails;
            }
        }
        apz.startLoader();
        let callBack = !apz.isNull(callBackFn) ? callBackFn : ApzCOB.FetchApplicationCB;
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "FetchApplication", "N", "N", req, false, callBack);
        }, 1000);
    },
    //FetchApplicationService Callback
    FetchApplicationCB: function (params) {
        window.IS_APPLICANT_CB_EXPIRED = false;
        window.IS_CO_APPLICANT_CB_EXPIRED = false;
        apz.stopLoader();
        let errMsg = "";
        if (!apz.isNull(params.resFull.appzillonBody.APZCBO__SendbackDataFetch_Res)) {
            if (!apz.isNull(params.resFull.appzillonBody.APZCBO__SendbackDataFetch_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = "Fetch Application Data Service Failed." + "<br/>" + params.resFull.appzillonBody.APZCBO__SendbackDataFetch_Res
                    .apiResponse.ResponseHeader.ResponseMessage;
            }
        } else if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
            if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseMessage)) {
                errMsg = params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseMessage;
            }
        } else {
            errMsg = "Fetch Application Data Service Failed";
        }
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = "";
                let intaceResp = "";
                if (params.ifaceName === "SendbackDataFetch") {
                    intaceResp = params.res.APZCBO__SendbackDataFetch_Res.apiResponse.ResponseBody.responseObj;
                } else if (params.ifaceName === "FetchApplication") {
                    intaceResp = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
                }
                if (gApzCOB.product === "DEPOSIT") {
                    if (gApzCOB.ExistingCustomer) {
                        response = JSON.parse(params.res.APZCBO__DepositFetchApplication_Res.apiResponse.ResponseBody.responseObj);
                    } else {
                        response = JSON.parse(params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj);
                    }
                } else if (gApzCOB.product === "CARDS") {
                    response = JSON.parse(params.res.APZCBO__CardFetchApplication_Res.apiResponse.ResponseBody.responseObj);
                    // alert("coming here ....to do")
                } else if (gApzCOB.product === "LOAN") {
                    if (gApzCOB.ExistingCustomer) {
                        response = JSON.parse(params.res.APZCBO__LoanFetchApplication_Res.apiResponse.ResponseBody.responseObj);
                    } else {
                        response = JSON.parse(intaceResp);
                    }
                } else {
                    response = JSON.parse(intaceResp);
                }
                //BRE CB Changes
                if (response.applicationMaster.currentStageNo === 3) {
                    if (apz.isNull(response.loanDetails)) {
                        window.cbWrapperData = response.cibilDetailsWrapperList || [];
                        response.cibilDetailsWrapperList = [];
                    }
                }
                if (!apz.isNull(response.cibilDetailsWrapperList) && response.cibilDetailsWrapperList.length > 0) {
                    response.cibilDetailsWrapperList.map((cibil) => {
                        let cbDatObj = cibil.cibilDetails.cbDate;
                        let cbDateFormatted = `${cbDatObj.year}-${cbDatObj.month}-${cbDatObj.day}`;
                        cibil.cibilDetails.cbDate = ApzCOB.dateformatter(cbDateFormatted, "Y-m-d");
                    });
                }
                if (clickList) {
                    ApzCOB.applicationMasterData(response);
                }
                window.applnRes = response;
                window.auditDtls = response.applicationTimelineDtl;
                window.pendingApplication = true;
                gApzCOB.requestNodes = [];
                gApzCOB.requestNodes = response;
                if (response.applicationMaster.productGroupCode === "LOAN") {
                    window.LoanInProgressProductCode = response.applicationMaster.productCode;
                    window.LoanInProgressProductGroupCode = response.applicationMaster.productGroupCode;
                    let ApplStatus = response.applicationMaster.applicationStatus;
                    if (ApplStatus === "INPROGRESS" || ApplStatus === "INPUTINPROGRESS" || ApplStatus === "PUSHBACK" || ApplStatus ===
                        "CAPUSHBACK" || ApplStatus === "IPUSHBACK" || (ApplStatus == "PENDING" && gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "BM")) {
                        if (leads.length > 0) {
                            let selectedLeadInfo = leads.filter(function (item) {
                                return (item.map.customerId == response.applicationMaster.searchCode2);
                            });
                            if (selectedLeadInfo.length > 0) {
                                gApzCOB.selLeadDtls = selectedLeadInfo[0].map;
                            } else {
                                ApzCOB.setselLeadDtls();
                            }
                        } else {
                            if (apz.isObjectEmpty(inSessionStore)) {
                                ApzCOB.setselLeadDtls();
                            }
                        }
                    }
                }
                if (apz.isObjectEmpty(inSessionStore) || ISPUSHBACKPPL || !dontReloadRC) {
                    inSessionStore = {
                        ...gApzCOB.requestNodes,
                    };
                    if (inSessionStore.applicationDocumentsWrapperList.length > 0) {
                        ApzCOB.handleDocumentsSessionStore();
                    }
                }
                ApzCOB.checkIsRejectApplication();
                if (params.ifaceName === "SendbackDataFetch") {
                    if (!apz.isNull(gApzCOB.requestNodes.actionHist) && !apz.isNull(gApzCOB.requestNodes.actionHist[0])) {
                        window.PUSHBACK_ACTION_HISTORY = gApzCOB.requestNodes.actionHist;
                    }
                }
                if (!apz.isNull(response.applnWfDefinitionList)) {
                    gApzCOB.applnWorkFlowRes = response.applnWfDefinitionList;
                }
                if (window.editappln && apz.currAppId !== "RevCof") {
                    gApzCOB.currentApplicant = 1;
                }
                apz.app.BaseScreens.parseJsonFetchResponse();
                apz.app.BaseScreens.updatePrimaryDetails();
                apz.app.BaseScreens.fetchAadhaarDetails();
                if (apz.isNull(gStates)) {
                    ApzCOB.FetchStates();
                }
                if (apz.isNull(gLovs)) {
                    ApzCOB.FetchLov();
                }
                if (window.clickList) {
                    apz.app.BaseScreens.revieweditflow();
                }
                if (apz.childScr === "ReviewConfirm") {
                    apz.app.ReviewConfirm.paintAllonScreen("single");
                }
                if (!apz.isNull(params.req.apiRequest.requestObj.custDtlId) && Number(gApzCOB.noOfApplicants) > 1 && !window.dontReloadRC) {
                    //do not reload the app, just get details of all applicants
                    apz.app.onLoad_ReviewConfirm();
                    apz.app.onShown_ReviewConfirm();
                }
                if (!window.editappln && !window.dontupdateCurrAppln && apz.childScr !== "ReviewConfirm") {
                    if (gApzCOB.applicationType === JointAccount && window.pendingApplication) {
                        if (gApzCOB.requestNodes.applicationMaster.applicantsCount > gApzCOB.requestNodes.customerDetailsList.length &&
                            gApzCOB.requestNodes.applicationMaster.currentScreenId === STAGES[STAGES.length - 1].split("~")[0]) {
                            gApzCOB.currentApplicant = gApzCOB.requestNodes.customerDetailsList.length + 1;
                        } else {
                            gApzCOB.currentApplicant = gApzCOB.requestNodes.customerDetailsList.length;
                        }
                    } else {
                        gApzCOB.currentApplicant = "1"; //gApzCOB.requestNodes.customerDetailsList.length;
                    }
                }
                if (window.existingAccount) {
                    window.pendingApplication = true;
                    ApzCOB.createApplication();
                }
                //   }
                /**SelfAssisted related Changes Starts***/
                apz.app.BaseScreens.launchPendingAppln();
                /**SelfAssisted related Changes Ends***/
                if (!apz.isNull(IS_REINITIATE_APPLICATION) && IS_REINITIATE_APPLICATION && apz.isNull(CURRENT_STAGE_NO)) {
                    ApzCOB.ReInitiateFromCustData();
                }
                // }
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(errMsg, "E");
            }
            if (gApzCOB.product === "CASA" && Number(gApzCOB.noOfApplicants) > 1 && window.itreviewconfirm) {
                apz.app.ReviewConfirm.paintApplicants();
                window.itreviewconfirm = false;
                $("#" + rvwScrId + "applicantNameList .pri").addClass("active");
                $("#" + rvwScrId + "applicantNameList_row_" + (gApzCOB.currentApplicant - 1)).removeClass("active");
            }
            if (CURRENT_STAGE_NAME === "CUSTVERIFICATION" && pendingApplication) {
                $("#" + BaseScrId + "sidebarController").addClass("sno");
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
