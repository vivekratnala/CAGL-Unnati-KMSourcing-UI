        ApzCOB.serverBuildParam(gAppId, "FetchDashboard", "N", "N", request, false, ApzCOB.fetchDashboardCB);
    },
    fetchDashboardCB: function (params) {
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let ifaceName = ApzCOB.GetInterfaceResMap(params);
                let response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
                let dataObj = {
                    product: ApplicationType,
                    dashboardData: response.map["dashboardLeadDtls"].map,
                };
                let arrayIndex = DASHBOARD_COUNT_DATA.findIndex((dash) => {
                    return dash.product === ApplicationType;
                });
                if (arrayIndex >= 0) {
                    DASHBOARD_COUNT_DATA.splice(arrayIndex, 1);
                }
                DASHBOARD_COUNT_DATA.push(dataObj);
                if (apz.deviceType === 'WEB') {
                    apz.app.Dashboard.showNewDashboardStats();
                } else {
                    apz.app.Dashboard.showNewDashboardStatsTab();
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    },
    convertBase64ToPDF: function (b64Data, fileName) {
        if (apz.deviceType === "WEB") {
            let downloadLink = document.createElement("a");
            downloadLink.href = ApplicationPDFbase64 + b64Data;
            downloadLink.download = fileName.concat(".pdf");
            downloadLink.click();
        } else {
            ApzCOB.convertBase64ToFile(b64Data, fileName);
        }
    },
    convertBase64ToPNG: function (b64Data, fileName) {
        if (apz.deviceType === "WEB") {
            let downloadLink = document.createElement("a");
            if (b64Data.includes(ApplicationPNGbase64)) {
                downloadLink.href = b64Data;
            } else {
                downloadLink.href = ApplicationPNGbase64 + b64Data;
            }
            downloadLink.download = fileName
            downloadLink.click();
        } else {
            ApzCOB.convertBase64ToFile(b64Data, fileName);
        }
    },
    convertBase64ToXLSX: function (b64Data, fileName) {
        if (apz.deviceType === "WEB") {
            const XLSX_BASE64 = "data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,";
            let downloadLink = document.createElement("a");
            if (b64Data.startsWith("data:")) {
                downloadLink.href = b64Data;
            } else {
                downloadLink.href = XLSX_BASE64 + b64Data;
            }
            downloadLink.download = fileName.endsWith(".xlsx") ? fileName : fileName + ".xlsx";
            downloadLink.click();
        } else {
            ApzCOB.convertBase64ToFile(b64Data, fileName);
        }
    },
    downloadBase64File: function (base64String, fileName) {
        //var byteCharacters = atob(base64String.split(',')[1]); // Decode Base64
        let byteCharacters = atob(base64String);
        let byteArrays = [];
        for (let offset = 0; offset < byteCharacters.length; offset += 1024) {
            let slice = byteCharacters.slice(offset, offset + 1024);
            let byteNumbers = new Array(slice.length);
            for (let i = 0; i < slice.length; i++) {
                byteNumbers[i] = slice.charCodeAt(i);
            }
            let byteArray = new Uint8Array(byteNumbers);
            byteArrays.push(byteArray);
        }
        let blob = new Blob(byteArrays, {
            type: "application/pdf",
        });
        let link = document.createElement("a");
        link.href = URL.createObjectURL(blob);
        link.download = fileName + ".pdf";
        link.click();
        link.remove();
    },
    formatSize: function (bytes) {
        if (bytes === 0) return "0 Bytes";
        const sizeUnits = ["Bytes", "KB", "MB", "GB", "TB", "PB"];
        let index = 0;
        let size = bytes;
        while (size >= 1024 && index < sizeUnits.length - 1) {
            size /= 1024;
            index++;
        }
        return `${size.toFixed(2)} ${sizeUnits[index]}`;
    },
    beautifyCbDtlsSummary: function (lparam, lArr) {
        if (!apz.isNull(lArr)) {
            if (!apz.isNull(lArr[lparam])) {
                if (lArr[lparam].toString().includes(":")) {
                    lArr[lparam] = lArr[lparam].split(":")[1].trim();
                }
            }
        }
    },
    toggleRpcEditButton: function () {
        if ([7, 8, 9, 10].includes(RPC_CURRENT_STAGE_NO)) {
            return;
        }
        $('.rpcEditBtn').addClass('sno');
        currentTypeFields.forEach(field => {
            const fieldSelector = `#RPC__${RPC_CURRENT_STAGE}__${field.fieldId}`;
            let $input = $(`${fieldSelector} .ett-inpt, ${fieldSelector} .sub-elt, ${fieldSelector} .ett-rdio`).first();
            let inputId = $input.attr("id");
            if (!inputId) return;
            let isEditable = field.fieldAttr.split("~")[2] === "E";
            let isVisible = $(`#${inputId}`).is(':visible');
            if (isEditable && isVisible) {
                $('.rpcEditBtn').removeClass('sno');
                return;
            }
        });
    },
    checkFieldVisibility: function (larray) {
        let lFlag = true;
        if (Array.isArray(larray)) {
            larray.forEach(el => {
                let isVisible = $(`#RPC__${RPC_CURRENT_STAGE}__${el}`).is(':visible');
                if (!isVisible) {
                    lFlag = false;
                }
            });
        } else {
            lFlag = false;
        }
        return lFlag;
    },
    setFieldData: function (fieldData) {
        switch (fieldData) {
            case 'no':
            case 'No':
            case 'NO':
            case 'N':
                fieldData = 'No';
                break;
            case 'YES':
            case 'Yes':
            case 'y':
            case 'Y':
                fieldData = 'Yes';
        }
        return fieldData
    },
    fetchAllRpcStageFieldsCB: function (params) {
        apz.stopLoader();
        try {
            if (!apz.isNull(params.res.APZCBO__RPCStageFields_Res) && params.res.APZCBO__RPCStageFields_Res.length > 0) {
                window.RPC_ALL_STAGE_FIELDS = params.res.APZCBO__RPCStageFields_Res.filter(stage => stage.stage_name !== "ReviewConfirm");
                window.RPC_ALL_STAGE_QUERIES = RPC_ALL_STAGE_FIELDS.flatMap(input => {
                    const parsedQueries = JSON.parse(input.queries);
                    return Object.entries(parsedQueries).map(([key, value]) => ({
                        stageID: input.id,
                        custType: key === "Applicant" ? "A" : key === "Co-App" ? "C" : key,
                        query: value
                    }));
                });
                if (apz.retrieve("isApplicationPreview") && (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 !== "RPC")) {
                    apz.app.PreviewApplicantDetails.paintStages();
                    apz.store("isApplicationPreview", false);
                }
            }
        } catch (e) {
            ApzCOB.showCommonErrRPCModal();
        }
    },
    fetchRpcStageFields: function (stageName, callFn) {
        let request = {};
        let params = {};
        let callbackFunc = "";
        if (apz.childScr !== "Saloandetails" && apz.childScr !== 'Disbursement') {
            if (RPC_CURRENT_STAGE === "ReviewConfirm" || stageName === "ReviewConfirm") {
                RPC_ALLSTAGES = Object.values(RPC_STAGES).map(stage => stage.screenName);
                request.stage_name = RPC_ALLSTAGES;
            } else {
                request.stage_name = RPC_CURRENT_STAGE;
            }
            callbackFunc = (!apz.isNull(stageName)) ? ApzCOB.fetchAllRpcStageFieldsCB : ApzCOB.fetchRpcStageFieldsCB;
        } else {
            request.stage_name = stageName;
            callbackFunc = callFn;
        }
        params.callBackObj = this;
        params.buildReq = "N";
        params.paintResp = "N";
        params.req = request;
        params.appId = gAppId;
        params.ifaceName = "RPCStageFields";
        params.async = true;
        params.callBack = callbackFunc;
        apz.startLoader();
        apz.server.callServer(params);
    },
    fetchRpcStageFieldsCB: function (params) {
        apz.stopLoader();
        try {
            if (!apz.isNull(params.res.APZCBO__RPCStageFields_Res) && params.res.APZCBO__RPCStageFields_Res.length > 0) {
                if (RPC_CURRENT_STAGE === "ReviewConfirm") {
                    window.RPC_CURRENT_STAGE_FIELDS = params.res.APZCBO__RPCStageFields_Res.filter(stage => stage.stage_name !== RPC_CURRENT_STAGE);
                    apz.app.ReviewConfirm.paintStages();
                } else {
                    window.RPC_CURRENT_STAGE_FIELDS = params.res.APZCBO__RPCStageFields_Res.filter(
                        (cur) => cur.stage_name === RPC_CURRENT_STAGE);
                    if (!$('.rpcStageSubmenuRow').hasClass('sno')) {
                        if ($(`#RPC__${RPC_CURRENT_STAGE}__rpcStageSubmenuItem_1`).length > 0) $(
                            `#RPC__${RPC_CURRENT_STAGE}__rpcStageSubmenuItem_1`).click();
                        if ($(`#RPC__${RPC_CURRENT_STAGE}__rpcStageSubmenuItem_2`).length > 0 && [6, 7].includes(RPC_CURRENT_STAGE_NO) && $(
                            `#RPC__RPCSidebar__menuBarList_row_-1_${RPC_CURRENT_STAGE_NO} .ttl-chld:visible`)?.length === 1 && !
                            isAppCoAppOccTagYes) $(`#RPC__${RPC_CURRENT_STAGE}__rpcStageSubmenuItem_2`).click();
                    } else {
                        ApzCOB.paintRpcFields("", 1)
                    }
                }
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.showCommonErrRPCModal();
        }
    },
    paintRpcFields: function (pthis, customerType) {
        window.custType = customerType === 1 ? "Applicant" : "Co-App";
        const $btn = $('#RPC__RPCDocumentSection__Compare_btn');
        if ($btn.data('bs.popover') && $btn.attr('aria-describedby')) {
            $btn.popover('hide');
        }
        let panTypeSts_coApp = ApzCOB.getPayloadDatafromWrapper('panNumberStatus', 'Co-App', 'customerDetailsList');
        let panTypenum_coApp = ApzCOB.getPayloadDatafromWrapper('panNumber', 'Co-App', 'customerDetailsList');
        let panTypeSts_App = ApzCOB.getPayloadDatafromWrapper('panNumberStatus', 'Applicant', 'customerDetailsList');
        let panTypenum_App = ApzCOB.getPayloadDatafromWrapper('panNumber', 'Applicant', 'customerDetailsList');
        if (custType === "Co-App" && panTypeSts_coApp == 'Verified' && !apz.isNull(panTypenum_coApp) && !window.COMPARE_DOC_TYPES.includes(
            'PAN_NUMBER_PHOTO')) {
            window.COMPARE_DOC_TYPES.push('PAN_NUMBER_PHOTO');
        } else if (custType === "Co-App" && panTypeSts_coApp == '') {
            window.COMPARE_DOC_TYPES = window.COMPARE_DOC_TYPES.filter(item => item !== "PAN_NUMBER_PHOTO");
        } else if (panTypeSts_App == 'Verified' && !apz.isNull(panTypenum_App) && custType == 'Applicant' && !window.COMPARE_DOC_TYPES
            .includes('PAN_NUMBER_PHOTO')) {
            window.COMPARE_DOC_TYPES.push('PAN_NUMBER_PHOTO');
        } else if (custType === "Applicant" && panTypeSts_App == '') {
            window.COMPARE_DOC_TYPES = window.COMPARE_DOC_TYPES.filter(item => item !== "PAN_NUMBER_PHOTO");
        }
        if (custType === "Co-App" && !apz.isNull(apz.data.scrdata.RPC__PaintDocumentType_Res)) {
            apz.data.scrdata.RPC__PaintDocumentType_Res = apz.data.scrdata.RPC__PaintDocumentType_Res.filter(doc => doc.doctype !== "Relationship proof");
            if (ApzCOB.getOccupation() === "Salaried") {
                apz.data.scrdata.RPC__PaintDocumentType_Res = apz.data.scrdata.RPC__PaintDocumentType_Res.filter(doc => doc.doctype !== "Employment proof");
            }
            apz.data.loadData('PaintDocumentType', 'RPC');
        }
        if (RPC_CURRENT_STAGE_NO === 2) {
            addrType = 'Personal'; subAddrType = 'SecondaryKyc';
            window.isSecKycExist = apz.app.SecondaryKYCRPC.checkRpcSecKycDataExist();
        } else if (RPC_CURRENT_STAGE_NO === 3) {
            window.custType = "Co-App";
        } else if (RPC_CURRENT_STAGE_NO === 4 || RPC_CURRENT_STAGE_NO === 5) {
            addrType = 'Personal'; subAddrType = 'Present';
        } else if (RPC_CURRENT_STAGE_NO === 7) {
            addrType = 'Occupation'; subAddrType = 'Office';
        }
        $('.fieldEditedTag,span.err').remove();
        $('.err-inpt').removeClass('err-inpt');
        window.RPC_CURRENT_STAGE_FIELDS = (RPC_CURRENT_STAGE_FIELDS.length > 1) ? RPC_CURRENT_STAGE_FIELDS.filter(el => el.id ===
            RPC_CURRENT_STAGE_NO) : RPC_CURRENT_STAGE_FIELDS;
        const stageDetails = JSON.parse(RPC_CURRENT_STAGE_FIELDS[0].stage_dtls);
        currentTypeFields = stageDetails[custType] || [];
        let fieldData = "",
            fieldId = '',
            calendarbtnId = '',
            dropDownArrowId = '';
        $(`#scr__RPC__${RPC_CURRENT_STAGE}__main input`).each(function () {
            $(this).parents('span').last().addClass('sno');
        }); //hiding all the fields first
        currentTypeFields.forEach(field => {
            if (!apz.isNull(field.fieldAttr, field.label)) {
                let [visibilityAttr, mandatoryAttr, editAttribute] = field.fieldAttr.split("~");
                if (ApplicationType !== 'RENEWAL' && field.fieldId === 'isNewCustomer') {
                    visibilityAttr = 'N';
                    mandatoryAttr = 'N'
                }
                const fieldSelector = `#RPC__${RPC_CURRENT_STAGE}__${field.fieldId}`;
                if (visibilityAttr?.toUpperCase() === "Y") {
                    $(fieldSelector).removeClass("sno");
                } else {
                    $(fieldSelector).addClass("sno");
                }
                fieldData = ApzCOB.getPayloadData(field.fieldId, custType);
                fieldId = field.fieldId;
                const labelSelector = `${fieldSelector} .ett-labl`;
                if (mandatoryAttr?.toUpperCase() === "M" && editFlag === true) {
                    $(labelSelector).addClass("req");
                } else {
                    $(labelSelector).removeClass("req");
                }
                let inputSelectorCurrentID;
                if ($(`${fieldSelector} .ett-inpt`).length) {
                    inputSelectorCurrentID = $(`${fieldSelector} .ett-inpt`).attr("id");
                    calendarbtnId = ($(fieldSelector).find('.ett-bttn')?.length > 0) ? $(fieldSelector).find('.ett-bttn').attr('id') :
                        '';
                } else if ($(`${fieldSelector} .etb-slct`).length) {
                    inputSelectorCurrentID = $(`${fieldSelector} .sub-elt`).attr("id");
                    dropDownArrowId = ($(fieldSelector).find('.sub-elt1')?.length > 0) ? $(fieldSelector).find('.sub-elt1').attr(
                        'id') : '';
                } else if ($(`${fieldSelector} .ett-rdio`).length) {
                    inputSelectorCurrentID = $(`${fieldSelector} .ett-rdio`).attr("id");
                }
                $(`#${inputSelectorCurrentID}`).attr('id', `RPC__${RPC_CURRENT_STAGE}__${field.fieldId}Input`);
                let inputSelectorID = `RPC__${RPC_CURRENT_STAGE}__${field.fieldId}Input`;
                if (inputSelectorID) {
                    ApzCOB.addDisableToInput(inputSelectorID);
                    if ($(`#${inputSelectorID}`).attr('apztype') === 'radiogroup') {
                        if (['streetVendor', 'insuranceReqd', 'coApplicantInsurance', 'isDisabled'].includes(fieldId)) {
                            fieldData = ApzCOB.setFieldData(fieldData);
                        }
                        if (['residenceAddressSince', 'residenceCitySince'].includes(fieldId)) {
                            fieldData = fieldData.replace('y', 'Y')
                        }
                        document.querySelectorAll(`#${inputSelectorID} input`)?.forEach(el => {
                            if (el?.nextElementSibling?.title === fieldData) {
                                $(`#${el?.id}`).prop('checked', true);
                                $(`#${el?.id}_lbl_`).removeClass('sno');
                            } else if (hideShowRadioOptions.includes(fieldId)) {
                                $(`#${el?.id}_lbl_`).addClass('sno');
                            }
                            ApzCOB.addDisableToInput(el?.id);
                        })
                    } else {
                        if (field.fieldId === 'roi') fieldData = fieldData + '%'
                        $(`#${inputSelectorID}`).val(fieldData);
                        if (amtFields.includes(field.fieldId)) {
                            $(`#${inputSelectorID}`).val(ApzCOB.formatIndianRupees(fieldData));
                        }
                        if ($(`#${inputSelectorID}`).parent().hasClass('ett-slct')) {
                            $(`#${inputSelectorID}`).val(fieldData).change();
                            if (apz.isNull(fieldData)) {
                                $(`#${inputSelectorID}`).val(PleaseSelect);
                            }
                        }
                    }
                    if (!apz.isNull(calendarbtnId)) {
                        ApzCOB.addDisableToInput(calendarbtnId); //disable calendar icon
                        $("#" + calendarbtnId).addClass("sno");
                        if (!ddMMYYYYRegex.test(fieldData)) {
                            let formattedDate = ApzCOB.convertDateFormat(fieldData, 'dd/mm/yyyy');
                            $(`#${inputSelectorID}`).val(formattedDate);
                        }
                    }
                    if (!apz.isNull(dropDownArrowId)) {
                        $("#" + dropDownArrowId).addClass("sno")
                    }
                    if ($(`${fieldSelector} .ett-inpt`).length) {
                        $(`#${inputSelectorID}`).attr('placeholder', `Enter ${field.label.toLowerCase()}`);
                    }
                }
                if (editFlag) {
                    ApzCOB.removeDisableToInput(inputSelectorID);
                }
                $(labelSelector).text(field.label);
                if (!apz.isNull(pthis)) {
                    $(pthis).parent().find('button').removeClass('active');
                    $(pthis).addClass('active');
                }
                return inputSelectorID;
            }
        });
        const queryRow = `RPC__${RPC_CURRENT_STAGE}__queriesRow`;
        $(`#${queryRow}`).html('');
        window.stageQueries = ApzCOB.paintingQuery();
        window.pushbackQuery = ApzCOB.chekPushbackQueries();
        if (stageQueries.length > 0 || pushbackQuery.length > 0) {
            ApzCOB.launchSubScreen("RPC_Query", queryRow, "");
        }
        if (RPC_CURRENT_STAGE_NO === 1) {
            let DOB = $('#RPC__PrimaryKycRPC__dobInput').val();
            $('#RPC__PrimaryKycRPC__ageInput').val(ApzCOB.getAge(DOB));
            apz.app.PrimaryKycRPC.fetchCustomerPhoto();
            apz.app.PrimaryKycRPC.updatedKycStatus();
            apz.app.PrimaryKycRPC.setDropdowvalues();
            //added to call setDropdowvalues function set dropdown values of Relationship
            if (custType === "Applicant") {
                $("#RPC__PrimaryKycRPC__relationShipWithApplicant").addClass("sno");
            }
        } else if (RPC_CURRENT_STAGE_NO === 2) { } else if (RPC_CURRENT_STAGE_NO === 3) {
            apz.app.onShown_RelationshipProofRPC();
        } else if (RPC_CURRENT_STAGE_NO === 6) {
            apz.app.BusinessPhotoRPC.configFieldsBasedOnConditions();
        } else if (RPC_CURRENT_STAGE_NO === 7) {
            apz.app.BusinessAddressProofRPC.configFieldsBasedOnConditions();
        } else if (RPC_CURRENT_STAGE_NO === 8) {
            ApzCOB.loadBankAccountProofRPCEmpty();
        } else if (RPC_CURRENT_STAGE_NO === 9) {
            let nomineeDOB = $('#RPC__OtherInformationRPC__nomineeDobInput').val();
            $('#RPC__OtherInformationRPC__ageInput').val(ApzCOB.getAge(nomineeDOB));
            apz.app.OtherInformationRPC.removeLoanDetails();
            ApzCOB.insDataHandling(scrid, custType);
        }
        if (RPC_CB_REHIT_STAGES.includes(RPC_CURRENT_STAGE_NO)) {
            ApzCOB.upateCbStatusRpc();
        }
        let editedFields = ApzCOB.getStageEditedFields();
        ApzCOB.updateEditedTags(editedFields);
        ApzCOB.toggleRpcEditButton();
        pcount = 0;
        rpcCompareLeftIndex = 0;
        rpcCompareRightIndex = 0;
        ApzCOB.rpcDocsFetch();
        ApzCOB.checkRpcPushbackEditable();
        if (RPC_CURRENT_STAGE_NO === 8) {
            window.kmAccverified = ApzCOB.getPayloadDatafromWrapper("accntVerified", "Applicant", "bankDetailsWrapperList");
            if (gApzCOB.selectedRole == 'RPC_Checker') {
                IS_ACCOUNTNUMBER_EDITED = inSessionStore?.rpcStatDetails?.some(item => item?.stageID === 8 && item?.editedFields?.some(field => ["reEnterAccountNumber", "accountNumber"].includes(field)));
            }
            if ($(`#RPC__${RPC_CURRENT_STAGE}__editBankDetailsInput_option_2`).is(":checked")) {
                if (kmAccverified == 'Verified') {
                    $(`#RPC__${RPC_CURRENT_STAGE}__rpcaccountVerified`).removeClass("sno");
                    $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).removeClass('sno');
                    $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('suc');
                } else if (!apz.isNull(kmAccverified)) {
                    $(`#RPC__${RPC_CURRENT_STAGE}__rpcinvaildAccount`).removeClass("sno");
                    $(`#RPC__${RPC_CURRENT_STAGE}__invalidAcc`).removeClass('sno');
                    $(`#RPC__${RPC_CURRENT_STAGE}__invalidAcc`).addClass('failed');
                }
            }
            if ($(`#RPC__${RPC_CURRENT_STAGE}__editBankDetailsInput_option_1`).is(":checked")) {
                if (IS_ACCOUNTNUMBER_EDITED) {
                    if (!apz.isNull($(`#RPC__${RPC_CURRENT_STAGE}__accountNumberInput`).val()) && kmAccverified == 'Verified') {
                        window.rpcaccisVerified = true;
                        window.isrpcEditAcccancel = false;
                    } else {
                        window.rpcaccisVerified = false;
                        window.isrpcEditAcccancel = true;
                    }
                    if (rpcaccisVerified) {
                        $(`#RPC__${RPC_CURRENT_STAGE}__rpcaccountVerified`).removeClass("sno");
                        $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).removeClass('sno');
                        $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('suc');
                    } else if (!apz.isNull(rpcaccisVerified)) {
                        $(`#RPC__${RPC_CURRENT_STAGE}__rpcaccountVerified`).addClass("sno");
                        $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('sno');
                        $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).removeClass('suc');
                    }
                }
            }
            if ($(`#RPC__BankAccountProofRPC__editBankDetailsInput_option_2`).is(":checked") && $(`.fieldEditedTag`).is(':visible')) {
                if (isAccdtlsedit) {
                    $(`#RPC__${RPC_CURRENT_STAGE}__pennyCheckBtnForm`).removeClass('sno');
                    ApzCOB.removeDisableToInput('RPC__BankAccountProofRPC__pennyCheckBtnId');
                    $(`#RPC__${RPC_CURRENT_STAGE}__statusform`).addClass('sno');
                    $(`#RPC__${RPC_CURRENT_STAGE}__statusDataform`).addClass('sno');
                    $(`#RPC__${RPC_CURRENT_STAGE}__exceptionForm`).addClass('sno');
                    return;
                }
                let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
                window.checkedAccount = inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload
                ApzCOB.getPennyCheckData();
                ApzCOB.addDisableToInput(`RPC__${RPC_CURRENT_STAGE}__reEnterAccountNumberInput`);
                if ($(`.fieldEditedTag`).is(':visible')) {
                    $(`#${bankScrnId}pennyCheckBtnForm`).removeClass('sno');
                    ApzCOB.removeDisableToInput('RPC__BankAccountProofRPC__pennyCheckBtnId');
                    if (checkedAccount?.pennyCheckStatus === '' || typeof checkedAccount?.pennyCheckStatus === 'undefined') {
                        return;
                    }
                } else {
                    ['bankName', 'branchName', 'accountName', 'ifsc', 'accountNumber', 'reEnterAccountNumber'].forEach(el => {
                        $(`#${bankScrnId + el}Input`).val('');
                    });
                    $(`#${bankScrnId}accountTypeInput`).val(PleaseSelect).change();
                    return;
                }
                if (exceptionDoc.length > 0) {
                    $(`#${bankScrnId}pennyCheckBtnForm, #${bankScrnId}statusform,  #${bankScrnId}exceptionForm, #${bankScrnId}exceptionMsg`).removeClass('sno');
                    $(`#RPC__${RPC_CURRENT_STAGE}__statusform`).addClass('sno');
                    $(`#${bankScrnId}statustext`).attr('class', 'ett-para pri fs14 penny-failed');
                    $(`#RPC__BankAccountProofRPC__statustext_txtcnt`).text('Penny Check Response: Fail');
                    $(`#${bankScrnId}exceptionText`).attr('class', 'ett-para pri fs14 suc');
                    ApzCOB.addDisableToInput('RPC__BankAccountProofRPC__pennyCheckBtnId');
                    ApzCOB.addDisableToInput(`RPC__${RPC_CURRENT_STAGE}__raiseExceptionBtn`);
                    // ApzCOB.removeDisableToInput('RPC__RPCFooter__Acceptnext');
                    pennyApprovalUpload = true;
                    $('.rpcEditBtn').removeClass('sno');
                } else if (pennyStatus) {
                    ApzCOB.handlePennyCheckPass();
                } else {
                    ApzCOB.handlePennyCheckFail();
                }
                $(`#RPC__BankAccountProofRPC__reEnterAccountNumber`).addClass('sno');
            }
        }
    },
    upateCbStatusRpc: function () {
        let applicantCBdata = inSessionStore?.cibilDetailsWrapperList?.find(cibil => Number(cibil?.cibilDetails?.custDtlId) === Number(gApzCOB
            .userDetails.custDtlId));
        let coApplicantCBdata = inSessionStore?.cibilDetailsWrapperList?.find(cibil => Number(cibil?.cibilDetails?.custDtlId) === Number(
            gApzCOB.userDetails.CoApplicantCustomerId));
        if (!apz.isObjectEmpty(applicantCBdata)) {
            APPLICANT_CIBIL_STATUS = applicantCBdata?.cibilDetails?.cbStatus;
        }
        if (!apz.isObjectEmpty(coApplicantCBdata)) {
            CO_APPLICANT_CIBIL_STATUS = coApplicantCBdata?.cibilDetails?.cbStatus;
        }
    },
    launchRpcCommonSection: function () {
        window.custType = 'Applicant';
        editFlag = false;
        const rpcDocumentCol = `RPC__RpcStageScreen__documentSection`;
        if (RPC_CURRENT_STAGE === 'RpcStageScreen') {
            window.RPC_CURRENT_STAGE = 'PrimaryKycRPC';
            ApzCOB.launchSubScreen("RPCSidebar", sidebarRow, "");
            ApzCOB.launchSubScreen("PrimaryKycRPC", mainSec, "");
        } else {
            if (RPC_CURRENT_STAGE_NO === 6 || RPC_CURRENT_STAGE_NO === 7) {
                ApzCOB.launchSubScreen("RPCSidebar", sidebarRow, "");
            }
            const headerRow = `RPC__${RPC_CURRENT_STAGE}__gr_row_1`;
            ApzCOB.launchSubScreen("RpcApplicationHeader", headerRow, "");
            if (isRpcDashboardPreview || isRpcPreviewEnabled) {
                if (!isRpcPreview) {
                    $(`#${rpcDocumentCol}`).addClass('sno');
                    $(`#${mainSec}`).addClass('revConfrmDiv');
                } else {
                    $("#RPC__ReviewConfirm__gr_row_1_apz_2").removeClass("sno ssp");
                }
            } else {
                ApzCOB.launchSubScreen("RPCDocumentSection", rpcDocumentCol, "");
                ApzCOB.launchSubScreen("RPCFooter", rpcFooterRow, "");
                if (RPC_CURRENT_STAGE === 'ReviewConfirm') {
                    if (!isRpcPreview) {
                        $(`#${rpcDocumentCol}`).addClass('sno');
                        $(`#${mainSec}`).addClass('revConfrmDiv');
                    } else {
                        $("#RPC__ReviewConfirm__gr_row_1_apz_2").removeClass("sno ssp");
                    }
                } else {
                    $(`#${rpcDocumentCol}`).removeClass('sno');
                    $(`#${mainSec}`).removeClass('revConfrmDiv');
                }
                let subMenu = [];
                if (!apz.isObjectEmpty(RPC_STAGES)) {
                    let stageData = Object.values(RPC_STAGES).find(stage => stage.id === RPC_CURRENT_STAGE_NO);
                    if (!apz.isObjectEmpty(stageData)) {
                        subMenu = stageData.subMenu;
                    }
                }
                if (subMenu.length > 0) {
                    let selectElementID = `RPC__${RPC_CURRENT_STAGE}__rpcStageSubmenuItem_0`;
                    let parentDiv = $(`#${selectElementID}`).parent();
                    subMenu.forEach((stage, index) => {
                        let currentIndex = index + 1;
                        if ([6, 7].includes(RPC_CURRENT_STAGE_NO) && subMenu.length == 1) {
                            currentIndex = ApzCOB.setcustTypeforOccuStages(subMenu[0]);
                        }
                        let newId = ApzCOB.cloneDashboardDivs(selectElementID, parentDiv, currentIndex);
                        $(`#${newId} span`).text(stage);
                        $(`#${newId}`).attr("onclick", `ApzCOB.paintRpcFields(this,${currentIndex})`);
                        if (currentIndex === 1) {
                            $(`#${newId}`).addClass("active");
                        }
                        $(`#${newId}`).removeClass("sno");
                    })
                } else {
                    $('.rpcStageSubmenuRow').addClass('sno');
                }
                ApzCOB.addActiveToCurrentStage();
                ApzCOB.updateSideMenuStatusTags();
            }
            if (!isRpcDashboardPreview) {
                $("body").addClass("unati");
                $("body").addClass("mak-chk");
            }
            apz.childScr = RPC_CURRENT_STAGE;
            $('.rpcEditBtn label.ett-labl').attr('onClick', 'ApzCOB.editFunction(this)');
        }
    },
    handleCancelButtonClick: function () {
        let currentCustType = custType === 'Applicant' ? 1 : 2;
        editFlag = false;
        let AccNO = $(`#RPC__${RPC_CURRENT_STAGE}__accountNumberInput`).val();
        $('.rpcEditBtn').removeClass('sno')
        ApzCOB.paintRpcFields(this, currentCustType)
        ApzCOB.disableRpcTabs(false);
        if (RPC_CURRENT_STAGE_NO === 8) {
            ApzCOB.loadBankAccountProofRPCEmpty();
            if ($(`#RPC__BankAccountProofRPC__editBankDetailsInput_option_2`).is(":checked") && $(`.fieldEditedTag`).is(':visible')) {
                $(`#RPC__${RPC_CURRENT_STAGE}__pennyCheckBtnForm`).removeClass('sno');
            }
        }
        ApzCOB.launchSubScreen("RPCFooter", rpcFooterRow, "");
        let AccNOdisableCheck = $(`#RPC__${RPC_CURRENT_STAGE}__accountNumberInput`).hasClass("disabled");
        if ($(`#RPC__${RPC_CURRENT_STAGE}__rpcverifyAccount`).is(':visible')) {
            $(`#RPC__${RPC_CURRENT_STAGE}__rpcverifyAccount`).addClass('sno');
        }
        if ($(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc_txtcnt`).is(':visible') && isrpcEditAcccancel) {
            $(`#RPC__${RPC_CURRENT_STAGE}__rpcaccountVerified`).addClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).removeClass('suc');
        } else {
            $(`#RPC__${RPC_CURRENT_STAGE}__rpcaccountVerified`).removeClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).removeClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('suc');
        }
        if ($(`#RPC__${RPC_CURRENT_STAGE}__invalidAcc_txtcnt`).is(':visible')) {
            $(`#RPC__${RPC_CURRENT_STAGE}__rpcinvaildAccount`).addClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__invalidAcc`).addClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__invalidAcc`).removeClass('failed');
        }
        if ($(`#RPC__${RPC_CURRENT_STAGE}__editBankDetailsInput_option_1`).is(":checked")) {
            window.rpcaccntVerified = inSessionStore?.bankDetailsWrapperList[0]?.bankDetails?.payload?.rpcaccntVerified
            if (rpcaccntVerified == "Verified") {
                $(`#RPC__${RPC_CURRENT_STAGE}__rpcaccountVerified`).removeClass("sno");
                $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).removeClass('sno');
                $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('suc');
            } else if (!apz.isNull(rpcaccntVerified) || (apz.isNull(AccNO) && AccNOdisableCheck)) {
                $(`#RPC__${RPC_CURRENT_STAGE}__rpcaccountVerified`).addClass("sno");
                $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('sno');
                $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).removeClass('suc');
            }
        }
    },
    editFunction: function (pthis) {
        editFlag = true;
        window.validPinCode = false;
        window.validmobNum = false;
        currentTypeFields.forEach(field => {
            if (!apz.isNull(field.fieldAttr, field.label)) {
                const [visibilityAttr, mandatoryAttr, editAttribute] = field.fieldAttr.split("~");
                const containerSelector = `#RPC__${RPC_CURRENT_STAGE}__${field.fieldId}`;
                const labelElement = $(containerSelector).find('.ett-labl');
                if (labelElement.length > 0) {
                    if (mandatoryAttr?.toUpperCase() === "M" && editFlag === true) {
                        labelElement.addClass("req");
                    } else {
                        labelElement.removeClass("req");
                    }
                }
            }
        });
        $("#RPC__RPCFooter__sc_row_1").addClass("sno");
        $("#RPC__RPCFooter__sc_row_2").removeClass("sno");
        currentTypeFields.forEach(({
            fieldAttr,
            label,
            fieldId
        }) => {
            if (!apz.isNull(fieldAttr) && !apz.isNull(label)) {
                let calendarbtnId = '';
                let [visibilityAttr, mandatoryAttr, editAttribute] = fieldAttr.split('~');
                if (ApplicationType !== 'RENEWAL' && fieldId === 'isNewCustomer') {
                    visibilityAttr = 'N';
                    mandatoryAttr = 'N';
                }
                const fieldSelector = `#RPC__${RPC_CURRENT_STAGE}__${fieldId}`;
                const lfieldId = fieldId;
                const inputSelectorID = $(`${fieldSelector} .ett-inpt`).attr("id") || $(`${fieldSelector} .sub-elt`).attr("id") || $(
                    `${fieldSelector} .ett-rdio`).attr("id");
                const isEditable = editAttribute?.toUpperCase() === 'E';
                isEditable ? ApzCOB.removeDisableToInput(inputSelectorID) : ApzCOB.addDisableToInput(inputSelectorID);
                if ($(`#${inputSelectorID}`).attr('apztype') === 'radiogroup') {
                    document.querySelectorAll(`#${inputSelectorID} input`)?.forEach(el => {
                        isEditable ? ApzCOB.removeDisableToInput(el?.id) : ApzCOB.addDisableToInput(el?.id)
                        if (hideShowRadioOptions.includes(lfieldId) && isEditable) {
                            $(`#${el?.id}_lbl_`).removeClass('sno');
                        }
                    })
                }
                if ($(`${fieldSelector} .ett-inpt`).length) {
                    const calendarbtnId = ($(fieldSelector).find('.ett-bttn')?.length > 0) ? $(fieldSelector).find('.ett-bttn').attr(
                        'id') : '';
                    if (!apz.isNull(calendarbtnId)) {
                        isEditable ? ApzCOB.removeDisableToInput(calendarbtnId) : ApzCOB.addDisableToInput(calendarbtnId);
                        $("#" + calendarbtnId).removeClass("sno")
                    }
                }
                if ($(`${fieldSelector} .etb-slct`).length) {
                    ['maritalStatus'].includes(lfieldId) ? $(`${fieldSelector}Input`).change() : ApzCOB.dropDownOnChange($(
                        `${fieldSelector}Input`)[0]);
                    const dropDownArrowId = ($(fieldSelector).find('.sub-elt1')?.length > 0) ? $(fieldSelector).find('.sub-elt1')
                        .attr('id') : '';
                    if (!apz.isNull(dropDownArrowId)) {
                        $("#" + dropDownArrowId).removeClass("sno")
                    }
                }
                if (['fathersName', 'spouseName'].includes(lfieldId)) {
                    $(`#RPC__${RPC_CURRENT_STAGE}__maritalStatusInput`).change()
                }
            }
        });
        ApzCOB.disableRpcTabs(true);
        $(pthis).parents('.rpcEditBtn').addClass('sno');
        if (RPC_CURRENT_STAGE_NO === 1) {
            let isApplicant = custType === 'Applicant';
            let isPrimaryKycNull = isApplicant ? apz.isNull(PRIMARY_KYC_VERIFICATION) : apz.isNull(CO_APPLICANT_PRIMARY_KYC_VERIFICATION);
            let kycFlag = isApplicant ? !PRIMARY_KYC_VERIFICATION : !CO_APPLICANT_PRIMARY_KYC_VERIFICATION;
            if (kycFlag && !isPrimaryKycNull) {
                $('#RPC__PrimaryKycRPC__alternateVoterId label.ett-labl.flb.pri').addClass('req');
            }
        }
        if (RPC_CURRENT_STAGE_NO === 8) {
            ApzCOB.loadBankAccountProofRPCEmpty();
            if ($(`#RPC__RPCFooter__RpcCancelBtn`).is(':visible')) {
                $('.rpcEditBtn').addClass('sno');
                //ApzCOB.addDisableToInput(`${bankScrnId}accountNumberInput`);
            }
            $(`#RPC__${RPC_CURRENT_STAGE}__pennyCheckBtnForm`).addClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__statusform`).addClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__statusDataform`).addClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__exceptionForm`).addClass('sno');
            $(`#RPC__${RPC_CURRENT_STAGE}__rpcverifyAccount`).addClass('sno');
            if (apz.isNull($(`#RPC__${RPC_CURRENT_STAGE}__accountNumberInput`).val())) {
                $(`#RPC__${RPC_CURRENT_STAGE}__invalidAcc`).addClass('sno');
                $(`#RPC__${RPC_CURRENT_STAGE}__verifiedAcc`).addClass('sno');
            }
            $(`#RPC__${RPC_CURRENT_STAGE}__accountNumberInput`).attr('type', 'password');
        }
        $('input.hasDatepicker').each(function (index, element) {
            $(element).prop('disabled', true);
        })
        if (RPC_CURRENT_STAGE_NO === 7) {
            if ($(`#${bussAddrPrfScrId}addressSameAsInput_option_Present`).is(":checked")) {
                addressradioCheck = 'Present'
                apz.app.BusinessAddressProofRPC.fetchAddressData(addressradioCheck)
                window.fields = [`${bussAddrPrfScrId}addressLine1Input`, `${bussAddrPrfScrId}addressLine2Input`, `${bussAddrPrfScrId}addressLine3Input`, `${bussAddrPrfScrId}landMarkInput`, `${bussAddrPrfScrId}pinCodeInput`
                ];
                fields.forEach(id => ApzCOB.addDisableToInput(id));
                ApzCOB.addDisableToInput(`${bussAddrPrfScrId}businessAddressProofInput_ext`);
            }
        }
    },
    disableRpcTabs: function (status) {
        $('.rpcSubMenu').prop('disabled', status);
    },
    getPayloadData: function (fieldId, custType, screenName) {
        if (custType === "Co-App") {
            window.coustmerTypValue = inSessionStore.customerDetailsList[0]?.customerType === "Applicant" ? 1 : 2;
        } else {
            window.coustmerTypValue = inSessionStore.customerDetailsList[1]?.customerType === "Applicant" ? 1 : 2;
        }
        let currentStageId = "";
        if (screenName) {
            let stage = Object.values(RPC_STAGES).find(stage => stage.screenName === screenName);
            currentStageId = stage ? stage.id : "";
        } else {
            currentStageId = !apz.isObjectEmpty(RPC_STAGES) ? RPC_STAGES[RPC_CURRENT_STAGE].id : "";
        }
        let requestWrapper = RPC_SCREEN_WRAPPER.filter(req => req.stage_id === currentStageId);
        let response = "";
        if (requestWrapper.length > 0) {
            requestWrapper.forEach(req => {
                if (req.stage_wrapper.length > 0) {
                    req.stage_wrapper.forEach(wrapper => {
                        if (apz.isNull(inSessionStore) || apz.isObjectEmpty(inSessionStore)) {
                            return;
                        }
                        let custDetailID = ApzCOB.getCustDetailID(custType);
                        switch (wrapper) {
                            case "customerDetailsList":
                                window.applicationData = [];
                                window.applicationData = inSessionStore[wrapper]?.filter(cust => cust.custDtlId ===
                                    custDetailID) || [];
                                for (let info of applicationData) {
                                    if (info.hasOwnProperty(fieldId)) {
                                        response = info[fieldId];
                                        break;
                                    }
                                    if (!apz.isNull(response)) break;
                                    let payloadData = {};
                                    if (typeof (info.payload) === 'object') {
                                        payloadData = info.payload;
                                    } else {
                                        payloadData = JSON.parse(info.payload);
                                    }
                                    if (payloadData && payloadData.hasOwnProperty(fieldId)) {
                                        if (payloadData[fieldId] === "NULL" || payloadData[fieldId] === null ||
                                            typeof payloadData[fieldId] === "undefined") {
                                            payloadData[fieldId] = "";
                                        }
                                        response = payloadData[fieldId];
                                        break;
                                    }
                                }
                                break;
                            case "addressDetailsWrapperList":
                                const addressData = inSessionStore[wrapper]?.[0]?.addressDetailsList.filter(el => el
                                    .custDtlId === custDetailID) || [];
                                for (let info of addressData) {
                                    if (info.hasOwnProperty('addressType')) {
                                        if (info.addressType?.toLowerCase() === addrType.toLowerCase() && info?.payload) {
                                            const parseddata = info.payload?.addressList || [];
                                            for (let addrlst of parseddata) {
                                                if (addrlst?.hasOwnProperty('addressType')) {
                                                    if (addrlst['addressType']?.toLowerCase() === subAddrType.toLowerCase()) {
                                                        if (addrlst.hasOwnProperty(fieldId)) {
                                                            response = addrlst[fieldId];
                                                            break;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                                break;
                            case "bankDetailsWrapperList":
                                const bankData = inSessionStore[wrapper]?.filter(cust => cust.bankDetails.custDtlId ===
                                    custDetailID) || [];
                                const bankparseddata = bankData[0].bankDetails.payload;
                                if (bankparseddata?.hasOwnProperty(fieldId)) {
                                    response = bankparseddata[fieldId]
                                    break;
                                }
                                break;
                            case "occupationDetailsWrapperList":
                                const occData = inSessionStore[wrapper]?.filter(ldata => ldata.occupationDetails.custDtlId ===
                                    custDetailID) || [];
                                const occparseddata = occData[0]?.occupationDetails?.payload;
                                if (occparseddata?.hasOwnProperty(fieldId)) {
                                    response = occparseddata[fieldId]
                                    break;
                                }
                                break;
                            case "applicationMaster":
                                if (custType === 'Applicant') {
                                    const customerDetail = inSessionStore[wrapper];
                                    if (customerDetail.hasOwnProperty(fieldId)) {
                                        response = customerDetail[fieldId];
                                        break;
                                    }
                                }
                                break;
                            case "insuranceDetailsWrapperList":
                                const insureDetail = inSessionStore.insuranceDetailsWrapperList.filter(el => el
                                    .insuranceDetails.custDtlId === custDetailID) || [];
                                const insureParsedData = insureDetail[0].insuranceDetails.payload;
                                if (insureParsedData?.hasOwnProperty(fieldId)) {
                                    response = insureParsedData[fieldId];
                                    break;
                                }
                                break;
                            case "cibilDetailsWrapperList":
                                const cibilDetail = inSessionStore.cibilDetailsWrapperList.filter(el => el.cibilDetails
                                    .custDtlId === custDetailID) || [];
                                const cibilParsedData = cibilDetail?.[0]?.cibilDetails?.payload;
                                if (cibilParsedData?.hasOwnProperty(fieldId)) {
                                    response = cibilParsedData[fieldId];
                                    break;
                                }
                                break;
                            case "loanDetails":
                                const loanData = inSessionStore[wrapper] || [];
                                if (loanData?.hasOwnProperty(fieldId)) {
                                    response = loanData[fieldId];
                                    break;
                                } else if (loanData?.payload) {
                                    const parsedPayload = loanData.payload;
                                    if (parsedPayload?.hasOwnProperty(fieldId)) {
                                        response = parsedPayload[fieldId];
                                        break;
                                    }
                                }
                                break;
                            default:
                                break;
                        }
                    });
                }
            });
        }
        return response;
    },
    getCustDetailID: function (customerType) {
        const custDetailID = (inSessionStore.customerDetailsList || []).find(cust => cust.customerType === customerType)?.custDtlId || '';
        return custDetailID;
    },
    isResidenceSameAsKyc: function () {
        let isSame = false;
        let applicantaddressProof = inSessionStore?.addressDetailsWrapperList?.[0]?.addressDetailsList.find(address => address.custDtlId ===
            gApzCOB.userDetails.custDtlId && address.addressType.toLocaleLowerCase() === "personal");
        if (!apz.isObjectEmpty(applicantaddressProof)) {
            let addressList = applicantaddressProof.payload.addressList;
            if (addressList.length > 0) {
                let presentAddress = addressList.find(addr => addr.addressType.toLocaleLowerCase() === "present");
                if (!apz.isObjectEmpty(applicantaddressProof)) {
                    let currentProof = presentAddress.currentAddressProof === "As per KYC document" ? "As per Voter ID" : presentAddress
                        .currentAddressProof;
                    if (currentProof === "As per Voter ID" || currentProof === "As per Applicant Primary KYC document") {
                        isSame = true;
                    }
                }
            }
        }
        return isSame;
    },
    getDocumentName: function (lstageId) {
        const docTypeMap = {
            4: "currentAddressProof",
            6: occBasedDocType[currApplOccupation],
            7: occBasedDocType[currApplOccupation]
        };
        let lstageName = '';
        if (lstageId) {
            lstageName = Object.values(RPC_STAGES).filter(stage => stage.id === lstageId)?.[0]?.screenName;
        }
        if ((lstageId ?? RPC_CURRENT_STAGE_NO) === 7) lstageName = "BusinessPhotoRPC";
        if ([4, 5].includes(lstageId ?? RPC_CURRENT_STAGE_NO)) {
            addrType = 'Personal'; subAddrType = 'Present';
        }
        return ApzCOB.getPayloadData(docTypeMap[lstageId ?? RPC_CURRENT_STAGE_NO], custType, lstageName);
    },
    rpcDocsFetch: function () {
        window.docSecScrId = 'RPC__RPCDocumentSection__';
        let docCustType = window.custType;
        if ([3, 4, 5].includes(RPC_CURRENT_STAGE_NO)) docCustType = "Applicant";
        let applicationData = [];
        window.stageDocuments = [];
        let coAppdocuments = [];
        let stageDetails = JSON.parse(JSON.stringify(RPC_SCREEN_WRAPPER.find(stage => stage.stage_id === RPC_CURRENT_STAGE_NO)));
        let stageDocType = stageDetails?.docTypes;
        let applnDocData = [];
        let kycdocuments = [];
        if (RPC_CURRENT_STAGE === 'ResidenceAddressProofRPC' && !stageDocType.includes("PRIMARY_KYC")) {
            addrType = 'Personal'; subAddrType = 'Present';
            let residenceAsKYC = ApzCOB.getPayloadData('currentAddressProof', 'Applicant');
            if (ApzCOB.isResidenceSameAsKyc() || residenceAsKYC === "As per Co-Applicant Primary KYC document") {
                let kycCustId = ApzCOB.getCustDetailID('Applicant');
                if (residenceAsKYC === "As per Co-Applicant Primary KYC document") kycCustId = ApzCOB.getCustDetailID('Co-App');
                applnDocData = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList?.filter(cust => cust.custDtlId ===
                    kycCustId) || [];
                if (Array.isArray(applnDocData) || applnDocData.length > 0) {
                    kycdocuments = applnDocData.filter(appDoc => {
                        return appDoc.payload.documentType === "PRIMARY_KYC" && appDoc.payload.isAdiDoc !== 'Y';
                    })
                    window.stageDocuments = [...stageDocuments, ...kycdocuments];
                }
            }
        } else if (RPC_CURRENT_STAGE === 'BusinessAddressProofRPC' && !stageDocType.includes("PRIMARY_KYC")) {
            let bussAddrProofAsKYC = ApzCOB.getPayloadData('businessAddressProof', custType);
            addrType = 'Occupation'; subAddrType = 'Office';
            let bussAddrTag = ApzCOB.getPayloadDatafromWrapper('addressSameAs', custType, 'addressDetailsWrapperList') === "Present";
            let kycCustId = ApzCOB.getCustDetailID(custType);
            applnDocData = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList?.filter(cust => cust.custDtlId === kycCustId) || [];
            if (Array.isArray(applnDocData) || applnDocData.length > 0) {
                if (bussAddrProofAsKYC === "As per Voter ID") {
                    kycdocuments = applnDocData.filter(appDoc => {
                        return appDoc.payload.documentType === "PRIMARY_KYC" && appDoc.payload.isAdiDoc !== 'Y';
                    })
                    window.stageDocuments = [...stageDocuments, ...kycdocuments];
                } else if (bussAddrTag) {
                    addrProofdocuments = applnDocData.filter(appDoc => {
                        return appDoc.payload.documentType === "ADDRESS_PROOF" && appDoc.payload.isAdiDoc !== 'Y';
                    })
                    window.stageDocuments = [...stageDocuments, ...addrProofdocuments];
                }
            }
        }
        let custDetailID = ApzCOB.getCustDetailID(docCustType);
        applicationData = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList?.filter(cust => cust.custDtlId === custDetailID) || [];
        $('#scr__RPC__RPCDocumentSection__main').removeClass('sno');
        if (!Array.isArray(applicationData) || applicationData.length === 0) {
            //"documentDetails is not an array or is empty"
        } else {
            if (RPC_CURRENT_STAGE_NO !== 9 && stageDocType.length > 0) {
                let occTag = ApzCOB.getPayloadDatafromWrapper('occupationTag', 'Co-App', 'occupationDetailsWrapperList');
                if (RPC_CURRENT_STAGE === 'BusinessPhotoRPC' && occTag?.toUpperCase() === 'YES') {
                    applicationData = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList || [];
                }
                let panStatusVal = ApzCOB.getPayloadDatafromWrapper('panNumberStatus', custType, 'customerDetailsList') === 'Verified';
                if (RPC_CURRENT_STAGE_NO === 1 && panStatusVal && !stageDocType.includes("PAN_NUMBER_PHOTO")) {
                    stageDocType.push('PAN_NUMBER_PHOTO');
                }
                stageDocType?.map(docType => {
                    let documents = [];
                    documents = applicationData.filter(appDoc => {
                        return appDoc.payload.documentType === docType && appDoc.payload.isAdiDoc !== 'Y';
                    })
                    addrType = 'Occupation'; subAddrType = 'Office';
                    bussAddrTag = ApzCOB.getPayloadDatafromWrapper('addressSameAs', custType, 'addressDetailsWrapperList') === "Present";
                    if (RPC_CURRENT_STAGE === 'BusinessAddressProofRPC' && bussAddrTag) {
                        documents = [];
                    }
                    window.stageDocuments = [...stageDocuments, ...documents];
                })
            } else {
                if (RPC_CURRENT_STAGE_NO === 9) {
                    let documents = [];
                    documents = applicationData.filter(appDoc => {
                        return appDoc.payload.isAdiDoc === 'Y';
                    })
                    window.stageDocuments = [...documents]
                }
            }
            if (stageDocuments.length > 0) {
                let docDetails = stageDocuments[0].payload;
                let docDispName = ([4, 6, 7].includes(RPC_CURRENT_STAGE_NO)) ? ApzCOB.getDocumentName() : docDetails.documentName;
                docDispName = (RPC_CURRENT_STAGE_NO === 8) ? "Bank Account Proof" : docDispName;
                if (docDetails?.documentName?.includes('Pennyless')) docDispName = 'Exception document';
                if (!isCompare) {
                    $(`#${docSecScrId}docName`).text(`${docDispName}`);
                }
                let fileName = ApzCOB.getFileName(pcount);
                window.ImageLocationDetails = {
                    latitude: docDetails.latitude || "",
                    longitude: docDetails.longitude || "",
                    uploadedTs: docDetails.uploadedTs || "",
                    documentFileName: docDetails.documentFileName || ""
                };
                ApzCOB.downloadFileFromServer(fileName);
            } else {
                $('#scr__RPC__RPCDocumentSection__main').addClass('sno');
            }
        }
    },
    getFileName: function (count, docArray) {
        let documentArray = [];
        if (!apz.isNull(docArray)) {
            documentArray = structuredClone(docArray);
        } else {
            documentArray = structuredClone(stageDocuments);
        }
        let docPayload = documentArray?.[count].payload;
        let fileName = docPayload?.documentFileName;
        let docDispName = '';
        if (docPayload?.documentType === "BUSINESS_PREMISE_PHOTO") {
            docDispName = docPayload.documentName;
        } else {
            docDispName = ([4, 6, 7].includes(RPC_CURRENT_STAGE_NO)) ? ApzCOB.getDocumentName() : docPayload.documentName;
        }
        docDispName = (RPC_CURRENT_STAGE_NO === 8) ? "Bank Account Proof" : docDispName;
        if (RPCDBVerify_STAGES[apz.childScr]?.id == 2) {
            docDispName = (RPCDBVerify_STAGES[apz.childScr].id == 2) ? "Passbook" : docPayload.documentType;
        } else if (RPCDBVerify_STAGES[apz.childScr]?.id == 3 || RPCDBVerify_STAGES[apz.childScr]?.id == 5) {
            docDispName = (RPCDBVerify_STAGES[apz.childScr].id == 3) || (RPCDBVerify_STAGES[apz.childScr]?.id == 5) ? "Udyam status screenshot" : docPayload.documentType;
        }
        if (docPayload?.documentName?.includes('Pennyless')) docDispName = 'Exception document';
        if (!isCompare) {
            $(`#RPC__RPCDocumentSection__docName`).text(`${docDispName}`);
        }
        return fileName;
    },
    downloadFileFromServer: function (fileName, callback, elemId) {
        window.currDocType = fileName?.split('.')?.[1];
        window.base64Id = elemId;
        if (elemId == 'eNach') {
            window.stageDocuments = eNachstageDocuments;
        }
        if (apz.childScr == 'RPCDBUdyamReg' || apz.childScr == 'RPCDBeNach' || apz.childScr == 'RPCDBReviewCnf' || apz.childScr == 'PreviewDBveriification') {
            fileName = stageDocuments?.[pcount]?.payload?.documentFileName;
        }
        let applnId;
        let json = {
            "destinationPath": "",
            // "filePath": (gApzCOB.requestNodes.appId).concat("/").concat(gApzCOB.product).concat("/").concat(applnId),
            "sessionReq": "N" //Y or N
        };
        if (apz.isNull(inSessionStore) || apz.isObjectEmpty(inSessionStore)) {
            return;
        } else {
            applnId = inSessionStore.applicationId;
        }
        json.destinationPath = "docs";
        json.fileName = fileName;
        json.base64 = "Y";
        json.filePath = apz.appId.concat("/").concat("LOAN").concat("/").concat(applnId);
        json.id = "";
        json.callBack = callback ?? ApzCOB.downloadFileFromServerCB;
        apz.startLoader();
        apz.ns.downloadFile(json);
    },
    downloadFileFromServerCB: function (params) {
        window.docSecScrId = 'RPC__RPCDocumentSection__';
        if (!apz.isNull(params.base64)) {
            if (apz.childScr == 'RPCDBUdyamReg' || apz.childScr == 'RPCDBeNach' || apz.childScr == 'RPCDBReviewCnf' || apz.childScr == 'PreviewDBveriification') {
                if (!isCompare) {
                    if (downloadDocflag) {
                        if (apz.childScr == 'RPCDBReviewCnf') {
                            window.docSecScrId = 'RPCDBV__RPCDBReviewCnf__'
                            if (reEnachNavtyp == 'eNext' || reEnachNavtyp == 'efront') {
                                docSecImageId.selector = '#RPCDBV__RPCDBReviewCnf__img'
                            } else {
                                docSecImageId.selector = '#RPCDBV__RPCDBReviewCnf__imgView'
                            }
                        } else if (apz.childScr == 'PreviewDBveriification') {
                            docSecScrId = 'cmnPre__PreviewDBveriification__'
                            if (reEnachNavtyp == 'eNext' || reEnachNavtyp == 'efront') {
                                docSecImageId.selector = '#cmnPre__PreviewDBveriification__img'
                            } else {
                                docSecImageId.selector = '#cmnPre__PreviewDBveriification__imgView'
                            }
                        } else {
                            window.docSecScrId = 'RPCDBV__RPCDBVerify__'
                            docSecImageId.selector = '#RPCDBV__RPCDBVerify__imgView'
                        }
                        if (reEnachNavtyp == 'eNext' || reEnachNavtyp == 'efront') {
                            $(`#${docSecScrId}img`).attr('src', 'data:image/png;base64,' + params.base64);
                            if (pcount === 0) {
                                $(`#${docSecScrId}eFrontImg`).attr('disabled', true);
                            } else {
                                $(`#${docSecScrId}eFrontImg`).attr('disabled', false);
                            }
                            if (pcount >= eNachstageDocuments.length - 1) {
                                $(`#${docSecScrId}eNextImg`).attr('disabled', true);
                            } else {
                                $(`#${docSecScrId}eNextImg`).attr('disabled', false);
                            }
                        } else {
                            $(`#${docSecScrId}imgView`).attr('src', 'data:image/png;base64,' + params.base64);
                            let id = `#${docSecScrId}imgView`;
                            if (Object.keys(window.ImageLocationDetails).length > 0) {
                                apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
                            }
                            if (pcount === 0) {
                                $(`#${docSecScrId}frontView_Img`).attr('disabled', true);
                            } else {
                                $(`#${docSecScrId}frontView_Img`).attr('disabled', false);
                            }
                            if (pcount >= stageDocuments.length - 1) {
                                $(`#${docSecScrId}backView_Img`).attr('disabled', true);
                            } else {
                                $(`#${docSecScrId}backView_Img`).attr('disabled', false);
                            }
                        }
                    }
                    apz.stopLoader();
                }
            }
            if (!isCompare) {
                $('iframe').remove();
                if (currDocType?.toLowerCase() === 'pdf') {
                    const iframe = document.createElement('iframe');
                    Object.assign(iframe, {
                        src: (ApplicationPDFbase64 + params.base64),
                        width: "450",
                        height: "400"
                    });
                    document.getElementById('RPC__RPCDocumentSection__RPC_ImageView_ul').appendChild(iframe);
                    $('#RPC__RpcStageScreen__documentSection .img-tools span').first().addClass('excptnname');
                    $(`#RPC__RPCDocumentSection__RPC_ImageView_li, #RPC__RpcStageScreen__documentSection .tols, #RPC__RpcStageScreen__documentSection .comp`)
                        .addClass('sno');
                } else {
                    $(`#${docSecScrId}RPC_ImageView`).attr('src', 'data:image/png;base64,' + params.base64);
                    let id = `#${docSecScrId}RPC_ImageView`;
                    if (Object.keys(window.ImageLocationDetails).length > 0) {
                        apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
                    }
                    ApzCOB.intializeGuillotine(docSecImageId);
                    $('#RPC__RpcStageScreen__documentSection .img-tools span').first().removeClass('excptnname');
                    $(`#RPC__RPCDocumentSection__RPC_ImageView_li, #RPC__RpcStageScreen__documentSection .tols, #RPC__RpcStageScreen__documentSection .comp`)
                        .removeClass('sno');
                }
                if (pcount === 0) {
                    $(`#${docSecScrId}frontView_Img`).attr('disabled', true);
                } else {
                    $(`#${docSecScrId}frontView_Img`).attr('disabled', false);
                }
                if (pcount >= stageDocuments.length - 1) {
                    $(`#${docSecScrId}backView_Img`).attr('disabled', true);
                } else {
                    $(`#${docSecScrId}backView_Img`).attr('disabled', false);
                }
            } else {
                let imageId = leftImg ? 'APZCBO__BaseScreens__compareLeftImg' : 'APZCBO__BaseScreens__compareRightImg';
                let pictureId = $(`#${imageId}`);
                let prevBtnElem = $(`#${imageId}`).parents('.compareImageSec').find('.cmpareNavigation.prev button');
                let nextBtnElem = $(`#${imageId}`).parents('.compareImageSec').find('.cmpareNavigation.next button');
                let documentsArray = [];
                if (leftImg) {
                    window.countIndex = rpcCompareLeftIndex;
                    documentsArray = structuredClone(stageDocuments);
                } else {
                    window.countIndex = rpcCompareRightIndex;
                    documentsArray = structuredClone(filteredDocumentArray);
                }
                $(`#${imageId}`).attr('src', 'data:image/png;base64,' + params.base64);
                ApzCOB.intializeGuillotine(pictureId);
                if (countIndex === 0) {
                    prevBtnElem.attr('disabled', true)
                } else {
                    prevBtnElem.attr('disabled', false)
                }
                if (countIndex >= documentsArray.length - 1) {
                    nextBtnElem.attr('disabled', true);
                } else {
                    nextBtnElem.attr('disabled', false);
                }
            }
            let docHeaderVal = $(`#${docSecScrId}docName`).text();
            if (docHeaderVal === '' && RPC_CURRENT_STAGE_NO === 1) {
                $(`#${docSecScrId}docName`).text(stageDocuments?.[0]?.payload?.documentName || 'Voter ID');
            }
        } else {
            $(`#${docSecScrId}frontView_Img`).attr('disabled', true);
            $(`#${docSecScrId}backView_Img`).attr('disabled', true);
            ApzCOB.hideLoader();
            ApzCOB.showCommonErrRPCModal(params.errorMessage);
        }
        apz.stopLoader();
    },
    leftImagePaintCB: function (params) {
        apz.stopLoader();
        if (!apz.isNull(params.base64)) {
            window.leftImg = true;
            $(`#APZCBO__BaseScreens__compareLeftImg`).attr('src', 'data:image/png;base64,' + params.base64);
            let id = `#APZCBO__BaseScreens__compareLeftImg`;
            if (Object.keys(window.ImageLocationDetails).length > 0) {
                apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
            };
            let pictureId = $(`#APZCBO__BaseScreens__compareLeftImg`);
            ApzCOB.intializeGuillotine(pictureId);
            if (pcount === 0) {
                $(`#APZCBO__BaseScreens__el_btn_68`).attr('disabled', true)
            } else {
                $(`#APZCBO__BaseScreens__el_btn_68`).attr('disabled', false)
            }
            if (pcount >= stageDocuments.length - 1) {
                $(`#APZCBO__BaseScreens__el_btn_69`).attr('disabled', true);
            } else {
                $(`#APZCBO__BaseScreens__el_btn_69`).attr('disabled', false);
            }
            let leftImgDocName = document.querySelector("#RPC__RPCDocumentSection__docName").innerText;
            $(`#APZCBO__BaseScreens__compareLeftDocName`).text(`${leftImgDocName}`);
            let filteredFileName = ApzCOB.filteredDocument();
            if (filteredFileName && leftImg) {
                ApzCOB.downloadFileFromServer(filteredFileName, ApzCOB.rightImagePaintCB);
            } else {
                ApzCOB.showCommonErrRPCModal("File not found");
            }
        } else {
            window.leftImg = false;
            ApzCOB.showCommonErrRPCModal("File not found");
        }
    },
    rightImagePaintCB: function (params) {
        apz.stopLoader();
        if (!apz.isNull(params.base64)) {
            window.rightImg = true;
            $(`#APZCBO__BaseScreens__compareRightImg`).attr('src', 'data:image/png;base64,' + params.base64);
            let id = `#APZCBO__BaseScreens__compareRightImg`;
            if (Object.keys(window.ImageLocationDetails).length > 0) {
                apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
            }
            let pictureId = $(`#APZCBO__BaseScreens__compareRightImg`);
            ApzCOB.intializeGuillotine(pictureId);
            if (pcount === 0) {
                $(`#APZCBO__BaseScreens__el_btn_70`).attr('disabled', true)
            } else {
                $(`#APZCBO__BaseScreens__el_btn_70`).attr('disabled', false)
            }
            if (pcount >= filteredDocumentArray.length - 1) {
                $(`#APZCBO__BaseScreens__el_btn_71`).attr('disabled', true);
            } else {
                $(`#APZCBO__BaseScreens__el_btn_71`).attr('disabled', false);
            }
            let RightImgDocName = filteredDocumentArray[0].payload.documentName;
            $(`#APZCBO__BaseScreens__compareRightDocName`).text(`${RightImgDocName}`);
            if (leftImg && rightImg) {
                ApzCOB.toggleModal(BaseScrId + "compareModal");
                ApzCOB.modalFuncs();
            }
        } else {
            window.rightImg = false;
            ApzCOB.showCommonErrRPCModal("File not found");
        }
    },
    modalFuncs: function () {
        const rotateBtn = document.getElementById("APZCBO__BaseScreens__el_icn_29");
        const zoomoutBtn = document.getElementById("APZCBO__BaseScreens__el_icn_30");
        const zoominBtn = document.getElementById("APZCBO__BaseScreens__el_icn_31");
        const leftImage = document.getElementById("APZCBO__BaseScreens__compareLeftImg");
        const rightImage = document.getElementById("APZCBO__BaseScreens__compareRightImg");
        const compareCloseBtn = document.getElementById("APZCBO__BaseScreens__compareModal_close");
        let selectedImageId;
        rotateBtn.disabled = true;
        zoomoutBtn.disabled = true;
        zoominBtn.disabled = true;
        $(`#APZCBO__BaseScreens__compareLeftImg`).parents('ul').addClass("compare-active");

        function enableRotateButton(event) {
            // rotateBtn.disabled = false; 
            const clickedImage = event.target;
            $(".compare-active").removeClass("compare-active");
            $(`#${event.target.id}`).parents('ul').addClass("compare-active");
            selectedImageId = clickedImage.id;
            // ApzCOB.rotateImage(clickedImage.id);
        }
        /*function rotateSelectedImage() {
            rotateBtn.disabled = false;
            if (selectedImageId) {
                ApzCOB.rotateImage(selectedImageId);
            }
        }

        function zoomOutSelectedImage() {
            zoomoutBtn.disabled = false;
            if (selectedImageId) {
                ApzCOB.zoomOut(selectedImageId);
            }
        }

        function zoomInSelectedImage() {
            zoominBtn.disabled = false;
            if (selectedImageId) {
                ApzCOB.zoomIn(selectedImageId);
            }
        }*/
        function removeoptions() {
            leftImage.removeEventListener('click', enableRotateButton);
            rightImage.removeEventListener('click', enableRotateButton);
            // rotateBtn.removeEventListener("click", rotateSelectedImage);
            // zoomoutBtn.removeEventListener("click", zoomOutSelectedImage);
            // zoominBtn.removeEventListener("click", zoomInSelectedImage);
            leftImage.style.transform = 'scale(1) rotate(0deg)';
            rightImage.style.transform = 'scale(1) rotate(0deg)';
            window.isCompare = false;
        }
        leftImage.addEventListener("click", enableRotateButton);
        rightImage.addEventListener("click", enableRotateButton);
        // rotateBtn.addEventListener("click", rotateSelectedImage);
        // zoomoutBtn.addEventListener("click", zoomOutSelectedImage);
        // zoominBtn.addEventListener("click", zoomInSelectedImage);
        compareCloseBtn.addEventListener("click", removeoptions);
        // $('#APZCBO__BaseScreens__compareModal_close').attr('onClick','ApzCOB.closeCompareModal()')
    },
    rpcDocNavigation: function (navType, sideType) {
        window.countIndex = 0;
        window.leftImg = false;
        window.rightImg = false;
        let fileName = '';
        reEnachNavtyp = sideType;
        if (reEnachNavtyp == 'eNext' || reEnachNavtyp == 'efront') {
            window.stageDocuments = eNachstageDocuments;
        }
        if (!isCompare) {
            pcount = navType === 'Prev' ? Math.max(0, pcount - 1) : Math.min(stageDocuments.length - 1, pcount + 1);
            fileName = ApzCOB.getFileName(pcount);
            if (apz.childScr == 'RPCDBUdyamReg' || apz.childScr == 'RPCDBeNach' || apz.childScr == 'RPCDBReviewCnf' || apz.childScr == 'PreviewDBveriification') {
                window.downloadDocflag = true
            }
            window.ImageLocationDetails = {
                latitude: window.stageDocuments[pcount].payload.latitude || "",
                longitude: window.stageDocuments[pcount].payload.longitude || "",
                uploadedTs: window.stageDocuments[pcount].payload.uploadedTs || "",
                documentFileName: window.stageDocuments[pcount].payload.documentFileName || ""
            };
            ApzCOB.downloadFileFromServer(fileName);
        } else {
            let isRightDoc = sideType === 'right';
            let documentArray = isRightDoc ? structuredClone(filteredDocumentArray) : structuredClone(stageDocuments);
            if (isRightDoc) {
                window.countIndex = navType === 'prev' ? --rpcCompareRightIndex : ++rpcCompareRightIndex;
                window.rightImg = true;
            } else {
                window.countIndex = navType === 'prev' ? --rpcCompareLeftIndex : ++rpcCompareLeftIndex;
                window.leftImg = true;
            }
            if (documentArray.length > 0 && countIndex < documentArray.length) {
                let paintId = leftImg ? 'APZCBO__BaseScreens__compareLeftDocName' : 'APZCBO__BaseScreens__compareRightDocName';
                $(`#${paintId}`).text(documentArray[countIndex].payload.documentName);
                fileName = ApzCOB.getFileName(countIndex, documentArray);
                window.ImageLocationDetails = {
                    latitude: documentArray[countIndex].payload.latitude || "",
                    longitude: documentArray[countIndex].payload.longitude || "",
                    uploadedTs: documentArray[countIndex].payload.uploadedTs || "",
                    documentFileName: documentArray[countIndex].payload.documentFileName || ""
                };
                ApzCOB.downloadFileFromServer(fileName, ApzCOB.downloadFileFromServerCB);
            }
        }
    },
    prevButton: function (sideType) {
        ApzCOB.rpcDocNavigation('prev', sideType);
    },
    nextButton: function (sideType) {
        ApzCOB.rpcDocNavigation('next', sideType);
    },
    downloadDocument: function () {
        let request = {};
        let params = {};
        request.applicationId = stageDocuments[0].applicationId;
        request.applicantType = custType;
        if (RPC_CURRENT_STAGE_NO === 3) {
            request.applicantType = "Applicant";
        }
        request.documentType = stageDocuments[0].payload.documentName;
        params.callBackObj = this;
        params.buildReq = "N";
        params.paintResp = "N";
        params.req = request;
        params.appId = gAppId;
        params.ifaceName = "MergeAndDownloadPDF";
        params.async = true;
        params.callBack = ApzCOB.downloadDocumentCB;
        apz.startLoader();
        apz.server.callServer(params);
    },
    downloadDocumentCB: function (params) {
        apz.stopLoader();
        if (ApzCOB.handleServiceCallBacks(params)) {
            try {
                let response = params.res.APZCBO__MergeAndDownloadPDF_Res.apiResponse.ResponseBody.responseObj;
                const base64Response = JSON.parse(response);
                ApzCOB.convertBase64ToPDF(base64Response.base64, params.req.documentType);
            } catch (e) {
                ApzCOB.showRpcModals({
                    text: technicalErrMsg,
                    Btn1: {
                        text: "OK",
                        onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
                    }
                }, "Error");
            }
        } else {
            ApzCOB.showRpcModals({
                text: technicalErrMsg,
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
                }
            }, "Error");
        }
    },
    fetchIFSC: function (ifscVal) {
        req = {
            "apiRequest": {
                "appId": "APZCBO",
                "interfaceName": "FetchIFSC",
                "requestObj": {
                    "ifsc": ifscVal, //"ABHY0065003",
                    "gkv": "1.1",
                    "method": "ifscfetch",
                    "id": "3"
                }
            }
        }
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "FetchIFSC", "N", "N", req, false, ApzCOB.fetchIFSCCB);
        }, 1000)
    },
    fetchIFSCCB: function (params) {
        apz.stopLoader();
        let ifscData = {};
        if (ApzCOB.handleServiceCallBacks(params)) {
            try {
                var responseVal = JSON.parse(params.res.APZCBO__FetchIFSC_Res.apiResponse.ResponseBody.responseObj);
                if (responseVal.errorCode === '0') {
                    var parsedResponse = JSON.parse(responseVal.responseObj);
                    ifscData = {
                        "fetchbankName": parsedResponse.result[0].BANK,
                        "fetchbranchName": parsedResponse.result[0].BRANCH
                    }
                    if (apz.isNull(ifscData.fetchbankName) || apz.isNull(ifscData.fetchbranchName)) {
                        if (apz.currAppId === 'DBkitG') {
                            $(`#${scrId}ifsc`).val('');
                        }
                        //------------- Swaroop changes KM Sourcing -------------------------------------------  
                        else if (apz.currAppId === "KmSourc") {
                            $("#KmSourc__OtherInformation__changeBankIFSCCode").val('');
                        }
                        //--------------------------------------------------------------------------------------                        
                        else {
                            $(`#RPC__${RPC_CURRENT_STAGE}__ifscInput`).val('');
                        }
                        ApzCOB.handleInValidIFSC();
                        ApzCOB.showNewCommonErrorModal(parsedResponse?.msg);
                        return;
                    } else {
                        ifscData.fetchbankName = ifscData.fetchbankName?.trim();
                        ifscData.fetchbranchName = ifscData.fetchbranchName?.trim();
                    }
                    if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 == "RPC") {
                        $(`#RPC__${RPC_CURRENT_STAGE}__bankNameInput`).val(ifscData.fetchbankName).focus();
                        $(`#RPC__${RPC_CURRENT_STAGE}__branchNameInput`).val(ifscData.fetchbranchName).focus();
                        apz.app.BankAccountProofRPC.subStrValue();
                    } else if (apz.currAppId === 'DBkitG') {
                        $(`#${scrId}bankName`).val(ifscData.fetchbankName).focus();
                        $(`#${scrId}branchName`).val(ifscData.fetchbranchName).focus();
                    }
                    //------------- Swaroop changes KM Sourcing -------------------------------------------        
                    else if (apz.currAppId === 'KmSourc') {
                        $("#KmSourc__OtherInformation__changeBankBankName").val(ifscData.fetchbankName).focus();
                        $("#KmSourc__OtherInformation__changeBankBranchName").val(ifscData.fetchbranchName).focus();
                    }
                    //----------------------------------------------------------------------------------------
                }
            } catch (e) {
                ApzCOB.hideLoader();
                ApzCOB.handleInValidIFSC();
                ApzCOB.showNewCommonErrorModal();
            }
        } else {
            ApzCOB.hideLoader();
            let errMsg = params.res.APZCBO__FetchIFSC_Res.apiResponse?.ResponseHeader?.ResponseMessage;
            ApzCOB.handleInValidIFSC();
            ApzCOB.showNewCommonErrorModal(errMsg);
        }
    },
    validateIFSC: function (pthis) {
        window.validIFSC = false;
        if (!ifsclengthErr) return;
        let {
            value: IFSCval,
            minLength: minlength,
            maxLength: maxlength
        } = pthis;
        let lengthValidate = (IFSCval.length < minlength || IFSCval.length > maxlength);
        // if (/*gIFSCRegex.test(IFSCval) && */!lengthValidate) {
        if (!apz.isNull(IFSCval) && !lengthValidate) {
            window.validIFSC = true;
            ApzCOB.fetchIFSC(IFSCval);
        } else {
            window.validIFSC = false;
            ApzCOB.handleInValidIFSC();
            if (apz.currAppId === 'RPC') {
                pthis = '#RPC__BankAccountProofRPC__ifscInput';
                if (!apz.isNull(IFSCval)) {
                    $(pthis).next(".err").remove();
                    $(`#${pthis.id}_li .err`).remove();
                    $(pthis).closest('span.srb.pri.err-inpt').removeClass("err-inpt");
                    $(`#RPC__${RPC_CURRENT_STAGE}__ifsc`).addClass('err-inpt');
                    let ifscErrMsg = "<span class='err' style='color: red; font-size: 12px;'>Please Enter a Valid IFSC Code</span>";
                    $(ifscErrMsg).insertAfter($(pthis));
                }
            }
        }
    },
    handleInValidIFSC: function () {
        if (apz.currAppId === 'DBkitG') {
            window.validIFSC = false;
            $(`#DBkitG__eNach__bankName, #DBkitG__eNach__branchName`).val('');
        } else if (apz.currAppId === 'RPC') {
            window.validIFSC = false;
            $(`#RPC__${RPC_CURRENT_STAGE}__bankNameInput`).val('');
            $(`#RPC__${RPC_CURRENT_STAGE}__branchNameInput`).val('');
            pthis = '#RPC__BankAccountProofRPC__ifscInput';
            $(pthis).next(".err").remove();
            $(`#${pthis.id}_li .err`).remove();
            $(pthis).closest('span.srb.pri.err-inpt').removeClass("err-inpt");
        }
        //------------------------Swaroop Changes KM sourcing----------------------------
        else if (apz.currAppId === 'KmSourc') {
            window.validIFSC = false;
            $("#KmSourc__OtherInformation__changeBankBankName").val('')
            $("#KmSourc__OtherInformation__changeBankBranchName").val('')
            pthis = 'KmSourc__OtherInformation__changeBankIFSCCode';
            $(pthis).next(".err").remove();
            $(`#${pthis.id}_li .err`).remove();
            $(pthis).closest('span.srb.pri.err-inpt').removeClass("err-inpt");
        }
        //-------------------------------------------------------------------------------
    },
    setcustTypeforOccuStages: function (subMenuVal) {
        if (applicantOccupation === coAppOccupation && isAppCoAppOccTagYes) return 1;
        if (applicantOccupation === 'Homemaker') return 2;
        if (coAppOccupation === 'Homemaker') return 1;
        if (coApplAcitivity === subMenuVal) {
            return 2;
        } else {
            return 1;
        }
    },
    fetchRpcOccupationTabs: function () {
        let responseArray = {
            "BusinessPhotoRPC": [],
            "BusinessAddressProofRPC": []
        };
        if (apz.isObjectEmpty(inSessionStore) || apz.isNull(inSessionStore.customerDetailsList)) {
            return responseArray;
        }
        let AppCustID = ApzCOB.getCustDetailID("Applicant");
        let coAppCustID = ApzCOB.getCustDetailID("Co-App");
        let custTypeOccupations = ['', ''];
        inSessionStore.customerDetailsList.filter(({
            custDtlId,
            occupation,
            payload
        }) => {
            if (Number(custDtlId) === Number(AppCustID)) {
                window.applicantOccupation = custTypeOccupations[0] = payload.occupation;
            } else {
                window.coAppOccupation = custTypeOccupations[1] = payload.occupation;
            }
        })
        if (custTypeOccupations.length === 0) return responseArray;
        let [appOccupation, coAppOccupation] = custTypeOccupations;
        isAppCoAppOccTagYes = false;
        if (appOccupation === "Self Employed" || coAppOccupation === "Self Employed") {
            let coAppOccupationData = inSessionStore.occupationDetailsWrapperList.find(
                (occupation) => Number(occupation.occupationDetails.custDtlId) === Number(coAppCustID));
            if (appOccupation.toLowerCase() === coAppOccupation.toLowerCase() && !apz.isObjectEmpty(coAppOccupationData)) {
                let CoAppOccupationPayload = typeof coAppOccupationData.occupationDetails.payload === "object" ? coAppOccupationData
                    .occupationDetails.payload : JSON.parse(coAppOccupationData.occupationDetails.payload);
                if (!apz.isObjectEmpty(CoAppOccupationPayload)) {
                    let isCoAppSameAsApplicant = CoAppOccupationPayload.occupationTag;
                    let occupationType = CoAppOccupationPayload.employeeActivity;
                    window.applActivity = window.coApplAcitivity = ApzCOB.getPayloadData('employeeActivity', 'Applicant', 'BusinessPhotoRPC');
                    if (isCoAppSameAsApplicant?.toUpperCase() === "YES") {
                        isAppCoAppOccTagYes = true;
                        responseArray.BusinessPhotoRPC.push(applActivity);
                        responseArray.BusinessAddressProofRPC.push(applActivity);
                    } else {
                        let AppOccupationData = inSessionStore.occupationDetailsWrapperList.find((occupation) => Number(occupation
                            .occupationDetails.custDtlId) === Number(AppCustID));
                        let AppOccupationPayload = typeof AppOccupationData.occupationDetails.payload === "object" ? AppOccupationData
                            .occupationDetails.payload : JSON.parse(AppOccupationData.occupationDetails.payload);
                        window.applActivity = AppOccupationPayload.employeeActivity;
                        window.coApplAcitivity = AppOccupationPayload.employeeActivity
                        responseArray.BusinessPhotoRPC.push(AppOccupationPayload.employeeActivity, occupationType);
                        responseArray.BusinessAddressProofRPC.push(AppOccupationPayload.employeeActivity, occupationType);
                    }
                }
            } else {
                let ApplicantOccupationTab = ApzCOB.getOccupationTab(appOccupation, AppCustID);
                let CoApplicantOccupationTab = ApzCOB.getOccupationTab(coAppOccupation, coAppCustID);
                window.applActivity = ApplicantOccupationTab;
                window.coApplAcitivity = CoApplicantOccupationTab;
                if (ApplicantOccupationTab) responseArray.BusinessPhotoRPC.push(ApplicantOccupationTab);
                if (CoApplicantOccupationTab) responseArray.BusinessPhotoRPC.push(CoApplicantOccupationTab);
                // responseArray.BusinessPhotoRPC.push(ApplicantOccupationTab, CoApplicantOccupationTab);
                if (appOccupation === "Self Employed" || coAppOccupation === "Self Employed") {
                    if (appOccupation === "Self Employed") {
                        responseArray.BusinessAddressProofRPC.push(ApplicantOccupationTab);
                    }
                    if (coAppOccupation === "Self Employed") {
                        responseArray.BusinessAddressProofRPC.push(CoApplicantOccupationTab);
                    }
                }
            }
        }
        Object.keys(responseArray).forEach((key) => {
            RPC_STAGES[key].subMenu = structuredClone(responseArray[key])
        });
        return responseArray;
    },
    getOccupationTab: function (occupation, custID) {
        if (occupation === "Self Employed") {
            let occupationData = inSessionStore.occupationDetailsWrapperList.find((occ) => Number(occ.occupationDetails.custDtlId) === Number(
                custID));
            if (occupationData && !apz.isObjectEmpty(occupationData)) {
                let payload = typeof occupationData.occupationDetails.payload === "object" ? occupationData.occupationDetails.payload : JSON
                    .parse(occupationData.occupationDetails.payload);
                return payload.employeeActivity || "";
            }
        } else if (occupation === "Salaried") {
            return "Employment Proof";
        } else if (occupation === "Wage earner") {
            return "Wage Earning Details";
        }
        return "";
    },
    setApplicantTypeBasedOnOcc: function (lactivity, isCheck) {
        let customerType = '';
        if (lactivity === "Employment Proof") {
            applicantType = "Salaried"
        } else if (lactivity === "Wage Earning Details") {
            applicantType = "Wage earner"
        } else if (lactivity != 'Wage Earning Details' || lactivity != "Employment Proof") {
            applicantType = "Self Employed"
        }
        if (applicantOccupation === coAppOccupation && isAppCoAppOccTagYes) {
            customerType = applicantType = 'Applicant';
            if (!isCheck) {
                custType = customerType;
            }
            return customerType;
        }
        if (inSessionStore.customerDetailsList.length > 0) {
            let parsedData = inSessionStore.customerDetailsList.map(item => item.payload);
            for (let i = 0; i < parsedData.length; i++) {
                if (parsedData[i].occupation === applicantType) {
                    customerType = applicantType = parsedData[i].gkCustomerType;
                    if (applicantType.includes('Co-App')) {
                        customerType = applicantType = "Co-App";
                        isSubMenuCoApp = true;
                    }
                    break;
                }
            }
        }
        if (!isCheck) {
            custType = customerType;
        }
        return customerType;
    },
    userDetailsData: function () {
        gApzCOB.userDetails = {};
        gApzCOB.userDetails.appId = gApzCOB.requestNodes.appId;
        gApzCOB.userDetails.applicationId = gApzCOB.requestNodes.applicationId;
        gApzCOB.userDetails.versionNum = gApzCOB.requestNodes.applicationMaster.versionNum;
        gApzCOB.userDetails.custDtlId = ApzCOB.getCustDetailID("Applicant");
        if (!apz.isNull(gApzCOB.requestNodes.applnWfDefinitionList)) {
            gApzCOB.applnWorkFlowRes = gApzCOB.requestNodes.applnWfDefinitionList
        }
    },
    validatePennyCheck: function () {
        window.applicationData = [];
        let custDetailID = ApzCOB.getCustDetailID("Applicant");
        applicationData = inSessionStore['customerDetailsList']?.filter(cust => cust.custDtlId === custDetailID) || [];
        var Mob = applicationData[0].mobileNumber;
        let beneficiaryAccount = $(`#RPC__${RPC_CURRENT_STAGE}__accountNumberInput`).val();
        beneficiaryIFSC = $(`#RPC__${RPC_CURRENT_STAGE}__ifscInput`).val();
        beneficiaryName = $(`#RPC__${RPC_CURRENT_STAGE}__accountNameInput`).val();
        var request = {
            "apiRequest": {
                "interfaceName": "SignzyPennylessCheck",
                "appId": gAppId,
                "applicationId": inSessionStore.applicationId,
                "requestObj": {
                    "beneficiaryAccount": beneficiaryAccount,
                    "beneficiaryIFSC": beneficiaryIFSC,
                    "beneficiaryMobile": Mob,
                    "beneficiaryName": beneficiaryName,
                    "nameFuzzy": true
                }
            }
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "SignzyPennylessCheck", "N", "N", request, false, ApzCOB.ValidatePennyCheckCB);
    },
    ValidatePennyCheckCB: function (params) {
        apz.stopLoader();
        var serviceFailErrMsg = 'Penny Check service failed. Please try again later.';
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let parsedCustomerDetails = JSON.parse(params.res.APZCBO__SignzyPennylessCheck_Res.apiResponse.ResponseBody.responseObj);
                let parsedResponse = parsedCustomerDetails.responseObj ? JSON.parse(parsedCustomerDetails.responseObj) : '';
                if (parsedResponse?.result?.reason?.toLowerCase() === 'success') {
                    ApzCOB.handlePennyCheckPass(parsedResponse);
                } else {
                    ApzCOB.handlePennyCheckFail();
                    var errMsg = parsedResponse?.result?.reason;
                    if (apz.isNull(errMsg)) {
                        errMsg = parsedCustomerDetails.hasOwnProperty('errorMessage') ? parsedCustomerDetails.errorMessage : params.res
                            .APZCBO__SignzyPennylessCheck_Res?.apiResponse?.ResponseHeader?.ResponseMessage;
                    }
                    ApzCOB.showCommonErrRPCModal(errMsg);
                }
            } else {
                inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload.pennyCheckStatus = '';
                ApzCOB.showCommonErrRPCModal(serviceFailErrMsg);
            }
        } catch (e) {
            inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload.pennyCheckStatus = '';
            ApzCOB.showCommonErrRPCModal(); //serviceFailErrMsg
        }
    },
    handlePennyCheckPass: function (paintData) {
        pennyStatus = true;
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload.pennyCheckStatus = 'Pass';
        $(`#RPC__${RPC_CURRENT_STAGE}__statusform, #RPC__${RPC_CURRENT_STAGE}__statusDataform`).removeClass('sno');
        $(`#RPC__${RPC_CURRENT_STAGE}__statustext`).attr('class', 'ett-para pri fs14 suc');
        $(`#RPC__BankAccountProofRPC__statustext_txtcnt`).text('Penny Check Response: Pass');
        $(`#RPC__${RPC_CURRENT_STAGE}__exceptionForm, #RPC__${RPC_CURRENT_STAGE}__exceptionMsg`).addClass('sno');
        // ApzCOB.removeDisableToInput('RPC__RPCFooter__Acceptnext');
        ApzCOB.addDisableToInput('RPC__BankAccountProofRPC__pennyCheckBtnId');
        if (gApzCOB.selectedRole === 'RPC_Maker') {
            $('.rpcEditBtn').removeClass('sno');
        }
        if (apz.isNull(paintData) && !apz.isNull(inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload?.pennyResp)) {
            paintData = JSON.parse(inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload?.pennyResp);
        }
        formattedTime = (paintData?.result?.auditTrail?.timestamp) ? ApzCOB.dateformatter(paintData?.result?.auditTrail?.timestamp, "date",
            "d/m/Y")?.split('.')?.[0] : paintData?.result?.auditTrail?.timestamp;
        responseData = {
            pennyAccountNumberInput: inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload?.accountNumber,
            pennyAccountNameInput: paintData?.result?.bankTransfer?.beneName,
            pennyifscInput: paintData?.result?.bankTransfer?.beneIFSC,
            bankTransactionStatusInput: paintData?.result?.bankTransfer?.response,
            bankRRNInput: paintData?.result?.bankTransfer?.bankRRN,
            bankResponseInput: paintData?.result?.reason,
            statuscodeInput: paintData?.result?.auditTrail?.value,
            statusasperserviceInput: paintData?.result?.reason,
            isvalidInput: paintData?.result?.active,
            responsedateInput: formattedTime
        }
        $.each(responseData, function (key, value) {
            $(`#RPC__${RPC_CURRENT_STAGE}__${key}`).text(value);
        });
    },
    handlePennyCheckFail: function () {
        pennyStatus = false;
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload.pennyCheckStatus = 'Fail';
        $(`#RPC__${RPC_CURRENT_STAGE}__reEnterAccountNumber, #RPC__${RPC_CURRENT_STAGE}__exceptionForm, #RPC__${RPC_CURRENT_STAGE}__statusform`)
            .removeClass('sno');
        $(`#RPC__${RPC_CURRENT_STAGE}__exceptionMsg`).addClass('sno');
        $(`#RPC__${RPC_CURRENT_STAGE}__statustext`).attr('class', 'ett-para pri fs14 penny-failed');
        $(`#RPC__BankAccountProofRPC__statustext_txtcnt`).text('Penny Check Response: Fail');
        ApzCOB.addDisableToInput('RPC__BankAccountProofRPC__pennyCheckBtnId');
        ApzCOB.removeDisableToInput('RPC__BankAccountProofRPC__raiseExceptionBtn');
        if (gApzCOB.selectedRole === 'RPC_Maker') {
            $('.rpcEditBtn').removeClass('sno');
        }
        if (checkedAccount.editBankDetails == 'No') {
            $(`#RPC__${RPC_CURRENT_STAGE}__reEnterAccountNumber`).addClass('sno');
        }
    },
    ageCalculator: function () {
        minAge = apz.isNull(minAge) ? 22 : minAge;
        maxAge = apz.isNull(maxAge) ? 60 : maxAge;
        var age = ApzCOB.getAge($('#RPC__PrimaryKycRPC__dobInput').val());
        if (age > 0) {
            $('#RPC__PrimaryKycRPC__ageInput').val(age).change();
        } else {
            $('#RPC__PrimaryKycRPC__ageInput').val('');
            $('#RPC__PrimaryKycRPC__dobInput').val('');
            let msg = `Please select valid age(min:${minAge},max:${maxAge})`;
            ApzCOB.showCommonErrRPCModal(msg);
        }
    },
    addSno: function (event) {
        let clickedId = event.target.id;
        if (clickedId === "RPC__PrimaryKycRPC__primaryKycIdInput") {
            $("#RPC__PrimaryKycRPC__sc_row_55").removeClass("sno");
            $("#RPC__PrimaryKycRPC__sc_row_81").addClass("sno");
        } else if (clickedId === "RPC__PrimaryKycRPC__alternateVoterIdInput") {
            $("#RPC__PrimaryKycRPC__sc_row_79").addClass("sno");
            $("#RPC__PrimaryKycRPC__sc_row_80").addClass("sno");
            let PKycFieldId = $("#RPC__PrimaryKycRPC__sc_row_76");
            PKycFieldId.removeClass("sno");
        }
    },
    KycPrimaryVerification: function (RpcalternateKycid) {
        let kycObj = {
            kycType: "voter",
            kycId: $("#" + realid).val().trim(),
            customerType: coustmerTypValue,
            applicationId: apz.isNull(inSessionStore.applicationMaster.applicationId) ? "" : inSessionStore.applicationMaster
                .applicationId,
            customerId: parseInt(inSessionStore.applicationMaster.customerId),
        };
        let req = {
            apiRequest: {
                interfaceName: "DedupeVoterID",
                requestObj: kycObj,
            },
        };
        ApzCOB.showLoader();
        ApzCOB.serverBuildParam(gAppId, "DedupeVoterID", "N", "N", req, false, ApzCOB.RPCKycDedupeCheckCB);
    },
    rpcDedupeCheckCB: function (params) {
        let responseObj = params.res?.APZCBO__DedupeVoterID_Res?.apiResponse?.ResponseHeader || {};
        try {
            ApzCOB.hideLoader();
            let isSuccess = ApzCOB.handleServiceCallBacks(params);
            let isApplicant = custType === "Applicant";
            let isAlternate = isApplicant ? IS_ALTERNATE_DEDUPE : IS_CO_APPLICANT_ALTERNATE_DEDUPE;
            if (isApplicant) {
                isAlternate ? (ALTERNATE_DEDUPE_STATUS = isSuccess) : (PRIMARY_DEDUPE_STATUS = isSuccess);
            } else {
                isAlternate ? (CO_APPLICANT_ALTERNATE_DEDUPE_STATUS = isSuccess) : (CO_APPLICANT_PRIMARY_DEDUPE_STATUS = isSuccess);
            }
        } catch (e) {
            ApzCOB.hideLoader();
            ApzCOB.showCommonErrRPCModal(responseObj?.ResponseMessage);
        }
        ApzCOB.handleDedupeResult(responseObj);
    },
    handleDedupeResult: function (responseHeader) {
        let isApplicant = custType === "Applicant";
        let isAlternate = isApplicant ? IS_ALTERNATE_DEDUPE : IS_CO_APPLICANT_ALTERNATE_DEDUPE;
        let dedupeStatus = isApplicant ? ALTERNATE_DEDUPE_STATUS || PRIMARY_DEDUPE_STATUS : CO_APPLICANT_ALTERNATE_DEDUPE_STATUS ||
            CO_APPLICANT_PRIMARY_DEDUPE_STATUS;
        let errorMessage = responseHeader?.ResponseMessage || 'Dedupe match found.!';
        let confmTxt = `${errorMessage} <br/> Would you like to reject the application?`;
        let popUpObj = {};
        popUpObj.text = confmTxt;
        popUpObj.Btn1 = {
            "text": "Yes",
            "onClick": "apz.app.RPCFooter.approveReject(this,'REJECTED')"
        }
        popUpObj.Btn2 = {
            "text": "No",
            "onClick": "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()"
        }
        if (isApplicant) {
            if (!ALTERNATE_DEDUPE_STATUS && IS_ALTERNATE_DEDUPE) { //Swaroop Raj R_CR127(Name as per KYC in RPC)
                //if (!ALTERNATE_DEDUPE_STATUS) {    
                ApzCOB.showRpcModals(popUpObj, "confirmation");
                return;
            }
            if (isAlternate && ALTERNATE_DEDUPE_STATUS) {
                ApzCOB.kycVerificationCheck({
                    kycType: "voter",
                    kycId: $(`#RPC__${RPC_CURRENT_STAGE}__alternateVoterIdInput`).val().trim(),
                }, ApzCOB.RPCkycVerificationCheckCB);
            } else if (IS_APPLICANT_PRIMARY_DEDUPE && PRIMARY_DEDUPE_STATUS) { //Swaroop 24th Dec
                ApzCOB.RPCkycVerificationCheck({
                    kycType: "voter",
                    kycId: $(`#RPC__${RPC_CURRENT_STAGE}__primaryKycIdInput`).val().trim(),
                });
            }
        } else {
            let coAppDedupeStatus = isAlternate ? CO_APPLICANT_ALTERNATE_DEDUPE_STATUS : CO_APPLICANT_PRIMARY_DEDUPE_STATUS;
            if (!coAppDedupeStatus) {
                ApzCOB.showRpcModals(popUpObj, "confirmation");
                return;
            }
            if (isAlternate && CO_APPLICANT_ALTERNATE_DEDUPE_STATUS) {
                ApzCOB.RPCkycVerificationCheck({
                    kycType: "voter",
                    kycId: $(`#RPC__${RPC_CURRENT_STAGE}__alternateVoterIdInput`).val().trim(),
                });
            } else if (IS_CO_APPLICANT_PRIMARY_DEDUPE && CO_APPLICANT_PRIMARY_DEDUPE_STATUS) {
                ApzCOB.RPCkycVerificationCheck({
                    kycType: "voter",
                    kycId: $(`#RPC__${RPC_CURRENT_STAGE}__primaryKycIdInput`).val().trim(),
                });
            }
        }
    },
    handleCoApplicantDedupe: function (responseHeader) {
        let coAppDedupeStatus = IS_CO_APPLICANT_ALTERNATE_DEDUPE ? CO_APPLICANT_ALTERNATE_DEDUPE_STATUS : CO_APPLICANT_PRIMARY_DEDUPE_STATUS;
        if (!coAppDedupeStatus) {
            window.RejectReason = `Co-Applicant(CO${CO_APP_ADDED_COUNT}) Dedupe Check Failed.`;
            if (CO_APP_ADDED_COUNT >= gApzCOB.noOfApplicants) {
                ApzCOB.toggleModal(PerDetScrId + "dedupeCheckReject");
            } else {
                $("#" + PerDetScrId + "dedupeRejectLabel").text(responseHeader.ResponseMessage);
                ApzCOB.toggleModal(PerDetScrId + "dedupeRejectOrAddmodel");
            }
        } else {
            ApzCOB.RPCkycVerificationCheck({
                kycType: "voter",
                // kycId: $("#" + (IS_CO_APPLICANT_ALTERNATE_DEDUPE ? realid : realid)).val().trim(),
                kycId: $(`#${realid}`).val().trim(),
            });
        }
    },
    RPCkycVerificationCheck: function (kycObj) {
        let req = {
            apiRequest: {
                interfaceName: "ValidateVoterID",
                requestObj: kycObj,
            },
        };
        ApzCOB.showLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "ValidateVoterID", "N", "N", req, false, ApzCOB.RPCkycVerificationCheckCB);
        }, 1000);
    },
    RPCkycVerificationCheckCB: function (params) {
        ApzCOB.hideLoader();
        let errMsg = "";
        const resBody = params?.resFull?.appzillonBody?.APZCBO__ValidateVoterID_Res;
        const resHeader = resBody?.apiResponse?.ResponseHeader;
        const responseMessage = resHeader?.ResponseMessage || "";
        if (!apz.isNull(resBody)) {
            errMsg = `${ApzCOB.getDescfromLitCode("LIT_KYC_VERIFICATION_SERVICE_FAILED")}<br/>${responseMessage}`;
        } else {
            errMsg = ApzCOB.getDescfromLitCode("LIT_KYC_VERIFICATION_SERVICE_FAILED");
        }
        try {
            if (!ApzCOB.handleServiceCallBacks(params)) throw new Error("Service Callback Failed");
            let responseObj = JSON.parse(params.res.APZCBO__ValidateVoterID_Res.apiResponse.ResponseBody.responseObj || "{}");
            if (responseObj.result_code === 101) {
                const isPrimary = window.kycVerificationType === "primary";
                const isApplicant = custType === "Applicant";
                if (isPrimary) {
                    isApplicant ? (PRIMARY_KYC_VERIFICATION = true) : (CO_APPLICANT_PRIMARY_KYC_VERIFICATION = true);
                    $(`#${primaryKycScrId}verifyPrimaryVoter, #${primaryKycScrId}InvalidPrimaryVoter`).addClass('sno');
                    $(`#${primaryKycScrId}primaryVoterVerified`).removeClass('sno');
                    $('#RPC__PrimaryKycRPC__alternateVoterId label.ett-labl.flb.pri').removeClass('req');
                } else {
                    isApplicant ? (ALTERNATE_KYC_VERIFICATION = true) : (CO_APPLICANT_ALTERNATE_KYC_VERIFICATION = true);
                    $(`#${primaryKycScrId}verifyAlternateVoter, #${primaryKycScrId}InvalidAltVoter`).addClass("sno");
                    $(`#${primaryKycScrId}alternateVoterVerified`).removeClass("sno");
                }
                // $(`#${primaryKycScrId}namePerKycInput`).val(responseObj.result?.name ?? "");
                $(`#${primaryKycScrId}namePerKycInput`).val(ApzCOB.getSubstrValue(`#${primaryKycScrId}namePerKycInput`, responseObj.result
                    .name ?? ""));
            } else {
                let invalidKyc = !responseObj?.error || responseObj.error.message === ApzCOB.getDescfromLitCode("LIT_EPICNUMBER");
                if (invalidKyc) {
                    const isPrimary = window.kycVerificationType === "primary";
                    const isApplicant = custType === "Applicant";
                    if (isPrimary) {
                        if (isApplicant) {
                            window.PRIMARY_KYC_VERIFICATION = false;
                            window.IS_APP_PRIMARY_CHECK_FAILED = true;
                        } else {
                            window.CO_APPLICANT_PRIMARY_KYC_VERIFICATION = false;
                            window.IS_COAPP_PRIMARY_CHECK_FAILED = true;
                        }
                        $(`#${primaryKycScrId}verifyPrimaryVoter, #${primaryKycScrId}primaryVoterVerified`).addClass("sno");
                        $(`#${primaryKycScrId}InvalidPrimaryVoter`).removeClass("sno");
                        $('#RPC__PrimaryKycRPC__alternateVoterId label.ett-labl.flb.pri').addClass('req');
                    } else {
                        if (isApplicant) {
                            window.ALTERNATE_KYC_VERIFICATION = false;
                            window.IS_APP_ALTERNATE_CHECK_FAILED = true;
                        } else {
                            window.CO_APPLICANT_ALTERNATE_KYC_VERIFICATION = false;
                            window.IS_COAPP_ALTERNATE_CHECK_FAILED = true;
                        }
                        $(`#${primaryKycScrId}verifyAlternateVoter, #${primaryKycScrId}alternateVoterVerified`).addClass("sno");
                        $(`#${primaryKycScrId}InvalidAltVoter`).removeClass("sno");
                    }
                    // $(`#${primaryKycScrId}namePerKycInput`).val("");
                } else {
                    errMsg += responseObj.errorDescription ? `<br>${responseObj.errorDescription}` : "";
                    errMsg += responseObj.error?.message ? `<br>${responseObj.error.message}` : "";
                    ApzCOB.showCommonErrRPCModal(errMsg);
                }
            }
        } catch (e) {
            ApzCOB.hideLoader();
            ApzCOB.showCommonErrRPCModal(errMsg);
        }
    },
    loadBankAccountProofRPCEmpty: function () {
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        if (inSessionStore.bankDetailsWrapperList.length > 0 && inSessionStore.bankDetailsWrapperList[currIndex]?.bankDetails?.payload) {
            try {
                let parsedBankDetails = inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload;
                ApzCOB.removeDisableToInput('RPC__RPCFooter__RpcCancelBtn');
                $(`#${bankScrnId}accountNumberInput`).attr('type', 'text');
                $(`#${bankScrnId}reEnterAccountNumber, #${bankScrnId}pennyCheckBtnForm`).addClass('sno')
                if (parsedBankDetails && parsedBankDetails?.editBankDetails === "Yes" && gApzCOB.selectedRole === 'RPC_Maker') {
                    ApzCOB.getPennyCheckData();
                    if (!editFlag) {
                        $('.rpcEditBtn').removeClass('sno');
                        ApzCOB.addDisableToInput(`RPC__${RPC_CURRENT_STAGE}__reEnterAccountNumberInput`);
                        if (parsedBankDetails?.rpcEditCheck) {
                            $(`#${bankScrnId}reEnterAccountNumber, #${bankScrnId}pennyCheckBtnForm`).removeClass('sno');
                            ApzCOB.removeDisableToInput('RPC__BankAccountProofRPC__pennyCheckBtnId');
                            if (parsedBankDetails?.pennyCheckStatus === '' || typeof parsedBankDetails?.pennyCheckStatus === 'undefined') {
                                return;
                            }
                        } else {
                            ['bankName', 'branchName', 'accountName', 'ifsc', 'accountNumber', 'reEnterAccountNumber'].forEach(el => {
                                $(`#${bankScrnId + el}Input`).val('');
                            });
                            $(`#${bankScrnId}accountTypeInput`).val(PleaseSelect).change();
                            return;
                        }
                        if (exceptionDoc.length > 0) {
                            $(`#${bankScrnId}pennyCheckBtnForm, #${bankScrnId}statusform,  #${bankScrnId}exceptionForm, #${bankScrnId}exceptionMsg`)
                                .removeClass('sno');
                            $(`#RPC__${RPC_CURRENT_STAGE}__statusform`).addClass('sno');
                            $(`#${bankScrnId}statustext`).attr('class', 'ett-para pri fs14 penny-failed');
                            $(`#RPC__BankAccountProofRPC__statustext_txtcnt`).text('Penny Check Response: Fail');
                            $(`#${bankScrnId}exceptionText`).attr('class', 'ett-para pri fs14 suc');
                            ApzCOB.addDisableToInput('RPC__BankAccountProofRPC__pennyCheckBtnId');
                            ApzCOB.addDisableToInput(`RPC__${RPC_CURRENT_STAGE}__raiseExceptionBtn`);
                            // ApzCOB.removeDisableToInput('RPC__RPCFooter__Acceptnext');
                            pennyApprovalUpload = true;
                            $('.rpcEditBtn').removeClass('sno');
                        } else if (pennyStatus) {
                            ApzCOB.handlePennyCheckPass();
                        } else {
                            ApzCOB.handlePennyCheckFail();
                        }
                    } else {
                        validAccNum = false;
                        window.validIFSC = false;
                        currentTypeFields.forEach(({
                            fieldId,
                            label,
                            fieldAttr
                        }) => {
                            if (!apz.isNull(fieldAttr, label)) {
                                const [visibilityAttr, mandatoryAttr, editAttribute] = fieldAttr.split("~");
                                const containerSelector = `#RPC__${RPC_CURRENT_STAGE}__${fieldId}`;
                                const inputSelectorID = `RPC__${RPC_CURRENT_STAGE}__${fieldId}Input`;
                                const labelElement = $(containerSelector).find('.ett-labl');
                                if (labelElement.length > 0) {
                                    mandatoryAttr?.toUpperCase() === "M" ? labelElement.addClass("req") : labelElement.removeClass(
                                        "req");
                                }
                                ApzCOB.removeDisableToInput(inputSelectorID);
                                if ($(`#${inputSelectorID}`).val() !== '') {
                                    $(`#${inputSelectorID}`).hasClass('sub-elt') ? $(`#${inputSelectorID}`).val(PleaseSelect).change() : $(`#${inputSelectorID}`).val('');
                                    ApzCOB.removeDisableToInput(inputSelectorID);
                                    dropDownArrowId = ($(containerSelector).find('.sub-elt1')?.length > 0) ? $(containerSelector).find('.sub-elt1').attr('id') : '';
                                    if (!apz.isNull(dropDownArrowId)) {
                                        $("#" + dropDownArrowId).removeClass("sno")
                                    }
                                }
                                if (['reEnterAccountNumber'].includes(fieldId)) {
                                    $(`#${bankScrnId}reEnterAccountNumber`).removeClass('sno');
                                }
                                if (['bankName', 'branchName'].includes(fieldId)) ApzCOB.addDisableToInput(inputSelectorID);
                                $('#RPC__BankAccountProofRPC__ct_frm_1').removeClass('select-disabled');
                                ApzCOB.removeDisableToInput("RPC__BankAccountProofRPC__ct_frm_1");
                            }
                        });
                    }
                } else if (parsedBankDetails && parsedBankDetails?.editBankDetails === "Yes" && gApzCOB.selectedRole === 'RPC_Checker') {
                    $('.rpcEditBtn').addClass('sno');
                    $(`#${bankScrnId}reEnterAccountNumber`).removeClass('sno');
                    ApzCOB.addDisableToInput(`${bankScrnId}reEnterAccountNumberInput`);
                    pennyStatus = ApzCOB.getPayloadDatafromWrapper('pennyCheckStatus', 'Applicant', 'bankDetailsWrapperList') || '';
                    if (pennyStatus?.toUpperCase() === 'PASS') {
                        ApzCOB.handlePennyCheckPass();
                    } else {
                        ApzCOB.handlePennyCheckFail();
                        $(`#RPC__${RPC_CURRENT_STAGE}__raiseExceptionBtn`).addClass('sno');
                    }
                }
                if (parsedBankDetails && parsedBankDetails?.editBankDetails === "No") {
                    if (gApzCOB.selectedRole == 'RPC_Maker') {
                        $('.rpcEditBtn').removeClass('sno');
                    } else {
                        $('.rpcEditBtn').addClass('sno');
                    }
                }
            } catch (error) {
                ApzCOB.showCommonErrRPCModal();
            }
        } else {
            ApzCOB.showCommonErrRPCModal();
        }
    },
    exceptionPopUpModal: function () {
        ApzCOB.toggleModal(BaseScrId + "pennycheckmodal"); //ExceptionModal
    },
    exceptionPopUpModalClose: function () {
        ApzCOB.toggleModal(BaseScrId + "pennycheckmodal");
        $("#RPC__BankAccountProofRPC__el_btn_2").attr("disabled", true);
    },
    zoomIn: function (targetID) {
        // let imageElement = $(`#${docSecScrId}RPC_ImageView`);
        let imageElement = $(`#${targetID}`);
        let parentImg = imageElement.parent().parent().attr('id');
        document.getElementById(parentImg).style.overflow = 'hidden';
        if (imageElement.length > 0) {
            let imageId = imageElement.attr('id');
            if (scale < 3) { // Limit max zoom to 3x
                scale += 0.1;
                document.getElementById(imageId).style.transform = `scale(${scale})`;
            } else {
                // "Maximum zoom level reached."
            }
        } else {
            // "Image element not found."
        }
    },
    zoomOut: function (targetID) {
        // let imageElement = $(`#${docSecScrId}RPC_ImageView`);
        let imageElement = $(`#${targetID}`);
        if (imageElement.length > 0) { // Ensure element exists
            let imageId = imageElement.attr('id');
            if (scale > 0.5) {
                scale = scale - 0.1;
                document.getElementById(imageId).style.transform = `scale(${scale})`;
            } else {
                // "Minimum zoom level reached."
            }
        } else {
            // "Image element not found."
        }
    },
    rotateImage: function (targetID) {
        // let imageElement = targetID ? $(`#${targetID}`) : $(`#${docSecScrId}RPC_ImageView`);
        let imageElement = $(`#${targetID}`);
        let parentImg = imageElement.parent().parent().attr('id');
        document.getElementById(parentImg).style.overflow = 'hidden';
        if (imageElement.length > 0) { // Ensure element exists
            let imageId = imageElement.attr('id');
            rotation = rotation + 90;
            document.getElementById(imageId).style.transform = `scale(${scale}) rotate(${rotation}deg)`;
        } else {
            // do nothing
        }
    },
    validateRPCStageFormFields: function () {
        let missingFields = [];
        currentTypeFields.forEach(field => {
            const fieldSelector = `#RPC__${RPC_CURRENT_STAGE}__${field.fieldId}`;
            let $input = $(`${fieldSelector} .ett-inpt, ${fieldSelector} .sub-elt, ${fieldSelector} .ett-rdio`).first();
            let inputId = $input.attr("id");
            if (!inputId) return;
            let [visibilityAttr, mandatoryAttr, editAttribute] = field.fieldAttr.split('~');
            if (ApplicationType !== 'RENEWAL' && field.fieldId === 'isNewCustomer') {
                visibilityAttr = 'N';
                mandatoryAttr = 'N';
            }
            let isVisible = visibilityAttr === 'Y';
            let isMandatory = mandatoryAttr === "M";
            let isEditable = editAttribute === "E";
            let isRadio = $input.is("input[type='radio']") || $(`#${inputId} input[type='radio']`).length > 0;
            let isDropDown = $(`#${inputId}`).hasClass("sub-elt");
            let isEmpty = false;
            if (!isDropDown) {
                isEmpty = isRadio ? $(`#${inputId} input[type='radio']:checked`).length === 0 : !$input.val()?.trim();
            } else {
                isEmpty = $input.val().trim().toLocaleLowerCase() === PleaseSelect.toLocaleLowerCase();
            }
            if (!$(fieldSelector).hasClass("sno") && isMandatory && isEmpty && isEditable) {
                let isEmpty = isRadio ? $(`#${inputId} input[type='radio']:checked`).length === 0 : !$input.val()?.trim();
                $input.next(".err").remove();
                $input.parent().find('.err').remove();
                $input.parent().parent().find('.err').remove(); //Dropdown
                if (isDropDown) {
                    $input.parents("li").css("display", "block");
                    $(RpcErrorMessage).insertAfter($input.parent());
                } else {
                    $(RpcErrorMessage).insertAfter($input);
                }
                $(fieldSelector).addClass('err-inpt');
                missingFields.push(inputId);
                let eventType = isRadio ? "change" : "input";
                $input.on(eventType, function () {
                    $(this).next(".err").remove();
                });
            } else {
                let valFlag = true;
                if (!isRadio && !isDropDown && !isEmpty) {
                    valFlag = ApzCOB.newFnCheckMaxMinLengthOnBlur(document.getElementById(inputId));
                }
                if (!valFlag) {
                    missingFields.push(inputId);
                    return;
                }
                $(fieldSelector).removeClass('err-inpt');
                $input.next(".err").remove();
            }
        });
        missingFields = [...missingFields, ...ApzCOB.conditionalValidation()]
        return missingFields.length === 0;
    },
    conditionalValidation: function () {
        let isApplicant = custType === "Applicant";
        let primaryKycTagId = 'RPC__PrimaryKycRPC__'
        let error = [];
        let errorMsg = '';
        let kycFields = [`${primaryKycTagId}primaryKycIdInput`, `${primaryKycTagId}alternateVoterIdInput`];
        if (RPC_CURRENT_STAGE_NO === 1) {
            let maritalStatus = $(`#${primaryKycTagId}maritalStatusInput`).val();
            let fieldId = maritalStatus?.toLowerCase() === "married" ? `#${primaryKycTagId}spouseNameInput` : `#${primaryKycTagId}fathersNameInput`;
            if (apz.isNull($(fieldId).val())) {
                error.push($(fieldId).attr("id"));
            }
            //-----------------------Swaroop Raj R (CR-90 Father name is not capturing) 24thNov2025--------------------
            if (custType === 'Co-App') { //new changes
                let selectedGenderCoApp = $(`#${primaryKycTagId}genderInput`).val();
                if (maritalStatus === "Married" && selectedGenderCoApp !== "Female") { //new changes
                    fieldId = `#${primaryKycTagId}fathersNameInput`;
                    if (apz.isNull($(fieldId).val())) {
                        error.push($(fieldId).attr("id"));
                    }
                }
            }
            //-----------------------------------------------------------------------------------------------------
            let primaryKycId = $(`#${primaryKycTagId}primaryKycIdInput`).val();
            let alternateVoterId = $(`#${primaryKycTagId}alternateVoterIdInput`).val();
            let isPrimaryKycNull = isApplicant ? apz.isNull(PRIMARY_KYC_VERIFICATION) : apz.isNull(CO_APPLICANT_PRIMARY_KYC_VERIFICATION);
            let isAlternateKycNull = isApplicant ? apz.isNull(ALTERNATE_KYC_VERIFICATION) : apz.isNull(
                CO_APPLICANT_ALTERNATE_KYC_VERIFICATION);
            if ($(`#RPC__PrimaryKycRPC__alternateVoterId .ett-labl`).hasClass('req') && apz.isNull(alternateVoterId)) {
                error.push(`${primaryKycTagId}alternateVoterIdInput`);
                $(`#${primaryKycTagId}verifyAlternateVoter`).addClass('sno');
            }
            if (isPrimaryKycNull && !apz.isNull(primaryKycId)) {
                error.push(`${primaryKycTagId}primaryKycIdInput`);
                $(`#${primaryKycTagId}verifyPrimaryVoter`).addClass('sno');
            }
            if (!PRIMARY_KYC_VERIFICATION && isAlternateKycNull && !apz.isNull(alternateVoterId)) {
                error.push(`${primaryKycTagId}alternateVoterIdInput`);
                $(`#${primaryKycTagId}verifyAlternateVoter`).addClass('sno');
            }
            let kycStatus = custType === "Applicant" ? (PRIMARY_KYC_VERIFICATION || ALTERNATE_KYC_VERIFICATION) : (
                CO_APPLICANT_PRIMARY_KYC_VERIFICATION || CO_APPLICANT_ALTERNATE_KYC_VERIFICATION);
            let nullFlagCheck = custType === "Applicant" ? (!apz.isNull(PRIMARY_KYC_VERIFICATION) && !apz.isNull(
                ALTERNATE_KYC_VERIFICATION)) : (!apz.isNull(CO_APPLICANT_PRIMARY_KYC_VERIFICATION) && !apz.isNull(
                    CO_APPLICANT_ALTERNATE_KYC_VERIFICATION));
            if (!kycStatus && nullFlagCheck) {
                error.push(`${primaryKycTagId}primaryKycIdInput`, `${primaryKycTagId}alternateVoterIdInput`);
                errorMsg = "Both primary and alternate voter ID are invalid!";
            }
            let errTxt = '';
            if (error.length > 0) {
                error.forEach(err => {
                    if ($(`#${err}`).hasClass('disabled')) return;
                    let isDropDown = $(`#${err}`).hasClass("sub-elt");
                    let $input = $(`#${err}`);
                    $input.next(".err").remove();
                    $input.parent().find('.err').remove();
                    errTxt = RpcErrorMessage;
                    if (kycFields.includes(err)) {
                        if (!errorMsg) {
                            errTxt = "<span class='err' style='color: red; font-size: 12px;'>Please validate the kyc id.</span>";
                        }
                    }
                    if (isDropDown) {
                        $input.parents("li").css("display", "block");
                        $(errTxt).insertAfter($input.parent());
                    } else {
                        $(errTxt).insertAfter($input);
                    }
                    let fieldSecID = $($input).attr('id').split('Input')?.[0];
                    $(`#${fieldSecID}`).addClass('err-inpt');
                })
                if (!apz.isNull(errorMsg)) {
                    if (!apz.isNull(errorMsg)) {
                        ApzCOB.showCommonErrRPCModal(errorMsg);
                    }
                }
            }
        } else if (RPC_CURRENT_STAGE_NO === 2) {
            aadhaarInpId = $(`#${secKycScrId}secondaryKycIdInput`);
            if (aadhaarInpId.val()?.trim() !== '') aadhaarInpId.blur();
            if ($('#RPC__SecondaryKYCRPC__secondaryKycId .err').length > 0) error.push(`${secKycScrId}secondaryKycIdInput`);
        }
        return error;
    },
    RpcEditSave: function () {
        let formValidate = ApzCOB.validateRPCStageFormFields();
        let accVerifyid = $(`#RPC__BankAccountProofRPC__rpcverifyAccount`).is(':visible');
        let inValidAccid = $(`#RPC__BankAccountProofRPC__rpcinvaildAccount`).is(':visible');
        if ((accVerifyid) || (inValidAccid)) {
            ApzCOB.fnDisplayMsg("Please Verify Bank Account", "E");
            return;
        }
        if (RPC_CURRENT_STAGE_NO === 1 && !$("#RPC__PrimaryKycRPC__verifyAlternateVoter").hasClass("sno") && (!$("#RPC__PrimaryKycRPC__el_txt_10_txtcnt").is(":visible") || $("#RPC__PrimaryKycRPC__el_hpl_3_txtcnt").is(":visible"))) {
            ApzCOB.fnDisplayMsg("Please verify Alternate Voter ID", "E");
            return;
        }
        if (formValidate && RPC_CURRENT_STAGE_NO === 8 && gApzCOB.selectedRole === 'RPC_Maker') {
            let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
            editBankTag = inSessionStore.bankDetailsWrapperList[currIndex]?.bankDetails?.payload?.editBankDetails === 'Yes';
            if (editBankTag && (!validAccNum || !validIFSC)) {
                if (!validAccNum) $(`#${reEnterInputId}`).blur();
                if (!validIFSC) $(`#${ifscInputId}`).blur();
                return
            };
        }
        if (formValidate && [2, 4, 7].includes(RPC_CURRENT_STAGE_NO) && !validPinCode) {
            const isEmpty = ["areaInput", "cityInput", "districtInput", "stateInput"].some(el => {
                return $(`#RPC__${RPC_CURRENT_STAGE}__${el}`).val() === '';
            });
            if (isEmpty) {
                window.validPinCode = false;
                ApzCOB.showInputErrMsg($(`#RPC__${RPC_CURRENT_STAGE}__pinCodeInput`)[0]);
            } else {
                $(`#RPC__${RPC_CURRENT_STAGE}__pinCodeInput`).blur();
            }
            return;
        }
        if ([1].includes(RPC_CURRENT_STAGE_NO)) {
            ApzCOB.newFnCheckMaxMinLengthOnBlur($(`#RPC__${RPC_CURRENT_STAGE}__mobileNumberInput`)[0]);
            if (!moblengthErr) {
                ApzCOB.showInputErrMsg($(`#RPC__${RPC_CURRENT_STAGE}__mobileNumberInput`)[0]);
                return;
            }
        }
        if (formValidate) {
            let {
                loginResponse
            } = gApzCOB.LoggedInUserDetails || {};
            let req = {
                apiRequest: {
                    requestObj: {},
                    // requestType: "Edit",
                    userId: loginResponse?.userDet?.id || "",
                    appId: gAppId,
                    interfaceName: "UploadRPCLoanData",
                },
            };
            let editedFields = [];
            currentApplicationData = structuredClone ? structuredClone(inSessionStore) : JSON.parse(JSON.stringify(inSessionStore));
            let {
                createTs,
                updateTs,
                applicationDate,
                lockTs,
                ...filteredData
            } = currentApplicationData.applicationMaster;
            if (RPC_SCREEN_WRAPPER.length > 0 && !apz.isNull(RPC_CURRENT_STAGE_NO)) {
                let curReqWrapper = RPC_SCREEN_WRAPPER.find(wrapper => parseInt(wrapper.stage_id) === parseInt(RPC_CURRENT_STAGE_NO));
                if (!apz.isObjectEmpty(curReqWrapper)) {
                    curReqWrapper.stage_wrapper?.forEach(reqWrapper => {
                        switch (reqWrapper) {
                            case "customerDetailsList":
                                var formattedData = ApzCOB.RpcEditSaveRequestFormat(reqWrapper);
                                var updatedFormatData = structuredClone(formattedData) || [];
                                if (RPC_CURRENT_STAGE_NO === 1) {
                                    updatedFormatData = ApzCOB.PrimaryKycVerifiactionReqMapper(updatedFormatData) ||
                                        updatedFormatData;
                                } else if (RPC_CURRENT_STAGE_NO === 2) {
                                    updatedFormatData = ApzCOB.SecKycReqMapper(updatedFormatData) || updatedFormatData;
                                }
                                req.apiRequest.requestObj[reqWrapper] = updatedFormatData;
                                req.apiRequest.requestObj.applicationMaster = ApzCOB.createApplicationMasterReq(
                                    currentApplicationData, updatedFormatData);
                                editedFields.push(...ApzCOB.editedFieldsFormatter(req.apiRequest.requestObj, reqWrapper));
                                break;
                            case "addressDetailsWrapperList":
                                req.apiRequest.requestObj.addressDetailsWrapperList = structuredClone(ApzCOB.RpcEditAddressWrapper());
                                editedFields.push(...ApzCOB.editedFieldsFormatter(req.apiRequest.requestObj, reqWrapper));
                                break;
                            // case "insuranceDetailsWrapperList":  
                            // case "bankDetailsWrapperList":
                            // case "loanDetails":
                            // case "occupationDetailsWrapperList":
                            default:
                                var formattedData = ApzCOB.RpcEditSaveRequestFormat(reqWrapper);
                                var updatedFormatData = structuredClone(formattedData) || [];
                                if (reqWrapper === "loanDetails") {
                                    req.apiRequest.requestObj[reqWrapper] = updatedFormatData?.[0];
                                } else {
                                    req.apiRequest.requestObj[reqWrapper] = updatedFormatData;
                                }
                                editedFields.push(...ApzCOB.editedFieldsFormatter(req.apiRequest.requestObj, reqWrapper));
                                break;
                        }
                    });
                }
            }
            req.apiRequest.requestObj = {
                ...req.apiRequest.requestObj,
                appId: currentApplicationData?.appId,
                applicationId: currentApplicationData?.applicationId,
                // versionNum: currentApplicationData?.versionNum,
                versionNum: 1,
                stageId: RPC_CURRENT_STAGE_NO?.toString(),
                requestType: "Edit",
                customerType: window.custType,
                editedFields,
            };
            apz.startLoader();
            ApzCOB.serverBuildParam(gAppId, "UploadRPCLoanData", "N", "N", req, false, ApzCOB.RpcEditSaveCB);
        }
    },
    PrimaryKycVerifiactionReqMapper: function (formattedData) {
        let primaryKycStatus = "";
        let alternateKycStatus = "";
        if (custType === "Applicant") {
            if (!apz.isNull(PRIMARY_KYC_VERIFICATION)) {
                primaryKycStatus = PRIMARY_KYC_VERIFICATION ? "Verified" : "Invalid";
            }
            if (!apz.isNull(ALTERNATE_KYC_VERIFICATION)) {
                alternateKycStatus = ALTERNATE_KYC_VERIFICATION ? "Verified" : "Invalid";
            }
        } else {
            if (!apz.isNull(CO_APPLICANT_PRIMARY_KYC_VERIFICATION)) {
                primaryKycStatus = CO_APPLICANT_PRIMARY_KYC_VERIFICATION ? "Verified" : "Invalid";
            }
            if (!apz.isNull(CO_APPLICANT_ALTERNATE_KYC_VERIFICATION)) {
                alternateKycStatus = CO_APPLICANT_ALTERNATE_KYC_VERIFICATION ? "Verified" : "Invalid";
            }
        }
        if (Array.isArray(formattedData) && formattedData[0]?.payload) {
            formattedData[0].payload.primaryKycIdValStatus = primaryKycStatus;
            formattedData[0].payload.alternateVoterIdValStatus = alternateKycStatus;
        }
        return formattedData;
    },
    SecKycReqMapper: function (formattedData) {
        let secKycName = $(`#${secKycScrId}secondaryKycNameInput`).val().trim();
        let secKycDOB = $(`#${secKycScrId}secondaryKycDobInput`).val().trim();
        if (Array.isArray(formattedData) && formattedData[0]?.payload) {
            formattedData[0].payload.secondaryKycName = secKycName;
            formattedData[0].payload.secondaryKycDob = secKycDOB;
        }
        return formattedData;
    },
    RpcEditAddressWrapper: function () {
        let custDetailID = ApzCOB.getCustDetailID(custType);
        if (RPC_CURRENT_STAGE_NO === 2) {
            addrType = 'Personal'; subAddrType = 'SecondaryKyc';
        } else if (RPC_CURRENT_STAGE_NO === 4 || RPC_CURRENT_STAGE_NO === 5) {
            addrType = 'Personal'; subAddrType = 'Present';
        } else if (RPC_CURRENT_STAGE_NO === 7) {
            addrType = 'Occupation'; subAddrType = 'Office';
        }
        let custTypeAddressData = currentApplicationData.addressDetailsWrapperList?.[0].addressDetailsList.find(address => address
            .custDtlId === custDetailID && address.addressType.toLowerCase() === addrType.toLowerCase());
        let addressPayload = {};
        let payloadData = {};
        let addressArray = [];
        if (!apz.isObjectEmpty(custTypeAddressData)) {
            if (addrType.toLowerCase() === 'personal') {
                try {
                    addressPayload = (typeof custTypeAddressData.payload === 'object') ? custTypeAddressData.payload : JSON.parse(
                        custTypeAddressData.payload);
                } catch (e) {
                    // "Error parsing address payload"
                    addressPayload = {};
                }
                if (Array.isArray(addressPayload?.addressList) && addressPayload.addressList.length > 0) {
                    if (RPC_CURRENT_STAGE_NO === 2) {
                        payloadData = addressPayload.addressList.find(
                            (secAdd) => secAdd.addressType.toLowerCase() === "communication") || {};
                    } else {
                        payloadData = addressPayload.addressList.find(
                            (secAdd) => secAdd.addressType.toLowerCase() === subAddrType.toLocaleLowerCase()) || {};
                    }
                    if (!apz.isObjectEmpty(payloadData)) {
                        ApzCOB.updateRpcFields(payloadData);
                        payloadData.addressType = subAddrType;
                        addressArray.push(payloadData);
                    }
                }
            } else if (addrType.toLowerCase() === 'occupation') {
                try {
                    addressPayload = (typeof custTypeAddressData.payload === 'object') ? custTypeAddressData.payload : JSON.parse(
                        custTypeAddressData.payload);
                } catch (e) {
                    // "Error parsing address payload:"
                    addressPayload = {};
                }
                if (Array.isArray(addressPayload?.addressList) && addressPayload.addressList.length > 0) {
                    payloadData = addressPayload.addressList.find((secAdd) => secAdd.addressType.toLowerCase() === subAddrType
                        .toLocaleLowerCase()) || {};
                    if (!apz.isObjectEmpty(payloadData)) {
                        ApzCOB.updateRpcFields(payloadData);
                        payloadData.addressType = subAddrType;
                        addressArray.push(payloadData);
                    }
                }
            }
        }
        return [{
            "addressDetailsList": [{
                "addressType": addrType,
                "payload": {
                    "addressList": addressArray
                }
            }]
        }];
    },
    updateRpcFields: function (obj) {
        Object.keys(obj).forEach(key => {
            let container = $(`#RPC__${RPC_CURRENT_STAGE}__${key}`);
            if (!container.hasClass("sno")) {
                let inputElement = container.find('.ett-inpt');
                if (inputElement.length) {
                    obj[key] = inputElement.val();
                } else {
                    let radioInputs = container.find('.etb-rdio input');
                    if (radioInputs.length) {
                        let selectedRadio = '';
                        radioInputs.each(function () {
                            if (this.checked) {
                                selectedRadio = $(this).next().attr('title') || '';
                            }
                        });
                        obj[key] = selectedRadio;
                    }
                }
            }
        });
    },
    RpcEditSaveCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.updateInsessionData(params);
                if (RPC_CURRENT_STAGE_NO === 8 && gApzCOB.selectedRole === 'RPC_Maker') {
                    pennyStatus = false;
                    pennyApprovalUpload = false;
                    isAccdtlsedit = true;
                    // ApzCOB.addDisableToInput('RPC__RPCFooter__Acceptnext');
                    $(`#RPC__${RPC_CURRENT_STAGE}__pennyCheckBtnForm`).addClass('sno');
                    $(`#RPC__${RPC_CURRENT_STAGE}__statusform`).addClass('sno');
                    $(`#RPC__${RPC_CURRENT_STAGE}__statusDataform`).addClass('sno');
                    $(`#RPC__${RPC_CURRENT_STAGE}__exceptionForm`).addClass('sno');
                }
                if (RPC_CURRENT_STAGE_NO === 6) {
                    // apz.app.RPCSidebar.navigateToStage(RPC_CURRENT_STAGE_NO);
                    ApzCOB.launchSubScreen("RPCSidebar", sidebarRow, "");
                }
                let editedFields = ApzCOB.getStageEditedFields();
                ApzCOB.updateEditedTags(editedFields);
                /*if (RPC_CB_REHIT_STAGES.includes(RPC_CURRENT_STAGE_NO) && editedFields.length > 0) {
                    apz.startLoader();
                    ApzCOB.BRECbService();
                } else {
                    ApzCOB.handleCancelButtonClick();
                }*/ //Co-Applicant edit CR
                ApzCOB.handleCancelButtonClick(); //Co-Applicant edit CR
                ApzCOB.updateSideMenuStatusTags();
            }
        } catch (error) {
            ApzCOB.showCommonErrRPCModal();
            ApzCOB.handleCancelButtonClick();
        }
    },
    RpcEditSaveRequestFormat: function (reqWrapper) {
        let wrapperData = {
            [reqWrapper]: []
        };
        let currentWrapperTypeData = '';
        let custDetailID = ApzCOB.getCustDetailID(custType);
        let currSubWrapper = '';
        let subWrapperTypes = ['occupationDetailsWrapperList', 'insuranceDetailsWrapperList', 'bankDetailsWrapperList'];
        // let custType = coustmerTypValue === 1 ? "Applicant" : "Co-App";
        switch (reqWrapper) {
            case "customerDetailsList":
                currentWrapperTypeData = currentApplicationData[reqWrapper]?.find(cust => cust.customerType === window.custType);
                break;
            case "loanDetails":
                currentWrapperTypeData = currentApplicationData[reqWrapper];
                break;
            case "occupationDetailsWrapperList":
                currentWrapperTypeData = currentApplicationData[reqWrapper].filter(el => el.occupationDetails.custDtlId === custDetailID);
                currentWrapperTypeData = currentWrapperTypeData?.[0]?.occupationDetails;
                currSubWrapper = 'occupationDetails';
                break;
            case "insuranceDetailsWrapperList":
                currentWrapperTypeData = currentApplicationData[reqWrapper].filter(el => el.insuranceDetails.custDtlId === custDetailID);
                currentWrapperTypeData = currentWrapperTypeData?.[0]?.insuranceDetails;
                currSubWrapper = 'insuranceDetails';
                break;
            case "bankDetailsWrapperList":
                currentWrapperTypeData = currentApplicationData[reqWrapper].filter(el => el.bankDetails.custDtlId === custDetailID);
                currentWrapperTypeData = currentWrapperTypeData?.[0]?.bankDetails;
                currSubWrapper = 'bankDetails';
                break;
        }
        if (!currentWrapperTypeData) return wrapperData[reqWrapper];
        const updateFields = (obj) => {
            Object.keys(obj).forEach(key => {
                // let inputElement = $(`#RPC__${RPC_CURRENT_STAGE}__${key} .ett-inpt`);
                const fieldSelector = `#RPC__${RPC_CURRENT_STAGE}__${key}`;
                let inputElement = $(`${fieldSelector} .ett-inpt, ${fieldSelector} .sub-elt, ${fieldSelector} .ett-rdio`).first();
                if (inputElement.length && !$(`#RPC__${RPC_CURRENT_STAGE}__${key}`).hasClass("sno")) {
                    if ($(`${fieldSelector} .etb-rdio input`).length > 0) {
                        $(`${fieldSelector} .etb-rdio input`).filter((el, item) => {
                            if (document.getElementById(item.id).checked) {
                                obj[key] = item?.nextElementSibling?.title;
                            }
                        })
                    } else {
                        obj[key] = inputElement.val();
                        if (amtFields.includes(key)) {
                            obj[key] = ApzCOB.unformatIndianRupees(inputElement.val());
                            if (key === "otherSourceAnnualIncome") obj[key] = (obj[key]).toString();
                        }
                        if (['dob', 'secondaryKycDob', 'businessEmpStartDate'].includes(key) && !YYYYMMDDRegex.test(inputElement
                            .val())) {
                            let formattedDate = ApzCOB.convertDateFormat(inputElement.val(), 'yyyy-mm-dd');
                            obj[key] = formattedDate;
                        }
                        if (key === 'panNumber' && obj[key] === 'Not Available') {
                            obj[key] = '';
                            obj['panNumberStatus'] = '';
                            obj['panNumberValue'] = 'No';
                        }
                    }
                }
            });
        };
        updateFields(currentWrapperTypeData);
        let dataPayload = {};
        if (typeof (currentWrapperTypeData.payload) === 'object') {
            dataPayload = currentWrapperTypeData.payload;
        } else {
            dataPayload = JSON.parse(currentWrapperTypeData.payload || "{}");
        }
        if (reqWrapper === "bankDetailsWrapperList" && dataPayload?.editBankDetails === 'Yes') {
            dataPayload.reEnterAccountNumber = $('#RPC__BankAccountProofRPC__reEnterAccountNumberInput').val();
            dataPayload.rpcaccntVerified = window.accIsvalid;
            dataPayload.rpcEditCheck = true;
        }
        updateFields(dataPayload);
        currentWrapperTypeData.payload = {
            ...dataPayload
        };
        if (reqWrapper === "customerDetailsList" && custType === 'Co-App' && ApplicationType === 'RENEWAL' && RPC_CURRENT_STAGE_NO === 1) {
            currentWrapperTypeData.payload.isNewCustomer = $('#RPC__PrimaryKycRPC__isNewCustomer .etb-rdio input:checked').next().attr('title');
        }
        if (subWrapperTypes.includes(reqWrapper) && !apz.isNull(currSubWrapper)) {
            wrapperData[reqWrapper].push({
                [currSubWrapper]: currentWrapperTypeData
            })
        } else {
            wrapperData[reqWrapper].push(currentWrapperTypeData);
        }
        return wrapperData[reqWrapper];
    },
    editedFieldsFormatter: function (request, wrapper) {
        let editedFields = [];
        if (ApzCOB.isObjEmpty(inSessionStore) || ApzCOB.isObjEmpty(request)) return editedFields;
        let currTypeInSessionData = '';
        let currentEditedData = [];
        let custDetailID = ApzCOB.getCustDetailID(custType);
        switch (wrapper) {
            case "customerDetailsList":
                currTypeInSessionData = inSessionStore[wrapper]?.find(cust => cust.customerType === window.custType);
                currentEditedData = request[wrapper]?.[0];
                break;
            case "addressDetailsWrapperList":
                let addressList = inSessionStore[wrapper]?.[0]?.addressDetailsList || [];
                let currentAddressData = addressList.filter(el => el.custDtlId === custDetailID && el.addressType.toLowerCase() === addrType
                    .toLowerCase());
                if (currentAddressData.length > 0) {
                    let addressPayload = typeof currentAddressData[0].payload === 'object' ? currentAddressData[0].payload : JSON.parse(
                        currentAddressData[0].payload || '{}');
                    currTypeInSessionData = addressPayload?.addressList?.find(address => address.addressType.toLowerCase() === subAddrType
                        .toLowerCase());
                }
                currentEditedData = request?.[wrapper]?.[0]?.addressDetailsList?.[0]?.payload?.addressList?.[0];
                break;
            case "loanDetails":
                currTypeInSessionData = inSessionStore[wrapper];
                currentEditedData = request[wrapper];
                break;
            case "occupationDetailsWrapperList":
                currTypeInSessionData = inSessionStore[wrapper].filter(el => el.occupationDetails.custDtlId === custDetailID);
                currTypeInSessionData = currTypeInSessionData?.[0]?.occupationDetails;
                currentEditedData = request[wrapper]?.[0]?.occupationDetails;
                break;
            case "insuranceDetailsWrapperList":
                currTypeInSessionData = inSessionStore[wrapper].filter(el => el.insuranceDetails.custDtlId === custDetailID);
                currTypeInSessionData = currTypeInSessionData?.[0]?.insuranceDetails;
                currentEditedData = request[wrapper]?.[0]?.insuranceDetails;
                break;
            case "bankDetailsWrapperList":
                currTypeInSessionData = inSessionStore[wrapper].filter(el => el.bankDetails.custDtlId === custDetailID);
                currTypeInSessionData = currTypeInSessionData?.[0]?.bankDetails;
                currentEditedData = request[wrapper]?.[0]?.bankDetails;
                break;
        }
        if (!currTypeInSessionData || !currentEditedData) return editedFields;
        const compareObjects = (obj1, obj2, excludeKeys = []) => {
            Object.keys(obj1).forEach(key => {
                if (!excludeKeys.includes(key) && obj1[key] !== obj2[key]) {
                    editedFields.push(key);
                }
            });
        };
        compareObjects(currTypeInSessionData, currentEditedData, ["payload"]);
        let inSessionDataPayload = {};
        if (typeof (currTypeInSessionData.payload) === 'object') {
            inSessionDataPayload = currTypeInSessionData.payload;
        } else {
            inSessionDataPayload = JSON.parse(currTypeInSessionData.payload || "{}");
        }
        let editedDataPayload = currentEditedData.payload || {};
        compareObjects(inSessionDataPayload, editedDataPayload);
        return editedFields;
    },
    updateEditedTags: function (editedFields) {
        if (editedFields.length === 0) return;
        editedFields.forEach(field => {
            let fieldLabel = $(`#RPC__${RPC_CURRENT_STAGE}__${field} label.ett-labl`);
            if (fieldLabel.length && !fieldLabel.siblings(".fieldEditedTag").length) {
                fieldLabel.parent().append('<span class="fieldEditedTag">Edited</span>');
            }
            if ($(`#RPC__${RPC_CURRENT_STAGE}__${field}Input`).hasClass('ett-rdio')) {
                fieldLabel.parent().addClass('rc-edited-field');
            }
            if (editedFields.includes("addressSameAs") && $(`#${bussAddrPrfScrId}addressSameAsInput_option_Present`).is(":checked")) {
                $('.rpcEditBtn').removeClass('sno');
                $(`#${bussAddrPrfScrId}editIconLbl_li`).removeClass('sno');
            }
        });
    },
    getNextDocLevel: function (docType, custDtlId) {
        let currDocs = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList?.filter(el => el.custDtlId === custDtlId && el?.payload?.documentType === docType);
        const existingLevels = currDocs.map(doc => parseInt(doc?.payload?.docLevel));
        for (let i = 1; i <= existingLevels?.length; i++) {
            if (!existingLevels.includes(i)) {
                return `${i}`;
            }
        }
        return `${existingLevels.length + 1}`;
    },
    exceptionFileUpload: function (fileObj, uploadType) {
        let docLevel = "1";
        pennyApprovalUpload = true;
        pennyStatus = false;
        customerType = 'Applicant';
        // uploadType = uploadType;
        IsReuploadTag = 'N';
        currentApplicationData = structuredClone ? structuredClone(inSessionStore) : JSON.parse(JSON.stringify(inSessionStore));
        let uploadStageId = "UPLOADDOCS";
        let callBackFn = "";
        if (uploadType === "PennyExceptionDoc") {
            uploadStageId = "pennyCheckDocs";
            callBackFn = ApzCOB.exceptionFileUploadCB;
        } else if (uploadType === "ReAssesmentDoc") {
            docLevel = ApzCOB.getNextDocLevel('ReAssesmentDoc', ApzCOB.getCustDetailID(customerType));
            callBackFn = ApzCOB.mergedFileUploadCB;
        } else if (uploadType === "DBKitDoc" || uploadType === "DBBankUpdate") {
            if (apz.childScr === "UdyamReg") {
                customerType = $(`#${scrId}custTypeRadio input:checked`).val();
                uploadType = $(`#${scrId}successTick_ul`).is(":visible") ? "Udyam Reg Success" : "Udyam Reg Failed";
                docLevel = ApzCOB.getNextDocLevel(uploadType, ApzCOB.getCustDetailID(customerType));
            } else if (apz.childScr === "eNach") {
                customerType = custType;
                docLevel = ApzCOB.getNextDocLevel('DBBankUpdate', ApzCOB.getCustDetailID(custType));
            }
            callBackFn = apz.app.DBbase.FileUploadCB;
            if (inSessionStore.applicationMaster.applicationStatus === "DBPUSHBACK") {
                IsReuploadTag = 'Y'
            }
        }
        window.uploadType = uploadType;
        window.customerType = customerType;
        let custDetailID = ApzCOB.getCustDetailID(customerType);
