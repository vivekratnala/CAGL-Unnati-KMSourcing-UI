        }
    },
    loadCompareOptions: function () {
        var docSecScrId = 'RPC__RPCDocumentSection__';
        var occObj = {
            "Applicant": applicantOccupation,
            "Co-App": coAppOccupation
        };
        var docToShow = [];
        if (RPC_CURRENT_STAGE_NO === 3) {
            window.custType = "Co-App";
        }
        /*if ($(`#${docSecScrId}commoncompare_popOver`).is(":visible")) {
            $(`#${docSecScrId}Compare_btn`).click();
        }*/
        if (COMPARE_DOC_TYPES.length > 0) {
            additionalDocs = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.filter(id => id.payload.isAdiDoc === 'Y' && id.custDtlId === ApzCOB.getCustDetailID(custType));
            let stageWrapper = RPC_SCREEN_WRAPPER.find(screen => screen.stage_id === RPC_CURRENT_STAGE_NO);
            if (RPC_CURRENT_STAGE_NO === 9) {
                var additionalDocTypes = []
                additionalDocs.forEach(function (el) {
                    if (!additionalDocTypes.includes(el.payload.documentType)) additionalDocTypes.push(el.payload.documentType);
                })
                stageWrapper.docTypes = additionalDocTypes;
            }
            if (!apz.isObjectEmpty(stageWrapper) && stageWrapper.hasOwnProperty('docTypes')) {
                let stageDocTypes = stageWrapper.docTypes;
                if (stageDocTypes.length > 0) {
                    COMPARE_DOC_TYPES.map(doc => {
                        stageDocTypes.map(stageDoc => {
                            if (stageDocTypes.includes(doc) && RPC_CURRENT_STAGE_NO !== 9) return;
                            let docText = ApzCOB.capitalize(doc.replaceAll('_', ' ').toLocaleLowerCase());
                            if (doc !== stageDoc) {
                                let obj = {
                                    "doctype": docText
                                }
                                let isDuplicate = docToShow.some(doc => doc.doctype === obj.doctype);
                                if (!isDuplicate) {
                                    if ((obj.doctype === "Employment proof" && occObj[custType] !== 'Salaried') || (obj.doctype === "Relationship proof" && custType === 'Co-App')) return;
                                    docToShow.push(obj);
                                }
                            }
                        })
                    })
                }
            }
            if (additionalDocs.length > 0 && RPC_CURRENT_STAGE_NO < 9) {
                let obj = {
                    "doctype": "Additional Documents"
                }
                docToShow.push(obj)
            }
            if (RPC_CURRENT_STAGE_NO !== 1 && custType == "Co-App") {
                window.comparepanNO = ApzCOB.getPayloadDatafromWrapper('panNumber', 'Co-App', 'customerDetailsList');
                if (apz.isNull(comparepanNO) || comparepanNO == 'Not Available') {
                    docToShow = docToShow.filter(doc => doc.doctype !== "Pan number photo");
                }
            }
            if (docToShow.length > 0) {
                apz.data.scrdata.RPC__PaintDocumentType_Res = [];
                apz.data.scrdata.RPC__PaintDocumentType_Res = structuredClone(docToShow);
                apz.data.loadData('PaintDocumentType', 'RPC');
                $('#RPC__RPCDocumentSection__Compare_btn').popover('toggle');
                // $('#RPC__RPCDocumentSection__commoncompare_popOver .srb.pri.wrapped').attr('onclick', 'ApzCOB.comparemodal(this);');
                $(`#${docSecScrId}ct_lst_2 .wrapped.undefined.ssp`).remove();
            }
        }
    },
    launchViewlogModal: function () {
        IS_VIEWLOG_FETCH = true;
        ApzCOB.FetchDBKITMasterData("ALL");
        ApzCOB.fetchStageWiseQueries('RPC');
        ApzCOB.fetchSanctionQuery(['Sanction', 'Deviation', 'ReAssessment']);
        ApzCOB.fetchCAMaster();
        setTimeout(() => {
            var activityIntfId = 'APZCBO__ActivityLog__o__APZCBO__ActivityLog_Res__'
            let arr = [];
            let timeLineWrapper = structuredClone ? structuredClone(inSessionStore.applicationTimelineDtl) : JSON.parse(JSON.stringify(inSessionStore.applicationTimelineDtl))
            timeLineWrapper.forEach(function (el, index) {
                timeStamp = '---';
                if (el?.timeStamp.includes(' ')) {
                    timeStamp = typeof (el.timeStamp) === 'string' ? ApzCOB.dateformatter(el.timeStamp.replace(' ', 'T'), "date", "d/m/Y") : '---';
                }
                if (Array.isArray(el?.rpcStatRemaks)) {
                    el.rpcStatRemaks = ApzCOB.getQueryValues(el.rpcStatRemaks, el);
                }
                if (el.stage === "Credit Assessment") {
                    if (!apz.isNull(el.remarks)) {
                        let remarksArray = [];
                        if (el.remarks.includes('|')) {
                            remarksArray = el.remarks.split('|');
                        } else {
                            remarksArray.push(el.remarks);
                        }
                        let totalRemarks = [];
                        if (remarksArray.length > 0) {
                            remarksArray.map(remark => {
                                let [stageId = '', queryId = ''] = remark?.split('_') || [];
                                const currentStage = CA_ALL_STAGE_FIELDS.find(caData => caData.id === Number(stageId));
                                let currentQueries = JSON.parse(currentStage?.queries || '{}').sendbackReason || [];
                                if (queryId.includes('R')) {
                                    currentQueries = JSON.parse(currentStage?.rejectReasons || '{}').rejectReason || [];
                                }
                                const queryDesc = currentQueries.find(q => q.id === queryId);
                                if (queryDesc?.value) {
                                    totalRemarks.push(queryDesc.value);
                                }
                            })
                            el.rpcStatRemaks = structuredClone(totalRemarks);
                            el.remarks = (totalRemarks?.length === 0 && remarksArray?.length > 0) ? remarksArray : '';
                        }
                    }
                } else if (decodeRemarkStages.includes(el.stage)) {
                    let remarksArray = [];
                    if (!apz.isNull(el.remarks)) {
                        // if(el.remarks.includes('|')){
                        remarksArray = el.remarks.split('|');
                        if (remarksArray.length > 0) {
                            el.rpcStatRemaks = ApzCOB.getQueryValues(remarksArray, el);
                            if (el?.rpcStatRemaks?.length === 0 && remarksArray?.length > 1) {
                                el.remarks = remarksArray[1];
                            } else if (el?.rpcStatRemaks?.length > 0) {
                                el.remarks = '';
                            } else {
                                el.remarks = el.remarks || '';
                            }
                        }
                        // }
                    }
                } else if (!apz.isNull(el.remarks)) {
                    if (el.remarks.includes('{"CUSTOMERDETAILS":')) {
                        let kmResponse = JSON.parse(el.remarks);
                        el.remarks = ApzCOB.handleSendbackResponses(kmResponse);
                    }
                }
                let lobj = {
                    "stage": apz.isNull(el?.stage) ? "---" : el?.stage,
                    "action": apz.isNull(el?.actionTaken) ? "---" : el?.actionTaken,
                    "userName": apz.isNull(el?.userId) ? "---" : (el?.userId.includes('SYSTEM') ? el?.userId.replace("SYSTEM(SYSTEM)", "Auto Approved") : el?.userId),
                    "actionTimeline": timeStamp,
                    "rpcStatRemaks": (apz.isNull(el?.rpcStatRemaks) || el?.rpcStatRemaks.length === 0) ? "---" : el?.rpcStatRemaks,
                    "remarks": el?.remarks ? el?.remarks : "---"
                }
                arr.push(lobj);
            })
            apz.data.scrdata.APZCBO__ActivityLog_Res = [];
            apz.data.scrdata.APZCBO__ActivityLog_Res = arr;
            apz.data.loadData("ActivityLog", gAppId);
            apz.stopLoader();
            ApzCOB.toggleModal(BaseScrId + "activityLogModal");
            $('.crt-list li').attr('onClick', '');
            $(`#${BaseScrId}activityLogList .srb.pri.wrapped.undefined.ssp`).remove();
            $(`#${BaseScrId}activityLogModal_content`).scrollTop(0, 0);
            apz.data.scrdata.APZCBO__ActivityLog_Res?.forEach(function (el, index) {
                rpcStatId = document.getElementById(`${activityIntfId}rpcStatRemaks_${index}_txtcnt`);
                remarksId = document.getElementById(`${activityIntfId}remarks_${index}_txtcnt`);
                if (Array.isArray(el?.rpcStatRemaks)) {
                    if (el.rpcStatRemaks?.length > 0) {
                        rpcStatId.innerHTML = el.rpcStatRemaks?.filter(msg => msg).map(msg => `• ${msg}`).join("<br>");
                    }
                }
                if (el?.remarks) {
                    el.remarks = el.remarks.includes('|') ? el.remarks.split('|')[1] : el.remarks;
                    if (el.remarks.includes('~')) {
                        el.remarks = el.remarks.split('~');
                    }
                    if (Array.isArray(el.remarks) && el.remarks?.length > 0) {
                        remarksId.innerHTML = el?.remarks?.map(msg => `• ${msg}`).join("<br>");
                    } else {
                        remarksId.innerHTML = el.remarks;
                    }
                }
            })
        }, 3000);
    },
    handleSendbackResponses: function (kmResp) {
        const result = [];
        for (const section in kmResp) {
            const parties = kmResp[section];
            for (const role in parties) {
                const response = parties[role]?.response;
                if (response) {
                    // result.push(`${section} > ${role}: ${response}`);
                    result.push(`${response}`);
                }
            }
        }
        return result;
    },
    getQueryValues: function (queryArray, tracker) {
        const allQueries = [];
        let stageData = [];
        if (decodeRemarkStages.includes(tracker.stage) && tracker.stage !== "Disbursement Kit Verification") {
            let sanctionStage = tracker.stage === "Pre Sanction" ? "ReAssessment" : tracker.stage === "Resanction" ? "Sanction" : tracker.stage;
            const sanctionEntry = SANCTION_QUERIES.find(sa => sa.stage_name.toLocaleLowerCase() === sanctionStage.toLocaleLowerCase());
            let stageQueries = [];
            if (apz.isNull(sanctionEntry)) {
                return;
            }
            if (sanctionStage === 'Sanction') {
                stageQueries = JSON.parse(sanctionEntry.queries)?.PUSHBACK?.queries || [];
            } else {
                stageQueries = JSON.parse(sanctionEntry.queries)?.queries || [];
            }
            queryArray.forEach(query => {
                const [queryCat, queryVal] = query.split('?');
                if (queryCat !== 'OTH') {
                    const currentCatData = stageQueries.find(q => Number(q.catID) === Number(queryCat));
                    currentCatData?.queries?.forEach(q => {
                        if (q.id === queryVal) {
                            allQueries.push(q.value);
                        }
                    });
                } else {
                    allQueries.push(queryVal || "");
                }
            });
        } else {
            if (Array.isArray(queryArray)) {
                queryArray.forEach(({ custType, query, stageID }, index) => {
                    if (apz.isNull(custType) && queryArray.some(item => item.includes('_')) && tracker.stage === "Disbursement Kit Verification") {
                        [stageID, query, TS] = queryArray[index].split('_');
                        stageID = parseInt(stageID);
                        custType = 'A';
                    }
                    if (!apz.isNull(tracker.stage)) {
                        if (tracker.stage === 'Disbursement Kit' || tracker.stage === "Disbursement Kit Verification") {
                            const stageIdMap = { 1: 8, 2: 9, 3: 10 };
                            let currentStage = DBKIT_MASTERDATA.find(dbData => dbData.id === stageID);
                            if (tracker.stage === "Disbursement Kit Verification") {
                                mappedStageID = stageIdMap[stageID]; // e.g., 3 => 10
                                currentStage = DBKIT_MASTERDATA.find(el => el.id === mappedStageID);
                            }
                            const currentQueries = JSON.parse(currentStage?.queries || '{}').sendbackReason || [];
                            stageData = structuredClone(currentQueries);
                            currentQueries.forEach(stageQuery => {
                                if (query?.includes(stageQuery.id)) {
                                    allQueries.push(stageQuery.value);
                                }
                            });
                        } else if (tracker.stage === "Credit Assessment") {
                            const currentStage = CA_ALL_STAGE_FIELDS.find(caData => caData.id === stageID);
                            const currentQueries = JSON.parse(currentStage?.queries || '{}').sendbackReason || [];
                            let queryDescVal = '';
                            if (stageID === 2) {
                                if (!Array.isArray(query)) {
                                    queryDescVal = query.split('?')[1] || '';
                                } else {
                                    if (query.length > 0) {
                                        query.forEach(queryItem => {
                                            let queryID = `${custType}_${queryItem}`;
                                            const queryDesc = currentQueries.find(q => q.id === queryID);
                                            if (queryDesc?.value) {
                                                queryDescVal = queryDesc.value;
                                                allQueries.push(queryDescVal);
                                            }
                                        });
                                    }
                                }
                            }
                        } else {
                            stageData = structuredClone(RPC_ALL_STAGE_QUERIES);
                            stageData.forEach(rpc => {
                                if (rpc.custType === custType && rpc.stageID === stageID) {
                                    rpc.query.forEach(queryItem => {
                                        if (query.includes(queryItem.id)) {
                                            allQueries.push(queryItem.value);
                                        }
                                    });
                                }
                            });
                        }
                        if (query?.length > 0) {
                            if (Array.isArray(query)) {
                                query.forEach(q => {
                                    if (/^oth\?/.test(q)) {
                                        allQueries.push(q.split("?")[1] || "");
                                    }
                                });
                            } else {
                                if (/^oth\?/.test(query)) {
                                    allQueries.push(query.split("?")[1] || "");
                                }
                            }
                        }
                    }
                });
            }
        }
        return allQueries;
    },
    converApplicationDate: function (inputDate) {
        let newDate = "";
        if (typeof (inputDate) === 'object' && !Array.isArray(inputDate)) {
            let ldate = inputDate;
            newDate = (`${ldate?.year}-${ldate?.month}-${ldate?.day}`);
        }
        return newDate;
    },
    formatamountVal: function (amount) {
        if (amount == null || amount === "") return "";
        amount = amount.toString()?.trim();
        let [integerPart, decimalPart] = amount.split(".");
        let lastThree = integerPart.substring(integerPart.length - 3);
        let otherNumbers = integerPart.substring(0, integerPart.length - 3);
        if (otherNumbers !== "") {
            lastThree = "," + lastThree;
        }
        let formattedInteger = otherNumbers.replace(/\B(?=(\d{2}){1,10}(?!\d))/g, ",") + lastThree;
        return decimalPart ? `${formattedInteger}.${decimalPart.substr(0, 2)}` : formattedInteger;
    },
    //DBKIT Code
    fetcheNachBankData: function (stageName, callbackFn) {
        var request = {};
        var params = {};
        params.callBackObj = this;
        params.buildReq = "N";
        params.paintResp = "N";
        params.req = request;
        params.appId = gAppId;
        params.ifaceName = "fetcheNachBanks";
        params.async = true;
        params.callBack = ApzCOB.fetcheNachBankDataCB;
        apz.startLoader();
        apz.server.callServer(params);
    },
    fetcheNachBankDataCB: function (params) {
        apz.stopLoader();
        try {
            if (!apz.isNull(params.res.APZCBO__fetcheNachBanks_Res) && params.res.APZCBO__fetcheNachBanks_Res.length > 0) {
                ALL_eNACH_BANKS = params.res.APZCBO__fetcheNachBanks_Res;
                ALL_eNACH_BANKS = ALL_eNACH_BANKS?.filter(el => typeof (el.bank_name) !== 'undefined');
                currApplicantBankAcc = ApzCOB.getPayloadData('ifsc', 'Applicant', 'BankAccountProofRPC');
                currApplicantBankAcc = currApplicantBankAcc?.split(0, 3)?.[0];
            }
        } catch (e) {
            apz.stopLoader();
            ApzCOB.showCommonErrRPCModal();
        }
    },
    getPayloadDatafromWrapper: function (fieldId, custType, wrapper) {
        window.applicationData = [];
        if (custType === "Co-App") {
            customerTypValue = inSessionStore.customerDetailsList[0]?.customerType === "Applicant" ? 1 : 2;
        } else {
            customerTypValue = inSessionStore.customerDetailsList[1]?.customerType === "Applicant" ? 1 : 2;
        }
        let response = "";
        if (!apz.isNull(wrapper)) {
            if (apz.isNull(inSessionStore) || apz.isObjectEmpty(inSessionStore)) {
                return;
            }
            let custDetailID = ApzCOB.getCustDetailID(custType);
            switch (wrapper) {
                case "customerDetailsList":
                    applicationData = inSessionStore[wrapper]?.filter(cust => cust.custDtlId === custDetailID) || [];
                    for (let info of applicationData) {
                        if (info.hasOwnProperty(fieldId)) {
                            response = info[fieldId];
                            break;
                        }
                        if (!apz.isNull(response)) break;
                        let payloadData = {};
                        if (typeof (info.payload) === 'object') {
                            payloadData = info.payload;
                        } else {
                            payloadData = JSON.parse(info.payload);
                        }
                        if (payloadData && payloadData.hasOwnProperty(fieldId)) {
                            if (payloadData[fieldId] === "NULL" || payloadData[fieldId] === null || typeof payloadData[fieldId] ===
                                "undefined") {
                                payloadData[fieldId] = "";
                            }
                            response = payloadData[fieldId];
                            break;
                        }
                    }
                    break;
                case "addressDetailsWrapperList":
                    const addressData = inSessionStore[wrapper]?.[0]?.addressDetailsList.filter(el => el.custDtlId === custDetailID) || [];
                    for (let info of addressData) {
                        if (info.hasOwnProperty('addressType')) {
                            if (info.addressType?.toLowerCase() === addrType.toLowerCase() && info?.payload) {
                                const parseddata = info.payload?.addressList || [];
                                for (let addrlst of parseddata) {
                                    if (addrlst?.hasOwnProperty('addressType')) {
                                        if (addrlst['addressType']?.toLowerCase() === subAddrType.toLowerCase()) {
                                            if (addrlst.hasOwnProperty(fieldId)) {
                                                response = addrlst[fieldId];
                                                break;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                    break;
                case "bankDetailsWrapperList":
                    const bankData = inSessionStore[wrapper]?.filter(cust => cust.bankDetails.custDtlId === custDetailID) || [];
                    if (bankData.length === 0) break;
                    const bankparseddata = bankData[0]?.bankDetails?.payload;
                    if (bankparseddata?.hasOwnProperty(fieldId)) {
                        response = bankparseddata[fieldId]
                        break;
                    }
                    break;
                case "occupationDetailsWrapperList":
                    const occData = inSessionStore[wrapper]?.filter(ldata => ldata.occupationDetails.custDtlId === custDetailID) || [];
                    const occparseddata = occData[0]?.occupationDetails?.payload;
                    if (occparseddata?.hasOwnProperty(fieldId)) {
                        response = occparseddata[fieldId]
                        break;
                    }
                    break;
                case "applicationMaster":
                    if (custType === 'Applicant') {
                        const customerDetail = inSessionStore[wrapper];
                        if (customerDetail.hasOwnProperty(fieldId)) {
                            response = customerDetail[fieldId];
                            break;
                        }
                    }
                    break;
                case "insuranceDetailsWrapperList":
                    const insureDetail = inSessionStore.insuranceDetailsWrapperList.filter(el => el.insuranceDetails.custDtlId ===
                        custDetailID) || [];
                    const insureParsedData = insureDetail[0].insuranceDetails.payload;
                    if (insureParsedData?.hasOwnProperty(fieldId)) {
                        response = insureParsedData[fieldId];
                        break;
                    }
                    break;
                case "cibilDetailsWrapperList":
                    const cibilDetail = inSessionStore.cibilDetailsWrapperList.filter(el => el.cibilDetails.custDtlId === custDetailID) || [];
                    const cibilParsedData = cibilDetail?.[0]?.cibilDetails;
                    if (cibilParsedData?.hasOwnProperty(fieldId)) {
                        response = cibilParsedData[fieldId];
                        break;
                    }
                    if (!apz.isNull(response)) break;
                    if (cibilParsedData?.payload?.hasOwnProperty(fieldId)) {
                        response = cibilParsedData?.payload?.[fieldId];
                        break;
                    }
                    break;
                case "loanDetails":
                    const loanData = inSessionStore[wrapper] || [];
                    if (loanData?.hasOwnProperty(fieldId)) {
                        response = loanData[fieldId];
                        break;
                    } else if (loanData?.payload) {
                        const parsedPayload = loanData.payload;
                        if (parsedPayload?.hasOwnProperty(fieldId)) {
                            response = parsedPayload[fieldId];
                            break;
                        }
                    }
                    break;
                case "renewalLeadDetails":
                case "leadDetails":
                    const leadData = inSessionStore[wrapper] || [];
                    if (leadData?.hasOwnProperty(fieldId)) {
                        response = leadData[fieldId];
                        break;
                    }
                    break;
                case "enachDetails":
                    let eNachData = inSessionStore[wrapper] || [];
                    if (eNachData.length > 0) {
                        eNachData = eNachData.find(el => el.customerType === custType);
                        if (eNachData?.hasOwnProperty(fieldId)) {
                            response = eNachData[fieldId];
                            break;
                        }
                    }
                    break;
                default:
                    break;
            }
        }
        return response;
    },
    showDBModals: function (propObj, modalType) {
        let DBModalId = "DBkitG__DBbase__";
        if (modalType === "confirmation") {
            $(`#${DBModalId}confirmationText_txtcnt`).html(propObj.text);
            if (!apz.isNull(propObj.Btn1.text) || !apz.isNull(propObj.Btn2.text)) {
                $(`#${DBModalId}confrmBtn1_txtcnt`).html(propObj.Btn1.text ? propObj.Btn1.text : "Yes");
                $(`#${DBModalId}confrmBtn2_txtcnt`).html(propObj.Btn2.text ? propObj.Btn2.text : "No");
                $(`#${DBModalId}confrmBtn1`).attr("onclick", propObj.Btn1.onClick);
                $(`#${DBModalId}confrmBtn2`).attr("onclick", propObj.Btn2.onClick);
                $(`#${DBModalId}dbconfirmationModal .suc-btns`).removeClass('sno');
            } else {
                $(`#${DBModalId}dbconfirmationModal .suc-btns`).addClass('sno');
            }
            ApzCOB.toggleModal(`${DBModalId}dbconfirmationModal`);
        } else if (modalType === "Error") {
            $(`#${DBModalId}errorText_txtcnt`).html(propObj.text);
            $(`#${DBModalId}errorBtn1`).attr("onclick", propObj.Btn.onClick);
            ApzCOB.toggleModal(`${DBModalId}dberrorModal`);
        } else if (modalType === "Success") {
            $(`#${DBModalId}successText_txtcnt`).html(propObj.text);
            $(`#${DBModalId}succBtn`).attr("onclick", propObj.Btn.onClick);
            ApzCOB.toggleModal(`${DBModalId}dbsuccessModal`);
        }
    },
    showDBCommonErrorModals: function (lerrMsg) {
        ApzCOB.showDBModals({
            text: lerrMsg ? lerrMsg : technicalErrMsg,
            Btn1: {
                text: "OK",
                onClick: "ApzCOB.closeCommonModal(`newCommonConfModal`)"
            }
        }, "Error");
