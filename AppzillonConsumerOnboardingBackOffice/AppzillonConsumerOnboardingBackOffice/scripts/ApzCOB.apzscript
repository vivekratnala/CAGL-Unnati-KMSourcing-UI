    //Fetch countries Service Callback
    FetchCountriesCB: function (params) {
        apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                let response = JSON.parse(params.res.APZCBO__FetchCountries_Res.apiResponse.ResponseBody.responseObj);
                gCountries = response;
            }
            if (!apz.isNull(gCountries) && apz.childScr === "CRSDeclaration") {
                gCountries.forEach(function (item) {
