apz.app.BaseScreens.updatePrimaryDetails = function() {
    gApzCOB.userDetails.mobileNum = gApzCOB.requestNodes.applicationMaster.mobileNumber;
    gApzCOB.userDetails.userName = gApzCOB.requestNodes.applicationMaster.createdBy;
    gApzCOB.userDetails.panNum = gApzCOB.requestNodes.applicationMaster.pan;
    gApzCOB.userDetails.email = gApzCOB.requestNodes.applicationMaster.emailId;
    gApzCOB.userDetails.kycFlag = gApzCOB.requestNodes.applicationMaster.kycType;
    gApzCOB.userDetails.nationalId = gApzCOB.requestNodes.applicationMaster.nationalId;
    gApzCOB.userDetails.declarationFlag = gApzCOB.requestNodes.applicationMaster.declarationFlag;
    gApzCOB.userDetails.product = gApzCOB.requestNodes.applicationMaster.productGroupCode;
    gApzCOB.userDetails.productCode = gApzCOB.requestNodes.applicationMaster.productCode;
    gApzCOB.userDetails.versionNum = window.versionNum;
    gApzCOB.userDetails.branchCode = gApzCOB.requestNodes.applicationMaster.searchCode1;
    gApzCOB.userDetails.cgCustId = "";
    if (gApzCOB.requestNodes.customerDetailsList.length > 0 && !apz.isNull(gApzCOB.requestNodes.customerDetailsList[0].payload) && !apz.isNull(
            gApzCOB.requestNodes.customerDetailsList[0].payload.custId)) gApzCOB.userDetails.cgCustId = gApzCOB.requestNodes.customerDetailsList[
        0].payload.custId;
    if (!apz.isNull(gApzCOB.requestNodes.insuranceDetailsWrapperList) && gApzCOB.requestNodes.insuranceDetailsWrapperList.length > 0) {
        let applicntInsData = [];
        applicntInsData = gApzCOB.requestNodes.insuranceDetailsWrapperList.filter(insData => parseInt(insData.insuranceDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));
        if (applicntInsData.length > 0) {
            gApzCOB.userDetails.insurenceReqForCoApp = applicntInsData[0].insuranceDetails.payload.coApplicantInsurance;
        }
    }
    gApzCOB.applicationType = gApzCOB.requestNodes.applicationMaster.applicantsCount > 1 ? JointAccount : "Single Account";
    gApzCOB.noOfApplicants = gApzCOB.requestNodes.applicationMaster.applicantsCount;
    if ((gApzCOB.mainProductGroupCode === 'DEPOSIT' || gApzCOB.mainProductGroupCode === 'LOAN') && !gApzCOB.ExistingCustomer) {
        gApzCOB.relatedApplicationId = gApzCOB.requestNodes.applicationMaster.applicationId;
    }
    //gApzCOB.relatedApplicationId = gApzCOB.requestNodes.applicationMaster.relatedApplicationId;//
    gApzCOB.product = gApzCOB.requestNodes.applicationMaster.productGroupCode;
    window.selectedType = gApzCOB.product;
    gApzCOB.productCode = gApzCOB.requestNodes.applicationMaster.productCode;
    /* gApzCOB.currentApplicant = gApzCOB.requestNodes.applicationMaster.custDtlSlNum > 1 ? gApzCOB.requestNodes.applicationMaster.custDtlSlNum : 1;*/
    if (pendingApplication) {
        gApzCOB.currentApplicant = apz.isNull(gApzCOB.currentApplicant) ? 1 : gApzCOB.currentApplicant;
    }
    if (apz.isNull(gApzCOB.currentApplicant)) {
        gApzCOB.currentApplicant = gApzCOB.requestNodes.applicationMaster.custDtlSlNum > 1 ? gApzCOB.requestNodes.applicationMaster.custDtlSlNum : gApzCOB.currentApplicant;
    }
    if (gApzCOB.product === 'CARDS') {
        gApzCOB.userDetails.filename = gApzCOB.requestNodes.cardDetails.customTheme;
        gApzCOB.userDetails.ModeofDelivryBlValE = gApzCOB.requestNodes.cardDetails.emailStmtReq;
        gApzCOB.userDetails.ModeofDelivryBlValp = gApzCOB.requestNodes.cardDetails.physicalStmtReq;
        gApzCOB.userDetails.IsCustomTheme = gApzCOB.requestNodes.cardDetails.theme;
        gApzCOB.userDetails.nameOnCard = gApzCOB.requestNodes.cardDetails.nameOnCard;
    }
    // Settinf customer dtls ID
    if (apz.isNull(gApzCOB.userDetails.custDtlId)) {
        gApzCOB.userDetails.custDtlId = "";
        gApzCOB.userDetails.createdByName = "";
    }
    if (apz.isNull(gApzCOB.userDetails.CoApplicantCustomerId)) {
        gApzCOB.userDetails.CoApplicantCustomerId = ""
    }
    if (!apz.isNull(inSessionStore.customerDetailsList)) {
        if (inSessionStore.customerDetailsList.length > 0) {
            inSessionStore.customerDetailsList.map(cust => {
                if (cust.customerType === "Applicant") {
                    gApzCOB.userDetails.custDtlId = cust.custDtlId;
                    gApzCOB.userDetails.createdByName = apz.isNull(cust.payload.createdByName) ? '' : cust.payload.createdByName;
                    if (!apz.isNull(cust.payload.customerIndex)) {
                        CO_APP_ADDED_COUNT = parseInt(cust.payload.customerIndex) === 0 ? 1 : parseInt(cust.payload.customerIndex);
                        /*if (ApplicationType === 'RENEWAL' && !isRenewalPopupEnabled) {
                            CO_APP_ADDED_COUNT = 2;
                        }*/ //Co-App Freeze
                    }
                } else {
                    gApzCOB.userDetails.CoApplicantCustomerId = cust.custDtlId;
                }
            })
        }
    }
    // Setting Personal And Occupation Address dtls ID
    if (apz.isNull(gApzCOB.userDetails.addressDtlsId)) {
        gApzCOB.userDetails.addressDtlsId = "";
    }
    if (apz.isNull(gApzCOB.userDetails.CoApplicantAddressDtlsId)) {
        gApzCOB.userDetails.CoApplicantAddressDtlsId = ""
    }
    if (apz.isNull(gApzCOB.userDetails.occAddressDtlsId)) {
        gApzCOB.userDetails.occAddressDtlsId = "";
    }
    if (apz.isNull(gApzCOB.userDetails.CoApOccAddressDtlsId)) {
        gApzCOB.userDetails.CoApOccAddressDtlsId = ""
    }
    if (!apz.isNull(inSessionStore.addressDetailsWrapperList)) {
        if (!apz.isNull(inSessionStore.addressDetailsWrapperList[0].addressDetailsList)) {
            if (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.length > 0) {
                let addressResponse = inSessionStore.addressDetailsWrapperList[0].addressDetailsList;
                addressResponse.map(address => {
                    if (address.addressType === "Personal" && parseInt(address.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                        gApzCOB.userDetails.addressDtlsId = address.addressDtlsId;
                    }
                    if (address.addressType === "Personal" && parseInt(address.custDtlId) === parseInt(gApzCOB.userDetails
                            .CoApplicantCustomerId)) {
                        gApzCOB.userDetails.CoApplicantAddressDtlsId = address.addressDtlsId;
                    }
                    if (address.addressType === "Occupation" && parseInt(address.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                        gApzCOB.userDetails.occAddressDtlsId = address.addressDtlsId;
                    }
                    if (address.addressType === "Occupation" && parseInt(address.custDtlId) === parseInt(gApzCOB.userDetails
                            .CoApplicantCustomerId)) {
                        gApzCOB.userDetails.CoApOccAddressDtlsId = address.addressDtlsId;
                    }
                })
            }
        }
    }
    // Setting Insurance dtls ID
    if (apz.isNull(gApzCOB.userDetails.insuranceDtlsId)) {
        gApzCOB.userDetails.insuranceDtlsId = "";
    }
    if (apz.isNull(gApzCOB.userDetails.coAppInsuranceDtlsId)) {
        gApzCOB.userDetails.coAppInsuranceDtlsId = ""
    }
    if (!apz.isNull(inSessionStore.insuranceDetailsWrapperList)) {
        if (inSessionStore.insuranceDetailsWrapperList.length > 0) {
            let insuranceResponse = inSessionStore.insuranceDetailsWrapperList;
            insuranceResponse.map(insurance => {
                if (parseInt(insurance.insuranceDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                    gApzCOB.userDetails.insuranceDtlsId = insurance.insuranceDetails.insuranceDtlId;
                }
                if (parseInt(insurance.insuranceDetails.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId)) {
                    gApzCOB.userDetails.coAppInsuranceDtlsId = insurance.insuranceDetails.insuranceDtlId;
                }
            })
        }
    }
    // Setting Occupation dtls ID
    if (apz.isNull(gApzCOB.userDetails.occptDtlId)) {
        gApzCOB.userDetails.occptDtlId = "";
    }
    if (apz.isNull(gApzCOB.userDetails.coAppOccptDtlId)) {
        gApzCOB.userDetails.coAppOccptDtlId = ""
    }
    if (!apz.isNull(inSessionStore.occupationDetailsWrapperList)) {
        if (inSessionStore.occupationDetailsWrapperList.length > 0) {
            let occupationResponse = inSessionStore.occupationDetailsWrapperList;
            occupationResponse.map(occupation => {
                if (parseInt(occupation.occupationDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                    gApzCOB.userDetails.occptDtlId = occupation.occupationDetails.occptDtlId;
                }
                if (parseInt(occupation.occupationDetails.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId)) {
                    gApzCOB.userDetails.coAppOccptDtlId = occupation.occupationDetails.occptDtlId;
                }
            })
        }
    }
    // Setting CB dtls ID
    if (apz.isNull(gApzCOB.userDetails.cbDtlsId)) {
        gApzCOB.userDetails.cbDtlsId = "";
    }
    if (apz.isNull(gApzCOB.userDetails.coApplicantCbDtlsId)) {
        gApzCOB.userDetails.coApplicantCbDtlsId = ""
    }
    if (!apz.isNull(inSessionStore.cibilDetailsWrapperList)) {
        if (inSessionStore.cibilDetailsWrapperList.length > 0) {
            let cbResponse = inSessionStore.cibilDetailsWrapperList;
            cbResponse.map(cb => {
                if (parseInt(cb.cibilDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                    gApzCOB.userDetails.cbDtlsId = cb.cibilDetails.cbDtlId;
                }
                if (parseInt(cb.cibilDetails.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId)) {
                    gApzCOB.userDetails.coApplicantCbDtlsId = cb.cibilDetails.cbDtlId;
                }
            })
        }
    }
    if (apz.isNull(gApzCOB.userDetails.existingLoanId)) {
        gApzCOB.userDetails.existingLoanId = "";
    }
    if (!apz.isNull(inSessionStore.existingLoanDetailsWrapperList)) {
        if (inSessionStore.existingLoanDetailsWrapperList.length > 0) {
            if (!apz.isNull(inSessionStore.existingLoanDetailsWrapperList[0])) {
                let existLoanResponse = inSessionStore.existingLoanDetailsWrapperList[0].existingLoanDetailsList;
                gApzCOB.userDetails.existisingLoanDtlId = existLoanResponse.map(function(i) {
                    return i.existingLoanId;
                })
                gApzCOB.userDetails.existingLoanId = existLoanResponse.map(function(i) {
                    return i.loanDtlsId;
                })
            }
        }
    }
    if(apz.isNull(gApzCOB.userDetails.applicationStatus)){
      gApzCOB.userDetails.applicationStatus = inSessionStore?.applicationMaster?.applicationStatus  || ""; 
    }
}
apz.app.BaseScreens.checkDtlIds = function() {
    let lFlag = false, reqFlag = false, custFlag = false, addrFlag = false, loanFlag = false, cbFlag = false, insFlag= false, bankFlag = false, occFlag = false;
    reqFlag = !apz.isNull(gApzCOB.requestNodes);
    if (reqFlag) {
        custFlag = !apz.isNull(gApzCOB.requestNodes.customerDetailsList) && gApzCOB.requestNodes.customerDetailsList.length > 0;
        addrFlag = !apz.isNull(gApzCOB.requestNodes.addressDetailsWrapperList[0].addressDetailsList) && gApzCOB.requestNodes.addressDetailsWrapperList[0].addressDetailsList.length > 0;
        loanFlag = !apz.isNull(gApzCOB.requestNodes.loanDetails) && gApzCOB.requestNodes.loanDetails.length > 0;
        cbFlag = !apz.isNull(gApzCOB.requestNodes.cibilDetailsWrapperList) && gApzCOB.requestNodes.cibilDetailsWrapperList.length > 0;
        insFlag = !apz.isNull(gApzCOB.requestNodes.insuranceDetailsWrapperList) && gApzCOB.requestNodes.insuranceDetailsWrapperList.length > 0;
        bankFlag = !apz.isNull(gApzCOB.requestNodes.bankDetailsWrapperList) && gApzCOB.requestNodes.bankDetailsWrapperList.length > 0;
        occFlag = !apz.isNull(gApzCOB.requestNodes.occupationDetailsWrapperList) && gApzCOB.requestNodes.occupationDetailsWrapperList.length > 0;
    }
    if (backNav) {
        if (CURRENT_STAGE_NO === 3) {
            /**************CustomerDetails**************/
            if (!apz.isNull(gApzCOB.userDetails.custDtlId)) {
                lFlag = true;
            } else if (custFlag) {
                let custData = gApzCOB.requestNodes.customerDetailsList.filter(el => el.customerType === "Applicant");
                if (!apz.isNull(custData) && custData.length > 0) {
                    if (!apz.isNull(custData[0].custDtlId)) {
                        gApzCOB.userDetails.custDtlId = custData[0].custDtlId;
                        lFlag = true;
                    } else {
                        lFlag = false;
                    }
                } else {
                    lFlag = false;
                }
            } else {
                lFlag = false;
            }
            if (!lFlag) {
                return lFlag;
            }
            /**************AddressDetails**************/
            if (!apz.isNull(gApzCOB.userDetails.addressDtlsId)) {
                lFlag = true;
            } else if (addrFlag) {
                let addrData = gApzCOB.requestNodes.addressDetailsWrapperList[0].addressDetailsList.filter(el => el.custDtlId === gApzCOB.userDetails.custDtlId && el.addressType === 'Personal');
                if (!apz.isNull(addrData) && addrData.length > 0) {
                    if (!apz.isNull(addrData[0].addressDtlsId)) {
                        gApzCOB.userDetails.addressDtlsId = addrData[0].addressDtlsId;
                        lFlag = true;
                    } else {
                        lFlag = false;
                    }
                } else {
                    lFlag = false;
                }
            } else {
                lFlag = false;
            }
            if (!lFlag) {
                return lFlag;
            }
        } else if (CURRENT_STAGE_NO === 5) {
            /**************CustomerDetails**************/
            if (!apz.isNull(gApzCOB.userDetails.CoApplicantCustomerId)) {
                lFlag = true;
            } else if (custFlag) {
                let custData = gApzCOB.requestNodes.customerDetailsList.filter(el => el.customerType === "Co-App");
                if (!apz.isNull(custData) && custData.length > 0) {
                    if (!apz.isNull(custData[0].custDtlId)) {
