apz.app.BaseScreens.headerTabSwitchCB = function(params) {
    apz.stopLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            window.LoanStatusDtls = response;
            window.allArrDatatab = [];
            window.page_Txt = window.LoanStatusDtls.map.totalPages;
            if (window.pageCount == 1) {
                $("#Dashbo__NewDashBoard__paginationPrevBtn").prop("disabled", true);
            } else {
                $("#Dashbo__NewDashBoard__paginationPrevBtn").prop("disabled", false);
            }
            for (let i of response.map.pendingRPC.myArrayList) {
                allArrDatatab.push(i.map);
            }
            apz.app.NewDashBoard.formatLOan_TAT(allArrDatatab);
            apz.data.scrdata.Dashbo__IPaintDashCase_Res = allArrDatatab;
            apz.data.loadData('IPaintDashCase', 'Dashbo');
            apz.app.NewDashBoard.pageCountTxt(window.dashtab);
            apz.app.NewDashBoard.addPointer("");
            apz.app.NewDashBoard.rem_add_ActClass({"id":"Dashbo__NewDashBoard__allBtn"});
            if (response.map.pendingRPC.myArrayList.length === 0) {
                $(`#${scrId}appDetailsList`).addClass('sno');
                $(`#${scrId}recordNotavalible`).removeClass('sno');
            } else {
                $(`#${scrId}appDetailsList`).removeClass('sno');
                $(`#${scrId}recordNotavalible`).addClass('sno');
            }
        } else {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};
apz.app.BaseScreens.fetchRPCDashboardData = function(pfilterType, ptype, pthis, pgno) {
    var lcallback = "";
    if (gApzCOB.selectedRole === 'RPC_Maker' && window.rpcDashboardActiveType === 'PUSHBACK' && ['pushBack', 'all'].includes(pfilterType)) {
        pfilterType = "IPUSHBACK";
        if (pfilterType === 'all') {
            pgno = window.pageCount = 1;
        }
    }
    if (!apz.isNull(pgno) && pgno === 1) {
        window.pageCount = 1;
    }
    //var lsearchValue = $('#Dashbo__NewDashBoard__searchInput').val().trim();
    var lsearchValue = "";
    if (ptype === "roleSwitch") {
        gApzCOB.selectedRole = pthis?.value?.replaceAll(" ", "_");
        $("#APZCBO__BaseScreens__dashboardDownArrow").click();
        $('#Dashbo__NewDashBoard__searchInput').val("");
        $(`#Dashbo__NewDashBoard__tatSortDown,#Dashbo__NewDashBoard__tatSortUp`).attr('style', '');
        /*if (pthis.value === "RPC DB verification") {
            apz.app.NewDashBoard.launchDbMicroApp();
            return;
        }*/
        lcallback = apz.app.BaseScreens.fetchRoleCB;
    } else if (ptype === "headerTabSwitch") {
        lcallback = apz.app.BaseScreens.headerTabSwitchCB;
        $('#Dashbo__NewDashBoard__searchInput').val("");
    } else if (ptype === "tabSwitch") {
        window.dashtab = pfilterType;
        window.tabId = pthis;
        $('#Dashbo__NewDashBoard__searchInput').val("");
        lcallback = apz.app.BaseScreens.tabClickMyTaskCB;
    } else if (ptype = "searchApplication") {
        window.dashtab = pfilterType;
        window.tabId = pthis;
        lcallback = apz.app.BaseScreens.tabClickMyTaskCB;
        lsearchValue = $('#Dashbo__NewDashBoard__searchInput').val().trim();
    }
    var request = {
        "apiRequest": {
            "interfaceName": "FetchRPCRoleData",
            "appId": gAppId,
            "requestObj": {
                "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                "branchCode": gApzCOB.LoggedInUserDetails.loginResponse.addInfo2,
                "fetchType": "",
                "searchVal": lsearchValue, // searchval
                "roleId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.privs.roles[0],
                "filterType": pfilterType, // filtertype
                "pageNo": pgno, // pgno
                "fetchRole": gApzCOB.selectedRole
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "FetchRPCRoleData", "N", "N", request, false, lcallback);
};
apz.app.BaseScreens.onClickUploadDoc = function() {
    $(`#${BaseScrId}browseExceptionDoc`).click();
};
apz.app.BaseScreens.browsefile = function(fileObj, browseId, type) {
    groupCode = inSessionStore.applicationMaster.productGroupCode;
    selType = type;
    selCat = '';
    dragNdrop = true;
    FileSideBrowseId = browseId;
    let docName = "";
    if (type === "PennyExceptionDoc") {
        gAllowedFileTypes = {"png":"png","jpeg":"jpeg","jpg":"jpg","pdf":"pdf"};
        docName = "Pennyless exception";
    } else if (type === "ReAssesmentDoc") {
        docName = "ReAssesment Document";
    }
    // gAllowedFileTypesRPC = {"png":"png","jpeg":"jpeg","jpg":"jpg","pdf":"pdf"};
    var fileExtenName = fileObj?.value?.split('.')?.[1]?.toLocaleLowerCase();
    fileExtenName = fileExtenName?.replace(/,$/, "");
    let sizeInBytes = maxDocUploadSize * 1024;
    if (!Object.values(gAllowedFileTypes).includes(fileExtenName) || fileObj.files[0].size > sizeInBytes) {
        if (type === "PennyExceptionDoc") {
            errMsg = `Upload a valid File ( jpg, jpeg, png, pdf ) under ${ApzCOB.formatSize(sizeInBytes)}.`;
            ApzCOB.showRpcModals({
                text: errMsg,
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.RpcStageScreen.closeRPCErrMdl(); ApzCOB.toggleModal(BaseScrId + 'pennycheckmodal')"
                }
            }, "Error");
            ApzCOB.toggleModal(BaseScrId + 'pennycheckmodal');
        } else if (type === "ReAssesmentDoc") {
            errMsg = `Upload a valid File ( jpg, jpeg, png ) under ${ApzCOB.formatSize(sizeInBytes)}.`;
            ApzCOB.showRpcModals({
                text: errMsg,
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
                }
            }, "Error");
        } //Close
        return;
    }
    filesObj = fileObj;
    var fileToUpload = fileObj.files;
    localFileObj = {};
    localFileObj.filename = fileToUpload[0].name;
    localFileObj.filetype = fileToUpload[0].type;
    localFileObj.filePath = `${apz.appId}/${groupCode}/${gApzCOB.userDetails.applicationId}`;
    localFileObj.docType = selType;
    localFileObj.documentName = docName;
    localFileObj.fieldID = BaseScrId + browseId;
    localFileObj.srcScreen = "UPLOADDOCS";
    localFileObj.docSize = fileObj.files[0].size;
    localFileObj.productGroupCode = groupCode;
    localFileObj.isExistingCustomer = 'N';
    localFileObj.documentFileName = localFileObj.documentFormat = localFileObj.filename;
    localFileObj.documentLoc = `${apz.appId}/${localFileObj.filename}`;
    apz.app.BaseScreens.fileReader(fileObj, type);
    $(fileObj).val('')
}
apz.app.BaseScreens.fileReader = function(fileObj, type) {
    var FR = new FileReader();
    FR.readAsDataURL(fileObj.files[0]);
    FR.onload = function(e) {
        encodedImage = "";
        encodedImage = e.target.result.substr(e.target.result.indexOf(',') + 1, e.target.result.length);
        if (!apz.isNull(encodedImage)) {
            localFileObj.imgSrc = encodedImage;
            localFileObj.base64Value = encodedImage;
            ApzCOB.exceptionFileUpload(localFileObj, type);
            // if(type === "PennyExceptionDoc"){
            //  ApzCOB.exceptionFileUpload(localFileObj);   
            // } else if(type === "ReAssesmentDoc"){
            //  ApzCOB.fileUpload(localFileObj);   
            // }
            // ApzCOB.exceptionFileUpload(localFileObj);
            // document.getElementById(localFileObj.fieldID).value = "";
        }
    }
}
apz.app.BaseScreens.switchFilterType = function(name, type) {
    const validTypes = ["PENDING", "SUBMITTED", "PUSHBACK", "REJECTED", "CAPUSHBACK", "APPROVED", "DBKITVERIFIED", "DBPUSHBACK", 
        "CA_DEVIATION", "REASSESSMENT", "RESANCTION", "PRESANCTION", "LUC", "PENDINGLUCVERIFICATION","LUCVERIFIED"];
    if (!validTypes.includes(type)) {
        return '';
    }
    switch (name) {
        case 'Sourcing stage':
        case 'SOURCING':
            return `SOURCING|${type}`;
        case 'BM sourcing approval':
        case 'BM_APPROVAL':
            return `BM_APPROVAL|${type}`;
        case 'RPC verification':
        case 'RPC_VERIFICATION':
            return `RPC_VERIFICATION|${type}`;
        case 'Credit assessment':
        case 'CREDIT_ASSESSMENT':
            return `CREDIT_ASSESSMENT|${type}`;
        case 'Deviation/re-assesment':
        case 'DEVIATION_RA':
            return `DEVIATION_RA|${type}`;
        case 'Sanction':
        case 'SANCTION':
            return `SANCTION|${type}`;
        case 'Disbursement inprogress':
        case 'DISBURSEMENT_INPROGRESS':
            return `DISBURSEMENT_INPROGRESS|${type}`;
        case 'Rejected':
        case 'REJECTED':
            return `REJECTED|${type}`;
        case 'Post disbursement ':
        case 'POSTDISBRUSEMENT':
            return `POST_DISBURSEMENT|${type}`;
        case 'Overall leads':
        case 'OVERALLEADS':
            return `OVERALLEADS|${type}`;
        case 'Not actioned leads':
        case 'UNACTIONED_LEADS':
            return `UNACTIONED_LEADS|${type}`;
        case 'Disbursed':
        case 'DISBURSED':
            return `DISBURSED|${type}`;
        default:
            return '';
    }
};
apz.app.BaseScreens.fetchRoleData = function(name, status, pthis, pageNo, type) {
    let logUser = gApzCOB.LoggedInUserDetails.loginResponse.addInfo1;
    if (type === 'initial') {
        let match = pthis.id.match(/_(\d+)$/);
        window.selectedRow = match ? parseInt(match[1], 10) : null;
        if(['AM','ACM'].includes(logUser)&& name?.toUpperCase() === 'SANCTION'){
            status = 'PRESANCTION';
        } else {
           status = 'PENDING';
        }
        if(['BCM', 'AM', 'RM', 'DM', 'ACM', 'BM'].includes(logUser)&& name?.toUpperCase() === "DEVIATION/RE-ASSESMENT"){
            status = 'CA_DEVIATION';
        }
        if (name.trim()?.toUpperCase() === 'POST DISBURSEMENT') {
            status = 'LUC';
        }
    }
    if (type === 'progress' || type === 'initial') {
        window.totalRecords = 0;
        window.currentPage = 1;
    }
    window.selectedTitle = name;
    if (['next', 'prev'].includes(type)) {
        status = SELECTED_SUB_STATUS;
    }
    window.SELECTED_SUB_STATUS = status;
    var request = {
        "apiRequest": {
            "interfaceName": "FetchRole",
            "appId": gAppId,
            "requestObj": {
                "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                "branchCode": gApzCOB.LoggedInUserDetails.loginResponse.addInfo2,
                "roleId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.privs.roles[0],
                "filterType": apz.app.BaseScreens.switchFilterType(name, status),
                "pageNo": pageNo
            }
        }
    }
    request.apiRequest.requestObj.fetchType = 'NEW';
    if (ApplicationType === 'RENEWAL') {
        request.apiRequest.requestObj.fetchType = ApplicationType;
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "FetchRole", "N", "N", request, false, apz.app.BaseScreens.fetchRoleDataCB);
}
apz.app.BaseScreens.fetchRoleDataCB = function(params) {
    apz.startLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            window.newDashboardStoreData = [];
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            window.fetchRoleCount = response.map.DashboardCounts;
            window.storeTypeCount = response.map.DashboardApplications.total;
            window.newDashboardStoreData = response.map.DashboardApplications.content;
            apz.app.Dashboard.paintNewDashboardData(selectedTitle, SELECTED_SUB_STATUS);
            apz.stopLoader();
        } else {
            apz.app.Dashboard.handleActiveCard();
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    } catch (e) {
        apz.app.Dashboard.handleActiveCard();
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};
apz.app.BaseScreens.PreviewCreditAssessmentDocs = function() {
    ApzCOB.toggleModal(`${BaseScrId}PrevDocMdl`);
    apz.app.BaseScreens.paintDocuments();
};
apz.app.BaseScreens.paintDocuments = function() {
    let lcat = ["Dairy Doc","Kirana Doc","Tailoring Doc","Other Doc","Agriculture Doc","Salary Doc","Pension Doc","Rentalincome_Agg Doc"];
    $(`#${BaseScrId}image_prev_sec`).addClass('sno');
    $(`#${BaseScrId}image_list_sec`).removeClass('sno');
    let mainParentDiv = $(`#${BaseScrId}main_parent_row`);
    let mainCloneDiv = `${BaseScrId}docs_row_0`;
    mainParentDiv.html('');
    let cloneDiv = `${BaseScrId}image_block_0`;
    if (apz.isObjectEmpty(inSessionStore) || !inSessionStore.hasOwnProperty('applicationDocumentsWrapperList')) return;
    let documentResp = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList
    if (documentResp.length > 0) {
        let FilteredDocs = documentResp.filter(docs => lcat.indexOf(docs.payload.documentType) != -1);
        if (FilteredDocs.length >= 0) {
            let lDocTypes = [...new Set(FilteredDocs.map(item => item.payload.documentType))]
            lDocTypes.forEach((doc,index) => {
                let newId = ApzCOB.cloneDashboardDivs(mainCloneDiv, mainParentDiv, index + 1);
                $(`#${newId} .doctitle p span`).text(apz.app.BaseScreens.getDocNames(doc));
                let parentDiv = $(`#${newId} .imgBase`);
                parentDiv.html('');
                FilteredDocs.forEach((ldoc, index) => {
                    if(ldoc.payload.documentType == doc) {
                        let newSubId = ApzCOB.cloneDashboardDivs(cloneDiv, parentDiv, index + 1);
                        $(`#${newId} #${newSubId} .docName a.ett-hypl span`).text(ldoc.payload.documentFileName);
                        $(`#${newId} #${newSubId}`).attr('data-id', ldoc.appDocId);
                        $(`#${newId} #${newSubId}`).attr('data-doc-type', doc);
                        $(`#${newId} #${newSubId} .docSize`).text((ldoc.payload.docSize / 1024)?.toFixed(0));
                    }
                });
            });
        } else {
            ApzCOB.showRpcModals({
                text: "No Credit assessment documents found.",
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.BaseScreens.closeErrMdl()"
                }
            }, "Error");
            ApzCOB.toggleModal(`${BaseScrId}PrevDocMdl`);
        }
    } else {
        ApzCOB.showRpcModals({
            text: "No documents found.",
            Btn1: {
                text: "OK",
                onClick: "apz.app.BaseScreens.closeErrMdl()"
            }
        }, "Error");
        ApzCOB.toggleModal(`${BaseScrId}PrevDocMdl`);
        return;
    }
}
apz.app.BaseScreens.getDocNames = function(ldocName) {
    let name = ldocName;
    switch(ldocName) {
        case "Dairy Doc" :  name = "Business - Dairy"; break;
        case "Kirana Doc" :  name = "Business - Kirana"; break;
        case "Tailoring Doc" :  name = "Business - Tailoring"; break;
        case "Other Doc" :  name = "Business - Other"; break;
        case "Agriculture Doc" :  name = "Agriculture"; break;
        case "Salary Doc" :  name = "Salary"; break;
        case "Pension Doc" :  name = "Pension"; break;
        case "Rentalincome_Agg Doc" :  name = "Rental Agreement"; break;
    }
    return name;
};
apz.app.BaseScreens.closeErrMdl = function() {
    $(`#APZCBO__BaseScreens__SA_Error_modal_close`).click();
}

apz.app.BaseScreens.reAssesmentDocViewCB = function(params){
    apz.stopLoader();
    if (!apz.isNull(params.base64)) {
        $(`#${BaseScrId}imgPrevView`).attr('src', 'data:image/png;base64,' + params.base64);
        $(`#${BaseScrId}image_list_sec`).addClass('sno');
        $(`#${BaseScrId}image_prev_sec`).removeClass('sno');
    }
};

apz.app.BaseScreens.ViewDoc = function(pthis) {
    let documentId = $(pthis).parents('.uploadimg').attr('data-id');
    let docDetails = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.find(doc => parseInt(doc.appDocId) === parseInt(documentId));
    if(!apz.isObjectEmpty(docDetails)){
        let fileName = docDetails?.payload?.documentFileName;
        let callBackFn = apz.app.BaseScreens.reAssesmentDocViewCB;
        ApzCOB.downloadFileFromServer(fileName,callBackFn);
    }
}


apz.app.BaseScreens.imagePrevBack = function() {
    $(`#${BaseScrId}image_prev_sec`).addClass('sno');
    $(`#${BaseScrId}image_list_sec`).removeClass('sno');
};

apz.app.BaseScreens.paintImageLocationDetails = function (id, details) {
    const $img = $(id);
    const $window = $img.closest('.guillotine-window');
    if (details.latitude === "" || details.longitude === "" || details.uploadedTs === "") {
        $img.siblings('.img-details').remove();
        $window.siblings('.img-details').remove();
        return;
    }
    const uploadedDate = new Date(details.uploadedTs);
    const formattedDate = uploadedDate.toLocaleString('en-GB');
    const detailsHtml = `
        <div class="img-details" 
            style="text-align:center; font-size:12px; color:#333; line-height:1.4; 
                   display:flex; flex-wrap:wrap; justify-content:space-around;">
            <div><strong>Date / Time:</strong> ${formattedDate}</div>
            <div><strong>Location:</strong> ${details.latitude}, ${details.longitude}</div>
        </div>
    `;
    $img.siblings('.img-details').remove();
    $window.siblings('.img-details').remove();
    if ($window.length) {
        const $parent = $window.parent();
        $parent.css('display', 'block');
        $window.after(detailsHtml);
    } 
    else {
        const $parent = $img.parent();
        $parent.css('display', 'block');
        $img.after(detailsHtml);
    }
    if(details.documentFileName != window.ImageLocationDetails.documentFileName){
        window.ImageLocationDetails = {}
    }
};

apz.app.BaseScreens.closeDownloadReportMdl = function() {
    $(`#${BaseScrId}downloadReportMdl_close`).click();
    ApzCOB.toggleModal(`${BaseScrId}DownloadReport`);
}
apz.app.BaseScreens.getReport = function () {
    let reportType = apz.getElmValue(`APZCBO__BaseScreens__reportType`);
    let fromDate = $(`#${BaseScrId}fromDate`).val();
    let toDate = $(`#${BaseScrId}toDate`).val();
    function convertToISO(dateStr) {
        if (!dateStr) return "";
        const [dd, mm, yyyy] = dateStr.split("/");
        return `${yyyy}-${mm}-${dd}`;
    }

    fromDate = convertToISO(fromDate);
    toDate = convertToISO(toDate);
    if (apz.isNull(reportType) || reportType === '') {
        ApzCOB.fnDisplayMsg("Please select Report Type", "E");
        return;
    }
    if ((fromDate === '' || apz.isNull(fromDate))) {
        ApzCOB.fnDisplayMsg("Please select From Date", "E");
        return;
    }
    if ((toDate === '' || apz.isNull(toDate))) {
        ApzCOB.fnDisplayMsg("Please select To Date", "E");
        return;
    }

    let request = {
        "apiRequest": {
            "requestObj": {
                "reportType": reportType,
                "fromDate": fromDate,
                "toDate": toDate
            },
            "interfaceName": "FetchTATReport",
            "appId": gAppId
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "FetchTATReport", "N", "N", request, false, apz.app.BaseScreens.getReportCB);

}
apz.app.BaseScreens.getReportCB = function(params) {
    apz.stopLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let ifaceName = ApzCOB.GetInterfaceResMap(params);
            let response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            ApzCOB.convertBase64ToXLSX(response.fileData, response.fileName);
        } else {
            if (params.res.APZCBO__FetchTATReport_Res.apiResponse.ResponseBody.responseObj.length != 0) {
                let response = params.res.APZCBO__FetchTATReport_Res.apiResponse.ResponseBody.responseObj;
                ApzCOB.fnDisplayMsg(response, "E");
                return;
            }
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    } catch (error) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};

apz.app.BaseScreens.onChangeReportType = function(pthis) { 
    apz.setElmValue("APZCBO__BaseScreens__fromDate", "")
    apz.setElmValue("APZCBO__BaseScreens__toDate", "")
}
apz.app.BaseScreens.viewFullApplicationPreview = function(pthis) {
    let rowIndex = pthis.getAttribute("rowno");
    let applicationId = apz.data.scrdata.APZCBO__MasterSearchDetails_Res.data[rowIndex].applicationId;
    if(apz.isNull(applicationId) || applicationId ===''){
        ApzCOB.fnDisplayMsg("Application ID not found", "E");
        return;
    } else {
        $("#APZCBO__BaseScreens__finalSearch_close").click();
        apz.app.BaseScreens.launchPreviewScreen(applicationId);
    }
}

apz.app.BaseScreens.launchPreviewScreen = function(applnId) {
    var req = {
        apiRequest: {
            interfaceName: "",
            appId: gAppId,
            requestObj: {
                applicationId: applnId,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                appId: gApzCOB.userDetails.appId,
                versionNum: 1,
            },
        },
    };
    apz.startLoader();
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, "FetchApplication", "N", "N", req, false, apz.app.BaseScreens.launchPreviewScreenCB);
    }, 1000);
}
apz.app.BaseScreens.launchPreviewScreenCB = function(params) {
    let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            ApzCOB.fetchSubProduct();
            ApzCOB.launchMicroApp('cmnPre', 'commonPreview', 'APZCBO__BaseScreens__BaseDIV', '');
        } else {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(errMsg, "E");
        }
    } catch {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(errMsg, "E");
    }
};
