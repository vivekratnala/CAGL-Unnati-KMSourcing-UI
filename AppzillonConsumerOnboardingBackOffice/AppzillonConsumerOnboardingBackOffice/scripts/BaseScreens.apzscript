            /**************AddressDetails**************/
            if (!apz.isNull(gApzCOB.userDetails.CoApOccAddressDtlsId)) {
                lFlag = true;
            } else if (addrFlag) {
                let addrData = gApzCOB.requestNodes.addressDetailsWrapperList[0].addressDetailsList.filter(el => el.custDtlId === gApzCOB.userDetails.CoApplicantCustomerId && el.addressType === 'Occupation');
                if (!apz.isNull(addrData) && addrData.length > 0) {
                    if (!apz.isNull(addrData[0].addressDtlsId)) {
                        gApzCOB.userDetails.CoApOccAddressDtlsId = addrData[0].addressDtlsId;
