apz.app.BaseScreens.sortLeads = function(FilteredLeads) {
    let hotLeads = [],normalLeads = [], warmLeads = [];
    $.map(FilteredLeads, function(lea) {
        let Priority = '';
        if (!apz.isNull(lea.map) && !apz.isNull(lea.map.priority)) {
            Priority = lea.map.priority;
        } else if (!apz.isNull(lea) && !apz.isNull(lea.priority)) {
            Priority = lea.priority;
        }
        if (/^hot.*$/g.test(Priority.toLowerCase())) {
            hotLeads.push(lea);
        } else if (/^normal.*$/g.test(Priority.toLowerCase())) {
            normalLeads.push(lea);
        } else if (/^warm.*$/g.test(Priority.toLowerCase())) {
            warmLeads.push(lea);
        }
    });
    let newFilteredLeads = [], leadsObj = {hotLeads, warmLeads, normalLeads};
    for (let i in leadsObj) {
        newFilteredLeads = newFilteredLeads.concat(Array.isArray(leadsObj[i]) ? leadsObj[i] : []);
    }
    return newFilteredLeads;
}
