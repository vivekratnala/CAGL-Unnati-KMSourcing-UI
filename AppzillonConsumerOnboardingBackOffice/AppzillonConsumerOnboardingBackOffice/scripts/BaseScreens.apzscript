            }
            if (!lFlag) {
                return lFlag;
            }
        } else {
            lFlag = true;
        }
    } else {
        lFlag = true;
    }
    return lFlag;
}
apz.app.BaseScreens.closeSucModal = function() {
    window.selectedType = '';
    if ($("#" + BaseScrId + 'successModal').is(":visible")) {
        $('#' + BaseScrId + 'successModal_close').trigger('click');
        //ApzCOB.toggleModal(BaseScrId + 'successModal');
    } else if ($("#" + BaseScrId + 'depositSucModal').is(":visible")) {
        $('#' + BaseScrId + 'depositSucModal_close').trigger('click');
        //ApzCOB.toggleModal(BaseScrId + 'depositSucModal');
    } else if ($("#" + BaseScrId + 'NewLoanSuccessModal').is(":visible")) {
        $('#' + BaseScrId + 'NewLoanSuccessModal_close').trigger('click');
        //ApzCOB.toggleModal(BaseScrId + 'NewLoanSuccessModal');
    } else if ($('#Reside__ResPinCode__' + "ResidentialPinCodeModal").is(':visible')) {
        $('#' + BaseScrId + 'ResidentialPinCodeModal_close').trigger('click');
        //ApzCOB.toggleModal(ResiDenPinCDScrId + "ResidentialPinCodeModal");
    } else if ($("#" + BaseScrId + 'CardSuccessModal').is(":visible")) {
        $('#' + BaseScrId + 'CardSuccessModal_close').trigger('click');
        //ApzCOB.toggleModal(BaseScrId + 'CardSuccessModal');
    } else if ($("#" + BaseScrId + 'LoanSuccessModal').is(":visible")) {
        $('#' + BaseScrId + 'LoanSuccessModal_close').trigger('click');
        //ApzCOB.toggleModal(BaseScrId + 'LoanSuccessModal');
    } else if ($("#" + BaseScrId + 'successModalFund').is(":visible")) {
        $('#' + BaseScrId + 'successModalFund_close').trigger('click');
        //ApzCOB.toggleModal(BaseScrId + 'successModalFund');
    }
    UNATTENDED_DATA = false;
    ApzCOB.launchMicroApp('Dashbo', 'dashboard', 'APZCBO__BaseScreens__BaseDIV', '');
    // apz.app.BaseScreens.fetchRole();
}
apz.app.BaseScreens.closeRPCSucModal = function() {
    if ($("#" + BaseScrId + 'RpcfooterSucc_modal').is(":visible")) {
        $('#' + BaseScrId + 'RpcfooterSucc_modal_close').trigger('click');
    }
    ApzCOB.launchMicroApp('Dashbo', 'NewDashBoard', `${gAppId}__BaseScreens__BaseDIV`, window.dashTaskData);
}
apz.app.BaseScreens.search = function() {
    apz.startLoader();
    window.searchValue = apz.deviceType === "WEB" ? $("#" + BaseScrId + "searchByNum").val() : $("#" + DashboardScrId + "searchByNum").val()
    window.approveRejectAction = gaction;
    var req = {
        "apiRequest": {
            "interfaceName": "SearchApplication",
            "appId": gAppId,
            "requestObj": {
                //"appId": gApzCOB.userDetails.appId,
                "mobileOrApplnId": searchValue, //you can send either mobile number or application id
                "userId": apz.userId
            }
        }
    }
    ApzCOB.serverBuildParam(apz.appId, "SearchApplication", "N", "N", req, false, apz.app.BaseScreens.searchCB);
};
apz.app.BaseScreens.searchCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            var temp = []
            if (response.length > 0) {
                gSearchDetails = response;
                if (window.advancesearch) {
                    window.advancesearch = false;
                    //ApzCOB.toggleModal(BaseScrId + 'advancesearch');
                    $('#' + BaseScrId + 'advancesearch_close').trigger('click');
                    $("#APZCBO__BaseScreens__searchByNum_button").removeClass('sno');
                    $('#APZCBO__BaseScreens__searchByNum').attr("placeholder", ApzCOB.getDescfromLitCode("LIT_COMM_TITLE_TXT_SEARCHBYMOBREFNO"));
                }
                ApzCOB.launchMicroApp('Dashbo', 'SearchApplication', 'APZCBO__BaseScreens__BaseDIV', '');
                //apz.data.scrdata.Dashbo__PaintData_Res = {}
                apz.data.scrdata.Dashbo__PaintData_Res.SearchApp = [];
                $.each(response, function(a, b) {
                    var obj = {};
                    obj.createdBy = b.createdBy
                    obj.applicationStatus = b.applicationStatus;
                    obj.applicationId = b.applicationId;
                    obj.productCode = b.productCode;
                    obj.productGroupCode = b.productGroupCode;
                    obj.mobileNumber = b.mobileNumber;
                    obj.submittedDate = apz.deviceType === "IOS" ? b.createTs.date.year + "/" + b.createTs.date.month + "/" + b.createTs
                        .date.day : b.createTs.date.year + "-" + b.createTs.date.month + "-" + b.createTs.date.day;
                    temp.push(obj)
                })
                apz.data.scrdata.Dashbo__PaintData_Res.SearchApp = temp
            } else {
                $("#" + BaseScrId + "searchByNum").val("")
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_NORESULTFOUND"), "E");
            }
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
    apz.stopLoader();
};
apz.app.BaseScreens.fetchNominee = function() {
    var req = {
        "apiRequest": {
            "interfaceName": "CobFetchNominee",
            "appId": gAppId,
            "requestObj": {
                "applicationId": gApzCOB.userDetails.applicationId,
                "appId": gApzCOB.userDetails.appId,
                "custDtlId": gApzCOB.userDetails.custDtlId,
                "versionNum": gApzCOB.userDetails.versionNum
            }
        }
    }
    ApzCOB.serverBuildParam(gAppId, "FetchNominee", "N", "N", req, false, apz.app.BaseScreens.fetchNomineeCB);
}
apz.app.BaseScreens.fetchDepositNominee = function() {
    var req = {
        "apiRequest": {
            "interfaceName": "DepositFetchNominee",
            "requestObj": {
                "customerId": gApzCOB.userDetails.customerId,
            }
        }
    }
    ApzCOB.serverBuildParam(gAppId, "DepositFetchNominee", "N", "N", req, false, apz.app.BaseScreens.fetchNomineeCB);
};
apz.app.BaseScreens.fetchNomineeCB = function(params) {
    apz.stopLoader();
    window.NomineeList = [];
    apz.data.scrdata.NomDet__FetchNominee_Res = [];
    if (apz.childScr === "NomineeDetails") {
        $('#' + nomineeScrId + 'nomineeHeaderList').addClass('sno');
        $('#' + nomineeScrId + 'nomineeList').addClass('sno');
        $('#' + nomineeScrId + 'noNomineeRow').removeClass('sno');
        $('#' + nomineeScrId + 'addNewNomRow').removeClass('sno');
    }
    apz.data.scrdata.NomDet__FetchNominee_Res = [];
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var response = '';
            if (gApzCOB.product === 'CASA') {
                response = JSON.parse(params.res.APZCBO__FetchNominee_Res.apiResponse.ResponseBody.responseObj);
                for (var i = 0; i < response.length; i++) {
                    var data = JSON.parse(response[i]["payload"]);
                    data["versionNo"] = response[i]["versionNum"];
                    data["nomineeDtlsId"] = response[i]["nomineeDtlsId"];
                    apz.data.scrdata.NomDet__FetchNominee_Res.push(data);
                }
            } else if (gApzCOB.product === 'DEPOSIT') {
                if (gApzCOB.ExistingCustomer) {
                    response = JSON.parse(params.res.APZCBO__DepositFetchNominee_Res.apiResponse.ResponseBody.responseObj);
                    response = response['nomineeList'];
                    for (var i = 0; i < response.length; i++) {
                        var data = {};
                        data["versionNo"] = response[i]["versionNum"];
                        data["nomineeDtlsId"] = response[i]["nomineeId"];
                        data.nomineeName = response[i]['nomineeName'];
                        data.nomineeRelationship = response[i]['relationship'];
                        //data.versionNo = response[i]['relationship'];
                        data.nomineeDtlsId = response[i]["nomineeDtlsId"];
                        data.nomineeId = response[i]["nomineeId"];
                        data.accNum = response[i]["accNum"];
                        data.nomineeMobile = response[i]['mobileNum'];
                        data.nomineeEmail = response[i]['email'];
                        data.nomineeDob = response[i]['dateOfBirth'];
                        data.nomineeState = response[i]['state'];
                        data.nomineeCity = response[i]['city'];
                        data.nomineePincode = response[i]['pinCode'];
                        data.nomineeAddressLine1 = response[i]['addressLine1'];
                        data.nomineeAddressLine2 = response[i]['addressLine2'];
                        data.nomineeAddressLine3 = response[i]['addressLine3'];
                        data.nomineeLandMark = response[i]['landMark'];
                        data.guardianName = response[i]['guardianName'];
                        data.guardianMobile = response[i]['gmobile'];
                        data.guardianRelationship = response[i]['grelationship'];
                        data.guardianDob = response[i]['gdob'];
                        data.guardianEmail = response[i]['gemail'];
                        data.guardianState = response[i]['gstate'];
                        data.guardianCity = response[i]['gcity'];
                        data.guardianPincode = response[i]['gpinCode'];
                        data.guardianAddressLine1 = response[i]['gaddressLine1'];
                        data.guardianAddressLine2 = response[i]['gaddressLine2'];
                        data.guardianAddressLine3 = response[i]['gaddressLine3'];
                        data.guardianLandMark = response[i]['glandMark'];
                        apz.data.scrdata.NomDet__FetchNominee_Res.push(data);
                    }
                } else {
                    response = JSON.parse(params.res.APZCBO__FetchNominee_Res.apiResponse.ResponseBody.responseObj);
                    for (var i = 0; i < response.length; i++) {
                        var data = JSON.parse(response[i]["payload"]);
                        data["versionNo"] = response[i]["versionNum"];
                        data["nomineeDtlsId"] = response[i]["nomineeDtlsId"];
                        apz.data.scrdata.NomDet__FetchNominee_Res.push(data);
                    }
                }
            }
            if (apz.currAppId === "NomDet") {
                if (apz.data.scrdata.NomDet__FetchNominee_Res.length > 0) {
                    $('#' + nomineeScrId + 'noNomineeRow').addClass('sno');
                    $('#' + nomineeScrId + 'nomineeHeaderList').removeClass('sno');
                    $('#' + nomineeScrId + 'nomineeList').removeClass('sno');
                }
                apz.app.NomineeDetails.nomineeMandatoryCheck();
                apz.data.loadData('FetchNominee', apz.currAppId);
            } else {
                if (apz.data.scrdata.NomDet__FetchNominee_Res.length > 0) {
                    var nomineeName = [],
                        nomineeRel = [],
                        nomineeDob = [],
                        nomineeMobNo = [],
                        nomineeGrdName = [];
                    apz.data.scrdata.RevCof__IPaintData_Res = {}
                    for (var i = 0; i < apz.data.scrdata.NomDet__FetchNominee_Res.length; i++) {
                        nomineeName.push(apz.data.scrdata.NomDet__FetchNominee_Res[i].nomineeName)
                        nomineeRel.push(apz.data.scrdata.NomDet__FetchNominee_Res[i].nomineeRelationship);
                        nomineeDob.push(apz.data.scrdata.NomDet__FetchNominee_Res[i].nomineeDob);
                        nomineeMobNo.push(apz.data.scrdata.NomDet__FetchNominee_Res[i].nomineeMobile);
                        nomineeGrdName.push(apz.data.scrdata.NomDet__FetchNominee_Res[i].guardianName);
                    }
                    var nomineeDetails = []
                    $.each(nomineeName, function(a, b) {
                        var obj = {
                            "nomineeName": nomineeName[a],
                            "nomineeRelation": nomineeRel[a],
                            "nomineeDob": nomineeDob[a],
                            "nomineeMobNo": nomineeMobNo[a],
                            "nomineeGrdName": nomineeGrdName[a]
                        }
                        nomineeDetails.push(obj);
                    })
                    $('#' + rvwScrId + 'nomineeHeaderRow').removeClass('sno');
                    $('#' + rvwScrId + 'nomineeListRow').removeClass('sno');
                    $('#' + rvwScrId + 'noNomineeRow').addClass('sno');
                    apz.data.scrdata.RevCof__IPaintData_Res = nomineeDetails;
                    $.each(apz.data.scrdata.RevCof__IPaintData_Res, function(a, b) {
                        apz.data.scrdata.RevCof__IPaintData_Res[a].nomineeDob = ApzCOB.dateformatter(b.nomineeDob, 'd M y')
                        if (apz.isNull(b.nomineeGrdName)) {
                            apz.data.scrdata.RevCof__IPaintData_Res[a].nomineeGrdName = "N/A"
                        }
                        if (apz.isNull(b.nomineeMobNo)) {
                            apz.data.scrdata.RevCof__IPaintData_Res[a].nomineeMobNo = "---"
                        }
                    })
                    apz.data.loadData("IPaintData", apz.currAppId);
                } else {
                    $('#' + rvwScrId + 'nomineeHeaderRow').addClass('sno');
                    $('#' + rvwScrId + 'nomineeListRow').addClass('sno');
                    $('#' + rvwScrId + 'noNomineeRow').removeClass('sno');
                }
                if (gApzCOB.product === 'DEPOSIT') {
                    if (gApzCOB.ExistingCustomer) {
                        // apz.app.ReviewConfirm.nomineeDetails();
                    }
                }
            }
        } else {
            if (params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode === "IV100") {
                if (gApzCOB.demoMode !== "Y") {
                    ApzCOB.fnDisplayMsg(params.res[ifaceName].apiResponse.ResponseBody.responseObj, "E");
                }
            }
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};
//function to append workflow stage based on action
apz.app.BaseScreens.stageBasedOnAction = function(pthis, gaction) {
    var clickedAction = "";
    if (!apz.isNull(pthis)) {
        //on click of respective buttons
        clickedAction = $(pthis).text().toLocaleUpperCase().trim();
        if (!apz.isNull(gaction)) {
            if (gaction === 'REJECTED') {
                clickedAction = 'REJECT';
            } else if (['PUSHBACK', 'CAAPPROVE'].includes(gaction)) {
                clickedAction = gaction;
            }
        }
    } else {
        //application edit flow 
        if (window.currentApplication === "Rejected") {
            clickedAction = 'CONTINUE';
            if (ApplicationType === 'RENEWAL') {
                clickedAction = 'APPROVE';
            }
        } else if (apz.isNull(window.currentApplication)) {
            if (window.editappln) {
                clickedAction = 'EDIT';
            } else if (ApplicationType === 'RENEWAL') {
                clickedAction = 'APPROVE';
            } else {
                clickedAction = 'CONTINUE';
            }
        } else {
            clickedAction = 'CONTINUE';
        }
    }
    if (LoggedInUserDetails.loginResponse.addInfo1 == 'RPC') {
        if (!apz.isNull(gaction)) {
            if (gaction === 'APPROVED') {
                clickedAction = 'APPROVE';
            } else if (gaction === 'SUBMIT') {
                if (gApzCOB.selectedRole === 'RPC_Checker') {
                    clickedAction = 'APPROVE';
                } else {
                    clickedAction = 'SUBMIT';
                }
            } else if (gaction === 'RPCPUSHBACK') {
                clickedAction = 'RPCPUSHBACK';
            } else if (gaction === 'PUSHBACK') {
                clickedAction = 'PUSHBACK';
            }
        }
    }
    if (!apz.isNull(gApzCOB.applnWorkFlowRes)) {
        gApzCOB.applnWorkFlowRes.filter(function(laction) {
            laction.action.split(',').filter(function(s) {
                if (laction.appId === gAppId && clickedAction.split(" ").join("") === s.toLocaleUpperCase()) {
                    gApzCOB.workflow.currentRole = laction.currentRole;
                    gApzCOB.workflow.action = laction.action;
                    gApzCOB.workflow.workflowId = laction.workFlowId;
                    gApzCOB.workflow.stage = laction.fromStageId;
                }
            });
        });
    };
};
