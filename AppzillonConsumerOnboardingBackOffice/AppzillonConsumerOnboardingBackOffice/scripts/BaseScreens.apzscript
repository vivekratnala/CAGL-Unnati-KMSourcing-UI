            if (!apz.isNull(gApzCOB.requestNodes.bankingFacilityList[i]["payload"])) {
                var CurrentBankCustID = window.editappln ? gApzCOB.requestNodes.bankingFacilityList[custIndex]['custDtlId'] : gApzCOB.requestNodes
