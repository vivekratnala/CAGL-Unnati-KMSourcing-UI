apz.app.BaseScreens.tabClickMyTaskCB = function(params) {
    apz.stopLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            window.dashTaskData = response;
            $("#Dashbo__NewDashBoard__pageInputbox").val(window.pageCount);
            window.fresh_case = [];
            window.reworkCase = [];
            window.RPC_CM = [];
            window.allArrDatatab = [];
            window.totalpageCount = window.LoanStatusDtls.map.pendingRPC.myArrayList.length;
            window.page_Txt = response.map.totalPages;
            if (window.pageCount == 1) {
                $(`#${scrId}paginationPrevBtn`).prop("disabled", true);
            } else {
                $(`#${scrId}paginationPrevBtn`).prop("disabled", false);
            }
            if (window.dashtab == 'freshCases') {
                for (let i of response.map.pendingRPC.myArrayList) {
                    fresh_case.push(i.map);
                }
                apz.data.scrdata.Dashbo__IPaintDashCase_Res = {};
                apz.data.loadData('IPaintDashCase', 'Dashbo');
                apz.app.NewDashBoard.formatLOan_TAT(fresh_case);
                apz.data.scrdata.Dashbo__IPaintDashCase_Res = fresh_case;
                apz.data.loadData('IPaintDashCase', 'Dashbo');
                $(`#${scrId}searchInput`).css({'border-color': ''});
                $(`#Dashbo__NewDashBoard__tatSortDown,#Dashbo__NewDashBoard__tatSortUp`).attr('style','');
                apz.app.NewDashBoard.pageCountTxt(window.dashtab);
                apz.app.NewDashBoard.addPointer("");
            } else if (window.dashtab == 'reworkCases') {
                for (let i of response.map.pendingRPC.myArrayList) {
                    reworkCase.push(i.map);
                }
                apz.app.NewDashBoard.formatLOan_TAT(reworkCase);
                apz.data.scrdata.Dashbo__IPaintDashCase_Res = {};
                apz.data.loadData('IPaintDashCase', 'Dashbo');
                apz.data.scrdata.Dashbo__IPaintDashCase_Res = reworkCase;
                apz.data.loadData('IPaintDashCase', 'Dashbo');
                $(`#${scrId}searchInput`).css({'border-color': ''});
                $(`#Dashbo__NewDashBoard__tatSortDown,#Dashbo__NewDashBoard__tatSortUp`).attr('style','');
                apz.app.NewDashBoard.pageCountTxt(window.dashtab);
                apz.app.NewDashBoard.addPointer("");
            } else if (window.dashtab == 'all') {
                for (let i of response.map.pendingRPC.myArrayList) {
                    allArrDatatab.push(i.map);
                }
                apz.app.NewDashBoard.formatLOan_TAT(allArrDatatab);
                apz.data.scrdata.Dashbo__IPaintDashCase_Res = {};
                apz.data.loadData('IPaintDashCase', 'Dashbo');
                apz.data.scrdata.Dashbo__IPaintDashCase_Res = allArrDatatab;
                apz.data.loadData('IPaintDashCase', 'Dashbo');
                $(`#${scrId}searchInput`).css({'border-color': ''});
                $(`#Dashbo__NewDashBoard__tatSortDown,#Dashbo__NewDashBoard__tatSortUp`).attr('style','');
                apz.app.NewDashBoard.pageCountTxt(window.dashtab);
                apz.app.NewDashBoard.addPointer("");
            } else if (["rpcCheckerToMaker", "rpcPushBack", "allSentBack", "pushBack", "rpcVerified", "pendingForRPCVerification", "IPUSHBACK"].includes(window.dashtab)) {
                for (let i of response.map.pendingRPC.myArrayList) {
                    RPC_CM.push(i.map);
                }
                apz.app.NewDashBoard.formatLOan_TAT(RPC_CM);
                apz.data.scrdata.Dashbo__IPaintDashCase_Res = {};
                apz.data.loadData('IPaintDashCase', 'Dashbo');
                apz.data.scrdata.Dashbo__IPaintDashCase_Res = RPC_CM;
                apz.data.loadData('IPaintDashCase', 'Dashbo');
                $(`#${scrId}searchInput`).css({'border-color': ''});
                $(`#Dashbo__NewDashBoard__tatSortDown,#Dashbo__NewDashBoard__tatSortUp`).attr('style','');
                apz.app.NewDashBoard.pageCountTxt(window.dashtab);
                apz.app.NewDashBoard.addPointer("");
            }
            $(`#${scrId}appDetailsList`).scrollTop(0, 0);
            if (response.map.pendingRPC.myArrayList.length === 0) {
                $(`#${scrId}appDetailsList`).addClass('sno');
                $(`#${scrId}recordNotavalible`).removeClass('sno');
            } else {
                $(`#${scrId}appDetailsList`).removeClass('sno');
                $(`#${scrId}recordNotavalible`).addClass('sno');
            }
            apz.app.NewDashBoard.rem_add_ActClass(window.tabId);
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.showCommonErrRPCModal();
    }
};
//on role pop-over click
apz.app.BaseScreens.roleSwitch = function(params) {
    var request = {
        "apiRequest": {
            "interfaceName": "FetchRPCRoleData",
            "appId": gAppId,
            "requestObj": {
                "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                "branchCode": gApzCOB.LoggedInUserDetails.loginResponse.addInfo2,
                "fetchType": "",
                "searchVal": "",
                "roleId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.privs.roles[0],
                "filterType": "all",
                "pageNo": 1
            }
        }
    }
    request.apiRequest.requestObj.fetchType = 'NEW';
    if (ApplicationType === 'RENEWAL') {
        request.apiRequest.requestObj.fetchType = ApplicationType;
    }
    if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "RPC") {
        gApzCOB.selectedRole = params?.value?.replaceAll(" ", "_");
        request.apiRequest.requestObj.fetchRole = gApzCOB.selectedRole;
    }
    apz.startLoader()
    ApzCOB.serverBuildParam(gAppId, "FetchRPCRoleData", "N", "N", request, false, apz.app.BaseScreens.fetchRoleCB);
};
apz.app.BaseScreens.fetchRole = function(params) { // to fetch the roles according to the userid
    var request = {
        "apiRequest": {
            "interfaceName": "FetchRole",
            "appId": gAppId,
            "requestObj": {
                "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                "branchCode": gApzCOB.LoggedInUserDetails.loginResponse.addInfo2,
                "roleId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.privs.roles[0]
            }
        }
    }
    request.apiRequest.requestObj.fetchType = 'NEW';
    if (ApplicationType === 'RENEWAL') {
        request.apiRequest.requestObj.fetchType = ApplicationType;
    }
    if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "RPC") {
        gApzCOB.selectedRole = (params?.value != "") ? params?.value?.replaceAll(" ", "_") : gApzCOB.selectedRole;
        request.apiRequest.requestObj.fetchRole = gApzCOB.selectedRole;
    }
    if (dashBoardKey === "CREDIT_ASSESSMENT_PENDING" && gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "BM") {
        request.apiRequest.requestObj.filterType = "CREDIT_ASSESSMENT|PENDING";
    }
    apz.startLoader()
    ApzCOB.serverBuildParam(gAppId, "FetchRole", "N", "N", request, false, apz.app.BaseScreens.fetchRoleCB);
}
apz.app.BaseScreens.fetchRoleCB = function(params) {
    apz.stopLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            window.dashTaskData = response;
            window.dataCountDashboard = response?.map?.DashboardCounts;
            if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "RPC") {
                apz.app.Login.OnClickMakerChecker();
                return;
            }
             NEW_DASHBOARD_DATA = structuredClone(response);
            if (['KM','BM'].includes(gApzCOB.LoggedInUserDetails.loginResponse.addInfo1)) {
            status1 = response.map['allowedStatus'];
            leads = response.map['leadDtls'].myArrayList;
             FilteredLeads = apz.app.BaseScreens.sortLeads(response.map['fliteredLeadDtls'].myArrayList);
            }
            if (IS_DASHBOARD_COUNT_ENABLED.indexOf(ApplicationType) >= 0) {
                apz.app.Dashboard.showNewDashboardStats();
            } else {
                $('#Dashbo__dashboard__showDashBoardRow').removeClass('sno');
                $('#Dashbo__dashboard__dashboard_count').addClass('sno');
            }
            if (window.dashBoardKey === "CREDIT_ASSESSMENT_PENDING") {
                ApzCOB.launchMicroApp('Dashbo', 'CaDashboard', `${gAppId}__BaseScreens__BaseDIV`, window.dashTaskData);
            }
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};
