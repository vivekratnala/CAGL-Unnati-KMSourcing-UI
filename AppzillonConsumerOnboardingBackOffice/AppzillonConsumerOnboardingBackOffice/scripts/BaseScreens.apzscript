                        }
                        if (occupationAddindex >= 0) {
                            gApzCOB.userDetails.occAddressDtlsId = gApzCOB.requestNodes.addressDetailsWrapperList[0]["addressDetailsList"][i]
                                ["addressDtlsId"];
                            var obj = {
                                "addressDetailsList": []
