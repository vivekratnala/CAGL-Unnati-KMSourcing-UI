var leadsList = [], UniqueKendras = [], FilteredKendra = [], FilteredMeetDay = [];
var searchVal = "";
IS_SERVICE_CALLBACK = false;
var kendraIDTag = "AppLst__ApplicationList__kendraID";
var meetingDayTag = "AppLst__ApplicationList__meetingDay";
var PleaseSelect = ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT");
var meetVal = PleaseSelect, kendraVal = PleaseSelect;
