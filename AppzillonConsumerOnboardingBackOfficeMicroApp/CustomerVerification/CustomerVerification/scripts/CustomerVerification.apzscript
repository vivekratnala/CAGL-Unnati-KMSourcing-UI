apz.app.CustomerVerification.validateUserName = function() {
    if (gApzCOB.demoMode === 'N') {
        var name = $('#' + CustVerfScrId + 'name').val();
        var nameReg = (/[a-zA-Z]/g.test(name));
        if ($('#' + CustVerfScrId + 'name').is(':visible')) {
            if (nameReg) {
                $('#' + CustVerfScrId + 'nameErr').addClass('sno');
                return true;
            } else {
                $('#' + CustVerfScrId + 'nameErr').removeClass('sno');
                return false;
            }
        } else {
            return true;
        }
    } else {
        return true;
    }
}
apz.app.CustomerVerification.backNavigation = function() {
    if ($("#CusVer__CustomerVerification__customerDetailsDiv").hasClass("sno")) {
        otpVerified = true;
        $("#CusVer__CustomerVerification__customerDetailsDiv").removeClass("sno");
        $("#CusVer__CustomerVerification__Authentication_formOTP").addClass("sno");
    } else if ($("#CusVer__CustomerVerification__Authentication_formOTP").hasClass("sno")) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_CUSTVER_CONF_TXT_EXIT"), "C", apz.app.CustomerVerification.closeApp);
        $('.cancel').text("No");
        $('.ok').text("Yes");
    }
};
apz.app.CustomerVerification.closeApp = function(params) {
    if (params.choice === true) {
        var req = {
            "id": "CLOSELAUNCH_ID",
            "callBack": ''
        };
        apz.ns.closeApplication(req);
    } //Removed empty else block
};
apz.app.CustomerVerification.litCodeDescPropertyFile = function(params) {
    if (!apz.isNull(gDocumentTexts)) {
        gDocumentTexts.filter(function(el) {
            if (el.split('~')[0] === "LIT_CUSTVER_DLBL1") {
                $('#' + CustVerfScrId + 'nationalIdLabel').text(ApzCOB.getLitsDescfromServer(el.split('~')[0]));
            } else if (el.split('~')[0] === "LIT_CUSTVER_DLBL2") {
                $('#' + CustVerfScrId + 'nationalID').attr('placeholder', ApzCOB.getLitsDescfromServer(el.split('~')[0]));
            } else if (el.split('~')[0] === "LIT_CUSTVER_DLBL3") {
                $('#' + CustVerfScrId + 'nationalIdErr_txtcnt').text(ApzCOB.getLitsDescfromServer(el.split('~')[0]));
            }
        })
    }
};
apz.app.CustomerVerification.checkbox = function() {
    if ($('input:checkbox:checked').length === 0) {
        $("#CusVer__CustomerVerification__el_cbx_1").prop('checked', false);
        $("#CusVer__CustomerVerification__userNameDIv").removeClass('sno');
        $("#CusVer__CustomerVerification__el_label_2").text(ApzCOB.getDescfromLitCode("LIT_COMM_LBL_TXT_MOBILENO"));
        $("#" + CustVerfScrId + "mobileNumberDiv").removeClass("sno");
        $("#" + CustVerfScrId + "CustomerId").removeClass("sno");
    } else {
        $("#CusVer__CustomerVerification__el_cbx_1").prop('checked', true);
        $("#CusVer__CustomerVerification__userNameDIv").addClass('sno');
        $("#CusVer__CustomerVerification__el_label_2").text(ApzCOB.getDescfromLitCode("LIT_CUSTID_MOB"));
        $("#" + CustVerfScrId + "mobileNumberDiv").removeClass("sno");
        $("#" + CustVerfScrId + "CustomerId").removeClass("sno");
    }
};
apz.app.CustomerVerification.isExistingCheckbox = function() {
    gApzCOB.ExistingCustomer = $("#" + CustVerfScrId + "checkbox").is(':checked');
    if (gApzCOB.ExistingCustomer) {
        temp.forEach(function(el) {
            if (gApzCOB.product === "CARDS") {
                temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CARD_ETB").CUSTVERIFICATION;
                paramName = "CUSTVERIFICATION";
                paramValue = "CUSTVERIFICATION";
                codeType = "CARD_ETB";
                apz.app.BaseScreens.getCommomCodeBasedOnProduct();
            } else if (gApzCOB.product === "LOAN") {
                temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "LOAN_ETB").CUSTVERIFICATION;
                paramName = "CUSTVERIFICATION";
                paramValue = "CUSTVERIFICATION";
                codeType = "LOAN_ETB";
            } else {
                temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "DEPOSIT_ETB").CUSTVERIFICATION;
                paramName = "CUSTVERIFICATION";
                paramValue = "CUSTVERIFICATION";
                codeType = "DEPOSIT_ETB";
                /*if (el.split('~')[0] === 'CustomerID' && el.split('~')[1] === 'Y') {
                    $("#" + CustVerfScrId + "customerIdDiv").removeClass("sno");
                }*/
            }
        })
    } else {
        if (gApzCOB.product === "CARDS") {
            temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CARD_NTB").CUSTVERIFICATION;
            paramName = "CUSTVERIFICATION";
            paramValue = "CUSTVERIFICATION";
            codeType = "CARD_NTB";
        } else {
            temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CASA").CUSTVERIFICATION;
            paramName = "CUSTVERIFICATION";
            paramValue = "CUSTVERIFICATION";
            codeType = "CASA";
        }
        //$("#" + CustVerfScrId + "customerIdDiv").addClass("sno");
    }
    $("#" + CustVerfScrId + 'customerDetails').find('label').removeClass('req');
    $("#" + CustVerfScrId + 'customerDetails').find('input').trigger('onfocus');
    apz.app.CustomerVerification.configureFields();
};
$("#" + CustVerfScrId + 'infoIcn_ul').click(function() {
    apz.app.CustomerVerification.showGeneralInstructions();
})
apz.app.CustomerVerification.loadCustLitConf = function() {
    switch (gApzCOB.product) {
        case "CASA":
            loadData = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CASA");
            loadData["LITCODES"].forEach(function(el) {
                MainHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL4");
                InfoHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL5");
            });
            break;
        case "DEPOSIT":
            if (gApzCOB.ExistingCustomer) {
                loadData = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "DEPOSIT_ETB");
                loadData["LITCODES"].forEach(function(el) {
                    MainHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL6");
                    InfoHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL7");
                });
            } else {
                loadData = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CASA");
                loadData["LITCODES"].forEach(function(el) {
                    MainHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL6");
                    InfoHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL7");
                });
            }
            break;
        case "CARDS":
            loadData = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CARD_NTB");
            loadData["LITCODES"].forEach(function(el) {
                MainHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL8");
                InfoHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL9");
            });
            break;
        case "LOAN":
            if (gApzCOB.ExistingCustomer) {
                loadData = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "LOAN_NTB");
                loadData["LITCODES"].forEach(function(el) {
                    MainHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL10");
                    InfoHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL11");
                });
            } else {
                loadData = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CASA");
                loadData["LITCODES"].forEach(function(el) {
                    MainHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL10");
                    InfoHeadr = ApzCOB.getLitsDescfromServer("LIT_CUSTVER_DLBL11");
                });
            }
            break;
        default:
            break;
    }
    apz.setElmValue(CustVerfScrId + "el_txt_1_txtcnt", MainHeadr);
    apz.setElmValue(CustVerfScrId + "el_txt_5_txtcnt", InfoHeadr);
}
