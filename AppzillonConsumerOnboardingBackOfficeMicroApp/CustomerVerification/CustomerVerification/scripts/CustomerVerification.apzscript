    var a = {
        fieldName: 'Name',
        fieldId: [CustVerfScrId + 'name'],
        fieldDivId: [CustVerfScrId + 'userNameDIv']
    };
    var b = {
        fieldName: 'MobileNo',
        fieldId: [CustVerfScrId + 'mobileNumber'],
        fieldDivId: [CustVerfScrId + 'mobileNumberDiv']
    };
    var c = {
        fieldName: 'Email',
        fieldId: [CustVerfScrId + 'email'],
        fieldDivId: [CustVerfScrId + 'emailDiv']
    };
    var d = {
        fieldName: 'NIDInput',
        fieldId: [CustVerfScrId + 'nationalID'],
        fieldDivId: [CustVerfScrId + 'nationalIDDiv']
    };
    var e = {
        fieldName: 'PANInput',
        fieldId: [CustVerfScrId + 'panNumber'],
        fieldDivId: [CustVerfScrId + 'panNumberDiv']
    };
    var f = {
        fieldName: 'GenralInst',
        fieldDivId: [CustVerfScrId + 'generalInstDiv']
    };
    var g = {
        fieldName: 'PanVerify',
        fieldDivId: [CustVerfScrId + 'panVerifyDiv']
    };
    var h = {
        fieldName: 'CustomerID',
        fieldId: [CustVerfScrId + 'customerID'],
        fieldDivId: [CustVerfScrId + 'customerIdDiv']
    };
    ApzCOB.ConfigureFields([a, b, c, d, e, f, g, h], paramName, paramValue, "", codeType);
    // ApzCOB.ConfigureFields([{
    //     'fieldName': 'Name',
    //     'fieldId': [CustVerfScrId + 'name'],
    //     'fieldDivId': [CustVerfScrId + 'userNameDIv']
    // }, {
    //     'fieldName': 'MobileNo',
    //     'fieldId': [CustVerfScrId + 'mobileNumber'],
    //     'fieldDivId': [CustVerfScrId + 'mobileNumberDiv']
    // }, {
    //     'fieldName': 'Email',
    //     'fieldId': [CustVerfScrId + 'email'],
    //     'fieldDivId': [CustVerfScrId + 'emailDiv']
    // }, {
    //     'fieldName': 'NIDInput',
    //     'fieldId': [CustVerfScrId + 'nationalID'],
    //     'fieldDivId': [CustVerfScrId + 'nationalIDDiv']
    // }, {
    //     'fieldName': 'PANInput',
    //     'fieldId': [CustVerfScrId + 'panNumber'],
    //     'fieldDivId': [CustVerfScrId + 'panNumberDiv']
    // }, {
    //     'fieldName': 'GenralInst',
    //     'fieldDivId': [CustVerfScrId + 'generalInstDiv']
    // }, {
    //     'fieldName': 'PanVerify',
    //     'fieldDivId': [CustVerfScrId + 'panVerifyDiv']
    // }], 'CUSTVERIFICATION', 'CUSTVERIFICATION');
    ApzCOB.showCountrycodeFlag(CustVerfScrId, "regnFlag")
}
apz.app.CustomerVerification.getCommomCodeBasedOnProduct = function() {
    switch (gApzCOB.product) {
        case "CASA":
            temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CASA").CUSTVERIFICATION;
            paramName = "CUSTVERIFICATION";
            paramValue = "CUSTVERIFICATION";
            codeType = "CASA";
            break;
        case "DEPOSIT":
            if (gApzCOB.ExistingCustomer) {
                temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "DEPOSIT_ETB").CUSTVERIFICATION;
                paramName = "CUSTVERIFICATION";
                paramValue = "CUSTVERIFICATION";
                codeType = "DEPOSIT_ETB";
                break;
            } else {
                temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CASA").CUSTVERIFICATION;
                paramName = "CUSTVERIFICATION";
                paramValue = "CUSTVERIFICATION";
                codeType = "CASA";
                break;
            }
            case "CARDS":
                if (gApzCOB.ExistingCustomer) {
                    temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CARD_ETB").CUSTVERIFICATION;
                    paramName = "CUSTVERIFICATION";
                    paramValue = "CUSTVERIFICATION";
                    codeType = "CARD_ETB";
                    break;
                } else {
                    temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CARD_NTB").CUSTVERIFICATION;
                    paramName = "CUSTVERIFICATION";
                    paramValue = "CUSTVERIFICATION";
                    codeType = "CARD_NTB";
                    break;
                }
                case "LOAN":
                    if (gApzCOB.ExistingCustomer) {
                        temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "LOAN_ETB").CUSTVERIFICATION;
                        paramName = "CUSTVERIFICATION";
                        paramValue = "CUSTVERIFICATION";
                        codeType = "LOAN_ETB";
                        break;
                    } else {
                        temp = ApzCOB.GetCommonCodes("CUSTVERIFICATION", "CASA").CUSTVERIFICATION;
                        paramName = "CUSTVERIFICATION";
                        paramValue = "CUSTVERIFICATION";
                        codeType = "CASA";
                        break;
                    }
                    default:
                        break;
    }
};
//To reset the Otp field.
apz.app.CustomerVerification.clearvalue = function() {
    if (apz.deviceType !== "WEB") {
        for (var i = 1; i <= pwdMaximumLength; i++) {
            $("#" + CustVerfScrId + "otp_" + i).val("");
        }
    }
};
//To start the timer value in otp screen.
apz.app.CustomerVerification.startTimer = function(timerval) {
    var counter;
    counter = new timerCounter();
    $("#" + CustVerfScrId + "Resendotp").addClass("sno");
    $("#" + CustVerfScrId + "otpExpireDiv").removeClass("sno");
    counter.init(CustVerfScrId + "otptimertext_txtcnt", timerval);
};
//Generate otp service
apz.app.CustomerVerification.GenerateOTP = function() {
    //var OTPuserID = apz.isNull(gApzCOB.userDetails.userName) ? gApzCOB.userDetails.mobileNum : gApzCOB.userDetails.userName;
    var OTPuserID = !apz.isNull(gApzCOB.userDetails.userName) ? gApzCOB.userDetails.userName : !apz.isNull(gApzCOB.userDetails.mobileNum) ?
        gApzCOB.userDetails.mobileNum : !apz.isNull(gApzCOB.userDetails.customerId) ? gApzCOB.userDetails.customerId : ""
    //apz.userId = gApzCOB.userDetails.mobileNum;
    otpFieldNumber = 0;
    apz.app.CustomerVerification.clearvalue();
    var req = {
        "apiRequest": {
            "interfaceName": "GenerateOtp",
            "appId": apz.currAppId,
            "userId": OTPuserID,
            "requestObj": {
                "payload": {}
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "AuthenticationService", "N", "N", req, true, apz.app.CustomerVerification.GenerateOTPCB);
};
//Generate otp service callback
apz.app.CustomerVerification.GenerateOTPCB = function(params) {
    otpVerified = false;
    if (ApzCOB.handleServiceCallBacks(params)) {
        var tempOtpObj = JSON.parse(params.res.APZCBO__AuthenticationService_Res.apiResponse.ResponseBody.responseObj)
        var tempRefNo = params.res.APZCBO__AuthenticationService_Res.apiResponse.ResponseBody.responseObj.split('\n').filter(data => data.indexOf("RefNo") !==
            -1);
        tempRefNo = (tempRefNo[0].split(":")[1]).replace(' ', "");
        var refNo = tempRefNo.replace(",", "");
        tempOtpObj.RefNo = refNo
        $("#" + CustVerfScrId + "OTPRefno").text(tempOtpObj.RefNo);
        $("#" + CustVerfScrId + "dummyotptxt").text(tempOtpObj.otp);
        apz.app.CustomerVerification.startTimer(tempOtpObj.otpExpiry);
        $("#" + CustVerfScrId + "otp").attr("maxlength", tempOtpObj.otpLength);
        //  document.getElementById(CustVerfScrId + "otp").type = (apz.deviceType === 'WEB' ? 'password' : "tel");
        document.getElementById(CustVerfScrId + "otp").type = "tel";
        $("#" + CustVerfScrId + "otp").addClass('mask');
        $("#" + CustVerfScrId + "expiryDIV").removeClass("sno");
        $("#" + CustVerfScrId + "otpsubmit").removeClass("sno");
        $("#" + CustVerfScrId + "otpconfirm").removeClass("sno");
        if (apz.deviceType !== "WEB") {
            apz.stopLoader();
        }
        $("#" + CustVerfScrId + "otp").focus();
        apz.stopLoader();
    } else {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_CUSTVER_ERR_TXT_OTP_GENERATION_FAILED"), $("#" + CustVerfScrId + "otpcancel").trigger("onclick"));
    }
};
$("#" + CustVerfScrId + "otp").keypress(function(e) {
    if (e.which === 13 && apz.deviceType === "WEB") {
        apz.app.CustomerVerification.screenLaunch();
    }
});
// validate otp service
apz.app.CustomerVerification.validate_otp = function() {
    if (ApzCOB.validateConfFields()) {
        apz.app.CustomerVerification.ValidateOTP()
    }
}
// validate otp service
apz.app.CustomerVerification.ValidateOTP = function(params) {
    //var OTPuserID = apz.isNull(gApzCOB.userDetails.userName) ? gApzCOB.userDetails.mobileNum : gApzCOB.userDetails.userName;
    var OTPuserID = !apz.isNull(gApzCOB.userDetails.userName) ? gApzCOB.userDetails.userName : !apz.isNull(gApzCOB.userDetails.mobileNum) ?
        gApzCOB.userDetails.mobileNum : !apz.isNull(gApzCOB.userDetails.customerId) ? gApzCOB.userDetails.customerId : ""
    var req = {
        "apiRequest": {
            "interfaceName": "ValidateOtp",
            "appId": apz.appId,
            "userId": OTPuserID,
            "requestObj": {
                "RefNo": $("#" + CustVerfScrId + "OTPRefno").text(),
                "otp": $("#" + CustVerfScrId + "otp").val(),
                "payload": {}
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "AuthenticationService", "N", "N", req, false, apz.app.CustomerVerification.ValidateOTPCB);
};
// validate otp service callback
apz.app.CustomerVerification.ValidateOTPCB = function(params) {
    otpFieldNumber = 0;
    //apz.stopLoader();
    apz.app.CustomerVerification.clearvalue();
    if (ApzCOB.handleServiceCallBacks(params)) {
        otpVerified = true;
        var tempOtpObj = JSON.parse(params.res.APZCBO__AuthenticationService_Res.apiResponse.ResponseBody.responseObj);
        if (tempOtpObj.Status === "success" && tempOtpObj.OTPValServiceResponse.status === "Y") {
            gApzCOB.OTPRefno = $("#" + CustVerfScrId + "OTPRefno").text();
            if (!approvedApplication) {
                // if (apz.deviceType !== "WEB") {
                apz.app.CustomerVerification.screenLaunch();
                //  }
            }
        } else {
            apz.stopLoader();
            $("#" + CustVerfScrId + "otp").val("");
            $("#" + CustVerfScrId + "otp").focus();
            apz.app.CustomerVerification.clearvalue();
            if (!apz.isNull(tempOtpObj.OTPValServiceResponse)) {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_CUSTVER_ERR_TXT_INCORRECT_OTP") + " " + tempOtpObj.OTPValServiceResponse["Attempts Left"] +
                    " " + ApzCOB.getDescfromLitCode("LIT_CUSTVER_ERR_TXT_ATTEMPT_LEFT"));
                otpVerified = false;
            } else {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_CUSTVER_INFO_TXT_OTPEXPIRED"));
                otpVerified = false;
                $("#CusVer__CustomerVerification__otpExpireDiv").addClass('sno');
                $("#CusVer__CustomerVerification__Resendotp").removeClass('sno');
            }
        }
    } else {
        apz.stopLoader();
        $("#" + CustVerfScrId + "otp").val("");
        $("#" + CustVerfScrId + "otp").focus();
        apz.app.CustomerVerification.clearvalue();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_CUSTVER_ERR_TXT_WRONGOTP"));
        otpVerified = false;
    }
};
//hide and show password on eye icon click
apz.app.CustomerVerification.HideShowPassword = function() {
    //var otptype = document.getElementById(CustVerfScrId + "otp").type;
    if ($("#" + CustVerfScrId + 'eyeClose').hasClass('sno')) {
        $("#" + CustVerfScrId + "otp").removeClass("mask");
        $("#" + CustVerfScrId + 'eyeClose').removeClass('sno')
        $("#" + CustVerfScrId + 'eyeOpen').addClass('sno')
    } else {
        $("#" + CustVerfScrId + "otp").addClass("mask");
        $("#" + CustVerfScrId + 'eyeClose').addClass('sno')
        $("#" + CustVerfScrId + 'eyeOpen').removeClass('sno')
    }
};
apz.app.CustomerVerification.letsStart = function() {
    /**
     * @author praisy.b
     * @since 04.06.21
     * Added fix for below issue
     * No mobile number validation
     **/
    window.isMobErr = false;
    if (!apz.isNull($('#' + CustVerfScrId + 'mobileNumber').val())) {
        ApzCOB.fnValidateMobileNumber(CustVerfScrId + 'mobileNumber');
    }
    var Email = $("#" + CustVerfScrId + 'email').val()
    apz.app.serReqList = [];
    apz.app.serReqList.push(Email);
    if ($("#" + CustVerfScrId + 'customerDetailsDiv').is(':visible') && !window.isMobErr && ApzCOB.validateConfFields()) {
        if (panEnabledorDisabled === "Y" && panMandatory === "M") {
            if ((panVerifybutton === "Y" && window.panVerified) || (window.panWithoutService && panMandatory === "N")) {
                apz.app.CustomerVerification.screenLaunch()
            } else {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_CUSTVER_ERR_TXT_VERIFY_PAN"), "E");
            }
        } else {
            apz.app.CustomerVerification.screenLaunch();
            /*if (gApzCOB.product === 'DEPOSIT') {
                ApzCOB.FetchCustomerDetails();
            } else {
                apz.app.CustomerVerification.screenLaunch();
            }*/
        }
    } else {
        window.isMobErr = false;
    }
};
//Screen launch navigation for customer verification sreen.
apz.app.CustomerVerification.screenLaunch = function() {
    var nextDivLaunch = true;
    var objNodeName = '';
    var mobileNum = '';
    if ($('#' + BaseScrId + 'newCustomerModal').is(':visible')) {
        ApzCOB.toggleModal(BaseScrId + 'newCustomerModal');
    }
    if (window.COUNTRYCODE === 'Y') {
        if (ApzCOB.GetCommonCodes("COUNTRYCODE", "COMM").COUNTRYCODE[0].includeInReq === "Y") {
            var mobNo = $('#' + CustVerfScrId + 'mobileNumber').val();
            gApzCOB.userDetails.mobileNum = mobNo === '' ? '' : $('#' + CustVerfScrId + 'regnFlag').val() + " " + $('#' + CustVerfScrId + 'mobileNumber')
                .val();
            mobileNum = mobNo === '' ? '' : $('#' + CustVerfScrId + 'regnFlag').val() + " " + $('#' + CustVerfScrId + 'mobileNumber').val();
        } else {
            gApzCOB.userDetails.mobileNum = $('#' + CustVerfScrId + 'mobileNumber').val();
            mobileNum = $('#' + CustVerfScrId + 'mobileNumber').val();
        }
    } else {
        gApzCOB.userDetails.mobileNum = $('#' + CustVerfScrId + 'mobileNumber').val();
        mobileNum = $('#' + CustVerfScrId + 'mobileNumber').val();
    }
    gApzCOB.userDetails.userName = $('#' + CustVerfScrId + 'name').val();
    // gApzCOB.userDetails.nationalId = $('#' + CustVerfScrId + 'aadharNumber').val();
    gApzCOB.userDetails.nationalId = $('#' + CustVerfScrId + 'nationalID').val();
    gApzCOB.userDetails.panNum = $('#' + CustVerfScrId + 'panNumber').val().toLocaleUpperCase();
    gApzCOB.userDetails.email = $('#' + CustVerfScrId + 'email').val();
    gApzCOB.userDetails.customerId = $('#' + CustVerfScrId + 'customerID').val();
    gApzCOB.userDetails.existingCustomer = $('#' + CustVerfScrId + 'checkbox').is(':checked') ? 'Y' : 'N';
    if (ApzCOB.validateConfFields()) {
        if (!apz.isNull(gApzCOB.userDetails.mobileNum) || !apz.isNull(gApzCOB.userDetails.email) || !apz.isNull(gApzCOB.userDetails.customerId)) {
            objNodeName = "withAuth";
        } else {
            objNodeName = "withoutAuth";
        }
        CustVerLookUp[objNodeName].split('|').forEach(function(a, b) {
            if (nextDivLaunch && $('#' + CustVerfScrId + a).is(":visible")) {
                if (!otpVerified) {
                    if (a === "customerDetailsDiv") {
                        $("#" + BaseScrId + "loginMainScreen").removeClass('sno');
                        apz.app.CustomerVerification.HideShowPassword();
                        apz.app.CustomerVerification.GenerateOTP();
                        $('#' + CustVerfScrId + 'otpMobileNo').text(apz.lits[apz.currAppId][apz.language]["LIT_CUSTVER_TITLE_TXT_OTP_SENT"] + " " +
                            mobileNum /*.substring(0, 2) + 'xxxxxx' + gApzCOB.userDetails.mobileNum.substring(7 + 1)*/
                            ); //To Mask Mobile Number
                        $('#' + CustVerfScrId + CustVerLookUp[objNodeName].split('|')[b]).addClass('sno');
                        $('#' + CustVerfScrId + CustVerLookUp[objNodeName].split('|')[b + 1]).removeClass('sno');
                        nextDivLaunch = false;
                        return;
                    } else if (a === "Authentication_formOTP") {
                        apz.app.CustomerVerification.ValidateOTP();
                        return;
                    }
                }
                if (otpVerified) {
                    $("#APZCBO__BaseScreens__sidebarController").removeClass('sno');
                    if (CustVerLookUp[objNodeName].split('|')[b + 1] === "pendingApplicationDiv" || CustVerLookUp[objNodeName].split('|')[
                            b + 1] === "pendingAppDiv") {
                        if (gApzCOB.product === 'CASA') {
                            ApzCOB.VerifyApplication();
                        } else if (gApzCOB.product === 'DEPOSIT') {
                            if (gApzCOB.ExistingCustomer) {
                                ApzCOB.DepositVerifyApplication();
                            } else {
                                ApzCOB.VerifyApplication();
                            }
                            //ApzCOB.DepositVerifyApplication();
                        } else if (gApzCOB.product === "CARDS") {
                            ApzCOB.CardVerifyApplication();
                        } else if (gApzCOB.product === 'LOAN') {
                            if (gApzCOB.ExistingCustomer) {
                                ApzCOB.LoanVerifyApplication();
                            } else {
                                ApzCOB.VerifyApplication();
                            }
                        }
                        $("#" + BaseScrId + 'DipInfoTile').text(ApzCOB.getDescfromLitCode('LIT_CUSTVER_INFO_TXT_INFORMATION'))
                        $("#" + BaseScrId + 'DipInfoContent').text(ApzCOB.getDescfromLitCode('LIT_CUSTVER_INFO_TXT_NEWCUSTBANKOPENSAVINGSACCASSDEPOSIT'))
                        $("#" + BaseScrId + 'LoanInfoTitle').text(ApzCOB.getDescfromLitCode('LIT_CUSTVER_INFO_TXT_INFORMATION'))
                        $("#" + BaseScrId + 'LoanInfoContent').text(ApzCOB.getDescfromLitCode('LIT_CUSTVER_INFO_TXT_NEWCUSTBANKOPENSAVINGSACCASSLOAN'))
                        $("#" + BaseScrId + 'NewCustContiBtnTxt').text(ApzCOB.getDescfromLitCode('LIT_CUSTVER_BTN_TXT_CONTINUE'));
                        $("#" + BaseScrId + 'NewCustExitBtnTxt').text(ApzCOB.getDescfromLitCode('LIT_CUSTVER_BTN_TXT_EXIT'));
                    } else {
                        $('#' + CustVerfScrId + CustVerLookUp[objNodeName].split('|')[b]).addClass('sno');
                        $('#' + CustVerfScrId + CustVerLookUp[objNodeName].split('|')[b + 1]).removeClass('sno');
                        nextDivLaunch = false;
                        return;
                    }
                }
            }
        })
    }
}
apz.app.CustomerVerification.showGeneralInstructions = function() {
    var genrlInst = [];
    var data = '';
    if (gApzCOB.product === 'CASA') {
        data = ApzCOB.GetCommonCodes("GENERALINSTRUCTIONS", "CASA")["GENERALINSTRUCTIONS"]
    }
    if (gApzCOB.product === 'DEPOSIT') {
        if (gApzCOB.ExistingCustomer) {
            data = ApzCOB.GetCommonCodes("GENERALINSTRUCTIONS", "DEPOSIT_ETB")["GENERALINSTRUCTIONS"]
        } else {
            data = ApzCOB.GetCommonCodes("GENERALINSTRUCTIONS", "CASA")["GENERALINSTRUCTIONS"]
        }
    }
    if (gApzCOB.product === 'CARDS') {
        if (gApzCOB.ExistingCustomer) {
            data = ApzCOB.GetCommonCodes("GENERALINSTRUCTIONS", "CARD_ETB")["GENERALINSTRUCTIONS"]
        } else {
            data = ApzCOB.GetCommonCodes("GENERALINSTRUCTIONS", "CARD_NTB")["GENERALINSTRUCTIONS"]
        }
    }
    if (gApzCOB.product === 'LOAN') {
        if (gApzCOB.ExistingCustomer) {
            data = ApzCOB.GetCommonCodes("GENERALINSTRUCTIONS", "LOAN_ETB")["GENERALINSTRUCTIONS"]
        } else {
            data = ApzCOB.GetCommonCodes("GENERALINSTRUCTIONS", "CASA")["GENERALINSTRUCTIONS"]
        }
    }
    $.each(data, function(i, k) {
        if (k.split("~")[2] === "Y") {
            var obj = {
                "images": k.split("~")[0],
                "value": k.split("~")[1]
            }
            genrlInst.push(obj)
        }
    })
    apz.data.scrdata.CusVer__IPaintGeneralIns_Res = {};
    apz.data.loadData("IPaintGeneralIns", "CusVer");
    apz.data.scrdata.CusVer__IPaintGeneralIns_Res = genrlInst;
    apz.data.loadData("IPaintGeneralIns", "CusVer");
}
apz.app.CustomerVerification.toggleModal = function() {
    $('#' + CustVerfScrId + 'customerDetailsDiv').trigger('click')
}
var count = 0;
apz.app.CustomerVerification.applicationType = function() {
    count += 1;
    if (count % 2 !== 0) {
        $('#' + CustVerfScrId + 'singleAcbtn').removeClass('active');
        $('#' + CustVerfScrId + 'jointAcbtn').addClass('active')
    } else {
        $('#' + CustVerfScrId + 'singleAcbtn').addClass('active')
        $('#' + CustVerfScrId + 'jointAcbtn').removeClass('active')
    }
}
