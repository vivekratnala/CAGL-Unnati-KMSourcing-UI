var CustVerfScrId = 'CusVer__CustomerVerification__',
    otpFieldNumber = 0,
    pwdMaximumLength = 6,
    OTPDIV = CustVerfScrId + "Authentication_formOTP",
    otpVerified = false,
    paramName = "",
    paramValue = "",
    codeType = "";
//window.isExisting = false;
gApzCOB.ExistingCustomer = gApzCOB.product === 'DEPOSIT' || gApzCOB.product === "CARDS" || gApzCOB.product === "LOAN" ? false : "";
var CustVerLookUp = {
    "withAuth": "customerDetailsDiv|Authentication_formOTP|pendingAppDiv|pendingApplicationDiv",
    "withoutAuth": "customerDetailsDiv|pendingAppDiv|pendingApplicationDiv"
}
var temp, panVerifybutton, panEnabledorDisabled, panMandatory, loadData, MainHeadr, InfoHeadr;
var imgpath = "apps/styles/themes/AppzillonConsumerOnboarding/img/";
window.panVerified = false;
//onload function
apz.app.onLoad_CustomerVerification = function(params) {
    apz.app.BaseScreens.hideNshowbackIcon();
    apz.app.CustomerVerification.getCommomCodeBasedOnProduct();
    apz.app.CustomerVerification.litCodeDescPropertyFile();
    if (backNav) {
        ConfigureScrJson.filter(function(i, k) {
            if (i.confParamName === "CUSTVERIFICATION") {
                $.each(i.Divs, function(a, b) {
                    if (a < i.Divs.length - 1) {
                        $('#' + i.MicroAppID + '__' + i.ScreenID + '__' + b).addClass('sno');
                    } else {
                        $('#' + i.MicroAppID + '__' + i.ScreenID + '__' + b).removeClass('sno');
                    }
                })
                return;
            }
        })
    }
};
//onshown function
apz.app.onShown_CustomerVerification = function(params) {
    /**
     * @author praisy.b
     * @since 08.06.21
     * Added fix for below issue
     * Show hand icon for open/close eye icon
     **/
    $('#' + BaseScrId + 'backIcon').addClass('sno');
    $('body').addClass('LoginBase')
    $(".icon-Eye-Open").css("cursor", "pointer");
    $(".icon-Eye-Close").css("cursor", "pointer");
    apz.app.CustomerVerification.loadCustLitConf();
    $("input").attr("autocomplete", "off");
    apz.app.CustomerVerification.panVerifyBtnStatus();
    if ($('#' + BaseScrId + 'backIcon').hasClass('sno')) {
        $('#' + CustVerfScrId + 'subHeaderRow').addClass('var1')
    }
    ApzCOB.disableCutCopyPaste();
    apz.app.CustomerVerification.showGeneralInstructions();
    gApzCOB.userDetails.currentStage = "appMaster";
    $('#' + CustVerfScrId + 'otp').addClass('mand')
    apz.app.CustomerVerification.configureFields();
    ApzCOB.setMinMaxLength([{
        'fieldName': 'UserName',
        'fieldId': CustVerfScrId + 'name'
    }, {
        'fieldName': 'MobileNumber',
        'fieldId': CustVerfScrId + 'mobileNumber'
    }, {
        'fieldName': 'CustomerId',
        'fieldId': CustVerfScrId + 'customerID'
    }, {
        'fieldName': 'AadharNumber',
        'fieldId': CustVerfScrId + 'aadharNumber'
    }, {
        'fieldName': 'PanNumber',
        'fieldId': CustVerfScrId + 'panNumber'
    }, {
        'fieldName': 'NationalId',
        'fieldId': CustVerfScrId + 'nationalID'
    }, {
        'fieldName': 'EmailId',
        'fieldId': CustVerfScrId + 'email'
    }]);
    $('#' + CustVerfScrId + 'success').addClass('sno');
    $('#' + CustVerfScrId + 'retry').addClass('sno');
    ApzCOB.showLanguageSelect();
    if (selectedType === 'CASA') {
        $("#" + CustVerfScrId + "CheckBox").addClass("sno");
    } else if (selectedType === 'DEPOSIT') {
        $("#" + CustVerfScrId + "checkBox").removeClass("sno");
        $("#" + CustVerfScrId + "checkbox").prop('checked', false);
        $("#" + CustVerfScrId + "customerIdDiv").addClass("sno");
        //  $("#" + CustVerfScrId + "checkbox").prop('checked', true)
        //  $("#" + CustVerfScrId + "checkbox").prop('disabled', true);
    } else {
        $("#" + CustVerfScrId + "checkBox").removeClass("sno");
        /*$("#" + CustVerfScrId + "el_cbx_1").prop('checked', true);
        $("#" + CustVerfScrId + "userNameDIv").addClass('sno');
        $("#" + CustVerfScrId + "mobileNumberDiv").removeClass("sno");
        $("#" + CustVerfScrId + "CustomerId").removeClass("sno");*/
    }
    if ($("#" + CustVerfScrId + "checkbox").is(':checked')) {
        $('#CusVer__CustomerVerification__sc_col_14').addClass('sno');
    }
    if (window.COUNTRYCODE === 'N') {
        $('#' + CustVerfScrId + 'countryFlagCol').addClass('sno');
    }
}
/*Hide and show fields based on configuration
fieldName - Commoncode table fieldName respective to stage.
fieldId - Id of the respective field.
fieldDivId - Id of the complete row.
*/
