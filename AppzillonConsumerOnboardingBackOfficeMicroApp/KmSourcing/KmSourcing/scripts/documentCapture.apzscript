        'fieldName': 'Dob',
        'fieldId': docScrId + 'ocr-dob'
    },
    // {
    //     'fieldName': 'Dob',
    //     'fieldId': KmbaseScrId + 'ocrDob'
    // },
    {
        'fieldName': 'AadharNumber',
        'fieldId': docScrId + 'ocrAadhaarNumber'
    },
    // {
    //     'fieldName': 'AadharNumber',
    //     'fieldId': KmbaseScrId + 'ocrAadhaar'
    // },
    {
        'fieldName': 'VoterID',
        'fieldId': docScrId + 'ocrVoterNumber'
    }, 
    // {
    //     'fieldName': 'VoterID',
    //     'fieldId': KmbaseScrId + 'ocrVoter'
    // },
    {
        'fieldName': 'PanNumber',
        'fieldId': docScrId + 'ocrPanNumber'
    },
    // {
    //     'fieldName': 'PanNumber',
    //     'fieldId': KmbaseScrId + 'ocrPan'
    // },
    {
        'fieldName': 'AddressLine1',
        'fieldId': docScrId + 'ocrAddr1'
    }, {
        'fieldName': 'AddressLine2',
        'fieldId': docScrId + 'ocrAddr2'
    }, {
        'fieldName': 'AddressLine3',
        'fieldId': docScrId + 'ocrAddr3'
    }, {
        'fieldName': 'Pincode',
        'fieldId': docScrId + 'ocr-pincode'
    },
    // {
    //     'fieldName': 'AddressLine1',
    //     'fieldId': KmbaseScrId + 'ocrAddressLine1'
    // }, {
    //     'fieldName': 'AddressLine2',
    //     'fieldId': KmbaseScrId + 'ocrAddressLine2'
    // }, {
    //     'fieldName': 'AddressLine3',
    //     'fieldId': KmbaseScrId + 'ocrAddressLine3'
    // }, {
    //     'fieldName': 'Pincode',
    //     'fieldId': KmbaseScrId + 'ocrPincode'
    // }
    ]);
    if (apz.app.docType === 'Aadhaar') {
