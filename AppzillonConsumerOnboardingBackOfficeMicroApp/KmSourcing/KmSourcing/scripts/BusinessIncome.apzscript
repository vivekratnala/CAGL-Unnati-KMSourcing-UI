apz.app.BusinessIncome.rentalService = function(pthis) {
    var typeOfBuilding, rentalIncome;
    let appisChecked = $(`#KmSourc__BusinessIncome__RentalincomeOwn_Owned_option_Applicant`).is(":checked")
    if (appisChecked && $('#KmSourc__BusinessIncome__BuildType_App').val() == 'Please Select') {
        return;
    }
    if (pthis.value) {
        if (pthis.id.includes("Ap")) {
            rentalApplicant = true;
            rentalCoApplicant = false
            typeOfBuilding = $(`#${kmScrId}BuildType_App`).val();
            rentalIncome = (($(`#${kmScrId}RentalIncomeMonth_App`).val()).split('.')[0]).replace(/[.,]/g, '');
            window.consideredMonthlyIncomeApp = '';
            $("#KmSourc__BusinessIncome__ConsideredRentalIncome_App").val('');
        } else if (pthis.id.includes("Co")) {
            rentalApplicant = false;
            rentalCoApplicant = true;
            typeOfBuilding = $(`#${kmScrId}BuildType_Co`).val();
            rentalIncome = (($(`#${kmScrId}RentalIncomeMonth_Co`).val()).split('.')[0]).replace(/[.,]/g, '');
            window.consideredMonthlyIncomeCoApp = '';
            $("#KmSourc__BusinessIncome__ConsideredRentalIncome_CoApp").val('');
        } else {
            //
        }
        const rentalObject = {
            "state": (inSessionStore.leadDetails?.permState || inSessionStore.renewalLeadDetails?.permState),
            "typeOfBuilding": typeOfBuilding,
            "rentalIncome": rentalIncome
        };
        apz.app.BusinessIncome.IncomeAssessmentCheck("Rental", rentalObject);
    }
}
apz.app.BusinessIncome.validatePensionData = function(pthis) {
    if (parseInt(pthis.value) === 0) {
        ApzCOB.fnDisplayMsg("please enter valid amount");
    }
}
apz.app.BusinessIncome.hideSections = function(pthis) {
    let parentid = $("#" + pthis.id).closest(".crt-form");
    if (parentid.length > 0) {
        parentIdStr = parentid.attr("id");
        $(`#${parentIdStr} #${kmScrId}Applicant`).addClass("sno");
        $(`#${parentIdStr} #${kmScrId}Co-Applicant`).addClass("sno");
