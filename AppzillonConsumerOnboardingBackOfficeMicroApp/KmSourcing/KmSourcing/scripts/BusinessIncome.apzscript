apz.app.BusinessIncome.pincodeCB = function(params) {
    apz.stopLoader();
    if (ApzCOB.handleServiceCallBacks(params)) {
        if (params.res.APZCBO__fetchpincode_Res.apiResponse.ResponseHeader.ResponseCode == "0") {
            let pincode_Detls = JSON.parse(JSON.parse(params.res.APZCBO__fetchpincode_Res.apiResponse.ResponseBody.responseObj).pinCodeDetails);
            window.validPinCode = true;
            addrFields.forEach(function(el) {
                if (pincode_Detls.hasOwnProperty(el.toLowerCase())) {
                    $(`#${kmScrId+index}_otherBussAddr${el}`).val(pincode_Detls[el.toLowerCase()]);
                }
            })
        }
    } else {
        let parmObj = {
            pinCode: "",
            city: "",
            district: "",
            state: "",
            country: "",
            area: ""
        };
        window.validPinCode = false;
        let paramsResp = params?.res?.APZCBO__fetchpincode_Res?.apiResponse?.ResponseHeader
        if (paramsResp?.ResponseCode == "1" && paramsResp?.ResponseMessage) {
            ApzCOB.fnDisplayMsg(paramsResp?.ResponseMessage, "E");
        }
        addrFields.forEach(function(el) {
            if (parmObj.hasOwnProperty(el.toLowerCase())) {
                $(`#${kmScrId+index}_otherBussAddr${el}`).val(parmObj[el.toLowerCase()]);
            }
        })
    }
}
apz.app.BusinessIncome.OnchangeOtherLineBusinessDropDown = function(pthis) {
    let Index = pthis.id.split("_")[4];
    if (pthis.value == "Others") {
        $(`#${kmScrId+Index}_O_OthLineOfBus`).val("");
        $(`#${kmScrId+Index}_OtherLineBusReasonRow`).removeClass('sno');
    } else if (pthis.value == "Please Select") {
        $(`#${kmScrId+Index}_O_OthLineOfBus`).val("");
        $(`#${kmScrId+Index}_OtherLineBusReasonRow`).addClass('sno');
    } else {
        $(`#${kmScrId+Index}_O_OthLineOfBus`).val(pthis.value);
        $(`#${kmScrId+Index}_OtherLineBusReasonRow`).addClass('sno');
    }
};
