}
apz.app.BusinessIncome.validateZeroInput = function(input) {
    if (input.value.length >= 1 && input.value.startsWith('0')) {
        input.value = input.value.replace(/^0+/, '');
    }
}
apz.app.BusinessIncome.validateMinLength = function(input) {
    const digitOnlyValue = input.value.replace('.', '');
    if (digitOnlyValue.length < 4) {
        ApzCOB.fnDisplayMsg("Please enter at least 4 digits", "E");
        input.value = '';
    }
}
apz.app.BusinessIncome.validateNetIncome = function(input) {
    if (!isNaN(input.value) && input.value > 100000) {
        ApzCOB.fnDisplayMsg("Amount cannot exceed ₹1,00,000.", "E");
        input.value = '';
    }
};
apz.app.BusinessIncome.onSelectBussAddr = function(pthis) {
    let Index = pthis.id.split("_")[4];
    $(`#${kmScrId+Index}_addressList`).find('.etb-rdio').each(function(i, item) {
        if (this.id === pthis.id) return true;
        $(this).find('input[type="radio"]').prop('checked', false);
    })
    $(`#${kmScrId+Index}_otherBussAddrRow`).addClass('sno');
    if (pthis.id.includes("otherBuss")) {
        $(`#${kmScrId+Index}_otherBussAddrRow`).removeClass('sno');
    }
}
