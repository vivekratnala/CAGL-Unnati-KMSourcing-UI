apz.app.OtherInformation.setMinMaxLength = function () {
    const fieldMap = {
        //accountHolderNameInput: "Name",
        //accountNumberInput: "AccountNumber",
        //ifscCodeInput: "IFSC",
        //bankNameInput: "BankName",
        //branchNameInput: "BankName",
        changeBankIFSCCode: "IFSC",
        changeBankBankName: "BankName",
        changeBankBranchName: "BankName"
        //,otherReasonInput:"",
        //nameOfAdditionalDoc:""

    };
    ApzCOB.setMinMaxLength(Object.entries(fieldMap).map(([fieldId, fieldName]) => ({
        fieldName,
        fieldId: kmScrId + fieldId
    })));
};
apz.app.OtherInformation.buildDDValues = function (items) {
    let params = [];
    items.forEach((desc, index) => {
        params.push({
            val: desc,
            desc: desc,
        });
    });
    if (!items.includes("Please Select")) {
        params.unshift({
            val: "",
            desc: "Please Select"
        });
    }

    return params;
};
apz.app.OtherInformation.fnLoadAMLQuestions = function () {
    apz.data.scrdata.KmSourc__loadAMLQuestions_Req = {};
    apz.data.scrdata.KmSourc__loadAMLQuestions_Req.amlQuestions = []
    ApzCOB.FetchDBKITMasterData("KMSOURCING")
    if (apz.isNull(DBKIT_MASTERDATA)) {
        let amlQuestionFilePath = apz.getDataFilesPath() + "/amlQuestionaire.json"
        let amlQuesDataSet = apz.getFile(amlQuestionFilePath)
        apz.data.scrdata.KmSourc__loadAMLQuestions_Req.amlQuestions = JSON.parse(amlQuesDataSet)
    } else {
        apz.data.scrdata.KmSourc__loadAMLQuestions_Req.amlQuestions = JSON.parse(DBKIT_MASTERDATA[0].queries)
    }
    let amlQuestions = apz.data.scrdata.KmSourc__loadAMLQuestions_Req.amlQuestions;
    apz.data.loadData("loadAMLQuestions", "KmSourc")
    for (let i = 0; i < amlQuestions.length; i++) {
        $("#KmSourc__loadAMLQuestions__i__amlQuestions__question_" + i).empty();
        $("#KmSourc__loadAMLQuestions__i__amlQuestions__question_" + i).append(`${amlQuestions[i].question}`);
        var $li = $('#' + kmScrId + 'amlQuestionList_row_' + i);
        var onclickCode = $li.attr('onclick');
        if (onclickCode) {
            onclickCode = onclickCode
                .replace('apz.data.selectRow(this, event);', '')
                .replace('apz.data.rowClicked(this,event);', '');
            $li.attr('onclick', onclickCode);
        }
    }
}
apz.app.OtherInformation.insNotOptDropDownValue = function () {
    let selectedReasons = $("#" + kmScrId + "insuranceNotOptingReasons").val();
    if (selectedReasons === "Other") {
        $("#" + kmScrId + "otherReasonRow").removeClass("sno");
    } else {
        $("#" + kmScrId + "otherReasonRow").addClass("sno");
    }
};
apz.app.OtherInformation.validateENach = function () {
    let bankName = $("#" + kmScrId + "bankNameInput").val().trim().toUpperCase();
    if (ALL_eNACH_BANKS.length > 0) {
        const bankExists = ALL_eNACH_BANKS.some(bank =>
            bank.bank_name.toUpperCase() === bankName
        );
        if (bankExists) {
            $("#" + kmScrId + "validateENachbtn").addClass("sno");
            $("#" + kmScrId + "eNachValidatedbtn").removeClass("sno");
            $("#" + kmScrId + "pennyChackbtn").removeClass("sno");
            //$("#"+kmScrId + "changeBankRadioBtn_option_yes").attr("disabled", true)
        } else {
            $("#" + kmScrId + "validateENachbtn").addClass("sno");
            $("#" + kmScrId + "eNachInvalidbtn").removeClass("sno");
            $("#" + kmScrId + "changeBankRadioBtn_option_no").attr("disabled", true)
            $("#" + kmScrId + "changeBankRadioBtn_option_yes").attr("checked", true)
            apz.app.OtherInformation.fnChangeAccountDetailsOnChange();
        }
    }
    else {
        ApzCOB.fnDisplayMsg("Please try again later", "E");
    }
};
apz.app.OtherInformation.validateENachOnChangeBank = function () {
    let bankName = $("#" + kmScrId + "changeBankBankName").val().trim().toUpperCase();
    const bankExistsOnChangeBank = ALL_eNACH_BANKS.some(bank =>
        bank.bank_name.toUpperCase() === bankName
    );
    if (bankExistsOnChangeBank) {
        $("#" + kmScrId + "changeBankValidateENachbtn").addClass("sno");
        $("#" + kmScrId + "changeBankeNachValidatedbtn").removeClass("sno");
    } else {
        $("#" + kmScrId + "changeBankValidateENachbtn").addClass("sno");
        $("#" + kmScrId + "changeBankeNachInvalid").removeClass("sno");
    }
};
apz.app.OtherInformation.fnInsuranceTypeOnChange = function (pthis) {
    let selectedRadioBtn = apz.getElmValue(kmScrId + "insuranceTypeRadioBtn");
    $("#" + kmScrId + "nomineeCustomApplicantDiv").addClass("sno");
    $("#" + kmScrId + "nomineeCustomCoApplicantDiv").addClass("sno");
    if (selectedRadioBtn === "jiontInsurance") {
        $("#" + kmScrId + "jiontInsuranceNote").removeClass("sno");
        $("#" + kmScrId + "applicantInsuranceNote").addClass("sno");

        $("#" + kmScrId + "nomineeApplicantDiv").removeClass("sno");
        $("#" + kmScrId + "nomineeCoApplicantDiv").removeClass("sno");

        $("#" + kmScrId + "insuranceWarningDiv").addClass("sno");
    }
    else if (selectedRadioBtn === "applicant") {
        $("#" + kmScrId + "applicantInsuranceNote").removeClass("sno");
        $("#" + kmScrId + "jiontInsuranceNote").addClass("sno");

        $("#" + kmScrId + "nomineeApplicantDiv").removeClass("sno");
        $("#" + kmScrId + "nomineeCoApplicantDiv").addClass("sno");

        $("#" + kmScrId + "insuranceWarningDiv").removeClass("sno");
    }
    else if (selectedRadioBtn === "noInsurance") {
        $("#" + kmScrId + "applicantInsuranceNote").addClass("sno");
        $("#" + kmScrId + "jiontInsuranceNote").addClass("sno");

        $("#" + kmScrId + "nomineeApplicantDiv").addClass("sno");
        $("#" + kmScrId + "nomineeCoApplicantDiv").addClass("sno");

        $("#" + kmScrId + "insuranceWarningDiv").removeClass("sno");
    }
};
apz.app.OtherInformation.fnChangeAccountDetailsOnChange = function (pthis) {
    //let selectedChangeBankRadioBtn = pthis.value; 
    let selectedChangeBankRadioBtn = apz.getElmValue(kmScrId + "changeBankRadioBtn");
    if (selectedChangeBankRadioBtn === "yes") {
        apz.setElmValue(kmScrId + "changeBankAccountType", "Savings");
        $("#" + kmScrId + "changedBankDetails").removeClass("sno");
        //to enable eNach-validate button if it is disabled
        $("#" + kmScrId + "changeBankValidateENachbtn").removeClass("sno");
        $("#" + kmScrId + "changeBankeNachValidatedbtn").addClass("sno");
    }
    else if (selectedChangeBankRadioBtn === "no") {
        $("#" + kmScrId + "changedBankDetails").addClass("sno");
    }
}
