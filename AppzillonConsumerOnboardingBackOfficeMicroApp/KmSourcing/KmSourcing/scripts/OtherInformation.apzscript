apz.app.OtherInformation.ageCalculator = function () {
    let minAge = 18;
    //let maxAge = 60;
    var age = ApzCOB.getAge(apz.getElmValue(kmScrId + "editModelNomineeDOB"));
    if (age > 0) {
        $('#' + kmScrId + 'editModelNomineeAge').val(age).change();
        ApzCOB.removeErrMessgae(kmScrId + 'editModelNomineeAge', "element");
    } else {
        $('#' + kmScrId + 'editModelNomineeAge').val('');
        apz.setElmValue(kmScrId + "editModelNomineeDOB", "");
        ApzCOB.fnDisplayMsg(`Please select valid age(min:${minAge})`, "E");
    }
};
apz.app.OtherInformation.dobValidation = function (pthis) {
    let age = $(pthis).val();
    minAge = apz.isNull(minAge) ? 18 : minAge;
    //maxAge = apz.isNull(maxAge) ? 60 : maxAge;
    let msg = `Please select valid age(min:${minAge})`;
    if (!(parseInt(age) >= minAge)) {
        $(pthis).val("");
        $("#" + kmScrId + "editModelNomineeDOB").val('');
        ApzCOB.fnDisplayMsg(msg, "E");
    }
};
