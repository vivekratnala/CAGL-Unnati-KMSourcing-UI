apz.app.OtherInformation.onClickeNachEnabledBanks = function () {
    ApzCOB.toggleModal(kmScrId + "eNachBanksListModal"); // Model Name
    apz.app.OtherInformation.painteNachBanksList();
};
apz.app.OtherInformation.painteNachBanksList = function () {
    formattedBanks = [];
    if (ALL_eNACH_BANKS?.length === 0) return;
    let uniqueBankNames = ALL_eNACH_BANKS.map(el => el.bank_name)?.unique();
    if (uniqueBankNames?.length === 0) return;
    uniqueBankNames.forEach((bankName, index) => {
        const bankEntries = (ALL_eNACH_BANKS).filter(b => b?.bank_name === bankName);
        if (bankEntries.length > 0) {
            const firstEntry = bankEntries[0];
            formattedBanks.push({
                srNo: index + 1,
                bank_name: firstEntry?.bank_name || '',
                net_banking_code: firstEntry['net_banking_code'] !== 'NA' ? "Y" : "N",
                debit_card_code: firstEntry['debit_card_code'] !== 'NA' ? "Y" : "N",
                aadhaar_otp_code: firstEntry['aadhaar_otp_code'] !== 'NA' ? "Y" : "N",
                bank_code: firstEntry?.code || ''
            });
        }
    });
    if (formattedBanks.length === 0) {
        $("#" + kmScrId + "noRecodsForm").removeClass("sno");
        return;
    }
    apz.data.scrdata.KmSourc__IPainteNachBanksList_Res = [];
    apz.data.scrdata.KmSourc__IPainteNachBanksList_Res = formattedBanks;
    apz.data.loadData("IPainteNachBanksList", "KmSourc");
    $("#" + kmScrId + "noRecodsForm").addClass("sno");
};
//smartsearch
apz.app.OtherInformation.search = async function (ev) {
    let p1 = new Promise(resolve => {
        setTimeout(async () => {
            let txtVal = await apz.app.OtherInformation.getValue();
            if (txtVal !== "" && searchVal !== txtVal || txtVal === "" && showAllList) {
                showAllList = txtVal === "" ? false : true;
                searchVal = txtVal;
                resolve(txtVal)
            }
        }, 1)
    });
    p1.then(async function (val) {
        window.searchLength = formattedBanks.filter(ldata => {
            const fieldsToSearch = [ldata.bank_name];
            return fieldsToSearch.some(field => field?.toString().toUpperCase().includes(val.toUpperCase()));
        });
        if (apz.data.scrdata.KmSourc__IPainteNachBanksList_Res.length === window.searchLength.length) {
            return
        }
        apz.data.scrdata.KmSourc__IPainteNachBanksList_Res = [...window.searchLength];
        apz.app.OtherInformation.hideNShow();
        $("#" + kmScrId + "eNachBanksList").scrollTop(0, 0);
        $("#" + kmScrId + "eNachBanksList .wrapped.undefined.ssp").remove()
    })
};
apz.app.OtherInformation.getValue = function () {
    return new Promise(resolve => {
        setTimeout(() => {
            resolve(document.getElementById(kmScrId + "searcheNachBank")?.value?.trim())
        }, 1e3)
    })
};
apz.app.OtherInformation.hideNShow = function () {
    if (window.searchLength.length === 0) {
        $("#" + kmScrId + "eNachBanksList").addClass("sno");
        $("#" + kmScrId + "noRecodsForm").removeClass("sno");
    } else {
        apz.data.loadData("IPainteNachBanksList", "KmSourc");
        $("#" + kmScrId + "eNachBanksList").removeClass("sno");
        $("#" + kmScrId + "noRecodsForm").addClass("sno");
    }
};
apz.app.OtherInformation.uploadBtnClick = function (fileObj, browseId, type, docCat) {
    IS_ADITIONAL_DOC_OPERATION = false;
    window.browseFileElem = fileObj;
    selType = type;
    if ($("#" + kmScrId + "" + selType).val() === PleaseSelect) {
        ApzCOB.fnDisplayMsg("Please select document type", "E");
        return false;
    } else {
        selCat = docCat;
        FileSideBrowseId = browseId;
        var browseAttr = $(fileObj).attr('id');
        DOC_NO = browseAttr.split('Camera')[1];
        apz.app.OtherInformation.SelectOption('camera');
    }
};
apz.app.OtherInformation.SelectOption = function (captureType) {
    var strDate = new Date().getTime() + "";
    if (captureType === 'camera' || captureType === 'photo') {
        var cameraObj = {
            "zoomLevel": "20",
            "targetWidth": "",
            "targetHeight": "",
            "crop": "Y", //Y or N
            "flash": "N",
            "action": "base64_Save", // save,base64
            "fileName": 'b' + strDate,
            "encodingType": "JPG",
            "quality": "80",
            "unCompressed": "N",
            "sourceType": captureType // photo / camera
        };
        cameraObj.id = "CAMERA_ID";
        cameraObj.callBack = apz.app.OtherInformation.cameraCallback;
        apz.ns.openCamera(cameraObj);
        ApzCOB.getGeoCordinatesMobile();
    } else {
        var json = {
            "filter": "",
            "fileCategory": "EXTERNAL", // AUDIO, VIDEO, PHOTO
            "location": "docs",
            "openFile": "N"
        };
        json.id = "FILEBROWSER_ID";
        json.callBack = apz.app.OtherInformation.getFileCallback;
        apz.ns.fileBrowser(json);
    }
};
apz.app.OtherInformation.getFileCallback = function (lparams) {
    if (apz.isNull(lparams.errorCode)) {
        var json = {
            "filePath": lparams.filePath,
            "id": "FILEREAD_ID",
            "callBack": apz.app.OtherInformation.readBase64
        };
        mobileFilePath = lparams.filePath;
        //json.id = "FILEREAD_ID";
        //json.callBack = apz.app.OtherInformation.readBase64;
        apz.ns.fileToBase64(json);
    } else {
        ApzCOB.fnDisplayMsg('Operation cancelled', "E", "");
    }
};
apz.app.OtherInformation.cameraCallback = function (lparams) {
    if (lparams.status) {
        filesObj = lparams;
        let docsize = ApzCOB.getBase64FileSizeInBytes(filesObj.encodedImage);
        groupCode = 'LOAN';
        localFileObj = {};
        localFileObj.filename = lparams.path.split('/')[lparams.path.split('/').length - 1];
        let activeCustType = gApzCOB?.currentApplicant == '1' ? 'A' : 'C';
        let fileExtenName = localFileObj.filename?.split('.')?.pop();
        // localFileObj.filename = `${activeCustType}_${selType}_${DOC_NO}.${fileExtenName}`;
        localFileObj.filetype = localFileObj.filename;
        localFileObj.filelocation = apz.appId + "/" + localFileObj.filename;
        localFileObj.fieldID = kmScrId + selType + FileSideBrowseId;
        localFileObj.filePath = `${apz.appId}/${groupCode}/${gApzCOB.userDetails.applicationId}`;
        localFileObj.productGroupCode = groupCode;
        localFileObj.docSize = docsize;
        localFileObj.base64Value = filesObj.encodedImage;
        localFileObj.docCategory = selCat;
        localFileObj.docType = selType;
        localFileObj.isAdiDoc = IS_ADITIONAL_DOC_OPERATION ? "Y" : "N";
        apz.app.OtherInformation.getFileArrNew();
        ApzCOB.documentAutoSave(localFileObj, selType);
    } else {
        ApzCOB.fnDisplayMsg(!apz.isNull(lparams.text) ? lparams.text : "Operation cancelled", "E", "");
    }
};
apz.app.OtherInformation.getFileArrNew = function () {
    var isValid3 = true;
    var tempFileArr = [];
    finalDocsArr = [];
    localFileObj.docSide = "Front";
    localFileObj.docNo = (!apz.isNull(DOC_NO)) ? parseInt(DOC_NO) : "";
    if (IS_ADITIONAL_DOC_OPERATION) {
        localFileObj.docName = $('#' + kmScrId + "otherdocType").val();
        localFileObj.docCategory = apz.getElmValue(kmScrId + 'otherdocpri');
    } else {
        localFileObj.docName = $('#' + kmScrId + selType + '_SubHeaderDropDown').val();
    }
    localFileObj.docLevel = parseInt(DOC_NO);
    let hasDocLevel2 = documentProofObj[selType]?.some(
        obj => parseInt(obj.docLevel) === 2
    );
    if (hasDocLevel2) {
        localFileObj.docLevel = 1;
    } else {
        localFileObj.docLevel = parseInt(DOC_NO);
    }
    documentProofObj[selType].push(localFileObj);
    documentProofObj[selType].sort((doc1, doc2) => doc1.docLevel - doc2.docLevel);
    tempFileArr = documentProofObj[selType];
    return tempFileArr;
}
apz.app.OtherInformation.readBase64 = function (lparams) {
    if (!apz.isNull(lparams.text)) {
        var curFileObj = {
            'encodedImage': lparams.text.split('\n').join(''),
            'path': mobileFilePath,
            'status': true
        }
        apz.app.OtherInformation.cameraCallback(curFileObj);
    }
};
//-----------------Penncy check---------------------------------------------------------------
apz.app.OtherInformation.pennyCheck = function () {
    apz.app.OtherInformation.validatePennyCheck();
};
apz.app.OtherInformation.validatePennyCheck = function () {
    window.applicationData = [];
    let custDetailID = ApzCOB.getCustDetailID("Applicant");
    applicationData = inSessionStore['customerDetailsList']?.filter(cust => cust.custDtlId === custDetailID) || [];
    var Mob = applicationData[0].mobileNumber;
    let beneficiaryAccount = $("#" + kmScrId + "accountNumberInput").val();
    let beneficiaryIFSC = $("#" + kmScrId + "ifscCodeInput").val();
    let beneficiaryName = $("#" + kmScrId + "accountHolderNameInput").val();
    var request = {
        "apiRequest": {
            "interfaceName": "SignzyPennylessCheck",
            "appId": gAppId,
            "applicationId": inSessionStore.applicationId,
            "requestObj": {
                "beneficiaryAccount": beneficiaryAccount,
                "beneficiaryIFSC": beneficiaryIFSC,
                "beneficiaryMobile": Mob,
                "beneficiaryName": beneficiaryName,
                "nameFuzzy": true
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "SignzyPennylessCheck", "N", "N", request, false, apz.app.OtherInformation.ValidatePennyCheckCB);
};
apz.app.OtherInformation.ValidatePennyCheckCB = function (params) {
    apz.stopLoader();
    var serviceFailErrMsg = 'Penny Check service failed. Please try again later.';
    let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let parsedCustomerDetails = JSON.parse(params.res.APZCBO__SignzyPennylessCheck_Res.apiResponse.ResponseBody.responseObj);
            let parsedResponse = parsedCustomerDetails.responseObj ? JSON.parse(parsedCustomerDetails.responseObj) : '';
            if (parsedResponse?.result?.reason?.toLowerCase() === 'success') {
                apz.app.OtherInformation.handlePennyCheckPass(parsedResponse);
            } else {
                apz.app.OtherInformation.handlePennyCheckFail();
                var errMsg = parsedResponse?.result?.reason;
                if (apz.isNull(errMsg)) {
                    errMsg = parsedCustomerDetails.hasOwnProperty('errorMessage') ? parsedCustomerDetails.errorMessage : params.res
                        .APZCBO__SignzyPennylessCheck_Res?.apiResponse?.ResponseHeader?.ResponseMessage;
                }
                ApzCOB.fnDisplayMsg(errMsg, "E");
            }
        } else {
            inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload.pennyCheckStatus = '';
            ApzCOB.fnDisplayMsg(serviceFailErrMsg, "E");
        }
    } catch (e) {
        inSessionStore.bankDetailsWrapperList[currIndex].bankDetails.payload.pennyCheckStatus = '';
        ApzCOB.fnDisplayMsg(); //serviceFailErrMsg
    }
};
