};
apz.app.CBcheck.getCurrentCustId = function() {
    if (apz.isNull(gApzCOB.requestNodes?.customerDetailsList)) return null;
    let isApplicant = gApzCOB.currentApplicant === 1;
    let wrapper = gApzCOB.requestNodes.customerDetailsList.find(c => isApplicant ? c.customerType === "Applicant" : c.customerType === "Co-App");
    return wrapper?.custDtlId ?? null;
};
apz.app.CBcheck.clearCbUI = function() {
    cibilDtls = {};
    // Hide result section and decision rows
    $('.cb-result-section').addClass('sno');
    $('#' + screenId + 'retryRow').addClass('sno');
    $('#' + screenId + 'rejectReasonRow').addClass('sno');
    // Clear status text fields
    $('#' + screenId + 'cbStatus').text('');
    $('#' + screenId + 'lastDate').text('');
    // Clear all CB result input fields
    $('#' + screenId + 'bureauName').val('');
    $('#' + screenId + 'cbScore').val('');
    $('#' + screenId + 'totIndebtness').val('');
    $('#' + screenId + 'writeoffSuitFiledFlag').val('');
    $('#' + screenId + 'overdueAmt').val('');
    $('#' + screenId + 'writeOffAmt').val('');
    $('#' + screenId + 'cgp_dpd').val('');
    $('#' + screenId + 'runningEMI').val('');
    $('#' + screenId + 'unnatiDec').val('');
    $('#' + screenId + 'unnatiDecReason').val('');
    $('#' + screenId + 'roi').val('');
    $('#' + screenId + 'finalTenure').val('');
    // Clear display text fields
    $('#' + screenId + 'eligibleAmount').text('');
    $('#' + screenId + 'roiDisplay').text('');
    $('#' + screenId + 'rejectReasonText').text('');
    // Reset bureau-specific row visibility to default
    $('.hitNohitRow').removeClass('sno');
    $('.runningEMIRow').removeClass('sno');
    $('.individualIndebtRow').addClass('sno');
};
apz.app.CBcheck.downloadCbReport = function() {
    // BRE Changes for Report download 
    if (CBCALLTYPEFLAG === 'IRE' && !apz.isNull(CB_HIGHMARK_REPORT_LINK)) {
        if (apz.deviceType === "WEB") {
            window.open(CB_HIGHMARK_REPORT_LINK, "_blank");
        } else {
            var json = {
                "url": CB_HIGHMARK_REPORT_LINK
            }
            json.id = "BROWSERID";
            json.callBack = apz.app.CBcheck.downloadCbReportCB;
            apz.startLoader();
            apz.ns.openUrl(json);
        }
    } else if (CBCALLTYPEFLAG === 'BRE') {
        if (!apz.isNull(CBBASE64) && !apz.isNull(CB_LOAN_ID)) {
            ApzCOB.convertBase64ToPDF(CBBASE64, CB_LOAN_ID);
        } else {
            ApzCOB.downloadBRECbReport();
        }
    }
}
apz.app.CBcheck.downloadCbReportCB = function(params) {
    apz.stopLoader();
}
apz.app.CBcheck.createRequest = function(skipValidation = false) {
    /* -------------------------------------------------------
    //   VALIDATION GATE
    ------------------------------------------------------- */
    // if (isVerified !== "N" && !apz.app.CBcheck.validateForm()) {
    //     return {};
    // }
        if (!skipValidation) {
        if (isVerified !== "N" && !apz.app.CBcheck.validateForm()) {
            return {};
        }
    }
    /* -------------------------------------------------------
    //   RESOLVE CURRENT CUSTOMER IDs
    ------------------------------------------------------- */
    let isApplicant = gApzCOB.currentApplicant === 1;
    let custDtlId = isApplicant ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId;
    let customerType = isApplicant ? "Applicant" : "Co-App";
    let addressDtlsId = isApplicant ? gApzCOB.userDetails.addressDtlsId : gApzCOB.userDetails.CoApplicantAddressDtlsId;
    /* -------------------------------------------------------
    //   INITIALISE SESSION STORES 
    ------------------------------------------------------- */
    if (!inSessionStore.customerDetailsList) {
        inSessionStore.customerDetailsList = [];
    }
    if (!inSessionStore.addressDetailsWrapperList) {
        inSessionStore.addressDetailsWrapperList = [{
            addressDetailsList: []
        }];
    }
    if (!inSessionStore.addressDetailsWrapperList[0].addressDetailsList) {
        inSessionStore.addressDetailsWrapperList[0].addressDetailsList = [];
    }
    /* -------------------------------------------------------
       BUILD CUSTOMER PAYLOAD
       Fields: mobileNumber, secMobileNo, isMobVerified,
               primaryKycType, primaryKycId, alternateVoterId,
               namePerKyc, kycStatus, ckyc,
               dob, age, gender,
               panNumberValue, panNumber, panName,
               primaryKycIdValStatus, relationShipWithApplicant
    ------------------------------------------------------- */
    let panNumberValue = $(`input[name="${screenId}panVal_"]:checked`).val() || "Y";
    let custPayload = {
        // Mobile
        mobileNumber: $(`#${screenId}primaryMobile`).val() || "",
        secMobileNo: $(`#${screenId}sec_mobile`).val() || "",
        isMobVerified: isApplicant ? (CB_OTP_STATE.applicant.verified ? "Y" : "N") : (CB_OTP_STATE.coapplicant.verified ? "Y" : "N"),
        // KYC
        primaryKycType: "VoterID",
        primaryKycId: $(`#${screenId}voterId`).val() || "",
        alternateVoterId: $(`#${screenId}alternateVoterId`).val() || "",
        namePerKyc: $(`#${screenId}nameAsPerVoter`).val() || "",
        kycStatus: isApplicant ? (PRIMARY_KYC_VERIFICATION ? "Verified" : "Pending") : (CO_APPLICANT_PRIMARY_KYC_VERIFICATION ? "Verified" :
            "Pending"),
        primaryKycIdValStatus: isApplicant ? (PRIMARY_KYC_VERIFICATION ? "Verified" : "Pending") : (CO_APPLICANT_PRIMARY_KYC_VERIFICATION ?
            "Verified" : "Pending"),
        ckyc: $(`#${screenId}ckycNumber`).val() || "",
        dob: isApplicant ? $(`#${screenId}dob`).val() : $(`#${screenId}coDob`).val(),
        age: isApplicant ? $(`#${screenId}age`).val() : $(`#${screenId}coAge`).val(),
        gender: isApplicant ? $(`#${screenId}gender`).val() : $(`#${screenId}coGender`).val(),
        // PAN
        panNumberValue: panNumberValue,
        panNumber: panNumberValue === "Y" ? ($(`#${screenId}panNum`).val() || "") : "",
        panName: panNumberValue === "Y" ? ($(`#${screenId}panName`).val() || "") : "",
        // Co-applicant specific
        relationShipWithApplicant: isApplicant ? "" : ($(`#${screenId}relationShipWithApplicant`).val() || "")
    };
    let existingCust = inSessionStore.customerDetailsList.find(c => String(c.custDtlId) === String(custDtlId));
    let mergedPayload = Object.assign({}, existingCust?.payload || {}, custPayload);
    let addressList = [];
    let presentAddr = {
        addressType: "Present",
        addressLine1: $(`#${screenId}addressLine1`).val() || "",
        addressLine2: $(`#${screenId}addressLine2`).val() || "",
        addressLine3: $(`#${screenId}addressLine3`).val() || "",
        pinCode: $(`#${screenId}pincode`).val() || "",
        city: $(`#${screenId}addPreCity`).val() || "",
        district: $(`#${screenId}addPreDistrict`).val() || "",
        state: $(`#${screenId}addPreState`).val() || "",
        country: $(`#${screenId}country`).val() || "INDIA",
        area: $(`#${screenId}area`).val() || "",
        landMark: $(`#${screenId}landmark`).val() || ""
    };
    addressList.push(presentAddr);
    // let voterAddr = {
    //     addressType: "Voter",
    //     addressLine1: $(`#${docScrId}ocrAddr1`).val() || "",
    //     addressLine2: $(`#${docScrId}ocrAddr2`).val() || "",
    //     addressLine3: $(`#${docScrId}ocrAddr3`).val() || "",
    //     pinCode: $(`#${docScrId}ocr-pincode`).val() || "",
    //     // city: $(`#${docScrId}addPreCity`).val() || "",
    //     // district: $(`#${docScrId}addPreDistrict`).val() || "",
    //     // state: $(`#${docScrId}addPreState`).val() || "",
    //     // country: $(`#${docScrId}country`).val() || "INDIA",
    //     // area: $(`#${docScrId}area`).val() || "",
    //     // landMark: $(`#${docScrId}landmark`).val() || ""
    // };
    /* -------------------------------------------------------
   BUILD VOTER ADDRESS (Context Aware)
------------------------------------------------------- */
    let voterAddr = null;
    if (apz.childScr === 'documentCapture') {
        let addr1 = $(`#${docScrId}ocrAddr1`).val() || "";
        let pin = $(`#${docScrId}ocr-pincode`).val() || "";
        if (addr1 || pin) {
            voterAddr = {
                addressType: "Voter",
                addressLine1: addr1,
                addressLine2: $(`#${docScrId}ocrAddr2`).val() || "",
                addressLine3: $(`#${docScrId}ocrAddr3`).val() || "",
                pinCode: pin
                // city: $(`#${docScrId}addPreCity`).val() || "",
                // district: $(`#${docScrId}addPreDistrict`).val() || "",
                // state: $(`#${docScrId}addPreState`).val() || "",
                // country: $(`#${docScrId}country`).val() || "INDIA",
                // area: $(`#${docScrId}area`).val() || "",
                // landMark: $(`#${docScrId}landmark`).val() || ""
            };
        }
    }
    /* Case 2: Not in documentCapture → restore from session */
    else if (!apz.isNull(inSessionStore?.addressDetailsWrapperList)) {
        let addrRoot = inSessionStore.addressDetailsWrapperList?.[0]?.addressDetailsList || [];
        let existingAddr = addrRoot.find(a => String(a.custDtlId) === String(custDtlId) && a.addressType === "Personal");
        let voterFromSession = existingAddr?.payload?.addressList?.find(a => a.addressType === "Voter");
        if (voterFromSession) {
            voterAddr = JSON.parse(JSON.stringify(voterFromSession));
        }
    }
    /* Push only if voter exists */
    if (voterAddr) {
        addressList.push(voterAddr);
    }
    /* -------------------------------------------------------
       UPDATE inSessionStore.customerDetailsList
    ------------------------------------------------------- */
    let custIndex = inSessionStore.customerDetailsList.findIndex(c => String(c.custDtlId) === String(custDtlId));
    if (custIndex >= 0) {
        inSessionStore.customerDetailsList[custIndex].payload = mergedPayload;
        inSessionStore.customerDetailsList[custIndex].mobileNumber = $(`#${screenId}primaryMobile`).val() || "";
        inSessionStore.customerDetailsList[custIndex].customerName = isApplicant ? ($(`#${screenId}customerName`).val() || "") : ($(
            `#${screenId}coCustomerName`).val() || "");
    } else {
        inSessionStore.customerDetailsList.push({
            custDtlId: custDtlId,
            customerType: customerType,
            customerName: isApplicant ? ($(`#${screenId}customerName`).val() || "") : ($(`#${screenId}coCustomerName`).val() || ""),
            mobileNumber: $(`#${screenId}primaryMobile`).val() || "",
            payload: mergedPayload
        });
    }
    /* -------------------------------------------------------
       UPDATE inSessionStore.addressDetailsWrapperList
    ------------------------------------------------------- */
    let addrDetailsList = inSessionStore.addressDetailsWrapperList[0].addressDetailsList;
    let addrIndex = addrDetailsList.findIndex(a => String(a.custDtlId) === String(custDtlId) && a.addressType === "Personal");
    // if (addrIndex >= 0) {
    //     addrDetailsList[addrIndex].payload.addressList = addressList;
    // }
    if (addrIndex >= 0) {

    let existingList = addrDetailsList[addrIndex].payload.addressList || [];

    addressList.forEach(newAddr => {

        let existingIndex = existingList.findIndex(
            a => a.addressType === newAddr.addressType
        );

        if (existingIndex >= 0) {
            // Update existing address type
            existingList[existingIndex] = newAddr;
        } else {
            // Add new address type
            existingList.push(newAddr);
        }

    });

    addrDetailsList[addrIndex].payload.addressList = existingList;
}
    else {
        addrDetailsList.push({
            addressDtlsId: addressDtlsId || "",
            custDtlId: parseInt(custDtlId),
            addressType: "Personal",
            payload: {
                addressList: addressList
            }
        });
    }
    /* -------------------------------------------------------
       BUILD LOAN DETAILS
    ------------------------------------------------------- */
    let loanDetails = null;
    if (isApplicant) {
        let loanAmountValue = $(`#${screenId}loanAmount`).val() || "";
        let cleanAmount = loanAmountValue.replace(/[\u20B9,]/g, "");
        let rawAmount = ApzCOB.fn_unFormatAmount(cleanAmount);
        loanDetails = {
            // loanAmount:  ApzCOB.fn_unFormatAmount($(`#${screenId}loanAmount`).val().replace(/[\u20B9,]/g, "")),
            loanAmount: rawAmount || "",
            payload: {
                loanPurpose: $(`#${screenId}loanPurpose`).val() || "",
                subCategory: $(`#${screenId}subLoanPurpose`).val() || "",
                frequencyOfRepayment: $(`#${screenId}frequencyOfRepayment`).val() || ""
            }
        };
        // Persist to session so later screens can read it
        window.inSessionStore.loanDetails = loanDetails;
    }
    /* -------------------------------------------------------
    //   BUILD REQUEST-LEVEL LISTS 
    ------------------------------------------------------- */
    let customerDetailsList = [{
        custDtlId: custDtlId,
        applicationId: gApzCOB.userDetails.applicationId,
        customerType: customerType,
        customerName: isApplicant ? ($(`#${screenId}customerName`).val() || "") : ($(`#${screenId}coCustomerName`).val() || ""),
        mobileNumber: $(`#${screenId}primaryMobile`).val() || "",
        payload: mergedPayload
    }];
    let finalAddressList = addressList;

if (addrIndex >= 0) {
    finalAddressList = addrDetailsList[addrIndex].payload.addressList;
}
    let addressDetailsWrapperList = [{
        addressDetailsList: [{
            addressDtlsId: addressDtlsId || "",
            custDtlId: parseInt(custDtlId),
            addressType: "Personal",
                        // payload: {
            //     "addressList": addressList
            // }
            payload: {
                "addressList": finalAddressList
            }
        }]
    }];
    let result = {
        customerDetailsList,
        addressDetailsWrapperList
    };
    if (loanDetails) {
        result.loanDetails = loanDetails;
    }
    if (!apz.isNull(window.inSessionStore.cibilDetailsWrapperList)) {
        result.cibilDetailsWrapperList = window.inSessionStore.cibilDetailsWrapperList;
    }
    return result;
};
// ============================================================
//  CB CHECK — createCBCheck 
// ============================================================
apz.app.CBcheck.createCBCheck = function() {
    let req = {};
    let intfName = "CreateLoan";
    req.apiRequest = {};
    req.apiRequest.requestObj = {};
    // Clear workflow list
    if (!apz.isNull(gApzCOB.requestNodes.applnWfDefinitionList) && gApzCOB.requestNodes.applnWfDefinitionList.length > 0) {
        gApzCOB.requestNodes.applnWfDefinitionList = [];
    }
    // Product defaults
    gApzCOB.product = "LOAN";
    gApzCOB.mainProductGroupCode = "LOAN";
    // Renewal override
    if (gApzCOB?.selLeadDtls?.oldPid || inSessionStore?.renewalLeadDetails?.oldPid) {
        gApzCOB.productCode = "1002";
        gApzCOB.SelectedProductName = productCodeBasedName[gApzCOB.productCode];
        ApplicationType = "RENEWAL";
    }
    /* -------------------------------------------------------
       VALIDATE FORM
    ------------------------------------------------------- */
    if (isVerified !== "N" && !apz.app.CBcheck.validateForm()) return;
    /* -------------------------------------------------------
       UPDATE PRIMARY DETAILS FOR EXISTING APPLICATION
    ------------------------------------------------------- */
    // if (!apz.isNull(gApzCOB.userDetails.applicationId)) {
    //     apz.app.BaseScreens.updatePrimaryDetails();
    //     if (!apz.app.BaseScreens.checkDtlIds()) {
    //         ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    //         return;
    //     }
    // }
    /* -------------------------------------------------------
       BUILD PAYLOAD via createRequest
    ------------------------------------------------------- */
    let requestBody = apz.app.CBcheck.createRequest();
    if (apz.isNull(requestBody) || Object.keys(requestBody).length === 0) return;
    /* -------------------------------------------------------
       SECONDARY KYC – read from session 
    ------------------------------------------------------- */
    let secondaryKycType = "";
    let secondaryKycId = "";
    let alternateVoterId = "";
    if (!apz.isNull(inSessionStore.customerDetailsList)) {
        let applicantData = inSessionStore.customerDetailsList.find(c => c.customerType === "Applicant");
        if (!apz.isNull(applicantData)) {
            secondaryKycType = applicantData.payload.secondaryKycType || "";
            secondaryKycId = applicantData.payload.secondaryKycId || "";
            alternateVoterId = applicantData.payload.alternateVoterId || "";
        }
    }
    /* -------------------------------------------------------
       RESOLVE Co-App IDs
    ------------------------------------------------------- */
    let isCoApp = gApzCOB.currentApplicant > 1;
    let custDtlId = isCoApp ? (gApzCOB.userDetails.CoApplicantCustomerId || "") : gApzCOB.userDetails.custDtlId;
    let addressDtlsId = isCoApp ? (parseInt(gApzCOB.userDetails.CoApplicantAddressDtlsId) || "") : gApzCOB.userDetails.addressDtlsId;
    /* -------------------------------------------------------
       ASSEMBLE API REQUEST
    ------------------------------------------------------- */
    req.apiRequest.userId = gApzCOB.LoggedInUserDetails.loginResponse.userDet.id;
    req.apiRequest.appId = gAppId;
    req.apiRequest.interfaceName = intfName;
    req.apiRequest.requestObj = {
        isNewSourcing: "Y",
        isStageVerified: isVerified,
        appId: gApzCOB.userDetails.appId,
        applicationId: !apz.isNull(gApzCOB.relatedApplicationId) ? gApzCOB.relatedApplicationId : gApzCOB.userDetails.applicationId,
        versionNum: window.versionNum,
        isExistingCustomer: "",
        /* ----- Core lists from createRequest ----- */
        customerDetailsList: requestBody.customerDetailsList,
        addressDetailsWrapperList: requestBody.addressDetailsWrapperList,
        existingLoanDetailsWrapperList: [],
        /* ----- Application master  ----- */
        applicationMaster: {
            applicationType: "online",
            createdBy: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
            currentScreenId: "CBcheck",
            currentStageNo: 1,
            custDtlId: custDtlId,
            addressDtlsId: addressDtlsId,
            customerId: gApzCOB.userDetails.customerId,
            declarationFlag: gApzCOB.userDetails.declarationFlag,
            mobileNumber: !apz.isNull(gApzCOB.userDetails.mobileNum) ? gApzCOB.userDetails.mobileNum : null,
            productCode: apz.isNull(gApzCOB.productCode) ? "1009" : gApzCOB.productCode,
            productGroupCode: gApzCOB.product,
            searchCode1: gApzCOB.selLeadDtls.kendraId,
            searchCode2: gApzCOB.selLeadDtls.customerId,
            custDtlSlNum: gApzCOB.currentApplicant,
            applicantsCount: gApzCOB.noOfApplicants,
            mainProductGroupCode: gApzCOB.mainProductGroupCode,
            kendraId: gApzCOB.selLeadDtls.kendraId,
            kendraName: gApzCOB.selLeadDtls.kendraName,
            branchId: gApzCOB.selLeadDtls.glBranchId,
            branchName: gApzCOB.selLeadDtls.glBranchName,
            memberId: gApzCOB.selLeadDtls.customerId,
            primaryKycType: "Voter ID",
            primaryKycId: gApzCOB.selLeadDtls.primaryKyc,
            secondaryKycType: secondaryKycType,
            secondaryKycId: secondaryKycId,
            workitemNo: gApzCOB.selLeadDtls.pid,
            alternateVoterId: alternateVoterId
        },
        /* ----- Workflow (simplified for CB stage) ----- */
        workflow: {
            currentRole: ""
        }
    };
    /* ----- Optional lists ----- */
    if (requestBody.loanDetails) {
        req.apiRequest.requestObj.loanDetails = requestBody.loanDetails;
    }
    if (requestBody.cibilDetailsWrapperList) {
        req.apiRequest.requestObj.cibilDetailsWrapperList = requestBody.cibilDetailsWrapperList;
    }
    /* -------------------------------------------------------
       FIRE SERVICE CALL
    ------------------------------------------------------- */
    apz.startLoader();
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, intfName, "N", "N", req, false, apz.app.CBcheck.createCBCheckCB);
    }, 1000);
};
apz.app.CBcheck.toggleInitiateRow = function() {
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let apiTriggered = isApplicant ? CB_API_TRIGGERED.applicant : CB_API_TRIGGERED.coapplicant;
    if (apiTriggered) {
        $('#' + screenId + 'initiateRow').addClass('sno');
        $('#' + screenId + 'cbNote').addClass('sno');
    } else {
        $('#' + screenId + 'initiateRow').removeClass('sno');
        $('#' + screenId + 'cbNote').removeClass('sno');
    }
};
apz.app.CBcheck.createCBCheckCB = function(params) {
    apz.stopLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let response = JSON.parse(params.res[params.apzIfaceName + "_Res"].apiResponse.ResponseBody.responseObj);
            // Persist applicationId
            if (response?.hasOwnProperty("applicationId")) {
                gApzCOB.userDetails.applicationId = response.applicationId;
            }
            // // Persist custDtlId for fresh case
            // if (response?.customerDetailsList?.length > 0) {
            //     let isApplicant = gApzCOB.currentApplicant <= 1;
            //     let custType = isApplicant ? "Applicant" : "Co-App";
            //     let returnedCust = response.customerDetailsList.find(c => c.customerType === custType);
            //     if (returnedCust?.custDtlId) {
            //         if (isApplicant) {
            //             gApzCOB.userDetails.custDtlId = returnedCust.custDtlId;
            //         } else {
            //             gApzCOB.userDetails.CoApplicantCustomerId = returnedCust.custDtlId;
            //         }
            //         // Sync into inSessionStore
            //         let sessionIdx = inSessionStore.customerDetailsList?.findIndex(c => c.customerType === custType);
            //         if (sessionIdx >= 0) {
            //             inSessionStore.customerDetailsList[sessionIdx].custDtlId = response.
            //         }
            //     }
            // }
            // // Persist addressDtlsId
            // if (!apz.isNull(response.addressList) && response.addressList.length > 0) {
            //     let indexID = parseInt(response.addressList[0], 10);
            //     let isApplicant = gApzCOB.currentApplicant <= 1;
            //     console.log("addressList from response:", response.addressList);
            //     console.log("indexID:", indexID);
            //     console.log("isApplicant:", isApplicant);
            //     if (isApplicant) {
            //         gApzCOB.userDetails.addressDtlsId = indexID;
            //     } else {
            //         gApzCOB.userDetails.CoApplicantAddressDtlsId = indexID;
            //     }
            //     let custDtlId = isApplicant ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId;
            //     let addrList = inSessionStore.addressDetailsWrapperList[0].addressDetailsList;
            //     let addrIndex = addrList.findIndex(a => a.addressType === "Personal" && parseInt(a.custDtlId, 10) === parseInt(custDtlId, 10));
            //     if (addrIndex >= 0) {
            //         addrList[addrIndex].addressDtlsId = indexID;
            //     }
            // }
            // Update global response nodes
            // Persist custDtlId for fresh case
            if (response?.custDtlId) {
                let isApplicant = gApzCOB.currentApplicant <= 1;
                let custType = isApplicant ? "Applicant" : "Co-App";
                if (isApplicant) {
                    gApzCOB.userDetails.custDtlId = response.custDtlId;
                } else {
                    gApzCOB.userDetails.CoApplicantCustomerId = response.custDtlId;
                }
                // Sync into inSessionStore
                let sessionIdx = inSessionStore.customerDetailsList?.findIndex(c => c.customerType === custType);
                if (sessionIdx >= 0) {
                    inSessionStore.customerDetailsList[sessionIdx].custDtlId = response.custDtlId;
                }
            }
            // Persist addressDtlsId
            if (response?.addressList?.length > 0) {
                let isApplicant = gApzCOB.currentApplicant <= 1;
                let custType = isApplicant ? "Applicant" : "Co-App";
                let addrValue = response.addressList[0];
                if (isApplicant) {
                    gApzCOB.userDetails.addressDtlsId = addrValue;
                } else {
                    gApzCOB.userDetails.CoApplicantAddressDtlsId = addrValue;
                }
                let custDtlId = isApplicant ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId;
                // let addrList = inSessionStore.addressDetailsWrapperList[0].addressDetailsList;
                // let addrIndex = addrList.findIndex(a => a.addressType === "Personal" && String(a.custDtlId, 10) === String(custDtlId, 10));
                // if (addrIndex >= 0) {
                //     addrList[addrIndex].addressDtlsId = addrValue;
                // }
                let addrList = inSessionStore?.addressDetailsWrapperList?.[0]?.addressDetailsList || [];
                let addrIndex = addrList.findIndex(a => a.addressType === "Personal");
                if (addrIndex !== -1) {
                    addrList[addrIndex].custDtlId = custDtlId;
                    addrList[addrIndex].addressDtlsId = addrValue;
                }
            }
            ApzCOB.responseNodeUpdate(response);
            /* =====================================================
               BRANCH: Navigate OR trigger BRE
            ===================================================== */
            // if (isVerified === "Y") {
            //     // Navigate: if applicant done and co-app tab exists → switch to co-app
            //     // else proceed to next screen
            //     if (gApzCOB.currentApplicant === 1) {
            //         let tabs = $('.cbcheckSubMenu');
            //         if (tabs.length > 1) {
            //             let coAppTab = tabs.eq(1);
            //             apz.app.CBcheck.handletabSwitch(coAppTab, 'CoApplicant');
            //         } else {
            //             ApzCOB.launchSubScreen("AadhaarDetails", "KmSourc__Kmbase__KMLaunchCol", "");
            //         }
            //     } else {
            //         ApzCOB.launchSubScreen("AadhaarDetails", "KmSourc__Kmbase__KMLaunchCol", "");
            //     }
            // }
            if (isVerified === "Y") {
                if (gApzCOB.currentApplicant === 1) {
                    let tabs = $('.cbcheckSubMenu');
                    if (tabs.length > 1) {
                        // Applicant done → switch to co-app tab
                        apz.app.CBcheck.handletabSwitch(tabs.eq(1), 'CoApplicant');
                    } else {
                        // No co-app → go to AadhaarDetails Applicant tab
                        window.AADHAAR_TAB_SWITCH_TARGET = 'Applicant';
                        ApzCOB.launchSubScreen("AadhaarDetails", "KmSourc__Kmbase__KMLaunchCol", "");
                        $(`#${kmbaseScr}sidebarForm a`).removeClass('active');
                        $(`#${kmbaseScr}AadhaarDetails_hyp`).addClass('active');
                        $(`#${kmbaseScr}AppAadhaarDetails_hyp`).addClass('active');
                    }
                } else {
                    // Co-app done → go to AadhaarDetails Applicant tab
                    window.AADHAAR_TAB_SWITCH_TARGET = 'Applicant';
                    ApzCOB.launchSubScreen("AadhaarDetails", "KmSourc__Kmbase__KMLaunchCol", "");
                    $(`#${kmbaseScr}sidebarForm a`).removeClass('active');
                    $(`#${kmbaseScr}AadhaarDetails_hyp`).addClass('active');
                    $(`#${kmbaseScr}AppAadhaarDetails_hyp`).addClass('active');
                }
            }
            //             apz.startLoader();
            // apz.app.CBcheck.triggerBREService();
        } else {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};
apz.app.CBcheck.initiateCreditCheck = function() {
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let custId = isApplicant ? (gApzCOB.userDetails.custDtlId || gApzCOB?.selLeadDtls?.custDtlId) : gApzCOB.userDetails.CoApplicantCustomerId;
    /* =====================================================
       CHECK IF CB ALREADY EXISTS IN SESSION
    ===================================================== */
    if (!apz.isNull(custId) && !apz.isNull(inSessionStore.cibilDetailsWrapperList)) {
        let existingCB = inSessionStore.cibilDetailsWrapperList.find(el => parseInt(el.cibilDetails.custDtlId) === parseInt(custId) && !apz
            .isNull(el.cibilDetails.cbDtlId) && el.cibilDetails.cbDtlId !== "");
        if (existingCB) {
            // Restore payload
            cibilDtls = JSON.parse(JSON.stringify(existingCB.cibilDetails.payload));
            // Mark form validated so post sections show
            if (isApplicant) {
                CB_FORM_STATE.applicant.validated = true;
                CB_API_TRIGGERED.applicant = true;
            } else {
                CB_FORM_STATE.coapplicant.validated = true;
                CB_API_TRIGGERED.coapplicant = true;
            }
            // Paint UI
            apz.app.CBcheck.paintCibilDetails();
            apz.app.CBcheck.togglePostValidationSections();
            apz.app.CBcheck.toggleInitiateRow();
            $('.cb-result-section').removeClass('sno');
        }
    }
    /* =====================================================
       VALIDATE FORM (Fresh Flow)
    ===================================================== */
    if (!apz.app.CBcheck.validateForm()) return;
    // Mark API triggered
    if (isApplicant) {
        CB_API_TRIGGERED.applicant = true;
    } else {
        CB_API_TRIGGERED.coapplicant = true;
    }
    apz.app.CBcheck.toggleInitiateRow();
    // Save + Trigger API
    isVerified = null;
    apz.app.CBcheck.createCBCheck();
    apz.app.CBcheck.triggerBREService();
};
apz.app.CBcheck.triggerBREService = function() {
    window.CBCALLTYPEFLAG = 'BRE';
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let coAppData = [];
    let coApp_flag = 0;
    let income, applicantIncome, depName = "",
        custDtlPayload = {};
    let loanAmount, frequency, term;
    let kendraId = "",
        branchId = "",
        currentStage = "",
        caglOs = "";
    // ---- Loan fields ----
    if (isApplicant) {
        let rawAmt = $(`#${screenId}loanAmount`).val() || "";
        loanAmount = ApzCOB.fn_unFormatAmount(rawAmt.replace(/[\u20B9,\s]/g, ""));
        frequency = $(`#${screenId}frequencyOfRepayment`).val() || "";
        term = inSessionStore?.loanDetails?.tenure || "12";
    } else {
        let loanData = inSessionStore?.loanDetails || {};
        let loanPayload = typeof loanData.payload === 'object' ? loanData.payload : (loanData.payload ? JSON.parse(loanData.payload) : {});
        loanAmount = loanData?.loanAmount || "";
        frequency = loanPayload?.frequencyOfRepayment || "";
        term = loanData?.tenure || "12";
    }
    //     let loanData = inSessionStore?.loanDetails || {};
    // let loanPayload = typeof loanData.payload === 'object'
    //     ? loanData.payload
    //     : (loanData.payload ? JSON.parse(loanData.payload) : {});
    // loanAmount = loanData?.loanAmount || "";
    // frequency  = loanPayload?.frequencyOfRepayment || "";
    // term       = loanData?.tenure || "12";
    // ---- Applicant details from session ----
    let custDetailsObj = inSessionStore.customerDetailsList?.find(c => c.customerType === "Applicant") || {};
    custDtlPayload = custDetailsObj.payload || {};
    // ---- depName ----
    if (custDtlPayload.maritalStatus?.toUpperCase() === "MARRIED") {
        depName = custDtlPayload.spouseName || "";
    } else {
        depName = custDtlPayload.fathersName || $(`#${screenId}fatherName`).val() || "";
    }
    // ---- Income ----
    income = ApzCOB.getOccupation("Income");
    applicantIncome = ApzCOB.getOccupation("Income", "applicant");
    // ---- Activation date ----
    let activation_date = gApzCOB?.selLeadDtls?.activationDate || inSessionStore?.leadDetails?.activationDate || inSessionStore
        ?.renewalLeadDetails?.activationDate || "";
    if (apz.isNull(activation_date)) {
        ApzCOB.fnDisplayMsg("Activation date is empty!", "E");
        apz.stopLoader();
        return;
    }
    // ---- Kendra / Branch ----
    kendraId = inSessionStore?.applicationMaster?.kendraId || inSessionStore?.leadDetails?.kendraId || gApzCOB?.selLeadDtls?.kendraId || "";
    branchId = inSessionStore?.applicationMaster?.branchId || inSessionStore?.leadDetails?.glBranchId || gApzCOB?.selLeadDtls?.glBranchId || "";
    currentStage = `${inSessionStore.applicationMaster?.applicationStatus} | ${inSessionStore.applicationMaster?.applicationStatus}`;
    caglOs = gApzCOB?.selLeadDtls?.caglOs || inSessionStore?.leadDetails?.caglOs || inSessionStore?.renewalLeadDetails?.caglOs || "";
    // ---- Co-applicant block ----
    if (!isApplicant) {
        let coAppDetailsObj = inSessionStore.customerDetailsList?.find(c => c.customerType === "Co-App") || {};
        if (!apz.isNull(coAppDetailsObj.payload)) {
            let ljson = {
                applicantType: "H",
                relationtype: coAppDetailsObj.payload.relationShipWithApplicant || "",
                address: ApzCOB.getCbAddressRequest(gApzCOB.userDetails.CoApplicantCustomerId),
                document: ApzCOB.getKYCIdsRequest("Co-App"),
                custName: coAppDetailsObj.customerName || "",
                gender: ApzCOB.breFieldsMapping("gender", coAppDetailsObj.payload.gender || ""),
                phone: coAppDetailsObj.mobileNumber || "",
                dob: coAppDetailsObj.payload.dob || "",
                earning_flag: "ABC"
            };
            coAppData.push(ljson);
            coApp_flag = 1;
            depName = coAppDetailsObj.customerName || "";
            income = (parseInt(applicantIncome || 0) + parseInt(income || 0)).toString();
        }
    }
    let kycDocs = ApzCOB.getKYCIdsRequest("Applicant");
    // if (kycDocs.length === 0) {
    //     kycDocs = [{
    //         docType: "VOTER-ID",
    //         docId: custDtlPayload.primaryKycId
    //     }];
    // }
    // ---- Build request ----
    let req = {
        apiRequest: {
            appId: apz.appId,
            interfaceName: "BRECBCheck",
            requestObj: {
                values: {
                    input: {
                        values: {
                            input: {
                                roi_type: 0,
                                Coapp_flag: coApp_flag,
                                applicant: {
                                    applicantType: "P",
                                    address: ApzCOB.getCbAddressRequest(gApzCOB.userDetails.custDtlId),
                                    document: ApzCOB.getKYCIdsRequest("Applicant"),
                                    // document: kycDocs,
                                    depType: "F",
                                    depName: depName,
                                    categoryId: "1",
                                    productCode: "CCR",
                                    dob: custDtlPayload.dob || "",
                                    durationOfAgreement: "12",
                                    bankProductId: "01",
                                    custName: custDetailsObj.customerName || "",
                                    gender: ApzCOB.breFieldsMapping("gender", custDtlPayload.gender || ""),
                                    phone: custDetailsObj.mobileNumber || "",
                                    loanType: ApzCOB.breFieldsMapping("loanType", "GRAMEEN UNNATI LOAN"),
                                    appId: gApzCOB.userDetails.applicationId,
                                    losIndicator: "1",
                                    losIndex: "LOS",
                                    slNo: "1",
                                    loanAmount: ApzCOB.fn_unFormatAmount(loanAmount.toString()),
                                    term: ApzCOB.breFieldsMapping('term', term.toString()),
                                    applied_frequency: frequency,
                                    email: "",
                                    maritalStatus: ApzCOB.breFieldsMapping("maritalStatus", custDtlPayload.maritalStatus || ""),
                                    kendra: kendraId,
                                    branch: branchId,
                                    stateBranch: ApzCOB.breFieldsMapping("state", window.glBranchState ?? ""),
                                    custId: inSessionStore?.applicationMaster?.memberId ?? gApzCOB.selLeadDtls.customerId,
                                    source: "OTHERS",
                                    enquiryType: "A",
                                    loanId: gApzCOB.userDetails.applicationId,
                                    DigiAgil_DFA_Flag: "Unnati",
                                    hh_annual_income: income,
                                    earning_flag: "ABC",
                                    loan_product_type: "ABC",
                                    activation_date: activation_date,
                                    product_code: "GL.GRM.UNNATI.LN",
                                    Q1: "",
                                    Q2: "",
                                    Q3: "",
                                    Q4: "",
                                    Q5: "",
                                    Q6: "",
                                    Q7: "",
                                    Q8: "",
                                    Q9: "",
                                    Q10: "",
                                    Q11: "",
                                    Q12: "",
                                    Q13: "",
                                    Q14: "",
                                    Q15: "",
                                    Q16: "",
                                    Q17: "",
                                    Q18: "",
                                    Q19: "",
                                    Q20: "",
                                    Q21: "",
                                    Q22: "",
                                    Q23: "",
                                    Q24: "",
                                    Q25: "",
                                    Q26: "",
                                    Q27: "",
                                    Q28: "",
                                    Field_Assessed_Income_of_customer: income,
                                    Income_Assessment_Flag: "1"
                                },
                                household_member: coAppData,
                                App_Insurance_flag: "No",
                                Coapp_Insurance_flag: "No",
                                Joint_Insurance_flag: "No",
                                App_Insurance_amt: 0,
                                Coapp_Insurance_amt: 0,
                                Joint_Insurance_amt: 0,
                                currentStage: currentStage,
                                caglOs: caglOs
                            }
                        }
                    }
                }
            }
        }
    };
    // Handle date object format
    if (activation_date && typeof activation_date === 'object') {
        const d = activation_date;
        req.apiRequest.requestObj.values.input.values.input.applicant.activation_date =
            `${d.year}-${String(d.month).padStart(2,'0')}-${String(d.day).padStart(2,'0')}`;
    }
    console.log("========== BRE REQUEST (CBCheck) ==========");
    console.log(JSON.stringify(req, null, 2));
    console.log("===========================================");
    console.log("LoanDetails from session:", inSessionStore.loanDetails);
    console.log("ApplicationMaster:", inSessionStore.applicationMaster);
    console.log("CustomerDetailsList:", inSessionStore.customerDetailsList);
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, "BRECBCheck", "N", "N", req, false, apz.app.CBcheck.BRECbServiceCB);
    }, 1000);
};
apz.app.CBcheck.BRECbServiceCB = function(params) {
    console.log("========== BRE RESPONSE ==========");
    console.log(params);
    console.log("==================================");
    window.CBBASE64 = "";
    window.CB_HIGHMARK_REPORT_LINK = "";
    let errMsg = "";
    if (!apz.isNull(params.resFull?.appzillonBody?.APZCBO__BRECBCheck_Res?.apiResponse)) {
        errMsg = params.resFull.appzillonBody.APZCBO__BRECBCheck_Res.apiResponse.ResponseHeader.ResponseMessage || "";
    } else {
        let isApplicant = gApzCOB.currentApplicant <= 1;
        // reset api flag
        if (isApplicant) {
            CB_API_TRIGGERED.applicant = false;
        } else {
            CB_API_TRIGGERED.coapplicant = false;
        }
        // clear UI
        apz.app.CBcheck.clearCbUI();
        // show retry
        $('#' + screenId + 'retryRow').removeClass('sno');
        // hide result section
        $('.cb-result-section').addClass('sno');
        errMsg = ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_CB_CHECK_SERVICE_FAILED");
    }
    if (ApzCOB.handleServiceCallBacks(params)) {
        apz.stopLoader();
        let responseObj = JSON.parse(params.res.APZCBO__BRECBCheck_Res.apiResponse.ResponseBody.responseObj);
        let cbResponseObj = JSON.parse(responseObj.responseObj.payloadColumn);
        if (!apz.isNull(cbResponseObj.finalDecision)) {
            let isApplicant = gApzCOB.currentApplicant <= 1;
            let cbScore = (!apz.isNull(cbResponseObj.cbScore) && parseInt(cbResponseObj.cbScore) !== 0) ? parseInt(cbResponseObj.cbScore) : 0;
            let isApproved = cbResponseObj.finalDecision.toLowerCase().includes("approve");
            if (!isApproved) {
                cbResponseObj.eligibleAmt = "0";
            }
            // ---- Populate cibilDtls global ----
            cibilDtls = {
                overdueAmt: cbResponseObj.overdueAmt ?? "",
                bureauName: cbResponseObj.bureauName ?? "",
                cbScore: cbScore,
                totIndebtness: cbResponseObj.totIndebtness ?? "",
                caglDpdFlag: cbResponseObj.caglDpdFlag ?? "",
                writeOffAmt: cbResponseObj.writeOffAmt ?? "",
                writeoffSuitFiledFlag: cbResponseObj.writeoffSuitFiledFlag ?? "",
                finalDecision: cbResponseObj.finalDecision ?? "",
                eligibleAmt: !apz.isNull(cbResponseObj.eligibleAmt) ? ApzCOB.fn_FormatAmount(cbResponseObj.eligibleAmt) : "0",
                foir: cbResponseObj.foir ?? "",
                cbLoanId: cbResponseObj.cbLoanId ?? "",
                appliedLoanCode: cbResponseObj.appliedLoanCode ?? "",
                approvedLoanEMI: cbResponseObj.approvedLoanEMI ?? "",
                eir: cbResponseObj.eir ?? "",
                eligibleEMI: cbResponseObj.eligibleEMI ?? "",
                finalTenure: cbResponseObj.finalTenure ?? "",
                flowResponse: cbResponseObj.flowResponse ?? "",
                irisMessage: cbResponseObj.irisMessage ?? "",
                kycId: cbResponseObj.kycId ?? "",
                memberId: cbResponseObj.memberId ?? "",
                otsFlag: cbResponseObj.otsFlag ?? "",
                individualIndebtness: cbResponseObj.individualIndebtness ?? "",
                rejectionReason: cbResponseObj.rejectionReason ?? "",
                retryAttempts: cbResponseObj.retryAttempts ?? "",
                roi: cbResponseObj.roi ?? ""
            };
            window.CB_LOAN_ID = cbResponseObj.cbLoanId ?? "";
            window.retry_Attempts = cbResponseObj.retryAttempts;
            if (responseObj.hasOwnProperty("base64") && !apz.isNull(responseObj.base64)) {
                window.CBBASE64 = responseObj.base64;
            }
            // ---- Set CIBIL status flags ----
            if (isApplicant) {
                gApzCOB.userDetails.cbDtlsId = parseInt(responseObj.responseObj.cbDtlId);
                window.APPLICANT_CIBIL_STATUS = isApproved;
            } else {
                gApzCOB.userDetails.coApplicantCbDtlsId = parseInt(responseObj.responseObj.cbDtlId);
                window.CO_APPLICANT_CIBIL_STATUS = isApproved;
            }
            // ---- Persist to session ----
            let custId = isApplicant ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId;
            let sessionCbObj = {
                cibilDetails: {
                    cbDtlId: parseInt(responseObj.responseObj.cbDtlId),
                    custDtlId: custId,
                    cbDate: ApzCOB.dateformatter(new Date(), 'Y-m-d'),
                    cbStatus: isApproved ? "PASS" : "FAIL",
                    payload: cibilDtls
                }
            };
            if (apz.isNull(inSessionStore.cibilDetailsWrapperList)) {
                inSessionStore.cibilDetailsWrapperList = [sessionCbObj];
            } else {
                let idx = inSessionStore.cibilDetailsWrapperList.findIndex(item => parseInt(item.cibilDetails.custDtlId) === parseInt(custId));
                if (idx >= 0) {
                    inSessionStore.cibilDetailsWrapperList[idx] = sessionCbObj;
                } else {
                    inSessionStore.cibilDetailsWrapperList.push(sessionCbObj);
                }
            }
            // ---- Paint results ----
            apz.app.CBcheck.paintCibilDetails();
        } else {
            apz.app.CBcheck.clearCbUI();
            $('#' + screenId + 'retryRow').removeClass('sno');
            $('.cb-result-section').addClass('sno');
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_LOAN_DETAILS_CB_CHECK_SERVICE_FAILED"), "E");
        }
    } else {
        apz.stopLoader();
        let isApplicant = gApzCOB.currentApplicant <= 1;
        if (isApplicant) {
            CB_API_TRIGGERED.applicant = false;
        } else {
            CB_API_TRIGGERED.coapplicant = false;
        }
        apz.app.CBcheck.clearCbUI();
        $('#' + screenId + 'retryRow').removeClass('sno');
        $('.cb-result-section').addClass('sno');
        ApzCOB.fnDisplayMsg(errMsg, "E");
    }
};
apz.app.CBcheck.retryCB = function() {
    let isApplicant = gApzCOB.currentApplicant <= 1;
    // Reset flag so initiate button comes back if needed
    if (isApplicant) {
        CB_API_TRIGGERED.applicant = false;
    } else {
        CB_API_TRIGGERED.coapplicant = false;
    }
    // Clear previous result from session
    let custId = isApplicant ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId;
    if (!apz.isNull(inSessionStore.cibilDetailsWrapperList)) {
        let idx = inSessionStore.cibilDetailsWrapperList.findIndex(item => parseInt(item.cibilDetails.custDtlId) === parseInt(custId));
        if (idx >= 0) {
            inSessionStore.cibilDetailsWrapperList.splice(idx, 1);
        }
    }
    cibilDtls = {};
    apz.app.CBcheck.clearCbUI();
    // Re-trigger BRE
    apz.startLoader();
    apz.app.CBcheck.triggerBREService();
};
