//   CB CHECK SCREEN
window.CBcheckScr = 'KmSourc__CBcheck__';
var screenId = 'KmSourc__CBcheck__';
var otpScreenId = 'KmSourc__Kmbase__';
window.CB_LOAN_ID = null;
//  IS_MOBILE_DEDUPE_REQ = true;
//  OTP GLOBAL STATE
window.CB_OTP_TIMER = null;
window.CB_OTP_TIME_LEFT = 150;
window.CB_OTP_RESEND_COUNT = 0;
window.CB_OTP_MAX_RESEND = 3;
window.CB_API_TRIGGERED = {
    applicant: false,
    coapplicant: false
};
window.CB_FORM_STATE = {
    applicant: {
        validated: false
    },
    coapplicant: {
        validated: false
    }
};
window.CB_OTP_STATE = {
    applicant: {
        verified: false,
        mobile: null
    },
    coapplicant: {
        verified: false,
        mobile: null
    }
};
window.CB_OTP_UI_UNLOCK = {
    applicant: false,
    coapplicant: false
};
window.CB_VERIFIED_MOBILES = {
    applicant: new Set(),
    coapplicant: new Set()
};
window.CB_Validate = {
    fnCheckMaxMinLengthOnBlur: function(pthis) {
        let minlength = pthis.minLength;
        let maxlength = pthis.maxLength;
        let value = pthis.value.trim();
        let $field = $("#" + pthis.id);
        if (!apz.isNull(value) && (value.length < minlength || value.length > maxlength)) {
            window.gIsMinMaxErr = true;
            $field.addClass("err");
            $("#" + pthis.id + "_ul").next().removeClass("sno");
            let errTxtFieldId = $("#" + pthis.id + "_ul").next()?.find('.icon-Error')?.next() ?? $('#dummyid');
            errTxtFieldId?.text(`Please enter minimum:${minlength} and maximum:${maxlength} characters!`);
            let wrapper;
            if ($field.closest(".etb-slct").length) {
                wrapper = $field.closest(".etb-slct").parent().parent();
            } else if ($field.closest(".ett-inpt").length) {
                wrapper = $field.closest(".ett-inpt").parent().parent();
            } else if ($field.closest("ul").length) {
                wrapper = $field.closest("ul").parent().parent();
            }
            wrapper?.addClass("error-inline");
        } else {
            window.gIsMinMaxErr = false;
            let wrapper;
            if ($field.closest(".etb-slct").length) {
                wrapper = $field.closest(".etb-slct").parent().parent();
            } else if ($field.closest(".ett-inpt").length) {
                wrapper = $field.closest(".ett-inpt").parent().parent();
            } else if ($field.closest("ul").length) {
                wrapper = $field.closest("ul").parent().parent();
            }
            wrapper?.removeClass("error-inline");
        }
    },
    required: function(fieldId, message) {
        let $el = $("#" + fieldId);
        if ($el.length === 0) return true;
        let value = ($el.val() || "").trim();
        if (!value || value === PleaseSelect) {
            showFieldError(fieldId, message);
            return false;
        }
        return true;
    },
    regex: function(fieldId, regex, message) {
        let $el = $("#" + fieldId);
        if ($el.length === 0) return true;
        let value = ($el.val() || "").trim();
        if (value && !regex.test(value)) {
            showFieldError(fieldId, message);
            return false;
        }
        return true;
    },
    lengthRange: function(fieldId, min, max, message) {
        let $el = $("#" + fieldId);
        if ($el.length === 0) return true;
        let value = ($el.val() || "").trim();
        if (value && (value.length < min || value.length > max)) {
            showFieldError(fieldId, message);
            return false;
        }
        return true;
    },
    maxLength: function(fieldId, max, message) {
        let $el = $("#" + fieldId);
        if ($el.length === 0) return true;
        let value = ($el.val() || "").trim();
        if (value && value.length > max) {
            showFieldError(fieldId, message);
            return false;
        }
        return true;
    }
};
//   ON LOAD
apz.app.onLoad_CBcheck = function() {
    apz.app.CBcheck.showSlider();
    apz.app.CBcheck.setDefaultSliderValue();
    $('#KmSourc__CBcheck__loanSlider').removeClass("wrapped");
    gApzCOB.currentApplicant = 1;
    PerDetScrId = CBcheckScr;
    apz.app.CBcheck.togglePanView();
    var applicantBtn = document.querySelector('.cbcheckSubMenu');
    if (applicantBtn) {
        apz.app.CBcheck.handletabSwitch(applicantBtn, 'Applicant');
    }
    apz.populateDropdown(document.getElementById(`${CBcheckScr}relationShipWithApplicant`), ApzCOB.formatDropDownforArray(ApzCOB.filterRelns(
        relations)));
    apz.populateDropdown(document.getElementById(`${CBcheckScr}loanPurpose`), ApzCOB.formatDropDownforArray(loanPurpose));
    apz.populateDropdown(document.getElementById(`${CBcheckScr}subLoanPurpose`), ApzCOB.formatDropDownforArray([
        ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")
    ]));
    $(`#${CBcheckScr}subLoanPurpose`).attr('disabled', true);
    let leadData = gApzCOB?.selLeadDtls ?? inSessionStore.leadDetails;
    var kendraFreq = leadData?.kendraMeetingFreq || '';
    if (kendraFreq === "WEEKLY") {
        filteredFrequencies = frequencyOfRepayment.slice(0, 4);
    } else if (kendraFreq === "BIWEEKLY") {
        filteredFrequencies = [0, 2, 3].map(i => frequencyOfRepayment[i]);
    } else {
        filteredFrequencies = [0, 3].map(i => frequencyOfRepayment[i]);
    }
    apz.populateDropdown(document.getElementById(`${CBcheckScr}frequencyOfRepayment`), ApzCOB.formatDropDownforArray(filteredFrequencies));
    apz.populateDropdown(document.getElementById(`${CBcheckScr}coGender`), ApzCOB.formatDropDownforArray(gender));
    apz.app.CBcheck.paintLoanDetails();
    $('.cb-otp-protected').addClass('sno');
    ApzCOB.setMinMaxLength([{
        'fieldName': 'Name',
        'fieldId': CBcheckScr + 'coCustomerName'
    }, {
        'fieldName': 'MobileNumber',
        'fieldId': CBcheckScr + 'primaryMobile'
    }, {
        'fieldName': 'MobileNumber',
        'fieldId': CBcheckScr + 'sec_mobile'
    }, {
        'fieldName': 'CKYC',
        'fieldId': CBcheckScr + 'ckycNumber' // C_KYC
    }, {
        'fieldName': 'AddressLine1',
        'fieldId': CBcheckScr + 'addressLine1'
    }, {
        'fieldName': 'AddressLine2',
        'fieldId': CBcheckScr + 'addressLine2'
    }, {
        'fieldName': 'AddressLine3',
        'fieldId': CBcheckScr + 'addressLine3'
    }, {
        'fieldName': 'Pincode',
        'fieldId': CBcheckScr + 'pincode'
    }, {
        'fieldName': 'City',
        'fieldId': CBcheckScr + 'addPreCity'
    }, {
        'fieldName': 'District',
        'fieldId': CBcheckScr + 'addPreDistrict'
    }, {
        'fieldName': 'State',
        'fieldId': CBcheckScr + 'addPreState'
    }]);
    // apz.app.CBcheck.togglePanView();
    $("#scr__" + screenId + "main").on("mousedown", "input, select", function() {
        clearFieldError(this.id);
    });
    $(`#${screenId}primaryMobile`).on('input', function() {
        this.value = this.value.replace(/[^0-9]/g, '');
        let newMobile = $(this).val();
        let isApplicant = gApzCOB.currentApplicant <= 1;
        let state = isApplicant ? CB_OTP_STATE.applicant : CB_OTP_STATE.coapplicant;
        let verifiedCache = isApplicant ? CB_VERIFIED_MOBILES.applicant : CB_VERIFIED_MOBILES.coapplicant;
        //  SPECIAL RULE: CO-APPLICANT SAME AS LAST VERIFIED APPLICANT MOBILE
        if (!isApplicant && CB_OTP_STATE.applicant.mobile && newMobile === CB_OTP_STATE.applicant.mobile) {
            CB_OTP_STATE.coapplicant.verified = true;
            CB_OTP_STATE.coapplicant.mobile = newMobile;
            CB_OTP_UI_UNLOCK.coapplicant = true;
            // Hide OTP UI
            $('#' + screenId + 'sendOtpBtn').addClass('sno');
            $('#' + screenId + 'otpSuccessRow').addClass('sno');
            // Show SAME MOBILE NOTE DIV
            $('#' + screenId + 'sameMobileInfoDiv').removeClass('sno');
            apz.app.CBcheck.toggleOtpProtectedSections();
            return;
        } else {
            // Hide note div if not same mobile
            $('#' + screenId + 'sameMobileInfoDiv').addClass('sno');
        }
        //  IF NUMBER WAS ALREADY VERIFIED BEFORE (CACHE)
        if (verifiedCache.has(newMobile)) {
            state.verified = true;
            state.mobile = newMobile;
            $('#' + screenId + 'otpSuccessRow').removeClass('sno');
            $('#' + screenId + 'sendOtpBtn').addClass('sno');
            $('#' + screenId + 'sameMobileInfoDiv').addClass('sno');
            apz.app.CBcheck.toggleOtpProtectedSections();
            return;
        }
        // NEW NUMBER (NOT VERIFIED)
        if (state.mobile !== newMobile) {
            state.verified = false;
            state.mobile = null;
            if (isApplicant) {
                CB_OTP_UI_UNLOCK.applicant = false;
            } else {
                CB_OTP_UI_UNLOCK.coapplicant = false;
            }
            $('#' + screenId + 'otpSuccessRow').addClass('sno');
            $('#' + screenId + 'sendOtpBtn').removeClass('sno');
            $('#' + screenId + 'sameMobileInfoDiv').addClass('sno');
            apz.app.CBcheck.toggleOtpProtectedSections();
        }
    });
    if (window.CBCHECK_TAB_SWITCH_TARGET) {
        let target = window.CBCHECK_TAB_SWITCH_TARGET;
        window.CBCHECK_TAB_SWITCH_TARGET = null;
        let tabs = $('.cbcheckSubMenu');
        if (target === 'CoApplicant' && tabs.length > 1) {
            apz.app.CBcheck.handletabSwitch(tabs.eq(1), 'CoApplicant');
        } else {
            apz.app.CBcheck.handletabSwitch(tabs.eq(0), 'Applicant');
        }
    }
    apz.app.CBcheck.toggleOtpProtectedSections();
    if (!apz.isNull(cbCallType)) {
        if (cbCallType.CB_TYPE === 'BOTH') {
            CBCALLTYPEFLAG = cbCallType.BRE_BRANCH.includes(gApzCOB.requestNodes.applicationMaster.branchId) ? 'BRE' : 'IRE';
        } else {
            CBCALLTYPEFLAG = cbCallType.CB_TYPE;
        }
    }
};
//Save Draft and switch tab
apz.app.CBcheck.saveAndSwitch = function(pthis, CustType) {
    apz.app.CBcheck.createRequest(true);
    apz.app.CBcheck.handletabSwitch(pthis, CustType);
}
//   TAB SWITCH
apz.app.CBcheck.handletabSwitch = function(pthis, CustType) {
    clearAllTabErrors();
    $('.cbcheckSubMenu').removeClass('active');
    $(pthis).addClass('active');
    // $('input[name="' + screenId + 'panVal_"][value="Y"]').prop('checked', true);
    apz.app.CBcheck.togglePanView();
    /* =========================================
       TAB SWITCH
    ========================================= */
    if (CustType === 'Applicant') {
        gApzCOB.currentApplicant = 1;
        $('.src-coapp').hide();
        $('.src-app').show();
        $(`#${kmbaseScr}sidebarForm a`).removeClass('active');
        $(`#${kmbaseScr}CBcheck_hyp`).addClass('active');
        $(`#${kmbaseScr}AppCBcheck_hyp`).addClass('active');
    } else {
        gApzCOB.currentApplicant = 2;
        $('.src-app').hide();
        $('.src-coapp').show();
        $(`#${kmbaseScr}sidebarForm a`).removeClass('active');
        $(`#${kmbaseScr}CBcheck_hyp`).addClass('active');
        $(`#${kmbaseScr}CoAppCBcheck_hyp`).addClass('active');
    }
    //   CLEAR FORM BEFORE PAINT
    apz.app.CBcheck.clearForm();
    //   PAINT DETAILS
    apz.app.CBcheck.paintDetails();
    apz.app.CBcheck.paintLoanDetails();
    //   OTP SECTION CHECK
    apz.app.CBcheck.refreshOtpUI();
    apz.app.CBcheck.toggleOtpProtectedSections();
    apz.app.CBcheck.restoreCibilFromSession();
    apz.app.CBcheck.toggleInitiateRow();
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let isOtpUnlocked = isApplicant ? CB_OTP_UI_UNLOCK.applicant : CB_OTP_UI_UNLOCK.coapplicant;
    if (isOtpUnlocked) {
        apz.app.CBcheck.togglePanView();
    }
};
//   BUILD SUB PURPOSE DROPDOWN
apz.app.CBcheck.buildSubPurposeDropdown = function(selectedPurpose) {
    if (selectedPurpose === PleaseSelect) {
        $(`#${CBcheckScr}subLoanPurpose`).val(PleaseSelect).attr('disabled', true);
        return;
    }
    let subPurposeList = loanSubPurpose?.[0]?.[selectedPurpose] || [];
    let formattedList = [...subPurposeList];
    if (!formattedList.includes(PleaseSelect)) {
        formattedList.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
    }
    apz.populateDropdown(document.getElementById(`${CBcheckScr}subLoanPurpose`), ApzCOB.formatDropDownforArray(formattedList));
    $(`#${CBcheckScr}subLoanPurpose`).attr('disabled', false);
};
//   ON CHANGE LOAN PURPOSE
apz.app.CBcheck.onChangeLoanPurpose = function(pthis) {
    let selectedPurpose = $(`#${CBcheckScr}loanPurpose`).val();
    apz.app.CBcheck.buildSubPurposeDropdown(selectedPurpose);
    ApzCOB.dropDownOnChange(pthis);
};
//   SLIDER
apz.app.CBcheck.showSlider = function() {
    $("#" + screenId + "loanSlider").slider({
        range: "min",
        value: parseInt(fdAmountMin),
        min: parseInt(fdAmountMin),
        max: parseInt(fdAmountMax),
        slide: function(event, ui) {
            ui.value = Math.round(ui.value / 1000) * 1000;
            $("#" + screenId + "loanAmount").val("\u20B9" + " " + ApzCOB.fn_FormatAmount(ui.value)).trigger("onchange");
        },
        change: function(event, ui) {
            ui.value = Math.round(ui.value / 1000) * 1000;
            $("#" + screenId + "loanAmount").val("\u20B9" + " " + ApzCOB.fn_FormatAmount(ui.value));
        },
        stop: function(event, ui) {
            ui.value = Math.round(ui.value / 1000) * 1000;
            $("#" + screenId + "loanAmount").val("\u20B9" + " " + ApzCOB.fn_FormatAmount(ui.value));
        }
    }).slider("pips", {
        rest: false,
    }).slider("float");
}
apz.app.CBcheck.setDefaultSliderValue = function() {
    $("#" + screenId + "loanSlider").slider("option", "value", fdDefaultLoanAmount);
    $("#" + screenId + "loanAmount").val("\u20B9" + " " + ApzCOB.fn_FormatAmount(fdDefaultLoanAmount));
};
apz.app.CBcheck.amountSliderControl = function() {
    var data = ApzCOB.fn_unFormatAmount($("#" + screenId + "loanAmount").val());
    if (!isNaN(data) && parseInt(data) >= fdAmountMin && parseInt(data) <= fdAmountMax) {
        $("#" + screenId + "loanSlider").slider("option", "value", data);
    }
};
///OTP
apz.app.CBcheck.openOtpModal = function() {
    let valid = apz.app.CBcheck.validateMobileForOtp();
    if (!valid) return;
    let mobile = $(`#${screenId}primaryMobile`).val();
    if (!mobile || mobile.length !== 10) {
        ApzCOB.fnDisplayMsg("Mobile number not available", "E");
        return;
    }
    let maskedMobile = "*******" + mobile.slice(-3);
    $(`#${otpScreenId}otpInfoText`).text(`OTP is sent to your Mobile No. ${maskedMobile}`);
    if (!mobile) {
        ApzCOB.fnDisplayMsg("Mobile number not available", "E");
        return;
    }
    ApzCOB.OtpSmsService(mobile);
    for (let i = 1; i <= 4; i++) {
        $('#' + otpScreenId + 'otp' + i).val('');
    }
    $('#' + screenId + 'otpSuccessRow').addClass('sno');
    ApzCOB.toggleModal(otpScreenId + "Otp_Modal");
    apz.app.CBcheck.initOtpInputs();
    window.CB_OTP_RESEND_COUNT = 0;
    $('#' + otpScreenId + 'resendOtpBtn').prop('disabled', true);
    apz.app.CBcheck.startOtpTimer();
    $('#' + otpScreenId + 'otp1').focus();
};
apz.app.CBcheck.initOtpInputs = function() {
    for (let i = 1; i <= 4; i++) {
        let fieldId = otpScreenId + 'otp' + i;
        $('#' + fieldId).off('input keydown');
        $('#' + fieldId).on('input', function() {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (this.value.length === 1 && i < 4) $('#' + otpScreenId + 'otp' + (i + 1)).focus();
        });
        $('#' + fieldId).on('keydown', function(e) {
            if (e.key === "Backspace" && this.value === "" && i > 1) $('#' + otpScreenId + 'otp' + (i - 1)).focus();
        });
    }
};
apz.app.CBcheck.startOtpTimer = function() {
    if (window.CB_OTP_TIMER) clearInterval(window.CB_OTP_TIMER);
    window.CB_OTP_TIME_LEFT = 150; // 2 minutes timer
    // $('#' + otpScreenId + 'resendOtpBtn').addClass('sno'); // Disable resend button
    $('#' + otpScreenId + 'resendOtpBtn').prop('disabled', true);
    $('#' + otpScreenId + 'otpTimer').removeClass('sno'); // Show timer UI
    window.CB_OTP_TIMER = setInterval(function() {
        let min = Math.floor(window.CB_OTP_TIME_LEFT / 60);
        let sec = window.CB_OTP_TIME_LEFT % 60;
        let formatted = `${min < 10 ? '0' + min : min}:${sec < 10 ? '0' + sec : sec}`;
        $('#' + otpScreenId + 'otpTimer').text("Time remaining " + formatted);
        window.CB_OTP_TIME_LEFT--;
        if (window.CB_OTP_TIME_LEFT <= 0) {
            clearInterval(window.CB_OTP_TIMER);
            window.CB_OTP_TIMER = null;
            $('#' + otpScreenId + 'otpTimer').addClass('sno'); // Hide timer UI
            if (window.CB_OTP_RESEND_COUNT < window.CB_OTP_MAX_RESEND) {
                // $('#' + otpScreenId + 'resendOtpBtn').removeClass('sno'); // Enable resend button
                $('#' + otpScreenId + 'resendOtpBtn').prop('disabled', false);
            }
        }
    }, 1000);
};
apz.app.CBcheck.resendOtp = function() {
    if (window.CB_OTP_RESEND_COUNT >= window.CB_OTP_MAX_RESEND) {
        ApzCOB.fnDisplayMsg("Maximum resend attempts reached", "E");
        return;
    }
    let mobile = $(`#${screenId}primaryMobile`).val();
    // let mobile = "6382154047";
    if (apz.isNull(mobile) || mobile === "") {
        ApzCOB.fnDisplayMsg("Primary mobile number not available", "E");
        return;
    }
    window.CB_OTP_RESEND_COUNT++;
    ApzCOB.OtpSmsService(mobile);
    apz.app.CBcheck.startOtpTimer();
    ApzCOB.fnDisplayMsg("OTP resent successfully", "S");
};
apz.app.CBcheck.otpVerifiedSuccess = function() {
    let currentMobile = $(`#${screenId}primaryMobile`).val();
    let isApplicant = gApzCOB.currentApplicant <= 1;
    if (isApplicant) {
        CB_OTP_STATE.applicant.verified = true;
        CB_OTP_STATE.applicant.mobile = currentMobile;
        CB_OTP_UI_UNLOCK.applicant = true;
        CB_VERIFIED_MOBILES.applicant.add(currentMobile);
        window.isVerified = "N";
        apz.app.CBcheck.createCBCheck();
    } else {
        CB_OTP_STATE.coapplicant.verified = true;
        CB_OTP_STATE.coapplicant.mobile = currentMobile;
        CB_OTP_UI_UNLOCK.coapplicant = true;
        CB_VERIFIED_MOBILES.coapplicant.add(currentMobile);
    }
    if (window.CB_OTP_TIMER) {
        clearInterval(window.CB_OTP_TIMER);
        window.CB_OTP_TIMER = null;
    }
    ApzCOB.toggleModal(otpScreenId + "Otp_Modal");
    $('#' + screenId + 'otpSuccessRow').removeClass('sno');
    $('#' + screenId + 'sendOtpBtn').addClass('sno');
    apz.app.CBcheck.toggleOtpProtectedSections();
    ApzCOB.fnDisplayMsg("OTP Verified Successfully", "S");
};
apz.app.CBcheck.verifyOtp = function() {
    let otp = '';
    for (let i = 1; i <= 4; i++) {
        otp += $('#' + otpScreenId + 'otp' + i).val();
    }
    if (otp.length !== 4) {
        ApzCOB.fnDisplayMsg("Enter complete OTP", "E");
        return;
    }
    ApzCOB.verfyOtpService(otp);
};
apz.app.CBcheck.togglePanView = function() {
    let selectedVal = $('input[name="' + screenId + 'panVal_"]:checked').val() || 'Y';
    if (selectedVal === 'N') {
        $('#' + screenId + 'panView').addClass('sno'); // Hide
    } else {
        $('#' + screenId + 'panView').removeClass('sno'); // Show
    }
};
apz.app.CBcheck.formValidator = function() {
    let isValid = true;
    let isApplicant = Number(gApzCOB.currentApplicant) === 1;

    function check(result) {
        if (!result) isValid = false;
    }
    let primaryMobileId = screenId + "primaryMobile";
    check(CB_Validate.required(primaryMobileId, "Primary mobile number is required"));
    // check(CB_Validate.regex(primaryMobileId, /^[0-9]{10}$/, "Mobile number must be 10 digits"));
    let otpState = isApplicant ? CB_OTP_STATE.applicant : CB_OTP_STATE.coapplicant;
    if (!otpState.verified) {
        showFieldError(primaryMobileId, "OTP verification is required");
        isValid = false;
    }
    if (isApplicant) {
        let loanAmountId = screenId + "loanAmount";
        check(CB_Validate.required(loanAmountId, "Loan amount is required"));
        let amountRaw = $("#" + loanAmountId).val();
        let amount = Number(ApzCOB.fn_unFormatAmount(amountRaw));
        if (!amountRaw || amount < Number(fdAmountMin) || amount > Number(fdAmountMax)) {
            showFieldError(loanAmountId, "Amount must be within allowed range");
            isValid = false;
        }
        check(CB_Validate.required(screenId + "loanPurpose", "Please select loan purpose"));
        check(CB_Validate.required(screenId + "subLoanPurpose", "Please select sub purpose"));
        check(CB_Validate.required(screenId + "frequencyOfRepayment", "Select repayment frequency"));
    }
    let dobId = isApplicant ? screenId + "dob" : screenId + "coDob";
    let ageId = isApplicant ? screenId + "age" : screenId + "coAge";
    check(CB_Validate.required(dobId, "Date of birth is required"));
    let ageVal = $("#" + ageId).val();
    let age = Number(ageVal);
    if (!ageVal || age < 18) {
        showFieldError(ageId, "Age must be 18 or above");
        isValid = false;
    }
    let address1Id = screenId + "addressLine1";
    let pincodeId = screenId + "pincode";
    clearFieldError(address1Id);
    check(CB_Validate.required(address1Id, "Address line 1 is required"));
    clearFieldError(pincodeId);
    check(CB_Validate.required(pincodeId, "Pincode is required"));
    if (!isApplicant) {
        let coNameId = screenId + "coCustomerName";
        clearFieldError(coNameId);
        check(CB_Validate.required(coNameId, "Co-applicant name is required"));
        check(CB_Validate.required(screenId + "relationShipWithApplicant", "Select relationship"));
        check(CB_Validate.required(screenId + "coGender", "Gender is required"));
        check(CB_Validate.required(screenId + "coDob", "Date of birth is required"));
        if (!ageVal || age < 18) {
            showFieldError(ageId, "Co-applicant must be 18 or above");
            isValid = false;
        }
    }
    return isValid;
};
apz.app.CBcheck.validateForm = function() {
    let valid = apz.app.CBcheck.formValidator();
    if (!valid) {
        ApzCOB.fnDisplayMsg("Please ensure all fields are properly filled before initiating the check.", "E");
        return false;
    }
    //  SET FORM VALIDATION STATE (PER TAB)
    let isApplicant = gApzCOB.currentApplicant <= 1;
    if (isApplicant) {
        CB_FORM_STATE.applicant.validated = true;
    } else {
        CB_FORM_STATE.coapplicant.validated = true;
    }
    //  SHOW POST VALIDATION SECTIONS ONLY FOR THAT TAB
    apz.app.CBcheck.togglePostValidationSections();
    return true;
};
apz.app.CBcheck.refreshOtpUI = function() {
    apz.app.CBcheck.deriveOtpStateFromSession();
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let state = isApplicant ? CB_OTP_STATE.applicant : CB_OTP_STATE.coapplicant;
    let verifiedCache = isApplicant ? CB_VERIFIED_MOBILES.applicant : CB_VERIFIED_MOBILES.coapplicant;
    let currentMobile = $(`#${screenId}primaryMobile`).val();
    //  CASE 1: CO-APPLICANT SAME AS APPLICANT VERIFIED MOBILE
    if (!isApplicant && CB_OTP_STATE.applicant.mobile && currentMobile === CB_OTP_STATE.applicant.mobile) {
        CB_OTP_STATE.coapplicant.verified = true;
        CB_OTP_STATE.coapplicant.mobile = currentMobile;
        CB_OTP_UI_UNLOCK.coapplicant = true;
        $('#' + screenId + 'sendOtpBtn').addClass('sno');
        $('#' + screenId + 'otpSuccessRow').addClass('sno');
        $('#' + screenId + 'sameMobileInfoDiv').removeClass('sno');
        apz.app.CBcheck.toggleOtpProtectedSections();
        return;
    }
    //  CASE 2: MOBILE EXISTS IN VERIFIED CACHE
    if (currentMobile && verifiedCache.has(currentMobile)) {
        state.verified = true;
        state.mobile = currentMobile;
        $('#' + screenId + 'otpSuccessRow').removeClass('sno');
        $('#' + screenId + 'sendOtpBtn').addClass('sno');
        $('#' + screenId + 'sameMobileInfoDiv').addClass('sno');
    } else {
        //  CASE 3: NOT VERIFIED
        $('#' + screenId + 'otpSuccessRow').addClass('sno');
        $('#' + screenId + 'sendOtpBtn').removeClass('sno');
        $('#' + screenId + 'sameMobileInfoDiv').addClass('sno');
    }
    apz.app.CBcheck.toggleOtpProtectedSections();
};

function clearFieldError(fieldId) {
    let field = document.getElementById(fieldId);
    if (!field) return;
    // Remove error-inline from any parent
    let parent = field.parentElement;
    while (parent) {
        if (parent.classList.contains("error-inline")) {
            parent.classList.remove("error-inline");
            break;
        }
        parent = parent.parentElement;
    }
    // Remove error message
    let errorEl = document.getElementById(fieldId + "_error");
    if (errorEl) {
        errorEl.remove();
    }
}

function showFieldError(fieldId, message) {
    let field = document.getElementById(fieldId);
    if (!field) return;
    clearFieldError(fieldId);
    let wrapper;
    // If dropdown (Appzillon select)
    if (field.closest(".etb-slct")) {
        wrapper = field.closest(".etb-slct").parentElement;
    }
    // If normal input
    else if (field.closest(".ett-inpt")) {
        wrapper = field.closest(".ett-inpt").parentElement;
    }
    // Fallback
    else {
        wrapper = field.parentElement;
    }
    if (wrapper) {
        wrapper.classList.add("error-inline");
    }
    let error = document.createElement("div");
    error.className = "cb-error-msg";
    error.id = fieldId + "_error";
    error.innerText = message;
    wrapper.appendChild(error);
}
apz.app.CBcheck.validateMobileForOtp = function() {
    let isApplicant = Number(gApzCOB.currentApplicant) === 1;
    let mobileId = screenId + "primaryMobile";
    let mobile = $("#" + mobileId).val();
    clearFieldError(mobileId);
    if (!mobile) {
        showFieldError(mobileId, "Mobile number is required");
        return false;
    }
    if (!/^[0-9]{10}$/.test(mobile)) {
        showFieldError(mobileId, "Mobile number must be 10 digits");
        return false;
    }
    // Co-applicant primary number matches LAST VERIFIED Applicant mobile
    if (!isApplicant) {
        let applicantVerifiedMobile = CB_OTP_STATE.applicant.mobile;
        if (applicantVerifiedMobile && mobile === applicantVerifiedMobile) {
            // Auto mark verified (NO OTP REQUIRED)
            CB_OTP_STATE.coapplicant.verified = true;
            CB_OTP_STATE.coapplicant.mobile = mobile;
            CB_OTP_UI_UNLOCK.coapplicant = true;
            CB_VERIFIED_MOBILES.coapplicant.add(mobile);
            // Hide OTP UI
            $('#' + screenId + 'sendOtpBtn').addClass('sno');
            $('#' + screenId + 'otpSuccessRow').addClass('sno');
            // Show SAME MOBILE NOTE DIV
            $('#' + screenId + 'sameMobileInfoDiv').removeClass('sno');
            apz.app.CBcheck.toggleOtpProtectedSections();
            return false; // Prevent OTP modal
        }
    }
    return true;
};
apz.app.CBcheck.ageCalculator = function(pthis) {
    // Get the ID of the field that triggered the event
    let id = pthis.id;
    // Calculate the age based on the selected date of birth
    let age = ApzCOB.getAge($('#' + id).val());
    // Determine whether the current applicant is the main applicant or co-applicant
    let isApplicant = gApzCOB.currentApplicant === 1; // true if Applicant, false if Co-applicant
    // If age is valid, update the corresponding age field
    if (age > 0) {
        if (isApplicant) { // If the current applicant is the main applicant
            $('#' + screenId + 'age').val(age).change(); // Update applicant's age
        } else { // If the current applicant is the co-applicant
            $('#' + screenId + 'coAge').val(age).change(); // Update co-applicant's age
        }
        // If age was previously set, clear the DOB field
        if (window.age) {
            $(`#${id}`).val('');
        }
    } else {
        // If age calculation fails (invalid DOB), show error and clear both DOB and age
        ApzCOB.fnDisplayMsg('Please select a valid date of birth', "E");
        $('#' + id).val(''); // Clear the DOB field
        if (isApplicant) {
            $('#' + screenId + 'age').val('');
        } else {
            $('#' + screenId + 'coAge').val('');
        }
    }
}

function clearAllTabErrors() {
    // Remove all inline error classes
    $(".error-inline").removeClass("error-inline");
    // Remove all error message divs
    $(".cb-error-msg").remove();
}
apz.app.CBcheck.toggleOtpProtectedSections = function() {
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let isUnlocked = isApplicant ? CB_OTP_UI_UNLOCK.applicant : CB_OTP_UI_UNLOCK.coapplicant;
    //  ALWAYS hide first
    $('.cb-otp-protected').addClass('sno');
    $('.cb-otp-common').addClass('sno');
    // If OTP not verified → STOP
    if (!isUnlocked) return;
    // OTP verified → show common sections (PAN, Address, etc.)
    $('.cb-otp-common').removeClass('sno');
    // Show tab specific sections
    if (isApplicant) {
        $('.src-app.cb-otp-protected').removeClass('sno');
    } else {
        $('.src-coapp.cb-otp-protected').removeClass('sno');
    }
};
apz.app.CBcheck.togglePostValidationSections = function() {
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let isFormValidated = isApplicant ? CB_FORM_STATE.applicant.validated : CB_FORM_STATE.coapplicant.validated;
    // Hide all post-validation sections first
    $('.cb-post-validated').addClass('sno');
    // If current tab form not validated, do nothing
    if (!isFormValidated) return;
    // Show common validated sections (for that tab only)
    $('.cb-common-validated').removeClass('sno');
    // Show tab specific validated sections
    if (isApplicant) {
        $('.src-app.cb-post-validated').removeClass('sno');
    } else {
        $('.src-coapp.cb-post-validated').removeClass('sno');
    }
};
apz.app.CBcheck.paintDetails = function() {
    /* =========================================
    //   FRESH CASE DETECTION 
    ========================================= */
    let customerList = inSessionStore?.customerDetailsList || gApzCOB?.requestNodes?.customerDetailsWrapperList;
    let addressWrapperRoot = inSessionStore?.addressDetailsWrapperList || gApzCOB?.requestNodes?.addressDetailsWrapperList;
    // Check if both inSessionStore and gApzCOB.requestNodes are null/empty -> Fresh Case
    if ((apz.isNull(inSessionStore.customerDetailsList) || inSessionStore.customerDetailsList.length === 0) && (apz.isNull(gApzCOB.requestNodes
            .customerDetailsList) || gApzCOB.requestNodes.customerDetailsList.length === 0)) {
        // Fresh Case - Use gApzCOB.selLeadDtls like PersonalDetails
        apz.app.CBcheck.paintFreshCaseDetails();
        return;
    }
    /* =========================================
    //   EXISTING CASE - Continue with normal painting
    ========================================= */
    if (!customerList?.length) {
        return;
    }
    /* =========================================
      IDENTIFY CURRENT APPLICANT 
    ========================================= */
    let isApplicant = gApzCOB.currentApplicant === 1;
    let custType = isApplicant ? "Applicant" : "Co-App";
    let custWrapper = customerList.find(c => c.customerType === custType);
    // if (apz.isNull(custWrapper) || apz.isNull(custWrapper.payload)) {
    //     return;
    // }
    if (apz.isNull(custWrapper) || apz.isNull(custWrapper.payload)) {
        // restore UI state for the tab
        apz.app.CBcheck.refreshOtpUI();
        apz.app.CBcheck.toggleOtpProtectedSections();
        apz.app.CBcheck.togglePostValidationSections();
        return;
    }
    let custId = custWrapper.custDtlId;
    let payload = custWrapper.payload;
    /* =========================================
    //   BASIC DETAILS
    ========================================= */
    if (isApplicant) {
        $('#' + screenId + 'customerName').val(custWrapper.customerName || "");
        $('#' + screenId + 'dob').val(payload.dob || "");
        $('#' + screenId + 'age').val(payload.age || "");
        $('#' + screenId + 'gender').val(payload.gender || "");
    } else {
        $('#' + screenId + 'coCustomerName').val(custWrapper.customerName || "");
        $('#' + screenId + 'coDob').val(payload.dob || "");
        $('#' + screenId + 'coAge').val(payload.age || "");
        $('#' + screenId + 'coGender').val(payload.gender || "");
        $('#' + screenId + 'relationShipWithApplicant').val(payload.relationShipWithApplicant || PleaseSelect);
    }
    /* =========================================
    //   KYC
    ========================================= */
    $('#' + screenId + 'nameAsPerVoter').val(payload.namePerKyc || "");
    $('#' + screenId + 'voterId').val(payload.primaryKycId || "");
    $('#' + screenId + 'alternateVoterId').val(payload.alternateVoterId || "");
    $('#' + screenId + 'ckycNumber').val(payload.ckyc || "");
    /* =========================================
    //   PAN
    ========================================= */
    $('#' + screenId + 'panName').val(payload.namePerPan || "");
    $('#' + screenId + 'panNum').val(payload.panNumber || "");
    let panVal = payload.panNumberValue || "Y";
    $(`input[name="${screenId}panVal_"][value="${panVal}"]`).prop("checked", true);
    apz.app.CBcheck.togglePanView();
    /* =========================================
    //   MOBILE
    ========================================= */
    // $('#' + screenId + 'primaryMobile').val(custWrapper.mobileNumber || "");
    // $('#' + screenId + 'sec_mobile').val(payload.secMobileNo || "");
    /* =========================================
   MOBILE
========================================= */
    let primaryMobile = custWrapper.mobileNumber || "";
    $('#' + screenId + 'primaryMobile').val(primaryMobile);
    $('#' + screenId + 'sec_mobile').val(payload.secMobileNo || "");
    /* =========================================
       RESTORE OTP STATE FROM SESSION
    ========================================= */
    // if (payload.isMobVerified === "Y" && primaryMobile) {
    //     if (isApplicant) {
    //         CB_OTP_STATE.applicant.verified = true;
    //         CB_OTP_STATE.applicant.mobile = primaryMobile;
    //         CB_OTP_UI_UNLOCK.applicant = true;
    //         CB_VERIFIED_MOBILES.applicant.add(primaryMobile);
    //     } else {
    //         CB_OTP_STATE.coapplicant.verified = true;
    //         CB_OTP_STATE.coapplicant.mobile = primaryMobile;
    //         CB_OTP_UI_UNLOCK.coapplicant = true;
    //         CB_VERIFIED_MOBILES.coapplicant.add(primaryMobile);
    //     }
    // }
    /* =========================================
    //   ADDRESS 
    ========================================= */
    // if (addressWrapperRoot?.length) {
    //     let wrappers = addressWrapperRoot?.[0]?.addressDetailsList || addressWrapperRoot;
    //     let addressWrapper = wrappers.find(w => w.addressType === "Personal" && w.custDtlId == custWrapper.custDtlId);
    //     if (!apz.isNull(addressWrapper) && !apz.isNull(addressWrapper.payload)) {
    //         let addrList = addressWrapper.payload?.addressList;
    //         if (!addrList?.length) return;
    //         // Find Present address specifically (AadhaarDetails pattern)
    //         let present = addrList.find(a => a.addressType === "Present");
    //         if (present) {
    //             $('#' + screenId + 'addressLine1').val(present.addressLine1 || "");
    //             $('#' + screenId + 'addressLine2').val(present.addressLine2 || "");
    //             $('#' + screenId + 'addressLine3').val(present.addressLine3 || "");
    //             $('#' + screenId + 'addPreCity').val(present.city || "");
    //             $('#' + screenId + 'addPreDistrict').val(present.district || "");
    //             $('#' + screenId + 'addPreState').val(present.state || "");
    //             $('#' + screenId + 'pincode').val(present.pinCode || "");
    //         }
    //     }
    // }
    /* =========================================
   ADDRESS 
========================================= */
    if (addressWrapperRoot?.length) {
        let wrappers = addressWrapperRoot?.[0]?.addressDetailsList || addressWrapperRoot;
        let addressWrapper = wrappers.find(w => w.addressType === "Personal" && String(w.custDtlId) === String(custWrapper.custDtlId));
        if (!apz.isNull(addressWrapper) && !apz.isNull(addressWrapper.payload)) {
            let addrList = addressWrapper.payload?.addressList || [];
            if (addrList.length > 0) {
                let present = addrList.find(a => a.addressType === "Present");
                let voter = addrList.find(a => a.addressType === "Voter");
                let addressToPaint;
                //  Intelligent selection
                if (window.CB_ADDRESS_OVERRIDE_TYPE === "Voter") {
                    addressToPaint = voter || present;
                    console.log("Painting Voter address (return from documentCapture)");
                } else {
                    addressToPaint = present || voter;
                    console.log("Painting Present address (default flow)");
                }
                if (addressToPaint) {
                    $('#' + screenId + 'addressLine1').val(addressToPaint.addressLine1 || "");
                    $('#' + screenId + 'addressLine2').val(addressToPaint.addressLine2 || "");
                    $('#' + screenId + 'addressLine3').val(addressToPaint.addressLine3 || "");
                    $('#' + screenId + 'addPreCity').val(addressToPaint.city || "");
                    $('#' + screenId + 'addPreDistrict').val(addressToPaint.district || "");
                    $('#' + screenId + 'addPreState').val(addressToPaint.state || "");
                    $('#' + screenId + 'pincode').val(addressToPaint.pinCode || "");
                }
            }
        }
    }
    /* =========================================
    //   UI STATE RESTORE
    ========================================= */
    apz.app.CBcheck.refreshOtpUI();
    apz.app.CBcheck.toggleOtpProtectedSections();
    apz.app.CBcheck.togglePostValidationSections();
};
apz.app.CBcheck.paintFreshCaseDetails = function() {
    /* =========================================
    //   FRESH CASE PAINTING 
    ========================================= */
    if (gApzCOB.currentApplicant === 1) {
        var cstDtls = gApzCOB.selLeadDtls;
        // Paint applicant fields from selLeadDtls
        $('#' + screenId + 'customerName').val(cstDtls.fullName || "");
        $('#' + screenId + 'dob').val(ApzCOB.dateformatter(cstDtls.dob, 'd/m/Y') || "");
        $('#' + screenId + 'age').val(ApzCOB.getAge(cstDtls.dob) || "");
        $('#' + screenId + 'gender').val(cstDtls.gender || "");
        // KYC Details
        $('#' + screenId + 'nameAsPerVoter').val(cstDtls.fullName || "");
        $('#' + screenId + 'voterId').val(cstDtls.primaryKyc || "");
        $('#' + screenId + 'alternateVoterId').val(cstDtls.alternateVoterId || "");
        $('#' + screenId + 'ckycNumber').val(cstDtls.applicantCkyc || "");
        // Mobile Details
        // $('#' + screenId + 'primaryMobile').val(cstDtls.mobileNo || "");
        // $('#' + screenId + 'sec_mobile').val(cstDtls.secMobileNo || "");
        let primaryMobile = cstDtls.mobileNo || "";
        $('#' + screenId + 'primaryMobile').val(primaryMobile);
        /* If lead already verified mobile */
        // if (cstDtls.isMobVerified === "Y" && primaryMobile) {
        //     CB_OTP_STATE.applicant.verified = true;
        //     CB_OTP_STATE.applicant.mobile = primaryMobile;
        //     CB_OTP_UI_UNLOCK.applicant = true;
        //     CB_VERIFIED_MOBILES.applicant.add(primaryMobile);
        // }
        // Address from selLeadDtls (if available)
        if (!apz.isNull(cstDtls.presLine1)) {
            $('#' + screenId + 'addressLine1').val(cstDtls.presLine1 || "");
            $('#' + screenId + 'addressLine2').val(cstDtls.presLine2 || "");
            $('#' + screenId + 'addressLine3').val(cstDtls.presLine3 || "");
            $('#' + screenId + 'addPreCity').val(cstDtls.presCity || "");
            $('#' + screenId + 'addPreDistrict').val(cstDtls.presDistrict || "");
            $('#' + screenId + 'addPreState').val(cstDtls.presState || "");
            $('#' + screenId + 'pincode').val(cstDtls.presPincode || "");
        }
        // Additional fields from selLeadDtls
        $('#' + screenId + 'relationShipWithApplicant').val(cstDtls.relationship || PleaseSelect);
    }
    // UI State Restore
    apz.app.CBcheck.refreshOtpUI();
    apz.app.CBcheck.toggleOtpProtectedSections();
    apz.app.CBcheck.togglePostValidationSections();
};
