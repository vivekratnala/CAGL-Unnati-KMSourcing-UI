apz.app.CBcheck.paintCibilDetails = function() {
    /* =========================================
       RESOLVE CUSTID
    ========================================= */
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let custId = isApplicant ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId;
    if (apz.isNull(custId)) {
        custId = apz.app.CBcheck.getCurrentCustId();
    }
    if (apz.isNull(custId) && isApplicant) {
        custId = gApzCOB?.selLeadDtls?.custDtlId || null;
    }
    if (apz.isNull(custId)) return;
    /* =========================================
       RESTORE cibilDtls FROM SESSION
    ========================================= */
    if (apz.isNull(cibilDtls) || Object.keys(cibilDtls).length === 0) {
        if (!apz.isNull(inSessionStore.cibilDetailsWrapperList) && inSessionStore.cibilDetailsWrapperList.length > 0) {
            let item = inSessionStore.cibilDetailsWrapperList.find(el => parseInt(el.cibilDetails.custDtlId) === parseInt(custId));
            if (!apz.isNull(item) && !apz.isNull(item.cibilDetails.payload)) {
                cibilDtls = JSON.parse(JSON.stringify(item.cibilDetails.payload));
            }
        }
    }
    if (apz.isNull(cibilDtls) || Object.keys(cibilDtls).length === 0) return;
    /* =========================================
       NORMALIZE DATA
       Use cbSummaryArr for colon-split fields
       Use direct clean for others
    ========================================= */
    cbSummaryArr.forEach(el => ApzCOB.beautifyCbDtlsSummary(el, cibilDtls));

    function cleanVal(val) {
        if (val === null || val === undefined || val === "null" || val === "NULL") return "";
        return val;
    }
    /* =========================================
       STATUS FLAGS
    ========================================= */
    let finalDecision = cleanVal(cibilDtls.finalDecision)?.toLowerCase() || '';
    let isApproved = finalDecision.includes("approve") || finalDecision === "pass";
    if (isApplicant) {
        window.APPLICANT_CIBIL_STATUS = isApproved;
    } else {
        window.CO_APPLICANT_CIBIL_STATUS = isApproved;
    }
    /* =========================================
       PAINT FIELDS DIRECTLY
    ========================================= */
    $('#' + screenId + 'bureauName').val(cleanVal(cibilDtls.bureauName));
    $('#' + screenId + 'cbScore').val(cleanVal(cibilDtls.cbScore));
    $('#' + screenId + 'totIndebtness').val(cleanVal(cibilDtls.totIndebtness));
    $('#' + screenId + 'writeoffSuitFiledFlag').val(cleanVal(cibilDtls.writeoffSuitFiledFlag));
    $('#' + screenId + 'overdueAmt').val(cleanVal(cibilDtls.overdueAmt));
    $('#' + screenId + 'writeOffAmt').val(cleanVal(cibilDtls.writeOffAmt));
    $('#' + screenId + 'cgp_dpd').val(cleanVal(cibilDtls.caglDpdFlag));
    $('#' + screenId + 'runningEMI').val(cleanVal(cibilDtls.foir));
    $('#' + screenId + 'unnatiDec').val(finalDecision);
    $('#' + screenId + 'unnatiDecReason').val(cleanVal(cibilDtls.rejectionReason));
    $('#' + screenId + 'roi').val(cleanVal(cibilDtls.roi) + "%");
    $('#' + screenId + 'finalTenure').val(cleanVal(cibilDtls.finalTenure) + " months");
    $('#' + screenId + 'eligibleAmount').text("Eligible amount : " + (cleanVal(cibilDtls.eligibleAmt) || "0"));
    $('#' + screenId + 'roiDisplay').text((cleanVal(cibilDtls.roi) || "0") + '%');
    /* =========================================
       MANUAL FIELDS — cbStatus + lastDate
    ========================================= */
    let isApiSuccess = cibilDtls.irisMessage === "success";
    $('#' + screenId + 'cbStatus').text(isApiSuccess ? 'Success' : 'Failure');
    let cbDate = "";
    if (!apz.isNull(inSessionStore.cibilDetailsWrapperList)) {
        let sessionItem = inSessionStore.cibilDetailsWrapperList.find(el => parseInt(el.cibilDetails.custDtlId) === parseInt(custId));
        cbDate = sessionItem?.cibilDetails?.cbDate || "";
    }
    if (apz.isNull(cbDate) || cbDate === "") {
        cbDate = ApzCOB.dateformatter(new Date(), 'd M Y');
    }
    $('#' + screenId + 'lastDate').text(cbDate);
    /* =========================================
       DECISION UI
    ========================================= */
    // if (isApproved) {
    //     $('#' + screenId + 'retryRow').addClass('sno');
    //     $('#' + screenId + 'rejectReasonRow').addClass('sno');
    // } else {
    //     $('#' + screenId + 'rejectReasonRow').removeClass('sno');
    //     $('#' + screenId + 'rejectReasonText').text(cleanVal(cibilDtls.rejectionReason) || '-');
    //     let retryAttempts = parseInt(cibilDtls.retryAttempts ?? 0);
    //     if (retryAttempts > 0) {
    //         $('#' + screenId + 'retryRow').removeClass('sno');
    //     } else {
    //         $('#' + screenId + 'retryRow').addClass('sno');
    //     }
    // }
    /* =========================================
       BUREAU SPECIFIC UI
    ========================================= */
    if (cibilDtls.bureauName === "BRE") {
        $('.hitNohitRow').addClass('sno');
        $('.runningEMIRow').addClass('sno');
        $('.individualIndebtRow').removeClass('sno');
    } else {
        $('.hitNohitRow').removeClass('sno');
        $('.runningEMIRow').removeClass('sno');
        $('.individualIndebtRow').addClass('sno');
    }
    /* =========================================
       SHOW RESULT SECTION
    ========================================= */
    $('.cb-result-section').removeClass('sno');
};
apz.app.CBcheck.deriveOtpStateFromSession = function() {
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let custType = isApplicant ? "Applicant" : "Co-App";
    let sessionCust = inSessionStore?.customerDetailsList?.find(c => c.customerType === custType);
    let currentMobile = $('#' + screenId + 'primaryMobile').val() || "";
    // Reset runtime state first
    let state = isApplicant ? CB_OTP_STATE.applicant : CB_OTP_STATE.coapplicant;
    let unlockState = isApplicant ? 'applicant' : 'coapplicant';
    state.verified = false;
    state.mobile = null;
    CB_OTP_UI_UNLOCK[unlockState] = false;
    if (!sessionCust || !sessionCust.payload) return;
    let payloadMobile = sessionCust.mobileNumber || "";
    let isVerifiedInSession = sessionCust.payload.isMobVerified === "Y";
    // Only trust session if mobile matches
    if (isVerifiedInSession && payloadMobile === currentMobile) {
        state.verified = true;
        state.mobile = currentMobile;
        CB_OTP_UI_UNLOCK[unlockState] = true;
        CB_VERIFIED_MOBILES[unlockState].add(currentMobile);
    }
};
apz.app.CBcheck.restoreCibilFromSession = function() {
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let custId = isApplicant ? (gApzCOB.userDetails.custDtlId || gApzCOB?.selLeadDtls?.custDtlId) : gApzCOB.userDetails.CoApplicantCustomerId;
    if (apz.isNull(custId)) return;
    if (apz.isNull(inSessionStore.cibilDetailsWrapperList)) return;
    let existing = inSessionStore.cibilDetailsWrapperList.find(el => parseInt(el.cibilDetails.custDtlId) === parseInt(custId));
    if (!existing || apz.isNull(existing.cibilDetails.payload)) {
        apz.app.CBcheck.clearCbUI();
        return;
    }
    // Restore payload
    cibilDtls = JSON.parse(JSON.stringify(existing.cibilDetails.payload));
    // Mark form validated
    if (isApplicant) {
        CB_FORM_STATE.applicant.validated = true;
        CB_API_TRIGGERED.applicant = true;
    } else {
        CB_FORM_STATE.coapplicant.validated = true;
        CB_API_TRIGGERED.coapplicant = true;
    }
    // Paint
    apz.app.CBcheck.paintCibilDetails();
    // Show post sections
    apz.app.CBcheck.togglePostValidationSections();
    //Hide initiate row
    apz.app.CBcheck.toggleInitiateRow();
    $('.cb-result-section').removeClass('sno');
};
