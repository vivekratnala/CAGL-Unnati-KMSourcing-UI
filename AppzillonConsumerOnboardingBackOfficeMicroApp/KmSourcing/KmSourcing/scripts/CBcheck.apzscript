apz.app.CBcheck.resetApplicantStates = function() {
    let isApplicant = gApzCOB.currentApplicant <= 1;
    if (isApplicant) {
        CB_OTP_STATE.applicant = {
            verified: false,
            mobile: null
        };
        CB_OTP_UI_UNLOCK.applicant = false;
        CB_FORM_STATE.applicant.validated = false;
    } else {
        CB_OTP_STATE.coapplicant = {
            verified: false,
            mobile: null
        };
        CB_OTP_UI_UNLOCK.coapplicant = false;
        CB_FORM_STATE.coapplicant.validated = false;
    }
    $('#' + screenId + 'otpSuccessRow').addClass('sno');
    $('#' + screenId + 'sendOtpBtn').removeClass('sno');
};
apz.app.CBcheck.paintLoanDetails = function() {
    if (apz.isNull(inSessionStore.loanDetails)) return;
    let LOAN_OBJ = inSessionStore.loanDetails;
    // Only paint for applicant (currentApplicant === 1)
    if (gApzCOB.currentApplicant === 1 && !apz.isNull(LOAN_OBJ)) {
        /* ===============================
        //   Loan Amount
        =============================== */
        let amount = LOAN_OBJ.loanAmount || fdDefaultLoanAmount;
        $('#' + screenId + 'loanAmount').val("\u20B9 " + ApzCOB.fn_FormatAmount(amount));
        // Sync slider
        $("#" + screenId + "loanSlider").slider("option", "value", amount);
        /* ===============================
        //   Loan Purpose
        =============================== */
        let purpose = LOAN_OBJ.payload?.loanPurpose || PleaseSelect;
        $(`#${screenId}loanPurpose`).val(purpose);
        /* ===============================
        //   Sub Purpose (REBUILD FIRST)
        =============================== */
        apz.app.CBcheck.buildSubPurposeDropdown(purpose);
        let subPurpose = LOAN_OBJ.payload?.subCategory || PleaseSelect;
        $(`#${screenId}subLoanPurpose`).val(subPurpose);
        /* ===============================
        //   Frequency
        =============================== */
        $(`#${screenId}frequencyOfRepayment`).val(LOAN_OBJ.payload?.frequencyOfRepayment || PleaseSelect);
    }
};
apz.app.onShown_CBcheck = function() {
    // SIDEBAR ACTIVE STATE — parent always active
    $(`#${kmbaseScr}sidebarForm a`).removeClass('active');
    $(`#${kmbaseScr}CBcheck_hyp`).addClass('active');
    // Child active based on current applicant or pending target
    if (window.CBCHECK_TAB_SWITCH_TARGET === 'CoApplicant') {
        $(`#${kmbaseScr}CoAppCBcheck_hyp`).addClass('active');
    } else {
        $(`#${kmbaseScr}AppCBcheck_hyp`).addClass('active');
    }
    // Restore loan + customer details from session
    apz.app.CBcheck.paintLoanDetails();
    apz.app.CBcheck.paintDetails();
    //  apz.app.CBcheck.handletabSwitch(document.querySelector('.cbcheckSubMenu.active'), gApzCOB.currentApplicant === 1 ? 'Applicant' :
    //  'CoApplicant');
    // $('.cb-otp-protected').addClass('sno');
    // Restore OTP UI state
    apz.app.CBcheck.refreshOtpUI();
    apz.app.CBcheck.toggleOtpProtectedSections();
    // Restore CIBIL details if already fetched
    apz.app.CBcheck.restoreCibilFromSession();
    // Toggle initiate button
    apz.app.CBcheck.toggleInitiateRow();
    let isApplicant = gApzCOB.currentApplicant <= 1;
    let isOtpUnlocked = isApplicant ? CB_OTP_UI_UNLOCK.applicant : CB_OTP_UI_UNLOCK.coapplicant;
    $('input[name="' + screenId + 'panVal_"]:checked').val()
    if (isOtpUnlocked) {
        apz.app.CBcheck.togglePanView();
    }
    // Reset address override flag
    window.CB_ADDRESS_OVERRIDE_TYPE = null;
};
