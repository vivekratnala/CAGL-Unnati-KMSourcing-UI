    $('#' + screenId + 'addressLine1').val("");
    $('#' + screenId + 'addressLine2').val("");
    $('#' + screenId + 'addressLine3').val("");
    $('#' + screenId + 'addPreCity').val("");
    $('#' + screenId + 'addPreDistrict').val("");
    $('#' + screenId + 'addPreState').val("");
    $('#' + screenId + 'pincode').val("");
    // $(`input[name="${screenId}panVal_"]`).prop("checked", false);
    // $(`input[name="${screenId}panVal_"][value="Y"]`).prop("checked", true);
