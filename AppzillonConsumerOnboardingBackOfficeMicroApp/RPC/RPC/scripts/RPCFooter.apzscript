apz.app.RPCFooter.radiocheckSendbackmodal = function() {
    ApzCOB.toggleModal(BaseScrId + "rpcSendback_mdl");
    if ($(`#${BaseScrId}el_rdo_3_option_One`).is(":checked")) {
        action = "RPCPUSHBACK";
    } else if ($(`#${BaseScrId}el_rdo_3_option_Two`).is(":checked")) {
        action = "PUSHBACK";
    }
    setTimeout(function() {
        // ApzCOB.toggleModal(BaseScrId + "conFormation_mdl");
        // $("#APZCBO__BaseScreens__sc_row_305").addClass("sno");
        // $("#APZCBO__BaseScreens__sc_row_306").removeClass("sno");
        // $("#APZCBO__BaseScreens__yes_btn").attr("onClick", "apz.app.RPCFooter.approveReject(this, action)");
        let RpcModalId = "RPC__RpcStageScreen__";
        let popUpObj = {};
        popUpObj.text = "Would you like to send-back the application?";
        popUpObj.Btn1 = {
            text: "Yes",
            onClick: "apz.app.RPCFooter.approveReject(this, action)",
        };
        popUpObj.Btn2 = {
            text: "No",
            onClick: "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()",
        };
        ApzCOB.showRpcModals(popUpObj, "confirmation");
        // $("#RPC__RpcStageScreen__confrmBtn2").attr("onClick", "ApzCOB.toggleModal(`RPC__RpcStageScreen__conFormation_mdl`)");
    }, 500);
};
apz.app.RPCFooter.launchPreviousNextfooter = function(laction) {
    let rpcSideMenuTag = 'RPC__RPCSidebar__menuBarList_row_-1_';
    if (laction == "Next") {
        loadStageNo = ++RPC_CURRENT_STAGE_NO;
    } else {
        loadStageNo = --RPC_CURRENT_STAGE_NO;
    }
    if (loadStageNo <= Object.values(RPC_STAGES).length) {
        if ($(`#${rpcSideMenuTag}${loadStageNo}`).hasClass('sno')) {
            apz.app.RPCFooter.launchPreviousNextfooter(laction);
        } else {
            apz.app.RPCSidebar.navigateToStage(loadStageNo);
            loadStageNo = "";
        }
    } else {
        loadStageNo = "";
        ApzCOB.showRpcModals({
            text: "Verify all the stages first",
            Btn1: {
                text: "OK",
                onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
            }
        }, "Error");
    }
};
apz.app.RPCFooter.queryChckdByDflt = function() {
    let applType = "";
    let chkdQueriesBYDyDflt = [];
    if (custType === "Applicant") {
        applType = "A";
    } else if (custType !== "Applicant") {
        applType = "C";
    }
    let queryDtls = inSessionStore?.rpcStatDetails?.filter(
        (item) => item.stageID === RPC_CURRENT_STAGE_NO && item.custType === applType);
    if (queryDtls?.length > 0) {
        chkdQueriesBYDyDflt = queryDtls[0].query;
        if (Array.isArray(window.QueriesPainted) && window.QueriesPainted.length > 0) {
            const othEntry = chkdQueriesBYDyDflt.find((item) => item.startsWith("oth?"));
            if (othEntry) {
                const [othId, othValue] = othEntry.split("?");
                const othIndex = window.QueriesPainted.findIndex(
                    (entry) => entry.id === othId);
                if (othIndex !== -1) {
                    $(`#${queriesIntfId}id_${othIndex}`).prop("checked", true);
                    $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
                    $(`#${BaseScrId}otherQueryReasonInp`).val(othValue);
                    othReasonSelected = true;
                }
            }
            window.QueriesPainted.forEach((entry, index) => {
                if (chkdQueriesBYDyDflt.includes(entry.id)) {
                    $(`#${queriesIntfId}id_${index}`).prop("checked", true);
                }
            });
        }
    } else {
        return;
    }
};
apz.app.RPCFooter.validatOnSubmit = function() {
    if (rpcStepperStatus.length > 0) {
        const allVerified = rpcStepperStatus.every(
            (item) => item.isVerified === true);
        const allQueriesResolved = rpcStepperStatus.every(
            (item) => item.isQueryExist === false);
        if (!allVerified) {
            ApzCOB.showRpcModals({
                text: "All stages  are not verified.",
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()",
                },
            }, "Error");
            return;
        }
        if (!allQueriesResolved) {
            ApzCOB.showRpcModals({
                text: "The application has queries. Please send back the application",
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()",
                },
            }, "Error");
            return;
        }
        let errMsg = '';
        let appCbStatus = ApzCOB.getPayloadDatafromWrapper('cbStatus', 'Applicant', 'cibilDetailsWrapperList') || '';
        let coAppCbStatus = ApzCOB.getPayloadDatafromWrapper('cbStatus', 'Co-App', 'cibilDetailsWrapperList') || '';
        if (appCbStatus !== 'PASS' && coAppCbStatus !== 'PASS') {
            errMsg = 'Both Applicant and Co-Applicant CB failed!';
        } else if (appCbStatus !== 'PASS') {
            errMsg = 'Applicant CB failed!';
        } else if (coAppCbStatus !== 'PASS') {
            errMsg = 'Co-Applicant CB failed!';
        }
        if (!apz.isNull(errMsg)) {
            ApzCOB.showRpcModals({
                text: errMsg,
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()",
                },
            }, "Error");
            return;
        }
        let rpcRemarks = $('#RPC__ReviewConfirm__rpcComment').val();
        if (apz.isNull(rpcRemarks)) {
            ApzCOB.showRpcModals({
                text: "Please enter the remarks.",
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()",
                },
            }, "Error");
            return;
        }
        if (allVerified && allQueriesResolved) {
            let RpcModalId = "RPC__RpcStageScreen__";
            let popUpObj = {};
            popUpObj.text = "Would you like to submit the application?";
            if (gApzCOB.selectedRole === "RPC_Maker") {
                popUpObj.Btn1 = {
                    text: "Yes",
                    onClick: "apz.app.RPCFooter.approveReject(this,'SUBMIT')",
                };
            } else if (gApzCOB.selectedRole === "RPC_Checker") {
                popUpObj.Btn1 = {
                    text: "Yes",
                    onClick: "apz.app.RPCFooter.approveReject(this,'APPROVED')",
                };
            }
            popUpObj.Btn2 = {
                text: "No",
                onClick: "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()",
            };
            ApzCOB.showRpcModals(popUpObj, "confirmation");
            // $("#RPC__RpcStageScreen__confrmBtn2").attr("onClick", "ApzCOB.toggleModal(`RPC__RpcStageScreen__conFormation_mdl`)");
        }
    } else return;
};
apz.app.RPCFooter.validatOnSendBack = function() {
    if (rpcStepperStatus.length > 0) {
        const allVerified = rpcStepperStatus.every(
            (item) => item.isVerified === true);
        const allQueriesResolved = rpcStepperStatus.every(
            (item) => item.isQueryExist === false);
        if (gApzCOB.selectedRole === "RPC_Maker") {
            if (allVerified && !allQueriesResolved) {
                let RpcModalId = "RPC__RpcStageScreen__";
                let popUpObj = {};
                popUpObj.text = "Would you like to send-back the application?";
                popUpObj.Btn1 = {
                    text: "Yes",
                    onClick: "apz.app.RPCFooter.approveReject(this, 'PUSHBACK')",
                };
                popUpObj.Btn2 = {
                    text: "No",
                    onClick: "apz.app.RpcStageScreen.closeRPCConfirmarionMdl()",
                };
                ApzCOB.showRpcModals(popUpObj, "confirmation");
                // $("#RPC__RpcStageScreen__confrmBtn2").attr("onClick", "ApzCOB.toggleModal(`RPC__RpcStageScreen__conFormation_mdl`)");
            } else if (allVerified) {
                //("All the stages have been verified successfully. Please submit the application");
                ApzCOB.showRpcModals({
                    text: "All the stages have been verified successfully. Please submit the application",
                    Btn1: {
                        text: "OK",
                        onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()",
                    },
                }, "Error");
                return;
            }
        }
        if (gApzCOB.selectedRole === "RPC_Checker") {
            if (allVerified && !allQueriesResolved) {
                ApzCOB.toggleModal(BaseScrId + "rpcSendback_mdl");
                $("#APZCBO__BaseScreens__okay_btn").attr("onClick", "apz.app.RPCFooter.radiocheckSendbackmodal()");
            } else if (allVerified) {
                ApzCOB.showRpcModals({
                    text: "All the stages have been verified successfully. Please submit the application",
                    Btn1: {
                        text: "OK",
                        onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()",
                    },
                }, "Error");
                return;
            }
        }
    } else return;
};
apz.app.RPCFooter.showSuccessModal = function(message) {
    let popUpObj = {
        text: message,
        Btn: {
            text: "Ok",
            onClick: "apz.app.RpcStageScreen.closeSuccessModalAndProceed()",
        }
    };
    ApzCOB.showRpcModals(popUpObj, "Success");
};
apz.app.RPCFooter.validateInput = function() {
    let inputField = $("#APZCBO__BaseScreens__otherQueryReasonInp");
    // ApzCOB.fnValidateIfsc(inputField[0]);
    let value = inputField.val().trim();
    if (value !== "") {
        ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    }
}
apz.app.RPCFooter.updateQueriesWithLatestDateTime = function() {
    if (
        (window.custType === 'Applicant' || window.custType === 'Co-App') && stageQueries && stageQueries.length > 0 && inSessionStore
        .verifiedStage && inSessionStore.verifiedStage.length > 0 && typeof RPC_CURRENT_STAGE_NO !== 'undefined') {
        var currentStage = parseInt(RPC_CURRENT_STAGE_NO, 10);
        var custLetter = (window.custType === 'Applicant') ? 'A' : 'C';
        var expectedSubMenu = (custLetter === 'A') ? 1 : 2;
        let formattedDateTime = "";
        rpcStepperStatus.forEach(status => {
            if (status.stageID === currentStage && status.isQueryExist && status.subMenu === expectedSubMenu) {
                let matchingEntry = inSessionStore.verifiedStage.find(entry => {
                    let parts = entry.split("_");
                    return parts.length >= 3 && parseInt(parts[0], 10) === currentStage && parts[1] === custLetter;
                });
                if (matchingEntry) {
                    let parts = matchingEntry.split("_");
                    let dateTimeStr = parts[2];
                    if (dateTimeStr.includes("T")) {
                        formattedDateTime = ApzCOB.dateformatter(dateTimeStr, "date", "d/m/Y").split('.')[0] ?? dateTimeStr;
                    }
                }
            }
        });
        $("#RPC__RPC_Query__queryText_txtcnt").text("Queries " + "(" + formattedDateTime + ")");
    }
}
