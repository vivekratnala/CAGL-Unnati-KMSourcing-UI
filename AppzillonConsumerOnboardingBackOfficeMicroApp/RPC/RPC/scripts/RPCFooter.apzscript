var rpcftrScrId = "RPC__RPCFooter__";
var submit_btn = "submit_btn";
var reject_btn = "reject_btn";
var sendBack_btn = "sendBack_btn";
var queriesIntfId = "APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__";
var othReasonId = "";
window.othReasonSelected = false;
var searchVal = "";
var sendBackopt1 = "#APZCBO__BaseScreens__el_rdo_3_option_One";
var sendBackopt2 = "#APZCBO__BaseScreens__el_rdo_3_option_Two";
var action = "";
var checkedQueries = [];
apz.app.onLoad_RPCFooter = function() {
    //Load Footer
};
apz.app.onShown_RPCFooter = function() {
    //Show Footer
    //apz.app.RPCFooter.loadQueryModal('Applicant');
    $("#" + rpcftrScrId + "Previous").prop("disabled", false);
    $("#" + rpcftrScrId + "Next").prop("disabled", false);
    if (RPC_CURRENT_STAGE_NO === 1) {
        $("#" + rpcftrScrId + "Previous").prop("disabled", true);
    } else if (RPC_CURRENT_STAGE_NO === gApzCOB?.rpcStages?.length) {
        $("#" + rpcftrScrId + "Next").prop("disabled", true);
    }
    apz.childScr = RPC_CURRENT_STAGE;
    $('#APZCBO__BaseScreens__queryModal_close').click(() => {
        apz.app.RPCFooter.onClickQueryMdlCancel();
    });
};
apz.app.RPCFooter.onClickQuery = function() {
    apz.app.RPCFooter.loadQueryModal(custType);
};
apz.app.RPCFooter.loadQueryModal = function(curAppl) {
    ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    let currentStageQueries = RPC_CURRENT_STAGE_FIELDS.find(field => field.id === RPC_CURRENT_STAGE_NO);
    let queryArray = [],
    currApplicantQueries = [];
    currApplicantQueries = JSON.parse(currentStageQueries?.queries)?.[curAppl];
    queryArray = [...currApplicantQueries,{
            id: "oth",
            value: "Other",
        }];
    // arr.push({
    //         id: "oth",
    //         value: "Other",
    //     });
    if (queryArray.length > 0) {
        apz.data.scrdata.APZCBO__RPCQueries_Res = [];
        apz.data.scrdata.APZCBO__RPCQueries_Res = structuredClone(queryArray);
        window.QueriesPainted = structuredClone(queryArray);
        apz.data.loadData("RPCQueries", gAppId);
        $(".crt-list li").attr("onClick", "");
        $(`#${BaseScrId}otherQueryReasonInp`).val("");
        // $(`#${BaseScrId}otherQueryReasonInp`).attr('maxlength',250);
        $('#APZCBO__BaseScreens__queryModal_content').scrollTop(0,0);
        $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
        $(`#${BaseScrId}queryList`).find("p").filter(function(el, item) {
            if ($(`#${queriesIntfId}value_${el}_txtcnt`)[0].textContent === "Other") {
                othReasonId = `#${queriesIntfId}id_${el}`;
                $(`#${queriesIntfId}id_${el}`).attr("onchange", "apz.app.RPCFooter.onSelectOtherReason();");
            }
        });
        apz.app.RPCFooter.queryChckdByDflt();
        $(`#${BaseScrId}queryList`).addClass("pb-70");
        if(currApplicantQueries.length === 0){
            $(`#${BaseScrId}search_row`).addClass('sno');  
            $('#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_0').prop('checked',true).change()
          } else {
            $(`#${BaseScrId}search_row`).removeClass('sno');  
          }
          ApzCOB.toggleModal(BaseScrId + "queryModal");
    }
};
apz.app.RPCFooter.onSelectOtherReason = function() {
    let othVal = $(othReasonId).prop("checked");
    if (othVal) {
        $(`#${BaseScrId}queryList`).removeClass("pb-70")
        othReasonSelected = true;
        $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
        // $(`#${BaseScrId}otherQueryReasonInp`).off("input").on("input", function() {
        //     let inputVal = $(this).val().trim();
        //     if (inputVal !== "") {
        //         ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
        //     } else {
        //         ApzCOB.addErrMessage(`${BaseScrId}otherQueryReasonInp`, "element");
        //     }
        // });
    } else {
        $(`#${BaseScrId}queryList`).addClass("pb-70")
        othReasonSelected = false;
        $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
        $(`#${BaseScrId}otherQueryReasonInp`).val("");
        ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    }
};
apz.app.RPCFooter.onClickQueryMdlCancel = function() {
    checkedQueries = [];
    $(`#${BaseScrId}queryList`).addClass("pb-70");
     $(othReasonId).prop("checked", false)
    $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
    $(`#${BaseScrId}otherQueryReasonInp`).val("");
    ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    ApzCOB.toggleModal(BaseScrId + "queryModal");
};
apz.app.RPCFooter.onClickQueryMdlSave = function() {
    var checkedLength = -1;
    if (othReasonSelected) {
        otherVal = $(`#${BaseScrId}otherQueryReasonInp`).val();
        if (apz.isNull(otherVal)) {
            ApzCOB.addErrMessage(`${BaseScrId}otherQueryReasonInp`, "element");
            document.getElementById('APZCBO__BaseScreens__el_txt_136_txtcnt').scrollIntoView();
            return;
        }
    }
    QueriesPainted.forEach(function(item, index) {
        if ($(`#${queriesIntfId}id_${index}`).prop("checked")) {
            checkedLength++;
            checkedQueries.push(QueriesPainted[index]?.id);
            if (othReasonId === `#${queriesIntfId}id_${index}`) {
                checkedQueries[checkedQueries?.length - 1] = checkedQueries?.[checkedQueries?.length - 1] + "?" + $(
                    `#${BaseScrId}otherQueryReasonInp`).val();
            }
        }
    });
    ApzCOB.RpcQuerySave(checkedQueries);
    checkedQueries = [];
};
apz.app.RPCFooter.searchInQueryMdl = function() {
    var query = $("#APZCBO__BaseScreens__searchQueryInput").val();
    window.searchresults = QueriesPainted.filter((lead) => Object.values(lead).some((value) => String(value).toLowerCase().includes(query
        .toLowerCase())));
    if (searchresults?.length > 0) {
        apz.data.scrdata.APZCBO__RPCQueries_Res = [];
        apz.data.scrdata.APZCBO__RPCQueries_Res = searchresults;
        apz.data.loadData("RPCQueries", gAppId);
        $(`#${BaseScrId}queryList .wrapped.undefined.ssp`).remove();
        $(`#${BaseScrId}queryList`).find("p").filter(function(el, item) {
            if ($(`#${queriesIntfId}value_${el}_txtcnt`)[0].textContent === "Other") {
                othReasonId = `#${queriesIntfId}id_${el}`;
                $(`#${queriesIntfId}id_${el}`).attr("onchange", "apz.app.RPCFooter.onSelectOtherReason();");
            }
        });
        // $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
        $(`#${BaseScrId}noResult_row`).addClass("sno");
        $(`#${BaseScrId}queryList`).removeClass("sno");
        // $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
    } else {
        $(`#${BaseScrId}noResult_row`).removeClass("sno");
        $(`#${BaseScrId}queryList`).addClass("sno");
        $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
    }
};
apz.app.RPCFooter.approveReject = function(pthis, gaction, rMarks) {
    apz.startLoader();
    ApzCOB.userDetailsData();
    apz.app.BaseScreens.stageBasedOnAction(pthis, gaction);
    window.approveRejectAction = gaction;
    if (!apz.isNull(inSessionStore.customerDetailsList)) {
        if (inSessionStore.customerDetailsList.length > 0) {
            inSessionStore.customerDetailsList.map((cust) => {
                if (cust.customerType === "Applicant") {
                    gApzCOB.userDetails.custDtlId = cust.custDtlId;
                } else {
                    gApzCOB.userDetails.CoApplicantCustomerId = cust.custDtlId;
                }
            });
        }
    }
    rMarks = rMarks || $('#RPC__ReviewConfirm__rpcComment').val() || '';
    window.approveRejectAction = "";
    switch (gaction) {
        case "SUBMIT":
            window.approveRejectAction = "PENDINGFORRPCVERIFICATION";
            break;
        case "APPROVED":
            window.approveRejectAction = "RPCVERIFIED";
            break;
        case "PUSHBACK":
            window.approveRejectAction = "IPUSHBACK";
            break;
        case "REJECTED":
            window.approveRejectAction = "REJECTED";
            break;
        case "RPCPUSHBACK":
            window.approveRejectAction = "RPCPUSHBACK";
            break;
        default:
            break;
    }
    var req = {
        apiRequest: {
            // "interfaceName": approveRejectAction === 'APPROVED' ? "CreateApplication" : "",
            interfaceName: "",
            appId: gAppId,
            requestObj: {
                appId: gApzCOB.userDetails.appId,
                status: approveRejectAction,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                applicationId: gApzCOB.userDetails.applicationId,
                versionNum: gApzCOB.userDetails.versionNum,
                custDtlId: gApzCOB.userDetails.custDtlId,
                remarks: rMarks,
                workflow: {
                    currentRole: gApzCOB.workflow.currentRole,
                    action: gApzCOB.workflow.action,
                    workflowId: gApzCOB.workflow.workflowId,
                    stage: gApzCOB.workflow.stage,
                },
            },
        },
    };
    ApzCOB.serverBuildParam(gAppId, "Stagemoment", "N", "N", req, false, apz.app.RPCFooter.approveRejectCB);
};
//Approve Reject Service Callback
apz.app.RPCFooter.approveRejectCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            // var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj)
            if (params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode == 0) {
                if (approveRejectAction === "SUBMIT" || approveRejectAction === "PENDINGFORRPCVERIFICATION" || approveRejectAction ===
                    "APPROVED" || approveRejectAction === "RPCVERIFIED") {
                    apz.stopLoader();
                    submittedTo = 'Next Stage';
                    if (gApzCOB.selectedRole === "RPC_Checker") submittedTo = 'Credit Assessment';
                    if (gApzCOB.selectedRole === "RPC_Maker") submittedTo = 'RPC Checker';
                    apz.app.RPCFooter.showSuccessModal("Application No " + gApzCOB.userDetails.applicationId + ` Submitted Successsfully to ${submittedTo}.`);
                    return;
                }
                if (approveRejectAction === "IPUSHBACK" || approveRejectAction === "RPCPUSHBACK") {
                    if (gApzCOB.selectedRole === "RPC_Checker") {
                        if (approveRejectAction === "IPUSHBACK") {
                            apz.stopLoader();
                            apz.app.RPCFooter.showSuccessModal("Application No " + gApzCOB.userDetails.applicationId +
                                " Sent back to KM Sourcing Successfully.");
                            return;
                        }
                        if (approveRejectAction === "RPCPUSHBACK") {
                            apz.stopLoader();
                            apz.app.RPCFooter.showSuccessModal("Application No " + gApzCOB.userDetails.applicationId +
                                " Sent back to RPC Maker Successfully.");
                            return;
                        }
                    }
                    apz.stopLoader();
                    apz.app.RPCFooter.showSuccessModal("Application No " + gApzCOB.userDetails.applicationId +
                        " Sent back to KM Sourcing Successfully.");
                    return;
                }
                if (approveRejectAction === "REJECTED") {
                    apz.stopLoader();
                    apz.app.RPCFooter.showSuccessModal("Application No " + gApzCOB.userDetails.applicationId + " Rejected Successfully.");
                    return;
                }
            } else {
                ApzCOB.showRpcModals({
                    text: "Failed",
                    Btn1: {
                        text: "OK",
                        onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
                    }
                }, "Error");
            }
        } else {
            apz.stopLoader(); // to be done after getting the proper response from backend
            // ApzCOB.fnDisplayMsg(params.res.Dashbo__ApproveRejectApplication_Res.apiResponse.ResponseHeader.ResponseMessage, "E");
            ApzCOB.showRpcModals({
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
                }
            }, "Error");
        }
    } catch (e) {
        apz.stopLoader();
        // ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_TECHNICALDIFF"), "E");
        ApzCOB.showRpcModals({
            text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
            Btn1: {
                text: "OK",
                onClick: "apz.app.RpcStageScreen.closeRPCErrMdl()"
            }
        }, "Error");
    }
    apz.stopLoader();
};
