apz.app.Saloandetails.reAssesmentDocDeleteCnfm = function(docId){
    let callBackFn = apz.app.Saloandetails.reAssesmentDocDeleteCnfmCB;
  ApzCOB.deleteDocument('','','',docId,callBackFn) 
}
apz.app.Saloandetails.reAssesmentDocDeleteCnfmCB = function (params) {
    apz.stopLoader();
    try {
        const isSuccess = ApzCOB.handleServiceCallBacks(params);
        const modalOptions = {
            text: isSuccess ? "Document Deleted.!" : "Document Delete Failed.!",
            Btn1: {
                text: "OK",
                onClick: isSuccess
                    ? "apz.app.DeviationSanctBase.closeSucmMdl()"
                    : "apz.app.DeviationSanctBase.closeErrMdl()"
            }
        };
        apz.app.DeviationSanctBase.closeCnfmMdl();
        if(isSuccess && params.res.APZCBO__DeleteDocument_Res.apiResponse.ResponseBody.responseObj === 'Success'){
        let deletedDocId = params?.req?.apiRequest?.requestObj?.appDocId || "";  
        let documentArray = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
        if(!apz.isNull(deletedDocId) && documentArray.length > 0){
         let updatedDocs =  documentArray.filter(item => Number(item.appDocId) !== Number(deletedDocId)); 
          inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = [];
           inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = structuredClone(updatedDocs);
        }
        }
        apz.app.Saloandetails.prepareReAssesDocs(); 
        ApzCOB.showRpcModals(modalOptions, isSuccess ? "Success" : "Error");
    } catch (e) {
        ApzCOB.showRpcModals({
            text: technicalErrMsg,
            Btn1: {
                text: "OK",
                onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
            }
        }, "Error");
    }
};
apz.app.Saloandetails.submitReAssesment = function () {
  const remarksElem = $(`#${screenMainId}reAssesmentResp`);
  const response = remarksElem.val();
  remarksElem.removeClass('err-border');
  $('.deviationErrorText').remove();
  if (apz.isNull(response)) {
    remarksElem.addClass('err-border');
    remarksElem.parent().append(`
      <span class="deviationErrorText" style="font-size:12px; color:red; text-align:left;">
        Enter the re-assesment response
      </span>`);
    return;
  }
  let curUserReAssesment = RE_ASSESMENT_DOCS.filter(reAsDoc => reAsDoc.payload.uploadedBy === gApzCOB.LoggedInUserDetails.loginResponse.addInfo1)
  const docCount = curUserReAssesment.length;
  const { MIN, MAX } = RE_ASSES_DOC_COUNT;
  //Commented out the document size validation to make it non-mandatory
  /*if (docCount < MIN || docCount > MAX) {
    ApzCOB.showRpcModals({
      text: `Re-assesment document should be minimum ${MIN} and maximum ${MAX}`,
      Btn1: {
        text: "OK",
        onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
      }
    }, "Error");
    return;
  }*/
  ApzCOB.showRpcModals({
    text: "Do you want to approve the Reassessment?",
    Btn1: {
      text: "Yes",
      onClick: `apz.app.Saloandetails.approveDeviationService("REASSESSMENT")`
    },
    Btn2: {
      text: "No",
      onClick: "apz.app.DeviationSanctBase.closeCnfmMdl()"
    }
  }, "confirmation");
};
apz.app.Saloandetails.BRECBService = function(lAmount) {
    const { loanDetails } = inSessionStore;
    let newSanctionAmt = $(`#${screenMainId}sanLoanInput`).val();
    let unformatAmt = newSanctionAmt.replace(/[^0-9.]/g, '');
    let finalSancAmt = unformatAmt.replace(/\.00$/, '');
    let errMsg = '';
    let curSancLoanAmt = Number(loanDetails?.sanctionedLoanAmount ?? 0);
    if (lAmount) {
        finalSancAmt = lAmount;
    }
    /*let isValid = curSancLoanAmt !== Number(finalSancAmt);
        if (!isValid) return;*/
    let currentStage = `${inSessionStore?.applicationMaster?.applicationStatus} | ${inSessionStore?.applicationMaster?.applicationStatus}`;
    let caglOs = gApzCOB?.selLeadDtls?.caglOs || inSessionStore?.leadDetails?.caglOs || inSessionStore?.renewalLeadDetails?.caglOs;
    let req = {
        "apiRequest": {
            "requestObj": {
                "appId": gAppId,
                "applicationId": gApzCOB.userDetails.applicationId,
                "versionNum": 1,
                "stageId": "BRE",
                "requestType": "Edit",
                "customerType": "Co-App",
                "updatedLoanAmount": Number(finalSancAmt),
                "customerDtlsId": gApzCOB.userDetails.CoApplicantCustomerId,
                "editedFields": [],
                "currentStage": currentStage,
                "caglOs": caglOs
            },
            "userId": LoggedInUserDetails.loginResponse.userDet.id,
            "appId": gAppId,
            "interfaceName": "UploadCALoanData"
        }
    }
    // apz.startLoader();
    let popUpObj = {
        text: "Calling BRE service. Please wait...",
        Btn1: { text: "", onClick: "" },
        Btn2: { text: "", onClick: "" }
    };
    ApzCOB.showRpcModals(popUpObj, "confirmation");
    ApzCOB.addDisableToInput('Sanct__DeviationSanctBase__confirmBtn');
    ApzCOB.serverBuildParam(gAppId, "UploadCALoanData", "N", "N", req, false, apz.app.Saloandetails.changeSanctionLoanAmtCB);
}
apz.app.Saloandetails.unFormatSancAmt = function(pthis) {
    let newSanctionAmt = $(pthis).val();
    let unformatAmt = newSanctionAmt.replace(/[^0-9.]/g, '');
    let finalSancAmt = unformatAmt.replace(/\.00$/, '');
    pthis.value = finalSancAmt.replace(gALLOWONLYINPNUM, "");
}
apz.app.Saloandetails.changeSanctionLoanAmt = function(pthis) {
    if(!apz.isNull(pthis)){
       ApzCOB.checkThousand(pthis);
    }
    const { loanDetails} = inSessionStore;
    let newSanctionAmt = $(`#${screenMainId}sanLoanInput`).val();
    let unformatAmt = newSanctionAmt.replace(/[^0-9.]/g, '');
    let finalSancAmt = unformatAmt.replace(/\.00$/, '');
    let errMsg = '';
    let curSancLoanAmt = Number(loanDetails?.sanctionedLoanAmount ?? 0);
    let isValid = curSancLoanAmt !== Number(finalSancAmt);
    errMsg = apz.app.Saloandetails.validateSanctionLoanAmount();
    if (apz.isNull(errMsg) || (errMsg === 'CB FAILED' && isValid)) {
        // if (!isValid) return;
        apz.app.Saloandetails.BRECBService(Number(finalSancAmt));
        return;
        /*let currentStage = `${inSessionStore?.applicationMaster?.applicationStatus} | ${inSessionStore?.applicationMaster?.applicationStatus}`;
        let caglOs = gApzCOB?.selLeadDtls?.caglOs || inSessionStore?.leadDetails?.caglOs || inSessionStore?.renewalLeadDetails?.caglOs;
        let req = {
            "apiRequest": {
                "requestObj": {
                    "appId": gAppId,
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "versionNum": 1,
                    "stageId": "Sanction",
                    "requestType": "Edit",
                    "customerType": "Co-App",
                    "updatedLoanAmount": Number(finalSancAmt),
                    "customerDtlsId": gApzCOB.userDetails.CoApplicantCustomerId,
                    "editedFields": [],
                    "currentStage": currentStage,
                    "caglOs": caglOs
                },
                "userId": LoggedInUserDetails.loginResponse.userDet.id,
                "appId": gAppId,
                "interfaceName": "UploadCALoanData"
            }
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "UploadCALoanData", "N", "N", req, false, apz.app.Saloandetails.changeSanctionLoanAmtCB);*/
    } else {
        if (errMsg !== 'CB FAILED') {
            ApzCOB.showRpcModals({
                text: errMsg,
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
                }
            }, "Error");
            apz.app.Saloandetails.showSanctionAmtDetails();
        } else {
            let CB_STATUS = ApzCOB.getPayloadDatafromWrapper('cbStatus', 'Co-App', 'cibilDetailsWrapperList');
            if (!apz.isNull(CB_STATUS) && CB_STATUS !== 'PASS') {
                window.rejectRsn = ApzCOB.getPayloadDatafromWrapper('rejectionReason', 'Co-App', 'cibilDetailsWrapperList')
                window.retry_Attempts = ApzCOB.getPayloadDatafromWrapper('retryAttempts', 'Co-App', 'cibilDetailsWrapperList');
                let irisMessage = ApzCOB.getPayloadDatafromWrapper('irisMessage', 'Co-App', 'cibilDetailsWrapperList')
                if (!retry_Attempts || retry_Attempts === 0) {
                    let errMsgBRE = `CB retrigger limit exceeded.Reject the application.<br/>Reject reason: ${window.rejectRsn ?? '-'}.`
                    if (irisMessage?.includes('success')) {
                        errMsgBRE = `BRE CB failed!.Reject the application.<br/>Reject reason: ${window.rejectRsn ?? '-'}.`
                    }
                    let popUpObj = {
                        text: errMsgBRE,
                        Btn: {
                            text: "Ok",
                            onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`);  apz.app.DeviationSanctBase.directReject(this,'REJECTED');"
                        }
                    };
                    ApzCOB.showNewCommonErrorModal(popUpObj);
                    apz.stopLoader();
                    return;
                } else {
                    let errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Remaining retry attempts: ${retry_Attempts}.<br/>Do you want to rehit BRE?`
                    if (irisMessage?.includes('bureauError') && !irisMessage?.includes('roll')) {
                        errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Do you want to rehit BRE?`
                    }
                    popUpObj = {
                        text: errMsgBRE,
                        Btn1: {
                            text: "Yes",
                            onClick: "apz.app.DeviationSanctBase.closeCnfmMdl(); apz.app.Saloandetails.BRECBService();"
                        },
                        Btn2: {
                            text: "No",
                            onClick: "apz.app.DeviationSanctBase.closeCnfmMdl()"
                        }
                    }
                }
                apz.stopLoader();
                ApzCOB.showRpcModals(popUpObj, "confirmation");
            }
            //   apz.app.DeviationSanctBase.directReject(this,'REJECTED')
        }
    }
};
apz.app.Saloandetails.changeSanctionLoanAmtCB = function(params){
    apz.stopLoader();
    $(`#Sanct__DeviationSanctBase__conFormation_mdl_close`).click();
    ApzCOB.addDisableToInput('Sanct__DeviationSanctBase__confirmBtn');
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let resp = params?.res?.APZCBO__UploadCALoanData_Res?.apiResponse?.ResponseBody ?? '';
            if (!apz.isNull(resp)) {
                let msg = resp?.responseObj ?? "";
                if (!apz.isNull(msg)) {
                    if (msg?.toUpperCase()?.includes('BRE CHECK SERVICE FAILED')) {
                        ApzCOB.showRpcModals({
                            text: msg,
                            Btn1: {
                                text: "OK",
                                onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
                            }
                        }, "Error");
                        apz.app.Saloandetails.showSanctionAmtDetails();
                        // ApzCOB.revertRecommendedLoanAmount();
                    } else {
                        ApzCOB.updateInsessionData(params);
                        let coApplicantCBDetails;
                        let {cibilDetailsWrapperList} = inSessionStore || {};
                        if([cibilDetailsWrapperList].some(apz.isObjectEmpty)) return;
                        coApplicantCBDetails = cibilDetailsWrapperList.find((item) => item.cibilDetails?.custDtlId == gApzCOB.userDetails.CoApplicantCustomerId)?.cibilDetails;
                        let CB_STATUS = coApplicantCBDetails?.cbStatus ?? "";
                        if (!apz.isNull(CB_STATUS) && CB_STATUS !== 'PASS') {
                            window.rejectRsn = coApplicantCBDetails?.payload?.rejectionReason;
                            window.retry_Attempts = coApplicantCBDetails?.payload?.retryAttempts;
                            let irisMessage = coApplicantCBDetails?.payload?.irisMessage;
                            if (!retry_Attempts || retry_Attempts === 0) {
                                let errMsgBRE = `CB retrigger limit exceeded.Reject the application.<br/>Reject reason: ${window.rejectRsn ?? '-'}.`
                                if (irisMessage?.includes('success')) {
                                    errMsgBRE = `BRE CB failed!.Reject the application.<br/>Reject reason: ${window.rejectRsn ?? '-'}.`
                                }
                                let popUpObj = {
                                    text: errMsgBRE,
                                    Btn: {
                                        text: "Ok",
                                        onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`); apz.app.DeviationSanctBase.directReject(this,'REJECTED');"
                                    }
                                };
                                ApzCOB.showNewCommonErrorModal(popUpObj);
                                apz.stopLoader();
                                return;
                            } else {
                                let errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Remaining retry attempts: ${retry_Attempts}.<br/>Do you want to rehit BRE?`
                                if (irisMessage?.includes('bureauError') && !irisMessage?.includes('roll')) {
                                    errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Do you want to rehit BRE?`
                                }
                                popUpObj = {
                                    text: `BRE failed due to ${rejectRsn}.<br/>Remaining retry attempts: ${retry_Attempts}.<br/>Do you want to retry?`,
                                    Btn1: {
                                        text: "Yes",
                                        onClick: "apz.app.DeviationSanctBase.closeCnfmMdl(); apz.app.Saloandetails.BRECBService();"
                                    },
                                    Btn2: {
                                        text: "No",
                                        onClick: "apz.app.DeviationSanctBase.closeCnfmMdl()"
                                    }
                                }
                            }
                            apz.stopLoader();
                            ApzCOB.showRpcModals(popUpObj, "confirmation");
                        } else {
                            ApzCOB.removeDisableToInput('Sanct__DeviationSanctBase__confirmBtn');
                            apz.app.Saloandetails.paintBMLoanDetals();
                            apz.app.Saloandetails.showSanctionAmtDetails();
                            apz.app.Saloandetails.validateSanctionLoanAmount();
                        }
                    }
                }
            }
        } else {
            apz.stopLoader();
            // ApzCOB.revertRecommendedLoanAmount();
            ApzCOB.showRpcModals({
                text: technicalErrMsg,
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
                }
            }, "Error");
        }
    } catch {
        apz.stopLoader();
        // ApzCOB.revertRecommendedLoanAmount();
        ApzCOB.showRpcModals({
            text: technicalErrMsg,
            Btn1: {
                text: "OK",
                onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
            }
        }, "Error");
    }
}
apz.app.Saloandetails.showSanctionAmtDetails = function () {
    const { CoApplicantCustomerId } = gApzCOB.userDetails;
    const { loanDetails, leadDetails, renewalLeadDetails } = inSessionStore;
    const coAppCBInfo = inSessionStore.cibilDetailsWrapperList.find(
        cb => Number(cb.cibilDetails.custDtlId) === Number(CoApplicantCustomerId)
    ) || {};
    if (apz.isObjectEmpty(coAppCBInfo)) return;
    const payload = coAppCBInfo.cibilDetails?.payload || {};
    const caglOs = leadDetails?.caglOs || renewalLeadDetails?.caglOs || "";
    // const loanAmt = Number(loanDetails?.sanctionedLoanAmount ?? loanDetails?.bmRecommendedLoanAmount ?? 0);
    const loanAmt = ApzCOB.getPayloadDatafromWrapper('eligibleAmt', 'Co-App', 'cibilDetailsWrapperList');
    const insuranceTotal = Number(payload.insuranceChargeJoint || 0) +
        Number(payload.insuranceChargeMember || 0) +
        Number(payload.insuranceChargeSpouse || 0);
    const netOffAmt = Number(payload.processingFees || 0) + Number(payload.stampDutyCharge || 0) + insuranceTotal +
        Number(caglOs || 0);
    const postNetOff = loanAmt - netOffAmt;
    const formatCurrency = val => val ? `₹ ${ApzCOB.formatamountVal(val)}` : 0;
    const freq = loanDetails?.payload?.frequencyOfRepayment;
    const emi = payload.approvedLoanEMI;
    const emiFreq = emi && freq ? `₹ ${emi} / ${freq}` : "";
    const roi = payload?.roi && payload.roi !== 'null' ? `${payload.roi}%` : "";
    const selectors = {
        sanLoanInput: loanAmt,
        sanLoanAmt: formatCurrency(loanAmt),
        sanROI: roi,
        sanPf: formatCurrency(payload.processingFees),
        sanInsPremium: formatCurrency(insuranceTotal),
        sanStampDuty: formatCurrency(payload.stampDutyCharge),
        sanOS: formatCurrency(caglOs),
        SancbTriggerDate: (`Current CAGL Outstanding (As of ${ApzCOB.getCBTriggerDate() || ''})`),
        sanNetoffAmt: formatCurrency(ApzCOB.formatToTwoDecimal(netOffAmt)),
        sanPostOff: formatCurrency(ApzCOB.formatToTwoDecimal(Number(postNetOff))),  
        sanInstallmentAmtFreq: ApzCOB.formatamountVal(emiFreq.split('/')[0]) + '/' + emiFreq.split('/')[1]
    };
    for (const [idSuffix, value] of Object.entries(selectors)) {
        const selector = `#${screenMainId}${idSuffix}`;
        $(selector).is("input") ? $(selector).val(value) : $(selector).text(value);
    }
};  
apz.app.Saloandetails.validateSanctionLoanAmount = function () {
    const { cibilDetailsWrapperList } = inSessionStore;
    let errMsg = "";
    if (!CURRENT_SANCTION_INFO || CURRENT_SANCTION_INFO.length === 0) return;
    const minAmt = CURRENT_SANCTION_INFO[0].min;
    const maxAmt = CURRENT_SANCTION_INFO[0].max;
    const bmRecommendedLoanAmt = Number(inSessionStore?.loanDetails?.bmRecommendedLoanAmount) || 0;
    const custDetailID = ApzCOB.getCustDetailID("Co-App");
    const coAppCibilDetail = cibilDetailsWrapperList.filter(item => item.cibilDetails.custDtlId === custDetailID);
     let CB_STATUS = coAppCibilDetail?.[0]?.cibilDetails?.cbStatus ?? "";
      if(!apz.isNull(CB_STATUS) && CB_STATUS === 'PASS'){
        const eligibleAmt = Number(coAppCibilDetail?.[0]?.cibilDetails?.payload?.eligibleAmt) || 0;
        const minLoanAmount = Math.min(eligibleAmt, bmRecommendedLoanAmt);
        const newAmount = Number($(`#${screenMainId}sanLoanInput`).val()) || 0;
        if (!newAmount || newAmount === 0) {
        errMsg = 'Enter valid loan amount';
        } else if (newAmount < minAmt || newAmount > maxAmt) {
        errMsg = `Sanction loan amount should be between minimum and maximum loan amount. <br/><br/> Minimum Loan Amount : ${minAmt} <br/> Maximum Loan Amount : ${maxAmt}`;
        } else if (apz.isNull(minLoanAmount) || newAmount > minLoanAmount) {
        errMsg = `Sanction loan amount should be minimum of New BRE and BM Recommended Amount. <br/><br/> Maximum Limit : ${minLoanAmount}`;
        } else if (apz.isNull(bmRecommendedLoanAmt) || newAmount > bmRecommendedLoanAmt) {
        errMsg = `Sanction loan amount should be minimum of New BRE and BM Recommended Amount. <br/><br/> Maximum Limit : ${minLoanAmount}`;
        }
        
      } else {
        errMsg = 'CB FAILED';
        window.rejectRsn = ApzCOB.getPayloadDatafromWrapper('rejectionReason', 'Co-App', 'cibilDetailsWrapperList')
        window.retry_Attempts = ApzCOB.getPayloadDatafromWrapper('retryAttempts', 'Co-App', 'cibilDetailsWrapperList');
      }
      return errMsg;
}
