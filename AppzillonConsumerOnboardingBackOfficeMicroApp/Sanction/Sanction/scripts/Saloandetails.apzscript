var screenMainId = "Sanct__Saloandetails__",
    reAssesmentResponseRiv = $(`#${screenMainId}reassessmentResponse`),
    applicationStatus = inSessionStore?.applicationMaster?.applicationStatus,
    RE_ASSESMENT_DOCS = [],
    CURRENT_SANCTION_INFO = [],
    currentDeviationID = '',
    DEVIATION_DATA = {
        "deviation": [],
        "reAssesment": []
    },
    RE_ASSES_DOC_COUNT = {
        'MAX': 2,
        'MIN': 1
    };
window.pendingReAssesmentCount = 0;
apz.app.onLoad_Saloandetails = function() {
    $('body').addClass("unati crdas sanction-dev");
    $('.headerLogo img').removeClass('sno');
    $(`#${screenMainId}btn__RLD`).click();
    apz.app.Saloandetails.paintFieldDataDetails();
    apz.app.Saloandetails.prepareDeviationData();
    $("input").attr("autocomplete", "off");
};
apz.app.onShown_Saloandetails = function() {
    const isResanction = inSessionStore.applicationMaster.applicationStatus === 'RESANCTION';
    const row421 = $("#" + screenMainId + "sc_row_421");
    if (isResanction) {
        row421.removeClass("sno");
        let formattedLoanAmount = ApzCOB.formatamountVal(inSessionStore.loanDetails.sanctionedLoanAmount);
        let lindex = inSessionStore.applicationTimelineDtl?.findLastIndex(el => el.stage === 'Resanction' || el.stage === 'Sanction')
        if (lindex >= 0) {
            let sanctRem = inSessionStore.applicationTimelineDtl[lindex]?.['remarks'];
            if (!apz.isNull(sanctRem)) {
                sanctRem = sanctRem?.split(' | ')?.[0];
                formattedLoanAmount = ApzCOB.formatamountVal(parseInt(sanctRem) ?? inSessionStore?.loanDetails?.sanctionedLoanAmount);
            }
        }
        $("#" + screenMainId + "el_txt_444_txtcnt").text("₹" + formattedLoanAmount);
        $("#" + screenMainId + "el_txt_300_txtcnt").text("Eligible Loan Amount as per BRE Re-Hit -");
        $("#" + screenMainId + "BMloanAmount").text(BREloanAmount);
    } else {
        row421.addClass("sno");
    }
    apz.app.Saloandetails.paintDeviationReAssesment('deviation');
    apz.app.Saloandetails.paintDeviationReAssesment('reAssesment');
     if (applicationStatus === 'CACOMPLETED' || applicationStatus === 'RESANCTION') {
        $('.reAssesmentModules.imgupload').addClass('sno');
        reAssesmentResponseRiv.removeClass('sno');
        $(`#${screenMainId}sanctionMainRow`).removeClass('sno');
        $(`#${sancBaseElemID}reject_btn`).removeClass('sno');
        $('#Sanct__Saloandetails__AMheading p.ett-para.pri span').text(`${gApzCOB.LoggedInUserDetails.loginResponse.addInfo1} Sanction`);
        apz.app.Saloandetails.getSanctionMatrixBasedOnRole();
        apz.app.Saloandetails.showSanctionAmtDetails();
        let sancloanAmt = Number(inSessionStore.loanDetails?.sanctionedLoanAmount ?? inSessionStore.loanDetails?.bmRecommendedLoanAmount ?? 0);
        let breEligibleAmt = ApzCOB.getPayloadDatafromWrapper('eligibleAmt', 'Co-App', 'cibilDetailsWrapperList');
        if (breEligibleAmt !== 'null' && sancloanAmt > breEligibleAmt) {
            $(`#${screenMainId}sanLoanInput`).val(breEligibleAmt);
        }
        // apz.app.Saloandetails.changeSanctionLoanAmt();
        apz.app.Saloandetails.BRECBService();
    } else if (applicationStatus === 'PENDINGPRESANCTION') {
        $(`#${screenMainId}preSanctionMainRow`).removeClass('sno');
    }
};
apz.app.Saloandetails.getSanctionMatrixBasedOnRole = function(){
  if(SANCTION_MATRIX.length === 0) return;
  CURRENT_SANCTION_INFO = SANCTION_MATRIX.filter(sanInfo => sanInfo.role === gApzCOB.LoggedInUserDetails.loginResponse.addInfo1);
}
apz.app.Saloandetails.paintFieldDataDetails = function() {
    if (apz.isObjectEmpty(inSessionStore)) return;
    apz.app.Saloandetails.paintLoanDetails();
    apz.app.Saloandetails.paintBMLoanDetals();
}
apz.app.Saloandetails.prepareReAssesDocs = function(){
    if(apz.isObjectEmpty(inSessionStore) || !inSessionStore.hasOwnProperty('applicationDocumentsWrapperList')) return;
    let documentResp = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList
    if(documentResp.length > 0){
      RE_ASSESMENT_DOCS =   documentResp.filter(docs => docs.payload.documentType === 'ReAssesmentDoc' && parseInt(docs.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));
    //   && docs.payload.uploadedBy === gApzCOB.LoggedInUserDetails.loginResponse.addInfo1
       let parentDiv = $(`#${screenMainId}reAssesDoc_cloneRow`);
         parentDiv.html('');
      if(RE_ASSESMENT_DOCS.length > 0){
         let selectElementID =  `${screenMainId}reassesDoctItem_0`;
         RE_ASSESMENT_DOCS.forEach((doc, index) => {
        let newId = ApzCOB.cloneDashboardDivs(selectElementID, parentDiv, index + 1);
        $(`#${newId} .docName a.ett-hypl span`).text(doc.payload.documentFileName);
        if(!apz.isNull(doc.payload.uploadedBy)){
         $(`#${newId} .docUploadedBy label`).html(`Uploaded By : <span>${doc.payload.uploadedBy}</span>`);   
        }else {
          $(`#${newId} .docUploadedBy`).addClass('sno');  
        }
        if(doc.payload.uploadedBy !== gApzCOB.LoggedInUserDetails.loginResponse.addInfo1){
           $(`#${newId}.uploadimg .dltIcon`).addClass('sno'); 
        }  else {
          $(`#${newId}.uploadimg .dltIcon`).removeClass('sno');   
         }
         $(`#${newId}`).attr('data-id',doc.appDocId);
        $(`#${newId}`).removeClass('sno');
         })
      }
    }
}
apz.app.Saloandetails.paintLoanDetails = function() {
    let {
        applicationMaster: applicationData,
        loanDetails,
        leadDetails,
        renewalLeadDetails
    } = inSessionStore || {};
    let applicationDate = ApzCOB.converApplicationDate(applicationData?.applicationDate);
    let formattedDate = !apz.isNull(applicationDate) ? ApzCOB.dateformatter(applicationDate, "d/m/Y") : '-';
    const fieldMappings = {
        loanAmountInput: ApzCOB.formatamountVal(loanDetails?.loanAmount),
        frequencyOfRepaymentInput: loanDetails?.payload?.frequencyOfRepayment,
        tenureInput: loanDetails?.tenure,
        kendraMeetingFreqInput: leadDetails?.kendraMeetingFreq || renewalLeadDetails?.kendraMeetingFreq,
        kendraMeetingDayInput: leadDetails?.kendraMeetingDay || renewalLeadDetails?.kendraMeetingDay,
        createdByInput: applicationData?.createdBy,
        applicationDateInput: formattedDate,
        loanPurposeInput: loanDetails?.payload?.loanPurpose,
        subCategoryInput: loanDetails?.payload?.subCategory
    };
    Object.entries(fieldMappings).forEach(([key, value]) => {
        $(`#${screenMainId}${key}`).val(value);
    });
}
apz.app.Saloandetails.paintBMLoanDetals = function(){
    let applicantCBDetails;
    let coApplicantCBDetails;
    let {cibilDetailsWrapperList,loanDetails,leadDetails,renewalLeadDetails} = inSessionStore || {};
    if([cibilDetailsWrapperList, loanDetails].some(apz.isObjectEmpty)) return;
    cibilDetailsWrapperList.forEach(custType => {
        if(custType.cibilDetails.custDtlId === gApzCOB.userDetails.custDtlId){
            applicantCBDetails = custType.cibilDetails.payload;
        } else {
            coApplicantCBDetails = custType.cibilDetails.payload;
        }
    })
    let insurancePremium = Number(coApplicantCBDetails?.insuranceChargeJoint) + Number(coApplicantCBDetails?.insuranceChargeMember) + Number(coApplicantCBDetails?.insuranceChargeSpouse);
    insurancePremium = isNaN(insurancePremium) ? 0 : insurancePremium;
    let netAmountTotal =  Number(coApplicantCBDetails?.processingFees) + Number(insurancePremium) + Number(coApplicantCBDetails?.stampDutyCharge) + Number(leadDetails?.caglOs || renewalLeadDetails?.caglOs);
    netAmountTotal = isNaN(netAmountTotal) ? 0 : netAmountTotal;
    let bmRecoLoanAmt = loanDetails?.bmRecommendedLoanAmount || '';
    let totalAmountValue = Number(bmRecoLoanAmt) - netAmountTotal;
    window.BREloanAmount = coApplicantCBDetails?.eligibleAmt ?? 0;
        let indebtNessVal = coApplicantCBDetails?.totIndebtness?.split('|')?.[0]?.split(':')?.[1]?.trim() || '';
        let TotalIncome = inSessionStore?.bcmpiIncomeDetails?.bcmpiIncomeDetailsWrapper?.fieldAssessedIncome || 0;
     let osAmt = leadDetails?.caglOs || renewalLeadDetails?.caglOs;
        let fields = {
        eligibalLoanAmount: ApzCOB.formatamountVal(BREloanAmount),
        bmRecommended: ApzCOB.formatamountVal(bmRecoLoanAmt),
        BMloanAmount: ApzCOB.formatamountVal(bmRecoLoanAmt),
        rateOfInterest: coApplicantCBDetails?.roi,
        processingFee: ApzCOB.formatamountVal(coApplicantCBDetails?.processingFees),
        insurencePremium: ApzCOB.formatamountVal(insurancePremium),
        StampCharges: ApzCOB.formatamountVal(coApplicantCBDetails?.stampDutyCharge),
        outstandingAmount: ApzCOB.formatamountVal(osAmt),
        cbTriggerDate: (`Current CAGL Outstanding (As of ${ApzCOB.getCBTriggerDate() || ''})`),
        netAmount:  ApzCOB.formatamountVal(netAmountTotal),
        totalAmount:  ApzCOB.formatamountVal(Number(totalAmountValue)),
        frequency: `₹ ${ApzCOB.formatamountVal(coApplicantCBDetails?.approvedLoanEMI)} / ${loanDetails?.payload?.frequencyOfRepayment}`,
        applicantOverdue: apz.app.Saloandetails.getCbAmt(applicantCBDetails?.overdueAmt),
        applicantWAmount: apz.app.Saloandetails.getCbAmt(applicantCBDetails?.writeOffAmt),
        applicantCBScore: applicantCBDetails?.cbScore,
        coAppOverDue: apz.app.Saloandetails.getCbAmt(coApplicantCBDetails?.overdueAmt),
        coAppWAmount: apz.app.Saloandetails.getCbAmt(coApplicantCBDetails?.writeOffAmt),
        coAppCBScore: coApplicantCBDetails?.cbScore,
        netIncome: ApzCOB.formatamountVal(TotalIncome),
        indebtedness: `₹ ${ApzCOB.formatamountVal(indebtNessVal)}`,
        foir: `${coApplicantCBDetails?.foirPercentage}%`
    }
     Object.entries(fields).forEach(([key, value]) => {
        $(`#${screenMainId}${key}`).text(value);
    });
}
apz.app.Saloandetails.getCbAmt = function(amtValue){
  let finalAmt = '';
   if(amtValue === undefined || apz.isNull(amtValue)) return finalAmt;
if (amtValue?.includes('|') && amtValue.includes(':')) {
    try {
        finalAmt = amtValue.split('|')[0].split(':')[1].trim();
    } catch (e) {
        finalAmt = '';
    }
}  
return finalAmt;
}
apz.app.Saloandetails.tabsClick = function(pthis,ptype) {
    $('.tabDiv').addClass('sno');
    $('.sanctionTabs').removeClass('active');
    $(pthis).addClass("active");
    $(`.tabDiv.${ptype}`).removeClass('sno');
}
apz.app.Saloandetails.paintDeviationReAssesment = function (divType) {
    if (apz.isObjectEmpty(DEVIATION_DATA) || !DEVIATION_DATA[divType]) return;
    const config = {
        deviation: {
            selectElementID: `${screenMainId}deviationItem_0`,
            parentDiv: `#${screenMainId}deviation_cloneRow`,
            metricRow: `#${screenMainId}deviationMetricRow`
        },
        reAssesment: {
            selectElementID: `${screenMainId}reassesmentItem_0`,
            parentDiv: `#${screenMainId}reassesment_cloneRow`,
            metricRow: `#${screenMainId}ReassessmentRow`
        }
    };
    let { selectElementID, parentDiv, metricRow } = config[divType];
    parentDiv = $(parentDiv);
    parentDiv.html('');
    let loggedInRole = LoggedInUserDetails?.loginResponse?.addInfo1;
    let isPendingReAssesExist = 0;
    let reAssesmentCompleted = 0;
    let reAssemRemark = '';
    if(DEVIATION_DATA[divType].length > 0){
    DEVIATION_DATA[divType].forEach((dev, index) => {
                  let newId = ApzCOB.cloneDashboardDivs(selectElementID, parentDiv, index + 1);
        if (divType === "deviation") {
            $(`#${newId} .devaitionDesc p.ett-para.pri`).text(dev.recordMsg);
            $(`#${newId} .deviationApproveDateTime p.ett-para.pri`).text(dev?.approvedTimeStamp);
            $(`#${newId} .deviationValidated p.ett-para.pri`).text(dev?.remarks);
            $(`#${newId} .pendingDeviationText button span`).text(`Pending with ${dev.authority}`);
            if (dev.approvedStatus === "PENDING"){
                if(dev.authority === loggedInRole) {
                    $(`#${newId} .deviationResponseTxt, #${newId} .approve`).removeClass('sno');   
                } else {
                    $(`#${newId} .pendingDeviationText`).removeClass('sno');
                }
                $(`#${newId} .autapproved`).addClass('sno');
            } else if (dev.approvedStatus === "APPROVED") {
                let approvedText = dev.authority === "SYSTEM" ? "Auto Approved" : `Approved By ${dev.authority}`;
                $(`#${newId} .deviationValidated, #${newId} .approved, #${newId} .autapproved`).removeClass('sno');
                $(`#${newId} .DeviationApproveText p.ett-para.pri`).text(approvedText);
            }
        } else if (divType === "reAssesment") {
            $(`#${newId} .reAssesmentDesc p.ett-para.pri`).text(dev.recordMsg);
             $(`#${newId} .otherPending button span`).text(`Pending with ${dev.authority}`);
            if (dev.approvedStatus === "PENDING"){
                if(dev.authority === loggedInRole) {
                    isPendingReAssesExist++;
                    $(`#${newId} .approve`).removeClass('sno');
                    $(`#${newId} .ownPending`).removeClass('sno');
                } else {
                    $(`#${newId} .otherPending`).removeClass('sno');
                }
            } else if (dev.approvedStatus === "APPROVED") {
                let approvedText = dev.authority === "SYSTEM" ? "Auto completed" : `Completed By ${dev.authority}`;
                $(`#${newId} .deviationValidated, #${newId} .approved, #${newId} .autapproved`).removeClass('sno');
                $(`#${newId} .ReAssesmentApproveText p.ett-para.pri`).text(approvedText);
                $(`#${newId} .ReAssesmentApproveDateTime p.ett-para.pri`).text(dev?.approvedTimeStamp);
                if(!apz.isNull(dev.remarks)){
                   $(`#${newId} .re-assesment-remark label`).html(`<span>Response : ${dev.remarks}</span>`);  
                }
                if(dev.authority === loggedInRole) {
                reAssesmentCompleted++;
                reAssemRemark = dev?.remarks;
                }
                $('.uploadimg .dltIcon').addClass('sno');
            }
            window.pendingReAssesmentCount = isPendingReAssesExist;
            apz.app.Saloandetails.prepareReAssesDocs();
        }
        $(metricRow).removeClass('sno');
        $(`#${newId}`).attr('data-id',dev.recordId)
        $(`#${newId}`).removeClass('sno');  
    });
     }  else {
             $(metricRow).addClass('sno');
        }
    if(applicationStatus === "PENDINGREASSESSMENT" && isPendingReAssesExist > 0){
      $('.reAssesmentModules .approve').removeClass('sno'); 
      reAssesmentResponseRiv.removeClass('sno');  
      $('.reAssementRemark').removeClass('sno');
    } else {
        $('.reAssesmentModules .approve').addClass('sno');
        reAssesmentResponseRiv.addClass('sno'); 
        $('.uploadimg .dltIcon').addClass('sno'); 
        $('.reAssesmentModules.reAssementRemark').addClass('sno'); 
    }
    if(reAssesmentCompleted > 0){
        $(`#${screenMainId}reAssesmentResp`).val(reAssemRemark); 
        ApzCOB.addDisableToInput(`${screenMainId}reAssesmentResp`);
        $('.reAssesmentModules.imgupload').addClass('sno');
        reAssesmentResponseRiv.removeClass('sno');
    } else {
        ApzCOB.removeDisableToInput(`${screenMainId}reAssesmentResp`); 
    }
};
apz.app.Saloandetails.paintSendBack = function(){
    let selectElementID = `${screenMainId}sendBacktItem_0`;
    let parentDiv = $(`#${screenMainId}sendBackReason_cloneRow`);
          let currentIndex = 1; 
          let newId = ApzCOB.cloneDashboardDivs(selectElementID, parentDiv, currentIndex);
           $(`#${newId}`).removeClass('sno');
}
apz.app.Saloandetails.prepareDeviationData = function(){
    let deviationArray = [];
    let reAssesmentArray = [];
    if(apz.isObjectEmpty(inSessionStore) || !inSessionStore.hasOwnProperty('deviationRATrackerList')) return;
    if(inSessionStore.deviationRATrackerList.length > 0){
       deviationArray = inSessionStore.deviationRATrackerList.filter(dev => dev.recordType === "CA_DEVIATION");
       reAssesmentArray = inSessionStore.deviationRATrackerList.filter(dev => dev.recordType === "REASSESSMENT");
    }
    DEVIATION_DATA.deviation = structuredClone(deviationArray);
    DEVIATION_DATA.reAssesment = structuredClone(reAssesmentArray);
}
apz.app.Saloandetails.approveDeviation = function(pthis){
    currentDeviationID = $(pthis).parents('.deviationItem').attr('id');
    $(`#${currentDeviationID} .deviationErrorText`).remove();
  let remarksElem = $(`#${currentDeviationID}`).find('.deviationResponseTxt input');
  let remarks = remarksElem.val();
  if(!apz.isNull(remarks)){
            let popUpObj = {};
            popUpObj.text = "Do you want to approve the deviation?";
            popUpObj.Btn1 = {
                "text": "Yes",
                "onClick": `apz.app.Saloandetails.approveDeviationService("CA_DEVIATION")`
            }
            popUpObj.Btn2 = {
                "text": "No",
                "onClick": "apz.app.DeviationSanctBase.closeCnfmMdl()"
            }
            ApzCOB.showRpcModals(popUpObj, "confirmation"); 
  } else {
      remarksElem.addClass('err-border');
      remarksElem.parent().append('<span style="font-size:12px;color:red;text-align:left;" class="deviationErrorText">Enter Remarks</span>');
  }
}
apz.app.Saloandetails.approveDeviationService = function(approveType){
     let deviationRecordID = '';
    if(approveType === "CA_DEVIATION"){
    deviationRecordID = $(`#${currentDeviationID}`).attr('data-id');
    let deviationData = inSessionStore.deviationRATrackerList.find(deviation => deviation.recordId === deviationRecordID);
    if(apz.isObjectEmpty(deviationData)) return;
    }
    let callBackFn = '';
   let req = {
    "apiRequest": {
        "interfaceName":"ApproveDeviationRaApplications",
        "userId":LoggedInUserDetails.loginResponse.userDet.id,
        "requestObj":{
            "applicationId":gApzCOB.userDetails.applicationId,
            "recordId":"",
            "recordType":approveType,
            "remarks": "",
            "role": LoggedInUserDetails?.loginResponse?.addInfo1
            // "role": "BCM"
        }
    }
    }
    if(approveType === "CA_DEVIATION"){
        req.apiRequest.requestObj.recordId = deviationRecordID;
        req.apiRequest.requestObj.remarks = $(`#${currentDeviationID}`).find('.deviationResponseTxt input').val();
        callBackFn = apz.app.Saloandetails.changeDeviationRemarksCB;
    } else if(approveType === "REASSESSMENT") {
        req.apiRequest.requestObj.remarks = $(`#${screenMainId}reAssesmentResp`).val(); 
        callBackFn = apz.app.Saloandetails.reAssementSubmitCB;
    }
    apz.startLoader();
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, "ApproveDeviationRaApplications", "N", "N", req, false, callBackFn);
    }, 1000)
}
apz.app.Saloandetails.changeDeviationRemarksCB = function(params) {
    apz.stopLoader();
    if (ApzCOB.handleServiceCallBacks(params)) {
        let responseVal = JSON.parse(params.res.APZCBO__ApproveDeviationRaApplications_Res.apiResponse.ResponseBody.responseObj);
        if(responseVal.length > 0){
            inSessionStore.deviationRATrackerList = [];
            inSessionStore.deviationRATrackerList = structuredClone(responseVal);
            apz.app.Saloandetails.prepareDeviationData();
            apz.app.Saloandetails.paintDeviationReAssesment('deviation');
            apz.app.DeviationSanctBase.closeCnfmMdl();
        }
    } else {
        ApzCOB.showRpcModals({
            text: errMsg,
            Btn1: {
                text: "OK",
                onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
            }
        }, "Error");
    }
}
apz.app.Saloandetails.reAssementSubmitCB = function(params) {
    apz.stopLoader();
    if (ApzCOB.handleServiceCallBacks(params)) {
        let responseVal = JSON.parse(params.res.APZCBO__ApproveDeviationRaApplications_Res.apiResponse.ResponseBody.responseObj);
        if(responseVal.length > 0){
            inSessionStore.deviationRATrackerList = [];
            inSessionStore.deviationRATrackerList = structuredClone(responseVal);
            apz.app.Saloandetails.prepareDeviationData();
            apz.app.Saloandetails.paintDeviationReAssesment('reAssesment');
            apz.app.DeviationSanctBase.closeCnfmMdl();
        }
    } else {
        ApzCOB.showRpcModals({
            text: errMsg,
            Btn1: {
                text: "OK",
                onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
            }
        }, "Error");
    }
}
apz.app.Saloandetails.changeDeviationRemarks = function(pthis){
   $('.deviationErrorText').remove(); 
}
apz.app.Saloandetails.uploadLink = function(){
    let curUserReAssesment = [];
    curUserReAssesment = RE_ASSESMENT_DOCS.filter(reAsDoc => reAsDoc.payload.uploadedBy === gApzCOB.LoggedInUserDetails.loginResponse.addInfo1)
    if (curUserReAssesment.length < RE_ASSES_DOC_COUNT.MAX) {
        if (apz.deviceType === 'ANDROID') {
            var cameraObj = {
                "zoomLevel": "20",
                "targetWidth": "950",
                "targetHeight": "950",
                "crop": "Y",
                "cropBox": "square",
                "flash": "N",
                "action": "base64_Save",
                "fileName": 'b',
                "quality": "75",
                "encodingType": "JPG",
                "sourceType": "camera"
            };
            cameraObj.id = "CAMERA_ID";
            cameraObj.callBack = apz.app.Saloandetails.cameraCallback;
            apz.ns.openCamera(cameraObj);
        } else {
            $(`#${screenMainId}reAssesmentUpload`).click();
        }
    } else {
        ApzCOB.showRpcModals({
            text: `Re-Assesment document max count should be below ${RE_ASSES_DOC_COUNT.MAX}`,
            Btn1: {
                text: "OK",
                onClick: "apz.app.DeviationSanctBase.closeErrMdl()"
            }
        }, "Error");
    }
}
apz.app.Saloandetails.cameraCallback = function(params) {
    window.cameracallbackres = params;
    let fileName = params.path.split('/').pop();
    let groupCode = inSessionStore.applicationMaster.productGroupCode;
    let type = "ReAssesmentDoc";
    let docName = "ReAssesment Document";
    window.localFileObj = {};
    localFileObj.filePath = `${apz.appId}/${groupCode}/${inSessionStore.applicationMaster.applicationId}`;
    localFileObj.filename = fileName;
    localFileObj.base64Value = params.encodedImage;
    localFileObj.productGroupCode = inSessionStore.applicationMaster.productGroupCode;
    localFileObj.documentName = docName;
    localFileObj.docSize = ApzCOB.getBase64FileSizeInBytes(params.encodedImage);
    ApzCOB.exceptionFileUpload(localFileObj, type);
    // apz.app.CaIncomeDetails.saveDocument(fileName, params.encodedImage);
}
apz.app.Saloandetails.reAssesmentDocView = function(pthis){
    let documentId = $(pthis).parents('.uploadimg').attr('data-id');
    let docDetails = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.find(doc => parseInt(doc.appDocId) === parseInt(documentId));
    if(!apz.isObjectEmpty(docDetails)){
        let fileName = docDetails?.payload?.documentFileName;
        let callBackFn = apz.app.Saloandetails.reAssesmentDocViewCB;
        window.ImageLocationDetails = {
            latitude: docDetails?.payload.latitude || "",
            longitude: docDetails?.payload.longitude || "",
            uploadedTs: docDetails?.payload.uploadedTs || "",
            documentFileName: docDetails?.payload.documentFileName || ""
        };
        ApzCOB.downloadFileFromServer(fileName,callBackFn);
    }
}
apz.app.Saloandetails.reAssesmentDocViewCB = function(params){
