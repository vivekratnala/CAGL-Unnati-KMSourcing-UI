apz.app.DBbase.searchInQueryMdl = function() {
    let query = $(`#${DbbaseScrId}searchQueryInput`).val();
    window.searchresults = shownQueries.filter((lead) => Object.values(lead).some((value) => String(value).toLowerCase().includes(query
        .toLowerCase())));
    if (searchresults?.length > 0) {
        apz.app.DBbase.paintQueries(searchresults);
        $(`#${DbbaseScrId}noResult_row`).addClass("sno");
        $(`#${DbbaseScrId}queryList`).removeClass("sno");
    } else {
        $(`#${DbbaseScrId}noResult_row`).removeClass("sno");
        $(`#${DbbaseScrId}queryList`).addClass("sno");
        $(`#${DbbaseScrId}otherQueryReasonForm`).addClass("sno");
    }
};
apz.app.DBbase.saveQuery = function(pvalue){
    window.selectedQueries = [];
    $(`#${DbbaseScrId}SUBMIT_querySave`).parent().find('.err').remove();
    const headerTxt = $('#DBkitG__DBbase__queryModal_window .modal-header h1').text();
    if ($("#OTH").is(":checked")) {
        let otherQuery = $(`#${DbbaseScrId}otherQueryReasonInp`).val();
        if (apz.isNull(otherQuery)) {
            ApzCOB.addErrMessage(`${DbbaseScrId}otherQueryReasonInp`, "element");
            return;
        } else {
            let lobj = {
                queryID: 'OTH',
                value: otherQuery
            };
            selectedQueries.push(lobj);
        }
    }
    shownQueries.forEach((query, queryIndex) => {
        let checkboxSelector = `#${query.id}`;
        if ($(checkboxSelector).is(":checked") && query.id !== 'OTH') {
            let lobj = {
                queryID: query.id,
                value: query.value
            };
            selectedQueries.push(lobj);
        }
    });
    if (selectedQueries.length > 0) {
        if (clickedAction === 'REJECT' && apz.isNull(pvalue)) {
            let confrmTxt = `Do you want to reject the application?`;
            let popUpObj = {};
            popUpObj.text = confrmTxt;
            popUpObj.Btn1 = {
                "text": "Yes",
                "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`);apz.app.DBbase.saveQuery('reject');"
            }
            popUpObj.Btn2 = {
                "text": "No",
                "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`)"
            }
            apz.app.DBbase.onClickQueryMdlCancel();
            ApzCOB.showNewCommonConfirmationModal(popUpObj);
            return;
        }
        let queryList = [];
        queryList = selectedQueries.map(item => {
            return `${item.queryID}_${item.value}`;
        });
        let finalQueryData = queryList.join(',');
        if (apz.childScr === 'Disbursement') {
            statusObject.lAction = "REJECT";
            statusObject.remarks = finalQueryData;
            statusObject.nextStatus = "REJECTED";
            apz.app.DBbase.DisbursementStageMovementCall();
        } else {
            queryList = selectedQueries.map(item => {
                return item.queryID === "OTH" ? `${DB_CURRENT_STAGE_NO}_A_${item.queryID}?${item.value}` : `${DB_CURRENT_STAGE_NO}_A_${item.queryID}`;
            });
            finalQueryData = queryList.join(',');
            let confrmTxt = ``;
            if(apz.childScr === 'DBLoanDetails' && headerTxt === 'Sendback') {
                let finalQueryData = queryList.join(',');
                let preferredOrder = shownQueries.filter(q => q.id !== "OTH").map(q => q.id).reverse();
                let selectedStage = [];
                let sendBackStageName = '';
                if (queryList?.some(item => item.includes('Q1'))) {
                    statusObject.lAction = "DBSANCTIONPUSHBACK";
                    selectedStage.push("Sanction");
                }
                let hasMatch = queryList?.some(q => CASendBackList.some(chk => q.includes(chk)));
                if (hasMatch) {
                    statusObject.lAction = "DBCAPUSHBACK";
                    selectedStage.push("Credit Assessment");
                }
                if (selectedStage.length > 1) {
                    selectedStage = selectedStage?.join(' and ');
                    sendBackStageName = 'Credit Assessment';
                } else if (selectedStage.length === 1) {
                    selectedStage = selectedStage?.[0];
                    sendBackStageName = (selectedStage == 'Sanction') ? 'Sanction' : 'Credit Assessment';
                }
                confrmTxt = `You have selected send back reasons pertaining to ${selectedStage}. Hence the application would be sent back to ${sendBackStageName} stage.`;
                apz.app.DBbase.onClickQueryMdlCancel();
                let popUpObj = {};
                popUpObj.text = confrmTxt;
                popUpObj.Btn = {
                    text: "Okay",
                    onClick: `ApzCOB.closeCommonModal('newCommonErrModal');apz.app.DBbase.Stagemoment('', '${statusObject.lAction}', '${finalQueryData}')`
                }
                ApzCOB.showNewCommonErrorModal(popUpObj);
            } else {
                statusObject.lAction = 'REJECTED';
                apz.app.DBbase.Stagemoment('', statusObject.lAction, finalQueryData);
            }
        }
    } else {
        window.selectedQueries = [];
        let errtext = "<span class='err' style='color: red; font-size: 14px;'>Please select atleast one query!</span>";
        $(`#${DbbaseScrId}SUBMIT_querySave`).parent().prepend(errtext);
    }
};
apz.app.DBbase.DisbursementStageMovementCall = function(){
            if (!apz.isNull(gApzCOB.applnWorkFlowRes)) {
        gApzCOB.applnWorkFlowRes.filter(function(workFlow) {
            workFlow.action.split(',').filter(function(s) {
                if (workFlow.appId === gAppId && statusObject.lAction.split(" ").join("") === s.toLocaleUpperCase()) {
                    gApzCOB.workflow.currentRole = workFlow.currentRole;
                    gApzCOB.workflow.action = workFlow.action;
                    gApzCOB.workflow.workflowId = workFlow.workFlowId;
                    gApzCOB.workflow.stage = workFlow.fromStageId;
                }
            });
        });
    }; 
            let req = {
            apiRequest: {
                // "interfaceName": approveRejectAction === 'APPROVED' ? "CreateApplication" : "",
                interfaceName: "",
                appId: gAppId,
                requestObj: {
                    appId: gApzCOB.userDetails.appId,
                    status: statusObject.nextStatus,
                    userId: `${gApzCOB.LoggedInUserDetails.loginResponse.addInfo1}(${gApzCOB.LoggedInUserDetails.loginResponse.userDet.id})`,
                    applicationId: gApzCOB.userDetails.applicationId,
                    versionNum: 1,
                    custDtlId: gApzCOB.userDetails.custDtlId,
                    remarks: statusObject.remarks,
                    workflow: {
                        currentRole: gApzCOB.workflow.currentRole,
                        action: gApzCOB.workflow.action,
                        workflowId: gApzCOB.workflow.workflowId,
                        stage: gApzCOB.workflow.stage,
                        currentStage: gApzCOB.workflow.stage
                    }
                }
            }
        };
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "Stagemoment", "N", "N", req, false, apz.app.DBbase.DisbStageMovementCallBack);    
};
apz.app.DBbase.DisbStageMovementCallBack = function(params){
    apz.stopLoader();
    let errMsg = "";
    const apiResponse = params.res?.APZCBO__Stagemoment_Res?.apiResponse;
    const responseMessage = apiResponse?.ResponseHeader?.ResponseMessage;
    if (!apz.isNull(responseMessage)) {
        errMsg = responseMessage;
    }
    try {
        const { lAction, nextStatus } = statusObject;
        const showSuccessModal = (message, closeEvt) => {
            const modalOptions = {
                text: message,
                Btn: {
                    text: "OK",
                    onClick: closeEvt
                }
            };
            ApzCOB.showNewCommonSuccessModal(modalOptions);
        };
        if (ApzCOB.handleServiceCallBacks(params)) {
            if (lAction === 'REJECT') {
                ApzCOB.toggleModal(`${DbbaseScrId}queryModal`);
                showSuccessModal("Application Rejected Successfully.!", "apz.app.DBbase.launchDashBoard()");
            } else if (nextStatus === "DISBURSED") {
                ApzCOB.toggleModal(`${BaseScrId}newCommonConfModal`);
                if (lAction === 'SUBMIT') {
                    window.IS_DISBURSEMENT_STAGE_MOVEMENT = true;
                    // showSuccessModal("Loan Disbursed Successfully", "apz.app.DBbase.launchWelcomeKit()");
                    showSuccessModal("Loan Disbursed Successfully", "ApzCOB.closeCommonModal(`newCommonSuccModal`);apz.app.Login.OnClickMakerChecker();");
                } else {
                    showSuccessModal("The application is moved to service call stage.", "apz.app.DBbase.launchDashBoard()");
                }
            } else if (nextStatus === "LUC") {
                ApzCOB.toggleModal(`${BaseScrId}newCommonConfModal`);
                showSuccessModal("The application is moved to LUC stage.", "apz.app.DBbase.launchDashBoard()");
            }
        } else {
            // Error handling
            if (lAction === 'REJECT') {
                errMsg = "Application Rejection Failed.!";
            } else if (nextStatus === "DISBURSED") {
                if(lAction === 'SUBMIT' && apz.childScr !== 'WelcomeKit'){
                  let error = JSON.parse(apiResponse.ResponseBody.responseObj); 
                  errMsg = `Disbursement Failed.Please try again.! <br/> API : ${error.apiName} <br/> Error : ${error.errorMessage}`
                } else {
                   errMsg = 'Service call stage movement feature not available.!' 
                }
            } else if (nextStatus === "LUC") {
                errMsg = "LUC stage moment Failed.Please try again.!";
            }
            const popUpObj = {
                text: errMsg || technicalErrMsg,
                Btn: {
                    text: "OK",
                    onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
                }
            };
            ApzCOB.toggleModal(`${BaseScrId}newCommonConfModal`);
            ApzCOB.showNewCommonErrorModal(popUpObj);
        }
        statusObject = {}; // Clear status
    } catch (e) {
        apz.stopLoader();
        const popUpObj = {
            text: errMsg || technicalErrMsg,
            Btn: {
                text: "OK",
                onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
            }
        };
        ApzCOB.toggleModal(`${BaseScrId}newCommonConfModal`);
        ApzCOB.showNewCommonErrorModal(popUpObj);
    }
};
apz.app.DBbase.submitDisbursement = function(){
    let disbursementComment = $(`#DBkitG__Disbursement__disbursmentComment`).val();
    if (!apz.isNull(disbursementComment)) {
        let confrmTxt = `Do you want to disburse the loan?`;
        let popUpObj = {};
        popUpObj.text = confrmTxt;
        popUpObj.Btn1 = {
            "text": "Yes",
            "onClick": `apz.app.DBbase.submitDisbursementCnfm('${disbursementComment}')`
        }
        popUpObj.Btn2 = {
            "text": "No",
            "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`)"
        }
        ApzCOB.showNewCommonConfirmationModal(popUpObj);
    } else{
        let popUpObj = {
            text: "Please enter disbursement comment",
            Btn: {
                text: "OK",
                onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
            }
        }
        ApzCOB.showNewCommonErrorModal(popUpObj);
    }
};
apz.app.DBbase.submitDisbursementCnfm = function(disbCmnt) {
    statusObject.lAction = "SUBMIT";
    statusObject.remarks = disbCmnt;
    statusObject.nextStatus = "DISBURSED";
    apz.app.DBbase.DisbursementStageMovementCall();
};
