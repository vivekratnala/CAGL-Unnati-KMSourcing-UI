var DbbaseScrId = 'DBkitG__DBbase__',
 dbErrorModalID = 'DBkitG__DBbase__dberrorModal',
 dbConfModalID = 'DBkitG__DBbase__dbconfirmationModal',
 dbSuccessModalID = 'DBkitG__DBbase__dbsuccessModal',
 QLelementID = `${DbbaseScrId}queryList_row_0`,
 QLParentDiv = $(`#${DbbaseScrId}queryList ul`),
 disbursementHeaderId = $(`#${DbbaseScrId}DisbursementHeader_hyp`),
 statusObject = {},
 clickedAction = '',
 raisedQueries = [],
 finalSBQueries = [],
 sbQueryResponse = '',
 CASendBackList = ["Q2", "Q3", "OTH"];
window.DB_CURRENT_STAGE_NO = '';
window.DB_CURRENT_STAGE = '';
window.ALL_eNACH_BANKS = '';
window.currApplicantBankAcc = '';
window.shownQueries = [];
window.selectedQueries = [];
window.returnSBQueries = [];
window.IS_WELCOMEKIT_VIEW = false;
window.IS_DISBURSEMENT_STAGE_MOVEMENT = false;
window.applicationStatus = dashBoardtitle === 'DISBURSEMENT PENDING' ? "DISBURSEMENT" :  inSessionStore?.applicationMaster?.applicationStatus;
window.DBKIT_STAGES = {
    DBLoanDetails: { id: 1, name: "Loan details" },
    eNach: { id: 2, name: "e-NACH registration" },
    UdyamReg: { id: 3, name: "Udyam registration" },
    DocExecutionUnnati: { id: 4, name: "Document Execution (Digital)" },
    DocExecutionManual: { id: 5, name: "Document Execution (Manual)" },
    DocExecutionPrayaas: { id: 6, name: "Document Execution (Prayaas)" },
    AdditionalDocuDigital: { id: 7, name: "Additional documentation (Digital)" },
    AdditionalDocuManual: { id: 8, name: "Additional documentation (Manual)" },
    RPCVerificationStatus: { id: 9, name: "RPC verification status" },
    Disbursement: { id: 10, name: "Disbursement" },
    WelcomeKit: { id: 11, name: "Welcome kit" },
    DisbursementStatus: { id: 12, name: "Disbursement status" }
};
apz.app.onLoad_DBbase = function() {
    //ApzCOB.fetchSubProduct();//Call while showing DB Dashboard.
    window.AppCustomerId = ApzCOB.getCustDetailID("Applicant");
    window.CoAppCustomerId = ApzCOB.getCustDetailID("Co-App");
    apz.app.DBbase.updateHeaderDetails();
    window.picture = $('#DBkitG__DBbase__imgView');
    ApzCOB.intializeGuillotine(picture);
};
apz.app.onShown_DBbase = function() {
    $('body').addClass(' unati crdas dbkit ');
    var dialog =
        `<div id="pdfDialog" class="sno"></div>`;
    $("div[id=pdfDialog]").remove();
    $(document.body).append(dialog);
    $('#APZCBO__BaseScreens__baseScroll').removeClass('custom-form-launch var2');
    $('#APZCBO__BaseScreens__landingRowHeader').addClass('sno');
    if(["DBKITVERIFIED", "DISBURSED"].includes(applicationStatus)) {
        disbursementHeaderId.addClass('active');
        $(`#${DbbaseScrId}disbDocumentationRow .current`).removeClass('current');
        $(`#${DbbaseScrId}DBLoanDetails_hyp_txtcnt`).text("Sanction Details");
    }
    const ids = ['eNachRow','UdyamRegRow','DocExecutionUnnatiRow','DocExecutionManualRow'];
    const menuSelector = ids.map(id => `#${DbbaseScrId}${id}`).join(',');
    $(`#${DbbaseScrId}disbursmentMenu`).removeClass('sno');
    $(menuSelector).addClass('sno');
    if (applicationStatus === 'DBKITVERIFIED') {
        $(`#${DbbaseScrId}Disbursement_hyp`).addClass('current');
        $(`#${DbbaseScrId}backBtn,#${DbbaseScrId}disburseBtn`).removeClass('sno');
         $(`#${DbbaseScrId}camHypRow,.extDocument`).removeClass('sno');
        ApzCOB.launchSubScreen("Disbursement", `${DbbaseScrId}DbkitLaunchDiv`);
    } else if (applicationStatus === 'DISBURSED') {
        apz.app.DBbase.addCompleteStatus(`${DbbaseScrId}Disbursement_hyp`);
        $(`#${DbbaseScrId}sendbackBtn,#${DbbaseScrId}nextBtn`).addClass('sno');
        $(`#${DbbaseScrId}submitBtn`).removeClass('sno');
        $(`#${DbbaseScrId}camHypRow,.extDocument`).removeClass('sno');
        $(`#${DbbaseScrId}WelcomeKit_hyp`).addClass('current');
        ApzCOB.launchSubScreen("WelcomeKit", `${DbbaseScrId}DbkitLaunchDiv`);
    } else if(applicationStatus === 'SANCTIONED' || applicationStatus === 'DBPUSHBACK'){
        $(`#${DbbaseScrId}disbursmentMenu`).addClass('sno');
        $(menuSelector).removeClass('sno');
        $(`#${DbbaseScrId}sendbackBtn,#${DbbaseScrId}nextBtn,#${DbbaseScrId}backBtn`).removeClass('sno');
        $(`#${DbbaseScrId}camHypRow,#${DbbaseScrId}loanAppHypRow,#${DbbaseScrId}sanctionHypRow,#${DbbaseScrId}kfsHypRow`).removeClass('sno');
        $(`#${DbbaseScrId}disburseBtn`).addClass('sno');
        $(`#${DbbaseScrId}DBLoanDetails_hyp`).click();
        $(`#${DbbaseScrId}sidebarlist_row a`).each(function() {
            ApzCOB.addDisableToInput(this.id)
        }); // disabling sidebar navigation
        ApzCOB.dbKitSideMenuStatusCheck();
        if (inSessionStore.applicationMaster.productCode === '1009') {
            window.ApplicationType = 'NEW';
            window.leadNode = 'leadDetails';
        } else if (inSessionStore.applicationMaster.productCode === '1002') {
            window.ApplicationType = 'RENEWAL';
            window.leadNode = 'renewalLeadDetails';
        }
        ApzCOB.FetchDBKITMasterData("ALL");
        ApzCOB.fetcheNachBankData();
        if (!apz.isNull(inSessionStore.documentList) && inSessionStore?.documentList?.length > 0) {
            $(`#${DbbaseScrId}DocExecutionManualRow`).removeClass('sno');
        }
    }
    if (applicationStatus === 'DBPUSHBACK') {
        $(`#${DbbaseScrId}DocExecutionUnnatiRow`).addClass('sno');
    }
    apz.app.DBbase.paintHeaderData();
};
apz.app.DBbase.updateHeaderDetails = function() {
    let loginResponse = LoggedInUserDetails.loginResponse;
    let loginName = loginResponse?.userDet?.name;
    let loginUserId = loginResponse?.userDet?.id;
    $(`#${DbbaseScrId}caloggedInUserName_txtcnt`).text(`${loginName} (${loginUserId})`);
    $(`#${DbbaseScrId}caloggedInRole_txtcnt`).text(`Role:${loginResponse?.addInfo1}`);
}
apz.app.DBbase.NavigateSidebar = function(dbsideID, pthis) {
    raisedQueries = [];
    finalSBQueries = [];
    returnSBQueries = [];
    apz.app.DBbase.nextBtnEnableDisable('enable');
    $('#DBkitG__DBbase__sidebarForm a').removeClass('active');
    $('.extDocument').addClass('sno');
    const disbDocHeaderMenuId = `${DbbaseScrId}disbDocumentation_hyp`;
    if(pthis.id !== `${DbbaseScrId}DBLoanDetails_hyp`) {
        if (apz.isNull(inSessionStore.dbKitVerifiedStage) || inSessionStore.dbKitVerifiedStage?.length === 0) {
            ApzCOB.showNewCommonErrorModal("Please verify Loan Details.");
            return;
        } else {
            if (inSessionStore.dbKitVerifiedStage.length > 0) {
                let verifiedstageNumbers = inSessionStore.dbKitVerifiedStage.map(entry => parseInt(entry.split('_')[0]));
                for (let i = 1; i < parseInt(dbsideID); i++) {
                    if (!verifiedstageNumbers.includes(i)) {
                        let screenName = DBKIT_STAGES[Object.keys(DBKIT_STAGES).find(key => DBKIT_STAGES[key].id === i)].name;
                        if (applicationStatus === 'DBPUSHBACK' && i === 4 && !apz.isNull(inSessionStore.documentList)) {
                            continue;
                        } else {
                            ApzCOB.showNewCommonErrorModal(`Please verify ${screenName}.`);
                            return;
                        }
                    }
                }
            }
        }
        $(`#${disbDocHeaderMenuId}`).addClass('active');
        $(`#${DbbaseScrId}disbDocumentationRow .current`).removeClass('current');
        if(pthis.id === `${disbDocHeaderMenuId}`) {
            $(`#${DbbaseScrId}eNach_hyp`).addClass('current');
            // add currentClass for unverified stage.
        } else {
            $(pthis).addClass('current');
        }
    } else {
        $(pthis).addClass('active');
        $(`#${DbbaseScrId}disbDocumentationRow .current`).removeClass('current');
    }
    let scrName = Object.keys(window.DBKIT_STAGES).find(key => window.DBKIT_STAGES[key].id === parseInt(dbsideID));
    ApzCOB.launchSubScreen(scrName, `${DbbaseScrId}DbkitLaunchDiv`);
    ApzCOB.dbKitSideMenuStatusCheck();
    apz.app.DBbase.addInprogressStatus(`${DbbaseScrId + scrName}_hyp`);
    window.DB_CURRENT_STAGE_NO = parseInt(dbsideID);
    ApzCOB.removeDisableToInput("DBkitG__DBbase__backBtn");
    if (DB_CURRENT_STAGE_NO === 1) {
        ApzCOB.addDisableToInput("DBkitG__DBbase__backBtn");
    }
    $(`#${DbbaseScrId}CAFooter_nav button`).addClass('sno');
    $(`#${DbbaseScrId}backBtn,#${DbbaseScrId}nextBtn,#${DbbaseScrId}rejectBtn`).removeClass('sno');
};
apz.app.DBbase.paintHeaderData = function() {
    const {
        applicationMaster: { memberId = "", applicationId = "", branchId = "", branchName = "", productCode = "", kendraId = "", kendraName = "" } = {}
    } = inSessionStore;
    const productName = subProductResponse?.filter(el => el.productCode === productCode )?.[0]?.productName;
    const custName = ApzCOB.getPayloadDatafromWrapper('customerName','Applicant','customerDetailsList');
    const setText = (id, value) => $(`#${DbbaseScrId + id}`).text(value);
    const LoanID = ApzCOB.getPayloadDatafromWrapper('t24LoanId','Applicant','loanDetails') || '-';
    setText("custNameID_txtcnt", `${custName} / ${memberId}`);
    setText("applicationId_txtcnt", applicationId);
    setText("branchInfo_txtcnt", `${branchId} / ${branchName}`);
    setText("kendraIDName_txtcnt", `${kendraId} / ${kendraName}`);
    setText("loanProduct_txtcnt", productName);
    setText("loanID_txtcnt", LoanID);
};
apz.app.DBbase.closeDBModal = function(modalId) {
    $(`#${DbbaseScrId + modalId}_close`).click();
};
apz.app.DBbase.downloadFiles = function(pdoctype, pcusttype) {
    window.docSelectedType = pdoctype;
    window.CB_LOAN_ID = '';
    if (pdoctype === 'CB') {
        let custType = (pcusttype === "1") ? 'Applicant' : 'Co-App';
        let custDetailID = ApzCOB.getCustDetailID(custType);
        CB_LOAN_ID = ApzCOB.getPayloadDatafromWrapper('cbLoanId', custType, 'cibilDetailsWrapperList');
        ApzCOB.downloadBRECbReport(custDetailID);
    } else if (pdoctype === 'EXECUTED') {
        let currLanguage = ApzCOB.getPayloadDatafromWrapper('language', 'Applicant', 'loanDetails');
        CB_LOAN_ID = `${pdoctype}_${gApzCOB.userDetails.applicationId}`
        ApzCOB.DBDocGenerateAndDownload('', 'FETCH_MANUAL', 'LOAN_APPLICATION', currLanguage, 'Y', apz.app.DBbase.downloadFilesCB, '');
    } else if (pdoctype === 'REGENERATE') {
        let currLanguage = '';
        if (!apz.isNull(inSessionStore.documentRecordDetails) && inSessionStore.documentRecordDetails.length > 0) {
            currLanguage = inSessionStore?.documentRecordDetails?.[0]?.language;
        }
	if (apz.isNull(currLanguage)){
            currLanguage = ApzCOB.getPayloadDatafromWrapper('language', 'Applicant', 'loanDetails');
        }
        CB_LOAN_ID = `${pdoctype}_${gApzCOB.userDetails.applicationId}`;
        ApzCOB.DBDocGenerateAndDownload('', 'REGENERATE', 'LOAN_APPLICATION', currLanguage, 'Y', apz.app.DBbase.downloadFilesCB, '');
    } else {
        CB_LOAN_ID = `${pdoctype}_${gApzCOB.userDetails.applicationId}`
        req = {
            "apiRequest": {
                "requestObj": {
                    "appId": "APZCBO",
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "reportType": pdoctype,
                    "generateReport": false
                },
                "interfaceName": "GenerateAndDownloadReport"
            }
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "GenerateAndDownloadReport", "N", "N", req, false, apz.app.DBbase.downloadFilesCB);
    }
};
apz.app.DBbase.downloadFilesCB = function(params) {
    let b64Data = "",
        errMsg = "File download failed.!";
    let interface = ApzCOB.GetInterfaceResMap(params);
    const apiResponse = params?.res?.[interface]?.apiResponse;
    if (apz.isObjectEmpty(apiResponse)) return;
    errMsg = apiResponse?.ResponseHeader?.ResponseMessage ?? errMsg;
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            const responseStr = apiResponse?.ResponseBody?.responseObj;
            const response = responseStr ? JSON.parse(responseStr) : {};
            let State = inSessionStore.leadDetails?.glBranchState || inSessionStore.renewalLeadDetails?.glBranchState;
            let match = language.find(item => item.key.toLowerCase().includes(State.toLowerCase()));
            window.leadLanguage = match ? match.value : '';
            function proceedAfterPDFReady() {
                if (['CB'].includes(docSelectedType)) {
                    apz.app.DBbase.viewDocumentCB(response, 'pdf');
                } else if (docSelectedType === 'WelcomeLetter' && IS_WELCOMEKIT_VIEW) {
                    apz.app.WelcomeKit.viewWelcomeKitDoc(response.base64);
                } else {
                    ApzCOB.convertBase64ToPDF(b64Data, CB_LOAN_ID);
                }
            }
            if (response?.base64) {
                if ((leadLanguage === "Malayalam" || leadLanguage === "Odia") && !['CamSheetReport', 'CB', 'EXECUTED'].includes(docSelectedType)) {
                    let convertedBase64 = response.base64;
                    convertedBase64 = convertedBase64.replace(/\n/g, "");
                    convertedBase64 = convertedBase64.replace(/\r/g, "");
                    let decodedHtml = convertedBase64;
                    let dialog = `<div id="pdfDialog" style="position:absolute; left:-9999px; visibility:visible;"></div>`;
                    $("div[id=pdfDialog]").remove();
                    $(document.body).append(dialog);
                    $("#pdfDialog").html(decodedHtml);
                    (async () => {
                        apz.startLoader();
                        const pages = document.querySelectorAll(".jrPage");
                        if (pages.length === 0) {
                            CBBASE64 = b64Data = response.base64;
                            console.log("No '.jrPage' elements found");
                            apz.stopLoader();
                            return;
                        }
                        const opt = {
                            margin: [5, 5, 5, 5],
                            filename: "download.pdf",
                            image: {
                                type: "jpeg",
                                quality: 1.0
                            },
                            html2canvas: {
                                scale: 1.5,
                                useCORS: true,
                                logging: false,
                            },
                            jsPDF: {
                                unit: "mm",
                                format: "a4",
                                orientation: "portrait",
                                compress: true,
                            },
                        };
                        const {
                            jsPDF
                        } = window.jspdf;
                        const pdf = new jsPDF(opt.jsPDF);
                        for (let i = 0; i < pages.length; i++) {
                            if (i !== 0) pdf.addPage();
                            const canvas = await html2canvas(pages[i], opt.html2canvas);
                            const imgData = canvas.toDataURL("image/jpeg", 1.0);
                            const pageWidth = pdf.internal.pageSize.getWidth();
                            const pageHeight = pdf.internal.pageSize.getHeight();
                            pdf.addImage(imgData, "JPEG", 0, 0, pageWidth, pageHeight);
                        }
                        const pdfBase64 = pdf.output("datauristring");
                        CBBASE64 = b64Data = pdfBase64.split(",")[1];
                        proceedAfterPDFReady();
                        apz.stopLoader();
                    })();
                } else {
                    CBBASE64 = b64Data = response.base64;
                    proceedAfterPDFReady();
                }
            } else if (response.mergedBase64) {
                if ((leadLanguage === "Malayalam" || leadLanguage === "Odia") && !['CamSheetReport', 'CB', 'EXECUTED'].includes(docSelectedType)) {
                    apz.startLoader();
                    mergedBase64 = response.mergedBase64;
                    let trimmed = mergedBase64.trim();
                    if (trimmed.startsWith("<!DOCTYPE") || trimmed.startsWith("<html") || trimmed.startsWith("<body")) {
                        mergedBase64 = mergedBase64.replace(/\n/g, "");
                        mergedBase64 = mergedBase64.replace(/\r/g, "");
                        mergedBase64 = mergedBase64.replace(/<hr\b[^>]*>/gi, '');
                        mergedBase64 = mergedBase64.replace(/<hr\s*\/>/gi, '');
                        mergedBase64 = mergedBase64.replace(/\swidth\s*=\s*["']50%["']/gi, '');
                        mergedBase64 = mergedBase64.replace(/(<td[^>]*style=["'][^"']*)width\s*:\s*50%[;]?([^"']*["'][^>]*>)/gi,
                            (_, before, after) => before + after);
                        let customStyle = `<style>
                                                                    .jrPage {
                                                                                page-break-after: always !important;
                                                                                width: 100% !important;
                                                                            }
                                                                    .jrPage tbody tr td > img {
                                                                                width: 100% !important;
                                                                            }
                                                            </style>`;
                        if (mergedBase64.includes("</head>")) {
                            mergedBase64 = mergedBase64.replace("</head>", `${customStyle}</head>`);
                        } else if (mergedBase64.includes("</body>")) {
                            mergedBase64 = mergedBase64.replace("</body>", `${customStyle}</body>`);
                        } else {
                            mergedBase64 = customStyle + mergedBase64;
                        }
                        const blob = new Blob([mergedBase64], {
                            type: "text/html"
                        });
                        const url = URL.createObjectURL(blob);
                        let btn = document.getElementById('openInTabBtn');
                        if (!btn) {
                            btn = document.createElement('button');
                            btn.id = 'openInTabBtn';
                        }
                        btn.onclick = () => window.open(url, '_blank');
                        apz.stopLoader();
                        btn.click();
                    }
                } else {
                    apz.stopLoader();
                    ApzCOB.convertBase64ToPDF(response.mergedBase64, CB_LOAN_ID);
                }
            } else {
                apz.stopLoader();
                ApzCOB.showNewCommonErrorModal("File Not Found.!");
            }
        } else {
            apz.stopLoader();
            ApzCOB.showNewCommonErrorModal(errMsg);
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.showNewCommonErrorModal(errMsg);
    }
};
apz.app.DBbase.scrollToId = function(id) {
    $(`#${id}`)[0].scrollIntoView({ behavior: 'smooth' });
};
apz.app.DBbase.gotoHome = function(modalId) {
    if(!apz.isNull(modalId)) ApzCOB.closeCommonModal(modalId);
    apz.app.Login.OnClickMakerChecker("");
};
apz.app.DBbase.reject = function() {
    clickedAction = 'REJECT';
    $(`#${DbbaseScrId}SUBMIT_querySave`).parent().find('.err').remove();
    let stageType = '';
    if(applicationStatus === 'DBKITVERIFIED'){
        stageType = 'Disbursement';
        ApzCOB.fetchRpcStageFields(stageType, apz.app.DBbase.fetchStageFieldsCB);
    } else {
        let stageMaster = DBKIT_MASTERDATA.filter(el => el.id === DB_CURRENT_STAGE_NO)?.[0]?.rejectReasons;
        let rejectReasons = JSON.parse(stageMaster ?? '')?.rejectReason;
        if(Array.isArray(rejectReasons) && rejectReasons.length > 0) {
            window.shownQueries = [...rejectReasons,{
            id: "OTH",
            value: "Other",
        }];
        }
        apz.app.DBbase.paintQueries(shownQueries);
        ApzCOB.toggleModal(`${DbbaseScrId}queryModal`);
        $(`#${DbbaseScrId}queryList`).addClass("pb-70");
        $(".crt-list li").attr("onClick", "");
        $(`#${DbbaseScrId}otherQueryReasonInp`).val("");
        $('#APZCBO__BaseScreens__queryModal_content').scrollTop(0,0);
        $(`#${DbbaseScrId}otherQueryReasonForm`).addClass("sno");
    }
};
apz.app.DBbase.paintQueries = function(queries) {
    let queryCategoryElem;
    $(`#${DbbaseScrId}queryList .dynamic_elems`).remove();
    if (queries.length === 0) {
        return;
    } else {
        queries.forEach((query, index) => {
            queryCategoryElem = `<span class="srb pri">
                    <span class="scb-col5">
                        <span id ="span_${query.id}" for="${query.id}" class=" etb-chek ett-chek hor pri queryList">
                            <span class="queryItems">
                                     <input id="${query.id}" class="" type="CHECKBOX" enabled="enabled" value="${query.id}" onchange = "apz.app.DBbase.checkQuery(this)">
                                     <label class="flb" for="${query.id}"></label>
                                 </span>
                                  </span>
                                  </span>
                           <span class="scb-col95">
                              <p id="query${query.id}_label" class="ett-para pri fs14 ltr-sp4 var2" >${query.value}</p>
                           </span>
                        </span>`;
            $(`#${QLelementID}`).html(queryCategoryElem);
            let clonedId = ApzCOB.cloneDashboardDivs(QLelementID, QLParentDiv, index + 1);
            $(`#${clonedId}`).addClass("query dynamic_elems");
            $(`#${clonedId}`).removeClass("sno ssp");
            $(`#${QLelementID}`).html("");
            $(`#${QLelementID}`).addClass('sno');
        })
    }
};
apz.app.DBbase.fetchStageFieldsCB = function(params) {
    apz.stopLoader();
    window.shownQueries = [];
    window.shownQueries = JSON.parse(params.res.APZCBO__RPCStageFields_Res[0].queries);
    apz.app.DBbase.paintQueries(shownQueries);
    ApzCOB.toggleModal(`${DbbaseScrId}queryModal`);
    // $(`#${DbbaseScrId}QCCloneRow_0`).html('')
};
apz.app.DBbase.checkQuery = function(pthis){
    window.selectedQueries = [];
    if(pthis.checked){
        if(pthis.value === "OTH"){
            $(`#${DbbaseScrId}queryList`).removeClass("pb-70")
            $(`#${DbbaseScrId}otherQueryReasonForm`).removeClass("sno mt24");
            $(`#${DbbaseScrId}otherQueryReasonForm`).addClass("pb-70");
        }
    } else {
       if(pthis.value === 'OTH'){
            $(`#${DbbaseScrId}otherQueryReasonForm`).addClass("sno"); 
            $(`#${DbbaseScrId}queryList`).addClass("pb-70");
        } 
    }
}
apz.app.DBbase.sendback = function() {
    clickedAction = 'SENDBACK';
    $(`#${DbbaseScrId}SUBMIT_querySave`).parent().find('.err').remove();
    $('#DBkitG__DBbase__queryModal_window .modal-header h1').text('Sendback');
    $(`#${DbbaseScrId}otherQueryReasonInp`).val('');
    $('#APZCBO__BaseScreens__queryModal_content').scrollTop(0, 0);
    $(`#${DbbaseScrId}otherQueryReasonForm`).addClass("sno");
    $(`#${DbbaseScrId}queryList`).addClass("pb-70");
    window.shownQueries = [];
    let stageData = DBKIT_MASTERDATA.find(el => el.id === DB_CURRENT_STAGE_NO);
    if (DB_CURRENT_STAGE_NO === 1) {
        const sendBackMaster = JSON.parse(stageData?.queries ?? '')?.sendbackReason;
        if(Array.isArray(sendBackMaster) && sendBackMaster.length > 0) {
            window.shownQueries = [...sendBackMaster,{
            id: "OTH",
            value: "Other",
        }];
        }
        apz.app.DBbase.paintQueries(shownQueries);
        ApzCOB.toggleModal(`${DbbaseScrId}queryModal`);
    }
};
apz.app.DBbase.back = function() {
    let prevstageId = (DBKIT_STAGES?.[apz.childScr]?.id ?? DB_CURRENT_STAGE_NO) - 1;
    if (applicationStatus === 'DBPUSHBACK' && prevstageId === 4) prevstageId-=1;
    if(prevstageId <= 0) return;
    let hypLinkId = Object.keys(window.DBKIT_STAGES).find(key => window.DBKIT_STAGES[key].id === parseInt(prevstageId));
    if (apz.childScr === "DBLoanDetails") {
        ApzCOB.launchMicroApp('Dashbo', 'DashboardViewAllApplication', 'APZCBO__BaseScreens__BaseDIV', '');
    } else {
        $(`#${DbbaseScrId + hypLinkId}_hyp`).click();
    }
};
apz.app.DBbase.DBQuerySaveCB = function(params) {
    apz.stopLoader();
        try {
            if (ApzCOB.handleServiceCallBacks(params)) {
                ApzCOB.updateInsessionData(params);
                ApzCOB.updateSideMenuStatusTags();
                apz.app.DBbase.next('YES');
            } else {
                ApzCOB.showNewCommonErrorModal("Save query response failed!");
            }
        } catch (e) {
            ApzCOB.showNewCommonErrorModal();
        }
}
apz.app.DBbase.validatePushbackBasedOnStage = function() {
    let sendBackResponse = $(`#${scrId}sendBackResponse`).val() || '';
    if (apz.isNull(sendBackResponse.trim())) {
        apz.app.DBbase.scrollToId(`${scrId}sendBackResponse`);
        ApzCOB.showNewCommonErrorModal('Please enter the response.');
        return;
    }
    if (apz.childScr === 'eNach') {
        let appRespData = ApzCOB.getPayloadDatafromWrapper("resDesc", 'Applicant', 'enachDetails') || '';
        let coappRespData = ApzCOB.getPayloadDatafromWrapper("resDesc", 'Co-App', 'enachDetails') || '';
        let coappBankEdit = ApzCOB.getPayloadDatafromWrapper("rpcEditCheck", 'Co-App', 'bankDetailsWrapperList');
        let validStatuses = ["success", "initiated"];
        let appEnachStatus = validStatuses.includes(appRespData?.toLowerCase());
        let coappEnachStatus = validStatuses.includes(coappRespData?.toLowerCase());
        if (!(appEnachStatus || (coappEnachStatus/* && coappBankEdit*/))) {
            ApzCOB.showNewCommonErrorModal('Please re-initiate eNach!');
            return;
        }
    } else if (apz.childScr === 'UdyamReg') {
        // validate if any changes are made
    }
    window.returnSBQueries = [];
    if (finalSBQueries.length > 0) {
        let respTS = apz.app.DBbase.getCurrentTS() || '';
        returnSBQueries = finalSBQueries.map(el => `${el}$${sendBackResponse}$${respTS}`);
    }
    if (returnSBQueries.length > 0) {
        ApzCOB.RpcDBQuerySave(returnSBQueries, apz.app.DBbase.DBQuerySaveCB)
    }
};
apz.app.DBbase.validateBasedOnStage = function(currentStageId, isSendBack){
    let lnavigate = true;
    let dbValidation = true;
    const nextStageId = currentStageId + 1;
    if (applicationStatus === 'DBPUSHBACK' && raisedQueries.length > 0 && apz.isNull(isSendBack)) {
        apz.app.DBbase.validatePushbackBasedOnStage();
        return;
    }
    if (apz.childScr === 'eNach') {
        lnavigate = apz.app.eNach.validateOnClickNext();
    }
    if (apz.childScr === "UdyamReg") {
        lnavigate = false;
        apz.app.UdyamReg.HandleNext();
    }
    if (nextStageId === 6) {
        lnavigate = false;
        let isValid = true;
        docsLength = $('#DBkitG__DocExecutionManual__docsList .uploaded .mand').length;
        if ((docsLength < DisbursementDocs?.length - 1) && applicationStatus === 'SANCTIONED') {
            ApzCOB.showNewCommonErrorModal("Please Upload mandatory documents.");
            isValid = false;
            return lnavigate;
        } else if (applicationStatus === 'DBPUSHBACK') {
            let otherDocIndex = APPROVED_DOCS.findIndex(el => el.displayName === "Others");
            if (otherDocIndex >= 0) {
                docsLength+=1;
            }
            const hasError = paintQueries.some((el, index) => {
                const responseValue = $(`#DBkitG__DocExecutionManual__responseInput_${index}`).val();
                const isVisibleReUpload = $(`#DBkitG__DocExecutionManual__reUploadDoc_${index}`).is(":visible");
                if (isVisibleReUpload) {
                    ApzCOB.showNewCommonErrorModal(`Please re-upload ${paintQueries[index].displayName} query document!`);
                    return true;
                }
                if (apz.isNull(responseValue)) {
                    ApzCOB.showNewCommonErrorModal(`Please enter the response for ${paintQueries[index].displayName} documents!`);
                    return true;
                }
                return false;
            });
            if (hasError) return;
            if (docsLength < APPROVED_DOCS.length) {
                ApzCOB.showNewCommonErrorModal("Please upload mandatory documents under approved documents!");
                return;
            }
            if ((docsLength < DisbursementDocs?.length - 1) && (paintQueries?.length === 0 && APPROVED_DOCS?.length === 0)) {
                ApzCOB.showNewCommonErrorModal("Please Upload mandatory documents.");
                isValid = false;
                return lnavigate;
            }
        }
        remarks = 'DBSUBMITREMARK';
        let dbKitremarks = $(`#${scrId}dbKitComment`).val();
        if (apz.isNull(dbKitremarks)) {
            ApzCOB.showNewCommonErrorModal("Please enter DBKit comments.");
            isValid = false;
            return lnavigate;
        }
        if (isValid) {
            let confrmTxt = `Are you sure you want to Submit for RPC DB Verification?`;
            onclickEvents = `ApzCOB.closeCommonModal('newCommonConfModal'); apz.app.DBbase.Stagemoment('','SUBMIT', '${remarks}')`;
            if (applicationStatus === 'DBPUSHBACK') {
                onclickEvents = `ApzCOB.closeCommonModal('newCommonConfModal'); ApzCOB.dbStageVerificationService(${currentStageId})`;
            }
            let popUpObj = {};
            popUpObj.text = confrmTxt;
            popUpObj.Btn1 = {
                "text": "Yes",
                "onClick": onclickEvents
            }
            popUpObj.Btn2 = {
                "text": "No",
                "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`)"
            }
            ApzCOB.showNewCommonConfirmationModal(popUpObj);
        }
    }
    return lnavigate;
}
apz.app.DBbase.next = function(isSendBack) {
    const currentStage = DBKIT_STAGES?.[apz.childScr];
    const currentStageId = Number(currentStage?.id);
    let isValid = apz.app.DBbase.validateBasedOnStage(currentStageId, isSendBack);
    //apz.app.DBbase.handlesideBar(); // sidebar icons
    if(isValid) {
        if( $('#DBkitG__eNach__eNachMethodRadio input:checked').val() == 'NotAvailable') {
            apz.app.eNach.saveEnachDetials(window.custType,'NotAvailable');
        }
        ApzCOB.dbStageVerificationService(currentStageId);
    }
};
apz.app.DBbase.save = function() {
    if (DB_CURRENT_STAGE_NO === 2) {
        apz.app.eNach.saveBankWrapperData();
    }
};
apz.app.DBbase.cancel = function() {
    if (DB_CURRENT_STAGE_NO === 2) {
        apz.app.eNach.onClickCancel();
        if ($("#DBkitG__eNach__accountNumber").hasClass("disabled")) {
            $("#DBkitG__eNach__verifyACC").addClass("sno");
        } else {
            $("#DBkitG__eNach__verifyACC").removeClass("sno");
        }
        coAppverified = false;
        if ($(`#${scrId}verifyACC`).is(':visible')) {
            $(`#${scrId}verifyACC`).addClass('sno');
        }
        if ($(`#${scrId}verifiedAcc_txtcnt`).is(':visible')) {
            $(`#${scrId}bankACCVerified`).addClass('sno');
            $("#" + scrId + "verifiedAcc").addClass('sno');
            $("#" + scrId + "verifiedAcc").removeClass('suc');
        }
        if (ApzCOB.getPayloadDatafromWrapper("accntVerified", "Applicant", "bankDetailsWrapperList") == 'Verified') {
            apz.app.eNach.setAppTag();
        }
        if ($(`#${scrId}invalidAcc_txtcnt`).is(':visible')) {
            $(`#${scrId}InvaildBankACC`).addClass('sno');
            $("#" + scrId + "invalidAcc").addClass('sno');
            $("#" + scrId + "invalidAcc").removeClass('failed');
        }
        if (coAppverified) {
            if (setCoappstatus == 'Verified') {
                $("#" + scrId + "bankACCVerified").removeClass("sno");
                $("#" + scrId + "verifiedAcc").removeClass('sno');
                $("#" + scrId + "verifiedAcc").addClass('suc');
                $("#" + scrId + "InvaildBankACC").addClass("sno");
                $("#" + scrId + "invalidAcc").addClass('sno');
                $("#" + scrId + "invalidAcc").removeClass('failed');
            } else {
                $("#" + scrId + "bankACCVerified").addClass('sno');
                $("#" + scrId + "verifiedAcc").addClass('sno');
                $("#" + scrId + "verifiedAcc").removeClass('suc');
                $("#" + scrId + "InvaildBankACC").removeClass("sno");
                $("#" + scrId + "invalidAcc").removeClass('sno');
                $("#" + scrId + "invalidAcc").addClass('failed');
            }
        }
    }
};
apz.app.DBbase.preview = function() {};
apz.app.DBbase.confirm = function() {};
apz.app.DBbase.submit = function() {};
apz.app.DBbase.submitToRPC = function() {
    let isValid = true;
    let ldocs = apz.app.eNach.fetchSelectedDocs();
    if (ldocs.length < 2) {
        ApzCOB.showNewCommonErrorModal("Please Upload atleast 2 documents.");
        isValid = false;
        return;
    }
    //service to send the application to rpc
    if (isValid) {
        let confrmTxt = `The application will be sent to RPC for bank account update. Do you confirm?`;
        let popUpObj = {};
        popUpObj.text = confrmTxt;
        popUpObj.Btn1 = {
            "text": "Yes",
            "onClick": "apz.app.DBbase.Stagemoment(this,'BANKUPDATEPUSHBACK')"
        }
        popUpObj.Btn2 = {
            "text": "No",
            "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`)"
        }
        ApzCOB.showNewCommonConfirmationModal(popUpObj);
    }
};
apz.app.DBbase.Stagemoment = function(pthis, gaction, gremarks) {
    if (gremarks === 'DBSUBMITREMARK') {
        gremarks = $(`#${scrId}dbKitComment`).val();
    }
    let rMarks = gremarks ?? '';
    ApzCOB.userDetailsData();
    ApzCOB.stageBasedOnAction(pthis, gaction);
    window.approveRejectAction = gaction;
    window.approveRejectAction = "";
    switch (gaction) {
        case "SUBMIT":
            window.approveRejectAction = "DBKITGENERATED";
            break;
        case "REJECTED":
            window.approveRejectAction = "REJECTED";
            break;
        case "PUSHBACK":
            window.approveRejectAction = "PUSHBACK";
            break;
        case "DBCAPUSHBACK":
            window.approveRejectAction = "RPCVERIFIED";
            break;
        case "DBSANCTIONPUSHBACK":
            window.approveRejectAction = "RESANCTION";
            break;
        case "BANKUPDATEPUSHBACK":
            window.approveRejectAction = "RPCBANKUPDATE";
            break;
        default:
            break;
    }
    let req = {
        apiRequest: {
            interfaceName: "",
            appId: gAppId,
            requestObj: {
                appId: gApzCOB.userDetails.appId,
                status: approveRejectAction,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                applicationId: gApzCOB.userDetails.applicationId,
                versionNum: gApzCOB.userDetails.versionNum,
                custDtlId: gApzCOB.userDetails.custDtlId,
                remarks: rMarks,
                workflow: {
                    currentRole: gApzCOB.workflow.currentRole,
                    action: gApzCOB.workflow.action,
                    workflowId: gApzCOB.workflow.workflowId,
                    stage: gApzCOB.workflow.stage,
                },
            },
        },
    };
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "Stagemoment", "N", "N", req, false, apz.app.DBbase.StagemomentCB);
};
apz.app.DBbase.StagemomentCB = function(params) {
    apz.app.DBbase.onClickQueryMdlCancel();
    ApzCOB.closeCommonModal(`newCommonConfModal`);
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let ifaceName = ApzCOB.GetInterfaceResMap(params);
            if (params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode == 0) {
                apz.stopLoader();
                if (approveRejectAction === "DBKITGENERATED") {
                    popUpObj = {
                        text: `Application No ${gApzCOB.userDetails.applicationId} Submitted Successsfully to RPC DB Verification`,
                        Btn: {
                            text: "Ok",
                            onClick: "apz.app.DBbase.gotoHome(`newCommonSuccModal`)",
                        }
                    };
                    ApzCOB.showNewCommonSuccessModal(popUpObj);
                    return;
                }
                if (["PUSHBACK", "RPCVERIFIED", "RESANCTION", "RPCBANKUPDATE"].includes(approveRejectAction)) {
                    apz.stopLoader();
                    popUpObj = {
                        text: ``,
                        Btn: {
                            text: "Ok",
                            onClick: "apz.app.DBbase.gotoHome(`newCommonSuccModal`)",
                        }
                    };
                    if (approveRejectAction === "PUSHBACK") {
                        popUpObj.text = `Application No ${gApzCOB.userDetails.applicationId} Sent back to KM Sourcing Successfully.`;
                        ApzCOB.showNewCommonSuccessModal(popUpObj);
                        return;
                    }
                    if (approveRejectAction === "RPCVERIFIED") {
                        popUpObj.text = `Application No ${gApzCOB.userDetails.applicationId} Sent back to Credit Assessment Successfully.`;
                        ApzCOB.showNewCommonSuccessModal(popUpObj);
                        return;
                    }
                    if (approveRejectAction === "RESANCTION") {
                        popUpObj.text = `Application No ${gApzCOB.userDetails.applicationId} Sent back to Re-Sanction Successfully with queries.`;
                        ApzCOB.showNewCommonSuccessModal(popUpObj);
                        return;
                    }
                    if (approveRejectAction === "RPCBANKUPDATE") {
                        popUpObj.text = `Application No ${gApzCOB.userDetails.applicationId} Sent back to RPC Successfully.`;
                        ApzCOB.showNewCommonSuccessModal(popUpObj);
                        return;
                    }
                }
                if (approveRejectAction === "REJECTED") {
                    apz.stopLoader();
                    popUpObj = {
                        text: `Application No ${gApzCOB.userDetails.applicationId} Rejected Successfully.`,
                        Btn: {
                            text: "Ok",
                            onClick: "apz.app.DBbase.gotoHome(`newCommonSuccModal`)",
                        }
                    };
                    ApzCOB.showNewCommonSuccessModal(popUpObj);
                    return;
                }
            } else {
                let popUpObj = {
                    text: "Failed",
                    Btn: {
                        text: "OK",
                        onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
                    }
                }
                ApzCOB.showNewCommonErrorModal(popUpObj);
            }
        } else {
            apz.stopLoader(); // to be done after getting the proper response from backend
            let popUpObj = {
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn: {
                    text: "OK",
                    onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
                }
            }
            ApzCOB.showNewCommonErrorModal(popUpObj);
        }
    } catch (e) {
        apz.stopLoader();
        let popUpObj = {
            text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
            Btn: {
                text: "OK",
                onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
            }
        }
        ApzCOB.showNewCommonErrorModal(popUpObj);
    }
    apz.stopLoader();
};
apz.app.DBbase.onClickUploadDoc = function(elmId) {
    if(apz.childScr === 'eNach') {
        let ldocs = apz.app.eNach.fetchSelectedDocs();
        if(ldocs.length >= maxStdDocUpload) {
            ApzCOB.showNewCommonErrorModal("Document Uploaded limit exceeded.");           
            return;
