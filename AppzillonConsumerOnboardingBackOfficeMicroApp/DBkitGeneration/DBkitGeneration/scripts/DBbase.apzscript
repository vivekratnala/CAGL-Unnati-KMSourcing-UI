    $(`#${hypId} svg`).removeClass('error suc inprg');
    if (![`${DbbaseScrId}DBLoanDetails_hyp`, `${DbbaseScrId}disbDocumentation_hyp`].includes(hypId)) {
        $(`#${hypId} use`).attr("xlink:href", "#icon-sidechldopt");
    } else {
