apz.app.DBbase.deleteDocumentCnfm = function(docId) {
    let callBackFn = apz.app.DBbase.deleteDocumentCnfmCB;
    ApzCOB.deleteDocument('', '', '', docId, callBackFn)
};
apz.app.DBbase.deleteDocumentCnfmCB = function(params) {
    apz.stopLoader();
    try {
        const isSuccess = ApzCOB.handleServiceCallBacks(params);
        const modalOptions = {
            text: isSuccess ? "Document Delete Success" : "Document Delete Failed.",
            Btn: {
                text: "OK",
                onClick: isSuccess ? "ApzCOB.closeCommonModal(`newCommonSuccModal`)" : "ApzCOB.closeCommonModal(`newCommonErrModal`)"
            }
        };
        ApzCOB.closeCommonModal(`newCommonConfModal`);
        if (isSuccess && params.res.APZCBO__DeleteDocument_Res.apiResponse.ResponseBody.responseObj === 'Success') {
            let deletedDocId = params?.req?.apiRequest?.requestObj?.appDocId || "";
            let documentArray = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
            if (!apz.isNull(deletedDocId) && documentArray.length > 0) {
                let updatedDocs = documentArray.filter(item => Number(item.appDocId) !== Number(deletedDocId));
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = [];
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = structuredClone(updatedDocs);
            }
        }
        let luploadType = '', lcustomerType = '';
        if (apz.childScr === 'UdyamReg') {
            luploadType = $(`#${scrId}successTick_ul`).is(":visible") ? "Udyam Reg Success" : "Udyam Reg Failed";
            lcustomerType = $(`#${scrId}custTypeRadio input:checked`).val();
        } else if (apz.childScr === 'eNach') {
            luploadType = 'DBBankUpdate';
            lcustomerType = custType;
            //condition for coApp
        }
        apz.app.DBbase.paintDocumentName(luploadType, lcustomerType);
        isSuccess ? ApzCOB.showNewCommonSuccessModal(modalOptions) : ApzCOB.showNewCommonErrorModal(modalOptions);
    } catch (e) {
        let popUpObj = {
            text: technicalErrMsg,
            Btn: {
                text: "OK",
                onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
            }
        }
        ApzCOB.showNewCommonErrorModal(popUpObj);
    }
};
