apz.app.DBbase.FileUploadCB = function(params) {
    apz.stopLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            ApzCOB.updateInsessionData(params);
            apz.app.DBbase.paintDocumentName(uploadType, customerType);
        }
    } catch (error) {
        let errMsg = "File upload failed.!";
        let interface = ApzCOB.GetInterfaceResMap(params);
        const apiResponse = params?.res?.[interface]?.apiResponse;
        errMsg = apiResponse?.ResponseHeader?.ResponseMessage ?? errMsg;
        ApzCOB.showNewCommonErrorModal(errMsg);
    }
};
apz.app.DBbase.paintDocumentName = function(docType, custType) {
    if (apz.isObjectEmpty(inSessionStore) || !inSessionStore.hasOwnProperty('applicationDocumentsWrapperList')) return;
    let documentResp = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
    if (documentResp.length > 0) {
        let cloneDiv = `${scrId}CloneRow_0`;
        let parentDiv = $(`#${scrId}DocsBlock`);
        parentDiv.html('');
        let ldocs = documentResp.filter(docs => docs.payload.documentType === docType && parseInt(docs.custDtlId) === parseInt(ApzCOB.getCustDetailID(custType)));
        if (ldocs.length > 0) {
            ldocs.forEach((doc, index) => {
                let newId = ApzCOB.cloneDashboardDivs(cloneDiv, parentDiv, index + 1);
                parentDiv.find('[id*="_0"]').each(function() {
                    let tempId = this.id.replace(/_0/g, '_'+ (index + 1));
                    this.id = tempId;
                });
                $(`#${newId} .uplnk  a.ett-hypl span`).text(doc.payload.documentFileName);
                if (!apz.isNull(doc.payload.uploadedBy) && docType === "ReAssesmentDoc") {
                    $(`#${newId} .docUploadedBy label`).html(`Uploaded By : <span>${doc.payload.uploadedBy}</span>`);
                } else {
                    $(`#${newId} .docUploadedBy`).addClass('sno');
                }
                $(`#${newId}`).attr('data-id', doc.appDocId);
                $(`#${newId}`).removeClass('sno');
                $(`#${newId} .updel ul li .ett-para.pri span`).text((!apz.isNull(doc.payload.docSize) ? (doc.payload.docSize / 1024).toFixed(2) : "-") + " KB");
            })
        }
    }
};
apz.app.DBbase.viewDocument = function(pthis) {
    let documentId = $(pthis).parents('.uploadimg').attr('data-id');
    let docDetails = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.find(doc => parseInt(doc.appDocId) === parseInt(
        documentId));
    if (!apz.isObjectEmpty(docDetails)) {
        window.paintFileName = docDetails?.payload?.documentFileName;
        let callBackFn = apz.app.DBbase.viewDocumentCB;
        ApzCOB.downloadFileFromServer(paintFileName, callBackFn);
    }
};
apz.app.DBbase.viewDocumentCB = function(params, pdocType) {
    apz.stopLoader();
    if (!apz.isNull(params.base64)) {
        if (pdocType === 'pdf') {
            apz.app.DBbase.viewPDFDocument(params.base64);
        } else {
            $(`#${DbbaseScrId}imgView_ul`).removeClass('sno');
            $(`#${DbbaseScrId}imgView`).attr('src', 'data:image/png;base64,' + params.base64);
            $(`#${DbbaseScrId}docViewModal .tool-hdr`).removeClass('sno');
            $(`#${DbbaseScrId}imgView_ul iframe`).remove();
            $(`#${DbbaseScrId}imgView_li`).removeClass('sno');
            ApzCOB.toggleModal(`${DbbaseScrId}docViewModal`);
        }
    } else {
        ApzCOB.showNewCommonErrorModal("Failed to fetch Document.");
    }
};
apz.app.DBbase.viewPDFDocument = function(base64) {
    $(`#${DbbaseScrId}imgView_ul iframe`).remove();
    const iframe = document.createElement('iframe');
    Object.assign(iframe, { src: (ApplicationPDFbase64 + base64), width: "700", height: "400"});
    document.getElementById(`${DbbaseScrId}imgView_ul`).appendChild(iframe);
    $(`#${DbbaseScrId}docViewModal .tool-hdr`).addClass('sno');
    ApzCOB.toggleModal(`${DbbaseScrId}docViewModal`);
    $(`#${DbbaseScrId}imgView_li`).addClass('sno');
};
