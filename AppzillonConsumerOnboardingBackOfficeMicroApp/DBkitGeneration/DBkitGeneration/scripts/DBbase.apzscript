    }
};
apz.app.DBbase.nextBtnEnableDisable = function(gaction) {
    const nxtBtnId = 'DBkitG__DBbase__nextBtn';
    if (gaction === 'disable') {
        ApzCOB.addDisableToInput(nxtBtnId);
        $('#'+ nxtBtnId).addClass('nxt-disabled');
    } else {
        ApzCOB.removeDisableToInput(nxtBtnId);
        $('#'+ nxtBtnId).removeClass('nxt-disabled');
    }
};
apz.app.DBbase.paintQuery = function(isRaised) {
    const stageIdMap = {8: 1, 9: 2, 10: 3};
    ['paintSBQueryDiv'].hide();
    let currStageData = inSessionStore.dbKitStatDetails.find(el => el.stageID === DB_CURRENT_STAGE_NO);
    if(apz.isNull(currStageData)) return [];
    let getStageQueryData = DBKIT_MASTERDATA.find(el => stageIdMap[el.id] === currStageData?.stageID);
    if(apz.isNull(getStageQueryData)) return [];
    getStageQueryData = JSON.parse(getStageQueryData.queries).sendbackReason;
    const queryIds = [];
    const matchingValues = [];
    const othQueries = [];
    sbQueryResponse = '';
    currStageData.query.forEach(q => {
        if (q.startsWith("oth?")) {
            let customValue = q.split('?')[1];
            if (customValue.includes('$')) {
                const parts = customValue.split('$');
                customValue = parts[0];
                sbQueryResponse = parts[1] || '';
            }
            othQueries.push({
                queryid: q.split('?')[0],
                queryDesc: customValue
            });
        } else {
            sbQueryResponse = q.includes('$') ? q.split('$')[1] : '';
            queryIds.push(q.includes('?') ? q.split('?')[0] : (q.includes('$') ? q.split('$')[0] : q));
        }
    });
    matchingValues.push(...getStageQueryData.filter(item => queryIds.includes(item.id)).map(item => ({
        queryid: item.id,
        queryDesc: item.value
    })));
    const orderedQueries = [...matchingValues, ...othQueries];
    let finalQueries = orderedQueries.map((item, index) => {
        if (item.queryDesc.includes('$')) {
            item.queryDesc = item.queryDesc.split('$')[0];
        }
        return {
            queryid: item.queryid,
            queryDesc: (index + 1) + '. ' + item.queryDesc
        };
    });
    finalSBQueries = [];
    orderedQueries.forEach((item, index) => {
        if (item.queryid === "oth") {
            finalSBQueries.push(`${item.queryid}?${item.queryDesc}`);
        } else {
            finalSBQueries.push(`${item.queryid}`);
        }
    });
    if (finalQueries.length > 0) {
        ['paintSBQueryDiv'].show();
        apz.data.scrdata.DBkitG__IpaintQueryInStage_Res = [];
        apz.data.scrdata.DBkitG__IpaintQueryInStage_Res = finalQueries;
        apz.data.loadData("IpaintQueryInStage", apz.currAppId);
        let queryuserId = inSessionStore.applicationTimelineDtl[inSessionStore.applicationTimelineDtl.length - 1]?.userId
        let formatTM = ApzCOB.formatDateTimeObj(currStageData?.timeStamp[0]);
        $(`#${scrId}queryRaisedByHeader_txtcnt`).text(`RPC DB verification remarks (${queryuserId} - ${formatTM})`);
        $(`#${scrId}sendBackResponse`).val(sbQueryResponse); //paintqueryValue if exists
    }
    if (isRaised) {
        return (finalQueries.length > 0) ? true : false;
    } else {
        return finalQueries;
    }
};
apz.app.DBbase.downloadShownImg = function() {
    ApzCOB.downloadCurrImage(`${DbbaseScrId}imgView`, paintFileName);
};
apz.app.DBbase.updateUdyamSidebarStatus = function() {
    let AppUdyamStatus = inSessionStore.udhyamDetails.find(el => el.customerType === 'Applicant')?.udhyamStatus;
    let CoAppUdyamStatus = inSessionStore.udhyamDetails.find(el => el.customerType === 'Co-App')?.udhyamStatus;
    if (AppUdyamStatus === "Failed" && CoAppUdyamStatus === "Failed") {
        apz.app.DBbase.addErrorStatus(`${DbbaseScrId}UdyamReg_hyp`);
    } else if (AppUdyamStatus === "Success" || CoAppUdyamStatus === "Success") {
        apz.app.DBbase.addCompleteStatus(`${DbbaseScrId}UdyamReg_hyp`);
    }
};
apz.app.DBbase.getCurrentTS = function() {
    let now = new Date(),
        pad = n => n.toString().padStart(2, '0');
    let docQueryTs = `${pad(now.getDate())}/${pad(now.getMonth() + 1)}/${now.getFullYear()} - ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
    return docQueryTs;
};
apz.app.DBbase.showPreview = function (params) {
    window.previousScreenId = apz.childScr;
    window.previousMicroAppId = apz.currAppId;
    if (params === "ApplicationDetails") {
        ApzCOB.toggleModal("APZCBO__BaseScreens__preview_modal")
        ApzCOB.launchMicroApp("cmnPre", "PreviewApplicantDetails", "APZCBO__BaseScreens__preview_modal_content", "");
    }
    if (params === "CreditAssessmentDetails") {
        ApzCOB.toggleModal("APZCBO__BaseScreens__preview_modal")
        ApzCOB.launchMicroApp("cmnPre", "PreviewCA", "APZCBO__BaseScreens__preview_modal_content", "");
    }
    if (params === "SanctionDetails") {
        ApzCOB.toggleModal("APZCBO__BaseScreens__preview_modal")
        ApzCOB.launchMicroApp("cmnPre", "PreviewSanction", "APZCBO__BaseScreens__preview_modal_content", "");
    }
}
