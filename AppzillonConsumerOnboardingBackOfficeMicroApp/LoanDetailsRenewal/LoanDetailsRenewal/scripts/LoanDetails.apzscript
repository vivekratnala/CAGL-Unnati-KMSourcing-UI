apz.app.onLoad_LoanDetails = function() {
    window.CB_LOAN_ID = '';
    apz.app.BaseScreens.hideNshowbackIcon();
    apz.app.BaseScreens.contactus();
    $('.req').removeClass('req');
    //Code to set type of cb to call
    if (!apz.isNull(cbCallType)) {
        if (cbCallType.CB_TYPE === 'BOTH') {
            CBCALLTYPEFLAG = cbCallType.BRE_BRANCH.includes(gApzCOB.requestNodes.applicationMaster.branchId) ? 'BRE' : 'IRE';
        } else {
            CBCALLTYPEFLAG = cbCallType.CB_TYPE;
        }
    }
    apz.app.LoanDetails.onLoadCollapseAll();
    apz.populateDropdown(document.getElementById(screenId + 'purpOfLoan'), ApzCOB.formatDropDownforArray(loanPurpose));
    // 	apz.populateDropdown(document.getElementById(screenId + 'subCategory'), ApzCOB.formatDropDownforArray(loanSubPurpose));
    apz.populateDropdown(document.getElementById(screenId + 'modeOfDisb'), ApzCOB.formatDropDownforArray(disbursementMode));
    //apz.populateDropdown(document.getElementById(screenId + 'freqOfRepayment'), ApzCOB.formatDropDownforArray(frequencyOfRepayment));
    apz.populateDropdown(document.getElementById(screenId + 'language'), ApzCOB.formatDropDownforArray(stateAndlanguage));
    apz.populateDropdown(document.getElementById(screenId + 'loanTenureYr'), ApzCOB.formatDropDownforArray(loanTenureMonths));
    // 	apz.app.LoanDetails.assignMinMaxLimit();
    var kendraFreq = gApzCOB.selLeadDtls.kendraMeetingFreq;
    if (kendraFreq === "WEEKLY") {
        filteredFrequencies = frequencyOfRepayment.slice(0, 4);
    } else if (kendraFreq === "BIWEEKLY") {
        filteredFrequencies = [0, 2, 3].map(i => frequencyOfRepayment[i]);   
    } else {
        filteredFrequencies = [0, 3].map(i => frequencyOfRepayment[i]);   
    }
    apz.populateDropdown(document.getElementById(screenId + 'freqOfRepayment'), ApzCOB.formatDropDownforArray(filteredFrequencies));
    apz.app.LoanDetails.showSlider();
    apz.app.LoanDetails.hideAndShowSlider();
    //apz.app.LoanDetails.fetchAllRoi();
    document.getElementById(BaseScrId + 'viewProdHpl').setAttribute('onclick', 'apz.app.LoanDetails.knowMore()');
    document.getElementById(BaseScrId + 'viewIntHpl').setAttribute('onclick', 'apz.app.LoanDetails.viewInt()');
    if (apz.deviceOs === "iOS") {
        $("#" + screenId + 'loanAmount').attr('type', 'Tel');
    }
    $('#APZCBO__BaseScreens__continue').attr('disabled', true);
    apz.setElmValue(screenId + "modeOfDisb", 'NEFT');
    ['loanDown', 'cibilUp', 'otpConsentBrowser_ul'].hide();
    if (apz.deviceType === "WEB") {
        $('#' + screenId + 'browseHyp_txtcnt').text('Browse');
    } else {
        $('#' + screenId + 'browseHyp_txtcnt').text('Capture');
    }
}
apz.app.onShown_LoanDetails = function() {
    $("#LoanRE__LoanDetails__modeOfSecur_option_MOSopt1_lbl_").addClass("sno");
    ApzCOB.removeDisableToInput(screenId + 'el_btn_7_0');
    if (gApzCOB.currentApplicant > 1 && CO_APPLICANT_CIBIL_STATUS && !backNav) {
        apz.startLoader();
    }
    apz.app.LoanDetails.configureFields();
    $(`#${BaseScrId}RefNumDiv`).removeClass('sno');
    $(`#${BaseScrId}RefNum`).text(ApzCOB.getDescfromLitCode("LIT_COMM_TXT_REF_NUM") + gApzCOB.userDetails.applicationId);
    $('#' + BaseScrId + 'headerViewProdCol').removeClass('sno');
    $('#' + BaseScrId + 'viewIntHpl').addClass('sno');
    $('#' + BaseScrId + 'headerText').text(gApzCOB.subProduct);
    $('#' + BaseScrId + 'backIcon').removeClass('sno');
    $('#' + BaseScrId + 'custIDandName').removeClass('sno');
    $('#' + BaseScrId + 'custIDandName').val("Member ID/Name - " + gApzCOB.selLeadDtls.customerId + "/" + gApzCOB.selLeadDtls.fullName);
    window.DepositSubProductCode = gApzCOB.productCode;
    window.DepositSubProductCodeName = gApzCOB.subProduct;
    window.otpConsentObj = {
        "OTPConsent": []
    };
    var TenureYrReading = apz.app.LoanDetails.format(fdYearMin, fdYearMax, 10);
    var depTenureReading = apz.app.LoanDetails.format(fdMonthMin, fdMonthMax, 10);
    var depAmountReading = apz.app.LoanDetails.format(fdAmountMin, fdAmountMax, 10);
    apz.app.BaseScreens.HeaderFooterData();
    apz.app.BaseScreens.getFirstStageNoForExistCust();
    $('#' + BaseScrId + 'sidebarCol').removeClass('sno');
    apz.app.LoanDetails.loanTenureYrSliderValues(TenureYrReading);
    apz.app.LoanDetails.loanTenureSliderValues(depTenureReading);
    apz.app.LoanDetails.loanAmountSliderValues(depAmountReading);
    $('#' + screenId + 'loanSlider').attr('min', fdAmountMin);
    $('#' + screenId + 'loanSlider').attr('max', fdAmountMax);
    $('#' + screenId + 'loanTenureSlider').attr('min', fdMonthMin);
    $('#' + screenId + 'loanTenureSlider').attr('max', fdMonthMax);
    $('#' + screenId + 'loanTenureYrSlider').attr('min', fdYearMin);
    $('#' + screenId + 'loanTenureYrSlider').attr('max', fdYearMax);
    $('#' + screenId + 'depoInterestRateSlider').attr('min', fdInterestMin);
    $('#' + screenId + 'depoInterestRateSlider').attr('max', fdInterestMax);
    $('#' + screenId + 'loanSlider').trigger('change');
    $('#' + screenId + 'loanTenureSlider').trigger('change');
    $('#' + screenId + 'loanTenureYrSlider').trigger('change');
    //$('#' + screenId + 'rateOfIntrst').val(22.00);
    let branchState = apz.isNull(gApzCOB.selLeadDtls.glBranchState) ? '' : gApzCOB.selLeadDtls.glBranchState.toUpperCase();
    for (var i = 0; i < rateOfInteres.length; i++) {
        if (rateOfInteres[i].key.toUpperCase() == branchState) {
            $(`#${screenId}rateOfIntrst`).val(rateOfInteres[i].value);
        }
    }
    $('#' + screenId + 'purpOfLoan').val(PleaseSelect).change();
    $('#' + screenId + 'subCategory').val(PleaseSelect).change();
    //$('#' + screenId + 'modeOfDisb').val(PleaseSelect);
    apz.setElmValue(screenId + "modeOfDisb", 'NEFT');
    for (var i = 0; i < language.length; i++) {
        if (language[i].key.split('~')[1].toUpperCase() == branchState) {
            $(`#${screenId}language`).val(language[i].value);
            ApzCOB.addDisableToInput(screenId + 'language');
        }
    }
    apz.app.LoanDetails.paintLoanDetails();
    if (LoanBackNavFlag) {
        $('#APZCBO__BaseScreens__continue').attr('disabled', false);
    }
    window.amount = $("#" + screenId + "loanAmount").val();
    window.tenure = $("#" + screenId + "loanTenureYr").val();
    window.tenureYr = $("#" + screenId + "loanTenureYr").val();
    window.totalTenure = tenureYr * 12 + parseInt(tenure);
    apz.app.LoanDetails.LoanDetailsCalculator(amount, rateOfInterest, totalTenure);
    ApzCOB.setMinMaxLength([{
        'fieldName': 'Amount',
        'fieldId': screenId + 'loanAmount'
    },
    {
        'fieldName': 'OTP',
        'fieldId': screenId + 'otp'
    }
     ])
    /*if (gApzCOB.currentApplicant > 1 && (!apz.isNull(CO_APPLICANT_CIBIL_STATUS))) {
    	apz.app.LoanDetails.paintCibilDetails();
    }*/
    if (pendingApplication) {
        apz.app.LoanDetails.setCbFlagsonSession();
    }
    apz.app.LoanDetails.hideAndShowLoanDetailsSec();
    if (gApzCOB.currentApplicant <= 1) {
        ApzCOB.showSubHeader("LIT_LOAN_APPLICATION_HEADER");
    } else {
        ApzCOB.showSubHeader("LIT_LOAN_APPLICATION_HEADER_CO_APP");
    }
    // apz.app.LoanDetails.fetchroi();
    upDocsData = ApzCOB.GetCommonCodes("UPLOADDOCS", "CASA")["UPLOADDOCS"];
    upDocsData["TYPES"].forEach(function(el) {
        if (el.split('~')[1] === "Y") {
            gAllowedFileTypes[el.split('~')[0]] = el.split('~')[0].toLocaleLowerCase();
        }
    });
    ApzCOB.hideDropDownArrow('loanTenureYr');
    ApzCOB.hideDropDownArrow('modeOfDisb');
    if (ISPUSHBACKPPL) {
        apz.app.LoanDetails.disablePushbackFields();
        $('#' + BaseScrId + 'backIcon').attr('onClick', 'ApzCOB.pushBackNavigationOnBack()');
    } else {
        $('#' + BaseScrId + 'backIcon').attr('onClick', 'ApzCOB.backNavigation()');
    }
    if(isRevAndConfEdit && gApzCOB.currentApplicant <= 1) {
        // apz.app.LoanDetails.disablePushbackFields();
        apz.app.LoanDetails.disableLoanEditFields();
    }
    if (IS_REJECTED_APPLICATION && !backNav) {
        if (gApzCOB.currentApplicant <= 1) {
            APPLICANT_CIBIL_STATUS = "";
        } else {
            CO_APPLICANT_CIBIL_STATUS = "";
        }
    }
    if (gApzCOB.currentApplicant <= 1) {
        if (!apz.isNull(APPLICANT_CIBIL_STATUS)) {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], true);
            apz.app.LoanDetails.disableLoanEditFields();
        } else {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], false);
        }
    } else {
        if (!apz.isNull(CO_APPLICANT_CIBIL_STATUS)) {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], true);
        } else {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], false);
        }
    }
    if (gApzCOB.currentApplicant <= 1) {
        $('#' + screenId + 'eligibleAmount_0_txtcnt').addClass('sno');
        $('#' + screenId + 'elligibileAmount_row').addClass('sno');
    } else {
        $('#' + screenId + 'eligibleAmount_0_txtcnt').removeClass('sno');
        $('#' + screenId + 'elligibileAmount_row').removeClass('sno');
    }
    ApzCOB.removeDisableToInput(screenId + 'el_btn_7_0');
    if (gApzCOB.currentApplicant <= 1) {
        if (IS_APPLICANT_CB_EXPIRED) {
            if (CBCALLTYPEFLAG === 'BRE') {
                income = ApzCOB.getOccupation("Income");
                if (apz.isNull(income)) {
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_ANNUAL_INCOME_MISSING"), "E");
                    apz.app.LoanDetails.collapseCibilCheck();
                    return;
                } else {
                    apz.app.LoanDetails.onclickCibilCheck();
                }
            } else {
                apz.app.LoanDetails.onclickCibilCheck();
            }
        }
    } else {
        if (IS_CO_APPLICANT_CB_EXPIRED) {
            if (CBCALLTYPEFLAG === 'BRE') {
                income = ApzCOB.getOccupation("Income");
                let applicantIncome = ApzCOB.getOccupation("Income", "applicant");
                if (apz.isNull(income) || apz.isNull(applicantIncome)) {
                    if (apz.isNull(applicantIncome)) {
                        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPLICANT_ANNUAL_INCOME_MISSING"), "E");
                    } else {
                        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_ANNUAL_INCOME_MISSING"), "E");
                    }
                    apz.app.LoanDetails.collapseCibilCheck();
                    return;
                } else {
                    ApzCOB.callCBService(); // Calling CB based on Type
                }
            } else {
                ApzCOB.callCBService(); // Calling CB based on Type
            }
        }
    }
    if (PUSHBACK_QUERY_STATUS.includes(gApzCOB.userDetails.applicationStatus)) {
        ApzCOB.paintingSourcingQuery();
    }
    $("#LoanRE__LoanDetails__modeOfSecur_option_MOSopt3").attr('checked', true);
};
apz.app.LoanDetails.paintCibilDetails = function() {
    ['cbRejectReasonRow_row'].hide();
    if (apz.isObjectEmpty(cibilDtls)) {
        if (!apz.isNull(inSessionStore.cibilDetailsWrapperList)) {
            if (!apz.isNull(inSessionStore.cibilDetailsWrapperList[CURRENT_APPLICANT_DETAILS_INDEX])) {
                let itemIndex = window.inSessionStore.cibilDetailsWrapperList.findIndex(item => parseInt(item.cibilDetails.custDtlId) === parseInt((gApzCOB.currentApplicant <= 1) ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId));
                if (!apz.isNull(itemIndex) && itemIndex >= 0) {
                    cibilDtls = inSessionStore.cibilDetailsWrapperList[itemIndex].cibilDetails.payload;
                    cibilDtls.cbReport = !apz.isNull(cibilDtls.cbReport) ? cibilDtls.cbReport.replaceAll('~', '&') : '';
                }
            }
        }
    }
    if (apz.isNull(CB_LOAN_ID)) {
        var appCbData;
        appCbData = inSessionStore.cibilDetailsWrapperList.filter(appCB => parseInt(appCB.cibilDetails.custDtlId) ===  ((gApzCOB.currentApplicant <= 1) ? parseInt(gApzCOB.userDetails.custDtlId) : parseInt(gApzCOB.userDetails.CoApplicantCustomerId)));
        if (!apz.isNull(appCbData) && appCbData.length > 0) {
            CB_LOAN_ID = appCbData[0].cibilDetails.payload.cbLoanId;
            if (apz.isNull(appCbData[0].cibilDetails.payload.bureauName) && appCbData[0].cibilDetails.payload.hasOwnProperty('irisMessage')) {
                appCbData[0].cibilDetails.payload.bureauName = 'BRE';
            }
        }
    }
    let finalDecision = !apz.isNull(cibilDtls.finalDecision) ? cibilDtls.finalDecision.toLowerCase() : '';
    if (gApzCOB.currentApplicant <= 1) {
        APPLICANT_CIBIL_STATUS = (finalDecision.includes("approve") || finalDecision === "pass") ? true : false;
        if (!apz.isNull(APPLICANT_CIBIL_STATUS)) {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], true);
            apz.app.LoanDetails.disableLoanEditFields();
        } else {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], false);
        }
    } else {
        CO_APPLICANT_CIBIL_STATUS = (finalDecision.includes("approve") || finalDecision === "pass") ? true : false;
        if (!apz.isNull(CO_APPLICANT_CIBIL_STATUS)) {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], true);
        } else {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], false);
        }
    }
    if (!apz.isNull(cibilDtls)) {
        var cibilDtlsJson = [];
        cbSummaryArr.forEach(el => ApzCOB.beautifyCbDtlsSummary(el, cibilDtls));
        cibilDtlsJson.push(cibilDtls);
        apz.data.scrdata.LoanRE__IpaintCibilDetails_Res = {};
        apz.data.scrdata.LoanRE__IpaintCibilDetails_Res = cibilDtlsJson;
        apz.data.loadData('IpaintCibilDetails', apz.currAppId);
    }
    if (finalDecision === "pass" || finalDecision.includes("approve")) {
        $('#' + screenId + 'highMarkDecisionTxt_0_txtcnt').text('CB check successful');
        $('#' + screenId + 'cibilSuccess_0').removeClass('sno')
        $('#' + screenId + 'cibilFailure_0').addClass('sno');
        $(`#${screenId}retryCB_0`).addClass('sno');
    } else {
        $('#' + screenId + 'highMarkDecisionTxt_0_txtcnt').text('CB check failed');
        ['cbRejectReasonRow_row'].show();
        $(`#${screenId}cbRejectReason_0_txtcnt`).text(`Reject reason: ${cibilDtls?.rejectionReason ?? '-'}`);
        $('#' + screenId + 'cibilSuccess_0').addClass('sno');
        $('#' + screenId + 'cibilFailure_0').removeClass('sno');
        if (!retry_Attempts || retry_Attempts === 0) {
            $(`#${screenId}retryCB_0`).addClass("sno");
            /*let popUpObj = {
                text: ,
                Btn: {
                    text: "Ok",
                    onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`); apz.app.LoanDetails.handleCbFailure();"
                }
            };
            ApzCOB.showNewCommonErrorModal(popUpObj);*/
            if (gApzCOB.currentApplicant <= 1 ? !APPLICANT_CIBIL_STATUS : !CO_APPLICANT_CIBIL_STATUS) {
                RejectReason = gApzCOB.currentApplicant <= 1 ? `Applicant CB Decision Failed.Reason: ${cibilDtls?.rejectionReason}` :
                    `Co-Applicant(C0${CO_APP_ADDED_COUNT}) CB Decision Failed.Reason: ${cibilDtls?.rejectionReason}`;
            }
            let errMsgBRE = `CB retrigger limit exceeded.Please reject the application.<br/>Reject reason: ${cibilDtls?.rejectionReason ?? '-'}.`;
            let typofAppl = gApzCOB.currentApplicant <= 1 ? `Applicant`: `Co-Applicant`;
            if (cibilDtls?.irisMessage?.includes('success')) {
                errMsgBRE = `${typofAppl} CB failed!.Please reject the application.<br/>Reject reason: ${cibilDtls?.rejectionReason ?? '-'}.`;
            }
            $(`#${screenId}rejectLabel`).html(errMsgBRE);
            $(`#${screenId}el_btn_4_txtcnt`).text('Reject');
            ApzCOB.toggleModal(screenId + 'rejectmodel');
        } else {
            ApzCOB.CBretriggermdl();
            $("#LoanRE__LoanDetails__retryCB_0").removeClass("sno");
            $("#LoanRE__LoanDetails__retryCB_0").attr("disabled", false);
        }
    }
    if (apz.isNull(CB_HIGHMARK_REPORT_LINK)) {
        CB_HIGHMARK_REPORT_LINK = cibilDtls.cbReport ?? '';
    }
    let elligibleAmount = (!apz.isNull(cibilDtls.eligibleAmt)) ? cibilDtls.eligibleAmt : "0";
    $('#' + screenId + 'eligibleAmount_0_txtcnt').text("Eligible amount : " + elligibleAmount);
    $(`#${paintCibilID}roi_0_txtcnt`).text(cibilDtls.roi+'%');
    if(!apz.isNull(cibilDtls.bureauName)) {
        if(cibilDtls.bureauName === "BRE") {
            ['hitNohitRow_row', 'runningEMIRow_row'].hide();
            ['individualIndebtRow_row'].show();
            if (gApzCOB.currentApplicant <= 1) {
                ['totIndebtnessRow_row'].hide();
            } else {
                ['totIndebtnessRow_row'].show();
            }
        } else {
            $('#' + paintCibilID + 'writeoffSuitFiledFlag_0_txtcnt').text(cibilDtls.writtenOff ?? '');
            ['hitNohitRow_row', 'runningEMIRow_row', 'totIndebtnessRow_row'].show();
            ['individualIndebtRow_row'].hide();
        }
    }
}
apz.app.LoanDetails.hideAndShowLoanDetailsSec = function() {
    if (gApzCOB.currentApplicant > 1 && !LoanBackNavFlag) {
        loanFlag = true;
        $(loanDetailsID).addClass("sno");
        $('#' + screenId + 'loanAvaDesc_ul').removeClass('sno');
        $('#' + screenId + 'gr_row_4').removeClass('active');
        ['gr_row_4', 'otpDiv'].hide();
        $(cibilCheckID).addClass("sno")
        apz.app.LoanDetails.onclickCibilCheck();
    }
}
apz.app.LoanDetails.configureFields = function() {
    var a = {
        fieldName: 'LoanAmount',
        fieldId: [screenId + 'loanAmount'],
        fieldDivId: [screenId + 'loanAmtDiv']
    };
    var b = {
        fieldName: 'Tenure',
        fieldId: [screenId + 'loanTenureYr'],
        fieldDivId: [screenId + 'TenureDiv']
    };
    var c = {
        fieldName: 'RateOfInterest',
        fieldId: [screenId + 'rateOfIntrst'],
        fieldDivId: [screenId + 'rateOfIntrstDiv']
    };
    var d = {
        fieldName: 'PurposeOfLoan',
        fieldId: [screenId + 'purpOfLoan'],
        fieldDivId: [screenId + 'purposeOfLoanDiv']
    };
    var e = {
        fieldName: 'SubCategory',
        fieldId: [screenId + 'subCategory'],
        fieldDivId: [screenId + 'subCategoryDiv']
    };
    var f = {
        fieldName: 'ModeOfDisb',
        fieldId: [screenId + 'modeOfDisb'],
        fieldDivId: [screenId + 'modeOfDisburDiv']
    };
    var g = {
        fieldName: 'ModeOfSecur',
        fieldId: [screenId + 'modeOfSecur'],
        fieldDivId: [screenId + 'modeOfSecurDiv']
    };
    var h = {
        fieldName: 'OTP',
        fieldId: [screenId + 'otp'],
        fieldDivId: [screenId + 'otpDiv']
    };
    var i = {
        fieldName: 'FreqOfRepayment',
        fieldId: [screenId + 'freqOfRepayment'],
        fieldDivId: [screenId + 'freqOfRepaymentDiv']
    };
    var j = {
        fieldName: 'Language',
        fieldId: [screenId + 'language'],
        fieldDivId: [screenId + 'languageDiv']
    };
    ApzCOB.ConfigureFields([a, b, c, d, e, f, g, h, i, j], 'LOANDETAILS', 'LOANDETAILS');
};
apz.app.LoanDetails.CheckManFiled = function() {
    if (fdMonthman === 'Y') {
        $('#LoanRE__LoanDetails__monthlable').addClass('req');
    } else {
        $('#LoanRE__LoanDetails__monthlable').removeClass('req');
    }
    if (fdYearMan === 'Y') {
        $('#LoanRE__LoanDetails__tenureyears').addClass('req');
    } else {
        $('#LoanRE__LoanDetails__tenureyears').removeClass('req');
    }
}
apz.app.LoanDetails.showSlider = function() {
    $("#" + screenId + "loanSlider").slider({
        range: "min",
        value: parseInt(fdAmountMin),
        min: parseInt(fdAmountMin),
        max: parseInt(fdAmountMax),
        slide: function(event, ui) {
            // apz.app.LoanDetails.onChangeofdepoAmountSlider();
            ui.value = Math.round(ui.value / 1000) * 1000;
            $("#" + screenId + "loanAmount").val(ApzCOB.fn_FormatAmount(ui.value)).trigger("onchange");
        },
        change: function(event, ui) {
            // apz.app.LoanDetails.onChangeofdepoAmountSlider();
            ui.value = Math.round(ui.value / 1000) * 1000;
            $("#" + screenId + "loanAmount").val(ApzCOB.fn_FormatAmount(ui.value));
        },
        stop: function(event, ui) {
            // apz.app.LoanDetails.onChangeofdepoAmountSlider();
