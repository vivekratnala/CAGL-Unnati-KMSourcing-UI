apz.app.LoanDetails.format = function(minvalue, maxvalue, div) {
    var min = minvalue - 1;
    var diff = maxvalue - min;
    var divs = div;
    var r = [],
        i, z;
    r.push(minvalue);
    var mainDiff = diff / divs;
    if (minvalue === 1) {
        for (i = 1; i <= divs; i++) {
            z = mainDiff * i
            z = Math.round(z)
            r.push(z)
        }
        return r;
    } else {
        for (i = 2; i <= divs + 1; i++) {
            z = mainDiff * i
            z = Math.round(z)
            r.push(z)
        }
        return r;
    }
};
