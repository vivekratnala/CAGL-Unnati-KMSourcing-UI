apz.app.LoanDetails.assignMinMaxLimit = function() {
    var limitList;
    var tempArr = [];
    if (apz.isNull(gApzCOB.subProduct)) {
        var req = {
            "apiRequest": {
                "requestObj": {
                    "productGroupCode": window.LoanInProgressProductGroupCode
                }
            }
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "FetchProductDetails", "N", "N", req, false, apz.app.LoanDetails.fetchSubProduct);
    } else {
        apz.data.scrdata.Select__IpaintProductDetails_Res.data.forEach(function(el) {
            if (el.productName === gApzCOB.subProduct) {
                var obj = {}
                Object.entries(el.feature).forEach(function(p) {
                    obj[p[0].split('~')[0]] = p[1];
                });
                limitList = obj
            }
        })
        apz.app.LoanDetails.setLimitList(limitList)
    }
};
