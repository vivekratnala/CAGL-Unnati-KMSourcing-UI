apz.app.EmploymentDetails.employeeAddress = function() {
    if (!apz.isNull(window.EMP_ADDRESS) && window.EMP_ADDRESS.length > 0) {
        gApzCOB.requestNodes['addressDetailsWrapperList'] = window.EMP_ADDRESS;
    }
    if ((!apz.isNull(window.EMP_ADDRESS_SAVE) && window.EMP_ADDRESS_SAVE.length > 0) && inSessionStoreEnabled) {
        window.inSessionStore.addressDetailsWrapperList = window.EMP_ADDRESS_SAVE;
