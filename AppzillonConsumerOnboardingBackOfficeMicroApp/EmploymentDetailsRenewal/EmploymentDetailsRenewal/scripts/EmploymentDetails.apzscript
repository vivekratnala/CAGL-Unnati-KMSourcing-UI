//function to display address details
apz.app.EmploymentDetails.paintAddressDetails = function() {
    arrIndex = "";
    var payloadIndex = -1;
    var addressData = "";
    curAddrDetails = gApzCOB.requestNodes['addressDetailsWrapperList'];
    //curAddrDetails=apz.isNull(window.dontPaint?beforeBack.addressDetailsWrapperList:window.inSessionStore.addressDetailsWrapperList)
    //?curAddrDetails:(window.dontPaint?beforeBack.addressDetailsWrapperList:window.inSessionStore.addressDetailsWrapperList);
    if (!apz.isNull(curAddrDetails) && curAddrDetails.length > 0) {
        ApzCOB.paintAddreDetails();
        //  if (!apz.isNull(window.inSessionStore.addressDetailsWrapperList)) {
        //   var isEmp = apz.currAppId === 'EmpDet' && window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].payload.addressList
        //       .some(function(e, i) {
        //           return (e.addressType.indexOf('Occupation') !== -1) //Check if the address array has occupation details
        //      });
        //   var isPer = apz.currAppId === 'PerDet' && window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].payload.addressList
        //       .some(function(e, i) {
        //           return (e.addressType.indexOf('Permanent') !== -1) //Check if the address array has permanent details
        //       })
        //  if (isEmp || isPer) {
        //      curAddressDetails = window.inSessionStore.addressDetailsWrapperList //If it has anyone of these details then paint from local save
        //  } else {
        //      curAddressDetails = gApzCOB.requestNodes['addressDetailsWrapperList'] //If it doesn't then paint from reponse
        //  }
        //}
        curAddrDetails[0]['addressDetailsList'].forEach(function(i, k) {
            i["payload"]["addressList"].filter(function(m, n) {
                if (m.addressType === "Occupation") {
                    /*if (!apz.isNull(i["addressDtlsId"])) {
                            gApzCOB.userDetails.occAddressDtlsId = i["addressDtlsId"];
                        }*/
                    arrIndex = k;
                    payloadIndex = n;
                    return;
                }
            })
        })
        if (payloadIndex > -1) {
            addressData = curAddrDetails[0]["addressDetailsList"][arrIndex]["payload"]["addressList"][payloadIndex];
            apz.app.EmploymentDetails.LoadEmpAddrIndex();
            /*if (window.pendingApplication) {
                window.EMP_ADDRESS = [];
                window.EMP_ADDRESS_SAVE = [];
                var obj = {
                    "addressDetailsList": []
                };
                obj.addressDetailsList.push(curAddrDetails[0]['addressDetailsList'][arrIndex])
                EMP_ADDRESS.push(obj);
                window.EMP_ADDRESS_SAVE.push(obj);
            }*/
            $('#' + EmpDetscrId + "pin").val(addressData["pinCode"]);
            $('#' + EmpDetscrId + "state").val(apz.isNull(addressData["state"]) ? PleaseSelect : addressData["state"]).change();
            $('#' + EmpDetscrId + "city").val(apz.isNull(addressData["city"]) ? PleaseSelect : addressData["city"]);
            $('#' + EmpDetscrId + "addressLine1").val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine1`, addressData["addressLine1"]));
            $('#' + EmpDetscrId + "addressLine2").val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine2`, addressData["addressLine2"]));
            $('#' + EmpDetscrId + "landMark").val(ApzCOB.getSubstrValue(`#${EmpDetscrId}landMark`, addressData["landMark"]));
        }
    }
}
//paint the details on click of back icon.
apz.app.EmploymentDetails.paintDetails = function() {
    apz.app.EmploymentDetails.employeeAddress();
    apz.app.EmploymentDetails.data();
    if (!apz.isNull(data)) {
        //
        var OccpDtls = data["payload"];
        $('#' + EmpDetscrId + "profession").val(!apz.isNull(OccpDtls["occupationType"]) ? OccpDtls["occupationType"] :
        PleaseSelect);
        var yearofExp = OccpDtls["experience"].split(' ')[0];
        var monsofExp = OccpDtls["experience"].split(' ')[2];
        $('#' + EmpDetscrId + "yrsOfExp").val(yearofExp ? yearofExp : PleaseSelect);
        $('#' + EmpDetscrId + "monOfExp").val(monsofExp ? monsofExp : PleaseSelect);
        //$('#' + EmpDetscrId + "employerName").val(OccpDtls["employer"]);
        $(`#${EmpDetscrId}employerName`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}employerName`, OccpDtls["employer"] ?? '')).trigger("onblur");
        $('#' + EmpDetscrId + "employeeId").val(OccpDtls["employeeId"]);
        $('#' + EmpDetscrId + "designation").val(!apz.isNull(OccpDtls["designation"]) ? OccpDtls["designation"] : PleaseSelect);
        $(`#${EmpDetscrId}typeOfEmployer`).val(!apz.isNull(OccpDtls.typeOfEmployer) ? OccpDtls.typeOfEmployer : PleaseSelect);
        $(`#${EmpDetscrId}currentBusinessYrs`).val(OccpDtls.employeeSince.split(" ")[0] ? OccpDtls.employeeSince.split(" ")[0] : PleaseSelect);
        $(`#${EmpDetscrId}currentBusinessMonths`).val(OccpDtls.employeeSince.split(" ")[2] ? OccpDtls.employeeSince.split(" ")[2] : PleaseSelect);
        $(`#${EmpDetscrId}retirementAge`).val(OccpDtls.retirementAge ? OccpDtls.retirementAge : PleaseSelect);
        $(`#${EmpDetscrId}lastEmployerName`).val(OccpDtls.lastEmployer ? OccpDtls.lastEmployer : "");
        $(`#${EmpDetscrId}prevBusinessYrs`).val(OccpDtls.previousJobYears.split(" ")[0] ? OccpDtls.previousJobYears.split(" ")[0] : PleaseSelect);
        $(`#${EmpDetscrId}prevBusinessMonths`).val(OccpDtls.previousJobYears.split(" ")[2] ? OccpDtls.previousJobYears.split(" ")[2] :
            PleaseSelect);
        $(`#${EmpDetscrId}typbssEmpent`).val(!apz.isNull(OccpDtls.typeofbusiness) ? OccpDtls.typeofbusiness : PleaseSelect);
        $(`#${EmpDetscrId}bssEmpAcc`).val(!apz.isNull(OccpDtls.employeeActivity) ? OccpDtls.employeeActivity : PleaseSelect);
        $(`#${EmpDetscrId}bssAddrProof`).val(!apz.isNull(OccpDtls.businessAddressProof) ? OccpDtls.businessAddressProof : PleaseSelect);
        $(`#${EmpDetscrId}empProof`).val(!apz.isNull(OccpDtls.employmentProof) ? OccpDtls.employmentProof : PleaseSelect);
        $(`#${EmpDetscrId}bssPerOwn`).val(!apz.isNull(OccpDtls.businessPremiseOwnerShip) ? OccpDtls.businessPremiseOwnerShip : PleaseSelect);
        $(`#${EmpDetscrId}freqOfInc`).val(!apz.isNull(OccpDtls.freqOfIncome) ? OccpDtls.freqOfIncome : PleaseSelect);
        apz.app.EmploymentDetails.setAnnualIncomeValue(OccpDtls.annualIncome);
        $(`#${EmpDetscrId}othSrcInc`).val(!apz.isNull(OccpDtls.otherSourceIncome) ? OccpDtls.otherSourceIncome: PleaseSelect);
        $(`#${EmpDetscrId}othSrcAnnInc`).val(OccpDtls.otherSourceAnnualIncome);
        $(`#${EmpDetscrId}busiEmpStartDatInput`).val(OccpDtls.businessEmpStartDate);
        $(`#${EmpDetscrId}busiEmpVintageInput`).val(OccpDtls.businessEmpVintageYear);
        if (!apz.isNull(OccpDtls.streetVendor)) {
            $('#' + EmpDetscrId + 'streetVendor_option_' + OccpDtls.streetVendor).attr("checked", true);
        }
        //apz.app.EmploymentDetails.paintDetailsOnBackNav();
        // apz.app.EmploymentDetails.paintAddressDetails();
        // if (!apz.isNull(occAddress[CURRENT_APPLICANT_DETAILS_INDEX])) {
        apz.app.EmploymentDetails.paintDetailsOnBackNav();
        // } 
    }
};
apz.app.EmploymentDetails.paintDetailsOnBackNav = function() {
    let currentIndex = gApzCOB.currentApplicant - 1;
    //Insurance Details
    if (!apz.isNull(inSessionStore.insuranceDetailsWrapperList) && !apz.isNull(inSessionStore.insuranceDetailsWrapperList[
            CURRENT_APPLICANT_DETAILS_INDEX])) {
        var InsDtls = '';
        inSessionStore.insuranceDetailsWrapperList.forEach(function(el, index) {
            if (gApzCOB.currentApplicant === 1) {
                if (parseInt(el.insuranceDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                    InsDtls = window.inSessionStore.insuranceDetailsWrapperList[index].insuranceDetails.payload;
                }
            } else if (gApzCOB.currentApplicant === 2) {
                if (parseInt(el.insuranceDetails.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId)) {
                    InsDtls = window.inSessionStore.insuranceDetailsWrapperList[index].insuranceDetails.payload;
                }
            }
        })
        //var InsDtls = window.inSessionStore.insuranceDetailsWrapperList[CURRENT_APPLICANT_DETAILS_INDEX].insuranceDetails.payload
        $(`#${EmpDetscrId}insuranceFor`).val(InsDtls.insuredName === "Applicant" ? 'Applicant' : 'Co-Applicant');
        let relatn = InsDtls.nomineeRelation;
        if (relatn.toLocaleLowerCase() === 'spouse') {
            let applicantData = ApzCOB.getApplicantCustData();
            if (applicantData.length > 0) {
                if (applicantData[0].payload.maritalStatus.toLocaleLowerCase() !== "married") {
                    relatn = PleaseSelect;
                }
            }
        }
        $(`#${EmpDetscrId}relationWithNominee`).val(relatn ? relatn : PleaseSelect).change();
        $(`#${EmpDetscrId}dobNominee`).val(InsDtls.nomineeDob ?? '');
        $(`#${EmpDetscrId}ageOfNominee`).val(InsDtls.age ?? '');
        //$(`#${EmpDetscrId}nomineeForInsur`).val(InsDtls.nomineeName ?? '');
        $(`#${EmpDetscrId}nomineeForInsur`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}nomineeForInsur`, InsDtls.nomineeName ?? '')).trigger("onblur");
        $(`#${EmpDetscrId}ApplInsRadio`).val(InsDtls.insuranceReqd === "Y" ? $(`#${EmpDetscrId}ApplInsRadio_option_Y`).attr("checked", true) : $(
            `#${EmpDetscrId}ApplInsRadio_option_N`).attr("checked", true));
        $(`#${EmpDetscrId}coAppInsuranceRadio`).val(InsDtls.coApplicantInsurance === 'Y' ? $(`#${EmpDetscrId}coAppInsuranceRadio_option_Y`).attr(
            "checked", true) : $(`#${EmpDetscrId}coAppInsuranceRadio_option_N`).attr("checked", true));
        if (InsDtls.coApplicantInsurance == 'Yes') {
            $(`#${EmpDetscrId}coAppInsuranceRadio_option_Y`).prop(`checked`, true);
        } else if (InsDtls.coApplicantInsurance == 'No') {
            $(`#${EmpDetscrId}coAppInsuranceRadio_option_N`).prop(`checked`, true);
        }
    }
    // apz.app.EmploymentDetails.ageCalculator();
    //Office Address Details
    if (!apz.isNull(inSessionStore.addressDetailsWrapperList)) {
        // 		let OffAddr = window.inSessionStore.addressDetailsWrapperList;
        // 		var occAddress = [],
        // 			personalAddress = [];
        // 		if (!apz.isNull(OffAddr)) {
        // 			OffAddr[0].addressDetailsList.forEach(function(i, k) {
        // 				if (i.addressType === "Occupation") {
        // 					occAddress.push(OffAddr[0].addressDetailsList[k])
        // 				} else if (i.addressType === "Personal") {
        // 					personalAddress.push(OffAddr[0].addressDetailsList[k])
        // 				}
        // 			})
        // 		}
        var address = inSessionStore.addressDetailsWrapperList[0].addressDetailsList
        var officelAddress = []
        if (gApzCOB.currentApplicant === 1) {
            address.forEach(function(i, k) {
                if (address[k].addressType === 'Occupation' && parseInt(address[k].custDtlId) === parseInt(gApzCOB.userDetails
                    .custDtlId)) {
                    officelAddress.push(address[k])
                }
            })
        } else if (gApzCOB.currentApplicant === 2) {
            address.forEach(function(i, k) {
                if (address[k].addressType === 'Occupation' && parseInt(address[k].custDtlId) === parseInt(gApzCOB.userDetails
                        .CoApplicantCustomerId)) {
                    officelAddress.push(address[k])
                }
            })
        }
        if (officelAddress.length > 0) {
            //var OffAdr = occAddress[CURRENT_APPLICANT_DETAILS_INDEX].payload.addressList[0];
            var OffAdr = officelAddress[0].payload.addressList[0]
            $(`#${EmpDetscrId}addressLine1`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine1`, OffAdr.addressLine1 ?? ''));
            $(`#${EmpDetscrId}addressLine2`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine2`, OffAdr.addressLine2 ?? ''));
            $(`#${EmpDetscrId}addressLine3`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine3`, OffAdr.addressLine3 ?? ''));
            $(`#${EmpDetscrId}pin`).val(OffAdr.pinCode ?? '');
            $(`#${EmpDetscrId}city`).val(OffAdr.city ?? '');
            $(`#${EmpDetscrId}district`).val(OffAdr.district ?? '');
            $(`#${EmpDetscrId}state`).val(OffAdr.state ?? '');
            $(`#${EmpDetscrId}country`).val(OffAdr.country ?? '');
            $(`#${EmpDetscrId}nameAsperAddr`).val(OffAdr.nameAsperAddressProof ?? '');
            $(`#${EmpDetscrId}el_inp_1`).val(OffAdr.addressType ?? '');
            $(`#${EmpDetscrId}el_inp_2`).val(OffAdr.landMark ?? '');
            $(`#${EmpDetscrId}el_inp_3`).val(OffAdr.area ?? '');
            $(`#${EmpDetscrId}location`).val(OffAdr.locateCoOrdinates ?? '');
            $(`#${EmpDetscrId}officeAddrSameAs_option_` + OffAdr.addressSameAs).attr("checked", true);
            if (!apz.isNull(OffAdr.addressSameAs) && OffAdr.addressSameAs !== 'Other') {
                $(`#${EmpDetscrId}officeAddrSameAs_option_` + OffAdr.addressSameAs).attr("checked", true).select();
            }
        }
    }
    //Bank Details
    if (!apz.isNull(inSessionStore.bankDetailsWrapperList)) {
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        var BnkDtls = window.inSessionStore.bankDetailsWrapperList[currIndex]?.bankDetails?.payload
        $(`#${EmpDetscrId}typeOfAcc`).val(BnkDtls.accountType ?? '');
        $(`#${EmpDetscrId}accHolderName`).val(BnkDtls.accountName ?? '');
        $(`#${EmpDetscrId}ifscCode`).val(BnkDtls.ifsc ?? '');
        $(`#${EmpDetscrId}bankName`).val(BnkDtls.bankName ?? '');
        $(`#${EmpDetscrId}branchName`).val(BnkDtls.branchName ?? '');
        $(`#${EmpDetscrId}accNumber`).val(BnkDtls.accountNumber ?? '');
    }
    // $(`#${EmpDetscrId}coappIns`).val(BnkDtls.coApplicantInsurance);
    //Occupation Deatails
    if (!apz.isNull(inSessionStore.occupationDetailsWrapperList) && !apz.isNull(inSessionStore.occupationDetailsWrapperList[    CURRENT_APPLICANT_DETAILS_INDEX])) {
        var OccupationDtls = '';
        inSessionStore.occupationDetailsWrapperList.forEach(function(el, index) {
            if (gApzCOB.currentApplicant === 1) {
                if (parseInt(el.occupationDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                    OccupationDtls = window.inSessionStore.occupationDetailsWrapperList[index].occupationDetails.payload;
                }
            } else if (gApzCOB.currentApplicant === 2) {
                if (parseInt(el.occupationDetails.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId)) {
                    OccupationDtls = window.inSessionStore.occupationDetailsWrapperList[index].occupationDetails.payload;
                }
            }
        })
        // var OccupationDtls = window.inSessionStore.occupationDetailsWrapperList[CURRENT_APPLICANT_DETAILS_INDEX].occupationDetails.payload
        if (!apz.isNull(OccupationDtls) || OccupationDtls.length > 0) {
            $(`#${EmpDetscrId}profession`).val(OccupationDtls.occupationType ?? '');
            $(`#${EmpDetscrId}profession`).change();
            $(`#${EmpDetscrId}typeOfEmployer`).val(OccupationDtls.typeOfEmployer ?? '');
            //$(`#${EmpDetscrId}employerName`).val(OccupationDtls.employer ?? '');
            $(`#${EmpDetscrId}employerName`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}employerName`, OccupationDtls.employer ?? '')).trigger("onblur");
            $(`#${EmpDetscrId}typbssEmpent`).val(OccupationDtls.typeofbusiness ?? '');
            $(`#${EmpDetscrId}bssEmpAcc`).val(OccupationDtls.employeeActivity ?? '');
            let bussAddrProof = OccupationDtls.businessAddressProof;
            $(`#${EmpDetscrId}bssAddrProof`).val(bussAddrProof ?? '');
            if(!apz.isNull(bussAddrProof) && (bussAddrProof.toLowerCase() !== PleaseSelect.toLowerCase()) && IS_REJECTED_APPLICATION) {
                ApzCOB.addDisableToInput(`${EmpDetscrId}bssAddrProof`);
            }
            let emplProof = OccupationDtls.employmentProof;
            $(`#${EmpDetscrId}empProof`).val(emplProof ?? '');
            if(!apz.isNull(emplProof) && (emplProof.toLowerCase() !== PleaseSelect.toLowerCase()) && IS_REJECTED_APPLICATION) {
                ApzCOB.addDisableToInput(`${EmpDetscrId}empProof`);
            }
            $(`#${EmpDetscrId}bssPerOwn`).val(OccupationDtls.businessPremiseOwnerShip ?? '');
            $(`#${EmpDetscrId}freqOfInc`).val(OccupationDtls.freqOfIncome ?? '');
            apz.app.EmploymentDetails.setAnnualIncomeValue(OccupationDtls.annualIncome);
            $(`#${EmpDetscrId}othSrcInc`).val(!apz.isNull(OccupationDtls.otherSourceIncome) ? OccupationDtls.otherSourceIncome : PleaseSelect);
            $(`#${EmpDetscrId}othSrcAnnInc`).val(OccupationDtls.otherSourceAnnualIncome ?? '');
            $(`#${EmpDetscrId}streetVendor`).val(OccupationDtls.streetVendor === 'Y' ? $(`#${EmpDetscrId}streetVendor_option_Y`).attr("checked", true) : $(`#${EmpDetscrId}streetVendor_option_N`).attr("checked", true));
            let appOccu = ApzCOB.getPayloadDatafromWrapper('occupation', 'Applicant', 'customerDetailsList');
            let coAppOccu = ApzCOB.getPayloadDatafromWrapper('occupation', 'Co-App', 'customerDetailsList');
            if (!apz.isNull(OccupationDtls.occupationTag) && !apz.isNull(appOccu) && !apz.isNull(coAppOccu)) {
                if (OccupationDtls.occupationTag.toLowerCase() === 'yes' && appOccu === coAppOccu) {
                    $(`#${EmpDetscrId}ocuupationTag_option_Yes`).click();
                } else {
                    $(`#${EmpDetscrId}ocuupationTag_option_NO`).click();
                }
                // apz.setElmValue(`${EmpDetscrId}ocuupationTag`, OccupationDtls.occupationTag);
            }
        }
    }
}
//to hide the sub header when all the subheader fields are hidden.
apz.app.EmploymentDetails.hideHeader = function() {
    ApzCOB.hideHeader([{
        'fieldId': [EmpDetscrId + 'professionDiv', EmpDetscrId + 'yrsOfExpDiv', EmpDetscrId + 'employerNameDiv', EmpDetscrId +
            'designationDiv', EmpDetscrId + 'currentBusinessYrsDiv', EmpDetscrId + 'grossIncomeDiv', EmpDetscrId +
            'monthlyTakeHomeDiv',
            EmpDetscrId + 'landlineNoDiv'
        ],
        'headerId': EmpDetscrId + 'OccupationDetailsHeader'
    }])
};
// request creation function
apz.app.EmploymentDetails.createRequest = function(iSave) {
    if (!accisVerified && gApzCOB.currentApplicant == 1 && accvalidationCheck) {
        ApzCOB.fnDisplayMsg("Please verify bank account", "E");
        return;
    }
    // Disability Sts insert
    currCusDtlId = ApzCOB.getCustDetailID(gApzCOB.currentApplicant === 1 ? 'Applicant' : 'Co-App');
    curindex = inSessionStore.customerDetailsList.findIndex(el => el.custDtlId === currCusDtlId);
    if (!checkedValues || checkedValues.length === 0) {
      checkedValues = inSessionStore.customerDetailsList[curindex].payload.disabilityList;
    }
	inSessionStore.customerDetailsList[curindex].payload.isDisabled = apz.getElmValue(EmpDetscrId + "ApplDisaRadio");
	inSessionStore.customerDetailsList[curindex].payload.disabilityList = window.checkedValues;
	inSessionStore.customerDetailsList[curindex].payload.UDID = apz.getElmValue(EmpDetscrId + "UDID_Num");
	inSessionStore.customerDetailsList[curindex].payload.disabilityPercentage = apz.getElmValue(EmpDetscrId + "percentageOfImp"); 
	inSessionStore.customerDetailsList[curindex].payload.disabliltyOtherValue = apz.getElmValue(EmpDetscrId + "others_input_impair");
    var prevJobYears = $('#' + EmpDetscrId + 'prevBusinessYrs').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'prevBusinessYrs').val() +
        " years ";
    var prevJobMon = $('#' + EmpDetscrId + 'prevBusinessMonths').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'prevBusinessMonths').val() +
        " months";
    var currJobYears = $('#' + EmpDetscrId + 'currentBusinessYrs').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'currentBusinessYrs')
    .val() + " years ";
    var currJobMon = $('#' + EmpDetscrId + 'currentBusinessMonths').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'currentBusinessMonths')
        .val() + " months";
    var totalExpYears = $('#' + EmpDetscrId + 'yrsOfExp').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'yrsOfExp').val() + " years ";
    var totalExpMon = $('#' + EmpDetscrId + 'monOfExp').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'monOfExp').val() + " months ";
    var designation = $('#' + EmpDetscrId + 'designation').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'designation').val();
    var occType = $('#' + EmpDetscrId + 'profession').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'profession').val();
    var typeOfBusineeOrEmp = $('#' + EmpDetscrId + 'typbssEmpent').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'typbssEmpent').val();
    var otherSourceIncome = $("#EmpDRE__EmploymentDetails__othSrcInc").val();
    var otherSourceIncomeValue = otherSourceIncome === "Others" ? otherSourceIncome + "|" + $("#" + EmpDetscrId + "otherSrcInc").val() :
        otherSourceIncome;
    var businessAddressPrrof = $('#' + EmpDetscrId + 'bssAddrProof').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'bssAddrProof').val();
    var employmentAddressPrrof = $('#' + EmpDetscrId + 'empProof').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'empProof').val();
    var retirementAge = $('#' + EmpDetscrId + 'retirementAge').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'retirementAge').val();
    var typeOfEmployer = $('#' + EmpDetscrId + 'typeOfEmployer').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'typeOfEmployer').val();
    var custDtlId = gApzCOB.currentApplicant > 1 ? gApzCOB.userDetails.CoApplicantCustomerId : gApzCOB.userDetails.custDtlId;
    var addrSameAs = $('input[name="EmpDRE__EmploymentDetails__officeAddrSameAs_"]:checked').val();
    if (addrSameAs?.toLowerCase() === "present") {
        addrType = 'Personal';
        subAddrType = 'Present';
        businessAddressPrrof = ApzCOB.getPayloadDatafromWrapper('currentAddressProof', custType, 'addressDetailsWrapperList');
        $(`#${EmpDetscrId}bssAddrProof`).val(businessAddressPrrof).change();
    }
    var obj = {
        "occupationDetails": {
            "occptDtlId": gApzCOB.userDetails.occptDtlId,
            "custDtlId": custDtlId,
            "payload": {
                "employer": $('#' + EmpDetscrId + 'employerName').val(),
                "employeeId": "", //$('#' + EmpDetscrId + 'employeeId').val(),
                "occupationType": occType,
                "designation": designation,
                "grossIncome": "", //ApzCOB.fn_unFormatAmount($('#' + EmpDetscrId + 'grossIncome').val()),
                "netTakeHome": "", //ApzCOB.fn_unFormatAmount($('#' + EmpDetscrId + 'monthlyTakeHome').val()),
                "organisationName": $('#' + EmpDetscrId + 'employerName').val(),
                "officePhone": "", //$('#' + EmpDetscrId + 'landlineNo').val(),
                "officeEmail": "", //$('#' + EmpDetscrId + 'companyEmail').val(),
                "employeeSince": currJobYears + currJobMon,
                "experience": totalExpYears + totalExpMon,
                "retirementAge": retirementAge,
                "lastEmployer": $('#' + EmpDetscrId + 'lastEmployerName').val(),
                "previousJobYears": prevJobYears + prevJobMon,
                "typeOfEmployer": typeOfEmployer,
                "natureOfOccupation": occType,
                "addressProof": "",
                "premiseOwnership": "",
                "incomeFrequency": "",
                "totalOtherSourcesAnnualIncome": "",
                "streetVendor": apz.getElmValue(EmpDetscrId + "streetVendor"),
                "modeOfIncome": "",
                "otherIncomeSources": [{
                    "source": '',
                    "annualIncome": ''
                }],
                "typeofbusiness": typeOfBusineeOrEmp,
                "occupationTag": apz.getElmValue(`${EmpDetscrId}ocuupationTag`),
                "employeeActivity": $("#EmpDRE__EmploymentDetails__bssEmpAcc").val(),
                "businessAddressProof": businessAddressPrrof,
                "employmentProof": employmentAddressPrrof,
                "businessPremiseOwnerShip": $("#EmpDRE__EmploymentDetails__bssPerOwn").val(),
                "freqOfIncome": $("#EmpDRE__EmploymentDetails__freqOfInc").val(),
                "annualIncome": $("#EmpDRE__EmploymentDetails__annualIncome").val(),
                "otherSourceIncome": otherSourceIncomeValue,
                "otherSourceAnnualIncome": $("#EmpDRE__EmploymentDetails__othSrcAnnInc").val(),
                "businessEmpStartDate": $("#EmpDRE__EmploymentDetails__busiEmpStartDatInput").val(),
                "businessEmpVintageYear": $("#EmpDRE__EmploymentDetails__busiEmpVintageInput").val(),
            }
        }
    }
    if (gApzCOB.currentApplicant > 1) {
        obj.occupationDetails.occptDtlId = apz.isNull(gApzCOB.userDetails.coAppOccptDtlId) ? "" : gApzCOB.userDetails.coAppOccptDtlId;
    }
    var addressDetObj = {
        "addressDetailsList": [{
            "addressDtlsId": gApzCOB.userDetails.occAddressDtlsId,
            "custDtlId": custDtlId,
            "addressType": "Occupation",
            "payload": {
                // "relatedKey": "occptDtlId",
                //  "relatedValue": gApzCOB.userDetails.occptDtlId,
                "addressList": apz.app.EmploymentDetails.address()
            }
        }]
    }
    if (gApzCOB.currentApplicant > 1) {
        addressDetObj.addressDetailsList[0].addressDtlsId = apz.isNull(gApzCOB.userDetails.CoApOccAddressDtlsId) ? "" : gApzCOB.userDetails
            .CoApOccAddressDtlsId;
    }
    let isBankInfoEdit = $('input[name="' + EmpDetscrId + 'AccDetRadio_"]:checked').val() === "Y" ? "Yes" : "No";
    var bankDetailsObj = {
        "bankDetails": {
            "bankDtlId": gApzCOB.userDetails.bankDtlsId,
            "custDtlId": gApzCOB.userDetails.custDtlId,
            "payload": {
                "accountType": $('#' + EmpDetscrId + 'typeOfAcc').val(),
                "accountName": $('#' + EmpDetscrId + 'accHolderName').val(),
                "ifsc": $('#' + EmpDetscrId + 'ifscCode').val(),
                "bankName": $('#' + EmpDetscrId + 'bankName').val(),
                "branchName": $('#' + EmpDetscrId + 'branchName').val(),
                "accountNumber": $('#' + EmpDetscrId + 'accNumber').val(),
                "accntVerified": window.accIsvalid,
                "longitude": window.storelongitude,
                "latitude": window.storelatitude,
                "uploadedTs": new Date().toISOString(),
                "editBankDetails": isBankInfoEdit
            }
        }
    }
    window.BANK_DETAILS = [];
    window.BANK_DETAILS.push(bankDetailsObj);
    if(gApzCOB.currentApplicant === 1){
    apz.app.EmploymentDetails.onchangecoapplicIns();
    }
    var relnNomi = $('#' + EmpDetscrId + 'relationWithNominee').val() === PleaseSelect ? "" : $('#' + EmpDetscrId + 'relationWithNominee').val();
    let insuredFor = gApzCOB.currentApplicant <= 1 ? "Applicant" : "Co-App";
    var insuranceDetailsObj = {
        "insuranceDetails": {
            "insuranceDtlId": gApzCOB.userDetails.insuranceDtlsId,
            "custDtlId": custDtlId,
            "payload": {
                "insuranceReqd": apz.getElmValue(EmpDetscrId + "ApplInsRadio"),
                "insuredName": insuredFor,
                "nomineeName": $('#' + EmpDetscrId + 'nomineeForInsur').val(),
                "nomineeRelation": relnNomi,
                "nomineeDob": $('#' + EmpDetscrId + 'dobNominee').val(),
                "age": $('#' + EmpDetscrId + 'ageOfNominee').val(),
                "coApplicantInsurance": gApzCOB.userDetails.insurenceReqForCoApp
            }
        }
    }
    if (gApzCOB.currentApplicant > 1 /* && gApzCOB.userDetails.insurenceReqForCoApp === "Yes"*/ ) {
        insuranceDetailsObj.insuranceDetails.insuranceDtlId = apz.isNull(gApzCOB.userDetails.coAppInsuranceDtlsId) ? "" : gApzCOB.userDetails
            .coAppInsuranceDtlsId;
        if (gApzCOB.userDetails.insurenceReqForCoApp !== "Yes") {
            var insPayload = insuranceDetailsObj.insuranceDetails.payload;
            insPayload.insuranceReqd = ''
            insPayload.insuredName = '';
            insPayload.coApplicantInsurance = '';
            insPayload.nomineeName = '';
            insPayload.nomineeRelation = '';
            insPayload.nomineeDob = '';
            insPayload.age = '';
            insPayload.coApplicantInsurance = '';
        }
    }
    window.INSURANCE_DETAILS = [];
    window.INSURANCE_DETAILS.push(insuranceDetailsObj)
    if (iSave === 'captureBefore') {
        window.afterBack.occupationDetailsWrapperList = [];
        window.afterBack.addressDetailsWrapperList = [];
        window.afterBack.occupationDetailsWrapperList.push(obj);
        window.afterBack.addressDetailsWrapperList = [addressDetObj];
        window.EMP_ADDRESS_SAVE = [];
        window.EMP_ADDRESS_SAVE.push(addressDetObj);
        return window.beforeBack;
    }
    if (iSave === 'captureAfter') {
        window.afterBack.occupationDetailsWrapperList = [];
        window.afterBack.addressDetailsWrapperList = [];
        window.afterBack.occupationDetailsWrapperList.push(obj);
        window.afterBack.addressDetailsWrapperList = [addressDetObj];
        window.EMP_ADDRESS_SAVE = [];
        window.EMP_ADDRESS_SAVE.push(addressDetObj);
        return window.afterBack;
    }
    // window.inSessionStore.occupationDetailsWrapperList = [];
    // window.inSessionStore.addressDetailsWrapperList = [];
    // window.inSessionStore.addressDetailsWrapperList = [addressDetObj];
    // window.inSessionStore.occupationDetailsWrapperList.push(obj);
    window.EMP_ADDRESS_SAVE = [];
    window.EMP_ADDRESS_SAVE.push(addressDetObj);
    if (iSave === 'triggerdSave') {
        return window.inSessionStore;
    }
    if (gApzCOB.currentApplicant <= 1) {
        if (!apz.isNull(window.inSessionStore.occupationDetailsWrapperList)) {
            let arrayIndex = window.inSessionStore.occupationDetailsWrapperList.findIndex(occupation => parseInt(occupation.occupationDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));
            if(arrayIndex >= 0){
              window.inSessionStore.occupationDetailsWrapperList[arrayIndex] = obj;  
            } else if(arrayIndex === -1) {
                window.inSessionStore.occupationDetailsWrapperList.push(obj);
            }
        } else {
            window.inSessionStore.occupationDetailsWrapperList = [];
            window.inSessionStore.occupationDetailsWrapperList.push(obj);
        }
    } else {
       let arrayIndex = window.inSessionStore.occupationDetailsWrapperList.findIndex(occupation => parseInt(occupation.occupationDetails.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId));
            if(arrayIndex >= 0){
              window.inSessionStore.occupationDetailsWrapperList[arrayIndex] = obj;  
            } else {
                window.inSessionStore.occupationDetailsWrapperList.push(obj);
            }
    }
    let addressStoreLength = window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList.length;
    let currentAddressRecords = [];
    let currentAddressDtlsId = '';
    let currentAddressIndex = '';
    if (gApzCOB.currentApplicant <= 1) {
    currentAddressRecords = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.filter(addres => addres.addressType === 'Occupation' &&
            parseInt(addres.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));
    } else {
     currentAddressRecords = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.filter(addres => addres.addressType === 'Occupation' &&
            parseInt(addres.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId));   
    }
    if(currentAddressRecords.length > 0){
     currentAddressDtlsId =   currentAddressRecords[0].addressDtlsId;
     currentAddressIndex = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(add => add
        .addressDtlsId === currentAddressDtlsId);
    }
    // var addrDtlsIDApp = (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.filter(addres => addres.addressType === 'Occupation' &&
    //         parseInt(addres.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)).length > 0) ? inSessionStore.addressDetailsWrapperList[0]
    //     .addressDetailsList.filter(addres => addres.addressType === 'Occupation' && parseInt(addres.custDtlId) === parseInt(gApzCOB.userDetails
    //         .custDtlId))[0].addressDtlsId : '';
    // var addrDtlsIDCoApp = (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.filter(addres => addres.addressType === 'Occupation' &&
    //         parseInt(addres.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId)).length > 0) ? inSessionStore
    //     .addressDetailsWrapperList[0].addressDetailsList.filter(addres => addres.addressType === 'Occupation' && parseInt(addres.custDtlId) ===
    //         parseInt(gApzCOB.userDetails.CoApplicantCustomerId))[0].addressDtlsId : ''
    // var addressStoreIndex = addrDtlsIDApp != '' ? inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(add => add
    //     .addressDtlsId === addrDtlsIDApp) : '';
    // var addressStoreIndexCoApp = addrDtlsIDCoApp != '' ? inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(add => add
    //     .addressDtlsId === addrDtlsIDCoApp) : '';
        if (!apz.isNull(window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[currentAddressIndex])) {
            window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[currentAddressIndex].payload = addressDetObj.addressDetailsList[0]
                .payload;
        } else {
            window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList.push(addressDetObj.addressDetailsList[0])
        }
    // insurance
    var insurApp = '',
        insurAppIndex = 0,
        insurCoApp = '',
        insurCoAppIndex = 1;
    if (!apz.isNull(inSessionStore.insuranceDetailsWrapperList)) {
        insurApp = (inSessionStore.insuranceDetailsWrapperList.filter(insur => parseInt(insur.insuranceDetails.custDtlId) === parseInt(gApzCOB
            .userDetails.custDtlId)).length > 0) ? inSessionStore.insuranceDetailsWrapperList.filter(insur => parseInt(insur.insuranceDetails
            .custDtlId) === parseInt(gApzCOB.userDetails.custDtlId))[0].insuranceDetails.insuranceDtlId : '';
        insurAppIndex = insurApp != '' ? inSessionStore.insuranceDetailsWrapperList.findIndex(ins => ins.insuranceDetails.insuranceDtlId ===
            insurApp) : '';
        insurCoApp = (inSessionStore.insuranceDetailsWrapperList.filter(insur => parseInt(insur.insuranceDetails.custDtlId) === parseInt(gApzCOB
            .userDetails.CoApplicantCustomerId)).length > 0) ? inSessionStore.insuranceDetailsWrapperList.filter(insur => parseInt(insur
            .insuranceDetails.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId))[0].insuranceDetails.insuranceDtlId : '';
        insurCoAppIndex = insurCoApp != '' ? inSessionStore.insuranceDetailsWrapperList.findIndex(ins => ins.insuranceDetails.insuranceDtlId ===
            insurCoApp) : '';
    }
    if (gApzCOB.currentApplicant <= 1) {
        if (!apz.isNull(window.inSessionStore.insuranceDetailsWrapperList)) {
            if (!apz.isNull(window.inSessionStore.insuranceDetailsWrapperList[insurAppIndex])) {
                window.inSessionStore.insuranceDetailsWrapperList[insurAppIndex].insuranceDetails.payload = insuranceDetailsObj.insuranceDetails
                    .payload;
            }
        } else {
            window.inSessionStore.insuranceDetailsWrapperList = [];
            window.inSessionStore.insuranceDetailsWrapperList.push(insuranceDetailsObj);
        }
    } else if (gApzCOB.currentApplicant > 1 /*&& inSessionStore.insuranceDetailsWrapperList[insurAppIndex].insuranceDetails.payload.insuranceReqd === "Y"*/) {
        if (window.inSessionStore.insuranceDetailsWrapperList.length === gApzCOB.currentApplicant) {
            if (!apz.isNull(window.inSessionStore.insuranceDetailsWrapperList[insurCoAppIndex])) {
                window.inSessionStore.insuranceDetailsWrapperList[insurCoAppIndex].insuranceDetails.payload = insuranceDetailsObj.insuranceDetails
                    .payload;
            }
        } else {
            window.inSessionStore.insuranceDetailsWrapperList.push(insuranceDetailsObj);
        }
    }
    // if (gApzCOB.currentApplicant <= 1) {
    //     if (!apz.isNull(window.inSessionStore.insuranceDetailsWrapperList)) {
    //         window.inSessionStore.insuranceDetailsWrapperList[gApzCOB.currentApplicant - 1] = insuranceDetailsObj;
    //     } else {
    //         window.inSessionStore.insuranceDetailsWrapperList = [];
    //         window.inSessionStore.insuranceDetailsWrapperList = [addressDetObj];
    //     }
    // } else {
    //     window.inSessionStore.insuranceDetailsWrapperList[gApzCOB.currentApplicant - 1] = insuranceDetailsObj;
    // }
    apz.app.EmploymentDetails.removeExpMand();
    gApzCOB["requestNodes"]['occupationDetailsWrapperList'] = [];
    window.EMP_ADDRESS = [];
    window.EMP_ADDRESS.push(addressDetObj);
    if (!window.pendingApplication) {
        gApzCOB.requestNodes['addressDetailsWrapperList'] = [];
    }
    gApzCOB["requestNodes"]['insuranceDetailsWrapperList'] = [];
    gApzCOB["requestNodes"]['bankDetailsWrapperList'] = [];
    window.inSessionStore.bankDetailsWrapperList = window.BANK_DETAILS;
    gApzCOB["requestNodes"]['insuranceDetailsWrapperList'] = window.INSURANCE_DETAILS;
    gApzCOB["requestNodes"]['bankDetailsWrapperList'] = window.BANK_DETAILS;
    gApzCOB["requestNodes"]['addressDetailsWrapperList'] = window.EMP_ADDRESS;
    gApzCOB["requestNodes"]['occupationDetailsWrapperList'].push(obj);
    if (apz.isNull(gApzCOB["requestNodes"]['applicationDocumentsWrapperList']) || gApzCOB["requestNodes"]['applicationDocumentsWrapperList']
        .length === 0) {
        var lobj = {};
        lobj["applicationDocumentsList"] = []
        gApzCOB["requestNodes"]['applicationDocumentsWrapperList'] = [];
        var lobj = {};
        lobj["applicationDocumentsList"] = []
        inSessionStore.applicationDocumentsWrapperList = [];
        inSessionStore.applicationDocumentsWrapperList.push(lobj)
    } else {
        if (!apz.isNull(gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList)) {
            if (gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList.length > 0) {
                gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList = gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList.filter(bankDocs => bankDocs.payload.screenId !== "EmploymentDetails")
            }
        }
    }
    if (BANK_DETAILS_EDIT_OPTION) {
        apz.app.EmploymentDetails.createBankDocRequest();
    }
    return gApzCOB["requestNodes"];
}
apz.app.EmploymentDetails.createBankDocRequest = function() {
    var lobj = {};
    lobj["applicationDocumentsList"] = []
    let bankDoc = bankdocProofObj.BankProof[0];
    var obj = {
        "appId": gAppId,
        "documentId": bankDoc.appDocId,
        "appDocId": bankDoc.appDocId,
        "applicationId": gApzCOB.userDetails.applicationId,
        "custDtlId": gApzCOB.userDetails.custDtlId,
        "payload": {
            "docSide": "Front",
            "documentFileName": bankDoc.filename,
            "documentFormat": bankDoc.filetype,
            "documentType": "Bank Passbook",
            "documentName": "Bank Passbook",
            "documentDesc": "",
            "documentLoc": bankDoc.filelocation,
            "screenId": "EmploymentDetails",
            "issueDate": "",
            "expiryDate": "",
            "docStatus": "A",
            "latitude": localFileObj.latitude,
            "longitude": localFileObj.longitude,
            "uploadedTs" :  new Date().toISOString(),
            "docCategory": "Bank Account Proof"
        }
    }
    if (apz.isNull(gApzCOB["requestNodes"]['applicationDocumentsWrapperList']) || gApzCOB["requestNodes"]['applicationDocumentsWrapperList']
        .length === 0) {
        lobj["applicationDocumentsList"].push(obj);
        gApzCOB["requestNodes"]['applicationDocumentsWrapperList'].push(lobj);
    } else {
        if (!apz.isNull(obj)) {
            gApzCOB["requestNodes"]['applicationDocumentsWrapperList'][0].applicationDocumentsList.push(obj)
        }
    }
    if(!apz.isNull(inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList)){
        inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = [...gApzCOB["requestNodes"]['applicationDocumentsWrapperList'][0].applicationDocumentsList]
    }
    return gApzCOB['requestNodes'];
}
apz.app.EmploymentDetails.ageCalculator = function() {
    var a = {
        'val': $('#' + EmpDetscrId + 'dobNominee').val(),
        'fromFormat': 'dd/MM/yyyy',
        'toFormat': 'dd-MM-yyyy'
    }
    var dobVal = apz.formatDate(a);
    dobVal = dobVal.split("-").reverse().join('').replaceAll("-", '');
    var year = Number(dobVal.substr(0, 4));
    var month = Number(dobVal.substr(4, 2)) - 1;
    var day = Number(dobVal.substr(6, 2));
    var today = new Date();
    var age = today.getFullYear() - year;
    var ageCount = ApzCOB.getAge($('#' + EmpDetscrId + 'dobNominee').val());
    if (ageCount > 0) {
    if (today.getMonth() < month || (today.getMonth() === month && today.getDate() < day)) {
        age--;
    }
    if (age === -1) {
        $('#' + EmpDetscrId + 'ageOfNominee').val(age + 1).change();
    } else {
        $('#' + EmpDetscrId + 'ageOfNominee').val(age).change();
    }
    $('#' + EmpDetscrId + 'ageOfNominee').removeClass('err');
    } else {
        ApzCOB.fnDisplayMsg('Please select valid dob', "E");
        $('#' + EmpDetscrId + 'dobNominee').val('');
        $('#' + EmpDetscrId + 'dobNominee').addClass('err');
        $('#' + EmpDetscrId + 'ageOfNominee').val('');
        $('#' + EmpDetscrId + 'ageOfNominee').addClass('err');
    }
}
apz.app.EmploymentDetails.validateMonths = function() {
    var isValid = true;
    if (parseInt($('#' + EmpDetscrId + 'monOfExp').val()) > 11) {
        isValid = false;
        $('#' + EmpDetscrId + 'monOfExp').val(PleaseSelect);
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EMPDTLS_MSG_MONTHERR"), "I");
    }
    return isValid;
}
apz.app.EmploymentDetails.address = function() {
    var addressArr = [];
    let addrSameAs = $('input[name="EmpDRE__EmploymentDetails__officeAddrSameAs_"]:checked').val();
    var empAddress = {
        "addressType": "Office",
        "addressSameAs": addrSameAs || '',
        "state": $('#' + EmpDetscrId + 'state').val(),
        "city": $('#' + EmpDetscrId + 'city').val(),
        "country": $('#' + EmpDetscrId + 'country').val(), //NR
        "pinCode": $('#' + EmpDetscrId + 'pin').val(),
        "addressLine1": $('#' + EmpDetscrId + 'addressLine1').val(),
        "addressLine2": $('#' + EmpDetscrId + 'addressLine2').val(),
        "addressLine3": $('#' + EmpDetscrId + 'addressLine3').val(),
        "district": $('#' + EmpDetscrId + 'district').val(),
        "nameAsperAddressProof": $('#' + EmpDetscrId + 'nameAsperAddr').val(),
        "dobAsperAddressProof": $('#' + EmpDetscrId + 'dob').val(),
        "residenceOwnership": "",
        "residenceAddressSince": "",
        "residenceCitySince": "",
        "landMark": $("#EmpDRE__EmploymentDetails__el_inp_2").val(),
        "area": $("#EmpDRE__EmploymentDetails__el_inp_3").val(),
        "locateCoOrdinatesFor": addrSameAs || '',
        "locateCoOrdinates": $('#' + coOrdinateInputTag).val()
    }
    addressArr.push(empAddress);
    return addressArr;
}
apz.app.EmploymentDetails.removeExpMand = function() {
    var isValid = false;
    if (!apz.isNull($('#' + EmpDetscrId + 'monOfExp').val()) || !apz.isNull($('#' + EmpDetscrId + 'yrsOfExp').val())) {
        isValid = true;
        $('#' + EmpDetscrId + 'yrsOfExp').removeClass('err');
        $('#' + EmpDetscrId + 'monOfExp').removeClass('err');
    }
    return isValid;
}
apz.app.EmploymentDetails.removeExpMandErr = function() {
    $('#' + EmpDetscrId + 'yrsOfExp').removeClass('err');
    $('#' + EmpDetscrId + 'monOfExp').removeClass('err');
}
