        } else {
            bankDetFLag = true;
            ['disbUp', 'insurUp', 'bankDown', 'occupUp', 'officeUp'].hide();
            ['disbDown', 'insurDown', 'bankUp', 'occupDown', 'officeDown'].show();
            $(disabDetId).addClass("sno");
            $(insDetId).addClass("sno");
            $(bankDetId).removeClass("sno");
            $(occDetId).addClass("sno");
            $(offAddrId).addClass("sno");
            $(`#${EmpDetscrId}gr_row_2`).removeClass('active');
            $(`#${EmpDetscrId}gr_row_30`).removeClass('active');
            $(`#${EmpDetscrId}gr_row_5`).addClass('active');
            $(`#${EmpDetscrId}gr_row_8`).removeClass('active');
            $(`#${EmpDetscrId}gr_row_11`).removeClass('active');
            $(`#${EmpDetscrId}insurSuccess_ul`).removeClass("sno");
            $(`#${EmpDetscrId}disabSuccess_ul`).removeClass("sno");
        }
        apz.app.EmploymentDetails.continueBtn();
        let toggleDivID = pthis.id;
        let toggleEventListIndex = window.toggleEvents.findIndex((item) => item.toggleID === pthis.id);
        ApzCOB.addEventToNextToggle(toggleEventListIndex);
    }
}
apz.app.EmploymentDetails.onclickoccup = function(pthis) {
    var formValidate;
    if (gApzCOB.currentApplicant <= 1) {
        //let checkkmVerified = $("#" + EmpDetscrId + "accountVerified").is(":visible");
        if (apz.childScr === "EmploymentDetails" && gApzCOB.currentApplicant == 1 && accIsvalid !== 'Verified') {
            ApzCOB.fnDisplayMsg("Please verify bank account number!", "E");
            formValidate = false;
            return;
        }
        formValidate = ApzCOB.fnformValidator(EmpDetscrId, 'ct_frm_2');
    } else {
        let isCoAppInsRequired = true;
        let applicantInsData = inSessionStore.insuranceDetailsWrapperList.filter(ins => parseInt(ins.insuranceDetails.custDtlId) === parseInt(
            gApzCOB.userDetails.custDtlId));
        if (applicantInsData.length > 0) {
            let coAppInsOption = applicantInsData[0].insuranceDetails.payload.coApplicantInsurance;
            isCoAppInsRequired = coAppInsOption === "Yes" ? true : false;
        }
        if (isCoAppInsRequired) {
            formValidate = ApzCOB.fnformValidator(EmpDetscrId, 'insurDetFieldsForm');
        } else {
            formValidate = true;
        }
    }
    if ($(`#${EmpDetscrId}ApplDisaRadio_option_N`).is(':checked') || $(`#${EmpDetscrId}ApplDisaRadio_option_Y`).is(':checked')) {
        $(`#${EmpDetscrId}disability_err_div`).addClass("sno");
        if ($(`#${EmpDetscrId}ApplDisaRadio_option_Y`).is(':checked')) {
            checkedValues = [];
            for (let i = 1; i <= 7; i++) {
                let id = EmpDetscrId + 'el_cbx_' + i;
                let cb = document.getElementById(id);
                if (cb) { // check if element exists
                    if (cb.checked) {
                        checkedValues.push(cb.getAttribute('checkedval'));
                    }
                }
            }
            if (checkedValues.length >= 1) {
                $(`#${EmpDetscrId}disabilityImparirment_err_div`).addClass("sno");
                if (($(`#${EmpDetscrId}UDID_Num`).val()).length != 18) {
                    $(`#${EmpDetscrId}UDID_err_row`).removeClass("sno");
                    return false;
                } else {
                    $(`#${EmpDetscrId}UDID_err_row`).addClass("sno");
                }
                if ($(`#${EmpDetscrId}percentageOfImp`).val() > 100 || $(`#${EmpDetscrId}percentageOfImp`).val().length == 0) {
                    $(`#${EmpDetscrId}percent_ERR_row`).removeClass("sno");
                    return false;
                } else {
                    $(`#${EmpDetscrId}percent_ERR_row`).addClass("sno");
                }
                if (checkedValues.includes('Others')) {
                    if (($(`#${EmpDetscrId}others_input_impair`).text()).length < 2) {
                        $(`#${EmpDetscrId}other_type_impair_errdiv`).removeClass("sno");
                        return false;
                    } else {
                        $(`#${EmpDetscrId}other_type_impair_errdiv`).addClass("sno");
                    }
                }
            } else {
                $(`#${EmpDetscrId}disabilityImparirment_err_div`).removeClass("sno");
                return false;
            }
        }
    } else {
        $(`#${EmpDetscrId}disability_err_div`).removeClass("sno");
        return false;
    }
    var bankPassbookValidate = apz.app.EmploymentDetails.checkBankDocUploaded();
    if (formValidate && bankPassbookValidate) {
        if ($(occDetId).is(":visible")) {
            $(occDetId).addClass("sno");
            $(`#${EmpDetscrId}gr_row_8`).removeClass('active');
            ['disbUp', 'insurUp', 'bankUp', 'occupDown', 'officeUp'].show();
            ['disbDown', 'insurDown', 'bankDown', 'occupUp', 'officeDown'].hide();
        } else {
            occDetFlag = true;
            ['disbUp', 'insurUp', 'bankUp', 'occupDown', 'officeUp'].hide();
            ['disbDown', 'insurDown', 'bankDown', 'occupUp', 'officeDown'].show();
            $(disabDetId).addClass("sno");
            $(insDetId).addClass("sno");
            $(bankDetId).addClass("sno");
            $(occDetId).removeClass("sno");
            $(offAddrId).addClass("sno");
            $(`#${EmpDetscrId}gr_row_30`).removeClass('active');
            $(`#${EmpDetscrId}gr_row_2`).removeClass('active');
            $(`#${EmpDetscrId}gr_row_5`).removeClass('active');
            $(`#${EmpDetscrId}gr_row_8`).addClass('active');
            $(`#${EmpDetscrId}gr_row_11`).removeClass('active');
            $(`#${EmpDetscrId}insurSuccess_ul`).removeClass("sno");
            $(`#${EmpDetscrId}bankSuccess_ul`).removeClass("sno");
            $(`#${EmpDetscrId}disabSuccess_ul`).removeClass("sno");
        }
        //apz.app.EmploymentDetails.continueBtn();
        let toggleDivID = pthis.id;
        let toggleEventListIndex = window.toggleEvents.findIndex((item) => item.toggleID === pthis.id);
        ApzCOB.addEventToNextToggle(toggleEventListIndex);
    }
}
apz.app.EmploymentDetails.checkBankDocUploaded = function() {
    let isValid = false;
    if (BANK_DETAILS_EDIT_OPTION) {
        if (!apz.isNull(bankdocProofObj.BankProof)) {
            if (bankdocProofObj.BankProof.length > 0) {
                isValid = true;
            }
        }
    } else {
        isValid = true;
    }
    if (!isValid) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EMPDTLS_TXT_UPLOAD_BANK_PASSOOK"), "E");
        return isValid;
    }
    if (accisVerified) {
        isValid = true;
    } else {
        if (gApzCOB.currentApplicant == 1) {
            isValid = false;
            ApzCOB.fnDisplayMsg("Please verify bank account", "E");
        } else {
            isValid = true;
        }
    }
    return isValid;
}
