    //     $('#' + EmpDetscrId + 'empProofRow').removeClass('sno');
    // } else {
    //     $('#' + EmpDetscrId + 'empProofRow').addClass('sno');
    // }
    // if (accType == 'Self Employed') {
    //     $('#' + EmpDetscrId + 'bssPerOwnRow').removeClass('sno');
    //     $('#' + EmpDetscrId + 'streetVendorDiv').removeClass('sno');
    // } else {
    //     $('#' + EmpDetscrId + 'bssPerOwnRow').addClass('sno');
    //     $('#' + EmpDetscrId + 'streetVendorDiv').addClass('sno');
    // }
    if (accType === "Homemaker") {
        ['gr_row_8', 'gr_row_11'].hide();
        occDetFlag = true;
        offAddrFlag = true;
    } else if (accType === "Wage earner") {
        ['gr_row_8'].show();
        ['gr_row_11'].hide();
    occDetFlag = offAddrFlag = true;
    } else {
        ['gr_row_8', 'gr_row_11'].show();
        occDetFlag = offAddrFlag = false;
    }
    let mandatoryFieldArray = [];
    if (accType !== "Homemaker") {
        mandatoryFieldArray = $('#' + EmpDetscrId + 'occupDetFieldsForm').find('.allOcc input');
        if (accType === "Salaried") {
            let salariedArray = $('#' + EmpDetscrId + 'occupDetFieldsForm').find('.salaried input');
            mandatoryFieldArray = [...mandatoryFieldArray, ...salariedArray];
        } else if (accType === "Self Employed") {
            let selfEmpArray = $('#' + EmpDetscrId + 'occupDetFieldsForm').find('.selfEmp input');
            mandatoryFieldArray = [...mandatoryFieldArray, ...selfEmpArray];
        } else {
            mandatoryFieldArray = [...mandatoryFieldArray];
        }
    }
    if (mandatoryFieldArray.length > 0) {
        let mandatoryInputIds = mandatoryFieldArray.map((elem) => elem.id);
        ApzCOB.addFieldMandatory(mandatoryInputIds);
    }
    upDocsData = ApzCOB.GetCommonCodes("UPLOADDOCS", "CASA")["UPLOADDOCS"];
    upDocsData["TYPES"].forEach(function(el) {
        if (el.split('~')[1] === "Y") {
            gAllowedFileTypes[el.split('~')[0]] = el.split('~')[0].toLocaleLowerCase();
        }
    });
    // $(`#${EmpDetscrId}ApplInsRadio_option_N`).attr("checked", true);
    // $(`#${EmpDetscrId}ApplInsRadio_option_N`).trigger('onchange');
    InsurHideShow.hide();
    //DisabilityHideShow.hide();
    $(`#${EmpDetscrId}ct_frm_2`).find('.ett-inpt').attr("disabled", true);
    $(`#${EmpDetscrId}AccDetRadio_option_N`).attr("checked", true);
    $(`#${EmpDetscrId}uploadDocRow`).addClass("sno"); //hide UploadRow
    /*temporary for Field validation*/
    //$(`#${EmpDetscrId}ifscCode`).val("CITI0000004").trigger("onblur");
    // $(`#${EmpDetscrId}accNumber`).val('987654321098765');
    // $(`#${EmpDetscrId}pin`).attr('onblur', 'apz.app.EmploymentDetails.onchangepincode(this)');
    /*temporary for Field validation*/
    const id = ["el_inp_3", "city", "district", "state", "country", "typeOfAcc"]
    id.forEach(function(val) {
        $('#' + EmpDetscrId + val).prop('disabled', true);
    })
    if (gApzCOB.currentApplicant > 1) {
        $(`#${EmpDetscrId}el_inp_3`).attr('disabled', false);
        $(`#${EmpDetscrId}ApplInsRadioRow`).addClass("sno");
        var data = window.inSessionStore.insuranceDetailsWrapperList;
        var radioBtn;
        //radioBtn = window.inSessionStore.insuranceDetailsWrapperList[0].insuranceDetails.payload.coApplicantInsurance;
        data.forEach(function(i, k) {
            if (parseInt(data[k].insuranceDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                radioBtn = window.inSessionStore.insuranceDetailsWrapperList[k].insuranceDetails.payload.coApplicantInsurance
                return;
            }
        })
        if (radioBtn === 'Y' || radioBtn === 'Yes') {
            InsurHideShow.show();
        }
        if (radioBtn === 'No' || radioBtn === 'N') {
            $(`#${EmpDetscrId}gr_row_2`).addClass("sno");
            occDetFlag = true;
            $(occDetId).removeClass('sno');
            $(`#${EmpDetscrId}gr_row_8`).addClass('active');
        }
        //['ocuupationTagDiv'].show();
        var occupation1, occupation2;
        inSessionStore.customerDetailsList.forEach(function(el, index) {
            if (el.customerType === "Applicant") {
                occupation1 = el.payload.occupation
                return
            }
            if (el.customerType === "Co-App") {
                occupation2 = el.payload.occupation
                return
            }
        })
        if (occupation1 === occupation2) {
            ['ocuupationTagDiv'].show();
        }
    }
    let insRadio = "";
    var ApplData = "";
    if (!apz.isNull(window.inSessionStore.insuranceDetailsWrapperList)) {
        // insRadio = window.inSessionStore.insuranceDetailsWrapperList[0].insuranceDetails.payload.insuranceReqd
        ApplData = window.inSessionStore.insuranceDetailsWrapperList.filter(custdata => custdata.insuranceDetails.custDtlId === gApzCOB.userDetails.custDtlId);
        if (!apz.isNull(ApplData)) {
            insRadio = ApplData[0].insuranceDetails.payload.insuranceReqd;
        }
    }
    var coAppIns = "#EmpDRE__EmploymentDetails__coAppInsuranceRadio input[name='EmpDRE__EmploymentDetails__coAppInsuranceRadio_']";
    if (!apz.isNull(insRadio)) {
        if (insRadio === 'Y') {
            $(coAppIns).attr('disabled', false);
            InsurHideShow.show();
        } else {
            $("#" + EmpDetscrId + "coAppInsuranceRadio_option_N").attr("checked", true);
            $(coAppIns).attr('disabled', true);
        }
        $(`#${EmpDetscrId}ApplInsRadio_option_` + insRadio).attr("checked", true).change();
    } else {
        $(`#${EmpDetscrId}ApplInsRadio_option_Y`).attr("checked", true).change();
        InsurHideShow.show();
        $(`#${EmpDetscrId}coAppInsuranceRadio_option_Y`).attr("checked", true);
    }
    if (gApzCOB.currentApplicant <= 1) {
        apz.app.EmploymentDetails.paintBankDetails();
        apz.app.EmploymentDetails.onchangecoapplicIns();
       /* if (isRejectedInKMSourcing && !accisVerified) {
            inSessionStore.bankDetailsWrapperList[0].bankDetails.payload.accntVerified = "";
            // $("#APZCBO__BaseScreens__continue").attr("disabled", true);
            // $("#APZCBO__BaseScreens__continue").addClass("disabled");
            ApzCOB.addDisableToInput('APZCBO__BaseScreens__continue');
            accisVerified = false;
        }*/
        if (accisVerified && !isRPC) {
            $("#" + EmpDetscrId + "verifyAccount").addClass("sno");
            $("#" + EmpDetscrId + "accountVerified_ul").removeClass("sno");
        }
    }
    ApzCOB.getToggleOnClickEventObj(EmpDetscrId);
    $('#' + BaseScrId + 'custIDandName').removeClass('sno');
    if (gApzCOB.currentApplicant <= 1) {
        apz.app.EmploymentDetails.checkBankDocument();
    }
    if (isRevAndConfEdit) {
        ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], true);
        // $('#APZCBO__BaseScreens__continue').attr('disabled', true);
        ApzCOB.addDisableToInput('APZCBO__BaseScreens__continue');
        ApzCOB.addDisableToInput(`${EmpDetscrId}bssAddrProof`);
        ApzCOB.addDisableToInput(`${EmpDetscrId}empProof`);
    }
    if (PUSHBACK_QUERY_STATUS.includes(gApzCOB.userDetails.applicationStatus)) {
        ApzCOB.paintingSourcingQuery();
    }
    $('input.hasDatepicker').each(function(index, element) {
        $(element).prop('disabled', true);
    })
    if(!reIntiatedAcc){
    apz.app.EmploymentDetails.rejectedintiatedAcc();
    }
    apz.app.EmploymentDetails.bankvalidationStatus();
    if (IS_REINITIATE_APPLICATION && accntStatus !== 'Verified') {
        accisVerified = false;
        $("#" + EmpDetscrId + "verifyAccount").removeClass("sno");
        $("#" + EmpDetscrId + "accountVerified_ul").addClass("sno");
    }
    if (gApzCOB.currentApplicant == 1) {
        if (accisVerified) {
            // $('#APZCBO__BaseScreens__continue').attr('disabled', false);
            // $("#APZCBO__BaseScreens__continue").removeClass("disabled");
            ApzCOB.removeDisableToInput('APZCBO__BaseScreens__continue');
        } else {
            // $("#APZCBO__BaseScreens__continue").attr("disabled", true);
            // $("#APZCBO__BaseScreens__continue").addClass("disabled");
            ApzCOB.addDisableToInput('APZCBO__BaseScreens__continue');
        }
    }
    $('#' + EmpDetscrId + 'bankDetForm').attr('onclick', 'apz.app.EmploymentDetails.onclickbank(this)');
    $('#' + EmpDetscrId + 'occupDetForm').attr('onclick', 'apz.app.EmploymentDetails.onclickoccup(this)');
    $('#' + EmpDetscrId + 'officeAddressForm').attr('onclick', 'apz.app.EmploymentDetails.onclickoffAddr(this)');
    ApzCOB.removeFieldMandatory(EmpDetscrId + 'accHolderName');
    ApzCOB.removeFieldMandatory(EmpDetscrId + 'bankName');
    ApzCOB.removeFieldMandatory(EmpDetscrId + 'branchName');
}
apz.app.EmploymentDetails.rejectedintiatedAcc = function(){
    if (isRejectedInKMSourcing && !rejectverifiedflag) {
        // Fetch payload safely
        window.checkAccdata = inSessionStore?.bankDetailsWrapperList?.[0]?.bankDetails?.payload;
        // Determine verification status
        if (checkAccdata?.accntVerified === "Verified") {
          accisVerified = false;
        } else {
          accisVerified = true;
        }
        // UI logic based on verification + reject flag
        if (!accisVerified && !rejectverifiedflag) {
            if (checkAccdata) {
                checkAccdata.accntVerified = "";
            }
            ApzCOB.addDisableToInput('APZCBO__BaseScreens__continue');
            $("#" + EmpDetscrId + "verifyAccount").removeClass("sno");
            $("#" + EmpDetscrId + "accountVerified_ul").addClass("sno");
            $("#" + EmpDetscrId + "invaildAccount_ul").addClass("sno");
            window.rejectverifiedflag = false;
        } else if (accisVerified && rejectverifiedflag) {
            window.reIntiatedAcc = true;
            window.rejectverifiedflag = true;
            $("#" + EmpDetscrId + "accountVerified_ul").removeClass("sno");
            $("#" + EmpDetscrId + "verifyAccount").addClass("sno");
            $("#" + EmpDetscrId + "invaildAccount_ul").addClass("sno");
        }
    }
}
apz.app.EmploymentDetails.bankvalidationStatus = function() {
    if (!apz.isNull(inSessionStore.bankDetailsWrapperList)) {
        window.accntStatus = inSessionStore?.bankDetailsWrapperList?.[0]?.bankDetails?.payload.accntVerified;
        if (accntStatus == 'Verified') {
            accisVerified = true;
            $("#" + EmpDetscrId + "verifyAccount").addClass("sno");
            $("#" + EmpDetscrId + "accountVerified_ul").removeClass("sno");
        } else {
            accisVerified = false;
            $("#" + EmpDetscrId + "verifyAccount").removeClass("sno");
            $("#" + EmpDetscrId + "accountVerified_ul").addClass("sno");
        }
    }
}
apz.app.EmploymentDetails.isReinitiateCase = function() {
    let timeline = inSessionStore.applicationTimelineDtl;
    window.isRejectedInKMSourcing = false;
    // loop through array
    $.each(timeline, function(i, item) {
        if (item.actionTaken === "Initiated By" && item.stage === "KM Sourcing") {
            // check if any later record has Rejected By with empty stage
            for (var j = i + 1; j < timeline.length; j++) {
                var next = timeline[j];
                if (next.actionTaken === "Rejected By" && (next.stage === "" || next.stage == null)) {
                    isRejectedInKMSourcing = true;
                    return false; // break both loops
                }
            }
        }
        if (isRejectedInKMSourcing) return false; // break outer loop
    });
}
apz.app.EmploymentDetails.populateData = function() {
    var data = [];
    data = inSessionStore.customerDetailsList.filter(cust => cust.customerType === (gApzCOB.currentApplicant <= 1 ? "Co-App" : "Applicant"));
    if (data.length > 0) {
        currCusDtlId = ApzCOB.getCustDetailID(gApzCOB.currentApplicant === 1 ? 'Applicant' : 'Co-App');
        curindex = inSessionStore.customerDetailsList.findIndex(el => el.custDtlId === currCusDtlId);
        var payloaddata = inSessionStore.customerDetailsList[curindex].payload;
        if (payloaddata.UDID && payloaddata.UDID.trim() !== "") {
            var disaSts = inSessionStore.customerDetailsList[curindex].payload.isDisabled;
            apz.setElmValue(EmpDetscrId + "ApplDisaRadio", disaSts);
            apz.setElmValue(EmpDetscrId + "UDID_Num", inSessionStore.customerDetailsList[curindex].payload.UDID);
            apz.setElmValue(EmpDetscrId + "percentageOfImp", inSessionStore.customerDetailsList[curindex].payload.disabilityPercentage);
            apz.setElmValue(EmpDetscrId + "others_input_impair", inSessionStore.customerDetailsList[curindex].payload.disabliltyOtherValue);
            var selectedList = inSessionStore.customerDetailsList[curindex].payload.disabilityList;
            if (disaSts == 'Y' || disaSts == 'Yes') {
                DisabilityHideShow.show();
                $('input[type="checkbox"]').each(function() {
                    var chkVal = $(this).attr('checkedval'); // read the custom attribute
                    if (selectedList.includes(chkVal)) {
                        $(this).prop('checked', true); // check it
                    } else {
                        $(this).prop('checked', false); // uncheck it
                    }
                });
            } else {
                DisabilityHideShow.hide();
            }
        } else {
            var disaSts = inSessionStore.customerDetailsList[curindex].payload.isDisabled;
            apz.setElmValue(EmpDetscrId + "ApplDisaRadio", disaSts);
            DisabilityHideShow.hide();
        }
        //$(`#${EmpDetscrId}nomineeForInsur`).val(data[0].customerName ?? '');
        $(`#${EmpDetscrId}nomineeForInsur`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}nomineeForInsur`, data[0].customerName ?? '')).trigger("onblur");
        $(`#${EmpDetscrId}dobNominee`).val(new Date(data[0].payload.dob ?? '').$format('d/m/Y')).change();
        if (gApzCOB.currentApplicant <= 1) {
            $(`#${EmpDetscrId}relationWithNominee`).val(data[0].payload.relationShipWithApplicant ?? PleaseSelect);
        } else {
            $(`#${EmpDetscrId}relationWithNominee`).val(PleaseSelect);
        }
    } else {
        DisabilityHideShow.hide();
    }
}
apz.app.EmploymentDetails.paintBankDetails = function() {
    if (!apz.isNull(window.inSessionStore.bankDetailsWrapperList) && !apz.isNull(window.inSessionStore.bankDetailsWrapperList.length > 0)) {
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        let bankData = window.inSessionStore.bankDetailsWrapperList[currIndex]?.bankDetails;
        let bankDataEditOption = bankData.payload.editBankDetails === "Yes" ? "Y" : "N";
        $("#" + EmpDetscrId + "AccDetRadio_option_" + bankDataEditOption).attr("checked", true);
        apz.app.EmploymentDetails.onChangeAccDetRadio()
    }
}
apz.app.EmploymentDetails.onShownPaintDetails = function() {
    var EmpDtls = gApzCOB.selLeadDtls;
    var insuredName = EmpDtls.nameAsPerBankAcc;
    if (gApzCOB.currentApplicant <= 1) {
        $(`#${EmpDetscrId}insuranceFor`).val("Applicant").attr("disabled", true);
    } else {
        $(`#${EmpDetscrId}insuranceFor`).val("Co-Applicant").attr("disabled", true);
    }
    $(`#${EmpDetscrId}accHolderName`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}accHolderName`, insuredName));
    $(`#${EmpDetscrId}typeOfAcc`).val(EmpDtls.typeOfAcc);
    $(`#${EmpDetscrId}ifscCode`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}ifscCode`, EmpDtls.ifscCode));
    $(`#${EmpDetscrId}accNumber`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}accNumber`, EmpDtls.accNumber));
    $(`#${EmpDetscrId}bankName`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}bankName`, EmpDtls.bankName));
    $(`#${EmpDetscrId}branchName`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}branchName`, EmpDtls.branchName));
}
apz.app.EmploymentDetails.hideAndShowBankDetailsSec = function() {
    if (gApzCOB.currentApplicant > 1) {
        bankDetFLag = true;
        $(bankDetId).addClass("sno");
        $('#EmpDRE__EmploymentDetails__gr_row_5').removeClass('active');
        $('#EmpDRE__EmploymentDetails__gr_row_5').addClass('sno');
        if (gApzCOB.userDetails.insurenceReqForCoApp !== 'Yes') {
            insLoanFlag = true;
            $(insDetId).addClass("sno");
            $('#EmpDRE__EmploymentDetails__gr_row_2').removeClass('active');
            $('#EmpDRE__EmploymentDetails__gr_row_2').addClass('sno');
        }
    }
}
//to set value to global variable on click of toggle nominee
apz.app.EmploymentDetails.toggleNomineeAdd = function() {
    if ($("#EmpDRE__EmploymentDetails__wsh_nominee").is(":checked") === true) {
        addNomineeDetails = 'Y'
    } else {
        addNomineeDetails = 'N'
    }
}
