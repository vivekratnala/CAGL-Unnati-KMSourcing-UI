    //     $('#' + EmpDetscrId + 'annualIncomeRow').addClass('sno');
    //     $('#' + EmpDetscrId + 'othSrcIncRow').addClass('sno');
    // } else {
    //     $('#' + EmpDetscrId + 'typBssEmpentRow').removeClass('sno');
    //     $('#' + EmpDetscrId + 'bssEmpAcctRow').removeClass('sno');
    //     $('#' + EmpDetscrId + 'bssAddrProofRow').removeClass('sno');
    //     $('#' + EmpDetscrId + 'freqOfIncRow').removeClass('sno');
    //     $('#' + EmpDetscrId + 'annualIncomeRow').removeClass('sno');
    //     $('#' + EmpDetscrId + 'othSrcIncRow').removeClass('sno');
    // }
