apz.app.EmploymentDetails.onchangeApplicIns = function() {
    var coAppIns = "#EmpDRE__EmploymentDetails__coAppInsuranceRadio input[name='EmpDRE__EmploymentDetails__coAppInsuranceRadio_']";
    if ($("#" + EmpDetscrId + "ApplInsRadio_option_Y").is(':checked')) {
        InsurHideShow.show();
        $(coAppIns).attr('disabled', false);
        if (gApzCOB.currentApplicant <= 1) {
            apz.app.EmploymentDetails.onchangecoapplicIns();
        }
    } else if ($("#" + EmpDetscrId + "ApplInsRadio_option_N").is(':checked')) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EMPDET_MSG_TXT_COAPPLICANTINSURANCE"), "C", apz.app.EmploymentDetails.onchangeCB);
    }
};
apz.app.EmploymentDetails.onchangecoapplicIns = function() {
    coAppInsurance = '';
    if ($(`#${EmpDetscrId}coAppInsuranceRadio_option_Y`).is(':checked')) {
        coAppInsurance = 'Yes'
    } else if ($(`#${EmpDetscrId}coAppInsuranceRadio_option_N`).is(':checked')) {
        coAppInsurance = 'No'
    } else {
        coAppInsurance = '';
    }
    gApzCOB.userDetails.insurenceReqForCoApp = coAppInsurance;
}

apz.app.EmploymentDetails.onchangeCB = function(params) {
    var coAppIns = "#EmpDRE__EmploymentDetails__coAppInsuranceRadio input[name='EmpDRE__EmploymentDetails__coAppInsuranceRadio_']";
    if (params.choice) {
      InsurHideShow.hide();
        $("#" + EmpDetscrId + "coAppInsuranceRadio_option_N").attr("checked", true);
        $(coAppIns).attr('disabled', true);  
    } else {
        $(`#${EmpDetscrId}ApplInsRadio_option_N`).prop('checked', false).change();
        $(`#${EmpDetscrId}ApplInsRadio_option_Y`).prop('checked', true).change();
    }
     if (gApzCOB.currentApplicant <= 1) {
        apz.app.EmploymentDetails.onchangecoapplicIns();
    }
}
apz.app.EmploymentDetails.onchangepincode = function(pthis) {
    if (pthis.value.length > 5) {
        ApzCOB.fetchpincodeDtls(pthis.value, 'emp');
    }
};
apz.app.EmploymentDetails.paint_pincode = function(params) {
    $(`#${EmpDetscrId}city`).val(params.city).change();
    $(`#${EmpDetscrId}district`).val(params.district).change();
    $(`#${EmpDetscrId}state`).val(params.state).change();
    $(`#${EmpDetscrId}country`).val(params.country).change();
    $(`#${EmpDetscrId}el_inp_3`).val(params.area).change();
};
apz.app.EmploymentDetails.onChangeAccDetRadio = function() {
    if ($(`#${EmpDetscrId}AccDetRadio_option_N`).is(':checked')) {
        $(`#${EmpDetscrId}uploadDocRow`).addClass("sno"); //hide UploadRow
        BANK_DETAILS_EDIT_OPTION = false;
    } else if ($(`#${EmpDetscrId}AccDetRadio_option_Y`).is(':checked')) {
        BANK_DETAILS_EDIT_OPTION = true;
        $(`#${EmpDetscrId}uploadDocRow`).removeClass("sno"); //show UploadRow
        $(`#${EmpDetscrId}gr_row_22`).addClass("sno");
        $(`#${EmpDetscrId}uploadBankDocDiv`).removeClass("sno");
        var tempArr = [];
        tempArr.unshift({
            "value": PleaseSelect,
            "desc": PleaseSelect
        });
        let obj = {
            "value": "Bank Passbook",
            "desc": "Bank Passbook"
        };
        tempArr.push(obj);
        apz.populateDropdown(document.getElementById(EmpDetscrId + 'el_dpd_1'), tempArr);
        $(`#${EmpDetscrId}el_dpd_1`).val("Bank Passbook");
        $(`#${EmpDetscrId}progressBar`).css(InactiveprogressBar);
    }
};
apz.app.EmploymentDetails.browsefile = function(fileObj, browseId) {
    selType = "BankAccDoc";
    FileSideBrowseId = browseId;
    var fileExtenName = fileObj.value.split('.')[1].toLocaleLowerCase();
    if (!Object.values(gAllowedFileTypes).includes(fileExtenName)) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EMPDET_MSG_TXT_UPLOAD_VALID_FILE"), "W");
        return;
    }
    filesObj = fileObj;
    var fileToUpload = fileObj.files;
    localFileObj = {}; //localFileObj.appid = apz.getElmValue(pageId + "appId");
    localFileObj.filename = fileToUpload[0].name;
    localFileObj.filetype = fileToUpload[0].type;
    localFileObj.filelocation = apz.appId + "/" + localFileObj.filename;
    localFileObj.docType = selType;
    localFileObj.fieldID = EmpDetscrId + browseId;
    FileSideBrowseId = "Browse1";
    if (apz.app.EmploymentDetails.getFileArr()) {
        apz.app.EmploymentDetails.fileReader(filesObj);
    }
};
apz.app.EmploymentDetails.getFileArr = function() {
    // localFileObj.docSide = "Front";
    // localFileObj.docName = "Bank Passbook";
    // localFileObj.docCategory = "Bank Account Proof";
    bankdocProofObj.BankProof.push(localFileObj);
    return true;
};
apz.app.EmploymentDetails.fileReader = function(fileObj) {
    var FR = new FileReader();
    FR.readAsDataURL(fileObj.files[0]);
    FR.onload = function(e) {
        encodedImage = "";
        encodedImage = e.target.result.substr(e.target.result.indexOf(',') + 1, e.target.result.length);
        if (!apz.isNull(encodedImage)) {
            if (isValidDoc) {
                localFileObj.imgSrc = encodedImage;
                document.getElementById(localFileObj.fieldID).value = "";
                ApzCOB.fileUpload(localFileObj);
            }
        }
    }
}
apz.app.EmploymentDetails.displayFileName = function() {
    if (bankdocProofObj.BankProof.length > 0) {
        $(`#${EmpDetscrId}bankDocRow`).addClass('uploaded');
        $(`#${EmpDetscrId}progressBar`).css(ActiveprogressBar);
        var lFilename = ApzCOB.fnShortenFileName(bankdocProofObj.BankProof[0]["filename"]);
        $(`#${EmpDetscrId}bankDocFname`).text(lFilename);
        ['bankDocDiv'].show();
        ['uploadBankDocDiv'].hide();
        $(`#${EmpDetscrId}docImage`).attr('src', "data:image/png;base64," + localFileObj.imgSrc);
        $(`#${EmpDetscrId}deleteIcon`).attr('onclick', "apz.app.EmploymentDetails.deleteOtherDocs('delete')");
    }
}
apz.app.EmploymentDetails.selectedFileData = function(appDocId) {
    var tempFileArr = [];
    if (!apz.isNull(appDocId)) {
        bankdocProofObj.BankProof["appDocId"] = appDocId;
    }
    tempFileArr.push(bankdocProofObj.BankProof[0]);
    return tempFileArr;
}
apz.app.EmploymentDetails.fileClick = function(obj) {
    var flname = $(obj).text();
    var tempFileArr = apz.app.EmploymentDetails.selectedFileData('');
    $.each(tempFileArr, function(i, k) {
        if (k.filename === flname) {
            viewBase64 = k.imgSrc;
            curImgObj = k;
            curImgIndex = i;
            apz.app.EmploymentDetails.noBase64(flname, k, i);
        }
    })
};
apz.app.EmploymentDetails.noBase64 = function(flname, k, i) {
    apz.app.EmploymentDetails.showDoc(flname, k, i);
};
apz.app.EmploymentDetails.noBase64CB = function(params) {
    if (!apz.isNull(params.base64)) {
        viewBase64 = params.base64;
        apz.app.EmploymentDetails.showDoc('', curImgObj, curImgIndex);
    }
};
apz.app.EmploymentDetails.showDoc = function(flname, k, i) {
    var fileType = apz.isNull(ApzCOB.getFileExtension(k.filetype)) ? k.filetype.split('/')[1] : ApzCOB.getFileExtension(k.filetype);
    if (fileType === 'png' || fileType === 'jpeg' || fileType === 'jpg') {
        $(`#${EmpDetscrId}imgSrc`).attr('src', "data:image/png;base64," + viewBase64);
        ApzCOB.toggleModal(EmpDetscrId + "viewUploadedFileModal");
        $(`#${EmpDetscrId}viewFileDeleteBtn`).attr('onclick', "apz.app.EmploymentDetails.deleteOtherDocs('delete')");
        // $(`#${EmpDetscrId}viewFileReuploadBtn`).attr('onclick', "apz.app.EmploymentDetails.deleteOtherDocs('reupload')");
    } else if (fileType === 'pdf') {
        var a = document.createElement("a");
        a.href = "data:application/octet-stream;base64," + viewBase64;
        a.download = apz.isNull(flname) ? k.filename : flname
        a.click();
    }
    apz.stopLoader();
}
apz.app.EmploymentDetails.deleteOtherDocs = function(actionType) {
    ActionFlag = actionType;
    if ($('#' + EmpDetscrId + "viewUploadedFileModal").is(':visible')) {
        ApzCOB.toggleModal(EmpDetscrId + "viewUploadedFileModal");
    }
    if (bankdocProofObj.BankProof[0] !== undefined) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EMPDET_MSG_TXT_DELETE_FILE_CONF"), "C", apz.app.EmploymentDetails.deleteOtherDocsCB);
    }
};
apz.app.EmploymentDetails.deleteOtherDocsCB = function(param) {
    if (!apz.isNull(param) && param.choice === true) {
        ApzCOB.deleteDocument("OtherDocs", "", param.thisObj);
        // apz.app.EmploymentDetails.deleteBnkDoc();
    }
    if ($('#' + EmpDetscrId + "viewUploadedFileModal").is(':visible')) {
        ApzCOB.toggleModal(EmpDetscrId + "viewUploadedFileModal");
        // deleteRowNo = param;
        ApzCOB.deleteDocument("OtherDocs", "");
        // ApzCOB.toggleModal(EmpDetscrId + "photoSignList");
    }
};
apz.app.EmploymentDetails.deleteBnkDoc = function(tempFileArr) {
    var type = tempFileArr[0]["docType"];
    var filename = tempFileArr[0]["filename"];
    var appDocID = apz.isNull(tempFileArr[0].appDocId) ? "" : parseInt(tempFileArr[0].appDocId);
    if (!apz.isNull(gApzCOB["requestNodes"]['applicationDocumentsWrapperList']) && gApzCOB["requestNodes"]['applicationDocumentsWrapperList'].length >
        0) {
        gApzCOB["requestNodes"]['applicationDocumentsWrapperList'][0].applicationDocumentsList.forEach(function(e, i) {
            if (e.payload.documentType === type && e.payload.documentFileName === filename && parseInt(e.appDocId) === appDocID) {
                gApzCOB["requestNodes"]['applicationDocumentsWrapperList'][0].applicationDocumentsList.splice(i, 1)
            }
        });
    }
    if (bankdocProofObj.BankProof.length > 0) {
        bankdocProofObj.BankProof = [];
        ['bankDocDiv'].hide();
        ['uploadBankDocDiv'].show()
        $(`#${EmpDetscrId}bankDocRow`).removeClass('uploaded');
        $(`#${EmpDetscrId}progressBar`).css(InactiveprogressBar);
        $(`#${EmpDetscrId}bankDocFname`).text("");
        $(`#${EmpDetscrId}deleteIcon`).attr('onclick', "");
    }
};
apz.app.EmploymentDetails.onChangeSourceOfIncome = function() {
    var sourceOfIncome = apz.getElmValue(EmpDetscrId + "othSrcInc")
    if (sourceOfIncome === 'Others') {
        $(`#${EmpDetscrId}otherSrcInc_ul`).removeClass("sno");
    } else {
        $(`#${EmpDetscrId}otherSrcInc_ul`).addClass("sno");
    }
}
apz.app.EmploymentDetails.onClickbrowseHyp = function() {
    if (apz.deviceType === "WEB") {
        $(`#${EmpDetscrId}bankDtlBrowser`).trigger('click');
    } else {
        FileSideBrowseId = "Browse1";
        apz.app.EmploymentDetails.SelectOption("camera");
    }
}
apz.app.EmploymentDetails.getVintageYear = function(pthis) {
    let startDate = $(pthis).val();
    var vintage = ApzCOB.getAge(startDate);
    $('#' + EmpDetscrId + 'busiEmpVintageInput').val(vintage);
    $('#' + EmpDetscrId + 'busiEmpVintageInput').removeClass('err');
    $('#' + EmpDetscrId + 'sc_row_307').addClass('sno');
}
apz.app.EmploymentDetails.SelectOption = function(captureType) {
    var strDate = new Date().getTime() + "";
    if (captureType === 'camera' || captureType === 'photo') {
        var cameraObj = {
            "crop": "Y", //Y or N
            "flash": "N",
            "action": "base64_Save", // save,base64
            "fileName": 'b' + strDate,
            "encodingType": "JPG",
            "sourceType": captureType // photo / camera
        };
        cameraObj.id = "CAMERA_ID";
        cameraObj.callBack = apz.app.EmploymentDetails.cameraCallback;
        apz.ns.openCamera(cameraObj);
        ApzCOB.getGeoCordinatesMobile();
    } else {
        var json = {
            "filter": "",
            "fileCategory": "EXTERNAL", // AUDIO, VIDEO, PHOTO
            "location": "docs",
            "openFile": "N"
        };
        json.id = "FILEBROWSER_ID";
        json.callBack = apz.app.UploadDocuments.getFileCallback;
        apz.ns.fileBrowser(json);
    }
};
apz.app.EmploymentDetails.cameraCallback = function(lparams) {
    if (lparams.status) {
        filesObj = lparams;
        localFileObj = {};
        localFileObj.filename = lparams.path.split('/')[lparams.path.split('/').length - 1];
        localFileObj.filetype = lparams.path.split('/')[lparams.path.split('/').length - 1];
        localFileObj.filelocation = apz.appId + "/" + localFileObj.filename;
        localFileObj.fieldID = EmpDetscrId + FileSideBrowseId;
        localFileObj.latitude = window.currentGeoCords?.latitude;
        localFileObj.longitude = window.currentGeoCords?.longitude;
        localFileObj.uploadedTs = new Date().toISOString();
        // localFileObj.docSide = "Front";
        // localFileObj.docType = "BankAccDoc";
        localFileObj.imgSrc = lparams.encodedImage;
        apz.app.EmploymentDetails.getFileArr();
        ApzCOB.fileUpload({
            'filename': lparams.path.split('/')[lparams.path.split('/').length - 1],
            'imgSrc': lparams.encodedImage
        });
    } else {
        ApzCOB.fnDisplayMsg(!apz.isNull(lparams.text) ? lparams.text : "Operation cancelled", "E", "");
    }
};
apz.app.EmploymentDetails.validateAnnualIncome = function() {
    var annualIncome = apz.getElmValue(EmpDetscrId + "annualIncome");
    if (annualIncome < minAnnualIncome || annualIncome > maxAnnualIncome) {
        $(`#${EmpDetscrId}annualIncome`).val('');
        ApzCOB.fnDisplayMsg((ApzCOB.getDescfromLitCode("LIT_EMPDTLS_MaxANNUAL_INCOME") + ' ' + ApzCOB.fn_FormatAmount(minAnnualIncome) + ' ' +
            'and' + ' ' + ApzCOB.fn_FormatAmount(maxAnnualIncome)), "E");
    }
}
apz.app.EmploymentDetails.StoreAppDocID = function(appDocID) {
    localFileObj.appDocId = appDocID;
    localFileObj.isPushbackUpload = "N";
}
apz.app.EmploymentDetails.geolocationCapture = function(pthis) {
    if (apz.deviceType === "WEB") {
        ApzCOB.getGeoCordinates();
    } else {
        ApzCOB.getGeoCordinatesMobile();
    }
}
apz.app.EmploymentDetails.AddrSameAs = function(pthis) {
    var val = pthis.value;
    var custAddr = [];
    var address = inSessionStore.addressDetailsWrapperList[0].addressDetailsList
    if (val == "Present" || val == "Permanent") {
        if (!apz.isObjectEmpty(inSessionStore.addressDetailsWrapperList)) {
            // if (gApzCOB.currentApplicant == 1) {
            //     custAddr = inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].payload.addressList;
            // } else if (gApzCOB.currentApplicant == 2) {
            //     custAddr = inSessionStore.addressDetailsWrapperList[0].addressDetailsList[1].payload.addressList;
            // }
            if (gApzCOB.currentApplicant == 1) {
                address.forEach(function(i, k) {
                    if (address[k].addressType === 'Personal' && parseInt(address[k].custDtlId) === parseInt(gApzCOB.userDetails
                            .custDtlId)) {
                        custAddr.push(address[k])
                    }
                })
            } else {
                address.forEach(function(i, k) {
                    if (address[k].addressType === 'Personal' && parseInt(address[k].custDtlId) === parseInt(gApzCOB.userDetails
                            .CoApplicantCustomerId)) {
                        custAddr.push(address[k])
                    }
                })
            }
        }
        let addressList = custAddr[0].payload.addressList;
        let matchedAddress = addressList.find(function(el) {
            return el.locateCoOrdinatesFor?.toLowerCase().includes(val.toLowerCase());
        }) || {};
        let matchedAddressType = addressList.find(function(el) {
            return el.addressType?.toLowerCase().includes(val.toLowerCase());
        }) || {};
        let coordinates = matchedAddress.locateCoOrdinates || "";
        for (var i = 0; i < officeAddrFields.length; i++) {
            $(officeAddrFields[i]).attr('disabled', true);
        }
        addrType = 'Personal';
        subAddrType = val;
        custType = gApzCOB.currentApplicant == 1 ? 'Applicant' : 'Co-App';
        addressLine1 = ApzCOB.getPayloadDatafromWrapper('addressLine1', custType, 'addressDetailsWrapperList');
        addressLine2 = ApzCOB.getPayloadDatafromWrapper('addressLine2', custType, 'addressDetailsWrapperList');
        addressLine3 = ApzCOB.getPayloadDatafromWrapper('addressLine3', custType, 'addressDetailsWrapperList');
        pinCode = ApzCOB.getPayloadDatafromWrapper('pinCode', custType, 'addressDetailsWrapperList');
        city = ApzCOB.getPayloadDatafromWrapper('city', custType, 'addressDetailsWrapperList');
        district = ApzCOB.getPayloadDatafromWrapper('district', custType, 'addressDetailsWrapperList');
        state = ApzCOB.getPayloadDatafromWrapper('state', custType, 'addressDetailsWrapperList');
        country = ApzCOB.getPayloadDatafromWrapper('country', custType, 'addressDetailsWrapperList');
        landMark = ApzCOB.getPayloadDatafromWrapper('landMark', custType, 'addressDetailsWrapperList');
        $(`#${EmpDetscrId}addressLine1`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine1`, addressLine1)).change();
        $(`#${EmpDetscrId}addressLine2`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine2`, addressLine2));
        $(`#${EmpDetscrId}addressLine3`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine3`, addressLine3));
        $(`#${EmpDetscrId}pin`).val(pinCode).change();
        $(`#${EmpDetscrId}city`).val(city);
        $(`#${EmpDetscrId}district`).val(district);
        $(`#${EmpDetscrId}state`).val(state);
        $(`#${EmpDetscrId}country`).val(country);
        $(`#${EmpDetscrId}el_inp_2`).val(landMark);
        $(`#${EmpDetscrId}pin`).blur();
        /* var applAddrArray = address.filter(el => el.addressType === "Personal" && el.custDtlId === parseInt(gApzCOB.userDetails.custDtlId));
        var presentAddrArray = applAddrArray[0].payload.addressList.filter(el => el.addressType === "Present");*/
        var selectedAddr = val + " Address";
        var $location = $("#EmpDRE__EmploymentDetails__location");
        var $row = $("#EmpDRE__EmploymentDetails__sc_row_320");
        if (selectedAddr === matchedAddress.locateCoOrdinatesFor) {
            $("#" + (EmpDetscrId + "location")).val(coordinates).prop('disabled', true);
            $('#' + EmpDetscrId + 'sc_col_351').addClass('sno');
            if ($location.hasClass("err")) {
                $location.removeClass("err");
            }
            $row.addClass("sno");
        } else {
            $('#' + EmpDetscrId + 'businessLocationCoordinateRow').removeClass('sno');
            $('#' + EmpDetscrId + 'sc_col_351').removeClass('sno');
            $("#" + (EmpDetscrId + "location")).val("").prop('disabled', true);
        }
        /*$(`#${EmpDetscrId}el_inp_2").val();
        $(`#${EmpDetscrId}el_inp_3").val();*/
    } else if (val == "Other") {
        for (var i = 0; i < officeAddrFields.length; i++) {
            $(officeAddrFields[i]).attr('disabled', false);
            $(officeAddrFields[i]).val("");
        }
        for (var i = 0; i < otherOfficeAddrFields.length; i++) {
            $(otherOfficeAddrFields[i]).val("");
        }
        $('#' + EmpDetscrId + 'businessLocationCoordinateRow').removeClass('sno');
        $('#' + EmpDetscrId + 'sc_col_351').removeClass('sno');
    }
}
apz.app.EmploymentDetails.onchangeNatureOfBusiness = function() {
    var tempArr = [];
    var natureOfBusiness = $(`#${EmpDetscrId}profession`).val();
    if (natureOfBusiness === PleaseSelect || natureOfBusiness === "") {
        $(`#${EmpDetscrId}bssEmpAcc`).val(PleaseSelect);
        $(`#${EmpDetscrId}bssEmpAcc`).attr('disabled', true);
    } else {
        tempArr = [...businessActivity[0][natureOfBusiness]];
        if (!tempArr.includes(PleaseSelect)) {
            tempArr.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
        }
        apz.populateDropdown(document.getElementById(EmpDetscrId + 'bssEmpAcc'), ApzCOB.formatDropDownforArray(tempArr));
        $(`#${EmpDetscrId}bssEmpAcc`).attr('disabled', false);
    }
}
apz.app.EmploymentDetails.checkBankDocument = function() {
    if (!apz.isNull(inSessionStore.bankDetailsWrapperList) && !apz.isNull(inSessionStore.applicationDocumentsWrapperList)) {
        if (inSessionStore.bankDetailsWrapperList.length > 0 && inSessionStore.applicationDocumentsWrapperList.length > 0) {
            let getBankData = inSessionStore.bankDetailsWrapperList.filter(bankData => parseInt(bankData.bankDetails.custDtlId) === parseInt(
                gApzCOB.userDetails.custDtlId));
            if (getBankData.length > 0) {
                let bankEditVal = getBankData[0].bankDetails.payload.editBankDetails === "Yes" ? true : false;
                if (bankEditVal) {
                    if (inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.length > 0) {
                        let docData = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
                        let getBankEditDoc = docData.filter(docs => docs.payload.screenId === "EmploymentDetails")
                        if (getBankEditDoc.length > 0) {
                            let indexNo = getBankEditDoc.length - 1;
                            let bankDocFileName = getBankEditDoc[indexNo].payload.documentFileName;
                            localFileObj = {}; //localFileObj.appid = apz.getElmValue(pageId + "appId");
                            localFileObj.filename = bankDocFileName;
                            localFileObj.filetype = getBankEditDoc[indexNo].payload.documentFormat;
                            localFileObj.filelocation = getBankEditDoc[indexNo].payload.documentLoc;
                            localFileObj.docType = getBankEditDoc[indexNo].payload.documentType;
                            localFileObj.fieldID = EmpDetscrId + "bankDtlBrowser";
                            localFileObj.appDocId = getBankEditDoc[indexNo].appDocId;
                            bankdocProofObj.BankProof = [];
                            bankdocProofObj.BankProof.push(localFileObj);
                            ApzCOB.downloadDocFileFromserver(bankDocFileName);
                        }
                    }
                }
            }
        }
    }
}
apz.app.EmploymentDetails.onchangeNatureOfOccpationTag = function() {
    var radioBtn = apz.getElmValue(EmpDetscrId + "ocuupationTag");
    if (radioBtn === 'Yes') {
        var occupation = inSessionStore.occupationDetailsWrapperList;
        var address = inSessionStore.addressDetailsWrapperList[0].addressDetailsList;
        var occupationDetl = [],
            businessAddr = [];
        //occupation Details
        if (!apz.isNull(inSessionStore.occupationDetailsWrapperList)) {
            if (inSessionStore.occupationDetailsWrapperList > 1) {
                occupation.forEach(function(i, k) {
                    if (parseInt(occupation[k].custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                        occupationDetl.push(occupation[k])
                        occupationDetl = structuredClone(occupationDetl);
                    }
                })
            } else {
                occupationDetl = inSessionStore.occupationDetailsWrapperList[0].occupationDetails.payload
            }
        }
        if (gApzCOB.currentApplicant > 1) {
            if (!apz.isNull(inSessionStore.occupationDetailsWrapperList) && !apz.isNull(occupationDetl)) {
                $(`#${EmpDetscrId}typbssEmpent`).val(occupationDetl.typeofbusiness);
                $(`#${EmpDetscrId}profession`).val(occupationDetl.natureOfOccupation);
                $(`#${EmpDetscrId}typeOfEmployer`).val(occupationDetl.typeOfEmployer);
                $(`#${EmpDetscrId}bssEmpAcc`).val(occupationDetl.employeeActivity);
                //$(`#${EmpDetscrId}employerName`).val(occupationDetl.employer);
                $(`#${EmpDetscrId}employerName`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}employerName`, occupationDetl.employer ?? '')).trigger("onblur");
                $(`#${EmpDetscrId}designation`).val(occupationDetl.designation);
                $(`#${EmpDetscrId}retirementAge`).val(occupationDetl.retirementAge);
                $(`#${EmpDetscrId}lastEmployerName`).val(occupationDetl.lastEmployer);
                $(`#${EmpDetscrId}bssAddrProof`).val(occupationDetl.businessAddressProof);
                if (!apz.isNull(occupationDetl.businessAddressProof) || IS_REJECTED_APPLICATION) {
                    ApzCOB.addDisableToInput(`${EmpDetscrId}bssAddrProof`);
                }
                $(`#${EmpDetscrId}empProof`).val(occupationDetl.employmentProof);
                if (!apz.isNull(occupationDetl.employmentProof) || IS_REJECTED_APPLICATION) {
                    ApzCOB.addDisableToInput(`${EmpDetscrId}empProof`);
                }
                $(`#${EmpDetscrId}bssPerOwn`).val(occupationDetl.businessPremiseOwnerShip);
                $(`#${EmpDetscrId}freqOfInc`).val(occupationDetl.freqOfIncome);
                $(`#${EmpDetscrId}annualIncome`).val(occupationDetl.annualIncome);
                $(`#${EmpDetscrId}othSrcInc`).val(occupationDetl.otherSourceIncome);
                $(`#${EmpDetscrId}othSrcAnnInc`).val(occupationDetl.otherSourceAnnualIncome);
                $(`#${EmpDetscrId}busiEmpVintageInput`).val(occupationDetl.businessEmpVintageYear);
                $(`#${EmpDetscrId}busiEmpStartDatInput`).val(occupationDetl.businessEmpStartDate);
                if (!apz.isNull(occupationDetl.streetVendor)) {
                    $(`#${EmpDetscrId}streetVendor_option_` + occupationDetl.streetVendor).attr("checked", true);
                }
                if (!apz.isNull(occupationDetl.otherSourceIncome)) {
                    if (occupationDetl.otherSourceIncome === 'Others') {
                        $(`#${EmpDetscrId}otherSrcInc`).val(occupationDetl.otherSourceIncome);
                    }
                }
            }
            $.map(occupationFields, function(field) {
                ApzCOB.addDisableToInput(field);
            });
            $('#EmpDRE__EmploymentDetails__busiEmpStartDatInput_button').attr('disabled',true);
            ApzCOB.removeErrMessgae(occupationFields, "array");
        }
        //Bussiness Address
        if (!apz.isNull(inSessionStore.addressDetailsWrapperList[0].addressDetailsList)) {
            if (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.length > 1) {
                address.forEach(function(i, k) {
                    if (address[k].addressType === 'Occupation' && parseInt(address[k].custDtlId) === parseInt(gApzCOB.userDetails
                            .custDtlId)) {
                        businessAddr.push(address[k])
                        businessAddr = businessAddr[0].payload.addressList[0];
                    }
                })
            } else {
                businessAddr = inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].payload.addressList[0]
            }
        }
        if (gApzCOB.currentApplicant > 1) {
            if (!apz.isNull(inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].payload.addressList[0]) && !apz.isNull(
                businessAddr)) {
                $(`#${EmpDetscrId}addressLine1`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine1`, businessAddr.addressLine1));
                $(`#${EmpDetscrId}addressLine2`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine2`, businessAddr.addressLine2));
                $(`#${EmpDetscrId}addressLine3`).val(ApzCOB.getSubstrValue(`#${EmpDetscrId}addressLine3`, businessAddr.addressLine3));
                $(`#${EmpDetscrId}pin`).val(businessAddr.pinCode);
                $(`#${EmpDetscrId}city`).val(businessAddr.city);
                $(`#${EmpDetscrId}district`).val(businessAddr.district);
                $(`#${EmpDetscrId}state`).val(businessAddr.state);
                $(`#${EmpDetscrId}country`).val(businessAddr.country);
                $(`#${EmpDetscrId}el_inp_2`).val(businessAddr.landMark);
                $(`#${EmpDetscrId}el_inp_3`).val(businessAddr.area);
                if (!apz.isNull(businessAddr.addressSameAs)) {
                    $(`#${EmpDetscrId}officeAddrSameAs_option_` + businessAddr.addressSameAs).attr("checked", true);
                } else {
                    $(`#${EmpDetscrId}officeAddrSameAs_option_Present`).attr("checked", true).change();
                }
            }
            $.map(businessAddrFields, function(field) {
                ApzCOB.addDisableToInput(field);
            });
            ApzCOB.removeErrMessgae(businessAddrFields, "array");
        }
    } else {
        $.map(businessAddrFields, function(field) {
            ApzCOB.removeDisableToInput(field);
        });
        $.map(occupationFields, function(field) {
            ApzCOB.removeDisableToInput(field);
        });
        $.map(radioFeilds, function(field) {
            $('#' + field).prop("checked", false);
        });
        var disabledFields = [`${EmpDetscrId}city`, `${EmpDetscrId}district`, `${EmpDetscrId}state`, `${EmpDetscrId}country`, `${EmpDetscrId}busiEmpVintageInput`];
        $.map(disabledFields, function(field) {
            ApzCOB.addDisableToInput(field);
        });
        ApzCOB.removeDisableToInput(`${paintKYCId}dob`);
        $(`#${paintKYCId}dob`).prop('disabled', true);
        $('#EmpDRE__EmploymentDetails__busiEmpStartDatInput_button').attr('disabled',false);
        apz.app.EmploymentDetails.setEmptyFields(fields, dropdowns);
        $('input[name="EmpDRE__EmploymentDetails__officeAddrSameAs_"]').prop('checked', false);
    }
    apz.app.EmploymentDetails.setAnnualIncomeValue();
}
apz.app.EmploymentDetails.setEmptyFields = function(fields, dropDown) {
    $.map(fields, function(field) {
        apz.setElmValue(field, "");
    });
    $.map(dropDown, function(field) {
        $(`#${field}`).val(PleaseSelect).change();
    });
}
apz.app.EmploymentDetails.onChangeRelnWtNomi = function(pthis) {
    $(`#${EmpDetscrId}nomineeForInsur`).val('');
    $(`#${EmpDetscrId}dobNominee`).val('');
    $(`#${EmpDetscrId}ageOfNominee`).val('');
    if (gApzCOB.currentApplicant <= 1) {
        var selVal = pthis.value.toLowerCase();
        let coAppData = inSessionStore.customerDetailsList.filter(custData => custData.customerType === "Co-App");
        let relnWithAppl = (coAppData.length > 0) ? coAppData[0].payload.relationShipWithApplicant : '';
        if (!apz.isNull(relnWithAppl)) {
            if (selVal === relnWithAppl.toLowerCase()) {
                apz.app.EmploymentDetails.populateData();
            }
        }
    }
}
apz.app.EmploymentDetails.onchangeAppliDisability = function() {
    disabilityFlag = true;
    $(`#${EmpDetscrId}disability_err_div`).addClass("sno");
    $(`#${EmpDetscrId}disabilityImparirment_err_div`).addClass("sno");
    $(`#${EmpDetscrId}other_type_impair_errdiv`).addClass("sno");
    $(`#${EmpDetscrId}UDID_err_row`).addClass("sno");
    $(`#${EmpDetscrId}percent_ERR_row`).addClass("sno");
    $(`#${EmpDetscrId}others_impair_div`).addClass("sno");
    if ($('#EmpDRE__EmploymentDetails__ApplDisaRadio_option_Y').is(':checked')) {
    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EMPDET_MSG_TXT_APPLICANTDISABILITYSTS"), "C", apz.app.EmploymentDetails.DisAblStatus);
    $('.ajs-button').text('No');
    $('.ajs-button.ajs-ok').text('Yes');
 }else{
     DisabilityHideShow.hide();
     apz.setElmValue(EmpDetscrId + "UDID_Num", "" );
     apz.setElmValue(EmpDetscrId + "percentageOfImp", "" );
	 //$('#EmpDet__EmploymentDetails__UDID_Num').val('');
	 //$('#EmpDet__EmploymentDetails__percentageOfImp').val('');
	 checkedValues = [];
	 for (let i = 1; i <= 7; i++) {
			let id = 'EmpDetscrId + el_cbx_' + i;
			let cb = document.getElementById(id);

			if (cb) { // check if element exists
				if(cb.checked){
				//console.log(id + ' → ' + val);
				$('#' + id).prop('checked', false);
				
				}
			}
		}
 }
}
apz.app.EmploymentDetails.DisAblStatus = function(params) {
    if (params.choice) {
        DisabilityHideShow.show();
        $(`#${EmpDetscrId}disability_err_div`).addClass("sno");
        $("#" + EmpDetscrId + "el_label_2").addClass("req");
        $("#" + EmpDetscrId + "UDID_Num_grp_lbl").addClass("req");
        $("#" + EmpDetscrId + "percentageOfImp_grp_lbl").addClass("req");
    }else{
		$("#" + EmpDetscrId + "ApplDisaRadio_option_Y").prop('checked', false);
		$("#" + EmpDetscrId + "ApplDisaRadio_option_N").prop('checked', true);
        DisabilityHideShow.hide();
        apz.setElmValue(EmpDetscrId + "UDID_Num", "" );
        apz.setElmValue(EmpDetscrId + "percentageOfImp", "" );
		//$('#EmpDet__EmploymentDetails__UDID_Num').val('');
		//$('#EmpDet__EmploymentDetails__percentageOfImp').val('');
		checkedValues = [];
		
		for (let i = 1; i <= 7; i++) {
			let id = 'EmpDetscrId + el_cbx_' + i;
			let cb = document.getElementById(id);

			if (cb) { // check if element exists
				if(cb.checked){
				//console.log(id + ' → ' + val);
				$('#' + cb).prop('checked', false);
				
				}
			}
		}
    }
}

apz.app.EmploymentDetails.addORremoveDisabilitySts = function(value) {
    checkedValues = [];
    for (let i = 1; i <= 7; i++) {
        let id = EmpDetscrId + 'el_cbx_' + i;
        let cb = document.getElementById(id);
        if (cb) { // check if element exists
            if (cb.checked) {
                //console.log(id + ' → ' + val);
                checkedValues.push(cb.getAttribute('checkedval'));
                /*if(cb.getAttribute('checkedval') == 'Others'){
                	$('#EmpDet__EmploymentDetails__UDID_Num_ul').removeClass('sno');
                }else{
                	$('#EmpDet__EmploymentDetails__UDID_Num_ul').addClass('sno');
                	$('#EmpDet__EmploymentDetails__UDID_Num').val('');
                }*/
            }
        }
    }
    if (checkedValues.includes('Others')) {
        $(`#${EmpDetscrId}others_impair_div`).removeClass("sno");
    } else {
        apz.setElmValue(EmpDetscrId + "others_input_impair", "");
        $(`#${EmpDetscrId}others_impair_div`).addClass("sno");
    }
    if (checkedValues.length > 0) {
        $(`#${EmpDetscrId}disabilityImparirment_err_div`).addClass("sno");
    }
}
apz.app.EmploymentDetails.setAnnualIncomeValue = function(lvalue) {
    income = ApzCOB.getOccupation("Income");
    $(`#${annualIncomeTag}`).val('');
    setType = false;
    if (!apz.isNull(income)) {
        $(`#${annualIncomeTag}`).val(income);
        setType = true;
    } else if (!apz.isNull(lvalue)) {
        $(`#${annualIncomeTag}`).val(lvalue);
        setType = true;
    }
    ApzCOB.AddOrRemoveDisableFields([annualIncomeTag], setType);
}
apz.app.EmploymentDetails.otherTypValidation = function() {
    if (($(`#${EmpDetscrId}others_input_impair`).text()).length < 2) {
        $(`#${EmpDetscrId}other_type_impair_errdiv`).removeClass("sno");
        return false;
    } else {
        $(`#${EmpDetscrId}other_type_impair_errdiv`).addClass("sno");
    }
}
apz.app.EmploymentDetails.UDIDCertiValidation = function() {
    if (($(`#${EmpDetscrId}UDID_Num`).val()).length != 18) {
        $(`#${EmpDetscrId}UDID_err_row`).removeClass("sno");
        return false;
    } else {
        $(`#${EmpDetscrId}UDID_err_row`).addClass("sno");
    }
}
apz.app.EmploymentDetails.TypImapairPercenValidation = function() {
    if ($(`#${EmpDetscrId}percentageOfImp`).val() > 100 || $(`#${EmpDetscrId}percentageOfImp`).val().length == 0) {
        $(`#${EmpDetscrId}percent_ERR_row`).removeClass("sno");
        return false;
    } else {
        $(`#${EmpDetscrId}percent_ERR_row`).addClass("sno");
    }
}
