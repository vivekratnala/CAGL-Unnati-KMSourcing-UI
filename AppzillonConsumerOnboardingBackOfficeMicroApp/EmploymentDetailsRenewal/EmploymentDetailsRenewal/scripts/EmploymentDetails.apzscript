apz.app.EmploymentDetails.onclickIns = function(pthis) {
    if ($(`#${EmpDetscrId}ApplDisaRadio_option_N`).is(':checked') || $(`#${EmpDetscrId}ApplDisaRadio_option_Y`).is(':checked')) {
        $(`#${EmpDetscrId}disability_err_div`).addClass("sno");
        if ($(`#${EmpDetscrId}ApplDisaRadio_option_Y`).is(':checked')) {
            checkedValues = [];
            for (let i = 1; i <= 7; i++) {
                let id = EmpDetscrId + 'el_cbx_' + i;
                let cb = document.getElementById(id);
                if (cb) { // check if element exists
                    if (cb.checked) {
                        checkedValues.push(cb.getAttribute('checkedval'));
                    }
                }
            }
            if (checkedValues.length >= 1) {
                $(`#${EmpDetscrId}disabilityImparirment_err_div`).addClass("sno");
                if (($(`#${EmpDetscrId}UDID_Num`).val()).length != 18) {
                    $(`#${EmpDetscrId}UDID_err_row`).removeClass("sno");
                    return false;
                } else {
                    $(`#${EmpDetscrId}UDID_err_row`).addClass("sno");
                }
                if ($(`#${EmpDetscrId}percentageOfImp`).val() > 100 || $(`#${EmpDetscrId}percentageOfImp`).val().length == 0) {
                    $(`#${EmpDetscrId}percent_ERR_row`).removeClass("sno");
                    return false;
                } else {
                    $(`#${EmpDetscrId}percent_ERR_row`).addClass("sno");
                }
                if (checkedValues.includes('Others')) {
                    if (($(`#${EmpDetscrId}others_input_impair`).text()).length < 2) {
                        $(`#${EmpDetscrId}other_type_impair_errdiv`).removeClass("sno");
                        return false;
                    } else {
                        $(`#${EmpDetscrId}other_type_impair_errdiv`).addClass("sno");
                    }
                }
            } else {
                $(`#${EmpDetscrId}disabilityImparirment_err_div`).removeClass("sno");
                return false;
            }
        }
    } else {
        $(`#${EmpDetscrId}disability_err_div`).removeClass("sno");
        return false;
    }
    if ($(insDetId).is(":visible")) {
        $(insDetId).addClass("sno");
        $(`#${EmpDetscrId}gr_row_2`).removeClass('active');
        ['disbUp', 'insurDown', 'bankUp', 'occupUp', 'officeUp'].show();
        ['disbDown', 'insurUp', 'bankDown', 'occupDown', 'officeDown'].hide();
    } else {
        insLoanFlag = true;
        ['disbUp', 'insurDown', 'bankUp', 'occupUp', 'officeUp'].hide();
        ['disbDown', 'insurUp', 'bankDown', 'occupDown', 'officeDown'].show();
        $(insDetId).removeClass("sno");
        $(`#${EmpDetscrId}gr_row_2`).addClass('active');
        $(`#${EmpDetscrId}gr_row_30`).removeClass('active');
        $(`#${EmpDetscrId}gr_row_5`).removeClass('active');
        $(`#${EmpDetscrId}gr_row_8`).removeClass('active');
        $(`#${EmpDetscrId}gr_row_11`).removeClass('active');
        $(disabDetId).addClass("sno");
        $(bankDetId).addClass("sno");
        $(occDetId).addClass("sno");
        $(offAddrId).addClass("sno");
        $(`#${EmpDetscrId}disabSuccess_ul`).removeClass("sno");
    }
    //apz.app.EmploymentDetails.continueBtn();
}
