apz.app.EmploymentDetails.data = function() {
    if (!apz.isNull(window.inSessionStore.occupationDetailsWrapperList) && !apz.isNull(window.inSessionStore.occupationDetailsWrapperList[CURRENT_APPLICANT_DETAILS_INDEX])) {
        let itemIndex =  window.inSessionStore.occupationDetailsWrapperList.findIndex(item => parseInt(item.occupationDetails.custDtlId) === parseInt((gApzCOB.currentApplicant <= 1) ? gApzCOB.userDetails.custDtlId : gApzCOB.userDetails.CoApplicantCustomerId));
        if (!apz.isNull(itemIndex) && itemIndex >= 0) {
            data = apz.isNull(window.inSessionStore.occupationDetailsWrapperList[itemIndex].occupationDetails) ? data : window.inSessionStore.occupationDetailsWrapperList[itemIndex].occupationDetails;
        }
    }
}
$('#' + EmpDetscrId + 'yrsOfExp,#' + EmpDetscrId + 'monOfExp').on('mousemove', function(event) {
    var input = document.getElementById(event.target.id);
    input.addEventListener("drop", $('#' + event.target.id).trigger('onblur'));
    // mouseDown = true;
})
apz.app.EmploymentDetails.getStateCityValueforDropdown = function() { //using it for setElmValue for setting state & city
    $.each(States, function(a, b) {
        stateVal.push(b.val)
        stateDesc.push(b.desc)
    })
    $.each(Cities, function(a, b) {
        cityVal.push(b.val)
        cityDesc.push(b.desc)
    })
}
apz.app.EmploymentDetails.paintLoanEmpDetails = function() {
    if (gApzCOB.ExistingCustomer) {
        if (!apz.isNull(gApzCOB.customerDetails.addressList) && gApzCOB.customerDetails.addressList.length > 0) {
            gApzCOB.customerDetails.addressList.filter(function(e) {
                if (JSON.parse(e.payloadColumn).addressList[0].addressType === "Occupation" || JSON.parse(e.payloadColumn).addressList[0]
                    .addressType === "Communication") {
                    gApzCOB.customerDetails.addrdet = JSON.parse(e.payloadColumn);
                    if (JSON.parse(e.payloadColumn).addressList[0].addressType === "Occupation") {
                        gApzCOB.customerDetails.addrdet.addressLine1 = gApzCOB.customerDetails.addrdet["addressList"][0].addressLine1
                        gApzCOB.customerDetails.addrdet.addressLine2 = gApzCOB.customerDetails.addrdet["addressList"][0].addressLine2
                        gApzCOB.customerDetails.addrdet.addressType = gApzCOB.customerDetails.addrdet["addressList"][0].addressType
                        gApzCOB.customerDetails.addrdet.city = gApzCOB.customerDetails.addrdet["addressList"][0].city
                        gApzCOB.customerDetails.addrdet.country = gApzCOB.customerDetails.addrdet["addressList"][0].country
                        gApzCOB.customerDetails.addrdet.landMark = gApzCOB.customerDetails.addrdet["addressList"][0].landMark
                        gApzCOB.customerDetails.addrdet.pinCode = gApzCOB.customerDetails.addrdet["addressList"][0].pinCode
                        gApzCOB.customerDetails.addrdet.state = gApzCOB.customerDetails.addrdet["addressList"][0].state
                        ApzCOB.stateDropDown(EmpDetscrId, 'state');
                        apz.app.EmploymentDetails.getStateCityValueforDropdown();
                        apz.setElmValue(EmpDetscrId + "state", stateVal[stateDesc.indexOf(gApzCOB.customerDetails.addrdet.state)]);
                        apz.setElmValue(EmpDetscrId + "city", cityVal[cityDesc.indexOf(gApzCOB.customerDetails.addrdet.city)]);
                        $("#" + EmpDetscrId + "addressLine1").val(gApzCOB.customerDetails.addrdet.addressLine1);
                        $("#" + EmpDetscrId + "addressLine2").val(gApzCOB.customerDetails.addrdet.addressLine2);
                        $("#" + EmpDetscrId + "landMark").val(gApzCOB.customerDetails.addrdet.landMark);
                        $("#" + EmpDetscrId + "pin").val(gApzCOB.customerDetails.addrdet.pinCode);
                        $("#" + EmpDetscrId + "doorNo").val(gApzCOB.customerDetails.addrdet.doorNum);
                    }
                }
            })
        }
        apz.app.EmploymentDetails.LoadOccupationDetails();
    }
    apz.app.EmploymentDetails.LoadDropDownValues();
}
apz.app.EmploymentDetails.LoadOccupationDetails = function() {
    if (!apz.isObjectEmpty(gApzCOB.customerDetails.occupationDetails)) {
        gApzCOB.customerDetails.occupationDet = JSON.parse(gApzCOB.customerDetails.occupationDetails['payloadColumn'])
        $("#" + EmpDetscrId + "profession").val(gApzCOB.customerDetails.occupationDet.occupationType);
        $("#" + EmpDetscrId + "employerName").val(gApzCOB.customerDetails.occupationDet.employer);
        $("#" + EmpDetscrId + "employeeId").val(gApzCOB.customerDetails.occupationDet.employeeId);
        $("#" + EmpDetscrId + "designation").val(gApzCOB.customerDetails.occupationDet.designation);
        $("#" + EmpDetscrId + "currentBusinessYrs").val(gApzCOB.customerDetails.occupationDet.employeeSince);
        $("#" + EmpDetscrId + "annualIncome").val(gApzCOB.customerDetails.occupationDet.annualIncome);
        $("#" + EmpDetscrId + "grossIncome").val(gApzCOB.customerDetails.occupationDet.grossIncome);
        $("#" + EmpDetscrId + "monthlyTakeHome").val(gApzCOB.customerDetails.occupationDet.netTakeHome);
        $('#' + EmpDetscrId + "companyEmail").val(gApzCOB.customerDetails.occupationDet.officeEmail);
        $('#' + EmpDetscrId + "landlineNo").val(gApzCOB.customerDetails.occupationDet.officePhone);
        $("#" + EmpDetscrId + "yrsOfExp").val(gApzCOB.customerDetails.occupationDet.experience.split(' ')[0]);
        $("#" + EmpDetscrId + "monOfExp").val(gApzCOB.customerDetails.occupationDet.experience.split(' ')[2]);
    }
}
apz.app.EmploymentDetails.LoadDropDownValues = function() {
    if ($("#" + EmpDetscrId + "designation").val() === '') {
        $("#" + EmpDetscrId + "designation").val(PleaseSelect);
    }
    if ($("#" + EmpDetscrId + "profession").val() === '') {
        $("#" + EmpDetscrId + "profession").val(PleaseSelect);
    }
}
apz.app.EmploymentDetails.LoadEmpAddrIndex = function() {
    if (window.pendingApplication) {
        window.EMP_ADDRESS = [];
        window.EMP_ADDRESS_SAVE = [];
        var obj = {
            "addressDetailsList": []
        };
        obj.addressDetailsList.push(curAddrDetails[0]['addressDetailsList'][arrIndex])
        EMP_ADDRESS.push(obj);
        window.EMP_ADDRESS_SAVE.push(obj);
    }
}
apz.app.EmploymentDetails.onLoadCollapseAll = function() {
    if (gApzCOB.currentApplicant > 1 && gApzCOB.userDetails.insurenceReqForCoApp !== 'Yes') {
        occDetFlag = true;
        $(occDetId).removeClass('sno');
        $(`#${EmpDetscrId}gr_row_8`).addClass('active');
    } else {
        disabilityFlag = true;
        $(disabDetId).removeClass('sno');
        //insLoanFlag = true;
        //$(insDetId).removeClass('sno');
        $(`#${EmpDetscrId}gr_row_2`).addClass('active');
    }
    $(insDetId).addClass('sno');
    $(bankDetId).addClass('sno');
    $(offAddrId).addClass('sno');
    $(`#${EmpDetscrId}gr_row_2`).removeClass('active');
    $(`#${EmpDetscrId}gr_row_5`).removeClass('active');
    $(`#${EmpDetscrId}gr_row_11`).removeClass('active');
}
apz.app.EmploymentDetails.onclickDisa = function(pthis) {
    if ($(disabDetId).is(":visible")) {
        $(disabDetId).addClass("sno");
