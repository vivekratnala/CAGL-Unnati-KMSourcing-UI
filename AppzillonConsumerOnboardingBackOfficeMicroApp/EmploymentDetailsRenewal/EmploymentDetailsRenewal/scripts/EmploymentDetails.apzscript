                $(`#${EmpDetscrId}disabilityImparirment_err_div`).removeClass("sno");
                return false;
            }
            if ($(`#${EmpDetscrId}percentageOfImp`).val() > 100 || $(`#${EmpDetscrId}percentageOfImp`).val().length == 0) {
