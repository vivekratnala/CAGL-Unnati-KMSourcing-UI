    if ($('#' + BaseScrId + 'backIcon').hasClass('sno')) {
        $('#' + EmpDetscrId + 'OccupationDetailsHeader').addClass('var1')
    }
    $('#' + EmpDetscrId + 'currentBusinessYrs').datepicker("option", "maxDate", Date.parse(DATE_TODAY));
    $('#' + EmpDetscrId + 'currentBusinessYrs').datepicker("option", "yearRange", "-100:+0");
    $('#' + EmpDetscrId + 'dobNominee').datepicker("option", "maxDate", Date.parse(DATE_TODAY));
    $('#' + EmpDetscrId + 'dobNominee').datepicker("option", "yearRange", "-100:+0");
    $('#' + EmpDetscrId + 'busiEmpStartDatInput').datepicker("option", "maxDate", Date.parse(DATE_TODAY));
