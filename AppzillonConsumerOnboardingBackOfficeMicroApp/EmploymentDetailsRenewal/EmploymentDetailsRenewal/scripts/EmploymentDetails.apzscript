//onload function
apz.app.onLoad_EmploymentDetails = function() {
    custType = gApzCOB.currentApplicant == 1 ? 'Applicant' : 'Co-App';
    apz.app.BaseScreens.contactus();
    apz.app.BaseScreens.hideNshowbackIcon();
    apz.app.EmploymentDetails.onLoadCollapseAll();
    if (apz.isNull(gStates)) {
        ApzCOB.FetchStates();
    } else {
        ApzCOB.stateDropDown(EmpDetscrId, 'state');
        ApzCOB.citydropDown(EmpDetscrId, "state", "city");
    }
    $('#' + EmpDetscrId + 'wsh_nominee').attr('disabled', true)
    var nominee = STAGES.filter(function(e) {
        return e.split('~')[0] === "NOMINEEDETAILS"
    })
    if (nominee.length > 0) {
        addNomineeDetails = 'Y'
        $('#' + EmpDetscrId + 'wsh_nominee').prop('checked', true)
    } else {
        addNomineeDetails = 'N'
        $('#' + EmpDetscrId + 'wsh_nominee').prop('checked', false)
    }
    $('#' + EmpDetscrId + 'profession').val(gApzCOB.selLeadDtls.occupation);
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'designation'), ApzCOB.formatDropDownforArray(designation));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'relationWithNominee'), ApzCOB.formatDropDownforArray(ApzCOB.filterRelns(nomineeRel)));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'typeOfEmployer'), ApzCOB.formatDropDownforArray(typeOfEmp));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'retirementAge'), ApzCOB.formatDropDownforArray(retirementAge));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'profession'), ApzCOB.formatDropDownforArray(natureOfEmp));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'currentBusinessYrs'), ApzCOB.formatDropDownforArray(resMn));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'currentBusinessMonths'), ApzCOB.formatDropDownforArray(resMn));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'prevBusinessYrs'), ApzCOB.formatDropDownforArray(resMn));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'prevBusinessMonths'), ApzCOB.formatDropDownforArray(resMn));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'yrsOfExp'), ApzCOB.formatDropDownforArray(resMn));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'monOfExp'), ApzCOB.formatDropDownforArray(resMn));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'typbssEmpent'), ApzCOB.formatDropDownforArray(typbssEmpent));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'bssEmpAcc'), ApzCOB.formatDropDownforArray(businessActivity));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'bssAddrProof'), ApzCOB.formatDropDownforArray(bssAddrProof));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'empProof'), ApzCOB.formatDropDownforArray(empProof));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'bssPerOwn'), ApzCOB.formatDropDownforArray(bssPerOwn));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'freqOfInc'), ApzCOB.formatDropDownforArray(freqOfInc));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'othSrcInc'), ApzCOB.formatDropDownforArray(othSrcInc));
    apz.populateDropdown(document.getElementById(EmpDetscrId + 'typeOfAcc'), ApzCOB.formatDropDownforArray(accTypes));
    // $('#APZCBO__BaseScreens__continue').attr('disabled', true);
    ApzCOB.addDisableToInput('APZCBO__BaseScreens__continue');
    ['disbDown', 'insurUp', "bankUp", "occupUp", "officeUp"].hide();
    if (apz.deviceType === "WEB") {
        $('#EmpDRE__EmploymentDetails__browseHyp_txtcnt').text('Browse');
    } else {
        $('#EmpDRE__EmploymentDetails__browseHyp_txtcnt').text('Capture');
    }
    $(`#${EmpDetscrId}profession`).change();
}
//on shown function
apz.app.onShown_EmploymentDetails = function() {
    if (gApzCOB.currentApplicant <= 1) {
        ApzCOB.showSubHeader("LIT_EMPLOYMENT_DETAILS_HEADER");
    } else {
        $(`#${EmpDetscrId}el_label_1`).html('Is Co-Applicant Disable');
        ApzCOB.showSubHeader("LIT_EMPLOYMENT_DETAILS_HEADER_CO_APP");
    }
    window.scroll(0, 0);
    ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], false);
    window.bankdocProofObj = {
        "BankProof": []
    };
