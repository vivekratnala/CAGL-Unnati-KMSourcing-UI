        return e.MicroAppID === apz.currAppId && window.allowedUnSave.indexOf(apz.currAppId) !== -1
    })[0].requestFunc.split('.');
    window.beforeBack = window[curFuncToExe[0]][curFuncToExe[1]][curFuncToExe[2]][curFuncToExe[3]]('triggerdSave');
    window.inSessionStoreEnabled = false; //dont save by default, ask everytime
    window.afterBack = {};
    if (gApzCOB.product === "LOAN" || gApzCOB.product === "CARDS") {
        apz.app.EmploymentDetails.paintLoanEmpDetails();
    }
    $('#' + EmpDetscrId + 'currentBusinessYrs').attr('placeholder', apz.dateFormat);
    // ApzCOB.showLanguageSelect();
    apz.app.EmploymentDetails.hideAndShowBankDetailsSec();
    if (!backNav) {
        apz.app.EmploymentDetails.onShownPaintDetails();
    }
    if (gApzCOB.applicationType !== 'Single Account') {
        if (gApzCOB.currentApplicant > 1) {
            $('#' + EmpDetscrId + 'coapplicInsRow').addClass('sno');
        } else {
            $('#' + EmpDetscrId + 'coapplicInsRow').removeClass('sno');
        }
    } else {
        $('#' + EmpDetscrId + 'coapplicInsRow').addClass('sno');
    }
    let accType = "";
    let custData = [];
    if(gApzCOB.currentApplicant <= 1) {
      custData =   inSessionStore.customerDetailsList.filter(cust => parseInt(cust.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId) &&  cust.customerType.toLocaleLowerCase() === 'applicant')
    } else {
        custData =   inSessionStore.customerDetailsList.filter(cust => parseInt(cust.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId) && cust.customerType.toLocaleLowerCase() !== 'applicant')
    }
    if (custData.length > 0) {
        accType = custData[0].payload.occupation;
        apz.app.EmploymentDetails.setAnnualIncomeValue();
    }
    if (accType == 'Salaried') {
        //$('#' + EmpDetscrId + 'bssAddrProofRow').addClass('sno');
        $('#' + EmpDetscrId + 'empProofRow').removeClass('sno');
    } else {
        $('#' + EmpDetscrId + 'empProofRow').addClass('sno')
    }
    var applicantOccupation = custData[0].payload.occupation;
    if (applicantOccupation === 'Salaried') {
        $('#' + EmpDetscrId + 'el_txt_25').text('Office Address Details');
    } else {
        $('#' + EmpDetscrId + 'el_txt_25').text('Business Address Details');
    }
    if (accType == 'Self Employed') {
        //$('#' + EmpDetscrId + 'bssAddrProofRow').removeClass('sno');
        $('#' + EmpDetscrId + 'empProofRow').addClass('sno');
        $('#' + EmpDetscrId + 'bssPerOwnRow').removeClass('sno');
        $('#' + EmpDetscrId + 'streetVendorDiv').removeClass('sno');
    } else {
        $('#' + EmpDetscrId + 'streetVendorDiv').addClass('sno');
        $('#' + EmpDetscrId + 'bssPerOwnRow').addClass('sno')
    }
    // if (accType == 'Homemaker') {
    //     $('#' + EmpDetscrId + 'typBssEmpentRow').addClass('sno');
    //     $('#' + EmpDetscrId + 'bssEmpAcctRow').addClass('sno');
    //     $('#' + EmpDetscrId + 'bssAddrProofRow').addClass('sno');
