apz.app.PreviewCA.previewInformalLoanObligation = function() {
    let loanObgdata = JSON.parse(inSessionStore?.bcmpiLoanObligations?.payload);
    let removeTloanObgkey = delete loanObgdata.totalLoanObligations;
    let loanObgkeys = Object.keys(loanObgdata).toString();
    $(`#${PreviewCAscrId}SrcInfrmlObg_txtcnt`).text(loanObgkeys);
    if (apz.isNull(loanObgkeys)) {
        $(`#${PreviewCAscrId}previewSrcInfrmlObg_txtcnt`).text("Nill");
    } else {
        $(`#${PreviewCAscrId}previewSrcInfrmlObg_txtcnt`).text(loanObgkeys);
    }
    let nilflag = true;
    if (loanObgdata.hasOwnProperty('chitFunds')) {
        nilflag = false;
        $(`#${PreviewCAscrId}RechitFund`).removeClass('sno')
        $(`#${PreviewCAscrId}othrLoanObgchit_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.chitFunds?.otherLoanObligation))
        $(`#${PreviewCAscrId}chitmntlyEMI_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.chitFunds?.monthlyEMI))
        $(`#${PreviewCAscrId}chitremainTenure_txtcnt`).text(loanObgdata?.chitFunds?.tenure)
        $(`#${PreviewCAscrId}chitsrcOfloanVal`).text("chitFunds");
    } else {
        $(`#${PreviewCAscrId}RechitFund`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('moneyLender')) {
        nilflag = false;
        $(`#${PreviewCAscrId}RemoneyLender`).removeClass('sno')
        $(`#${PreviewCAscrId}mnylndrLoanval_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.moneyLender?.otherLoanObligation))
        $(`#${PreviewCAscrId}mnyLndrEMI_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.moneyLender?.monthlyEMI))
        $(`#${PreviewCAscrId}mnyLndrTenure_txtcnt`).text(loanObgdata?.moneyLender?.tenure)
        $(`#${PreviewCAscrId}mnyLndrsrc`).text("Money lender");
    } else {
        $(`#${PreviewCAscrId}RemoneyLender`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('Friends')) {
        nilflag = false;
        $(`#${PreviewCAscrId}Refriends`).removeClass('sno')
        $(`#${PreviewCAscrId}frndothrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Friends?.otherLoanObligation))
        $(`#${PreviewCAscrId}frndEMImtly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Friends?.monthlyEMI))
        $(`#${PreviewCAscrId}frndremainTnur_txtcnt`).text(loanObgdata?.Friends?.tenure)
        $(`#${PreviewCAscrId}frndSrcloan`).text("Friends");
    } else {
        $(`#${PreviewCAscrId}Refriends`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('Relatives')) {
        nilflag = false;
        $(`#${PreviewCAscrId}Rerelatives`).removeClass('sno')
        $(`#${PreviewCAscrId}rltvothrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Relatives?.otherLoanObligation))
        $(`#${PreviewCAscrId}rltvEMImntly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Relatives?.monthlyEMI))
        $(`#${PreviewCAscrId}rltvremainTnur_txtcnt`).text(loanObgdata?.Relatives?.tenure)
        $(`#${PreviewCAscrId}rltvSrcloan`).text("Relatives");
    } else {
        $(`#${PreviewCAscrId}Rerelatives`).addClass('sno')
    }
    if (loanObgdata?.hasOwnProperty('Coopsociety')) {
        $(`#${PreviewCAscrId}RecoopSociety`).removeClass('sno')
        $(`#${PreviewCAscrId}sctyothrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Coopsociety?.otherLoanObligation))
        $(`#${PreviewCAscrId}sctyEMImntly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Coopsociety?.monthlyEMI))
        $(`#${PreviewCAscrId}sctyremaintnur_txtcnt`).text(loanObgdata?.Coopsociety?.tenure)
        $(`#${PreviewCAscrId}sctySrcloan`).text("Co-op society");
    } else {
        $(`#${PreviewCAscrId}RecoopSociety`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('Localfinance')) {
        nilflag = false;
        $(`#${PreviewCAscrId}RelocalFinance`).removeClass('sno')
        $(`#${PreviewCAscrId}lfinothrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Localfinance?.otherLoanObligation))
        $(`#${PreviewCAscrId}lfinEMImntly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Localfinance?.monthlyEMI))
        $(`#${PreviewCAscrId}lfinremainTnur_txtcnt`).text(loanObgdata?.Localfinance?.tenure)
        $(`#${PreviewCAscrId}lfinSrcloan`).text("Local finance");
    } else {
        $(`#${PreviewCAscrId}RelocalFinance`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('Other')) {
        nilflag = false;
        $(`#${PreviewCAscrId}ReOthers`).removeClass('sno')
        $(`#${PreviewCAscrId}othrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Other?.otherLoanObligation))
        $(`#${PreviewCAscrId}othrEMImntly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Other?.monthlyEMI))
        $(`#${PreviewCAscrId}othrremainTnur_txtcnt`).text(loanObgdata?.Other?.tenure)
        $(`#${PreviewCAscrId}othrLoanSrc`).text("Other");
    } else {
        $(`#${PreviewCAscrId}ReOthers`).addClass('sno')
    }
    if (nilflag) {
        $(`#${PreviewCAscrId}ReNill`).removeClass('sno')
        $(`#${PreviewCAscrId}nilSrcLoan`).text("Nil other loan obligations");
    } else {
        $(`#${PreviewCAscrId}ReNill`).addClass('sno')
    }
}
