apz.app.PreviewCA.paintBusinessData = function() {
    let businessDtls = incomeDtls?.business;
    let dairyData = incomeDtls?.business?.dairy;
    let kiranaData = incomeDtls?.business?.Kirana;
    let tailoringData = incomeDtls?.business?.Tailoring;
    let otherData = incomeDtls?.business?.Other;
    let businessKeys = Object.keys(businessDtls).toString();
    let businessKeysArray = businessKeys.split(",");
    businessCounter = 1;
    if (businessDtls.hasOwnProperty('dairy') && dairyData.length !== 0) {
        $(`#${PreviewCAscrId}businessdairyRow`).removeClass('sno');
        dairyData.forEach(function(item, index) {
            if (index > 0) {
                ApzCOB.cloneDashboardDivs('cmnPre__PreviewCA__businessSub_0', $(
                    '#cmnPre__PreviewCA__businessdairyCol'), index.toString());
            }
            let dairyKey = businessKeysArray.find(key => key === "dairy");
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairyHeading_txtcnt`).text(
                `Business ${businessCounter}`);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairybuisnessType1_txtcnt`).text(
                dairyKey);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairyownedBy1_txtcnt`).text(item
                ?.DairyType);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairytotalNumberOfProducts1_txtcnt`)
                .text(item?.totalCowsAndBuffalos);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairynetBuisnessAmt1_txtcnt`).text(ApzCOB.formatamountVal(item.IncomeAssessmentChecknetBusinessIncome));
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairytitle_txtcnt`).text(ApzCOB
                .getDescfromLitCode("LIT_dairyBusApp") + ' - ' + item?.DairyType);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairyappbusinessLocation_txtcnt`)
                .text(item?.dairyLocation);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairyappbusinessTenure_txtcnt`).text(
                item?.dairyTenure);
            const cowBreeds = [item?.cowBreed1, item?.cowBreed2, item?.cowBreed3].filter(breed => breed?.trim()).join(', ');
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairycowBreedVal_txtcnt`).text(
                cowBreeds);
            const buffaloBreeds = [item?.buffaloBreed1, item?.buffaloBreed2, item?.buffaloBreed3].filter(b => b?.trim()).join(', ');
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairybuffaloBreed_txtcnt`).text(
                buffaloBreeds);
            const buffaloCounts = [item?.noOfBuffaloBreed1, item?.noOfBuffaloBreed2, item?.noOfBuffaloBreed3].filter(c => c?.toString()
                .trim()).join(', ');
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairybuffaloCount_txtcnt`).text(
                buffaloCounts);
            const cowCounts = [item?.noOfCowBreed1, item?.noOfCowBreed2, item?.noOfCowBreed3].filter(c => c?.toString().trim()).join(
            ', ');
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairynoOfCows_txtcnt`).text(
            cowCounts);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairymntlyIncome_txtcnt`).text(ApzCOB.formatamountVal(item?.netMonthlyIncome));
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairyappBusiPermisesValue_txtcnt`)
                .text(item.businessAddressSameAsResidance);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairybusinessTypeValue_txtcnt`).text(
                item?.dairyBusinessType);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairyorganisationValue_txtcnt`).text(
                item?.organizationName);
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairycowrevenueVal_txtcnt`).text(ApzCOB.formatamountVal(item?.avgDailyRevenuePerCow));
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairybuffalorevenueVal_txtcnt`).text(
                ApzCOB.formatamountVal(item?.avgDailyRevenuePerBuffalo));
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairycowMntlyInc_txtcnt`).text(ApzCOB.formatamountVal(item?.avgMonthlyRevenuePerCow));
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairybuffaloMntlyInc_txtcnt`).text(
                ApzCOB.formatamountVal(item?.avgMonthlyRevenuePerBuffalo));
            $(`#cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__dairynetBusinessCal_txtcnt`).text(ApzCOB.formatamountVal(item?.IncomeAssessmentChecknetBusinessIncome));
            custTypeInPrinciple = item?.DairyType;
            apz.app.PreviewCA.paintDocumentName(
                `cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__DairyUploadedImage_0`,
                `cmnPre__PreviewCA__businessSub_${index} #cmnPre__PreviewCA__Dairy_ParentBusRow`, "Dairy Doc");
            businessCounter++;
        })
    } else {
        $(`#${PreviewCAscrId}businessdairyRow`).addClass('sno');
    }
    if (businessDtls.hasOwnProperty('Kirana') && kiranaData.length !== 0) {
