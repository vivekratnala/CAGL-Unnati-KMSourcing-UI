            $(`#cmnPre__PreviewCA__tailoringSub_${index} #cmnPre__PreviewCA__tailorNetBusiness_txtcnt`).text(ApzCOB.formatamountVal(item?.netBusinessIncome));
            custTypeInPrinciple = item?.tailoringType;
            apz.app.PreviewCA.paintDocumentName(
