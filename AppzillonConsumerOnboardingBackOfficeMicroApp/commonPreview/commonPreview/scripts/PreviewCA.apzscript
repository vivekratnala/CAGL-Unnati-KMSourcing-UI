    $(`#${PreviewCAscrId}otherDetailsNooffamMem_txtcnt`).text(othDtls?.noOfFamilyMembers);
    $(`#${PreviewCAscrId}otherdetailEarningMem_txtcnt`).text(othDtls?.noOfOtherEarningMembers);
    $(`#${PreviewCAscrId}otherDetailsBasicAmenitie_txtcnt`).text(othDtls.basicAmenities);
    $(`#${PreviewCAscrId}otherDetailsAssets_txtcnt`).text(othDtls.otherAssets);
    $(`#${PreviewCAscrId}otherDetailsNoOf2Wheeler_txtcnt`).text(othDtls?.noOfTwoWheelerOwned)
    $(`#${PreviewCAscrId}otherDetailsIfSmartphone_txtcnt`).text(othDtls?.smartphoneRadio)
    $(`#${PreviewCAscrId}otherDetailsNoOfSmartPhones_txtcnt`).text(othDtls?.smartphonesOwned)
    $(`#${PreviewCAscrId}otherDetailsAnyAlmirah_txtcnt`).text(othDtls?.almirah)
    $(`#${PreviewCAscrId}otherDetailsAnyFurniture_txtcnt`).text(othDtls?.chair)
    $(`#${PreviewCAscrId}otherDetailsSavingModes_txtcnt`).text(othDtls?.modeOfSavings)
    $(`#${PreviewCAscrId}otherExpensesFood_txtcnt`).text(othDtls?.foodExpense)
    $(`#${PreviewCAscrId}otherExpensesEducation_txtcnt`).text(othDtls?.educationExpense)
    $(`#${PreviewCAscrId}otherExpensesCloth_txtcnt`).text(othDtls?.expenseOnClothing)
    $(`#${PreviewCAscrId}otherExpensesMedical_txtcnt`).text(othDtls?.medicalExpense);
    $(`#${PreviewCAscrId}otherExpensesHosueHolds_txtcnt`).text(othDtls?.householdExpenses)
    $(`#${PreviewCAscrId}LandDetailsAgri_txtcnt`).text(othDtls?.agriland)
    $(`#${PreviewCAscrId}LandDetailsHoldBy_txtcnt`).text(othDtls?.landOwnerName)
    $(`#${PreviewCAscrId}LandDetailsRelationship_txtcnt`).text(othDtls?.relationshipWithApplicant);
