window.PreviewCAscrId = 'cmnPre__PreviewCA__';
window.CURRENTSCREEN = "PreviewCA";
var imageIDs = [];
var lobj = {};
var businessCounter = 1;
var imgIndex = 0;
var imgArray = [];
apz.app.onLoad_PreviewCA = function() {
    // $('body').addClass(' unati crdas dbkit ');
    window.CAloandetails = inSessionStore.loanDetails;
    window.applicationMaster = inSessionStore.applicationMaster;
    window.CAleadetails = inSessionStore.leadDetails;
    window.CArenewalLeadDetails = inSessionStore.renewalLeadDetails;
}
apz.app.onShown_PreviewCA = function() {
    $(`#${PreviewCAscrId}PreviewCADtls`).addClass('active');
    $('.careviewconf').removeClass('sno');
    apz.app.PreviewCA.Previewloandetails(); // Loan Details
    apz.app.PreviewCA.previewInsuranceDetails();
    apz.app.PreviewCA.previewPhotoKyc(); // Photo Kyc
    apz.app.PreviewCA.previewAddressContact(); // Address Contact
    apz.app.PreviewCA.previewIncomeDetails(); // Income Details
    apz.app.PreviewCA.previewInformalLoanObligation(); // Informal Loan Obligation
    apz.app.PreviewCA.previewOtherDetails(); // Other Details
    apz.app.PreviewCA.paintNetIncome();
    $('#cmnPre__PreviewCA__docViewModal_close').on('click', function() {
        apz.childScr = window.previousScreenId;
        apz.currAppId = window.previousMicroAppId;
    });
}

apz.app.PreviewCA.Previewloandetails = function() {
    let sourcingDate = window.applicationMaster?.createTs?.date?.day + '/' + String(window.applicationMaster?.createTs?.date?.month).padStart(2, '0') +'/' + window.applicationMaster?.createTs?.date?.year;
    $("#cmnPre__PreviewCA__Appliedamount_txtcnt").text(window.CAloandetails?.loanAmount);
    $("#cmnPre__PreviewCA__Repaymentfrequency_txtcnt").text(window.CAloandetails?.payload?.frequencyOfRepayment);
    $("#cmnPre__PreviewCA__Loantenure_txtcnt").text(window.CAloandetails?.tenure);
    $(`#${PreviewCAscrId}Sourcingdate`).text(!sourcingDate ||sourcingDate === 'undefined/undefined/undefined' ? '---' : sourcingDate);
    if (inSessionStore.hasOwnProperty('leadDetails')) {
        $("#cmnPre__PreviewCA__Kendrameetingfrequency").text(window.CAleadetails.kendraMeetingFreq);
        $("#cmnPre__PreviewCA__Kendrameetingday_txtcnt").text(KendraMeetingDays.filter(el => el?.slice(0, 3)?.toUpperCase() === window
            .CAleadetails?.kendraMeetingDay?.toUpperCase())?.[0]);
        $("#cmnPre__PreviewCA__KendramanagerID_txtcnt").text(window.applicationMaster.createdBy);
    } else if (inSessionStore.hasOwnProperty('renewalLeadDetails')) {
        $("#cmnPre__PreviewCA__Kendrameetingfrequency").text(window.CArenewalLeadDetails.kendraMeetingFreq);
        $("#cmnPre__PreviewCA__Kendrameetingday_txtcnt").text(KendraMeetingDays.filter(el => el?.slice(0, 3)?.toUpperCase() === window
            .CArenewalLeadDetails?.kendraMeetingDay?.toUpperCase())?.[0]);
        $("#cmnPre__PreviewCA__KendramanagerID_txtcnt").text(window.applicationMaster.createdBy);
    }
    if (!apz.isNull(CAloandetails.payload.loanPurpose)) {
        $("#cmnPre__PreviewCA__Purposeofloan_txtcnt").text(window.CAloandetails?.payload?.loanPurpose);
        $("#cmnPre__PreviewCA__Subpurpose_txtcnt").text(window.CAloandetails?.payload?.subCategory);
    }
};

apz.app.PreviewCA.previewPhotoKyc = function() {
    apz.app.PreviewCA.fetchImageIds();
}
apz.app.PreviewCA.fetchImageIds = function() {
    imgArray = [];
    imgIndex = 0;
    imageIDs = document.querySelectorAll(".kycdocs img")
    Array.from(imageIDs).forEach(img => {
        let obj = {};
        obj.custType = img.id.split('__')[2];
        obj.docType = img.id.split('__')[3];
        obj.ActualdocType = img.id.split('__')[3];
        if (apz.childScr == "AddressContactus") {
            let custDetailID;
            if (obj.custType === 'A') {
                custDetailID = gApzCOB.userDetails.custDtlId;
            } else {
                custDetailID = gApzCOB.userDetails.CoApplicantCustomerId;
            }

            const addressList = inSessionStore.addressDetailsWrapperList[0]
                .addressDetailsList
                .find(custAdd => custAdd.addressType === "Personal" && custAdd.custDtlId == custDetailID)
                ?.payload?.addressList || [];

            const currentAddressProof = addressList.find(item => item.addressType == "Present")?.currentAddressProof?.toLowerCase() ?? "";

            if (["as per voter id", "as per kyc"].includes(currentAddressProof)) {
                obj.docType = "PRIMARY_KYC";
            }
        }
        imgArray.push(obj);
    });
    imgArray = imgArray.filter(obj => obj.docType);
    if (imgArray.length > 0) {
        apz.app.paintDocuments(imgArray[imgIndex].custType, imgArray[imgIndex].docType, imgArray[imgIndex].ActualdocType);
    }
}

apz.app.paintDocuments = function(custType, docType, ActualdocType) {
    let custDetailID
    if (custType === 'A') {
        custDetailID = gApzCOB.userDetails.custDtlId;
    } else {
        custDetailID = gApzCOB.userDetails.CoApplicantCustomerId
    }
    if (docType == "ADDRESS_PROOF") {
        let addressList = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.filter((custAdd) => custAdd.addressType === "Personal" &&
            custAdd.custDtlId == custDetailID)[0].payload.addressList;
        let currentAddressProof = addressList.filter(item => item.addressType == "Present")[0]?.currentAddressProof.toLocaleLowerCase() ?? "";
        if (currentAddressProof == "as per voter id" || currentAddressProof == "as per kyc") {
            docType = "PRIMARY_KYC";
        }
    }
    let applicationData = [];
    applicationData = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList?.filter(cust => cust.custDtlId ===
        custDetailID) || [];
    if (!Array.isArray(applicationData) || applicationData.length === 0) {
        ApzCOB.fnDisplayMsg("File not found", "E");
    } else {
        applicationData.forEach(appDoc => {
            if (appDoc.payload.documentType === docType && appDoc.payload.docLevel === '1') {
                lobj.custType = custType;
                lobj.docType = docType;
                lobj.documentName = appDoc.payload.documentName;
                lobj.docLevel = appDoc.payload.docLevel;
                lobj.documentFileName = appDoc.payload.documentFileName;
                lobj.actualdocType = ActualdocType;
                window.ImageLocationDetails = {
                    latitude:  appDoc.payload.latitude || "",
                    longitude:  appDoc.payload.longitude || "",
                    uploadedTs:  appDoc.payload.uploadedTs || "",
                    documentFileName:  appDoc.payload.documentFileName || ""
                };
            }
        });
        ApzCOB.downloadFileFromServer(lobj.documentFileName, apz.app.paintDocumentsCB);
    }
};
apz.app.paintDocumentsCB = function(params) {
    apz.stopLoader();
    let imgPaintId;
    if (CURRENTSCREEN === "photokyc") {
        imgPaintId = "cmnPre__photokyc__";
    } else if (CURRENTSCREEN === "AddressContactus") {
        imgPaintId = "cmnPre__AddressContactus__";
    } else if (CURRENTSCREEN === "PreviewCA") {
        imgPaintId = "cmnPre__PreviewCA__";
    }
    if (!apz.isNull(params.base64)) {
        $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}`).attr('src', 'data:image/png;base64,' + params.base64);
        let id = `#${imgPaintId}${lobj.custType}__${lobj.actualdocType}`;
        if (Object.keys(window.ImageLocationDetails).length > 0) {
            apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
        };
        $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}`).attr("documentName", `${lobj.documentName}`);
        $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}`).attr("docLevel", `${lobj.docLevel}`);
        switch (CURRENTSCREEN) {
            case "photokyc":
                if (lobj.custType === "A" && lobj.docType === "PRIMARY_KYC") {
                    $("#cmnPre__photokyc__el_txt_3_txtcnt").text(lobj.documentName);
                } else if (lobj.custType === "C" && lobj.docType === "PRIMARY_KYC") {
                    $("#cmnPre__photokyc__el_txt_21_txtcnt").text(lobj.documentName);
                } else if (lobj.custType === "A" && lobj.docType === "RELATIONSHIP_PROOF") {
                    $("#cmnPre__photokyc__el_txt_13_txtcnt").text(lobj.documentName);
                } else {}
                break;
            case "AddressContactus":
                if (lobj.custType === "A" && (lobj.docType === "ADDRESS_PROOF" || lobj.docType === "PRIMARY_KYC")) {
                    $("#cmnPre__AddressContactus__el_txt_38_txtcnt").text(lobj.documentName);
                }
                break;
            case "PreviewCA":
                if (lobj.custType === "A" && lobj.docType === "PRIMARY_KYC") {
                    $("#cmnPre__PreviewCA__el_txt_315_txtcnt").text(lobj.documentName);
                } else if (lobj.custType === "C" && lobj.docType === "PRIMARY_KYC") {
                    $("#cmnPre__PreviewCA__el_txt_334_txtcnt").text(lobj.documentName);
                } else if (lobj.custType === "A" && lobj.docType === "RELATIONSHIP_PROOF") {
                    $("#cmnPre__PreviewCA__el_txt_335_txtcnt").text(lobj.documentName);
                } else if (lobj.custType === "A" && lobj.docType === "ADDRESS_PROOF") {
                    $("#cmnPre__PreviewCA__el_txt_345_txtcnt").text(lobj.documentName);
                }
                break;
        }
    } else {
        ApzCOB.fnDisplayMsg("File not found", "E");
    }
    imgIndex++;
    if (imgIndex < imgArray.length) {
        apz.app.paintDocuments(imgArray[imgIndex].custType, imgArray[imgIndex].docType, imgArray[imgIndex].ActualdocType);
    }
}

apz.app.PreviewCA.previewAddressContact = function() {
    let addressDetails;
    let permanentDetails;
    if (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.length > 0 && inSessionStore.customerDetailsList.length > 0) {
        inSessionStore.addressDetailsWrapperList[0].addressDetailsList.forEach(type => {
            if (type.addressType === "Personal" && type.custDtlId === gApzCOB.userDetails.custDtlId) {
                type.payload.addressList.forEach(address => {
                    if (address.addressType === "Present") {
                        addressDetails = address;
                        $(`#${PreviewCAscrId}A_present_address`).text(
                            `${addressDetails.addressLine1}, ${addressDetails.area}, ${addressDetails.city} - ${addressDetails.pinCode}, ${addressDetails.country}`
                        );
                    } else if (address.addressType === "Permanent") {
                        permanentDetails = address;
                        if (address.addressSameAs === 'Y') {
                            $(`#${PreviewCAscrId}A_permanent_address`).text("Same as present address");
                        } else {
                            $(`#${PreviewCAscrId}A_permanent_address`).text(
                                `${permanentDetails.addressLine1}, ${permanentDetails.area}, ${permanentDetails.city} - ${permanentDetails.pinCode}, ${permanentDetails.country}`
                            );
                        };
                    }
                });
            }
        });
        const applicant = inSessionStore.customerDetailsList.find(c => c.customerType === "Applicant");
        $(`#${PreviewCAscrId}A_mobilenumber`).text(applicant?.mobileNumber || "");
        $(`#${PreviewCAscrId}A_residence_ownership_txtcnt`).text(addressDetails.residenceOwnership);
        $(`#${PreviewCAscrId}A_residence_stability_txtcnt`).text(addressDetails.residenceAddressSince);
        $(`#${PreviewCAscrId}A_residence_stabilit_present_city_txtcnt`).text(addressDetails.residenceCitySince);
    }
}
apz.app.PreviewCA.previewInsuranceDetails = function() {
    let applicantInsuranceDetails = [];
    let coAppInsuranceDetails = [];
    let jointInsuranceDetails = [];
    let loanAmt = Number(inSessionStore?.loanDetails?.loanAmount);
    if (loanAmt > 200000) {
        loanAmt = 200000
    }
    if (Array.isArray(inSessionStore?.insuranceDetailsWrapperList) && inSessionStore.insuranceDetailsWrapperList.length > 0) {
        inSessionStore.insuranceDetailsWrapperList.forEach((item) => {
            let insuredName = item.insuranceDetails?.payload?.insuredName;
            if (insuredName === "Applicant") {
                applicantInsuranceDetails = item.insuranceDetails;
            } else if (insuredName === "Co-App") {
                coAppInsuranceDetails = item.insuranceDetails;
            } else if (insuredName === "Joint") {
                jointInsuranceDetails = item.insuranceDetails;
            }
        });
    }
    if (applicantInsuranceDetails?.payload?.insuranceOption === "Applicant") {
        $(`#${PreviewCAscrId}insType`).text("Applicant")
        $(`#${PreviewCAscrId}totalInsPremium`).text(applicantInsuranceDetails?.payload?.insurancePremium);
        $(`#${PreviewCAscrId}A_sumAssuredInput`).text(loanAmt)
        $(`#${PreviewCAscrId}A_nameOfInsurerInput`).text(applicantInsuranceDetails?.payload?.insurerName)
        $(`#${PreviewCAscrId}A_insurancePremiumInput`).text(applicantInsuranceDetails?.payload?.insurancePremium)
        $(`#${PreviewCAscrId}A_nomineeInsurenceInput`).text(applicantInsuranceDetails?.payload?.nomineeName)
        $(`#${PreviewCAscrId}A_dobInput`).text(applicantInsuranceDetails?.payload?.nomineeDob)
        $(`#${PreviewCAscrId}A_ageOfNomineeInput`).text(applicantInsuranceDetails?.payload?.age)
        $(`#${PreviewCAscrId}A_nomineeRelationshipInput`).text(applicantInsuranceDetails?.payload?.nomineeRelation)
        $(`#${PreviewCAscrId}A_genderInput`).text(!apz.isNull(applicantInsuranceDetails.payload.gender) ? applicantInsuranceDetails
            .payload.gender : "");
    } else if (applicantInsuranceDetails?.payload?.insuranceOption === "Both") {
        $(`#${PreviewCAscrId}App_Row`).addClass("sno");
        $(`#${PreviewCAscrId}Both_Row`).removeClass("sno");
        $(`#${PreviewCAscrId}insType`).text("Both")
        $(`#${PreviewCAscrId}totalInsPremium`).text(Number(ApzCOB.fn_unFormatAmount(applicantInsuranceDetails?.payload?.insurancePremium) || 0) + Number(
            ApzCOB.fn_unFormatAmount(coAppInsuranceDetails?.payload?.insurancePremium)));
        $(`#${PreviewCAscrId}CA_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
        $(`#${PreviewCAscrId}CA_nameOfInsurerInput`).text(applicantInsuranceDetails?.payload?.insurerName)
        $(`#${PreviewCAscrId}CA_insurancePremiumInput`).text(applicantInsuranceDetails?.payload?.insurancePremium)
        $(`#${PreviewCAscrId}CA_nomineeInsurenceInput`).text(applicantInsuranceDetails?.payload?.nomineeName)
        $(`#${PreviewCAscrId}CA_dobInput`).text(applicantInsuranceDetails?.payload?.nomineeDob)
        $(`#${PreviewCAscrId}CA_ageOfNomineeInput`).text(applicantInsuranceDetails?.payload?.age)
        $(`#${PreviewCAscrId}CA_nomineeRelationshipInput`).text(applicantInsuranceDetails?.payload?.nomineeRelation)
        $(`#${PreviewCAscrId}CA_genderInput`).text(!apz.isNull(applicantInsuranceDetails.payload.gender) ? applicantInsuranceDetails
            .payload.gender : "");
        $(`#${PreviewCAscrId}CC_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
        $(`#${PreviewCAscrId}CC_nameOfInsurerInput`).text(coAppInsuranceDetails?.payload?.insurerName)
        $(`#${PreviewCAscrId}CC_insurancePremiumInput`).text(coAppInsuranceDetails?.payload?.insurancePremium)
        $(`#${PreviewCAscrId}CC_nomineeInsurenceInput`).text(coAppInsuranceDetails?.payload?.nomineeName)
        $(`#${PreviewCAscrId}CC_dobInput`).text(coAppInsuranceDetails?.payload?.nomineeDob)
        $(`#${PreviewCAscrId}CC_ageOfNomineeInput`).text(coAppInsuranceDetails?.payload?.age)
        $(`#${PreviewCAscrId}CC_nomineeRelationshipInput`).text(coAppInsuranceDetails?.payload?.nomineeRelation)
        $(`#${PreviewCAscrId}CC_genderInput`).text(!apz.isNull(coAppInsuranceDetails.payload.gender) ? coAppInsuranceDetails.payload
            .gender : "");
    } else if (applicantInsuranceDetails.payload.insuranceOption === "Joint") {
        $(`#${PreviewCAscrId}App_Row`).addClass("sno");
        $(`#${PreviewCAscrId}insType`).text("Joint")
        $(`#${PreviewCAscrId}totalInsPremium`).text(jointInsuranceDetails?.payload?.insurancePremium);
        if (jointInsuranceDetails?.payload?.nomineeAdded === "No") {
            $(`#${PreviewCAscrId}Both_Row`).removeClass("sno");
            $(`#${PreviewCAscrId}CA_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
            $(`#${PreviewCAscrId}CA_nameOfInsurerInput`).text(applicantInsuranceDetails?.payload?.insurerName)
            $(`#${PreviewCAscrId}CA_insurancePremiumInput`).text(applicantInsuranceDetails?.payload?.insurancePremium)
            $(`#${PreviewCAscrId}CA_nomineeInsurenceInput`).text(applicantInsuranceDetails?.payload?.nomineeName)
            $(`#${PreviewCAscrId}CA_dobInput`).text(applicantInsuranceDetails?.payload?.nomineeDob)
            $(`#${PreviewCAscrId}CA_ageOfNomineeInput`).text(applicantInsuranceDetails?.payload?.age)
            $(`#${PreviewCAscrId}CA_nomineeRelationshipInput`).text(applicantInsuranceDetails?.payload?.nomineeRelation)
            $(`#${PreviewCAscrId}CA_genderInput`).text(!apz.isNull(applicantInsuranceDetails.payload.gender) ?
                applicantInsuranceDetails.payload.gender : "");
            $(`#${PreviewCAscrId}CC_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
            $(`#${PreviewCAscrId}CC_nameOfInsurerInput`).text(coAppInsuranceDetails?.payload?.insurerName)
            $(`#${PreviewCAscrId}CC_insurancePremiumInput`).text(coAppInsuranceDetails?.payload?.insurancePremium)
            $(`#${PreviewCAscrId}CC_nomineeInsurenceInput`).text(coAppInsuranceDetails?.payload?.nomineeName)
            $(`#${PreviewCAscrId}CC_dobInput`).text(coAppInsuranceDetails?.payload?.nomineeDob)
            $(`#${PreviewCAscrId}CC_ageOfNomineeInput`).text(coAppInsuranceDetails?.payload?.age)
            $(`#${PreviewCAscrId}CC_nomineeRelationshipInput`).text(coAppInsuranceDetails?.payload?.nomineeRelation)
            $(`#${PreviewCAscrId}CC_genderInput`).text(!apz.isNull(coAppInsuranceDetails.payload.gender) ? coAppInsuranceDetails
                .payload.gender : "");
        } else {
            $(`#${PreviewCAscrId}Joint_Row`).removeClass("sno");
            $(`#${PreviewCAscrId}BA_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
            $(`#${PreviewCAscrId}BA_nameOfInsurerInput`).text(jointInsuranceDetails?.payload?.insurerName)
            $(`#${PreviewCAscrId}BA_insurancePremiumInput`).text(jointInsuranceDetails?.payload?.insurancePremium)
            $(`#${PreviewCAscrId}BA_nomineeInsurenceInput`).text(jointInsuranceDetails?.payload?.nomineeName)
            $(`#${PreviewCAscrId}BA_dobInput`).text(jointInsuranceDetails?.payload?.nomineeDob)
            $(`#${PreviewCAscrId}BA_ageOfNomineeInput`).text(jointInsuranceDetails?.payload?.age)
            $(`#${PreviewCAscrId}BA_nomineeRelatiaonshipInput`).text(jointInsuranceDetails?.payload?.nomineeRelation)
            $(`#${PreviewCAscrId}BA_genderInput`).text(!apz.isNull(jointInsuranceDetails.payload.gender) ? jointInsuranceDetails
                .payload.gender : "");
        }
    } else {
        $(`#${PreviewCAscrId}App_Row`).addClass("sno");
        $(`#${PreviewCAscrId}insType`).text("No Insurance")
        $(`#${PreviewCAscrId}totalInsPremium`).text("");
    }
}
apz.app.PreviewCA.previewIncomeDetails = function() {
    incomeDtls = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload);
    apz.app.PreviewCA.paintAgricultureData();
    apz.app.PreviewCA.paintSalaryData();
    apz.app.PreviewCA.paintPensionData();
    apz.app.PreviewCA.paintrentalIncomeData();
    apz.app.PreviewCA.paintWageData();
    apz.app.PreviewCA.paintBusinessData();
    let incomeSourcesToPaint = apz.app.PreviewCA.getPresentIncomeSources();
    let formattedIncomeSources = incomeSourcesToPaint.join(', ');
    $(`#${PreviewCAscrId}availSourcesIncome_txtcnt`).text(formattedIncomeSources);
    apz.app.PreviewCA.paintIncomeOwnershipDetails();
    if (incomeDtls.hasOwnProperty('homeMaker')) {
        $(`#${PreviewCAscrId}InprinciplehomeMaker`).removeClass('sno');
        $(`#${PreviewCAscrId}inpriHomemaker_txtcnt`).text(incomeDtls?.homeMaker);
    }
}

apz.app.PreviewCA.paintIncomeOwnershipDetails = function() {
    const ownership = apz.app.PreviewCA.getIncomeSourceOwnership();
    const formatOwnership = (value) => {
        if (Array.isArray(value)) return value.join(', ');
        return value || "None";
    };
    $(`#${PreviewCAscrId}OtherInc1_ownedBy`).text(ownership.agriculture);
    $(`#${PreviewCAscrId}OtherInc2_ownedBy`).text(ownership.salary);
    $(`#${PreviewCAscrId}OtherInc4_ownedBy`).text(ownership.pension);
    $(`#${PreviewCAscrId}OtherInc5_ownedBy`).text(ownership.rentalIncome);
    $(`#${PreviewCAscrId}OtherInc3_ownedBy`).text(ownership.wage);
    $(`#${PreviewCAscrId}business3_ownedBy`).text(formatOwnership(ownership.tailoring));
    $(`#${PreviewCAscrId}business2_ownedBy`).text(formatOwnership(ownership.kirana));
    $(`#${PreviewCAscrId}business4_ownedBy`).text(formatOwnership(ownership.otherBusiness));
    $(`#${PreviewCAscrId}business1_ownedBy`).text(formatOwnership(ownership.dairy));
};


apz.app.PreviewCA.getIncomeSourceOwnership = function() {
    const result = {};
    const checkPresence = (app, coApp) => {
        const hasApplicant = !!app && Object.keys(app).length > 0;
        const hasCoApplicant = !!coApp && Object.keys(coApp).length > 0;
        if (hasApplicant && hasCoApplicant) return "Both";
        if (hasApplicant) return "Applicant";
        if (hasCoApplicant) return "Co-Applicant";
        return "None";
    };
    result.agriculture = checkPresence(incomeDtls.agriculture?.applicant, incomeDtls.agriculture?.coApplicant);
    result.salary = checkPresence(incomeDtls.salary?.applicant, incomeDtls.salary?.coApplicant);
    result.pension = checkPresence(null, incomeDtls.pension?.coApplicant);
    result.rentalIncome = checkPresence(incomeDtls.rentalIncome?.applicant, incomeDtls.rentalIncome?.coApplicant);
    result.wage = checkPresence(incomeDtls.wage?.applicant, incomeDtls.wage?.coApplicant);
    result.tailoring = (incomeDtls.business?.Tailoring || []).map(item => item.tailoringType);
    result.kirana = (incomeDtls.business?.Kirana || []).map(item => item.kiranaType);
    result.otherBusiness = (incomeDtls.business?.Other || []).map(item => item.otherType);
    result.dairy = (incomeDtls.business?.dairy || []).map(item => item.DairyType);
    const homeMaker = incomeDtls.homeMaker;
    result.homeMaker = homeMaker === "Applicant" || homeMaker === "Co-Applicant" ? homeMaker : "None";
    return result;
}

apz.app.PreviewCA.getPresentIncomeSources = function() {
    incomeDtls = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload);
    const incomeDtlsKeys = Object.keys(incomeDtls || {});
    const ignoreKeys = ["applicantTotalIncome", "coApplicantTotalIncome", "otherFamilyIncome", "fieldAssessedIncome", "fieldAssessedIncomeDate",
        "homeMaker"
    ];
    const incomeSources = [];
    incomeDtlsKeys.forEach(key => {
        if (ignoreKeys.includes(key)) return;
        const value = incomeDtls[key];
        const isObjectWithData = typeof value === "object" && value !== null && (
            (Array.isArray(value) && value.length > 0) || Object.values(value).some(v => v && (typeof v === "object" ? Object.keys(v)
                .length > 0 : true)));
        if (isObjectWithData) {
            const readableName = key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase()).trim();
            incomeSources.push(readableName);
        }
    });
    return incomeSources;
};

apz.app.PreviewCA.paintAgricultureData = function() {
    if (incomeDtls.hasOwnProperty('agriculture') || apz.isObjectEmpty(incomeDtls.agriculture)) {
        $(`#${PreviewCAscrId}agricultureDetailRow`).addClass('sno');
    }
    if (!apz.isObjectEmpty(incomeDtls.agriculture) && incomeDtls.agriculture.hasOwnProperty('applicant')) {
        $(`#${PreviewCAscrId}agricultureDetailRow`).removeClass('sno');
        $(`#${PreviewCAscrId}agriBothchecked`).addClass('sno');
        $(`#${PreviewCAscrId}Apptitle`).addClass('sno');
        $(`#${PreviewCAscrId}agriApplicantRow`).removeClass('sno');
        $(`#${PreviewCAscrId}agriCoapplicantRow`).addClass('sno');
        $(`#${PreviewCAscrId}agrOwnedby_txtcnt`).text("Applicant");
