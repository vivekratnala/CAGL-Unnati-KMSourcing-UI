                "Tailoring Doc");
            businessCounter++;
        })
    } else {
        $(`#${PreviewCAscrId}businesstailoringRow`).addClass('sno');
    }
    if (businessDtls.hasOwnProperty('Other') && otherData.length !== 0) {
        $(`#${PreviewCAscrId}businessotherRow`).removeClass('sno');
