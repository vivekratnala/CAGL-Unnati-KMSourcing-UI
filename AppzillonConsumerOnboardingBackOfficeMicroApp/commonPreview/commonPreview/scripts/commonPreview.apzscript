window.cmnPreviewscrId = 'cmnPre__commonPreview__';
window.Preview_STAGES = '';
apz.app.onLoad_commonPreview = function() {
    $('body').addClass(' unati crdas dbkit ');
    $('.mainsubsec').css('width', '100%');

    apz.app.commonPreview.updateHeaderDetails();
    window.applicationStatus =  inSessionStore?.applicationMaster?.applicationStatus 
}
apz.app.onShown_commonPreview = function() {
    $(`#${cmnPreviewscrId}PreviewApplicantDtls`).addClass('active');
    apz.app.commonPreview.paintHeaderData();
    ApzCOB.launchSubScreen("PreviewApplicantDetails", `${cmnPreviewscrId}preViewScrndiv`);
    apz.app.commonPreview.handleMenu();
    $("#cmnPre__commonPreview__sidebar_col").removeClass("sno");
    if ($(window).width() >= 600 && $(window).width() <= 1024) {
        $("#cmnPre__commonPreview__sidebar_col").addClass("sno");
        $("#cmnPre__commonPreview__sidebar_col").addClass("sideon");
        $('#cmnPre__commonPreview__previewMenu_btn, #cmnPre__commonPreview__closeSidebar').show();
    } else {
        $('#cmnPre__commonPreview__previewMenu_btn, #cmnPre__commonPreview__closeSidebar').hide();
        $("#cmnPre__commonPreview__sidebar_col").removeClass("sno");
        $("#cmnPre__commonPreview__sidebar_col").removeClass("sideon");
    }
    $('#cmnPre__PreviewCA__docViewModal_close').on('click', function() {
    ApzCOB.toggleModal(`${PreviewCAscrId}docViewModal`);
        $('#APZCBO__BaseScreens__preview_modal').addClass('in');
    });
}
apz.app.commonPreview.updateHeaderDetails = function() {
    let loginResponse = LoggedInUserDetails.loginResponse;
    let loginName = loginResponse?.userDet?.name;
    let loginUserId = loginResponse?.userDet?.id;
    $(`#${cmnPreviewscrId}caloggedInUserName_txtcnt`).text(`${loginName} (${loginUserId})`);
    $(`#${cmnPreviewscrId}caloggedInRole_txtcnt`).text(`Role:${loginResponse?.addInfo1}`);
}
apz.app.commonPreview.paintHeaderData = function(lscrId) {
    lscrId = lscrId || cmnPreviewscrId;
    const {
        applicationMaster: {
            memberId = "",
            applicationId = "",
            applicationStatus = "",
            branchId = "",
            branchName = "",
            productCode = "",
            kendraId = "",
            kendraName = ""
        } = {}
    } = inSessionStore;
    const productName = subProductResponse?.filter(el => el.productCode === productCode)?.[0]?.productName;
    const custName = ApzCOB.getPayloadDatafromWrapper('customerName', 'Applicant', 'customerDetailsList');
    const setText = (id, value) => $(`#${lscrId + id}`).text(value);
    setText("custNameID_txtcnt", `${custName} / ${memberId}`);
    setText("applicationId_txtcnt", applicationId);
    setText("branchInfo_txtcnt", `${branchId} / ${branchName}`);
    setText("kendraIDName_txtcnt", `${kendraId} / ${kendraName}`);
    setText("loanProduct_txtcnt", productName);
    setText("applicationStatus_txtcnt", applicationStatus);
    setText("loanID_txtcnt", ApzCOB.getPayloadDatafromWrapper('t24LoanId', 'Applicant', 'loanDetails') ?? '');
};
