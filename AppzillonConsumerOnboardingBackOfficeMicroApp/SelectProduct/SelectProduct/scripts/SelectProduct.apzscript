//Fetch subproducts Service
apz.app.SelectProduct.FetchProductsDetails = function(pthis) {
    /* if (gApzCOB.product === 'DEPOSIT' && !apz.isNull(gApzCOB.ExistingCustomer) && !gApzCOB.ExistingCustomer) {
         groupCode = 'CASA';
     } else {*/
    var rowno = $(pthis).attr('rowno');
    apz.data.scrdata.Select__IpaintProduct_Res.forEach(function(el) {
        if (el.productGroupName === $('#Select__IpaintProduct__o__Select__IpaintProduct_Res__productGroupName_' + rowno).text()) {
            groupCode = el.productGroupCode;
            groupName = el.productGroupName;
            productGroupDesc = el.productGroupDesc
        }
        if (el.productGroupCode === window.selectedDashboProduct) {
            groupCode = window.selectedDashboProduct;
            groupName = window.selectedDashboProduct;
            productGroupName = window.selectedDashboProduct;
            productGroupDesc = el.productGroupDesc
        }
    })
    //  }
    var req = {
        "apiRequest": {
            "requestObj": {
                "productGroupCode": groupCode
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "FetchProductDetails", "N", "N", req, false, apz.app.SelectProduct.FetchProductsDetailsCB);
};
//Fetch subproducts Service callback
apz.app.SelectProduct.FetchProductsDetailsCB = function(params) {
    changeMainProduct = gApzCOB.product;
    tempArr = [];
    prodArr = []
    var eligibleprod = [];
    try {
        apz.stopLoader();
        if (ApzCOB.handleServiceCallBacks(params)) {
            //var nameArr = [];
            apz.data.scrdata.Select__IpaintProductDetails_Res = {};
            var response = JSON.parse(params.res.APZCBO__FetchProductDetails_Res.apiResponse.ResponseBody.responseObj);
            if (response.length > 0) {
                /*  if (gApzCOB.product === 'DEPOSIT' && !apz.isNull(gApzCOB.ExistingCustomer) && !gApzCOB.ExistingCustomer) {
                      selectedType = groupCode;
                      gApzCOB.product = selectedType;
                      gApzCOB.productCode = ApzCOB.GetCommonCodes("DEFAULTCASAPRODUCTCODE");
                  } else {*/
                if (gApzCOB.product === 'CARDS') {
                    if (gApzCOB.userDetails.eligibleCardsList === undefined) {
                        apz.app.SelectProduct.FetchEligiblelist();
                    }
                    if (CURRENT_STAGE_NO >= 3) {
                        if (gApzCOB.userDetails.eligibleCardsList.length > 0) {
                            for (var i = 0; i < response.length; i++) {
                                for (var j = 0; j < gApzCOB.userDetails.eligibleCardsList.length; j++) {
                                    if (response[i].productCode === gApzCOB.userDetails.eligibleCardsList[j]) {
                                        eligibleprod.push(response[i]);
                                    }
                                }
                            }
                            response = eligibleprod;
                        } else {
                            //apz.app.SelectProduct.loadCustLitConf();
                            response = [];
                        }
                    }
                }
                selectedType = groupCode;
                gApzCOB.mainProductGroupCode = selectedType;
                gApzCOB.product = selectedType;
                $('#' + SelProdScrId + 'subProducts').removeClass('sno');
                $('#' + SelProdScrId + 'product').addClass('sno');
                $('#' + BaseScrId + 'selectLangRow').addClass('sno');
                $('#' + SelProdScrId + 'productDetails').addClass('sno');
                $(BaseScroll).addClass(SecondaryProduct);
                //$('#' + SelProdScrId + 'backTotoprow').removeClass('sno');
                if (response.length > 0) {
                    response.map(function(data, index) {
                        var listValue = {};
                        var compValue = {};
                        var prodName = {};
                        var featureList = Object.values(JSON.parse(response[index].productFeatures));
                        listValue.productName = data.productName;
                        listValue.productCode = data.productCode;
                        listValue.productType = data.productType;
                        listValue.intrestrate = JSON.parse(data.productFeatures)['Interest Rate~Y'];
                        listValue.disburseindays = JSON.parse(data.productFeatures)['Disbursement In'];
                        listValue.value = data.productDesc.split('~');
                        Object.getOwnPropertyNames(CommSelectProduct).forEach(function(el) {
                            if (el.split('~')[0] === data.productGroupCode) {
                                CommSelectProduct[el].forEach(function(k) {
                                    if (k.split('~')[0] === data.productName) {
                                        listValue.Image = k.split('~')[1];
                                        prodName.Image = k.split('~')[1];
                                    }
                                })
                            }
                        })
                        listValue.feature = JSON.parse(response[index].productFeatures);
                        if (listValue) {
                            listValue.key = Object.keys(listValue.feature);
                            tempArr.push(listValue);
                            var featureData = featureList.map(function(desc, i) {
                                //var feature = desc
                                return desc;
                            });
                            compValue.name = listValue.productName
                            compValue.description = featureData
                            prodName.prodName = listValue.productName
                            //compArr.push(compValue);
                            prodArr.push(prodName);
                        }
                    });
                } else {
                    ApzCOB.toggleModal(BaseScrId + 'NonEligibleModal');
                    apz.app.SelectProduct.loadCustLitConf();
                    $('#' + gAppId + '__BaseScreens__headerText').addClass('sno');
                }
                // Paint Product in Select Product based on ApplicationType
                tempArr = tempArr.filter(ele => ele.productType.toUpperCase() === ApplicationType.toUpperCase());
                gApzCOB.SelectedProductName = tempArr[0].productName.toUpperCase();
                if (tempArr.length > 0) {
                    prodArr = prodArr.filter(ele => ele.prodName.toUpperCase() === gApzCOB.SelectedProductName);
                }
                apz.data.scrdata.Select__IpaintProductDetails_Res = {
                    data: tempArr,
                    //featureDesc: compArr,
                    products: prodArr
                };
                ApzCOB.getProductData();
                apz.data.loadData('IpaintProductDetails', apz.currAppId);
                //$(`#{SelProdScrId}subProductList_row_1`).addClass('sno');
                $('#' + SelProdScrId + 'productList_new_row_1').addClass("sno");
                $('#' + SelProdScrId + 'subProductLabel_txtcnt').text(ApzCOB.getDescfromLitCode("LIT_SELECTPRODUCT_TXT_SUBTITLE_FIND_SUITABLE") +
                    ' "' + gApzCOB.product + '"')
                $('#Select__SelectProduct__el_txt_43_txtcnt').text(groupName);
                $('#Select__SelectProduct__el_txt_44_txtcnt').text(productGroupDesc);
                apz.app.SelectProduct.hideNshowknowMore();
                apz.app.SelectProduct.paintSubProductDesc();
                //  }
                if (gApzCOB.product === 'CARDS') {
                    if (CURRENT_STAGE_NO >= 3) {
                        for (i = 0; i < response.length; i++) {
                            apz.setElmValue("Select__SelectProduct__el_btn_7_" + i + "_txtcnt", "Select");
                        }
                        /*$('#' + SelProdScrId + 'ct_nav_3').addClass("sno");
                        $('#' + SelProdScrId + 'el_hpl_4').addClass("sno");*/
                        //  $('#' + SelProdScrId + 'sc_row_36').addClass("sno");
                        if (apz.deviceType === "WEB") {
                            $('#' + SelProdScrId + 'subProLab').addClass("sno");
                            $('#' + SelProdScrId + 'subProductLabel_txtcnt').text(ApzCOB.getDescfromLitCode("LIT_CHOOSE_CARD") + ' "' + gApzCOB
                                .product + '"')
                        } else {
                            $('#Select__SelectProduct__subProductLabel_txtcnt').text(ApzCOB.getDescfromLitCode(
                                "LIT_COMM_GREETING_TXT_CONGRATULATIONSFORCARD"));
                        }
                        $('#' + SelProdScrId + 'backTotoprow').addClass('sno');
                    } else {
                        //   $('#' + SelProdScrId + 'sc_row_36').removeClass("sno");
                        $('#' + SelProdScrId + 'subProLab').removeClass("sno");
                        $('#' + SelProdScrId + 'backTotoprow').removeClass('sno');
                        $('#' + SelProdScrId + 'subProductLabel_txtcnt').text(ApzCOB.getDescfromLitCode(
                            "LIT_SELECTPRODUCT_TXT_SUBTITLE_FIND_SUITABLE") + ' "' + gApzCOB.product + '"')
                    }
                }
                if (gApzCOB.product === 'DEPOSIT') {
                    apz.app.BaseScreens.getCommomCodeBasedOnProduct();
                }
                if (!backNav) {
                    if (gApzCOB.product === 'CARDS') {
                        if (CURRENT_STAGE_NO >= 3) {} else {
                            apz.app.BaseScreens.getCommomCodeBasedOnProduct();
                        }
                    } else {
                        apz.app.BaseScreens.getCommomCodeBasedOnProduct();
                    }
                }
                if (!apz.isNull(gApzCOB.ExistingCustomer) && !gApzCOB.ExistingCustomer) {
                    if (gApzCOB.product === 'CARDS') {
                        if (CURRENT_STAGE_NO >= 4) {} else {
                            if (gApzCOB.product === "CARDS") {
                                if (!backNav) {
                                    apz.app.BaseScreens.NonExistingCustomerCurScr();
                                }
                            } else {
                                /*if (!backNav) {
                                    apz.app.BaseScreens.NonExistingCustomerCurScr();
                                }*/
                            }
                        }
                    } else {
                        if (!backNav) {
                            apz.app.BaseScreens.NonExistingCustomerCurScr();
                        }
                    }
                }
            } else {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_SELECTPRODUCT_ALERT_TXT_COMING_SOON"), "I");
            }
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
    if (apz.deviceType !== "WEB") {
        window.scroll(0, 0);
    } else {
        ApzCOB.scrollToTop();
    }
};
