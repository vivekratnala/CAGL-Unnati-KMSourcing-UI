            if(compareData[i].feature){
                listData = compareData[i].feature.map(function(data, index){
                var listValue = {
                     name: data
                  };
               return listValue;
             });
		     }
        }*/
    tempArr.featureDesc = {}
    compareData.forEach(function(j, k) {
        tempArr['featureDesc'][j.productName] = []
        tempArr.feature = [];
        Object.getOwnPropertyNames(j["feature"]).forEach(function(p, q) {
            var exists = false;
            var obj = {};
            obj['value'] = Object.keys(j["feature"])[q];
            obj['desc'] = Object.values(j["feature"])[q];
            tempArr['feature'].forEach(function(el) {
                if (el.name === obj['value']) {
                    exists = true
                }
            })
            if (!exists) {
                var lobj = {};
                lobj["name"] = obj['value'];
                tempArr['feature'].push(lobj)
            }
            tempArr['featureDesc'][j.productName].push(obj);
        })
    })
    /*  if(compareData.length > 0){
		       compareData.map(function(data, index) {
					var compValue = {};
					var featureList = Object.values(data.feature);
					var featureData = featureList.map(function(desc, i){
						 var feature = desc
                        return feature;
					});
					compValue.name = data.productName,
					compValue.description = featureData
					compArr.push(compValue);
					});
		    };*/
    // apz.data.scrdata.Select__IpaintProductDetails_Res = tempArr
    //apz.data.scrdata.Select__IpaintProductDetails_Res = {}
    apz.data.scrdata.Select__IpaintProductDetails_Res['featureName'] = tempArr['feature']
    var featureDesc = [];
    Object.getOwnPropertyNames(tempArr['featureDesc']).forEach(function(x, y) {
        var finalObj = {}
        finalObj['desc'] = []
        finalObj['header'] = x;
        tempArr['feature'].forEach(function(el) {
            tempArr['featureDesc'][x].forEach(function(s, t) {
                if (el['name'] === s.value) {
                    var obj = {
                        "value": s.value,
                        "description": s.desc
                    };
                    finalObj['desc'].push(obj);
                }
            })
        })
        featureDesc.push(finalObj)
        //   apz.app.SelectProduct.dynamicRow(featureDesc);
    })
    /*apz.data.scrdata.Select__IpaintProductDetails_Res = {
                data: tempArr,
                featureName: listData,
                products: prodArr,
				featureDesc: compArr
            };*/
    //   apz.app.SelectProduct.dynamicRow(featureDesc);
    apz.data.scrdata.Select__IpaintProductDetails_Res['featureDesc'] = featureDesc;
    apz.data.loadData('IpaintProductDetails', apz.currAppId);
    for (var i = $('#' + SelProdScrId + 'CompareDescTbl_table').parent().prev().find('th').length - 1; i > 1; i--) {
        $('#' + SelProdScrId + 'CompareDescTbl_table').parent().prev().find('th').eq(i).remove();
        $('#' + SelProdScrId + 'CompareDescTbl_table').children().eq(0).find('th').eq(i).remove();
    }
    /*for (var i = $('#' + SelProdScrId + 'CompareDescTbl_table').parent().prev().find('th').length - 1; i > 1; i--) {
        $('#' + SelProdScrId + 'CompareDescTbl_table').parent().prev().find('th').eq(i).remove()
    }*/
    // for (var m = 0; m < $('#' + SelProdScrId + CompareDiscription).length; m++) {
    //     var featureNamelen = apz.data.scrdata.Select__IpaintProductDetails_Res['featureName'].length;
    //     var tablerowlen = $('#' + SelProdScrId + CompareDiscription).length;
    //     var lastrowlen = $('#' + SelProdScrId + CompareDiscription).length - 1;
    //     if (tablerowlen > featureNamelen) {
    //         $('#' + SelProdScrId + CompareDiscription).eq(lastrowlen).remove();
    //     }
    //     for (var n = $('#' + SelProdScrId + CompareDiscription).eq(m).children().length - 1; n > 1; n--) {
    //         $('#' + SelProdScrId + CompareDiscription).eq(m).children().eq(n).remove();
    //     }
    // }
    apz.app.SelectProduct.compareProductFeature();
    apz.app.SelectProduct.dynamicRow()
};
