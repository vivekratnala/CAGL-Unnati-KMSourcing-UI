apz.app.SelectProduct.dynamicRow = function() {
    var buttonHtml = '';
    var array = apz.data.scrdata.Select__IpaintProductDetails_Res['featureDesc'];
    /*var rowlen = $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().length - 1;
    var prodDescRow = $('#' + SelProdScrId + 'CompareDescTbl_tbody').children()[rowlen].outerHTML;
    prodDescRow = prodDescRow.replace(rowlen, rowlen + 1);
    $('#' + SelProdScrId + 'CompareDescTbl_tbody').append(prodDescRow);*/
    for (var j = 0; j < array.length; j++) {
        if (j > 0) {
            var prodDescOuterHeaderHtml1 = $('#' + SelProdScrId + 'CompareDescTbl_table').parent().prev().find('th')[1].outerHTML
            prodDescOuterHeaderHtml1 = prodDescOuterHeaderHtml1.replace(1, j + 1);
            $('#' + SelProdScrId + 'CompareDescTbl_table').parent().prev().find('th').parent().append(prodDescOuterHeaderHtml1);
            $('#' + SelProdScrId + 'CompareDescTbl_table').children().eq(0).find('tr').append(prodDescOuterHeaderHtml1);
            /*var prodDescOuterHeaderHtml2 = $('#' + SelProdScrId + 'CompareDescTbl_table thead tr th')[1].outerHTML
             prodDescOuterHeaderHtml2 = prodDescOuterHeaderHtml2.replace(j, j + 1);
            $('#' + SelProdScrId + 'CompareDescTbl_table thead tr th').parent().find('th').append(prodDescOuterHeaderHtml2)*/
            apz.data.loadData('IpaintProductDetails', apz.currAppId);
        }
        for (var k = 0; k < array[j]['desc'].length; k++) {
            for (var i = 0; i < apz.data.scrdata.Select__IpaintProductDetails_Res['featureName'].length; i++) {
                var productText = $('#Select__IpaintProductDetails__o__featureName__name_' + i).text()
                if (productText === array[j]['desc'][k]['value']) {
                    var desc = array[j]['desc'][k]['description'];
                    //  $('#' + SelProdScrId + 'CompareDescTbl_col_' + (j + 1) + '_th').text(array[j]['header'])
                    $('#' + SelProdScrId + 'CompareDescTbl_table').parent().prev().find('th').eq(j + 1).text(array[j]['header'])
                    $('#' + SelProdScrId + 'CompareDescTbl_table').children().eq(0).find('th').eq(j + 1).text(array[j]['header'])
                    $('#Select__SelectProduct__CompareDescTbl_row_' + k).children()
                    if (j > 0) {
                        var prodDescOuterBodyHtml = $('#' + SelProdScrId + CompareDiscription).eq(k).children().eq(1)[0].outerHTML;
                        $('#' + SelProdScrId + CompareDiscription).eq(k).append(prodDescOuterBodyHtml);
                        apz.data.loadData('IpaintProductDetails', apz.currAppId);
                        var a = $('#' + SelProdScrId + CompareDiscription).eq(k).children().length;
                        $('#' + SelProdScrId + CompareDiscription).eq(k).children().eq(a - 1).text(desc)
                    } else {
                        $('#' + SelProdScrId + CompareDiscription).eq(k).children().eq(1).text(desc);
                    }
                }
            }
        }
    }
    var rowlen = $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().length - 1;
    var prodDescRow = $('#' + SelProdScrId + 'CompareDescTbl_tbody').children()[rowlen].outerHTML;
    prodDescRow = prodDescRow.replace(rowlen, rowlen + 1);
    var btnValue = 0
    $('#' + SelProdScrId + 'CompareDescTbl_tbody').append(prodDescRow);
    for (var t = $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).find('td').length - 1; t >= 0; t--) {
        if (t === 0) {
            $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).find('td').eq(t).text("");
        } else {
            if (gApzCOB.product === 'CARDS') {
                if (CURRENT_STAGE_NO >= 3) {
                    $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).find('td').eq(t).remove();
                    buttonHtml =
                        '<td id="td_Select__SelectProduct__applyNow_btn_0" class=" pri lft"><button id="Select__SelectProduct__applyNow_btn_0" rowno="0" type="button" class="ett-bttn pri med" style=" width:150PX;"><span id="Select__SelectProduct__applyNow_btn_0_txtcnt">Select</span></button></td>';
                    buttonHtml = buttonHtml.split('0').join(btnValue);
                    //var tdlen = $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).eq(0).find('td').length
                    $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).append(buttonHtml);
                    ApzCOB.attachOnclickEvent([].concat($("#" + SelProdScrId + 'applyNow_btn_' + btnValue)), 'ApzCOB.createCreditCard(' + "'"
                        .concat(array[btnValue]['header']).concat("'") + ')');
                    btnValue = btnValue + 1;
                } else {
                    $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).find('td').eq(t).remove();
                    buttonHtml =
                        '<td id="td_Select__SelectProduct__applyNow_btn_0" class=" pri lft"><button id="Select__SelectProduct__applyNow_btn_0" rowno="0" type="button" class="ett-bttn pri med" style=" width:150PX;"><span id="Select__SelectProduct__applyNow_btn_0_txtcnt">Apply Now</span></button></td>';
                    buttonHtml = buttonHtml.split('0').join(btnValue);
                    //var tdlen = $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).eq(0).find('td').length
                    $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).append(buttonHtml);
                    ApzCOB.attachOnclickEvent([].concat($("#" + SelProdScrId + 'applyNow_btn_' + btnValue)), 'apz.app.SelectProduct.ApplyNow(' +
                        "'".concat(array[btnValue]['header']).concat("'") + ')');
                    btnValue = btnValue + 1;
                }
            } else {
                $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).find('td').eq(t).remove();
                buttonHtml =
                    '<td id="td_Select__SelectProduct__applyNow_btn_0" class=" pri lft"><button id="Select__SelectProduct__applyNow_btn_0" rowno="0" type="button" class="ett-bttn pri med" style=" width:150PX;"><span id="Select__SelectProduct__applyNow_btn_0_txtcnt">Apply Now</span></button></td>';
                buttonHtml = buttonHtml.split('0').join(btnValue);
                //var tdlen = $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).eq(0).find('td').length
                $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).append(buttonHtml);
                ApzCOB.attachOnclickEvent([].concat($("#" + SelProdScrId + 'applyNow_btn_' + btnValue)), 'apz.app.SelectProduct.ApplyNow(' + "'"
                    .concat(array[btnValue]['header']).concat("'") + ')');
                btnValue = btnValue + 1;
            }
            /* if (apz.isNull(tdlen)) {
                 $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).append(buttonHtml);
             } else {
                 $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).eq(0).find('td').eq(tdlen - 1).before(buttonHtml);
             }*/
            //  $('#' + SelProdScrId + 'CompareDescTbl_tbody').children().eq(rowlen + 1).append(buttonHtml);
            /* for (var p = 0; p < array.length; p++) {
                 ApzCOB.attachOnclickEvent([].concat($("#" + SelProdScrId + 'applyNow_btn_' + p)), 'apz.app.SelectProduct.ApplyNow(' + array[p][
                     'header'
                 ] + ')');
             }*/
        }
    }
};
apz.app.SelectProduct.paintSubProductDesc = function() {
    apz.data.scrdata.Select__IpaintProductDetails_Res.data.forEach(function(m, n) {
        m.value.forEach(function(k, l) {
            if (l === 0) {
                $('#' + SelProdScrId + 'featureDescMain_' + n + '_txtcnt').text("");
                //return;
            } else {
                if (l > 1) {
                    for (var i = $('#' + SelProdScrId + 'featureDescSub_' + n).parent().find('p').length - 1; i > 0; i--) {
                        $('#' + SelProdScrId + 'featureDescSub_' + n).parent().find('p').eq(i)
                        .remove() // to remove dynamically added rows
                    }
                }
                $('#' + SelProdScrId + 'featureDescSub_' + n).parent().find('p').find('span').text("")
                //return;
            }
        })
    })
    apz.data.scrdata.Select__IpaintProductDetails_Res.data.forEach(function(m, n) {
        m.value.forEach(function(k, l) {
            if (l === 0) {
                $('#' + SelProdScrId + 'featureDescMain_' + n + '_txtcnt').text(m.value[0]);
                //return;
            } else {
                if (l > 1) {
                    var prodDescOuterHtml = $('#' + SelProdScrId + 'featureDescSub_' + n)[0].outerHTML;
                    var a = $('#' + SelProdScrId + 'featureDescSub_' + n).parent().find('p').length
                    $('#' + SelProdScrId + 'featureDescSub_' + n).parent().find('p').eq(a - 1).after(
                    prodDescOuterHtml); // to add dynamically added rows
                    $('#' + SelProdScrId + 'featureDescSub_' + n).parent().find('p').eq(a).find('span').text(k)
                    // $('#' + SelProdScrId + 'featureDescSub_0_li').children().eq(a).find('span').text(m)
                } else {
                    $('#' + SelProdScrId + 'featureDescSub_' + n).parent().find('p').find('span').text(k)
                }
                //return;
            }
        })
    })
}
apz.app.SelectProduct.hideNshowknowMore = function() {
    if (selectedType === "CASA") {
        apz.data.loadJsonData("SavingsAccount", apz.currAppId);
        apz.data.scrdata.Select__IpaintProductDetails_Res.data.forEach(function(m, n) {
            if (!apz.isNull(apz.data.scrdata.Select__SavingsAccount_Res[m.productName])) {
                $('#' + SelProdScrId + 'knowMoreLink_' + n).removeClass('sno');
            } else {
                $('#' + SelProdScrId + 'knowMoreLink_' + n).addClass('sno');
            }
        })
    } else if (selectedType === "DEPOSIT") {
        apz.data.loadJsonData("DepositAccount", apz.currAppId);
        apz.data.scrdata.Select__IpaintProductDetails_Res.data.forEach(function(m, n) {
            if (!apz.isNull(apz.data.scrdata.Select__DepositAccount_Res[m.productName])) {
                $('#' + SelProdScrId + 'knowMoreLink_' + n).removeClass('sno');
            } else {
                $('#' + SelProdScrId + 'knowMoreLink_' + n).addClass('sno');
            }
        })
    }
}
apz.app.SelectProduct.knowMore = function(pthis) {
    var rowno = $(pthis).attr('rowno');
    var subproduct = $('#Select__IpaintProductDetails__o__data__productName_' + rowno).text();
    ApzCOB.toggleModal(SelProdScrId + "knowMoreModal");
    //  for (var s = 0; s < featureDesc.length; s++) {
    if ($('#' + SelProdScrId + 'featureDesctxt_li').children().length > 1) {
        for (var t = $('#' + SelProdScrId + 'featureDesctxt_li').children().length - 1; t > 0; t--) {
            $('#' + SelProdScrId + 'featureDesctxt_li').children().eq(t).remove();
            //  $('#' + SelProdScrId + 'CompareDescList_row_' + s).children().children().eq((t)).remove();
        }
        $('#' + SelProdScrId + 'featureDesctxt_li').children().find('span').text("")
    }
    // }
    $('#' + SelProdScrId + 'knowMoreModal_window').find('h1').text(subproduct)
    $('#' + SelProdScrId + 'selectedSubAccount').text(subproduct);
    apz.data.scrdata.Select__IpaintProduct_Res.forEach(function(p) {
        if (p.productGroupCode === selectedType) {
            $('#' + SelProdScrId + 'selectedAcc').text(p.productGroupName);
        }
    })
    if (selectedType === "CASA") {
        apz.app.SelectProduct.knowMoreCasa(subproduct);
    } else if (selectedType === "DEPOSIT") {
        apz.app.SelectProduct.knowMoreDeposit(subproduct);
    } else if (selectedType === "LOAN") {
        apz.app.SelectProduct.knowMoreLoans(subproduct);
    } else if (selectedType === "CARDS") {
        apz.app.SelectProduct.knowMoreCards(subproduct);
    }
}
