apz.app.onLoad_SelectProduct = function(params) {
    apz.app.BaseScreens.contactus();
    if (apz.isNull(gApzCOB.product) && gApzCOB.product === 'CARDS' && CURRENT_STAGE_NAME === 'ELIGIBLECARDSLIST') {
        apz.app.Dashboard.FetchProducts();
    }
    // apz.app.SelectProduct.FetchProducts();
    // apz.data.loadData('IpaintProduct', apz.currAppId);
    $('#' + SelProdScrId + 'subProducts').addClass('sno');
    $('#' + SelProdScrId + 'productDetails').addClass('sno');
    if (apz.deviceType === 'WEB') {
        $('#' + BaseScrId + "baseScroll").scroll(function() {
            if ($('#' + BaseScrId + "baseScroll").scrollTop() > 100) {
                $('#' + SelProdScrId + 'backTotoprow').removeClass("sno");
            } else {
                $('#' + SelProdScrId + 'backTotoprow').addClass("sno");
            }
        })
    }
    if (apz.deviceType !== 'WEB') {
        $(window).ready(function() {
            $(window).scroll(function() {
                if ($(window).scrollTop() > 150) {
                    $("#Select__SelectProduct__backTotoprow").removeClass("sno");
                } else {
                    $("#Select__SelectProduct__backTotoprow").addClass("sno");
                }
            })
        })
    }
    apz.app.SelectProduct.swiper();
    apz.app.SelectProduct.subProSwiper();
    apz.app.SelectProduct.comProSwiper();
    $(BaseScroll).removeClass(SecondaryProduct);
    $('#' + BaseScrId + 'baseScroll').addClass(ProductScreen);
    $("#APZCBO__BaseScreens__sidebarController").addClass('sno');
    $("#Select__SelectProduct__subProductList").addClass('sno');
};
apz.app.onShown_SelectProduct = function(params) {
    $(`#${BaseScrId}RefNumDiv`).addClass('sno');
    if (changeSubProduct) {
        apz.app.BaseScreens.getCommomCodeBasedOnProduct();
    }
    $('#' + SelProdScrId + 'cmpBtn').attr('disabled', true);
    //$('#' + SelProdScrId + 'backTotoprow').removeClass('sno');
    //ApzCOB.showLanguageSelect();
    if (window.selectedType !== '') {
        groupCode = window.selectedType;
        apz.app.SelectProduct.FetchProductsDetails();
        $('#' + SelProdScrId + 'product').addClass('sno');
        // $('#' + SelProdScrId + 'selProdBckIcn').addClass('sno')
        $('#' + SelProdScrId + 'subProducts').removeClass('sno');
    }
    if (window.selectedDashboProduct !== "ALL") {
        apz.app.SelectProduct.FetchProductsDetails(window.selectedDashboProduct);
    }
    if (gApzCOB.product === 'CARDS') {
        if (CURRENT_STAGE_NO >= 3) {
            $('#' + SelProdScrId + 'subProducts').addClass(SelectProductName);
            $('#Select__SelectProduct__subProLab').removeClass('sno');
            $('#' + BaseScrId + 'headerText').addClass('sno');
            // $('#' + SelProdScrId + 'selProdBckIcn').removeClass('sno');
            $('#Select__SelectProduct__sc_row_102').addClass('sno');
            if (backNav) {
                $('#' + BaseScrId + 'backIcon').addClass('sno');
            }
            $('#Select__SelectProduct__subProductLabel_txtcnt').text(ApzCOB.getDescfromLitCode("LIT_COMM_GREETING_TXT_CONGRATULATIONSFORCARD"));
        } else {
            $('#' + SelProdScrId + 'subProducts').removeClass(SelectProductName);
        }
    } else {
        $('#' + SelProdScrId + 'subProducts').removeClass(SelectProductName);
    }
    $(BaseScroll).addClass(SecondaryProduct);
    apz.app.SelectProduct.removeMainProductList();
    apz.app.SelectProduct.paintSelectedLanguage();
};
apz.app.SelectProduct = function(pthis) {
    var filterData;
    var rowno = $(pthis).attr('rowno');
    if (!apz.isNull(apz.data.scrdata.Select__IpaintProduct_Res)) {
        filterData = apz.data.scrdata.Select__IpaintProduct_Res.filter(function(el) {
            return el.productGroupName === $('#Select__IpaintProduct__o__Select__IpaintProduct_Res__productGroupName_' + rowno).text();
        })
    }
    ApzCOB.toggleModal(SelProdScrId + 'productDetailsModal');
    ApzCOB.FetchProductsDetails(filterData[0]['productGroupCode']);
};
apz.app.SelectProduct.createRequest = function() {
    gApzCOB["requestNodes"].cardDetails = {
        "appId": gAppId,
        "applicationId": gApzCOB.userDetails.applicationId,
        "cardName": gApzCOB.subProduct,
        "creditLimit": gApzCOB.userDetails.allCardInfo.creditLimit,
        "currency": gApzCOB.userDetails.allCardInfo.currency,
        "withdrawalLimit": gApzCOB.userDetails.allCardInfo.withdrawalLimit,
        "ccDtlId": gApzCOB.userDetails.ccDtlId,
        //"customImagePath": gApzCOB.userDetails.filelocation,
        //"customTheme": gApzCOB.userDetails.filename,
        //"emailStmtReq": gApzCOB.userDetails.ModeofDelivryBlValE,
        //"nameOnCard": $("#" + CardServiceScrId + "nameOnCard").val(),
        //"physicalStmtReq": gApzCOB.userDetails.ModeofDelivryBlValp,
        //"theme": "",
        "versionNum": gApzCOB.userDetails.versionNum
    }
    /*gApzCOB["requestNodes"]['cardDetails'] = [];
    gApzCOB["requestNodes"]['cardDetails'].push(obj);*/
    return gApzCOB["requestNodes"];
};
