apz.app.SelectProduct.ApplyNow = function(pthis) {
    $('#APZCBO__IpaintApplicationType__o__APZCBO__IpaintApplicationType_Res__applnType_0_txtcnt').text(ApzCOB.getDescfromLitCode(
        'LIT_SELECTPRODUCT_BTN_TXT_SINGLEACCOUNT'));
    $('#APZCBO__IpaintApplicationType__o__APZCBO__IpaintApplicationType_Res__applnType_1_txtcnt').text(ApzCOB.getDescfromLitCode(
        'LIT_SELECTPRODUCT_BTN_TXT_JOINTACCOUNT'));
    $('#APZCBO__BaseScreens__continueBtn').text(ApzCOB.getDescfromLitCode('LIT_SELECTPRODUCT_BTN_TXT_CONTINUE'));
    $('#APZCBO__BaseScreens__el_btn_25').text(ApzCOB.getDescfromLitCode('LIT_SELECTPRODUCT_BTN_TXT_CANCEL'));
    changeSubProduct = false;
    if (changeMainProduct !== gApzCOB.product) {
        gApzCOB.productDetails.productCode = '';
    }
    window.recurringDepEnabled = 'N';
    if ($("#" + SelProdScrId + "knowMoreModal").is(":visible")) {
        gApzCOB.subProduct = $("#" + SelProdScrId + "knowMoreModal").find('ul').find('h1').text()
    } else if (apz.isNull($(pthis).attr('rowno'))) {
        gApzCOB.subProduct = pthis;
        $('#' + SelProdScrId + 'compareModal').modal('hide');
    } else {
        var rowNo = $(pthis).attr('rowno');
        gApzCOB.subProduct = $('#Select__IpaintProductDetails__o__data__productName_' + rowNo).text();
    }
    apz.data.scrdata.Select__IpaintProductDetails_Res.data.forEach(function(el) {
        if (el.productName === gApzCOB.subProduct) {
            gApzCOB.productCode = el.productCode
            gApzCOB.productType = el.productType
            gApzCOB.NoOfJointHolder = el.feature.NoOfJointHolder
            gApzCOB.JointAccountRequired = el.feature.isJointAccountRequired
        }
    })
    //if (gApzCOB.productCode === gApzCOB.productDetails.productCode || apz.isNull(gApzCOB.productDetails.productCode)){
    if (gApzCOB.productType !== 'FIXED DEPOSIT') {
        window.recurringDepEnabled = 'Y';
    }
    //apz.app.SelectProduct.modifylaunchConfigureJson();
    if (gApzCOB.product === 'CARDS') {
        if (CURRENT_STAGE_NO >= 3) {} else {
            apz.app.SelectProduct.modifylaunchConfigureJson();
            apz.app.BaseScreens.sideBarMenu();
        }
    }
    apz.app.BaseScreens.sideBarMenu();
    if (apz.currAppId === 'Select') {
        if (CURRENT_STAGE_NO >= 3 /*pthis.firstElementChild.textContent === "Select"*/ ) {
            ApzCOB.createCreditCard();
            // ApzCOB.LaunchConfiguredScreens();
        } else {
            apz.app.BaseScreens.getCommomCodeBasedOnProduct();
            //  if (gApzCOB.product === "DEPOSIT" || gApzCOB.product === "LOAN" || gApzCOB.product === "CARDS") {
            apz.app.SelectProduct.LoadFlowForAllProducts();
            /*if (gApzCOB.productCode === gApzCOB.productDetails.productCode || apz.isNull(gApzCOB.productDetails.productCode)) {
                if (gApzCOB.product === "DEPOSIT" || gApzCOB.product === "CARDS" || gApzCOB.product === "LOAN") {
                    gApzCOB.applicationType = "Single Account";
                }
                apz.app.BaseScreens.CompletedAndInprogress()
                ApzCOB.LaunchConfiguredScreens();
                if (gApzCOB.product === 'CASA' && CURRENT_STAGE_NAME === 'SELECTPRODUCT') {
                    $('#' + BaseScrId + 'baseScroll').addClass(ProductScreen);
                } else {
                    $('#' + BaseScrId + 'baseScroll').removeClass(ProductScreen);
                }
                gApzCOB.productDetails.product = gApzCOB.product;
                gApzCOB.productDetails.productCode = gApzCOB.productCode;
                gApzCOB.productDetails.subProductName = gApzCOB.subProduct;
            } else {
                changeSubProduct = true;
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_INFO_TXT_EXISTINGAPPOFPRODUCT") + " " + "'" + gApzCOB.productDetails.subProductName + "'" +
                    " " + ApzCOB.getDescfromLitCode("LIT_COMM_CONF_TXT_WILLDISCARDSURETOCONTINUE"), "C", apz.app.SelectProduct.discardApp);
            }*/
        }
    }
}
apz.app.SelectProduct.modifylaunchConfigureJson = function() {
    if (gApzCOB.product === 'DEPOSIT') {
        var scrID = '';
        if (window.recurringDepEnabled === 'N') {
            scrID = 'RecDeposit'
            /*var index = STAGES.findIndex(function(el) {
                return el.split('~')[0] === 'INITIALFUND';
            })
            STAGES.splice(index, 1);
            STAGES.forEach(function(i, k) {
                stgNum = k + 1
                STAGES[k] = i.split('~')[0] + '~' + stgNum;
            })*/
        } else {
            scrID = 'FixedDeposit'
        }
        var indexVal = ConfigureScrJson.findIndex(function(el) {
            return el.ScreenID === scrID
        })
        ConfigureScrJson.splice(indexVal, 1);
    }
};
apz.app.SelectProduct.backNavigation = function() {
    if ($('#' + SelProdScrId + 'subProducts').is(':visible')) {
        window.selectedType = '';
        ApzCOB.launchMicroApp("Select", "SelectProduct", BaseScrId + "STAGE" + currRow, "");
        //$('#' + SelProdScrId + 'subProducts').addClass('sno');
        //$('#' + SelProdScrId + 'backTotoprow').removeClass('sno');
        // $('#' + SelProdScrId + 'product').removeClass('sno')
        //  ApzCOB.showLanguageSelect();
    } else if ($('#' + SelProdScrId + 'productDetails').is(':visible')) {
        $('#' + SelProdScrId + 'productDetails').addClass('sno');
        $('#' + SelProdScrId + 'backTotoprow').removeClass('sno');
        $('#' + SelProdScrId + 'subProducts').removeClass('sno')
        $(BaseScroll).addClass(SecondaryProduct);
    } else if ($('#' + SelProdScrId + 'product').is(':visible')) {
        //   ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EXIT"), "C", apz.app.SelectProduct.closeApp);
        apz.app.SelectProduct.closeApp();
    }
}
