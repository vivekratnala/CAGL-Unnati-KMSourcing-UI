apz.app.SelectProduct.paintSelectedLanguage = function() {
    var languages = ApzCOB.GetCommonCodes('APPCONTROL', "COMM")['LANGUAGE'];
    var isselectedclass = 'is-selected';
    window.gSelLangDesc = [];
    $.each(languages, function(i, k) {
        var langObj = {};
        langObj.value = k.value
        langObj.desc = apz.lits[apz.currAppId][k.value][k.desc];
        window.gSelLangDesc.push(langObj)
    })
    apz.populateDropdown(document.getElementById(SelProdScrId + 'changeLang'), window.gSelLangDesc);
    $.each(window.gSelLangDesc, function(i, k) {
        var langVal = $('#' + SelProdScrId + 'changeLang' + '_div').find('ul').children()[i].id;
        if (k.value === apz.language) {
            $('#' + SelProdScrId + 'changeLang').val(k.desc);
            $('#' + langVal).addClass(isselectedclass);
        } else if ($('#' + langVal).hasClass(isselectedclass)) {
            $('#' + langVal).removeClass(isselectedclass);
        }
    })
    var x = document.getElementById('Select__SelectProduct__changeLang');
    var y = document.getElementById('Select__SelectProduct__changeLang_div');
    x.addEventListener('click', function() {
        y.parentElement.classList.add('language');
    });
}
apz.app.SelectProduct.LoadCountForEligCards = function() {
    if (count >= 1) {
        $('#' + BaseScrId + 'STAGE' + i).children().children().eq(0).children().children().children().children().eq(1).remove()
    } else {
        count++;
    }
}
apz.app.SelectProduct.LoadKnowMoreDepForEn = function(subproduct) {
    if (apz.language === 'en') {
        apz.data.loadJsonData("DepositAccount", apz.currAppId);
        apz.data.scrdata.Select__IpaintknowMoreDetails_Res = {};
        apz.data.scrdata.Select__DepositAccount_Res[subproduct][0]['Image'] = {}
        Object.getOwnPropertyNames(CommSelectProduct).forEach(function(el) {
            if (el.split('~')[0] === selectedType) {
                CommSelectProduct[el].forEach(function(k) {
                    if (k.split('~')[0] === subproduct) {
                        apz.data.scrdata.Select__DepositAccount_Res[subproduct][0]['Image'] = k.split('~')[1];
                    }
                })
            }
        })
        apz.data.scrdata.Select__IpaintknowMoreDetails_Res.DepositAccount = apz.data.scrdata.Select__DepositAccount_Res[subproduct];
        apz.data.loadData("IpaintknowMoreDetails", apz.currAppId);
        data = apz.data.scrdata.Select__IpaintknowMoreDetails_Res.DepositAccount[0]["points"];
        //a = 'apps/styles/themes/AppzillonConsumerOnboarding/img/';
        b = apz.data.scrdata.Select__IpaintknowMoreDetails_Res.DepositAccount[0]["Image"];
        feature = apz.data.scrdata.Select__IpaintknowMoreDetails_Res.DepositAccount[0]["Feature"];
        $('#' + SelProdScrId + "Feature").text(feature);
        benefits = apz.data.scrdata.Select__IpaintknowMoreDetails_Res.DepositAccount[0]["Benefits"];
        $('#' + SelProdScrId + "Benefits").text(benefits);
        $('#' + SelProdScrId + "Image").attr('src', window.ImagePath + b);
    }
}
