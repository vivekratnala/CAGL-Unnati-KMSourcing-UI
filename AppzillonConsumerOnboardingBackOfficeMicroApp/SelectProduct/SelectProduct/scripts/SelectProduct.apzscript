apz.app.SelectProduct.compareProductFeature = function() {
    for (var m = 0; m < $('#' + SelProdScrId + CompareDiscription).length; m++) {
        var featureNamelen = apz.data.scrdata.Select__IpaintProductDetails_Res['featureName'].length;
        var tablerowlen = $('#' + SelProdScrId + CompareDiscription).length;
        var lastrowlen = $('#' + SelProdScrId + CompareDiscription).length - 1;
        if (tablerowlen > featureNamelen) {
            $('#' + SelProdScrId + CompareDiscription).eq(lastrowlen).remove();
        }
        for (var n = $('#' + SelProdScrId + CompareDiscription).eq(m).children().length - 1; n > 1; n--) {
            $('#' + SelProdScrId + CompareDiscription).eq(m).children().eq(n).remove();
        }
    }
};
apz.app.SelectProduct.discardApp = function(params) {
    apz.app.SelectProduct.discardAppCB(params);
}
apz.app.SelectProduct.discardAppCB = function(params) {
    if (params.choice === true) {
        //otpVerified = false;
        if (changeSubProduct) {
            apz.app.BaseScreens.getCommomCodeBasedOnProduct();
            //navin changes while changing the product in SELECT PRODUCT SCREEN
            gApzCOB.productDetails.product = gApzCOB.product;
            gApzCOB.productDetails.productCode = gApzCOB.productCode;
            gApzCOB.productDetails.subProductName = gApzCOB.subProduct;
            /**********/
        }
        if (!apz.isNull(gApzCOB.userDetails.applicationId)) {
            gApzCOB.userDetails.currentScreen = 'CUSTVERIFICATION';
            if (gApzCOB.product === "CASA") {
                ApzCOB.VerifyApplication();
            } else if (gApzCOB.product === "DEPOSIT") {
                //gApzCOB.userDetails.currentScreen = 'CUSTVERIFICATIONDP';
                ApzCOB.DepositVerifyApplication();
            } else if (gApzCOB.product === "CARDS") {
                //gApzCOB.userDetails.currentScreen = 'CUSTVERIFICATIONCDEC';
                ApzCOB.CardVerifyApplication();
            } else if (gApzCOB.product === "LOAN") {
                //gApzCOB.userDetails.currentScreen = 'CUSTVERIFICATIONLN';
                ApzCOB.LoanVerifyApplication();
            }
        } else {
            changeSubProduct = false;
            ApzCOB.LaunchConfiguredScreens();
        }
    } else {
        apz.app.BaseScreens.hide();
        $('#APZCBO__BaseScreens__baseRow').removeClass('close-menu');
    }
}
apz.app.SelectProduct.DipDiscardApp = function(params) {
    apz.app.SelectProduct.DipDiscardAppCB(params);
}
apz.app.SelectProduct.DipDiscardAppCB = function(params) {
    if (params.choice === true) {
        gApzCOB.applicationType = "Single Account"
        if (apz.isNull(gApzCOB.userDetails.applicationId)) {
            ApzCOB.LaunchConfiguredScreens();
        } else {
            ApzCOB.DepositVerifyApplication();
        }
    } else {
        apz.app.BaseScreens.hide();
    }
}
apz.app.SelectProduct.loadCustLitConf = function() {
    var MainHeadr = '';
    var InfoHeadr = '';
    switch (gApzCOB.product) {
        case "CARDS":
            //loadData = ApzCOB.GetCommonCodes("CUSTVERIFICATIONCD");
            loadData["LITCODES"].forEach(function(el) {
                MainHeadr = ApzCOB.getLitsDescfromServer("LIT_NON_PERIOD");
                InfoHeadr = ApzCOB.getLitsDescfromServer("LIT_NON_ELI_CONTCTNO");
            });
            break;
        default:
            break;
    }
    apz.setElmValue(BaseScrId + "Applyperiod", ApzCOB.getDescfromLitCode("LIT_YOUCAN_APPLY") + " " + MainHeadr + " months");
    apz.setElmValue(BaseScrId + "contactUsno", ApzCOB.getDescfromLitCode("LIT_YOUCAN_CONTACT") + " " + InfoHeadr);
}
apz.app.SelectProduct.FetchEligiblelist = function() {
    var req = {
        "apiRequest": {
            "interfaceName": "FetchEligibleCards",
            "requestObj": {
                "kycID": ""
            }
        }
    }
    /*var req = {
        "appId": gAppId,
    }*/
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "FetchEligibleCards", "N", "N", req, false, apz.app.SelectProduct.FetchEligiblelistCB);
}
apz.app.SelectProduct.FetchEligiblelistCB = function(params) {
    apz.stopLoader();
    gApzCOB.userDetails.eligibleCardsList = []
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            for (let i = 0; i < response.eligibleCards.length; i++) {
                gApzCOB.userDetails.eligibleCardsList.push(response.eligibleCards[i].productCode);
            }
            gApzCOB.userDetails.allCardInfo = response;
            gApzCOB.userDetails.allCardInfo = response;
            if (window.itscards) {
                window.itscards = false;
                apz.app.SelectProduct.FetchProductsDetails();
            }
            //for(i=0;i<)
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};
//function to remove main product list from Eligible Cards Screen.
apz.app.SelectProduct.removeMainProductList = function(params) {
    var totaldivs = $('div[id^= "' + BaseScrId + '' + "STAGE" + '"]').length;
    for (var i = 1; i < totaldivs; i++) {
        if (!apz.isNull($('#' + BaseScrId + 'STAGE' + 1).children()[0])) {
            if (!apz.isNull($('#' + BaseScrId + 'STAGE' + i).children()[0])) {
                if ($('#' + BaseScrId + 'STAGE' + i).children()[0]['id'] === 'scr__Select__SelectProduct__main') {
                    apz.app.SelectProduct.LoadCountForEligCards();
                    /*if (count >= 1) {
                        $('#' + BaseScrId + 'STAGE' + i).children().children().eq(0).children().children().children().children().eq(1).remove()
                    } else {
                        count++;
                    }*/
                }
            }
        }
    }
    apz.data.loadData('IpaintProduct', apz.currAppId);
}
apz.app.SelectProduct.swiper = function() {
    $("#" + comDivDash).addClass(swipercontainertext);
    $("#" + comDivDash).find("ul").removeClass("pri");
    $("#" + comDivDash).find("ul").addClass(SwiperWrapper);
    // $("#Select__SelectProduct__productList ul > li").addClass(SwiperSlider);
    $(dashboPrevBtn).addClass(SwiperButtonPrev);
    $(dashboNextBtn).addClass(SwiperButtonNext);
    try {
        new Swiper(SwiperContainer, {
            slidesPerView: 4,
            slidesPerGroup: 1,
            spaceBetween: 0,
            longSwipes: true,
            initialSlide: "0",
            loop: false,
            onSlideChangeEnd: function(swiper) {
                if (swiper.isEnd) {
                    $(dashboNextBtn).addClass(swiperBtnDisable);
                    $(dashboPrevBtn).removeClass(swiperBtnDisable);
                }
                if (swiper.isBeginning) {
                    $(dashboPrevBtn).addClass(swiperBtnDisable);
                }
            },
            touchMoveStopPropagation: true,
            pagination: SwiperPagination,
            clickable: true
        });
    } catch {
        //do nothing
    }
}
