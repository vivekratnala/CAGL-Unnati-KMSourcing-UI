//Compare nav
apz.app.SelectProduct.goToCompare = function(param) {
    // cmpCount = 0;
    $('span[id^=' + "'" + SelProdScrId + 'compareRow_row' + "'" + ']').removeClass('add'); // reset the buttons before comparing
    $('span[id^=' + "'" + SelProdScrId + 'addToCompare_' + "'" + ']').text(AddToCompare);
    $('#' + SelProdScrId + 'cmpBtn').attr('disabled', true);
    $("#" + SelProdScrId + "cmpBtn").text(ApzCOB.getDescfromLitCode("LIT_SELECTPRODUCT_BTN_TXT_COMPARE"));
    if (param === 'compare') {
        $("#" + SelProdScrId + "productDetails").addClass("compare");
        $(".applyRow").addClass("sno");
        $('#' + SelProdScrId + 'subProducts').addClass('sno');
        $('#' + SelProdScrId + 'product').addClass('sno');
        $('#' + SelProdScrId + 'backTotoprow').addClass('sno');
        $('#' + SelProdScrId + 'productDetails').removeClass('sno');
        $("#" + SelProdScrId + "headingTxt_txtcnt").text(ApzCOB.getDescfromLitCode("LIT_SELECTPRODUCT_TXT_SUBTITLE_COMPARE"));
        $(BaseScroll).removeClass(SecondaryProduct);
        if (gApzCOB.product === 'CARDS') {
            if (CURRENT_STAGE_NO >= 3) {
                $("#APZCOB__BaseScreens__headerText").text(ApzCOB.getDescfromLitCode("LIT_SELECTPRODUCT_TXT_SUBTITLE_COMPARE"));
                $('#Select__SelectProduct__proDetRow').removeClass("sno");
                $('#Select__SelectProduct__sc_row_9').addClass('sno');
                $('#Select__SelectProduct__sc_col_2').removeClass('sno');
                $('#APZCOB__BaseScreens__headerText').addClass('sno');
                $('#Select__SelectProduct__productDetails').addClass('grb product-second product select-product');
                $('#Select__SelectProduct__productDetails').removeClass('product-second select-product');
            }
        }
    } else if (param === 'product') {
        $("#" + SelProdScrId + "productDetails").removeClass("compare");
        $(BaseScroll).addClass(SecondaryProduct);
        $(".applyRow").removeClass("sno");
        $('#' + SelProdScrId + 'subProducts').removeClass('sno');
        $('#' + SelProdScrId + 'backTotoprow').removeClass('sno');
        $('#' + SelProdScrId + 'product').addClass('sno');
        $('#' + SelProdScrId + 'productDetails').addClass('sno');
        $("#" + SelProdScrId + "headingTxt_txtcnt").text(ApzCOB.getDescfromLitCode("LIT_SELECTPRODUCT_TXT_SUBTITLE_FIND_SUITABLE"));
    }
};
apz.app.SelectProduct.addToCompare = function(pthis) {
    var id = pthis.id;
    var rowno = $("#" + id).attr("rowno");
    var btnType = $(pthis).text()
    var selectedProduct = apz.data.scrdata.Select__IpaintProductDetails_Res.data[rowno].productName;
    if (!apz.isNull(btnType)) {
        if (btnType === AddToCompare) {
            // cmpCount = parseInt(cmpCount) + 1;
            $('#' + SelProdScrId + 'addToCompare_' + rowno).parent().next().parent().addClass("add");
            $('#' + SelProdScrId + 'addToCompare_' + rowno + "_txtcnt").text("Selected");
            selectedProd.push(apz.data.scrdata.Select__IpaintProductDetails_Res.data[rowno]);
            apz.app.SelectProduct.ComparePro();
        }
    } else {
        // if (btnType === "Selected") {
        // cmpCount = parseInt(cmpCount) - 1;
        $('#' + SelProdScrId + 'addToCompare_' + rowno).parent().next().parent().removeClass("add");
        $('#' + SelProdScrId + 'addToCompare_' + rowno + "_txtcnt").text(AddToCompare);
        selectedProd.forEach(function(data, index) {
            if (selectedProduct === data.productName) {
                return selectedProd.splice(index, 1);
            }
            return []
        })
        apz.app.SelectProduct.ComparePro();
    }
    //  }
};
apz.app.SelectProduct.compareFeatures = function(pthis) {
    ApzCOB.toggleModal(SelProdScrId + 'compareModal');
    //var listData = '';
    var compareData = selectedProd;
    // var tempArr = [];
