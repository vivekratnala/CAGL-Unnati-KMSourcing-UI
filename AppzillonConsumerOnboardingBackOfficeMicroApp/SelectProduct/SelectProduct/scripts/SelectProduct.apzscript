        $('#' + SelProdScrId + "Benefits").text(benefits);
        $('#' + SelProdScrId + "Image").attr('src', window.ImagePath + b);
    }
    data.forEach(function(m, n) {
        if (n > 0) {
            var prodDescOuterHtml = $('#' + SelProdScrId + 'featureDesctxt')[0].outerHTML;
            var a = $('#' + SelProdScrId + 'featureDesctxt_li').children().length;
            $('#' + SelProdScrId + 'featureDesctxt_li').children().eq(a - 1).after(prodDescOuterHtml);
            $('#' + SelProdScrId + 'featureDesctxt_li').children().eq(a).find('span').text(m)
        } else {
            $('#' + SelProdScrId + 'featureDesctxt_li').children().find('span').text(m)
        }
    })
}
