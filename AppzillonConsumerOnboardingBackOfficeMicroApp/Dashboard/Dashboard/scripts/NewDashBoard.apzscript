apz.app.NewDashBoard.rem_add_ActClass = function(params) {
    $('.my-task-tab button').removeClass('active');
    $(`#${params.id}`).addClass('active');
};
apz.app.NewDashBoard.setvalforTabs = function(){
    if (gApzCOB.selectedRole == 'RPC_Maker') {
        if (rpcDashboardActiveType == 'PENDING') {
            window.dashtab = 'all';
        } else if (rpcDashboardActiveType == 'COMPLETED') {
            window.dashtab = 'pendingForRPCVerification';
        } else if (rpcDashboardActiveType == 'PUSHBACK') {
            window.dashtab = 'pushBack';
        }
    } else if (gApzCOB.selectedRole == 'RPC_Checker') {
        if (rpcDashboardActiveType == 'PENDING') {
            window.dashtab = 'all';
        } else if (rpcDashboardActiveType == 'COMPLETED') {
            window.dashtab = 'rpcVerified';
        } else if (rpcDashboardActiveType == 'PUSHBACK') {
            window.dashtab = 'allSentBack';
        }
    }
}
apz.app.NewDashBoard.onFocusSearchInput = function() {
    $(`#${scrId}searchInput`).css({'border-color': ''});
};
apz.app.NewDashBoard.searchInpData = function(pthis) {
    searchVal = $(`#${scrId}searchInput`).val();
    apz.app.NewDashBoard.setvalforTabs();
    let lselectedId = {
        "id" : "Dashbo__NewDashBoard__allBtn"
    }
    apz.app.BaseScreens.fetchRPCDashboardData(window.dashtab, "searchApplication", lselectedId, 1);
};
apz.app.NewDashBoard.primarLaunch = function(pthis) {
    let rowno = document.getElementById(pthis.id).getAttribute('rowno');
    window.data = apz.data.scrdata.Dashbo__IPaintDashCase_Res[rowno];
    let applnId = data.applicationId;
    let req = {
        "apiRequest": {
            "interfaceName": "",
            "appId": gAppId,
            "requestObj": {
                "applicationId": applnId,
                "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                //  "applicationId": "16202346089849322",
                "appId": gApzCOB.userDetails.appId,
                "versionNum": 1
            }
        }
    }
    let lcallback = apz.app.NewDashBoard.primarLaunchCB;
    if(gApzCOB.selectedRole == "RPC_DB_verification") {
        lcallback = apz.app.NewDashBoard.launchDbMicroAppCB;
    }
    apz.startLoader();
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, "FetchApplication", "N", "N", req, false, lcallback);
    }, 1000)
};
apz.app.NewDashBoard.primarLaunchCB = function(params) {
    let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            gApzCOB.rpcStages = [];
            gApzCOB.rpcStages = Object.values(RPC_STAGES);
            ApzCOB.updateInsessionData(params);
                    if(rpcDashboardActiveType === 'PENDING'){
                        apz.app.NewDashBoard.fnlockApplicaton("lockUser", gApzCOB?.userDetails?.applicationId);
                        ApzCOB.launchMicroApp('RPC', 'RpcStageScreen', 'APZCBO__BaseScreens__BaseDIV', "");
                        if (apz.deviceType == 'WEB') {
                            $("#APZCBO__BaseScreens__logoutIcon").addClass("sno");
                            $("#APZCBO__BaseScreens__home_Icon").removeClass("sno");
                        }  
                        window.isRpcDashboardPreview = false;
                        window.isRpcPreviewEnabled = false;
                    } else {
                        isRpcDashboardPreview = true;
                    ApzCOB.previewModal();
                    }
        } else {
            apz.stopLoader();
            let responseMsg = params?.res?.APZCBO__FetchApplication_Res?.apiResponse?.ResponseBody?.responseObj || "";
            if (responseMsg.includes('GK')) {
                $(`#${scrId}locktxt_txtcnt`).text(responseMsg);
                ApzCOB.toggleModal(scrId + 'lockModal');
            } else {
                if (responseMsg.includes('Renewal')) {
                    errMsg = responseMsg;
                }
                $(`#${scrId}locktxt_txtcnt`).text(errMsg);
                ApzCOB.toggleModal(scrId + 'lockModal');
            }
        }
    } catch {
        apz.stopLoader();
        ApzCOB.toggleModal(scrId + 'lockModal');
        $(`#${scrId}locktxt_txtcnt`).html(technicalErrMsg);
    }
};
apz.app.NewDashBoard.addPointer = function(params) {
    if (params == "") {
        for (let i = 0; i < apz.data.scrdata.Dashbo__IPaintDashCase_Res.length; i++) {
            $("#Dashbo__IPaintDashCase__o__Dashbo__IPaintDashCase_Res__applicationId_" + i).css("cursor", "pointer");
        }
    } else {
        for (let i of params) {
            $("#" + scrId + i).css("cursor", "pointer");
        }
    }
};
apz.app.NewDashBoard.tat_formatDate = function(input) {
    const timeRegex = /(\d{1,5})S\|(\d{1,5})M\|(\d{1,5})H\|(\d{1,5})D/;
    const match = input.match(timeRegex);
    let str = "";
    if (!match) {
        throw new Error("Invalid input format");
    }
    if (match[match.length - 1] != 0) {
        str = match[match.length - 1] + "Days Before";
    } else if (match[match.length - 2] != 0) {
        str = match[match.length - 2] + "hours Before";
    } else if (match[match.length - 3] != 0) {
        str = match[match.length - 3] + "minutes Before";
    } else if (match[match.length - 4] != 0) {
        str = "Just now";
    }
    return str;
};
apz.app.NewDashBoard.sortTat = function(params) {
    const getSeconds = (tat) => {
        if (tat?.toLowerCase()?.includes("day")) {
            return parseInt(tat) * 24 * 60 * 60;
        }
        if (tat?.toLowerCase()?.includes("hour")) {
            return parseInt(tat) * 60 * 60;
        }
        if (tat?.toLowerCase()?.includes("minutes")) {
            return parseInt(tat) * 60;
        }
        return 0;
    };
    apz.data.scrdata.Dashbo__IPaintDashCase_Res.sort((a, b) => {
        const tatA = getSeconds(a.rpcTAT);
        const tatB = getSeconds(b.rpcTAT);
        return params === "One" ? tatA - tatB : tatB - tatA;
    });
    $(`#Dashbo__NewDashBoard__tatSortDown,#Dashbo__NewDashBoard__tatSortUp`).attr('style','');
    let rpctatCSS = {'fill': 'rgb(0, 72, 134)'};
    if(params === "One") {
        $(`#${scrId}tatSortDown`).css(rpctatCSS);
    } else {
        $(`#${scrId}tatSortUp`).css(rpctatCSS);
    }
    apz.data.loadData('IPaintDashCase', 'Dashbo');
};
apz.app.NewDashBoard.PaginationInput = function() {
    apz.app.NewDashBoard.setvalforTabs();
    let enteredPageNo = parseInt($(`#${scrId}pageInputbox`).val());
    if (enteredPageNo > 0 && enteredPageNo <= window.page_Txt) {
        window.pageInpVal = enteredPageNo;
        window.pageCount = window.pageInpVal;
        $(`#${scrId}paginationPrevBtn`).prop("disabled", true);
        $(`#${scrId}paginationNextBtn`).prop("disabled", true);
        if (window.pageCount == 1) {
            $(`#${scrId}paginationPrevBtn`).prop("disabled", false);
        }
        if (window.pageCount == window.page_Txt) {
            $(`#${scrId}paginationNextBtn`).prop("disabled", false);
        }
        let activeId = $("#Dashbo__NewDashBoard__sc_row_25 button.active").attr('id');
        apz.app.BaseScreens.fetchRPCDashboardData(window.dashtab, "tabSwitch", {"id": activeId}, window.pageInpVal);
    } else {
        $(`#${scrId}pageInputbox`).val(parseInt(window.pageCount));
        ApzCOB.showRpcModals({
                    text: 'Invalid page number',
                    Btn1: {
                        text: "OK",
                        onClick: "apz.app.NewDashBoard.closeRPCErrMdl()"
                    }
        }, "Error");
    }
};
apz.app.NewDashBoard.nextBtn = function() {
    apz.app.NewDashBoard.setvalforTabs();
    if (window.pageCount != window.page_Txt) {
        window.pageCount += 1;
        let activeId = $("#Dashbo__NewDashBoard__sc_row_25 button.active").attr('id'); 
        apz.app.BaseScreens.fetchRPCDashboardData(window.dashtab, "tabSwitch", {"id": activeId}, window.pageCount);
        $(`#${scrId}paginationPrevBtn`).prop("disabled", false);
    }
};
apz.app.NewDashBoard.prevBtn = function() {
    apz.app.NewDashBoard.setvalforTabs();
    window.pageCount -= 1;
    if (window.pageCount == 1) {
        $(`#${scrId}paginationPrevBtn`).prop("disabled", true);
    }
    let activeId = $("#Dashbo__NewDashBoard__sc_row_25 button.active").attr('id'); 
    apz.app.BaseScreens.fetchRPCDashboardData(window.dashtab, "tabSwitch", {"id": activeId}, window.pageCount);
};
apz.app.NewDashBoard.convertValuesToString = function(obj) {
    if (typeof obj !== "object" || obj === null) {
        return String(obj); // Convert primitive values to string
    }
    if (Array.isArray(obj)) {
        return obj.map(item => apz.app.NewDashBoard.convertValuesToString(item)); // Convert array items
    }
    return Object.fromEntries(Object.entries(obj).map(([key, value]) => [key, apz.app.NewDashBoard.convertValuesToString(value)]));
};
apz.app.NewDashBoard.validDuplicate = function(data, appliId) {
    let flag = true;
    for (let i of data) {
        if (i.applicationId == appliId) {
            flag = false;
        }
    }
    return flag;
};
apz.app.NewDashBoard.pageCountTxt = function(params) {
    if (window.page_Txt == 0) {
        // window.page_Txt = 1;
        $(`#${scrId}paginationPrevBtn`).prop("disabled", true);
        $(`#${scrId}paginationNextBtn`).prop("disabled", true);
        $("#" + scrId + "Pageofpage_txtcnt").text("Page " + window.page_Txt + " of " + window.page_Txt);
    } else {
        if (window.page_Txt <= 1) {
            $(`#${scrId}paginationPrevBtn`).prop("disabled", true);
            $(`#${scrId}paginationNextBtn`).prop("disabled", true);
            $(`#${scrId}pageInputbox`).prop("disabled", true);
        } else if (window.page_Txt > 1) {
            if (window.pageCount == 1) {
                $(`#${scrId}paginationPrevBtn`).prop("disabled", true);
                $(`#${scrId}paginationNextBtn`).prop("disabled", false);
                $(`#${scrId}pageInputbox`).prop("disabled", false);
            } else if (window.pageCount == window.page_Txt) {
                $(`#${scrId}paginationPrevBtn`).prop("disabled", false);
                $(`#${scrId}paginationNextBtn`).prop("disabled", true);
                $(`#${scrId}pageInputbox`).prop("disabled", false);
            } else {
                $(`#${scrId}paginationNextBtn`).prop("disabled", false);
                $(`#${scrId}paginationPrevBtn`).prop("disabled", false);
                $(`#${scrId}pageInputbox`).prop("disabled", false);
            }
        }
        $("#" + scrId + "Pageofpage_txtcnt").text("Page " + window.pageCount + " of " + window.page_Txt);
    }
};
apz.app.NewDashBoard.fnlockApplicaton = function(params, applicId) {
    var request = {
        "apiRequest": {
            "interfaceName": params,
            "appId": gAppId,
            "requestObj": {
                "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                "applicationId": applicId
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "CommonAPI", "N", "N", request, false, apz.app.NewDashBoard.fnlockApplicatonCB);
};
apz.app.NewDashBoard.fnlockApplicatonCB = function(params) {
    apz.stopLoader();
}
apz.app.NewDashBoard.closeLockModal = function() {
    if ($("#" + scrId + 'lockModal').is(":visible")) {
        $('#' + scrId + 'lockModal_close').trigger('click');
    }
};
apz.app.NewDashBoard.headerTab = function(params, tabType) {
    $(`#${scrId}searchInput`).css({'border-color': ''});
    $(`#${scrId}tatSortDown,#${scrId}tatSortUp`).attr('style','');
    window.rpcDashboardActiveType = tabType;
    let arrId = ['rpc_COMPLETED_Tab', 'rpc_PENDING_Tab', 'rpc_PUSHBACK_Tab'];
    for (let i of arrId) {
        if ($("#" + scrId + i).hasClass('active-dash')) {
            $("#" + scrId + i).removeClass('active-dash');
        }
    }
    let id = params.id.split("__")[2];
    $("#" + scrId + id).addClass('active-dash');
    window.pageCount = 1;
    $("#Dashbo__NewDashBoard__pageInputbox").val(window.pageCount);
    if (id == "rpc_COMPLETED_Tab") {
        if (gApzCOB.selectedRole == 'RPC_Maker') {
            apz.app.BaseScreens.fetchRPCDashboardData("pendingForRPCVerification", "headerTabSwitch", "", 1);
            $(`#${scrId}el_label_20`).text("Pending with Checker");
            $(`#${scrId}allBtn`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("pendingForRPCVerification","tabSwitch",this,1)`);
            $(`#${scrId}sc_col_47`).addClass("brdr-left")
        } else if (gApzCOB.selectedRole == 'RPC_DB_verification') {
            apz.app.BaseScreens.fetchRPCDashboardData("DBKITVERIFIED", "headerTabSwitch", "", 1);
            $(`#${scrId}el_label_20`).text("Approved");
            $(`#${scrId}sc_col_47`).addClass("brdr-left");
            $(`#${scrId}allBtn`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("DBKITVERIFIED","tabSwitch",this,1)`);
            $(`#${scrId}sc_col_49`).addClass("brdr-left");
        } else {
            apz.app.BaseScreens.fetchRPCDashboardData("rpcVerified", "headerTabSwitch", "", 1);
            $(`#${scrId}el_label_20`).text("Approved");
            $(`#${scrId}sc_col_47`).addClass("brdr-left");
            $(`#${scrId}allBtn`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("rpcVerified","tabSwitch",this,1)`);
            $(`#${scrId}sc_col_49`).addClass("brdr-left");
        }
        $(`#${scrId}checkerToMakerPushback`).hide();
        $(`#${scrId}subTab1`).hide();
        $(`#${scrId}el_hpl_3`).hide();
    } else if (id == "rpc_PUSHBACK_Tab") {
        if (gApzCOB.selectedRole == 'RPC_Maker') {
            apz.app.BaseScreens.fetchRPCDashboardData("IPUSHBACK", "headerTabSwitch", "", 1);
            $(`#${scrId}allBtn`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("IPUSHBACK","tabSwitch",this,1)`);
            $(`#${scrId}checkerToMakerPushback`).hide();
            $(`#${scrId}subTab1`).hide();
            $(`#${scrId}el_hpl_3`).hide();
            $(`#${scrId}el_label_20`).text("Sent Back");
        } else if(gApzCOB.selectedRole == 'RPC_DB_verification') {
            apz.app.BaseScreens.fetchRPCDashboardData("DBPUSHBACK", "headerTabSwitch", "", 1);
            $(`#${scrId}allBtn`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("DBPUSHBACK","tabSwitch",this,1)`);
            $(`#${scrId}checkerToMakerPushback`).hide();
            $(`#${scrId}subTab1`).hide();
            $(`#${scrId}el_hpl_3`).hide();
            $(`#${scrId}el_label_20`).text("Sent Back");
        } else {
            apz.app.BaseScreens.fetchRPCDashboardData("allSentBack", "headerTabSwitch", "", 1);
            $(`#${scrId}checkerToMakerPushback`).hide();
            $(`#${scrId}subTab1`).show();
            $(`#${scrId}el_hpl_3`).show();
            $(`#${scrId}subTab1`).text("RPC Checker to Maker");
            $(`#${scrId}el_hpl_3`).text("RPC Checker to Sourcing");
            $(`#${scrId}subTab1`).attr("onclick", "");
            $(`#${scrId}el_hpl_3`).attr("onclick", "");
            $(`#${scrId}allBtn`).attr("onclick", "");
            $(`#${scrId}allBtn`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("allSentBack","tabSwitch",this,1)`);
            $(`#${scrId}subTab1`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("rpcPushBack","tabSwitch",this,1)`);
            $(`#${scrId}el_hpl_3`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("IPUSHBACK","tabSwitch",this,1)`);
            $(`#${scrId}el_label_20`).text("Sent Back");
            $(`#${scrId}sc_col_47`).removeClass("brdr-left")
        }
    } else {
        $(`#${scrId}checkerToMakerPushback`).show();
        $(`#${scrId}subTab1`).show();
        $(`#${scrId}el_hpl_3`).show();
        $(`#${scrId}sc_col_47`).removeClass("brdr-left");
        $(`#${scrId}subTab1`).text("Fresh Cases");
        $(`#${scrId}el_hpl_3`).text("Rework Cases");
        $(`#${scrId}el_label_20`).text("My Task");
        $(`#${scrId}subTab1`).attr("onclick", "");
        $(`#${scrId}el_hpl_3`).attr("onclick", "");
        $(`#${scrId}allBtn`).attr("onclick", "");
        $(`#${scrId}allBtn`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("all","tabSwitch",this,1)`);
        $(`#${scrId}subTab1`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("freshCases","tabSwitch",this,1)`);
        $(`#${scrId}el_hpl_3`).attr("onclick", `apz.app.BaseScreens.fetchRPCDashboardData("reworkCases","tabSwitch",this,1)`);
        $(`#${scrId}allBtn`).click();
    }
};
