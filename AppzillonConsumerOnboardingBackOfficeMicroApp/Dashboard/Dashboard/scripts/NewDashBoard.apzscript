var scrId = "Dashbo__NewDashBoard__";
window.isRPCLogin = true;
var searchVal = '';
window.rpcDashboardTypes = ['PENDING', 'COMPLETED', 'PUSHBACK'];
window.rpcDashboardActiveType = 'PENDING';
window.isRpcDashboardPreview = false;
var headerarrId = ['rpc_COMPLETED_Tab', 'rpc_PENDING_Tab', 'rpc_PUSHBACK_Tab'];
window.RPC_CURRENT_STAGE = '';
apz.app.onLoad_NewDashBoard = function() {
    $(`#${BaseScrId}sc_col_283`).removeClass("sno");
    $(`#${BaseScrId}sc_row_200`).removeClass("dashbrd-header"); 
    $('body').addClass('unati');
};
apz.app.onShown_NewDashBoard = function(params) {
    window.approvedDocs = [];
    window.dbVerificationQueries = [];
    window.reuploadedDocs = [];
    window.documentList = [];
    apz.app.NewDashBoard.setMinMaxLength();
    ApzCOB.fetchSubProduct();
    window.LoanStatusDtls = params;
    $('body').removeClass('crdas dbkit');
    $(`#${BaseScrId}loggedInUserName_txtcnt`).text(
        `${LoggedInUserDetails.loginResponse.userDet.name} (${LoggedInUserDetails.loginResponse.userDet.id})`);
        apz.app.NewDashBoard.commonElemHiding();
    if (gApzCOB.selectedRole == 'RPC_Maker') {
        apz.app.NewDashBoard.makerScrPainting();
        $(`#${BaseScrId}loggedInRole_txtcnt`).text("Role: RPC Maker");
    } else if (gApzCOB.selectedRole == 'RPC_Checker') {
        apz.app.NewDashBoard.checkerScrPainting();
        $(`#${BaseScrId}loggedInRole_txtcnt`).text("Role: RPC Checker");
    } else if (gApzCOB.selectedRole == 'RPC_DB_verification'){
        apz.app.NewDashBoard.DBVerificationPainting();
        $(`#${BaseScrId}loggedInRole_txtcnt`).text("Role: RPC DB verification");
    }
    apz.app.NewDashBoard.paintCaseAGeng();
    $(`#${scrId}allBtn`).click();
    apz.app.NewDashBoard.fnlockApplicaton("unlockUser", "");
    if (apz.deviceType == 'WEB') {
        $(`#${BaseScrId}logoutIcon`).removeClass("sno");
        $(`#${BaseScrId}home_Icon`).addClass("sno");
    }
    rpcDashboardTypes.map(types => {
        $(`#${scrId}rpc_${types}_Tab`).attr("onclick", `apz.app.NewDashBoard.headerTab(this,'${types}')`); 
        headerarrId.push(`rpc_${types}_Tab`);
    })
    apz.app.NewDashBoard.addPointer(headerarrId);
    $("body").removeClass("mak-chk");
    $(`#${scrId}rpc_PENDING_Tab`).addClass('active-dash');
    if (window.pageCount == 1) {
        $(`#${scrId}paginationPrevBtn`).prop("disabled", true);
    }
    $("#Dashbo__NewDashBoard__sc_col_59").attr("onclick", "apz.app.NewDashBoard.searchInpData(this)");
    $("input").attr("autocomplete", "off");
    let textValue = "";
    if(gApzCOB.selectedRole === 'RPC_Maker') {
        textValue = "RPC Maker to Sourcing";
    } else if (gApzCOB.selectedRole === 'RPC_DB_verification') {
        textValue = "Sent to DB Kit Execution";
    } else {
        textValue = "RPC Checker to Sourcing";
    }
    $(`#${scrId}sentBackTileInnerText`).text(textValue);
    
};
apz.app.NewDashBoard.setMinMaxLength = function() {
    const fieldMap = {
        searchInput: "searchRPC"
    };
    ApzCOB.setMinMaxLength(Object.entries(fieldMap).map(([fieldId, fieldName]) => ({
        fieldName,
        fieldId: scrId + fieldId
    })));
};
apz.app.NewDashBoard.commonElemHiding = function(){
 $(`#${scrId}makerPendingPushbackTray`).addClass("sno");  
 $(`#${scrId}checkerToMakerPushback`).addClass("sno");
  $(`#${scrId}checkerToSourcingPushback`).addClass("sno");
}
apz.app.NewDashBoard.makerScrPainting = function() {
    window.fresh_case = [];
    window.reworkCase = [];
    window.RPC_CM = [];
    $(`#${scrId}PendingMainTxt`).text("Maker's Pool")
    $(`#${scrId}compTxt`).text("Pending with Checker");
    $(`#${scrId}completedSubTxt`).text("Approved by RPC Maker");
    $(`#${scrId}makerPendingPushbackTray`).removeClass("sno");
    $(`#${scrId}checkerToMakerPushback`).removeClass("sno");
    $(`#${scrId}completedCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.PendingRpcVerification ?? ''));
    $(`#${scrId}pendingTotalCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.totalApplications ?? ''));
    $(`#${scrId}sentBackToSourcingCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.SourcingPushback ?? ''));
    $(`#${scrId}freshCaseCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.freshCases ?? ''));
    $(`#${scrId}reworkCaseCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.reworkCases ?? ''));
    $(`#${scrId}checkerToMakerPushbackCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.rpcCheckerToMaker ?? ''));
};
apz.app.NewDashBoard.formatLOan_TAT = function(params) {
    for (let i of params) {
        if (!i.loanAmount.toString().includes("₹")) {
            i.loanAmount = "₹" + ApzCOB.fn_FormatAmount(i.loanAmount);
        }
        if (!i.rpcTAT?.toLowerCase()?.includes("days") && !i.rpcTAT?.toLowerCase()?.includes("hours") && !i.rpcTAT?.toLowerCase()?.includes("minutes") && !i.rpcTAT?.toLowerCase()?.includes("just")) {
            i.rpcTAT = apz.app.NewDashBoard.tat_formatDate(i.rpcTAT);
            i.rpcTAT = i.rpcTAT.replace(/(\d{1,5})([a-zA-Z]{1,20})/, '$1 $2');
        }
    }
};
apz.app.NewDashBoard.checkerScrPainting = function() {
    $(`#${scrId}compTxt`).text("Approved");
    $(`#${scrId}completedSubTxt`).text("Approved by Checker");
    $(`#${scrId}PendingMainTxt`).text("Checker's Pool");
    $(`#${scrId}checkerToSourcingPushback`).removeClass("sno");
    $(`#${scrId}completedCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.RpcVerified ?? ''));
    $(`#${scrId}freshCaseCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.freshCases ?? ''));
    $(`#${scrId}reworkCaseCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.reworkCases ?? ''));
    $(`#${scrId}pendingTotalCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.totalApplications ?? ''));
    $(`#${scrId}checkerToMakerSendBackCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.rpcCheckerToMaker ?? ''));
    $(`#${scrId}sentBackToSourcingCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.SourcingPushback ?? ''));
};
apz.app.NewDashBoard.paintCaseAGeng = function() {
    let caseAgeingData = window.LoanStatusDtls.map.RPCCaseAgeing.myArrayList;
    if (caseAgeingData.length > 0) {
        let caseArr = caseAgeingData.map(item => ({
            days: Object.keys(item.map)[0],
            dayVal: ApzCOB.formatToTwoDigits(Object.values(item.map)[0] ?? '')
        }));
        apz.data.scrdata.Dashbo__IPaintCaseAgeng_Res = caseArr;
        apz.data.loadData('IPaintCaseAgeng', 'Dashbo');
    }
};
