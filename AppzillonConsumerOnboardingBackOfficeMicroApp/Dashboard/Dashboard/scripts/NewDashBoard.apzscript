apz.app.NewDashBoard.launchDbMicroApp = function(lappId){
    gApzCOB.userDetails.applicationId = lappId;
    gApzCOB.userDetails.versionNum = 1;
    let applnId = gApzCOB.userDetails.applicationId;
    let req = {
            apiRequest: {
                interfaceName: "",
                appId: gAppId,
                requestObj: {
                    applicationId: applnId,
                    userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                    //  "applicationId": "16202346089849322",
                    appId: gApzCOB.userDetails.appId,
                    versionNum: gApzCOB.userDetails.versionNum,
                },
            },
        };
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "FetchApplication", "N", "N", req, false, apz.app.NewDashBoard.launchDbMicroAppCB);
        }, 1000);
}
apz.app.NewDashBoard.launchDbMicroAppCB = function(params) {
    let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            ApzCOB.fetchSubProduct();//
            if (rpcDashboardActiveType === 'PENDING') {
                apz.app.NewDashBoard.fnlockApplicaton("lockUser", gApzCOB?.userDetails?.applicationId);
                ApzCOB.launchMicroApp('RPCDBV', 'RPCDBVerify', `${gAppId}__BaseScreens__BaseDIV`, '');
                isRpcDashboardPreview = false;
            } else {
                isRpcDashboardPreview = true;
                ApzCOB.RPCDBpreviewModal();
            }
        } else {
            apz.stopLoader();
            let responseMsg = params?.res?.APZCBO__FetchApplication_Res?.apiResponse?.ResponseBody?.responseObj || "";
            if (responseMsg.includes('GK')) {
                $(`#${scrId}locktxt_txtcnt`).text(responseMsg);
                ApzCOB.toggleModal(scrId + 'lockModal');
            } else {
                if (responseMsg.includes('Renewal')) {
                    errMsg = responseMsg;
                }
                $(`#${scrId}locktxt_txtcnt`).text(errMsg);
                ApzCOB.toggleModal(scrId + 'lockModal');
            }
        }
    } catch {
        apz.stopLoader();
        ApzCOB.toggleModal(scrId + 'lockModal');
        $(`#${scrId}locktxt_txtcnt`).html(technicalErrMsg);
    }
};
apz.app.NewDashBoard.DBVerificationPainting = function() {
    $(`#${scrId}compTxt`).text("Approved");
    $(`#${scrId}completedSubTxt`).text("Sent for Disbursement");
    $(`#${scrId}PendingMainTxt`).text("DB Verification");
    $(`#${scrId}sentBackTileInnerText`).text('Sent to DB Kit Execution');
    $(`#${scrId}checkerToSourcingPushback`).addClass("sno");
    $(`#${scrId}completedCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.RpcVerified ?? ''));
    $(`#${scrId}freshCaseCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.freshCases ?? ''));
    $(`#${scrId}reworkCaseCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.reworkCases ?? ''));
    $(`#${scrId}pendingTotalCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.totalApplications ?? ''));
    $(`#${scrId}sentBackToSourcingCount_txtcnt`).text(ApzCOB.formatToTwoDigits(window.LoanStatusDtls.map.SourcingPushback ?? ''));
};

apz.app.NewDashBoard.masterSearchInpData = function (pthis) {
    if (isViewAccessEnabled) {
        $(".viewDetailsBtn").removeClass('sno')
    } else {
        $(".viewDetailsBtn").addClass('sno')
    }
    apz.app.NewDashBoard.setvalforTabs();
    let searchVal = $(`#${scrId}masterSearchNew`).val();
    var req = {
        "apiRequest": {
            "requestObj": {
                "searchValue": searchVal
            },
            "interfaceName": "MasterSearchApi",
            "appId": "APZCBO"
        }
    }
    ApzCOB.serverBuildParam(gAppId, "MasterSearchApi", "N", "N", req, false, apz.app.NewDashBoard.masterSearchInpDataCB);
}
apz.app.NewDashBoard.masterSearchInpDataCB = function (params) {
     apz.stopLoader();
    ApzCOB.toggleModal("APZCBO__BaseScreens__finalSearch");
    if (ApzCOB.handleServiceCallBacks(params)) {
        apz.stopLoader();
        let masterSearchData = JSON.parse(params.res.APZCBO__MasterSearchApi_Res.apiResponse.ResponseBody.responseObj);
        if (masterSearchData.length > 0) {
            $("#APZCBO__BaseScreens__no_data_row").addClass("sno");
            $("#APZCBO__BaseScreens__search_data_row").removeClass("sno");
            apz.data.scrdata.APZCBO__MasterSearchDetails_Res = {}
            let ProductData = apz.data.scrdata.Select__IpaintProductDetails_Res.data
            const modifiedData = masterSearchData.map(item => {
                let loanTypeName = item.loanType;
                if (ProductData.length > 0 && item.loanType) {
                    const prodInfo = ProductData.find(prod => prod.productCode === item.loanType);
                    if (prodInfo) {
                        loanTypeName = prodInfo.productName;
                    }
                }
                return {
                    ...item,
                    loanType: loanTypeName,
                    customerName: `${item.customerName}/${item.customerId}`,
                    branchId: `${item.branchName}/${item.branchId}`,
                    kendraId: `${item.kendraName}/${item.kendraId}`,
                    loanAmount: item.loanAmount ? item.loanAmount : "-"
                };
            });
            apz.data.scrdata.APZCBO__MasterSearchDetails_Res.data = modifiedData;
            apz.data.loadData("MasterSearchDetails", "APZCBO");
        } else {
            $("#APZCBO__BaseScreens__search_data_row").addClass("sno");
            $("#APZCBO__BaseScreens__no_data_row").removeClass("sno");

        }
    }
};
apz.app.NewDashBoard.openReportModal = function () {
    apz.setElmValue("APZCBO__BaseScreens__fromDate", "")
    apz.setElmValue("APZCBO__BaseScreens__toDate", "")
    $('#APZCBO__BaseScreens__fromDate').datepicker("option", "maxDate", Date.parse(DATE_TODAY));
    $('#APZCBO__BaseScreens__fromDate').datepicker("option", "yearRange", "-100:+0");
    $('#APZCBO__BaseScreens__toDate').datepicker("option", "maxDate", Date.parse(DATE_TODAY));
    $('#APZCBO__BaseScreens__toDate').datepicker("option", "yearRange", "-100:+0");
    const arr = Object.entries(RPC_REPORTS_LOV).map(([desc, val]) => ({
        "val": val,
        "desc": desc
    }));
    apz.populateDropdown(document.getElementById("APZCBO__BaseScreens__reportType"), arr);
    ApzCOB.toggleModal("APZCBO__BaseScreens__DownloadReport");
};
