var DashboardViewAllAppScrId = 'Dashbo__DashboardViewAllApplication__';
var DashboardViewList = [];
var gAllowedFileTypes = {};
dashBoardtitle = window.DASHBOARD_WIDGET_SELECTED_DATA.title.replaceAll('_', ' ')
window.ACTIONABLES = [];
var role = gApzCOB.LoggedInUserDetails.loginResponse.addInfo1;
var UniqueKendras = [];
var kendraIDTag = "Dashbo__DashboardViewAllApplication__kendraID";
var meetingDayTag = "Dashbo__DashboardViewAllApplication__meetingDay";
var PleaseSelect = ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT");
var meetVal = PleaseSelect
  , kendraVal = PleaseSelect;
var leadsList = [], UniqueKendras = [], FilteredKendra = [], FilteredMeetDay = [];
var roleActionablesMap = {
    KM: ['UNATTENDED_LEADS', 'SOURCING_STAGE', 'CB_PASS_IN_KM_STAGE'],
    BM: ['BM_RECOMMENDATION_PENDING', 'SANCTION_APPROVAL_PENDING', 'DISBURSEMENT_PENDING', 'DB_KIT_GENERATION_PENDING', 'RESANCTION', 'DISBURSED'],
    AM: ['SANCTION_APPROVAL_PENDING', 'RESANCTION', 'CA_DEVIATION', 'REASSESSMENT'],
    DM_RM:['SANCTION_APPROVAL_PENDING', 'RESANCTION'],
    BCM_ACM: ['CA_DEVIATION', 'REASSESSMENT']
};
if (role === 'KM') {
    ACTIONABLES = roleActionablesMap.KM;
} else if (role === 'BM') {
    ACTIONABLES = roleActionablesMap.BM;
}  else if (['AM'].includes(role)) {
    ACTIONABLES = roleActionablesMap.AM;
} else if (['DM', 'RM'].includes(role)) {
    ACTIONABLES = roleActionablesMap.DM_RM;
} else if (['BCM', 'ACM'].includes(role)) {
    ACTIONABLES = roleActionablesMap.BCM_ACM;
}
apz.app.onLoad_DashboardViewAllApplication = function() {
    $("#" + BaseScrId + "landingRowHeader").removeClass('sno');
    $("#APZCBO__BaseScreens__sidebarController").removeClass('sno');
    $(BaseScroll).removeClass(SecondaryProduct);
    $('#APZCBO__BaseScreens__backIcon').removeClass('sno');
    $('#APZCBO__BaseScreens__headerText').removeClass('sno');
    $('#APZCBO__BaseScreens__homeicon').addClass('sno');
    $('#sidebar').addClass('sno');
    $('.stageDiv').addClass('sno');
    $('#' + BaseScrId + 'custIDandName').addClass('sno');
    $('#APZCBO__BaseScreens__BaseDIV_apz_2').removeClass('sno');
    $('#APZCBO__BaseScreens__BaseDIV_apz_2').removeClass('ssp');
    window.UNATTENDED_DATA = false;
    $('#APZCBO__BaseScreens__BaseDIV').removeClass('verify_approve');
};
apz.app.onShown_DashboardViewAllApplication = function(params) {
    $('#' + gAppId + '__BaseScreens__headerText').text(dashBoardtitle);
    $('body').removeClass("LoginBase");
    $("#" + BaseScrId + "searchByNumCol").addClass('sno');
    $("#" + BaseScrId + "applnStatus").addClass('sno');
    $("#" + BaseScrId + "footerbtnRow").addClass('sno');
    apz.app.DashboardViewAllApplication.LoadAllApplication();
     ApzCOB.fetchSubProduct();
};
apz.app.DashboardViewAllApplication.listOnClick = async function(ev) {
    let selectedStatus = dashBoardtitle.replaceAll(' ', '_');
    if (['DB_KIT_GENERATION_PENDING', 'DISBURSEMENT_PENDING','DISBURSED'].includes(selectedStatus) && apz.deviceType !== "WEB") {
        ApzCOB.fnDisplayMsg("Please use WEB login!", "E");
        return;
    }
    if (ACTIONABLES.includes(dashBoardtitle.replaceAll(' ', '_'))) {
        window.clickList = true;
        // IS_DASHBOARD_VIEW_DATA  = true;
        var growNo = $(ev).attr('rowno');
        gApzCOB.product = "LOAN";
        gApzCOB.userDetails.createdBy = apz.data.scrdata.Dashbo__DashboardViewAllApplication_Res[growNo].kmID;
        gApzCOB.userDetails.applicationId = apz.data.scrdata.Dashbo__DashboardViewAllApplication_Res[growNo].applicationId;
        gApzCOB.userDetails.customerId = apz.data.scrdata.Dashbo__DashboardViewAllApplication_Res[growNo].memberId;
        gApzCOB.userDetails.versionNum = 1;
        UNATTENDED_SCREEN = false;
        UNATTENDED_DATA = true;
        if (!apz.isNull(gApzCOB.userDetails.applicationId)) {
            // $('#' + BaseScrId + 'headerText').text(gApzCOB.userDetails.createdBy + " (" + gApzCOB.userDetails.memberId + ")");
            gApzCOB.ExistingCustomer = false;
            gApzCOB.mainProductGroupCode = gApzCOB.product;
            let clickedStatus = dashBoardtitle.replaceAll(' ', '_');
            if (gApzCOB.mainProductGroupCode === 'LOAN') {
                if (apz.isNull(window.CURRENT_STAGE_NAME) && !apz.isNull(gApzCOB.userDetails.customerId)) {
                    if (['CA_DEVIATION', 'REASSESSMENT', 'SANCTION_APPROVAL_PENDING', 'DISBURSEMENT_PENDING', 'DB_KIT_GENERATION_PENDING','RESANCTION','DISBURSED'].includes(clickedStatus)) {
                        gApzCOB.userDetails.versionNum = 1;
                        let callBackFn = '';
                        if (['DISBURSEMENT_PENDING','DB_KIT_GENERATION_PENDING','DISBURSED'].includes(clickedStatus)) {
                            callBackFn = apz.app.DashboardViewAllApplication.fetchDisbursementApplicationCB;
                        } else {
                            callBackFn = apz.app.DashboardViewAllApplication.fetchSanctionApplicationCB;
                        }
                        ApzCOB.FetchApplication("", callBackFn);
                    } else {
                        ApzCOB.FetchApplication(growNo);
                    }
                } else {
                    if (gApzCOB.ExistingCustomer) {
                        ApzCOB.LoanFetchApplication(growNo);
                    }
                }
            } else {
                if (apz.isNull(window.CURRENT_STAGE_NAME) && !apz.isNull(gApzCOB.userDetails.customerId)) {
                    ApzCOB.FetchCustomerDetails(growNo);
                } else {
                    ApzCOB.FetchApplication(growNo);
                }
            }
        } else {
            ApzCOB.startNewApplication();
        }
        /*var screenType = apz.app.Dashboard.setScreenType();
        ApzCOB.launchMicroApp('Dashbo', 'ReviewConfirm', gAppId + '__BaseScreens__BaseDIV', {
            "rowNum": rowNum,
            "screenType": screenType
        });*/
    }
};
apz.app.DashboardViewAllApplication.LoadAllApplication = function() {
    apz.stopLoader();
    UNATTENDED_SCREEN = true;
    let dashboardData = window.DASHBOARD_WIDGET_SELECTED_DATA.data;
    if (dashboardData.length === 0) {
        $('#' + DashboardViewAllAppScrId + 'searchRow').addClass('sno');
        $('#' + DashboardViewAllAppScrId + 'viewListHeader').addClass('sno');
        $('#' + DashboardViewAllAppScrId + 'viewList').addClass('sno');
        $('#' + DashboardViewAllAppScrId + 'noRecodsForm').removeClass('sno');
    } else {
        UniqueKendras = FilteredLeads.getUniqueKendra();
        UniqueKendras.unshift(ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT"));
        apz.populateDropdown(document.getElementById(DashboardViewAllAppScrId + "kendraID"), ApzCOB.formatDropDownforArray(UniqueKendras));
        apz.populateDropdown(document.getElementById(DashboardViewAllAppScrId + "meetingDay"), ApzCOB.formatDropDownforArray(KendraMeetingDays));
        apz.app.DashboardViewAllApplication.formatViewAllObj(dashboardData);
        apz.data.scrdata.Dashbo__DashboardViewAllApplication_Res = DashboardViewList;
        apz.data.loadData('DashboardViewAllApplication', 'Dashbo');
        if (dashBoardtitle === 'UNATTENDED LEADS') {
            apz.app.viewallapplication.addPriorityClass(DashboardViewList);
        }
        $('#' + DashboardViewAllAppScrId + 'searchRow').removeClass('sno');
        $('#' + DashboardViewAllAppScrId + 'viewListHeader').removeClass('sno');
        $('#' + DashboardViewAllAppScrId + 'viewList').removeClass('sno');
        $('#' + DashboardViewAllAppScrId + 'noRecodsForm').addClass('sno');
    }
};
apz.app.DashboardViewAllApplication.formatViewAllObj = function(dashboardData) {
    dashboardData.map(item => {
        let lresp = item.map;
        let memberId = apz.isNull(lresp.memberId) ? "" : lresp.memberId;
        if (apz.isNull(memberId)) {
            memberId = apz.isNull(lresp.customerId) ? "" : lresp.customerId;
        }
        let memberName = apz.isNull(lresp.firstName) ? "" : lresp.firstName;
        if (apz.isNull(memberName)) {
            memberName = apz.isNull(lresp.customerName) ? "" : lresp.customerName;
        }
        let currentStatus = apz.isNull(lresp.currentStatus) ? "" : lresp.currentStatus;
        if (!apz.isNull(lresp.currentStageNo)) {
            if (KM_STAGES.length > 0) {
                const currentStage = KM_STAGES.find(stage => parseInt(stage.key) === lresp.currentStageNo);
                if (currentStage) {
                    currentStatus = currentStage.value;
                } else {
                    currentStatus = dashBoardtitle;
                }
            } else {
                currentStatus = dashBoardtitle;
            }
        } else {
            currentStatus = dashBoardtitle;
        }
        let priority = apz.isNull(lresp.priority) ? "" : lresp.priority;
        if (apz.isNull(priority)) {
            $('#Dashbo__DashboardViewAllApplication__viewListHeader ul li span.pri.priorityVal').addClass('sno');
            $('#Dashbo__DashboardViewAllApplication__viewList ul li.pri span.dataPaintCol.priorityVal').addClass('sno');
            $('#Dashbo__DashboardViewAllApplication__viewListHeader ul li span.pri.memberName,#Dashbo__DashboardViewAllApplication__viewList ul li.pri span.dataPaintCol.memberName')
                .addClass('autoFit');
            $('#Dashbo__DashboardViewAllApplication__viewListHeader ul li span.pri.kendraName,#Dashbo__DashboardViewAllApplication__viewList ul li.pri span.dataPaintCol.kendraName')
                .addClass('autoFit');
        } else {
            $('#Dashbo__DashboardViewAllApplication__viewListHeader ul li span.pri.priorityVal').removeClass('sno');
            $('#Dashbo__DashboardViewAllApplication__viewList ul li.pri span.dataPaintCol.priorityVal').removeClass('sno');
            $('#Dashbo__DashboardViewAllApplication__viewListHeader ul li span.pri.memberName,#Dashbo__DashboardViewAllApplication__viewList ul li.pri span.dataPaintCol.memberName')
                .removeClass('autoFit');
            $('#Dashbo__DashboardViewAllApplication__viewListHeader ul li span.pri.kendraName,#Dashbo__DashboardViewAllApplication__viewList ul li.pri span.dataPaintCol.kendraName')
                .removeClass('autoFit');
        }
        let obj = {};
        obj.memberId = (!apz.isNull(memberId)) ? memberId : "";
        obj.memberName = (!apz.isNull(memberName)) ? memberName : "";;
        obj.kendraName = (!apz.isNull(lresp.kendraName)) ? lresp.kendraName : "";;
        obj.kendraId = (!apz.isNull(lresp.kendraId)) ? lresp.kendraId : "";;
        obj.vintage = (!apz.isNull(lresp.kendraVintageYrs)) ? ApzCOB.fn_unFormatAmount(lresp.kendraVintageYrs) : "";;
        obj.meetingDay = (!apz.isNull(lresp.kendraMeetingDay)) ? lresp.kendraMeetingDay : "";;
        obj.outstandingAmount = (!apz.isNull(lresp.caglOs)) ? ApzCOB.CustomizedAmountFormatting(Number(lresp.caglOs)) : "";;
        obj.kmID = (!apz.isNull(lresp.createdBy)) ? lresp.createdBy : "";;
        obj.priority = (!apz.isNull(priority)) ? priority : "";;
        obj.currentStatus = (!apz.isNull(currentStatus)) ? currentStatus : dashBoardtitle;
        obj.applicationId = (!apz.isNull(lresp.applicationId)) ? lresp.applicationId : "";;
        DashboardViewList.push(obj);
    })
    if (dashBoardtitle === 'UNATTENDED LEADS') {
        DashboardViewList = apz.app.BaseScreens.sortLeads(DashboardViewList);
    }
    return DashboardViewList;
}
apz.app.DashboardViewAllApplication.searchIB = function(ev) {
    var value = $('#' + ev.id).val();
    var array = DashboardViewList;
    window.searchLength = [];
    if (!apz.isNull(value)) {
        window.searchLength = ApzCOB.arraySearch(value, array, ["createdBy", "kendraId", "memberId", "kendraName", "meetingDay", "memberName",
            "outstandingAmount", "vintage", "currentStatus"
        ], "Dashbo__DashboardViewAllApplication_Res");
    } else {
        window.searchLength = DashboardViewList;
        apz.data.scrdata.Dashbo__DashboardViewAllApplication_Res = [...DashboardViewList];
    }
    if (window.searchLength.length === 0) {
        $("#" + DashboardViewAllAppScrId + 'viewList').addClass('sno');
        $("#" + DashboardViewAllAppScrId + "noRecodsForm").removeClass("sno");
    } else {
        $("#" + DashboardViewAllAppScrId + 'viewList').removeClass('sno');
        $("#" + DashboardViewAllAppScrId + "noRecodsForm").addClass("sno");
        apz.data.loadData('DashboardViewAllApplication', 'Dashbo');
        if (dashBoardtitle === 'UNATTENDED LEADS') {
            apz.app.viewallapplication.addPriorityClass(searchLength);
        }
        $(`#${DashboardViewAllAppScrId}viewList`).scrollTop(0, 0);
    }
    $('#Dashbo__DashboardViewAllApplication__viewList').css('max-height', 'max-content')
};
apz.app.viewallapplication.loadViewAllData = function() {
    var productfilterdArr = [];
    var indexVal = 0;
    if (window.currentApplication === 'InProgress') {
        apz.data.scrdata.Widget__IPaintWidgetInProgress_Res.WidgetData = ViewList;
        viewAllApplicationList = apz.data.scrdata.Dashbo__ViewAllApplication_Res = apz.data.scrdata.Widget__IPaintWidgetInProgress_Res.WidgetData;
        /*viewAllApplicationList.forEach(function(i, e) {
            i.subDate = new Date(i.subDate).toString("dd MMM yyyy");
        })*/
        viewAllApplicationList.forEach(function(widgetData, index) {
            if (slectedProductsArr.length > 0) {
                indexVal = slectedProductsArr.findIndex(function(e) {
                    return widgetData.productGroupCode === e;
                })
            }
            if (apz.isNull(indexVal) || indexVal >= 0) {
                if (!productfilter) {
                    widgetData.applicationDate = ApzCOB.dateformatter(widgetData.applicationDate.year + "/" + widgetData.applicationDate
                        .month + "/" + widgetData.applicationDate.day, "d M Y");
                }
                widgetData.Status = widgetData.queueStatus;
                widgetData.productIcon = apz.app.BaseScreens.getProductIcon(widgetData.productGroupCode);
                if (apz.isNull(widgetData.createdBy)) {
                    widgetData.createdBy = "Customer";
                    widgetData.mbcreatedBy = "Customer";
                } else {
