apz.app.viewallapplication.addPriorityClass = function(lArray) {
    let priorId = 'Dashbo__DashboardViewAllApplication__o__Dashbo__DashboardViewAllApplication_Res__priority_';
    for (var i = 0; i < lArray.length; i++) {
        if (!apz.isNull(lArray[i].priority)) {
            $(`#${priorId + i}_txtcnt .priority`).remove();
            $(`#${priorId + i}_txtcnt`).attr('class', `priority ${lArray[i].priority.split(' l')[0].toLocaleLowerCase()}`);
        }
    }
}
apz.app.DashboardViewAllApplication.fetchSanctionApplicationCB = function(params){
    apz.stopLoader();
     let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }  
    try {
     if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            const { CoApplicantCustomerId } = gApzCOB.userDetails;
             const coAppCBInfo = inSessionStore.cibilDetailsWrapperList.find(cb => Number(cb.cibilDetails.custDtlId) === Number(CoApplicantCustomerId)) || {};
            if(!apz.isObjectEmpty(coAppCBInfo)){
                ApzCOB.launchMicroApp('Sanct', 'DeviationSanctBase', `${gAppId}__BaseScreens__BaseDIV`, window.dashTaskData);
            } else {
                ApzCOB.fnDisplayMsg("Co-Applicant CB details not found.!", "E");
            }
     }
    } catch {
        apz.stopLoader();
    }
}
 apz.app.DashboardViewAllApplication.fetchDisbursementApplicationCB = function(params){
    apz.stopLoader();
    let errMsg = "Fetch Application Data Service Failed";
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            ApzCOB.updateInsessionData(params);
            ApzCOB.launchMicroApp('DBkitG', 'DBbase', `${gAppId}__BaseScreens__BaseDIV`, ' ');
        } else {
            ApzCOB.showNewCommonErrorModal(errMsg);}
    } catch(e) {
        ApzCOB.showNewCommonErrorModal(errMsg);
    }
}
Array.prototype.getUniqueKendra = function() {
    var obj = {}, arr= [], i, ele;
    for(i = 0; ele = this[i]; i++) {
        obj[ele.map.kendraId] = 1;
    }
    for(ele in obj) {
        arr.push(ele);
    }
    return arr;
};
apz.app.DashboardViewAllApplication.filterLeads = function(pthis) {
    if (pthis.id === kendraIDTag) {
        if (!(pthis.value === PleaseSelect)) {
            kendraVal = pthis.value;
            FilteredKendra = FilteredLeads.filter(function(el) {
                return parseInt(el.map.kendraId) === parseInt(kendraVal);
            })
            apz.app.DashboardViewAllApplication.fetchApplications(FilteredKendra);
        } else {
            FilteredKendra = [];
            kendraVal = PleaseSelect;
            apz.app.DashboardViewAllApplication.fetchApplications(FilteredMeetDay);
        }
    } else if (pthis.id === meetingDayTag) {
        if (!(pthis.value === PleaseSelect)) {
            meetVal = pthis.value.slice(0, 3).toUpperCase()
            FilteredMeetDay = FilteredLeads.filter(function(el) {
                return el.map.kendraMeetingDay === meetVal;
            })
            apz.app.DashboardViewAllApplication.fetchApplications(FilteredMeetDay);
        } else {
            FilteredMeetDay = [];
            meetVal = PleaseSelect;
            apz.app.DashboardViewAllApplication.fetchApplications(FilteredKendra);
        }
    }
    if (FilteredKendra.length > 0 || FilteredMeetDay.length > 0) {
        apz.app.DashboardViewAllApplication.filterBasedSearch(FilteredKendra, kendraVal, FilteredMeetDay, meetVal);
    } else if(kendraVal === PleaseSelect && meetVal === PleaseSelect) {
        apz.app.DashboardViewAllApplication.fetchApplications(FilteredLeads);
    }
}
apz.app.DashboardViewAllApplication.fetchApplications = function(FilteredLeads) {
    leadsList = [];
    for (var i = 0; i < FilteredLeads.length; i++) {
        let leadRow = FilteredLeads[i].map;
        var elem = {};
        elem.memberId = leadRow.customerId ?? '';
        elem.memberName = leadRow.fullName ?? '';
        elem.kendraName = leadRow.kendraName ?? '';
        elem.kendraId = leadRow.kendraId ?? '';
        elem.vintage = leadRow.noOfYrsRel ?? '';
        elem.meetingDay = leadRow.kendraMeetingDay ?? '';
        elem.priority = leadRow.priority ?? '';
        elem.currentStatus = leadRow.currentStatus ?? 'UNATTENDED LEADS';
        leadsList.push(elem);
    }
    if (leadsList.length > 0) {
        apz.data.scrdata.Dashbo__DashboardViewAllApplication_Res = {};
        apz.data.scrdata.Dashbo__DashboardViewAllApplication_Res = leadsList;
        apz.data.loadData('DashboardViewAllApplication', 'Dashbo');
        apz.app.DashboardViewAllApplication.appendPriority(leadsList);
        ['viewList', 'viewListHeader'].show();
        ['noRecodsForm'].hide();
        $(`#${DashboardViewAllAppScrId}viewList .wrapped.undefined.ssp`).remove();
    } else {
        $(`#${DashboardViewAllAppScrId}viewListHeader`).addClass('sno');
        $(`#${DashboardViewAllAppScrId}viewList`).addClass('sno');
        $(`#${DashboardViewAllAppScrId}noRecodsForm`).removeClass('sno');
    }
};
apz.app.DashboardViewAllApplication.filterBasedSearch = function(kArr, kVal, mArr, mVal) {
    if (kArr.length > 0 && mArr.length > 0) {
        PaintArr = FilteredLeads.filter(function(el) {
            return parseInt(el.map.kendraId) === kVal && el.map.kendraMeetingDay === mVal
        });
        apz.app.DashboardViewAllApplication.fetchApplications(PaintArr)
    }
};
apz.app.DashboardViewAllApplication.appendPriority = function(leadArray) {
    let baseId = 'Dashbo__DashboardViewAllApplication__o__Dashbo__DashboardViewAllApplication_Res__priority_';
    for (var i = 0; i < leadArray.length; i++) {
        if (!apz.isNull(leadArray[i].priority)) {
            let priorityText = leadArray[i].priority.trim();
            let spanId = `${baseId + i}_txtcnt`;
            if (/^normal.*$/g.test(priorityText.toLowerCase())) {
                $(`#${spanId}`).removeClass("warm").removeClass("hot").addClass("normal");
            } else if (/^warm.*$/g.test(priorityText.toLowerCase())) {
                $(`#${spanId}`).removeClass("normal").removeClass("hot").addClass("warm");
            } else if (/^hot.*$/g.test(priorityText.toLowerCase())) {
                $(`#${spanId}`).removeClass("normal").removeClass("warm").addClass("hot");
            }
            $(`#${spanId}`).text(priorityText);
        }
    }
};
