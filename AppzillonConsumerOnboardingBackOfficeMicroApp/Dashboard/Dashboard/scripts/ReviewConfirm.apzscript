// function to fetch rejected application histoty details
apz.app.ReviewConfirm.viewRejectedHistory = function() {
    var req = {
        "apiRequest": {
            "interfaceName": "",
            "appId": gAppId,
            "requestObj": {
                "applicationId": gApzCOB.userDetails.applicationId,
                "appId": gApzCOB.userDetails.appId,
            }
        }
    }
    ApzCOB.serverBuildParam("Dashbo", "ViewRejectedHistory", "N", "N", req, false, apz.app.ReviewConfirm.viewRejectedHistoryCB);
};
//RejectedHistory  Callback
apz.app.ReviewConfirm.viewRejectedHistoryCB = function(params) {
    apz.stopLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            apz.data.scrdata.Dashbo__ViewRejectedHistory_Res = response;
            apz.data.scrdata.Dashbo__ViewRejectedHistory_Res.forEach(function(widgetData, index) {
                var date = ApzCOB.dateformatter(widgetData.createTs.date.year + "/" + widgetData.createTs.date.month + "/" + widgetData
                    .createTs.date.day, "d M Y");
                var time = widgetData.createTs.time.hour + ":" + widgetData.createTs.time.minute + ":" + widgetData.createTs.time.second
                widgetData.dateTime = date + " " + time;
            })
            apz.data.loadData('ViewRejectedHistory', 'Dashbo');
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_TECHNICALDIFF"), "E");
    }
};
apz.app.ReviewConfirm.paintApplicants = function() {
    $('#' + rvwScrId + 'applicantNameList').removeClass('sno');
    apz.data.scrdata.Dashbo__IPaintJointNames_Res = [];
    var custDet = gApzCOB.requestNodes.customerDetailsList;
    var tempName = '';
    if(gApzCOB.requestNodes.customerDetailsList.length > 0){
            if (gApzCOB.requestNodes.customerDetailsList[0]["seqNumber"] === gApzCOB.requestNodes.customerDetailsList.length) {
        for (var i = custDet.length - 1; i >= 0; i--) {
            tempName = {
                'applicantName': custDet[i]['customerName'],
                'id': apz.isNull(custDet[i]['custDtlId']) ? gApzCOB.userDetails.custDtlId : custDet[i]['custDtlId']
            }
            apz.data.scrdata.Dashbo__IPaintJointNames_Res.push(tempName);
        }
    } else {
        gApzCOB.requestNodes.customerDetailsList.forEach(function(k, i) {
            tempName = {
                'applicantName': k.customerName,
                'id': apz.isNull(k.custDtlId) ? gApzCOB.userDetails.custDtlId : k.custDtlId
            }
            apz.data.scrdata.Dashbo__IPaintJointNames_Res.push(tempName);
        })
    }   
    }
    /*gApzCOB.requestNodes.customerDetailsList.forEach(function(k, i) {
        if (k.seqNumber === i + 1) {
            var tempName = {
                'applicantName': k.customerName,
                'id': apz.isNull(k.custDtlId) ? gApzCOB.userDetails.custDtlId : k.custDtlId
            }
        }
        apz.data.scrdata.Dashbo__IPaintJointNames_Res.push(tempName);
    })*/
    apz.data.loadData('IPaintJointNames', 'Dashbo');
};
apz.app.ReviewConfirm.getApplicantDetails = function(pthis) {
    $('#' + rvwScrId + 'applicantNameList .pri').children().removeClass('active');
    $('#' + pthis.id).parent().parent().addClass('active');
    gApzCOB.currentApplicant = $("#Dashbo__ReviewConfirm__applicantNameList_row_0").hasClass("active") ? 1 : 2;
    currTab = gApzCOB.currentApplicant === 1 ? 'Applicant' : 'Co-App';
    window.dontReloadRC = true;
    window.dontupdateCurrAppln = true;
    var rowNo = $('#' + pthis.id).attr('rowno');
    var curApplicantId = Number(apz.data.scrdata.Dashbo__IPaintJointNames_Res[rowNo].id);
    if (gApzCOB.product === 'LOAN') {
        gApzCOB.ExistingCustomer = false
    }
    var id = 'Dashbo__IPaintJointNames__o__Dashbo__IPaintJointNames_Res__applicantName_0'
    apz.app.ReviewConfirm.expandCollapse("collapse");
    $('#Dashbo__ReviewConfirm__pl_pnl_8_div').removeClass('active');
    ApzCOB.FetchApplication();
};
apz.app.ReviewConfirm.paintAuditDetails = function() {
    var larr = [];
    if (!apz.isNull(window.auditDtls)) {
        window.auditDtls.filter(function(e) {
            var obj = {};
            obj.dateTime = e.timeStamp;
            obj.action = e.actionTaken;
            /*var ldate = e.timeStamp.date;
            var ltime = e.timeStamp.time;
            obj.dateTime = ApzCOB.getFullDate(e, ldate.year, ldate.month, ldate.day, ltime.hour, ltime.minute, ltime.second);*/
            obj.createdBy = e.userId;
            larr.push(obj)
        })
        apz.data.scrdata.Dashbo__IPaintAuditDetails_Res = larr;
        apz.data.loadData('IPaintAuditDetails', 'Dashbo');
        for (i = 0; i < window.auditDtls.length; i++) {
            if (apz.userId === window.auditDtls[i].userId && gApzCOB.requestNodes.applicationMaster.applicationStatus !== 'INPROGRESS') {
                $('#' + rvwScrId + 'reviewFooterRow').addClass('sno')
            } else {
                $('#' + rvwScrId + 'reviewFooterRow').removeClass('sno')
            }
            if (gApzCOB.requestNodes.applicationMaster.applicationStatus === 'PUSHBACK') {
                $('#' + rvwScrId + 'reviewFooterRow').removeClass('sno')
            }
        }
    }
    // Paint Pushback History
    var listarr = [];
    if (ISPUSHBACKPPL) {
        if (window.PUSHBACK_ACTION_HISTORY.length > 0) {
            window.PUSHBACK_ACTION_HISTORY.filter(function(e) {
                var obj = {};
                obj.SendBack_Time = e.SendBack_Time;
                obj.Remarks = e.Remarks;
                obj.SendBack_Category = e.SendBack_Category;
                obj.SendBack_SubCategory = e.SendBack_SubCategory;
                obj.PID = e.PID;
                obj.SendBack_Stage = e.SendBack_Stage;
                listarr.push(obj)
            })
            apz.data.scrdata.Dashbo__IPaintPushbackHistory_Res = listarr;
            apz.data.loadData('IPaintPushbackHistory', 'Dashbo');
            ["pushbackTimeList"].show();
        } else {
            ["pushbackTimeList"].hide();
        }
    } else {
        ["pushbackTimeList"].hide();
    }
    if (gApzCOB.requestNodes.applicationMaster.applicationStatus === 'REJECTED') {
        $('#' + rvwScrId + 'reviewFooterRow').removeClass('sno');
        $('.reject-secbtn').addClass('sno');
    }
};
