        $('#' + rvwScrId + 'lname').text(apz.isNull(customerDetails.customerLName) ? "---" : customerDetails.customerLName);
        $('#' + rvwScrId + 'mobno').text(apz.isNull(customerDetails.mobileNum) ? "---" : customerDetails.mobileNum);
