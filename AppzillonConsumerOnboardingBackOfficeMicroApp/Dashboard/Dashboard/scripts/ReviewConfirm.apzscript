        $('#' + rvwScrId + 'nameCard').text((temp = bankFacilityPayload.nameOnCard) === "" ? "---" : bankFacilityPayload.nameOnCard);
        $('#' + rvwScrId + 'branchNAme').text(apz.isNull(bankFacilityPayload.branchName) ? "---" : bankFacilityPayload.branchName);
        $('#' + rvwScrId + 'branchAdd').text(apz.isNull(bankFacilityPayload.branchAddress) ? "---" : bankFacilityPayload.branchAddress);*/
