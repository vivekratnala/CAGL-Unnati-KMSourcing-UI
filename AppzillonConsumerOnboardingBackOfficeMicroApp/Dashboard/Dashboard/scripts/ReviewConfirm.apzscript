apz.app.ReviewConfirm.uploadDocs = function() {
    finalimgdata = [];
    allFileNames = [];
    allDocTypes = [];
    allAppDocID = [];
    docCallBackCounter = 0;
    apz.data.scrdata.Dashbo__IPaintDocs_Res = [];
    if (!apz.isNull(gApzCOB.requestNodes.applicationDocumentsWrapperList) && gApzCOB.requestNodes.applicationDocumentsWrapperList.length > 0) {
        //var data = gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"];
        $('#' + rvwScrId + 'docDetrow').removeClass('sno');
        let activeCustId = '';
        let custResDetails = gApzCOB.requestNodes.customerDetailsList;
        gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList = ApzCOB.sortDocuments(gApzCOB.requestNodes.applicationDocumentsWrapperList[0]?.applicationDocumentsList);
        let documentList = gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList;
        if (custResDetails.length > 1) {
            let customerDataArray = []
            if (currTab === "Applicant") {
                customerDataArray = gApzCOB.requestNodes.customerDetailsList.filter(custData => custData.customerType.toLowerCase() ===
                    "applicant");
            } else {
                customerDataArray = gApzCOB.requestNodes.customerDetailsList.filter(custData => custData.customerType.toLowerCase() !==
                    "applicant");
            }
            if (customerDataArray.length > 0) {
                activeCustId = customerDataArray[0].custDtlId;
            }
            documentList = documentList.filter(doc => doc.custDtlId === activeCustId)
        }
        if (documentList.length > 0) {
            let applicantCustId = $.each(documentList, function(i, k) {
                fileName = k.payload.documentFileName
                allFileNames.push(fileName);
                if (k.payload.screenId === "KYCVerification" && k.payload.docSide === 'Front' && k.payload.nationality === "ARE") {
                    allDocTypes.push('Emirates Front');
                } else if (k.payload.screenId === "KYCVerification" && k.payload.docSide === 'Back' && k.payload.nationality === "ARE") {
                    allDocTypes.push('Emirates Back');
                } else if (k.payload.screenId === "KYCVerification" && k.payload.docSide === 'Front' && k.payload.nationality !== "ARE") {
                    allDocTypes.push('Aadhaar Front');
                } else if (k.payload.screenId === "KYCVerification" && k.payload.docSide === 'Back' && k.payload.nationality !== "ARE") {
                    allDocTypes.push('Aadhaar Back');
                } else if (k.payload.docSide === 'Photo' || k.payload.docSide === 'Sign') {
                    allDocTypes.push(k.payload.docSide);
                } else if (k.payload.documentType === 'OtherDocs') {
                    allDocTypes.push(k.payload.documentName);
                } else {
                    allDocTypes.push(k.payload.documentType.replaceAll('_',' '));
                    allAppDocID.push(k.appDocId);
                }
            })
            if (apz.deviceType !== 'WEB') {
                $('#Dashbo__IPaintDocs__o__Dashbo__IPaintDocs_Res__docs_0').parent().parent().addClass('sno');
                apz.app.ReviewConfirm.paintDocNames(allDocTypes,allAppDocID);
            } else {
                apz.app.ReviewConfirm.downloadFileFromserver(0);
            }
        } else {
            $('#' + rvwScrId + 'docsListRow').addClass('sno');
            $('#' + rvwScrId + 'nodocsFoundRow').removeClass('sno');
        }
    } else {
        $('#' + rvwScrId + 'docsListRow').addClass('sno');
        $('#' + rvwScrId + 'nodocsFoundRow').removeClass('sno');
    }
}
apz.app.ReviewConfirm.paintDocNames = function(aDT) {
    apz.data.scrdata.Dashbo__IPaintDocs_Res = [];
    aDT.forEach(function(e, i) {
        apz.data.scrdata.Dashbo__IPaintDocs_Res.push({
            'docs': "",
            'docname': e,
            'appDocId': allAppDocID[i]
        });
    });
    if (apz.data.scrdata.Dashbo__IPaintDocs_Res.length > 0) {
        apz.data.loadData("IPaintDocs", apz.currAppId);
        $('#' + rvwScrId + 'docsListRow').removeClass('sno');
        $('#' + rvwScrId + 'nodocsFoundRow').addClass('sno');
    } else {
        $('#' + rvwScrId + 'docsListRow').addClass('sno');
        $('#' + rvwScrId + 'nodocsFoundRow').removeClass('sno');
    }
};
apz.app.ReviewConfirm.downloadFileFromserver = function(fileCounter) {
    //apz.startLoader();
    var obj = {
        docname: fileName
    };
    var applnId = !gApzCOB.ExistingCustomer && !apz.isNull(gApzCOB.requestNodes.applicationMaster) && !apz.isNull(gApzCOB.requestNodes
        .applicationMaster.relatedApplicationId) ? gApzCOB.requestNodes.applicationMaster.applicationId : gApzCOB.userDetails.applicationId;
    if (gApzCOB.mainProductGroupCode === 'DEPOSIT' || gApzCOB.mainProductGroupCode === 'LOAN') {
        var DepLoanAppId = gApzCOB.userDetails.applicationId;
        applnId = DepLoanAppId
    }
    // obj.docname = fileName;
    tempFileArr.push(obj);
    //var flname = allFileNames[fileCounter];
    var json = {
        "destinationPath": "",
        "filePath": (gApzCOB.requestNodes.appId).concat("/").concat(gApzCOB.product).concat("/").concat(applnId),
        "sessionReq": "N" //Y or N
    };
    json.destinationPath = "docs";
    json.fileName = apz.isNull(fileCounter) ? fileName : allFileNames[fileCounter];
    json.base64 = "Y";
    json.filePath = (gApzCOB.requestNodes.appId).concat("/").concat(gApzCOB.product).concat("/").concat(applnId);
    json.id = "";
    json.callBack = apz.isNull(fileCounter) ? apz.app.ReviewConfirm.viewDocMBCB : apz.app.ReviewConfirm.downloadFileFromserverCB;
    apz.startLoader();
    apz.ns.downloadFile(json);
};
/**** Callback function will be called only if bsae64 image is requested *********/
apz.app.ReviewConfirm.downloadFileFromserverCB = function(params) {
    apz.startLoader();
    if (!apz.isNull(params.base64)) {
        var obj = {
            docs: params.base64,
            docname: allDocTypes[docCallBackCounter]
        };
        /* obj.docs = params.base64;
         obj.docname = allDocTypes[docCallBackCounter];*/
        finalimgdata.push(obj);
    }
    if (!apz.isNull(gApzCOB.requestNodes.applicationDocumentsWrapperList) && gApzCOB.requestNodes.applicationDocumentsWrapperList.length >
     0) {
     let activeCustId = '';
     let custResDetails = gApzCOB.requestNodes.customerDetailsList;
     let documentList = gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList;
     if (custResDetails.length > 1) {
         let customerDataArray = []
         if (currTab === "Applicant") {
             customerDataArray = gApzCOB.requestNodes.customerDetailsList.filter(custData => custData.customerType.toLowerCase() ===
                 "applicant");
         } else {
             customerDataArray = gApzCOB.requestNodes.customerDetailsList.filter(custData => custData.customerType.toLowerCase() !==
                 "applicant");
         }
         if (customerDataArray.length > 0) {
             activeCustId = customerDataArray[0].custDtlId;
         }
         documentList = documentList.filter(doc => doc.custDtlId === activeCustId)
     }
     if (docCallBackCounter === documentList.length) {
         apz.stopLoader();
         if (finalimgdata.length > 0) {
             apz.stopLoader();  
             apz.app.ReviewConfirm.paintDocumetsInWeb(finalimgdata);
         } else {
              $('#' + rvwScrId + 'docsListRow').addClass('sno');
            $('#' + rvwScrId + 'nodocsFoundRow').removeClass('sno');
         }
     } else {
         docCallBackCounter++;
         apz.app.ReviewConfirm.downloadFileFromserver(docCallBackCounter);
     }
    }
};
apz.app.ReviewConfirm.paintDocumetsInWeb = function(finalimgdata){
    apz.data.scrdata.Dashbo__IPaintDocs_Res = finalimgdata;
                if (apz.data.scrdata.Dashbo__IPaintDocs_Res.length > 0) {
                    $('#' + rvwScrId + 'docsListRow').removeClass('sno');
                    $('#' + rvwScrId + 'nodocsFoundRow').addClass('sno');
                } else {
                    $('#' + rvwScrId + 'docsListRow').addClass('sno');
                    $('#' + rvwScrId + 'nodocsFoundRow').removeClass('sno');
                }
                apz.stopLoader();
                apz.data.loadData("IPaintDocs", apz.currAppId);
                docCallBackCounter = 0;
                apz.stopLoader();
                finalimgdata = [];
}
apz.app.ReviewConfirm.viewDocMB = function(pthis) {
    var indexId = '';
    var appDocID = $(pthis).parent().find('.mobAppDocId').text();
    allDocTypes.forEach(function(el, index) {
        if (el === pthis.textContent) {
            indexId = index;
        }
    })
    var DocArr = gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"].filter(docs => docs.appDocId === parseInt(appDocID))
    if (DocArr.length > 0) {
        let docList = DocArr.filter(doc => doc.custDtlId === CurrApplId);
        if (docList.length > 0) {
            fileName = docList[0].payload.documentFileName;
            window.ImageLocationDetails = {
                latitude: docList[0].payload.latitude || "",
                longitude: docList[0].payload.longitude || "",
                uploadedTs: docList[0].payload.uploadedTs || "",
                documentFileName: docList[0].payload.documentFileName || ""
            };
            //var data = gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"];
            apz.app.ReviewConfirm.downloadFileFromserver();
        }
    }
};
apz.app.ReviewConfirm.viewDocMBCB = function(param) {
    ApzCOB.toggleModal(rvwScrId + "viewUploadedFileModal");
    $('#' + rvwScrId + 'mbImageView').attr('src', 'data:image/png;base64,' + param.base64);
    let id = '#' + rvwScrId + 'mbImageView';
    if (Object.keys(window.ImageLocationDetails).length > 0) {
        apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
    }
    apz.stopLoader();
};
apz.app.ReviewConfirm.checkDocUploaded = function(index){
    CURRENT_APPLICANT_DETAILS_INDEX = index;
    [...mandatoryDocumentTypes] = index === 0 ? [...mandatoryDocumentTypesApp] : [...mandatoryDocumentTypesCoApp];
    window.documentProofObj = window.inSessionStore.applicationDocumentsWrapperListSess[CURRENT_APPLICANT_DETAILS_INDEX];
    let isValid = false;
    let mandateRefArray = [...mandatoryDocumentTypes];
  mandatoryDocumentTypes.map(docs => {
    let docMinCount = parseInt(docMaxAndMand.filter(docM => docM.key === docs)[0]['value'].split('~')[1]);
    if(!apz.isNull(documentProofObj)){
      if(documentProofObj[docs].length >= docMinCount){
          mandateRefArray.splice(mandateRefArray.indexOf(docs), 1);
      }
    }
  })  
  if(mandateRefArray.length === 0){
    isValid = true;  
  } else {
      isValid = false;

  }
   return isValid;
}
//Fetch products Service
apz.app.ReviewConfirm.approveReject = function (pthis, gaction) {
    /*let isValidApp = apz.app.ReviewConfirm.checkDocUploaded(0);
    let isValidCoApp = apz.app.ReviewConfirm.checkDocUploaded(1);
    if (!isValidApp) {
        ApzCOB.fnDisplayMsg('Kindly upload the mandatory document under Applicant Document Upload.', "E", "");
        return;
    }
    if (!isValidCoApp) {
        ApzCOB.fnDisplayMsg('Kindly upload the mandatory document under Co-Applicant Document Upload.', "E", "");
        return;
    }*/
    let pushbackSubmitCheck = true;
     let remarks = $('#' + rvwScrId + 'remarks').val();
    if (gaction === "APPROVED" && (PUSHBACK_QUERY_STATUS.includes(gApzCOB.userDetails.applicationStatus))) {
    const { isValid, errors } = ApzCOB.validateQueryResponses();
    if (!isValid) {
        pushbackSubmitCheck = false;
        const errorHtml = errors.join(" <br/> ");
        ApzCOB.fnDisplayMsg(
        `Below stages have send-back queries. Please enter response:<br/><br/>${errorHtml}`,
        "E",
        ""
        );
    } else {
        if(gApzCOB.userDetails.applicationStatus === 'CAPUSHBACK'){
            gaction = "CAAPPROVE";
        }
        remarks = inSessionStore?.sourcingQueryResponse?.response ?? "";
    }
    }
    if(pushbackSubmitCheck){
    apz.app.BaseScreens.stageBasedOnAction(pthis, gaction);
    if(gApzCOB.userDetails.applicationStatus === 'CAPUSHBACK' &&  gaction === "CAAPPROVE"){
         gaction = 'RPCVERIFIED' ;
    }
    window.approveRejectAction = gaction;
    if (!apz.isNull(inSessionStore.customerDetailsList)) {
        if (inSessionStore.customerDetailsList.length > 0) {
            inSessionStore.customerDetailsList.map(cust => {
                if (cust.customerType === "Applicant") {
                    gApzCOB.userDetails.custDtlId = cust.custDtlId;
                } else {
                    gApzCOB.userDetails.CoApplicantCustomerId = cust.custDtlId;
                }
            })
        }
    }
    var req = {
        "apiRequest": {
            // "interfaceName": approveRejectAction === 'APPROVED' ? "CreateApplication" : "",
            "interfaceName": "",
            "appId": gAppId,
            "requestObj": {
                "appId": gApzCOB.userDetails.appId,
                "status": approveRejectAction,
                "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                "applicationId": gApzCOB.userDetails.applicationId,
                "versionNum": gApzCOB.userDetails.versionNum,
                "custDtlId": gApzCOB.userDetails.custDtlId,
                "remarks": remarks,
                "workflow": {
                    "currentRole": gApzCOB.workflow.currentRole,
                    "action": gApzCOB.workflow.action,
                    "workflowId": gApzCOB.workflow.workflowId,
                    "stage": gApzCOB.workflow.stage
                }
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam("Dashbo", "ApproveRejectApplication", "N", "N", req, false, apz.app.ReviewConfirm.approveRejectCB);
    }
};
//Approve Reject Service Callback
apz.app.ReviewConfirm.approveRejectCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            if (approveRejectAction === "APPROVED" || approveRejectAction === 'RPCVERIFIED') {
                ApzCOB.toggleModal(BaseScrId + 'successModal');
                $('#' + BaseScrId + 'approveRow').removeClass('sno');
                $('#' + BaseScrId + 'createRow').addClass('sno');
                gApzCOB.userDetails.accNumber = response.accNumber;
                gApzCOB.userDetails.cifNum = gApzCOB.selLeadDtls.customerId;
                $('#' + BaseScrId + 'accNum').text(gApzCOB.userDetails.applicationId);
                $('#' + BaseScrId + 'cifNum').text(gApzCOB.selLeadDtls.customerId);
                $('#' + BaseScrId + 'sucText').text(ApzCOB.getDescfromLitCode("LIT_APPLICATION_APPROVED_FURTHER_PROCESS"));
                $(`#${BaseScrId}bmNewGenId_txtcnt`).text(apz.isNull(gApzCOB.selLeadDtls.pid) ? "" : gApzCOB.selLeadDtls.pid);
                var declFlag = inSessionStore?.applicationMaster?.declarationFlag;
                            if (declFlag !== 'I') {
                            $("#APZCBO__BaseScreens__sc_row_184").removeClass("sno");
                              } else {
                                $("#APZCBO__BaseScreens__sc_row_184").addClass("sno");
                            }
                // ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPLICATION_APPROVED"), "I", apz.app.Dashboard.LaunchDashboardCB);
            }
            if (approveRejectAction === "REJECTED") {
                //$('#' + BaseScrId + 'sucText').text(ApzCOB.getDescfromLitCode("LIT_APPLICATION_REJECTED"));
                if(!IS_PUSHBACKREJECT){
                ApzCOB.toggleModal(rvwScrId + 'rejectmodel');
                }
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPLICATION_REJECTED"), "S", apz.app.Dashboard.LaunchDashboardCB);
                IS_PUSHBACKREJECT = false;
            }
            if (approveRejectAction === "PUSHBACK") {
                //$('#' + BaseScrId + 'sucText').text(ApzCOB.getDescfromLitCode("LIT_APPLICATION_PUSHBACK"));
                ApzCOB.toggleModal(rvwScrId + 'rejectmodel');
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPLICATION_PUSHBACK"), "S", apz.app.Dashboard.LaunchDashboardCB);
            }
            // apz.app.BaseScreens.fetchRole();
        } else {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(params.res.Dashbo__ApproveRejectApplication_Res.apiResponse.ResponseHeader.ResponseMessage, "E");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_TECHNICALDIFF"), "E");
    }
    apz.stopLoader();
};
apz.app.ReviewConfirm.hideNshowBtns = function() {
    $("#" + rvwScrId + approveBtn + ",#" + rvwScrId + agreeBtn + ",#" + rvwScrId + rejectBtn + ",#" + rvwScrId + editBtn + ",#" + rvwScrId +
        submitBtn + ",#" + rvwScrId + cancelBtn + ",#" + rvwScrId + submit + ",#" + rvwScrId + assignToMeBtn).addClass("sno");
    !apz.isNull(gApzCOB.requestNodes.applicationMaster.remarks) ? $("#" + rvwScrId + "remarksRow").removeClass('sno') : $("#" + rvwScrId +
        "remarksRow").addClass('sno');
    $("#" + rvwScrId + "remarks").val(gApzCOB.requestNodes.applicationMaster.remarks);
    apz.app.ReviewConfirm.actionBasedOnNextStage();
};
