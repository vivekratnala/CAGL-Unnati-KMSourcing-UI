apz.app.ReviewConfirm.perAddressDetails = function() {
    //var addressdata = "";
    if (!apz.isNull(gApzCOB.requestNodes.addressDetailsWrapperList) && gApzCOB.requestNodes.addressDetailsWrapperList.length > 0) {
        //var curAddressDetails = gApzCOB.requestNodes['addressDetailsWrapperList'];
        apz.app.ReviewConfirm.LoadCustAdd();
        /*if (!apz.isNull(window.CUST_ADDRESS && window.EMP_ADDRESS.length > 0)) {
            var a = window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"]["addressList"][0];
                var RCfullAddress;
                if (a.state === ApzCOB.getDescfromLitCode("LIT_PLS_SELECT")) {
                    RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.pinCode;
                } else {
                    RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.city + ' ' + a.state + ' ' + a.pinCode;
                }
                $('#' + rvwScrId + 'addr_li').text(RCfullAddress);
            /*if (window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"].commAddEqPerAdd === 'N') {
                var a = window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"]["addressList"][0];
                var RCfullAddress;
                if (a.state === ApzCOB.getDescfromLitCode("LIT_PLS_SELECT")) {
                    RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.pinCode;
                } else {
                    RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.city + ' ' + a.state + ' ' + a.pinCode;
                }
                $('#' + rvwScrId + 'addr_li').text(RCfullAddress);
            } else {
                var a = window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"]["addressList"][0];
                var RCfullAddress;
                if (a.state === ApzCOB.getDescfromLitCode("LIT_PLS_SELECT")) {
                    RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.pinCode;
                } else {
                    RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.city + ' ' + a.state + ' ' + a.pinCode;
                }
                $('#' + rvwScrId + 'addr_li').text(RCfullAddress);
            }*/
        //}
        // $('#' + rvwScrId + 'addr').text(gApzCOB.nationalIdDetails.address);
        window.CUST_ADDRESS = gApzCOB.requestNodes.addressDetailsWrapperList;
        if (window.CUST_ADDRESS.length > 0) {
            var filteredAddr = window.CUST_ADDRESS[0].addressDetailsList.filter(function(el) {
                return parseInt(el.custDtlId) === CurrApplId && el.addressType.toLowerCase() === 'personal';
            });
            if (filteredAddr.length > 0) {
                // addressdata = window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"]["addressList"][0];
                addressdata = filteredAddr[0].payload.addressList.filter(function(el) {
                    return el.addressType.toLowerCase() === "present";
                });
                if (addressdata.length > 0) {
                    addressdata = addressdata[0];
                    applicantState = addressdata.state.toUpperCase();
                    $('#' + rvwScrId + "addressType").text(apz.isNull(addressdata["addressType"]) ? "---" : addressdata["addressType"]);
                    $('#' + rvwScrId + "pin").text(apz.isNull(addressdata["pinCode"]) ? "---" : addressdata["pinCode"]);
                    $('#' + rvwScrId + "state").text(apz.isNull(addressdata["state"]) ? "---" : addressdata["state"]).change();
                    //  $('#' + rvwScrId + "state").trigger('change');
                    $('#' + rvwScrId + "city").text(apz.isNull(addressdata["city"]) ? "---" : addressdata["city"]);
                    $('#' + rvwScrId + "addressLine1").text(apz.isNull(addressdata["addressLine1"]) ? "---" : addressdata["addressLine1"]);
                    $('#' + rvwScrId + "addressLine2").text(apz.isNull(addressdata["addressLine2"]) ? "---" : addressdata["addressLine2"]);
                    $('#' + rvwScrId + 'residenceProof').text(apz.isNull(addressdata['currentAddressProof']) ? "---" : addressdata[
                        'currentAddressProof']);
                    $('#' + rvwScrId + 'locateCoOrdinatesFor').text(apz.isNull(addressdata['locateCoOrdinatesFor']) ? "---" : addressdata[
                        'locateCoOrdinatesFor']);
                    $('#' + rvwScrId + 'locateCoOrdinates').text(apz.isNull(addressdata['locateCoOrdinates']) || 
                    addressdata['locateCoOrdinates'] === "undefined N, undefined E"? "---": addressdata['locateCoOrdinates']);
                    $(`#${rvwScrId}addressLine3`).text(apz.isNull(addressdata.addressLine3) ? "---" : addressdata.addressLine3);
                    $(`#${rvwScrId}district`).text(apz.isNull(addressdata.district) ? "---" : addressdata.district);
                    $(`#${rvwScrId}country`).text(apz.isNull(addressdata.country) ? "---" : addressdata.country);
                    $(`#${rvwScrId}presArea`).text(apz.isNull(addressdata.area) ? "---" : addressdata.area);
                    $(`#${rvwScrId}presLandmark`).text(apz.isNull(addressdata.landMark) ? "---" : addressdata.landMark);
                    $(`#${rvwScrId}ownership`).text(apz.isNull(addressdata.residenceOwnership) ? "---" : addressdata.residenceOwnership);
                    $(`#${rvwScrId}cityYears`).text(addressdata.residenceCitySince);
                    $(`#${rvwScrId}resYears`).text(apz.isNull(addressdata.residenceAddressSince) ? "---" : addressdata.residenceAddressSince);
                    $(`#${rvwScrId}typeOfHouse`).text(apz.isNull(addressdata.houseType) ? "---" : addressdata.houseType);
                }
                // var perAddrdata = window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"]["addressList"][1];
                perAddrdata = filteredAddr[0].payload.addressList.filter(function(el) {
                    return el.addressType.toLowerCase() === "permanent";
                });
                if (perAddrdata.length > 0) {
                    perAddrdata = perAddrdata[0];
                    if (!apz.isNull(perAddrdata.addressSameAs) && perAddrdata.addressSameAs == 'Y') {
                        $(`#${rvwScrId}permanentAdd`).text('Yes');
                        ['permanentAddShowDiv'].hide();
                    } else if (!apz.isNull(perAddrdata.addressSameAs) && perAddrdata.addressSameAs == 'N') {
                        $(`#${rvwScrId}permanentAdd`).text('No');
                        ['permanentAddShowDiv'].show();
                        $(`#${rvwScrId}permanentAddres1`).text(apz.isNull(perAddrdata.addressLine1) ? "---" : perAddrdata.addressLine1);
                        $(`#${rvwScrId}permanentAddres2`).text(apz.isNull(perAddrdata.addressLine2) ? "---" : perAddrdata.addressLine2);
                        $(`#${rvwScrId}permanentAddres3`).text(apz.isNull(perAddrdata.addressLine3) ? "---" : perAddrdata.addressLine3);
                        $(`#${rvwScrId}permanentPincode`).text(apz.isNull(perAddrdata.pinCode) ? "---" : perAddrdata.pinCode);
                        $(`#${rvwScrId}permanentcity`).text(apz.isNull(perAddrdata.city) ? "---" : perAddrdata.city);
                        $(`#${rvwScrId}permanentDist`).text(apz.isNull(perAddrdata.district) ? "---" : perAddrdata.district);
                        $(`#${rvwScrId}permanentState`).text(apz.isNull(perAddrdata.state) ? "---" : perAddrdata.state);
                        $(`#${rvwScrId}permanentCountry`).text(apz.isNull(perAddrdata.country) ? "---" : perAddrdata.country);
                        $(`#${rvwScrId}permArea`).text(apz.isNull(perAddrdata.area) ? "---" : perAddrdata.area);
                        $(`#${rvwScrId}permLandmark`).text(apz.isNull(perAddrdata.landMark) ? "---" : perAddrdata.landMark);
                    }
                }
                // var commAddrdata = window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"]["addressList"][2];
                commAddrdata = filteredAddr[0].payload.addressList.filter(function(el) {
                    return el.addressType.toLowerCase() === "communication";
                });
                if (commAddrdata.length > 0) {
                    commAddrdata = commAddrdata[0];
                    $(`#${rvwScrId}commAddRadio`).text(apz.isNull(commAddrdata.addressSameAs) ? "---" : commAddrdata.addressSameAs);
                    if (!apz.isNull(commAddrdata.addressSameAs) && commAddrdata.addressSameAs != 'other') {
                        ['commAddRadioShowDiv'].hide();
                    } else {
                        ['commAddRadioShowDiv'].show();
                        $(`#${rvwScrId}commAddress1`).text(apz.isNull(commAddrdata.addressLine1) ? "---" : commAddrdata.addressLine1);
                        $(`#${rvwScrId}commAddress2`).text(apz.isNull(commAddrdata.addressLine2) ? "---" : commAddrdata.addressLine2);
                        $(`#${rvwScrId}commAddress3`).text(apz.isNull(commAddrdata.addressLine3) ? "---" : commAddrdata.addressLine3);
                        $(`#${rvwScrId}commPincode`).text(apz.isNull(commAddrdata.pinCode) ? "---" : commAddrdata.pinCode);
                        $(`#${rvwScrId}commCity`).text(apz.isNull(commAddrdata.city) ? "---" : commAddrdata.city);
                        $(`#${rvwScrId}commDist`).text(apz.isNull(commAddrdata.district) ? "---" : commAddrdata.district);
                        $(`#${rvwScrId}commState`).text(apz.isNull(commAddrdata.state) ? "---" : commAddrdata.state);
                        $(`#${rvwScrId}commCountry`).text(apz.isNull(commAddrdata.country) ? "---" : commAddrdata.country);
                        $(`#${rvwScrId}commArea`).text(apz.isNull(commAddrdata.area) ? "---" : commAddrdata.area);
                        $(`#${rvwScrId}commLandmark`).text(apz.isNull(commAddrdata.landMark) ? "---" : commAddrdata.landMark);
                    }
                }
            }
        }
        // apz.app.ReviewConfirm.LoadLandMark();
    }
    /*$('#' + rvwScrId + "landMark").text(apz.isNull(addressdata["landMark"]) ? "---" : addressdata["landMark"]);
    if (window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"].commAddEqPerAdd === 'N') {
        $('#' + rvwScrId + "commAddr").text('No');
    } else {
        $('#' + rvwScrId + "commAddr").text('Yes');
    }*/
}
apz.app.ReviewConfirm.nomineeDetails = function() {
    // apz.app.BaseScreens.fetchNominee();
    window.NomineeList = [];
    if (!apz.isNull(gApzCOB.requestNodes.nomineeDetailsWrapperList) && gApzCOB.requestNodes.nomineeDetailsWrapperList.length > 0) {
        $('#' + rvwScrId + 'nomineeDetrow').removeClass('sno');
        gApzCOB.requestNodes.nomineeDetailsWrapperList[0]['nomineeDetailsList'].filter(function(p) {
            if (!apz.isNull(p.payload)) {
                NomineeList.push(p.payload);
            }
        })
    }
    if (!apz.isNull(NomineeList) && NomineeList.length !== 0) {
        var nomineeName = [],
            nomineeRel = [];
        apz.data.scrdata.Dashbo__IPaintData_Res = {}
        for (var i = 0; i < NomineeList.length; i++) {
            nomineeName.push(NomineeList[i].nomineeName)
            nomineeRel.push(NomineeList[i].nomineeRelationship);
        }
        var nomineeDetails = []
        $.each(nomineeName, function(a, b) {
            var obj = {}
            obj.nomineeName = nomineeName[a];
            obj.nomineeRelation = nomineeRel[a];
            nomineeDetails.push(obj);
        })
        $('#' + rvwScrId + 'nomineeHeaderRow').removeClass('sno');
        $('#' + rvwScrId + 'nomineeListRow').removeClass('sno');
        $('#' + rvwScrId + 'noNomineeRow').addClass('sno');
        apz.data.scrdata.Dashbo__IPaintData_Res = nomineeDetails;
        apz.data.loadData("IPaintData", apz.currAppId);
    } else {
        $('#' + rvwScrId + 'nomineeHeaderRow').addClass('sno');
        $('#' + rvwScrId + 'nomineeListRow').addClass('sno');
        $('#' + rvwScrId + 'noNomineeRow').removeClass('sno');
    }
};
apz.app.ReviewConfirm.empDetails = function() {
     let custDetails = [];
    if (currTab === "Applicant") {
        custDetails = gApzCOB.requestNodes.customerDetailsList.filter(
        cust => cust.customerType.toLowerCase() === 'applicant');
    } else {
        custDetails = gApzCOB.requestNodes.customerDetailsList.filter(
        cust => cust.customerType.toLowerCase() !== 'applicant');
    }
    if (custDetails.length > 0) {
        let disFields = ['typeOfImpairDiv', 'udidDiv', 'percentImpDiv'];
        if (custDetails[0].payload.UDID) {
            let disSts = custDetails[0].payload.isDisabled;
            if (disSts == 'Y') {
                disFields.show();
                $(`#${rvwScrId}appDisaSts`).text('Yes');
                var typImpair = custDetails[0].payload.disabilityList;
                typImpair = typImpair.join(", ");
                $(`#${rvwScrId}typeofImpair`).text(typImpair);
                $(`#${rvwScrId}udid`).text(custDetails[0].payload.UDID);
                $(`#${rvwScrId}percentImp`).text(custDetails[0].payload.disabilityPercentage);
            } else if (disSts == 'N') {
                disFields.hide();
                $(`#${rvwScrId}appDisaSts`).text('No');
            }
        } else {
            ['DisabilityDetailsDiv'].hide();
        }
        const occupation = custDetails[0].payload.occupation;
        if (occupation === 'Salaried') {
            $('#' + rvwScrId + 'el_txt_277').text('Office Address Details');
        } else {
            $('#' + rvwScrId + 'el_txt_277').text('Business Address Details');
        }
    }
    if (!apz.isNull(gApzCOB.requestNodes.occupationDetailsWrapperList) && gApzCOB.requestNodes.occupationDetailsWrapperList.length > 0) {
        // var occupationPayload = gApzCOB.requestNodes.occupationDetailsWrapperList[0].occupationDetails.payload;
        var occupationPayload = gApzCOB.requestNodes.occupationDetailsWrapperList.filter(function(el) {
            return parseInt(el.occupationDetails.custDtlId) === CurrApplId;
        })
        //if (occupationPayload.length > 0) {
        if (!apz.isNull(occupationPayload) && occupationPayload.length > 0) {    
            occupationPayload = occupationPayload[0].occupationDetails.payload
            //var a;
            var totalexperience = ""
            var yrs = occupationPayload.experience.split(" ")[0]
            if (yrs === "") {
                yrs = "0 years "
            } else {
                yrs = yrs + " years "
            }
            var mons = occupationPayload.experience.split(" ")[2]
            if (mons === "") {
                mons = "0 months"
            } else {
                mons = mons + " months"
            }
            totalexperience = yrs + mons;
            $('#' + rvwScrId + 'empDetDiv').removeClass('sno');
            var ProfOccTxt = (apz.isNull(occupationPayload.occupationType) ? "---" : occupationPayload.occupationType);
            $('#' + rvwScrId + 'profOccu').text(ProfOccTxt);
            $('#' + rvwScrId + 'yrsOfExp').text(totalexperience);
            var DesignTxt = (apz.isNull(occupationPayload.designation) ? "---" : occupationPayload.designation);
            $('#' + rvwScrId + 'designation').text(DesignTxt);
            /*var GrossIncTxt = (apz.isNull(ApzCOB.fn_FormatAmount(occupationPayload.annualIncome / 12)) ? "---" : ApzCOB.fn_FormatAmount(occupationPayload.annualIncome / 12));*/
            var GrossIncTxt = (apz.isNull(occupationPayload.grossIncome) ? "---" : ApzCOB.fn_FormatAmount(occupationPayload.grossIncome));
            $('#' + rvwScrId + 'grossInc').text(GrossIncTxt);
            var netTakeHomeTxt = (apz.isNull(occupationPayload.netTakeHome) ? "---" : ApzCOB.fn_FormatAmount(occupationPayload.netTakeHome));
            $('#' + rvwScrId + 'netTakeHome').text(netTakeHomeTxt);
            var LanNoTxt = (apz.isNull(occupationPayload.officePhone) ? "---" : occupationPayload.officePhone);
            $('#' + rvwScrId + 'lanNo').text(LanNoTxt);
            var CEmailTxt = (apz.isNull(occupationPayload.officeEmail) ? "---" : occupationPayload.officeEmail);
            $('#' + rvwScrId + 'cEmail').text(CEmailTxt);
        }
        window.CUST_ADDRESS = [];
        window.CUST_ADDRESS = gApzCOB.requestNodes.addressDetailsWrapperList;
        let officeAddressData = [];
        if (currTab === "Applicant") {
            officeAddressData = window.CUST_ADDRESS[0].addressDetailsList.filter(businessAdd => {
                return (parseInt(businessAdd.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId) && businessAdd.addressType ===
                    "Occupation")
            })
        } else {
            officeAddressData = window.CUST_ADDRESS[0].addressDetailsList.filter(businessAdd => {
                return (parseInt(businessAdd.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId) && businessAdd
                    .addressType === "Occupation")
            })
        }
        if (officeAddressData.length > 0) {
            if (!apz.isObjectEmpty(officeAddressData[0].payload.addressList[0])) {
                var a = officeAddressData[0].payload.addressList[0];
                var RCfullAddress;
                if (a.state === ApzCOB.getDescfromLitCode("LIT_PLS_SELECT")) {
                    RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.pinCode;
                } else {
                    RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.city + ' ' + a.state + ' ' + a.pinCode;
                }
                //$('#' + rvwScrId + 'ofcAddr_li').text(RCfullAddress);
                var OrgAddressTxt = (apz.isNull(RCfullAddress) ? "---" : RCfullAddress);
                $('#' + rvwScrId + 'ofcAddr').text(OrgAddressTxt);
                $(`#${rvwScrId}offAddrSameAs`).text(apz.isNull(a.addressSameAs) ? "---" : a.addressSameAs);
                $(`#${rvwScrId}bussAddr1`).text(apz.isNull(a.addressLine1) ? "---" : a.addressLine1);
                $(`#${rvwScrId}bussAddr2`).text(apz.isNull(a.addressLine2) ? "---" : a.addressLine2);
                $(`#${rvwScrId}bussAddr3`).text(apz.isNull(a.addressLine3) ? "---" : a.addressLine3);
                $(`#${rvwScrId}bussPincode`).text(apz.isNull(a.pinCode) ? "---" : a.pinCode);
                $(`#${rvwScrId}bussCity`).text(apz.isNull(a.city) ? "---" : a.city);
                $(`#${rvwScrId}bussDistrict`).text(apz.isNull(a.district) ? "---" : a.district);
                $(`#${rvwScrId}bussState`).text(apz.isNull(a.state) ? "---" : a.state);
                $(`#${rvwScrId}bussCountry`).text(apz.isNull(a.country) ? "---" : a.country);
                $(`#${rvwScrId}bussArea`).text(apz.isNull(a.area) ? "---" : a.area);
                $(`#${rvwScrId}bussLandmark`).text(apz.isNull(a.landMark) ? "---" : a.landMark);
                $(`#${rvwScrId}bussLocationCordinatefor`).text(apz.isNull(a.locateCoOrdinatesFor) ? "---" : a.locateCoOrdinatesFor);
                $(`#${rvwScrId}bussLocationcoordinate`).text(apz.isNull(a.locateCoOrdinates) ? "---" : a.locateCoOrdinates);
            }
        }
        //if (occupationPayload.length > 0) {
        if (!apz.isNull(occupationPayload)) {
            var CurrEmpTxt = apz.isNull(occupationPayload.employeeSince) ? "---" : occupationPayload.employeeSince;
            $('#' + rvwScrId + 'curEmpyrs').text(CurrEmpTxt);
            var EmpIdTxt = (apz.isNull(occupationPayload.employeeId) ? "---" : occupationPayload.employeeId);
            $('#' + rvwScrId + 'empId').text(EmpIdTxt);
            var EmplrTxt = (apz.isNull(occupationPayload.employer) ? "---" : occupationPayload.employer);
            $('#' + rvwScrId + 'curEmployer').text(EmplrTxt);
            var AnnualIncTxt = (apz.isNull(occupationPayload.annualIncome) ? "---" : ApzCOB.fn_FormatAmount(occupationPayload.annualIncome));
            $('#' + rvwScrId + 'annualInc').text(AnnualIncTxt);
            var NatureOfBusi = (apz.isNull(occupationPayload.occupationType) ? "---" : occupationPayload.occupationType);
            if (NatureOfBusi == 'Please Select') {
                $(`#${rvwScrId}natureOfEmp`).text("---");
            } else {
                $(`#${rvwScrId}natureOfEmp`).text(NatureOfBusi);
            }
            var typbssEmpentTxt = (apz.isNull(occupationPayload.typeofbusiness) ? "---" : occupationPayload.typeofbusiness);
            if (typbssEmpentTxt == 'Please Select') {
                $('#' + rvwScrId + 'typbssEmpentrw').text("---");
            } else {
                $('#' + rvwScrId + 'typbssEmpentrw').text(typbssEmpentTxt);
            }
            var bssEmpAccTxt = (apz.isNull(occupationPayload.employeeActivity) ? "---" : occupationPayload.employeeActivity);
            if (bssEmpAccTxt == 'Please Select') {
                $('#' + rvwScrId + 'bssEmpAccrw').text("---");
            } else {
                $('#' + rvwScrId + 'bssEmpAccrw').text(bssEmpAccTxt);
            }
            var bssAddrProofTxt = (apz.isNull(occupationPayload.businessAddressProof) ? "---" : occupationPayload.businessAddressProof);
            if (bssAddrProofTxt == 'Please Select') {
                $('#' + rvwScrId + 'bssAddrProofrw').text("---");
            } else {
                $('#' + rvwScrId + 'bssAddrProofrw').text(bssAddrProofTxt);
            }
            var empProofTxt = (apz.isNull(occupationPayload.employmentProof) ? "---" : occupationPayload.employmentProof);
            if (empProofTxt == 'Please Select') {
                $('#' + rvwScrId + 'empProofrw').text("---");
            } else {
                $('#' + rvwScrId + 'empProofrw').text(empProofTxt);
            }
            var bssPerOwnTxt = (apz.isNull(occupationPayload.businessPremiseOwnerShip) ? "---" : occupationPayload.businessPremiseOwnerShip);
            if (bssPerOwnTxt == 'Please Select') {
                $('#' + rvwScrId + 'bssPerOwnrw').text("---");
            } else {
                $('#' + rvwScrId + 'bssPerOwnrw').text(bssPerOwnTxt);
            }
            var freqOfIncTxt = (apz.isNull(occupationPayload.freqOfIncome) ? "---" : occupationPayload.freqOfIncome);
            if (freqOfIncTxt == 'Please Select') {
                $('#' + rvwScrId + 'freqOfIncrw').text("---");
            } else {
                $('#' + rvwScrId + 'freqOfIncrw').text(freqOfIncTxt);
            }
            var othSrcIncTxt = (apz.isNull(occupationPayload.otherSourceIncome) ? "---" : occupationPayload.otherSourceIncome);
            if (othSrcIncTxt == 'Please Select') {
                $('#' + rvwScrId + 'othSrcIncrw').text("---");
            } else {
                $('#' + rvwScrId + 'othSrcIncrw').text(othSrcIncTxt);
            }
            var othSrcAnnIncTxt = (apz.isNull(occupationPayload.otherSourceAnnualIncome) ? "---" : ApzCOB.fn_FormatAmount(occupationPayload
                .otherSourceAnnualIncome));
            if (othSrcAnnIncTxt == 'Please Select') {
                $('#' + rvwScrId + 'othSrcAnnIncrw').text("---");
            } else {
                $('#' + rvwScrId + 'othSrcAnnIncrw').text(othSrcAnnIncTxt);
            }
            $(`#${rvwScrId}modeOfIncome`).text(apz.isNull(occupationPayload.modeOfIncome) ? "---" : occupationPayload.modeOfIncome);
            $(`#${rvwScrId}streetVendor`).text(apz.isNull(occupationPayload.streetVendor) ? "---" : occupationPayload.streetVendor);
            $(`#${rvwScrId}employmentStartdate`).text(apz.isNull(occupationPayload.businessEmpStartDate) ? "---" : occupationPayload
                .businessEmpStartDate);
            $(`#${rvwScrId}employmentVintage`).text(apz.isNull(occupationPayload.businessEmpVintageYear) ? "---" : occupationPayload
                .businessEmpVintageYear);
        }
    }
    /*BankDetails*/
    if (!apz.isNull(gApzCOB.requestNodes.bankDetailsWrapperList) && gApzCOB.requestNodes.bankDetailsWrapperList.length > 0) {
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        var bankdetlsPayload = gApzCOB.requestNodes.bankDetailsWrapperList[currIndex]?.bankDetails?.payload;
        /*var bankdetlsPayload = gApzCOB.requestNodes.bankDetailsWrapperList.filter(function(el){
            return parseInt(el.bankDetails.custDtlId) === CurrApplId;
        })
        bankdetlsPayload = bankdetlsPayload[0].bankDetails.payload;*/
        //if (bankdetlsPayload.length > 0) {
        if (!apz.isNull(bankdetlsPayload)) {
            var accountNameTxt = (apz.isNull(bankdetlsPayload.accountName) ? "---" : bankdetlsPayload.accountName);
            if (accountNameTxt == 'Please Select') {
                $('#' + rvwScrId + 'accHolderName').text("---");
            } else {
                $('#' + rvwScrId + 'accHolderName').text(accountNameTxt);
            }
            var accountNumberTxt = (apz.isNull(bankdetlsPayload.accountNumber) ? "---" : bankdetlsPayload.accountNumber);
            $('#' + rvwScrId + 'accNumber').text(accountNumberTxt);
            var accountTypeTxt = (apz.isNull(bankdetlsPayload.accountType) ? "---" : bankdetlsPayload.accountType);
            if (accountTypeTxt == 'Please Select') {
                $('#' + rvwScrId + 'accType').text("---");
            } else {
                $('#' + rvwScrId + 'accType').text(accountTypeTxt);
            }
            var bankNameTxt = (apz.isNull(bankdetlsPayload.bankName) ? "---" : bankdetlsPayload.bankName);
            $('#' + rvwScrId + 'bankName').text(bankNameTxt);
            var ifscTxt = (apz.isNull(bankdetlsPayload.ifsc) ? "---" : bankdetlsPayload.ifsc);
            $('#' + rvwScrId + 'ifscCode').text(ifscTxt);
            var branchNameTxt = (apz.isNull(bankdetlsPayload.branchName) ? "---" : bankdetlsPayload.branchName);
            $('#' + rvwScrId + 'branchName').text(branchNameTxt);
            let bankDataEditOption = (apz.isNull(bankdetlsPayload.editBankDetails) ? "---" : bankdetlsPayload.editBankDetails);
            $(`#${rvwScrId}AccDetRadio`).text(bankDataEditOption);
        }
    }
    /*insuranceDetails*/
    var insFields = ['insuranceForDiv', 'nomineeInsuranceDiv', 'relationNomineeDiv', 'dobNomineeDiv', 'ageNomineeyrsDiv'];
    if (!apz.isNull(gApzCOB.requestNodes.insuranceDetailsWrapperList) && gApzCOB.requestNodes.insuranceDetailsWrapperList.length > 0) {
        ['InsuranceDtlsDiv', 'applicantInsurDiv', 'coApplInsurDiv'].show();
        // var insurancePayload = gApzCOB.requestNodes.insuranceDetailsWrapperList[0].insuranceDetails.payload;
        var insurancePayload = gApzCOB.requestNodes.insuranceDetailsWrapperList.filter(function(el) {
            return parseInt(el.insuranceDetails.custDtlId) === CurrApplId;
        })
        if (insurancePayload.length > 0) {
            insurancePayload = insurancePayload[0].insuranceDetails.payload;
            var insuredNameTxt = (apz.isNull(insurancePayload.insuredName) ? "---" : insurancePayload.insuredName);
            $('#' + rvwScrId + 'insuranceFor').text(insuredNameTxt);
            var nomineeNameTxt = (apz.isNull(insurancePayload.nomineeName) ? "---" : insurancePayload.nomineeName);
            $('#' + rvwScrId + 'nomineeInsurance').text(nomineeNameTxt);
            var nomineeRelationTxt = (apz.isNull(insurancePayload.nomineeRelation) ? "---" : insurancePayload.nomineeRelation);
            if (nomineeRelationTxt == 'Please Select') {
                $('#' + rvwScrId + 'relationNominee').text("---");
            } else {
                $('#' + rvwScrId + 'relationNominee').text(nomineeRelationTxt);
            }
            var nomineeDobTxt = (apz.isNull(insurancePayload.nomineeDob) ? "---" : insurancePayload.nomineeDob);
            $('#' + rvwScrId + 'dobNominee').text(nomineeDobTxt);
             var ageTxt = (apz.isNull(insurancePayload.nomineeDob) ? "---" : ApzCOB.getAge(insurancePayload.nomineeDob));
            $('#' + rvwScrId + 'ageNomineeyrs').text(ageTxt);
            var coApplIns = insurancePayload.coApplicantInsurance;
            window.coApplicantInsurance = (!apz.isNull(coApplIns) && coApplIns == 'No') ? "No" : "Yes";
            if (insurancePayload.insuranceReqd == 'Y') {
                insFields.show();
                $(`#${rvwScrId}applicantInsur`).text('Yes');
                $(`#${rvwScrId}coApplInsur`).text(apz.isNull(coApplIns) ? "---" : coApplicantInsurance);
            } else if (insurancePayload.insuranceReqd == 'N') {
                ['InsuranceDtlsDiv'].show();
                insFields.hide();
                $(`#${rvwScrId}applicantInsur`).text('No');
                $(`#${rvwScrId}coApplInsur`).text('No');
            }
            if (currTab === 'Applicant') {
                window.coApplicantInsu = insurancePayload.coApplicantInsurance;
            }
            if (currTab != 'Applicant') {
                if (!apz.isNull(window.coApplicantInsurance) && window.coApplicantInsurance == 'Yes') {
                    ['InsuranceDtlsDiv'].show();
                    ['applicantInsurDiv', 'coApplInsurDiv'].hide();
                    coAppInsuranceFlag = false;
                } else if (!apz.isNull(window.coApplicantInsurance) && window.coApplicantInsurance == 'No') {
                    ['InsuranceDtlsDiv'].hide();
                    coAppInsuranceFlag = true;
                }
                if (window.coApplicantInsu === 'No') {
                    ['InsuranceDtlsDiv'].hide();
                }
                if (window.coApplicantInsu === 'No' && occupationValue === 'Homemaker') {
                    coAppInsuranceFlag = true;
                }
            }
        }
    }
    if (gApzCOB.requestNodes.insuranceDetailsWrapperList === undefined && occupationValue === 'Homemaker') {
        ['InsuranceDetailsDiv'].hide();
        coAppInsuranceFlag = true;
    }
    apz.app.ReviewConfirm.hideNshowAdditionalDetails();
}
apz.app.ReviewConfirm.hideNshowAdditionalDetails = function() {
    if (coAppInsuranceFlag && homeMakerFlag) {
        ['empDetDiv'].hide();
        coAppInsuranceFlag = false;
        homeMakerFlag = false;
    } else {
        ['empDetDiv'].show();
    }
}
apz.app.ReviewConfirm.bankFac = function() {
