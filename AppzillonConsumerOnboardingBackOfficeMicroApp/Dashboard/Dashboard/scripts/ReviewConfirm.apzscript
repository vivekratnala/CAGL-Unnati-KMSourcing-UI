}
apz.app.ReviewConfirm.tabsHideNshow = function() {
    STAGES.forEach(function(m, n) {
        ConfigureScrJson.forEach(function(i, k) {
            if (i.confParamName === m.split('~')[0].toUpperCase()) {
                $('#' + rvwScrId + i.reviewNconfirm).removeClass("sno");
            }
        })
    })
}
apz.app.ReviewConfirm.perDetails = function(isSingleFetch) {
    if (!apz.isNull(gApzCOB.requestNodes.customerDetailsList) && gApzCOB.requestNodes.customerDetailsList.length > 0) {
        if (gApzCOB.product === 'LOAN') {
            if(!apz.isNull(isSingleFetch)){

            }
            if (gApzCOB.requestNodes.customerDetailsList.length > 1) {
                let activeCustData = [];
                if (currTab.toLowerCase() === 'applicant') {
                    activeCustData = gApzCOB.requestNodes.customerDetailsList.filter(custData => {
                        return custData.customerType.toLowerCase() === "applicant"
                    });
                } else {
                    activeCustData = gApzCOB.requestNodes.customerDetailsList.filter(custData => {
                        return custData.customerType.toLowerCase() !== "applicant"
                    });
                }
                customerDetails = activeCustData[0];
            } else {
                customerDetails = gApzCOB.requestNodes.customerDetailsList[0];
            }
        }
        /* else {
                    customerDetails = gApzCOB.requestNodes.customerDetailsList[0];
                }*/
        currTab = customerDetails.customerType;
        CurrApplId = (currTab.toLowerCase() === 'applicant') ? parseInt(gApzCOB.userDetails.custDtlId) : parseInt(gApzCOB.userDetails
            .CoApplicantCustomerId);
        if (currTab == 'Applicant') {
            ['relationwithAppDiv'].hide();
            ['nameasKYCDiv', 'RevGenderDiv', 'coApplInsurDiv', 'LoanDetailsHideShow', 'bankDetailsDiv'].show();
            $('#' + rvwScrId + 'custTypeLbl').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_TYPE"))
            $('#' + rvwScrId + 'custIdLbl').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_ID"))
            $('#' + rvwScrId + 'custNameLbl').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_NAME"))
        } else {
            ['nameasKYCDiv', 'relationwithAppDiv', 'RevGenderDiv'].show();
            ['coApplInsurDiv', 'LoanDetailsHideShow', 'bankDetailsDiv'].hide();
            $('#' + rvwScrId + 'custTypeLbl').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_TYPE"))
            $('#' + rvwScrId + 'custIdLbl').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_ID"))
            $('#' + rvwScrId + 'custNameLbl').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_NAME"))
        }
        custDtlsPayload = customerDetails.payload;
        $('#' + rvwScrId + 'personalDetDiv').removeClass('sno');
        if (!apz.isNull(customerDetails)) {
            $('#' + rvwScrId + 'custName').text(apz.isNull(customerDetails.customerName) ? "---" : customerDetails.customerName);
            $('#' + rvwScrId + 'mobno').text(apz.isNull(customerDetails.mobileNumber) ? "---" : customerDetails.mobileNumber);
            if (!apz.isNull(custDtlsPayload)) {
                if (!apz.isNull(custDtlsPayload.title)) {
                    $('#' + rvwScrId + 'title').text(apz.isNull(custDtlsPayload.title) ? "---" : custDtlsPayload.title);
                }
                $('#' + rvwScrId + 'dob').text(apz.isNull(custDtlsPayload.dob) ? "---" : ApzCOB.dateformatter(custDtlsPayload.dob, 'd M Y'));
                $('#' + rvwScrId + 'gender').text(apz.isNull(custDtlsPayload.gender) ? "---" : custDtlsPayload.gender);
                if (!apz.isNull(custDtlsPayload.secMobileNo)) {
                    $('#' + rvwScrId + 'altMob').text(apz.isNull(custDtlsPayload.secMobileNo) ? "---" : custDtlsPayload.secMobileNo);
                }
                $('#' + rvwScrId + 'panCard').text(apz.isNull(custDtlsPayload.pan) ? "---" : custDtlsPayload.pan)
                var mstatus = custDtlsPayload.maritalStatus.toLocaleLowerCase();
                var spouseName = custDtlsPayload.spouseName;
                // if (mstatus === "single") {
                //     mstatus = "Single"
                //     $('#' + rvwScrId + 'spouseName').text("---")
                // } else if (mstatus === "married") {
                //     mstatus = "Married"
                // }
                $('#' + rvwScrId + 'spouseName').text(apz.isNull(spouseName) ? "---" : spouseName)
                $('#' + rvwScrId + 'Mstatus').text(mstatus);
                $('#' + rvwScrId + 'email').text(apz.isNull(custDtlsPayload.emailId) ? "---" : custDtlsPayload.emailId);
                $('#' + rvwScrId + 'fname').text(apz.isNull(custDtlsPayload.firstName) ? "---" : custDtlsPayload.firstName);
                $('#' + rvwScrId + 'mName').text(apz.isNull(custDtlsPayload.middleName) ? "---" : custDtlsPayload.middleName);
                $('#' + rvwScrId + 'lname').text(apz.isNull(custDtlsPayload.lastName) ? "---" : custDtlsPayload.lastName);
                $('#' + rvwScrId + 'pKycType').text(apz.isNull(custDtlsPayload.primaryKycType) ? "---" : custDtlsPayload.primaryKycType);
                $('#' + rvwScrId + 'pKycName').text(apz.isNull(custDtlsPayload.primaryKycId) ? "---" : custDtlsPayload.primaryKycId);
                $(`#${rvwScrId}altVoterId`).text(apz.isNull(custDtlsPayload.alternateVoterId) ? "---" : custDtlsPayload.alternateVoterId);
                $(`#${rvwScrId}cKYC`).text(apz.isNull(custDtlsPayload.ckyc) ? "---" : custDtlsPayload.ckyc);
                $(`#${rvwScrId}panNumber`).text(apz.isNull(custDtlsPayload.panNumber) ? "---" : custDtlsPayload.panNumber === 'Not Available' ? '' : custDtlsPayload.panNumber);
                $('#' + rvwScrId + 'sKycType').text(apz.isNull(custDtlsPayload.secondaryKycType) ? "---" : custDtlsPayload.secondaryKycType);
                $('#' + rvwScrId + 'sKycName').text(apz.isNull(custDtlsPayload.secondaryKycId) ? "---" : custDtlsPayload.secondaryKycId);
                $('#' + rvwScrId + 'occupation').text(apz.isNull(custDtlsPayload.occupation) ? "---" : custDtlsPayload.occupation);
                $('#' + rvwScrId + 'annualIncome').text(apz.isNull(custDtlsPayload.annualIncome) ? "---" : ApzCOB.fn_FormatAmount(custDtlsPayload.annualIncome));
                $(`#${rvwScrId}custType`).text(customerDetails.customerType === "Applicant" ? customerDetails.customerType : "Co-Applicant");
                $(`#${rvwScrId}relationwithApp`).text(apz.isNull(custDtlsPayload.relationShipWithApplicant) ? "---" : custDtlsPayload
                    .relationShipWithApplicant);
                $(`#${rvwScrId}nameasKYC`).text(apz.isNull(custDtlsPayload.namePerKyc) ? "---" : custDtlsPayload.namePerKyc);
                $(`#${rvwScrId}fatherName`).text(apz.isNull(custDtlsPayload.fathersName) ? "---" : custDtlsPayload.fathersName);
                $(`#${rvwScrId}custId`).text(apz.isNull(custDtlsPayload.custId) ? "---" : custDtlsPayload.custId);
                $(`#${rvwScrId}custAge`).text(ApzCOB.getAge(custDtlsPayload.dob));
                $(`#${rvwScrId}perDetReligion`).text(apz.isNull(custDtlsPayload.religion) ? "---" : custDtlsPayload.religion);
                $(`#${rvwScrId}perDetCaste`).text(apz.isNull(custDtlsPayload.caste) ? "---" : custDtlsPayload.caste);
                $(`#${rvwScrId}perDetEducation`).text(apz.isNull(custDtlsPayload.education) ? "---" : custDtlsPayload.education);
                $(`#${rvwScrId}branchMail`).text(apz.isNull(custDtlsPayload.emailId) ? "---" : custDtlsPayload.emailId);
            }
        }
        if (custDtlsPayload.occupation === 'Homemaker') {
            ['occupationDetailsDiv', 'sc_row_677'].hide();
            occupationValue = custDtlsPayload.occupation;
            homeMakerFlag = true
        } else {
            ['occupationDetailsDiv', 'sc_row_677'].show();
            homeMakerFlag = false
        }
        if (custDtlsPayload.occupation === 'Self Employed') {
            ['streetVendorDiv', 'bssPerOwnrowid'].show();
            ['empProofrowid'].hide();
        }
        if (custDtlsPayload.occupation === 'Salaried') {
            ['empProofrowid'].show();
            ['streetVendorDiv', 'bssPerOwnrowid'].hide();
        }
        if (custDtlsPayload.occupation === 'Wage earner') {
            ['streetVendorDiv', 'bssPerOwnrowid', 'empProofrowid'].hide();
        }
        apz.app.ReviewConfirm.hideNshowAdditionalDetails();
    }
    apz.app.ReviewConfirm.perAddressDetails();
}
