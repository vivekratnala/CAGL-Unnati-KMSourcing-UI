apz.app.onLoad_ReviewConfirm = function(params) {
    //apz.app.ReviewConfirm.tabsHideNshow();
    $("#" + BaseScrId + "applnStatus").removeClass('war');
    $("#" + BaseScrId + "applnStatus").removeClass('suc');
    $("#" + BaseScrId + "applnStatus").removeClass('err');
    $("#" + BaseScrId + "applnStatus").removeClass('appr');
    addInfo1 = gApzCOB.LoggedInUserDetails.loginResponse.addInfo1;
    if (addInfo1 !== 'KM') {
        if (apz.deviceType == 'WEB') {
            document.getElementById('APZCBO__BaseScreens__BaseDIV').classList.add('verify_approve');
        } else {
            document.getElementById('APZCBO__BaseScreens__BaseDIV').classList.remove('verify_approve');
        }
    }
    if (params.screenType === "InProgress") {
        window.currentApplication = "InProgress";
        window.applnStatus = "InProgress";
        $("#" + BaseScrId + "applnStatus").addClass('war');
    } else if (params.screenType === "Rejected") {
        window.currentApplication = "Rejected";
        window.applnStatus = "Rejected";
        $("#" + BaseScrId + "applnStatus").addClass('err');
    } else if (params.screenType === "AssignLeads") {
        window.currentApplication = "AssignLead";
        window.applnStatus = "AssignLeads";
    } else if (params.screenType === "Approvals") {
        window.currentApplication = "Approvals";
        window.applnStatus = "Pending";
        $("#" + BaseScrId + "applnStatus").addClass('appr');
    } else if (params.screenType === "Completed") {
        window.currentApplication = "Completed";
        window.applnStatus = "Completed";
        $("#" + BaseScrId + "applnStatus").addClass('suc');
    } else if (params.screenType === "Pushback") {
        window.currentApplication = "Pushback";
        window.applnStatus = "Pushback";
        $("#" + BaseScrId + "applnStatus").addClass('war');
    } else if (params.screenType === "PendingCreditAssesment") {
        window.currentApplication = "PendingCreditAssesment";
        window.applnStatus = "PendingCreditAssesment";
        $("#" + BaseScrId + "applnStatus").addClass('appr');
    }
    $("#" + BaseScrId + "applnStatus").removeClass('sno');
    $("#" + BaseScrId + "applnStatus").text(window.applnStatus);
    $("#" + rvwScrId + "createdBy").text(gApzCOB.userDetails.createdBy);
    if (gApzCOB.requestNodes.applicationMaster.versionNum > 1) {
        window.editappln = true;
    }
    //apz.app.ReviewConfirm.roleBasedAccess();
    apz.app.ReviewConfirm.setStageNo();
    //  ApzCOB.commonSelectProduct();
    if (window.currentApplication === 'InProgress') {
        ApzCOB.FetchProductsDetails('LOAN');
    }
}
apz.app.onShown_ReviewConfirm = function() {
    apz.startLoader();
    $(`#${BaseScrId}RefNumDiv`).addClass('sno');
     $('body').removeClass('newdashboardlat');
    if (!apz.isNull(gApzCOB.requestNodes.customerDetailsList) && gApzCOB.requestNodes.customerDetailsList.length > 0) {
        let applicantData = ApzCOB.getApplicantCustData();
        var customerName = applicantData === 1 ? applicantData["customerName"] : "";
        //$('#' + rvwScrId + 'createdBy').text(customerName + " " + "(Created By - " + gApzCOB.userDetails.createdBy + ")");
        $('#' + rvwScrId + 'createdBy').text(`Created By - ${gApzCOB.userDetails.createdByName} (${gApzCOB.userDetails.createdBy})`);
        $('#' + BaseScrId + 'headerText').removeClass('sno');
        $('#' + BaseScrId + 'headerText').text("Reference Number" + " " + "-" + " " + gApzCOB.userDetails.applicationId + " ");
    } else {
        $('#' + BaseScrId + 'headerText').removeClass('sno');
        $('#' + BaseScrId + 'headerText').text("Reference Number" + " " + "-" + " " + gApzCOB.userDetails.applicationId + " ");
    }
    $('body').removeClass("LoginBase");
    $("#" + BaseScrId + "landingRowHeader").removeClass('sno');
    $('#' + BaseScrId + 'backIcon').removeClass('sno');
    $("#" + BaseScrId + "footerbtnRow").addClass('sno');
    if ($('#' + BaseScrId + 'backIcon').hasClass('sno')) {
        $('#' + rvwScrId + 'subHeaderRow').addClass('var1')
    }
    window.addEventListener('scroll', function() {
        pageYOffset < document.documentElement.clientHeight ? $('#' + rvwScrId + 'toparrow').addClass('sno') : $('#' + rvwScrId +
            'toparrow').removeClass('sno');
    });
    $('#' + rvwScrId + 'collapseText').addClass('sno');
    $('#' + rvwScrId + 'pdE').trigger('click');
    $('#' + rvwScrId + 'backTotoprow').addClass('sno');
    if (Number(gApzCOB.noOfApplicants) > 1) {
        window.dontupdateCurrAppln = false;
        window.dontReloadRC = true;
        apz.app.ReviewConfirm.paintApplicants();
        $('#' + rvwScrId + 'applicantNameList .pri').removeClass('active');
        $('#' + rvwScrId + 'applicantNameList_row_' + (0)).addClass('active');
        var lastChild = $('#' + rvwScrId + 'applicantNameList ul li').length - 1;
    }
    currTab = $(`#${rvwScrId}applicantNameList_row_0`).hasClass("active") ? "Applicant" : "Co-App";
    CurrApplId = (currTab.toLowerCase() === 'applicant') ? parseInt(gApzCOB.userDetails.custDtlId) : parseInt(gApzCOB.userDetails
        .CoApplicantCustomerId);
    apz.app.ReviewConfirm.paintAllonScreen();
    if (Number(gApzCOB.noOfApplicants) > 1 && gApzCOB.currentApplicant !== Number(gApzCOB.noOfApplicants) && gApzCOB.applicationType ===
        'Joint Account') {
        $('#' + rvwScrId + 'jointRow').removeClass('sno');
        $('#' + rvwScrId + 'currentApplicantNum_txtcnt').text(gApzCOB.currentApplicant + 1);
    }
    apz.app.ReviewConfirm.JointAccount();
    apz.stopLoader();
    if (window.itsfromsearch) {
        window.itssearchrc = true;
        window.itsfromsearch = false;
    }
    $("#APZCBO__BaseScreens__sidebarController").removeClass('sno');
    $(BaseScroll).removeClass(SecondaryProduct);
    $('#' + BaseScrId + 'homeicon').addClass('sno');
    if (!apz.isNull(gApzCOB.selLeadDtls)) {
        $('#' + BaseScrId + 'custIDandName_txtcnt').text(`Member ID/Name - ${gApzCOB.selLeadDtls.customerId} / ${gApzCOB.selLeadDtls.fullName}`)
    }
    apz.app.ReviewConfirm.fetchSubProduct();
    gApzCOB.currentApplicant = $("#Dashbo__ReviewConfirm__applicantNameList_row_0").hasClass("active") ? 1 : 2;
    $('#' + BaseScrId + 'backIcon').attr('onClick', 'ApzCOB.backNavigation()');
    $('#APZCBO__BaseScreens__backIcon').attr('disabled',false);
    if(gApzCOB.userDetails.applicationStatus === 'PUSHBACK'){
    ApzCOB.paintingSourcingQuery();
    }
}
apz.app.ReviewConfirm.sendBackEdit = function(stage){
    if(stage === "CUSTOMERDETAILS"){
       ApzCOB.fnDisplayMsg('Queries in personal details section can not be addressed. Please Reject the application!', "E", apz.app.ReviewConfirm.sendBackReject);  
       return false;
    } else {
        const isApplicant = currTab === 'Applicant';
        gApzCOB.currentApplicant = isApplicant ? 1 : 2;
        const stageMap = {
        Applicant: {
        CUSTOMERDETAILS: 3,
        OCCUPATIONDETAILS: 7
        },
        CoAPP: {
        CUSTOMERDETAILS: 5,
        OCCUPATIONDETAILS: 8
        }
        };
        const baseRowMapping = {
        'CUSTOMERDETAILS' : 'perDetBaseRow',
        'OCCUPATIONDETAILS' : 'EmpDetBaseRow'
        }
        let cutBaseId = baseRowMapping[stage];
        CURRENT_STAGE_NO = stageMap[isApplicant ? 'Applicant' : 'CoAPP'][stage] || 0;
        backNav = true;
        ApzCOB.editlaunch(stage, cutBaseId, true, CURRENT_STAGE_NO);        
    }
}
apz.app.ReviewConfirm.sendBackReject = function(){
    IS_PUSHBACKREJECT = true;
  apz.app.ReviewConfirm.approveReject(this,'REJECTED')  
}
apz.app.ReviewConfirm.sendBackLoanEdit = function() {
    gApzCOB.currentApplicant = 1;
    CURRENT_STAGE_NO = 4;
    backNav = true;
    ApzCOB.editlaunch("LOANDETAILS", "loanDetailsDiv", true, CURRENT_STAGE_NO);
}
apz.app.ReviewConfirm.sendBackDocEdit = function() {
    window.isRevAndConfEdit = true;
    window.isRevAndConfEditCustType = gApzCOB.currentApplicant;
    if (currTab === "Applicant") {
        gApzCOB.currentApplicant = 1;
        CURRENT_STAGE_NO = 9;
    } else {
        gApzCOB.currentApplicant = 2;
        CURRENT_STAGE_NO = 10;
    }
    backNav = true;
    ApzCOB.editlaunch("UPLOADDOCUMENTS", UpDocBaseRow, true, CURRENT_STAGE_NO);
}
apz.app.ReviewConfirm.paintAllonScreen = function(iSingle) {
    if (window.currentApplication === "Rejected" && !dontupdateCurrAppln) {
        apz.app.ReviewConfirm.RejectReason();
        apz.app.ReviewConfirm.hideNshowBtns();
    } else {
        apz.app.ReviewConfirm.tabsHideNshow();
        if (gApzCOB.product === 'DEPOSIT') {
            apz.app.ReviewConfirm.perDepositDetails();
        } else {
            apz.app.ReviewConfirm.perDetails(iSingle);
        }
        apz.app.ReviewConfirm.empDetails();
        apz.app.ReviewConfirm.nomineeDetails();
        // apz.app.BaseScreens.fetchNominee();
        apz.app.ReviewConfirm.paintLoanDetails();
        apz.app.ReviewConfirm.bankFac();
        apz.app.ReviewConfirm.uploadDocs();
        apz.app.ReviewConfirm.depositDetails();
        apz.app.ReviewConfirm.autoPayDetails();
        apz.app.ReviewConfirm.paintInitialFundRD();
        // apz.app.ReviewConfirm.configureFields();
        apz.app.ReviewConfirm.hideNshowBtns();
    }
    apz.app.ReviewConfirm.paintAuditDetails();
    apz.app.ReviewConfirm.LoadCustomerDetailsList();
    if (["Pushback","Rejected"].includes(window.currentApplication)) {
        // if(iSingle !== 'single'){
        ApzCOB.initSourcingQuery();
        ApzCOB.getSourcingPushBackQuery();
        // }
        if(window.currentApplication === 'Pushback'){
             $('.documentEdit').removeClass('sno');
        $('.documentEdit button').attr('onClick', 'apz.app.ReviewConfirm.sendBackDocEdit()')
        if (currTab === "Applicant") {
            $('.loanDataEdit').removeClass('sno');
            $('.loanDataEdit button').attr('onClick', 'apz.app.ReviewConfirm.sendBackLoanEdit()');
        } else {
            $('.loanDataEdit').addClass('sno');
        }
        }
    } else {
        if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "BM" && window.currentApplication === "Approvals") {
            window.IS_BM_DOC_EDIT = true;
            $('.documentEdit').removeClass('sno');
            if (gApzCOB.product === 'LOAN') {
                gApzCOB.ExistingCustomer = false
            }
            $('.documentEdit button').attr('onClick', 'apz.app.ReviewConfirm.sendBackDocEdit()')
        } else {
            window.IS_BM_DOC_EDIT = false;
            $('.documentEdit').addClass('sno');
        }
        $('.loanDataEdit').addClass('sno');
    }
}
apz.app.ReviewConfirm.handleSendbackInSourcing = function() {  
const custType = currTab === 'Applicant' ? 'Applicant' : 'Co-APP';
Object.entries(SOURCING_SENDBACK_QUERIES).forEach(([key, data]) => {
 let currentSecQuery = SOURCING_SENDBACK_QUERIES[key][custType].query;
 if(currentSecQuery.length > 0){
   $(`.${key}_Edit`).removeClass('sno') 
    $(`.${key}_Edit button`).attr('onClick', `apz.app.ReviewConfirm.sendBackEdit('${key}')`);
 }
});
}
var expandType = ""
apz.app.ReviewConfirm.setStageNo = function() {
    if (!window.revAndConf) {
        window.revConfBaseRow = baseRow - 1;
        window.revConfSTAGENO = STAGE_NO - 1;
    }
}
apz.app.ReviewConfirm.depositDetails = function() {
    if (!apz.isObjectEmpty(DEPOSIT_OBJ)) {
        $('#' + rvwScrId + 'depositDetRow').removeClass('sno');
        $('#' + rvwScrId + 'depType').text(DEPOSIT_OBJ.productType);
        $('#' + rvwScrId + 'depAmt').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + (!apz.isNull(DEPOSIT_OBJ.depositAmount) ? ApzCOB
            .fn_FormatAmount(DEPOSIT_OBJ.depositAmount) : ''));
        $('#' + rvwScrId + 'maturityamount').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + (!apz.isNull(DEPOSIT_OBJ.maturityAmount) ?
            ApzCOB.fn_FormatAmount(DEPOSIT_OBJ.maturityAmount) : ''));
        $('#' + rvwScrId + 'depTenure').text(DEPOSIT_OBJ.tenureInMonths);
        $('#' + rvwScrId + 'depIntRate').text(DEPOSIT_OBJ.roi + '%');
    } else {
        $('#' + rvwScrId + 'depositDetRow').addClass('sno');
    }
}
apz.app.ReviewConfirm.autoPayDetails = function() {
    if (gApzCOB.ExistingCustomer && gApzCOB.product === 'DEPOSIT') {
        if (DEPOSIT_OBJ.autopayEnabled === 'N') {
            $('#' + rvwScrId + 'autoPayRow').addClass('sno');
        }
        $('#' + rvwScrId + 'frmacc').text(!apz.isNull(DEPOSIT_OBJ.autopaySrcAccount) ? DEPOSIT_OBJ.autopaySrcAccount : "");
        $('#' + rvwScrId + 'paymentDate').text(!apz.isNull(DEPOSIT_OBJ.autopayDate) ? DEPOSIT_OBJ.autopayDate : "");
        $('#' + rvwScrId + 'matInst').text(!apz.isNull(DEPOSIT_OBJ.maturityInstn) ? DEPOSIT_OBJ.maturityInstn : "");
        $('#' + rvwScrId + 'payAcc').text(!apz.isNull(DEPOSIT_OBJ.payoutAccount) ? DEPOSIT_OBJ.payoutAccount : "");
    }
};
apz.app.ReviewConfirm.paintInitialFundRD = function() {
    if (gApzCOB.ExistingCustomer && gApzCOB.product === 'DEPOSIT') {
        $('#' + rvwScrId + 'acctype').text(!apz.isNull(DEPOSIT_OBJ.initialFundAccountType) ? DEPOSIT_OBJ.initialFundAccountType : "");
        $('#' + rvwScrId + 'fromaccount').text(!apz.isNull(DEPOSIT_OBJ.initialFundAccount) ? DEPOSIT_OBJ.initialFundAccount : "");
        $('#' + rvwScrId + 'avalbal').text(!apz.isObjectEmpty(gApzCOB.customerDetails) ? gApzCOB.customerDetails.accList[0].availBalance : "");
    }
};
apz.app.ReviewConfirm.paintLoanDetails = function() {
    if (!apz.isObjectEmpty(gApzCOB.requestNodes.loanDetails)) {
        $('#' + rvwScrId + 'loanDetailsDiv').removeClass('sno');
        $('#' + rvwScrId + 'LoanDetails').text(gApzCOB.subProduct + ' ' + 'Details');
        var response = gApzCOB.requestNodes.loanDetails;
        var loanRespDtls = gApzCOB.requestNodes.loanDetails.payload;
        $('#' + rvwScrId + 'LoanAmount').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(response.loanAmount));
        //$('#' + rvwScrId + 'LoanTenure').text(response.tenureInMonths);
        $('#' + rvwScrId + 'LoanAmount').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(response.loanAmount));
        $('#' + rvwScrId + 'TenureinMonths').text(response.tenure);
        $('#' + rvwScrId + 'rateofInterest').text(response.roi + '%');
        $('#' + rvwScrId + 'purposeLoan').text(apz.isNull(loanRespDtls.loanPurpose) ? "---" : loanRespDtls.loanPurpose);
        var subCategoryTxt = (apz.isNull(loanRespDtls.subCategory) ? "---" : loanRespDtls.subCategory);
        var freqOfRepay = (apz.isNull(loanRespDtls.frequencyOfRepayment) ? "---" : loanRespDtls.frequencyOfRepayment);
        if (subCategoryTxt == 'Please Select') {
            $('#' + rvwScrId + 'subCategory').text("---");
        } else {
            $('#' + rvwScrId + 'subCategory').text(subCategoryTxt);
        }
        $('#' + rvwScrId + 'modeDisbursement').text(apz.isNull(loanRespDtls.modeOfDisbursement) ? "---" : loanRespDtls.modeOfDisbursement);
        $('#' + rvwScrId + 'modeSecurity').text(apz.isNull(loanRespDtls.modeOfSecurity) ? "---" : loanRespDtls.modeOfSecurity);
        if (freqOfRepay == 'Please Select') {
            $(`#${rvwScrId}freqOfRepayment`).text("---");
        } else {
            $(`#${rvwScrId}freqOfRepayment`).text(freqOfRepay);
        }
        $(`#${rvwScrId}commLanguage`).text(apz.isNull(loanRespDtls.language) ? "---" : loanRespDtls.language);
        //$('#' + rvwScrId + 'PayableInterest').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(response.interest));
        /* $('#' + rvwScrId + 'TotPayAmount').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(response
             .totPayableAmount));
         //$('#' + rvwScrId + 'monthlyEMI').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(response.monthlyEmi));*/
    } else {
        $('#' + rvwScrId + 'loanDetailsDiv').addClass('sno');
    }
    if (!apz.isObjectEmpty(gApzCOB.requestNodes.cibilDetailsWrapperList)) {
        // if (cibilDtls.length > 0) {
        var cibilDtls = gApzCOB.requestNodes.cibilDetailsWrapperList.filter(function(el) {
            return parseInt(el.cibilDetails.custDtlId) === CurrApplId;
        })
        if (cibilDtls.length > 0) {
            cibilDtls = cibilDtls[0].cibilDetails.payload;
            cbSummaryArr.forEach(el => ApzCOB.beautifyCbDtlsSummary(el, cibilDtls));
            // var cibilDtls = gApzCOB.requestNodes.cibilDetailsWrapperList[0].cibilDetails.payload;;
            $('#' + rvwScrId + 'bureauName').text(cibilDtls.bureauName);
            $('#' + rvwScrId + 'hitNohit').text(cibilDtls.hitNohit);
            $('#' + rvwScrId + 'cbScore').text(cibilDtls.cbScore);
            $('#' + rvwScrId + 'cbROI').text(cibilDtls.roi ? `${cibilDtls.roi}%` : '');
            $('#' + rvwScrId + 'totalIndebtedness').text(cibilDtls.totIndebtness);
            $('#' + rvwScrId + 'lastSixtyMonths').text(cibilDtls.NoParInLastMonths);
            $('#' + rvwScrId + 'dpdLastMonth').text(cibilDtls.maxDpdInLastMonths);
            $('#' + rvwScrId + 'suitWrittenoff').text(cibilDtls.writeoffSuitFiledFlag);
            $('#' + rvwScrId + 'overlapMMFL').text(cibilDtls.overlapWithMmfl);
            $('#' + rvwScrId + 'overdueAmount').text(cibilDtls.overdueAmt);
            $('#' + rvwScrId + 'writtenoffAmt').text(cibilDtls.writeOffAmt);
            $('#' + rvwScrId + 'finalDecision').text(gApzCOB.requestNodes.cibilDetailsWrapperList[0].cibilDetails.cbStatus);
            $('#' + rvwScrId + 'eligbAmount').text(cibilDtls.eligibleAmt);
            $('#' + rvwScrId + 'runningEmi').text(apz.isNull(cibilDtls.foir) ? "---" : cibilDtls.foir);
            $('#' + rvwScrId + 'caglDpd').text(apz.isNull(cibilDtls.caglDpdFlag) ? "---" : cibilDtls.caglDpdFlag);
            $(`#${rvwScrId}individualIndebtness`).text(apz.isNull(cibilDtls.individualIndebtness) ? "---" : cibilDtls.individualIndebtness);
            if (!apz.isNull(cibilDtls.bureauName)) {
                if (cibilDtls.bureauName === "BRE") {
                    $('#' + rvwScrId + 'suitWrittenoff').text(cibilDtls.writeoffSuitFiledFlag);
                    ['hitNohitDiv', 'runningEmiDiv'].hide();
                    ['individualIndebtDiv'].show();
                    if (gApzCOB.currentApplicant <= 1) {
                        ['totalIndebtednessDiv'].hide();
                    } else {
                        ['totalIndebtednessDiv'].show();
                    }
                } else {
                    ['hitNohitDiv', 'runningEmiDiv', 'totalIndebtednessDiv'].show();
                    ['individualIndebtDiv'].hide();
                }
            }
        }
    }
}
apz.app.ReviewConfirm.hideAndShowTabs = function(pthis, params) {
    var selectedTabId = $('#' + pthis.id + '_ul').parent().parent().parent().parent()[0]['id'];
    for (var i = 0; i < $(rvwScrId + 'DetailsForm').children().length; i++) {
        var id = $('#' + rvwScrId + 'DetailsForm').children()[i]['id'];
        $('#' + id).removeClass('active')
    }
    if (!apz.isNull(expandType)) {
        if (expandType === "expand") {
            $('#' + rvwScrId + 'backTotoprow').removeClass('sno')
            $('#' + selectedTabId).addClass('active');
            $('#' + rvwScrId + 'nomineeDetrow').addClass('active');
            $('#' + rvwScrId + 'docDetrow').addClass('active');
            $('#' + rvwScrId + 'collapseText').removeClass('sno');
            $('#' + rvwScrId + 'expandText').addClass('sno');
            $('#' + rvwScrId + 'loanDetailsDiv').addClass('active');
            $('#' + rvwScrId + 'depositDetRow').addClass('active');
            $('#' + rvwScrId + 'autopayDetRow').addClass('active');
            $('#' + rvwScrId + 'initialDepositRow').addClass('active');
            $('#' + rvwScrId + 'auditDetailsTab').addClass('active');
        }
        if (expandType === "collapse") {
            $('#' + rvwScrId + 'backTotoprow').addClass('sno')
            $('#' + selectedTabId).removeClass('active');
            $('#' + rvwScrId + 'nomineeDetrow').removeClass('active');
            $('#' + rvwScrId + 'docDetrow').removeClass('active');
            $('#' + rvwScrId + 'collapseText').addClass('sno');
            $('#' + rvwScrId + 'expandText').removeClass('sno');
            $('#' + rvwScrId + 'loanDetailsDiv').removeClass('active');
            $('#' + rvwScrId + 'depositDetRow').removeClass('active');
            $('#' + rvwScrId + 'autopayDetRow').removeClass('active');
            $('#' + rvwScrId + 'initialDepositRow').removeClass('active');
            $('#' + rvwScrId + 'auditDetailsTab').removeClass('active');
        }
    } else {
        if ($('#' + selectedTabId).hasClass('active')) {
            $('#' + selectedTabId).removeClass('active');
            if (params === "Nominee") {
                $('#' + rvwScrId + 'nomineeDetrow').removeClass('active');
            }
            if (params === "docs") {
                $('#' + rvwScrId + 'docDetrow').removeClass('active');
            }
            if (params === "loanDetails") {
                $('#' + rvwScrId + 'loanDetailsDiv').removeClass('active');
            }
            if (params === "deposit") {
                $('#' + rvwScrId + 'depositDetRow').removeClass('active');
            }
            if (params === "audit") {
                $('#' + rvwScrId + 'auditDetailsTab').removeClass('active');
                $('#' + rvwScrId + 'TimeLineNotFoundList').addClass('sno');
            }
            if (params === "autoPay") {
                $('#' + rvwScrId + 'autopayDetRow').removeClass('active');
            }
            if (params === "initialDep") {
                $('#' + rvwScrId + 'initialDepositRow').removeClass('active');
            }
        } else {
            $('#' + rvwScrId + 'personalDetDiv').removeClass('active');
            $('#' + rvwScrId + 'empDetDiv').removeClass('active');
            $('#' + rvwScrId + 'uploadDoc').removeClass('active');
            $('#' + rvwScrId + 'bankingDetRow').removeClass('active');
            $('#' + rvwScrId + 'nomineeDetrow').removeClass('active');
            $('#' + rvwScrId + 'docDetrow').removeClass('active');
            $('#' + selectedTabId).addClass('active');
            if (params === "Nominee") {
                $('#' + rvwScrId + 'nomineeDetrow').addClass('active');
            }
            if (params === "docs") {
                $('#' + rvwScrId + 'docDetrow').addClass('active');
            }
            if (params === "loanDetails") {
                $('#' + rvwScrId + 'loanDetailsDiv').addClass('active');
            }
            if (params === "deposit") {
                $('#' + rvwScrId + 'depositDetRow').addClass('active');
            }
            if (params === "audit") {
                $('#' + rvwScrId + 'auditDetailsTab').addClass('active');
                if (apz.data.scrdata.Dashbo__IPaintAuditDetails_Res.length == 0) {
                    $('#' + rvwScrId + 'TimeLineNotFoundList').removeClass('sno');
                }
            }
            if (params === "autoPay") {
                $('#' + rvwScrId + 'autopayDetRow').addClass('active');
            }
            if (params === "initialDep") {
                $('#' + rvwScrId + 'initialDepositRow').addClass('active');
            }
        }
    }
}
apz.app.ReviewConfirm.expandCollapse = function(params) {
