    if (gApzCOB.applicationType === 'Joint Account') {
        $('#' + rvwScrId + 'person2DetailsForm').removeClass('sno');
    } else {
        $('#' + rvwScrId + 'person2DetailsForm').addClass('sno');
    }
};
