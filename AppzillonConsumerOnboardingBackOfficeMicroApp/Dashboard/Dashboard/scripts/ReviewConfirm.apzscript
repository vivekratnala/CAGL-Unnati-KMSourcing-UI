            if (!apz.isObjectEmpty(gApzCOB.requestNodes.customerDetailsList[payloadno])) {
                customerDetails1 = gApzCOB.requestNodes.customerDetailsList.length === 1 ? gApzCOB.requestNodes.customerDetailsList[0].payload :
                    gApzCOB.requestNodes.customerDetailsList[payloadno].payload;
            }
        }
        apz.app.ReviewConfirm.LoadCustMaritualStatus();
        /*if (!apz.isNull(customerDetails1)) {
            var mstatus1 = customerDetails1.maritalStatus;
            if (mstatus1 === 'S') {
                $('#' + rvwScrId + 'RevSpouseNameDiv').addClass('sno')
            }
        }*/
    }
};
apz.app.ReviewConfirm.LoadBankingFacility = function() {
    $('#' + rvwScrId + 'debitcard').text(bankFacilityPayload.debitCardRequired === "Y" ? "Yes" : "No")
    $('#' + rvwScrId + 'nameCard').text((temp = bankFacilityPayload.nameOnCard) === "" ? "---" : bankFacilityPayload.nameOnCard);
    $('#' + rvwScrId + 'branchNAme').text(apz.isNull(bankFacilityPayload.branchName) ? "---" : bankFacilityPayload.branchName);
    $('#' + rvwScrId + 'branchAdd').text(apz.isNull(bankFacilityPayload.branchAddress) ? "---" : bankFacilityPayload.branchAddress);
};
apz.app.ReviewConfirm.LoadCustAdd = function() {
    if (!apz.isNull(window.CUST_ADDRESS) && window.EMP_ADDRESS.length > 0) {
        var a = window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"]["addressList"][0];
        var RCfullAddress;
        if (a.state === ApzCOB.getDescfromLitCode("LIT_PLS_SELECT")) {
            RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.pinCode;
        } else {
            RCfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.city + ' ' + a.state + ' ' + a.pinCode;
        }
        $('#' + rvwScrId + 'addr_li').text(RCfullAddress);
    }
};
apz.app.ReviewConfirm.LoadLandMark = function() {
    $('#' + rvwScrId + "landMark").text(apz.isNull(addressdata["landMark"]) ? "---" : addressdata["landMark"]);
    if (window.CUST_ADDRESS[0]["addressDetailsList"][0]["payload"].commAddEqPerAdd === 'N') {
        $('#' + rvwScrId + "commAddr").text('No');
    } else {
        $('#' + rvwScrId + "commAddr").text('Yes');
    }
};
apz.app.ReviewConfirm.LoadDepCustAdd = function() {
    var mstatus = customerDetails.maritialStatus;
    if (mstatus === "S") {
        mstatus = "Single"
        $('#' + rvwScrId + 'spouseName').text("---")
    } else if (mstatus === "M") {
        mstatus = "Married"
        //$('#' + rvwScrId + 'spouseName').text(apz.isNull(spouseName) ? "---" : spouseName)
    }
    $('#' + rvwScrId + 'Mstatus').text(apz.isNull(customerDetails.mstatus) ? "---" : mstatus);
    $('#' + rvwScrId + 'title').text(apz.isNull(customerDetails.title) ? "---" : customerDetails.title);
    $('#' + rvwScrId + 'email').text(apz.isNull(customerDetails.emailId) ? "---" : customerDetails.emailId);
    $('#' + rvwScrId + 'nationality').text(apz.isNull(customerDetails.nationality) ? "---" : customerDetails.nationality);
    $('#' + rvwScrId + 'lname').text(apz.isNull(customerDetails.customerLName) ? "---" : customerDetails.customerLName);
    $('#' + rvwScrId + 'mobno').text(apz.isNull(customerDetails.mobileNum) ? "---" : customerDetails.mobileNum);
    $('#' + rvwScrId + 'addr').text(apz.isNull(customerDetails.permAddress) ? "---" : customerDetails.permAddress);
};
apz.app.ReviewConfirm.LoadCustMaritualStatus = function() {
    if (!apz.isNull(customerDetails1)) {
        var mstatus1 = customerDetails1.maritalStatus;
        if (mstatus1 !== 'Married') {
            $('#' + rvwScrId + 'RevSpouseNameDiv').addClass('sno')
        }
    }
};
apz.app.ReviewConfirm.LoadApplWorkFlowRes = function() {
    if (!apz.isNull(gApzCOB.applnWorkFlowRes) && gApzCOB.applnWorkFlowRes.length > 0) {
        gApzCOB.applnWorkFlowRes.filter(function(laction) {
            laction.action.split(',').filter(function(s) {
                switch (s.toLocaleUpperCase()) {
                    case "SUBMIT":
                        noOfBtns = noOfBtns + 1;
                        $("#" + rvwScrId + submit).removeClass("sno");
                        break;
                    case "REJECT":
                        noOfBtns = noOfBtns + 1;
                        $("#" + rvwScrId + rejectBtn).removeClass("sno");
                        $("#" + rvwScrId + "remarksRow").removeClass('sno');
                        break;
                    case "ASSIGNTOME":
                        noOfBtns = noOfBtns + 1;
                        $("#" + rvwScrId + assignToMeBtn).removeClass("sno");
                        break;
                    case "APPROVE":
                        noOfBtns = noOfBtns + 1;
                        $("#" + rvwScrId + approveBtn).removeClass("sno");
                        $("#" + rvwScrId + "remarksRow").removeClass('sno');
                        break;
                    case "EDIT":
                        noOfBtns = noOfBtns + 1;
                        //$("#" + rvwScrId + editBtn).removeClass("sno");
                        break;
                }
            })
        })
        if (noOfBtns === 1) {
            $("#" + rvwScrId + cancelBtn).removeClass("sno");
        }
        apz.app.ReviewConfirm.applicationAccess();
    }
};
apz.app.ReviewConfirm.LoadAccessPermission = function() {
    if (gApzCOB.FetchRole.accessPermission === "I") {
        // if (gApzCOB.requestNodes.applicationMaster.createdBy === gApzCOB.LoggedInUserDetails.loginResponse.userDet.id) {
            $("#" + rvwScrId + submitBtn + ",#" + rvwScrId + cancelBtn + ",#" + rvwScrId + rejectBtn).removeClass("sno");
            $("#" + rvwScrId + rejectBtn).attr('onClick', 'apz.app.ReviewConfirm.inProgressReject()');
            $("#" + rvwScrId + "remarksRow").removeClass('sno')
        // }
    } else if (!apz.isNull(gApzCOB.requestNodes.applicationMaster.createdBy) && gApzCOB.FetchRole.accessPermission === "V") {
        $("#" + rvwScrId + submitBtn + ",#" + rvwScrId + cancelBtn).removeClass("sno");
    }
};
apz.app.ReviewConfirm.inProgressReject = function() {
    if (!apz.isNull($('#' + rvwScrId + 'remarks').val().trim())) {
        accisVerified = false;
        accvalidationCheck = false;
        rejectverifiedflag = false;
        apz.app.ReviewConfirm.labelchangepuchback()
        ApzCOB.toggleModal(rvwScrId + 'rejectmodel');
        apz.app.ReviewConfirm.panNumberStatusupdate();
    } else {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_REMARK_REQUIRED_ERR"), "E")
    }
}
apz.app.ReviewConfirm.LoadAssignToMe = function() {
    if (!apz.isNull(gApzCOB.requestNodes.applicationMaster.assignedTo)) {
        if (gApzCOB.requestNodes.applicationMaster.assignedTo === gApzCOB.LoggedInUserDetails.loginResponse.userDet.id) {
            if (window.currentApplication === "InProgress") {
                if (!apz.isNull(gApzCOB.requestNodes.applicationMaster.createdBy)) {
                    $("#" + rvwScrId + editBtn + ",#" + rvwScrId + submit).removeClass('sno');
                }
                /*else {
                    $("#" + rvwScrId + editBtn + ",#" + rvwScrId + submit).addClass('sno');
                }*/
            } else if (window.currentApplication === "Approvals") {
                $("#" + rvwScrId + submit).removeClass('sno');
            }
        } else {
            $("#" + rvwScrId + editBtn + ",#" + rvwScrId + submit + ",#" + rvwScrId + cancelBtn).addClass('sno');
            // apz.app.ReviewConfirm.edit();
        }
    } else {
        //  if (gApzCOB.requestNodes.applicationMaster.createdBy !== gApzCOB.LoggedInUserDetails.loginResponse.userDet.id) {
        if (!window.currentApplication == "Pushback") {
            $("#" + rvwScrId + approveBtn + ",#" + rvwScrId + agreeBtn + ",#" + rvwScrId + rejectBtn + ",#" + rvwScrId + editBtn + ",#" +
                rvwScrId + submitBtn + ",#" + rvwScrId + cancelBtn + ",#" + rvwScrId + submit).addClass("sno");
        }
        // apz.app.ReviewConfirm.edit();
        !apz.isNull(gApzCOB.requestNodes.applicationMaster.remarks) ? $("#" + rvwScrId + "remarksRow").removeClass('sno') : $("#" + rvwScrId +
            "remarksRow").addClass('sno');
        //  }
    }
};
apz.app.ReviewConfirm.LoadCreatedByLoginDet = function() {
    if (gApzCOB.requestNodes.applicationMaster.createdBy === gApzCOB.LoggedInUserDetails.loginResponse.userDet.id) {
        $("#" + rvwScrId + approveBtn + ",#" + rvwScrId + agreeBtn + ",#" + rvwScrId + rejectBtn + ",#" + rvwScrId + editBtn + ",#" + rvwScrId +
            submitBtn + ",#" + rvwScrId + cancelBtn + ",#" + rvwScrId + submit + ",#" + rvwScrId + assignToMeBtn).addClass("sno");
        // apz.app.ReviewConfirm.edit();
        apz.isNull(gApzCOB.requestNodes.applicationMaster.remarks) ? $("#" + rvwScrId + "remarksRow").removeClass('sno') : $("#" + rvwScrId +
            "remarksRow").addClass('sno');
    }
};
apz.app.ReviewConfirm.labelchangepuchback = function() {
    document.querySelector('.crt-list #Dashbo__ReviewConfirm__el_label_2').innerHTML = "Are You Sure, You want to reject this application.";
    // document.querySelector('.crt-list #Dashbo__ReviewConfirm__el_label_2').innerHTML = "Are You Sure, You want to send back this application.";
}
apz.app.ReviewConfirm.fetchSubProduct = function() {
    var req = {
        "apiRequest": {
            "requestObj": {
                "productGroupCode": 'LOAN'
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "FetchProductDetails", "N", "N", req, false, apz.app.ReviewConfirm.fetchSubProductCB);
}
apz.app.ReviewConfirm.fetchSubProductCB = function(params) {
    apz.stopLoader();
    window.subProductResponse = JSON.parse(params.res.APZCBO__FetchProductDetails_Res.apiResponse.ResponseBody.responseObj)
    apz.data.scrdata.Select__IpaintProductDetails_Res = {};
    apz.data.scrdata.Select__IpaintProductDetails_Res.data = window.subProductResponse;
    ApzCOB.getProductData();
}
apz.app.ReviewConfirm.reInitiateReject = function(pthis, gaction) {
    apz.startLoader();
    apz.app.BaseScreens.stageBasedOnAction(pthis, gaction);
    window.approveRejectAction = gaction;
    if (!apz.isNull(inSessionStore.customerDetailsList)) {
        if (inSessionStore.customerDetailsList.length > 0) {
            inSessionStore.customerDetailsList.map(cust => {
                if (cust.customerType === "Applicant") {
                    gApzCOB.userDetails.custDtlId = cust.custDtlId;
                } else {
                    gApzCOB.userDetails.CoApplicantCustomerId = cust.custDtlId;
                }
            })
        }
    }
    var req = {
        "apiRequest": {
            // "interfaceName": approveRejectAction === 'APPROVED' ? "CreateApplication" : "",
            "interfaceName": "",
            "appId": gAppId,
            "requestObj": {
                "appId": gApzCOB.userDetails.appId,
                "status": "INPROGRESS",
                "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                "applicationId": gApzCOB.userDetails.applicationId,
                "versionNum": gApzCOB.userDetails.versionNum,
                "custDtlId": gApzCOB.userDetails.custDtlId,
                "remarks": $('#' + rvwScrId + 'remarks').val(),
                "workflow": {
                    "currentRole": "Initiator",
                    "action": "REINITIATE",
                    "workflowId": "REJECTAPPLICATION",
                    "stage": "INPUT"
                }
            }
        }
    }
    ApzCOB.serverBuildParam(gAppId, "RejectReinitiate", "N", "N", req, false, apz.app.ReviewConfirm.reInitiateRejectCB);
};
apz.app.ReviewConfirm.reInitiateRejectCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            window.IS_REINITIATE_APPLICATION = true;
            ApzCOB.FetchApplication();
            if (!apz.isNull(inSessionStore)) {
                window.bankIndex = inSessionStore?.bankDetailsWrapperList.findIndex(el => el.bankDetails.custDtlId === ApzCOB.getCustDetailID('Applicant'))
            }
            if (inSessionStore?.bankDetailsWrapperList?.[bankIndex]?.bankDetails?.payload) {
                inSessionStore.bankDetailsWrapperList[bankIndex].bankDetails.payload.accntVerified = "";
            } else {
                ApzCOB.getPayloadDatafromWrapper("accntVerified", "Applicant", "bankDetailsWrapperList") = '';
            }
        } else {
           apz.stopLoader();
           ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_REJECT_REINITIATE_SERVICE_FAILED"), "E");
        }
    } catch {
        
    }
}
apz.app.ReviewConfirm.panNumberStatusupdate = function() {
    if (!apz.isNull(inSessionStore.customerDetailsList)) {
        let cus_Array = inSessionStore.customerDetailsList;
        for (i = 0; i < cus_Array.length; i++) {
            if (!apz.isNull(inSessionStore.customerDetailsList[i].payload.panNumberStatus)) {
                inSessionStore.customerDetailsList[i].payload.panNumberStatus = '';
            }
        }
    }
}
