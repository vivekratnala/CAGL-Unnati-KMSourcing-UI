//update application workflow table based on workflow definition
apz.app.ReviewConfirm.ApplnWorkflowUpdate = function(pthis) {
    apz.startLoader();
    apz.app.BaseScreens.stageBasedOnAction(pthis);
    var req = {
        "apiRequest": {
            "interfaceName": "",
            "appId": gAppId,
            "requestObj": {
                "appId": gApzCOB.userDetails.appId,
                "applicationId": gApzCOB.userDetails.applicationId,
                "applicationStatus": gApzCOB.userDetails.applicationStatus,
                "createdBy": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                "versionNum": gApzCOB.userDetails.versionNum,
                "workflow": {
                    "currentRole": gApzCOB.workflow.currentRole,
                    "action": gApzCOB.workflow.action,
                    "workflowId": gApzCOB.workflow.workflowId,
                    "stage": gApzCOB.workflow.stage,
                    "remarks": $('#' + rvwScrId + 'remarks').val()
                }
            }
        }
    }
    ApzCOB.serverBuildParam(gAppId, "PopulateApplicationWorkflow", "N", "N", req, false, apz.app.ReviewConfirm.ApplnWorkflowUpdateCB);
};
//Approve Reject Service Callback
apz.app.ReviewConfirm.ApplnWorkflowUpdateCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            // var ifaceName = ApzCOB.GetInterfaceResMap(params);
            // var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            if (gApzCOB.workflow.currentRole === 'Verifier') {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPLN_VERIFIED"), "S", apz.app.Dashboard.LaunchDashboardCB);
            } else {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPLN_SUBMITTED"), "S", apz.app.Dashboard.LaunchDashboardCB);
            }
            apz.app.BaseScreens.fetchRole();
        } else {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_TECHNICALDIFF"), "E");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_TECHNICALDIFF"), "E");
    }
    apz.stopLoader();
};
