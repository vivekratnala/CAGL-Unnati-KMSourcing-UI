apz.app.viewallapplication.filterByProducts = function(pthis) {
    productfilter = true;
    if (count === 0) {
        var lrowno = $(pthis).attr('rowno');
        var indexVal = slectedProductsArr.findIndex(function(e) {
            return e === $(ViewProductGroupCode + lrowno).text();
        })
        if (indexVal < 0) {
            slectedProductsArr.push($(ViewProductGroupCode + lrowno).text())
        } else {
            slectedProductsArr.splice(indexVal, 1);
        }
        apz.app.viewallapplication.loadViewAllData();
        count++;
    } else {
        count = 0
    }
};
//to make checkbox selected by default based on product selection from dashboard 
apz.app.viewallapplication.selectedProductsCheck = function() {
    for (var i = 0; i < $("#" + ViewAllAppScrId + 'popoverList ul').find('li').length; i++) {
        if ($(ViewProductGroupCode + i).text() === window.selectedDashboProduct) {
            $("#" + ViewAllAppScrId + 'productcheckbox_' + i).attr('checked', true);
        }
    }
}
