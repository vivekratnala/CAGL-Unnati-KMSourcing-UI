};
apz.app.Dashboard.DashBoardCountClick = function(key) {
    window.DASHBOARD_WIDGET_SELECTED_DATA = {};
    dashBoardKey = key;
    let obj = {};
    if (!apz.isNull(dashBoardKey)) {
        if (!ApzCOB.isObjEmpty(DASHBOARD_WIDGETS_DATA)) {
            obj.data = DASHBOARD_WIDGETS_DATA[dashBoardKey].map.value.myArrayList;
            obj.title = dashBoardKey;
            if (obj.data.length > 0) {
                window.DASHBOARD_WIDGET_SELECTED_DATA = obj;
                apz.data.scrdata.Dashbo__NewDashboardPaintData_Res = {};
                apz.app.Dashboard.formatViewAllObj(obj.data);
                apz.data.scrdata.Dashbo__NewDashboardPaintData_Res = FormattedDashboardList;
                apz.data.loadData('NewDashboardPaintData', 'Dashbo');
                $("#" + DashboardScrId + "noRecordRow").addClass('sno');
                $("#" + DashboardScrId + "mainDataRow").removeClass('sno');
                var dashboardTitle = obj.title.replaceAll('_', ' ')
                $('#' + DashboardScrId + 'selectedDashTitle').text(dashboardTitle);
            } else {
                $("#" + DashboardScrId + "noRecordRow").removeClass('sno');
                $("#" + DashboardScrId + "mainDataRow").addClass('sno');
            }
        }
    }
};
