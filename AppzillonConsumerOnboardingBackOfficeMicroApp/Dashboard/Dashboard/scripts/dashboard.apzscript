apz.app.Dashboard.creditAssessFetchapplicationCB = function(params) {
    let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            ApzCOB.launchMicroApp('CrdAss', 'Cabase', 'APZCBO__BaseScreens__BaseDIV', '');
        } else {
            apz.stopLoader();
            if (params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj == ApzCOB.getDescfromLitCode("LIT_fetchLockAppli")) {
                $(`#${DashboardScrId}locktxt_txtcnt`).text(ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"));
                ApzCOB.toggleModal(DashboardScrId + 'lockModal');
            } else {
                $(`#${DashboardScrId}locktxt_txtcnt`).text(errMsg);
                ApzCOB.toggleModal(DashboardScrId + 'lockModal');
            }
        }
    } catch {
        apz.stopLoader();
        ApzCOB.toggleModal(DashboardScrId + 'lockModal');
        $(`#${DashboardScrId}locktxt_txtcnt`).html(technicalErrMsg);
    }
};
apz.app.Dashboard.closeLockModal = function() {
    if ($("#" + DashboardScrId + 'lockModal').is(":visible")) {
        $('#' + DashboardScrId + 'lockModal_close').trigger('click');
    }
};
apz.app.Dashboard.loadUnttendedData = function(pthis, key) {
    window.DASHBOARD_WIDGET_SELECTED_DATA = {};
    let currentCount = [];
    let dashBoardKey = key;
    let obj = {};
    if (!apz.isNull(dashBoardKey)) {
        if (!ApzCOB.isObjEmpty(NEW_DASHBOARD_DATA)) {
            currentCount = NEW_DASHBOARD_DATA?.map?.fliteredLeadDtls?.myArrayList ?? [];
            if (currentCount.length > 0) {
                obj.data = structuredClone(currentCount);
                obj.title = dashBoardKey;
                window.DASHBOARD_WIDGET_SELECTED_DATA = obj;
                ApzCOB.launchMicroApp("Dashbo", "DashboardViewAllApplication", "APZCBO__BaseScreens__BaseDIV", "");
            } else {
                apz.app.Dashboard.handleNorecord('Not Actioned Leads');
                apz.app.Dashboard.handleActiveCard(pthis);
            }
        }
    }
};
apz.app.Dashboard.masterSearchInpData = function() {
    if (isViewAccessEnabled) {
        $(".viewDetailsBtn").removeClass('sno')
    } else {
        $(".viewDetailsBtn").addClass('sno')
    }
    let searchVal = $("#" + DashboardScrId + "masterSearch").val().toLowerCase().trim();
    if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "HOM") {
        searchVal = $("#" + DashboardScrId + "searchHOM").val().toLowerCase().trim();
    }
    var req = {
        "apiRequest": {
            "requestObj": {
                "searchValue": searchVal
            },
            "interfaceName": "MasterSearchApi",
            "appId": "APZCBO"
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "MasterSearchApi", "N", "N", req, false, apz.app.Dashboard.masterSearchInpDataCB);
}
apz.app.Dashboard.masterSearchInpDataCB = function(params) {
    apz.stopLoader();
    ApzCOB.toggleModal("APZCBO__BaseScreens__finalSearch");
    if (ApzCOB.handleServiceCallBacks(params)) {
        apz.stopLoader();
        let masterSearchData = JSON.parse(params.res.APZCBO__MasterSearchApi_Res.apiResponse.ResponseBody.responseObj);
        if (masterSearchData.length > 0) {
            $("#APZCBO__BaseScreens__no_data_row").addClass("sno");
            $("#APZCBO__BaseScreens__search_data_row").removeClass("sno");
            apz.data.scrdata.APZCBO__MasterSearchDetails_Res = {}
            let ProductData = apz.data.scrdata.Select__IpaintProductDetails_Res.data
            const modifiedData = masterSearchData.map(item => {
                let loanTypeName = item.loanType;
                if (ProductData.length > 0 && item.loanType) {
                    const prodInfo = ProductData.find(prod => prod.productCode === item.loanType);
                    if (prodInfo) {
                        loanTypeName = prodInfo.productName;
                    }
                }
                return {
                    ...item,
                    loanType: loanTypeName,
                    customerName: `${item.customerName}/${item.customerId}`,
                    branchId: `${item.branchName}/${item.branchId}`,
                    kendraId: `${item.kendraName}/${item.kendraId}`,
                    loanAmount: item.loanAmount ? item.loanAmount : "-"
                };
            });
            apz.data.scrdata.APZCBO__MasterSearchDetails_Res.data = modifiedData;
            apz.data.loadData("MasterSearchDetails", "APZCBO");
        } else {
            $("#APZCBO__BaseScreens__search_data_row").addClass("sno");
            $("#APZCBO__BaseScreens__no_data_row").removeClass("sno");
        }
    }
};
$("#Dashbo__dashboard__checkbox_options").addClass("sno");
$("#Dashbo__dashboard__radio_options").removeClass("sno");
$("#Dashbo__dashboard__radio_options").addClass("sno");
$("#Dashbo__dashboard__checkbox_options").removeClass("sno");
apz.app.Dashboard.OnClickFilter = function() {
    apz.data.scrdata.Dashbo__IPaintListofSubFilters_Res = {};
    apz.data.scrdata.Dashbo__IPaintListofFilters_Res = {};
    apz.data.scrdata.Dashbo__IPaintListofSubFilters_Res.data = apz.data.scrdata.Select__IpaintProductDetails_Res.data.map(item => ({
        FilterLables: item.productName,
        FilterLableValue: item.productType.toUpperCase(),
        FilterCheck: "N"
    }));
    apz.data.scrdata.Dashbo__IPaintListofFilters_Res.data = [{
        FilterLables: "Product",
        FilterLableValue: "Product",
        FilterCheck: "N"
    }, ];
    apz.data.loadData("IPaintListofSubFilters", "Dashbo");
    apz.data.loadData("IPaintListofFilters", "Dashbo");
    $('#Dashbo__dashboard__applyFilterBtn').prop('disabled', true);
    listofSubFilter = apz.data.scrdata.Dashbo__IPaintListofSubFilters_Res.data;
    apz.data.scrdata.Dashbo__IPaintListofSubFilters_Res.data.forEach((_, i) => $('#Dashbo__IPaintListofSubFilters__o__data__FilterCheck_' + i).prop('checked', false));
    ApzCOB.toggleModal("Dashbo__dashboard__fltr_mdl");
    $("#Dashbo__dashboard__searchFilterInput").val("");
    $('body').addClass('unati');
    $("#Dashbo__IPaintListofFilters__o__data__FilterLables_0").click()
    $("#Dashbo__dashboard__checkbox_options").addClass("rdo-input")
    $.each(apz.data.scrdata.Dashbo__IPaintListofSubFilters_Res.data, function(i, item) {
        var isMatch = item.FilterLableValue === ApplicationType;
        $('#Dashbo__IPaintListofSubFilters__o__data__FilterCheck_' + i).prop('checked', isMatch);
    });
}
$('#Dashbo__dashboard__fltr_mdl_close').on('click', function() {
    $('body').removeClass('unati');
});
apz.app.Dashboard.OnApplyFilters = function() {
    $('body').removeClass('unati');
    // Apply the selected filters
    const selectedSubFilters = selectedSubFilterOptions.filter(item => item.FilterCheck === "Y");
    const selectedMainFilter = apz.data.scrdata.Dashbo__IPaintListofFilters_Res.data.find(item => item.FilterCheck === "Y");
    gApzCOB.mainProductGroupCode = 'LOAN';
    gApzCOB.product = 'LOAN';
    gApzCOB.productCode = '1009';
    ApzCOB.toggleModal("Dashbo__dashboard__fltr_mdl");
    window.ApplicationType = selectedSubFilters.map(item => item.FilterLableValue).join(',');
    if (window.ApplicationType === 'RENEWAL') {
        gApzCOB.productCode = '1002';
    }
    gApzCOB.SelectedProductName = productCodeBasedName[gApzCOB.productCode];
    ApzCOB.fetchSubProduct();
    apz.app.BaseScreens.getCommomCodeBasedOnProduct();
    if (selectedSubFilters.length != 0) {
        window.isFilterApplied = true;
        if (IS_DASHBOARD_COUNT_ENABLED.indexOf(ApplicationType) < 0) {
            IS_DASHBOARD_COUNT_ENABLED.push(ApplicationType);
        }
        apz.app.BaseScreens.fetchRole();
    }
}
apz.app.Dashboard.OnCancelFilters = function() {
    $('body').removeClass('unati');
    ApzCOB.toggleModal("Dashbo__dashboard__fltr_mdl");
}
apz.app.Dashboard.OnClickMainFilter = function(pthis) {
    $(pthis).closest('li').addClass('active').siblings().removeClass('active');
    const id = $(pthis).attr('id');
    const index = parseInt(id.split('_').pop());
    $.each(apz.data.scrdata.Dashbo__IPaintListofFilters_Res.data, function(i, item) {
        if (i === index) {
            item.FilterCheck = "Y";
        } else {
            item.FilterCheck = "N";
        }
    });
}
apz.app.Dashboard.OnClickSubFilter = function(pthis) {}
apz.app.Dashboard.OnClickCheckboxFilter = function(pthis) {
    const id = $(pthis).attr('id');
    const dataList = apz.data.scrdata.Dashbo__IPaintListofSubFilters_Res.data;
    const index = parseInt(id.split('_').pop());
    if (dataList[index].FilterLableValue != ApplicationType) {
        $('#Dashbo__dashboard__applyFilterBtn').prop('disabled', false);
    }
    $.each(apz.data.scrdata.Dashbo__IPaintListofSubFilters_Res.data, function(i, item) {
        if (i === index) {
            item.FilterCheck = "Y";
            $('#Dashbo__IPaintListofSubFilters__o__data__FilterCheck_' + i).prop('checked', true);
        } else {
            item.FilterCheck = "N";
            $('#Dashbo__IPaintListofSubFilters__o__data__FilterCheck_' + i).prop('checked', false);
        }
    });
    selectedSubFilterOptions = dataList.map(obj => ({
        ...obj
    }));
    const selectedValue = dataList[index].FilterLableValue;
    $.each(listofSubFilter, function(i, item) {
        item.FilterCheck = (item.FilterLableValue === selectedValue) ? "Y" : "N";
    });
};
apz.app.Dashboard.onProductSelection = function(pthis) {}
apz.app.Dashboard.searchSubFilters = function() {
    const val = $('#' + DashboardScrId + 'searchFilterInput').val().toLowerCase();
    const allData = listofSubFilter;
    const filtered = allData.filter(item => item.FilterLables.toLowerCase().includes(val));
    apz.data.scrdata.Dashbo__IPaintListofSubFilters_Res.data = filtered;
    apz.data.loadData("IPaintListofSubFilters", "Dashbo");
}

