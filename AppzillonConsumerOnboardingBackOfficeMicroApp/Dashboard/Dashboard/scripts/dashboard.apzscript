apz.app.onLoad_dashboard = function() {
    // Nothing
    PRIMARY_DEDUPE_STATUS = null;
    PRIMARY_KYC_VERIFICATION = null;
    SECONDARY_KYC_VERIFICATION = null;
    ALTERNATE_KYC_VERIFICATION = null;
    ALTERNATE_DEDUPE_STATUS = null;
    SECONDARY_DEDUPE_STATUS = null;
    APPLICANT_CIBIL_STATUS = "";
    CO_APPLICANT_CIBIL_STATUS = "";
    CB_HIGHMARK_REPORT_LINK = "";
    IS_APPLICANT_PRIMARY_DEDUPE = null;
    IS_CO_APPLICANT_PRIMARY_DEDUPE = null;
    IS_CO_APPLICANT_SECONDARY_DEDUPE = null;
    IS_CO_APPLICANT_ALTERNATE_DEDUPE = null;
    CO_APPLICANT_PRIMARY_KYC_VERIFICATION = null;
    CO_APPLICANT_SECONDARY_KYC_VERIFICATION = null;
    CO_APPLICANT_ALTERNATE_KYC_VERIFICATION = null;
    window.IS_APPLICANT_CB_EXPIRED = null;
    window.IS_CO_APPLICANT_CB_EXPIRED = null;
    ApzCOB.initSourcingQuery();
    $(`#${BaseScrId}sourcingQueryRow,#${BaseScrId}sorcingRemarksSec`).addClass('sno');
    window.PUSHBACK_ACTION_HISTORY = [];
    apz.app.BaseScreens.initializeVariables();
    if (apz.isNull(apz.data.scrdata.Select__IpaintProduct_Res)) {
        apz.app.Dashboard.FetchProducts();
    } else {
        if (apz.isNull(apz.data.scrdata.Dashbo__PaintData_Res.ViewAllProducts)) {
            apz.data.scrdata.Dashbo__PaintData_Res.Products = [];
            apz.data.scrdata.Dashbo__PaintData_Res.ViewAllProducts = [];
            apz.data.scrdata.Select__IpaintProduct_Res.filter(function(el) {
                var obj = {};
                obj.productGroupCode = el.productGroupCode;
                apz.data.scrdata.Dashbo__PaintData_Res.Products.push(obj)
                apz.data.scrdata.Dashbo__PaintData_Res.ViewAllProducts.push(obj)
            })
        }
        apz.data.loadData('PaintData', 'Dashbo');
        $('#' + DashboardScrId + 'dashProductList_row_0').addClass('active');
    }
    $('li[id^= "' + BaseScrId + '' + "menulist_row_" + '"]').removeClass('progress');
    $('li[id^= "' + BaseScrId + '' + "menulist_row_" + '"]').removeClass('completed');
    $("#APZCBO__BaseScreens__sidebarController").removeClass('sno');
    completeArray = [];
    inprogressArray = [];
    ApzCOB.updateStepperStage();
    applicantState = '';
    $('#APZCBO__BaseScreens__landingRowHeader').addClass('sno');
};
apz.app.onShown_dashboard = function() {
    $('body').removeClass('unati sanction-dev crdas sanction-suc-scr dbkit ajs-no-overflow');
    $('body').addClass('newdashboardlat');
    window.ISPUSHBACKPPL = false;
    window.IS_BM_DOC_EDIT = false;
    window.PUSHBACKVIEWALL = false;
    ApzCOB.fetchSubProduct();
    $("#APZCBO__BaseScreens__sidebarController").removeClass('sno');
    $(`#${BaseScrId}RefNumDiv`).addClass('sno');
    ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], false);
    $("#" + BaseScrId + "SettingIconCol").removeClass('sno');
    window.selectedDashboProduct = 'LOAN';
    $("#header").removeClass("sno");
    $('body').addClass('LoginBase');
    $("#" + BaseScrId + "dashBoardList").removeClass("sno");
    $("#" + BaseScrId + "menulist").addClass("sno");
    $("#" + BaseScrId + "sidebaricon").addClass("sno");
    $("#" + BaseScrId + "searchByNum").val('');
    $('#' + DashboardScrId + 'MBsearchRow').addClass('sno');
    if (apz.deviceType === "WEB") {
        $("#" + BaseScrId + "searchByNumCol").removeClass('sno');
        $("#" + BaseScrId + "applnStatus").addClass('sno');
        $("#" + BaseScrId + "sc_col_5").removeClass("sno");
        $("#" + BaseScrId + "sc_col_4").removeClass("sno");
        $("#" + BaseScrId + "sc_col_3").removeClass("sno");
    } else {
        $("#" + BaseScrId + "searchByNumCol").addClass('sno');
        $('#' + BaseScrId + 'sc_col_34').addClass('sno');
        $("#" + BaseScrId + "sc_col_5").removeClass("sno");
        $("#" + BaseScrId + "sc_col_53").addClass("sno");
    }
    if (!apz.isNull(gApzCOB.LoggedInUserDetails.loginResponse.userDet.name)) {
        apz.setElmValue(BaseScrId + "userName_txtcnt", gApzCOB.LoggedInUserDetails.loginResponse.userDet.name);
        apz.setElmValue(BaseScrId + "userRole_txtcnt", gApzCOB.LoggedInUserDetails.loginResponse.addInfo1);
    }
    apz.app.Dashboard.paintlastLogin();
    $('div[id^=' + "'" + BaseScrId + "STAGE" + "'" + ']').addClass('sno')
    gApzCOB['requestNodes']['nomineeDetailsWrapperList'] = [];
    $('#' + BaseScrId + 'baseScroll').removeClass('product-screen');
    document.getElementById('APZCBO__BaseScreens__BaseDIV').classList.remove('verify_approve');
    gApzCOB.currentApplicant = $("#Dashbo__ReviewConfirm__applicantNameList_row_0").hasClass("active") ? 1 : 2;
    $('body').removeClass('modal-open')
    $(`#${BaseScrId}custIDandName`).addClass('sno');
    gApzCOB.product = gApzCOB.product ?? 'LOAN';
    gApzCOB.mainProductGroupCode = 'LOAN';
    dashBoardKey = '';
    if (ApplicationType === 'NEW') {
        gApzCOB.productCode = '1009';
    } else if (ApplicationType === 'RENEWAL') {
        gApzCOB.productCode = '1002';
    }
    gApzCOB.SelectedProductName = productCodeBasedName[gApzCOB.productCode];
    apz.app.BaseScreens.getCommomCodeBasedOnProduct();
    if (isNotLoginCB) {
        apz.app.BaseScreens.fetchRole();
    } else {
        if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === 'HOM') {
            $('#Dashbo__dashboard__dashboardMainCol').children().addClass('sno');
            $("#Dashbo__dashboard__headofficer_dashboard_screen").removeClass("sno");
            return;
        } else {
            $("#Dashbo__dashboard__headofficer_dashboard_screen").addClass("sno")
        }
        if (apz.deviceType === 'WEB') {
            apz.app.Dashboard.showNewDashboardStats();
        } else {
            apz.app.Dashboard.showNewDashboardStatsTab();
        }
    }
    if (isNotLoginCB || logoClicked) {
        $('#' + DashboardScrId + 'gr_row_33').addClass('mt0');
    }
    IS_DASHBOARD_VIEW_DATA = false;
};
