//DBKIT
apz.app.Dashboard.launchDbMicroApp = function() {
    applicationStatus = '';
    gApzCOB.userDetails.applicationId = '1741070411056942';
    gApzCOB.userDetails.versionNum = 1;
    var applnId = gApzCOB.userDetails.applicationId;
    var req = {
        apiRequest: {
            interfaceName: "",
            appId: gAppId,
            requestObj: {
                applicationId: applnId,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                //  "applicationId": "16202346089849322",
                appId: gApzCOB.userDetails.appId,
                versionNum: gApzCOB.userDetails.versionNum,
            },
        },
    };
    apz.startLoader();
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, "FetchApplication", "N", "N", req, false, apz.app.Dashboard.launchDbMicroAppCB);
    }, 1000);
}
apz.app.Dashboard.launchDbMicroAppCB = function(params) {
    let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            ApzCOB.fetchSubProduct();
            ApzCOB.launchMicroApp('DBkitG', 'DBbase', `${gAppId}__BaseScreens__BaseDIV`, ' ');
        } else {
            apz.stopLoader();
            $(`#${scrId}locktxt_txtcnt`).text(errMsg);
            ApzCOB.toggleModal(scrId + 'lockModal');
        }
    } catch {
        apz.stopLoader();
        ApzCOB.toggleModal(scrId + 'lockModal');
        $(`#${scrId}locktxt_txtcnt`).html(technicalErrMsg);
    }
};
apz.app.Dashboard.formatViewAllObj = function(dashboardData) {
    window.FormattedDashboardList = [];
    dashboardData.map(item => {
        let lresp = item.map;
        let memberId = apz.isNull(lresp.memberId) ? "" : lresp.memberId;
        if (apz.isNull(memberId)) {
            memberId = apz.isNull(lresp.customerId) ? "" : lresp.customerId;
        }
        let memberName = apz.isNull(lresp.firstName) ? "" : lresp.firstName;
        if (apz.isNull(memberName)) {
            memberName = apz.isNull(lresp.customerName) ? "" : lresp.customerName;
        }
        let currentStatus = apz.isNull(lresp.currentStatus) ? "" : lresp.currentStatus;
        if (!apz.isNull(lresp.currentStageNo)) {
            if (KM_STAGES.length > 0) {
                const currentStage = KM_STAGES.find(stage => parseInt(stage.key) === lresp.currentStageNo);
                if (currentStage) {
                    currentStatus = currentStage.value;
                } else {
                    currentStatus = dashBoardtitle;
                }
            } else {
                currentStatus = dashBoardtitle;
            }
        } else {
            currentStatus = dashBoardtitle;
        }
        let priority = apz.isNull(lresp.priority) ? "" : lresp.priority;
        let obj = {};
        obj.memberId = (!apz.isNull(memberId)) ? memberId : "";
        obj.memberName = (!apz.isNull(memberName)) ? memberName : "";;
        obj.kendraName = (!apz.isNull(lresp.kendraName)) ? lresp.kendraName : "";;
        obj.kendraId = (!apz.isNull(lresp.kendraId)) ? lresp.kendraId : "";;
        obj.vintage = (!apz.isNull(lresp.kendraVintageYrs)) ? ApzCOB.fn_unFormatAmount(lresp.kendraVintageYrs) : "";;
        obj.meetingDay = (!apz.isNull(lresp.kendraMeetingDay)) ? lresp.kendraMeetingDay : "";;
        obj.outstandingAmount = (!apz.isNull(lresp.caglOs)) ? ApzCOB.CustomizedAmountFormatting(Number(lresp.caglOs)) : "";;
        obj.kmID = (!apz.isNull(lresp.createdBy)) ? lresp.createdBy : "";;
        obj.priority = (!apz.isNull(priority)) ? priority : "";;
        obj.currentStatus = (!apz.isNull(currentStatus)) ? currentStatus : dashBoardtitle;
        obj.applicationId = (!apz.isNull(lresp.applicationId)) ? lresp.applicationId : "";;
        FormattedDashboardList.push(obj);
    })
    if (dashBoardtitle === 'Not actioned leads' || dashBoardtitle === 'UNACTIONED_LEADS') {
        window.FormattedDashboardList = apz.app.BaseScreens.sortLeads(DashboardViewList);
    }
    return window.FormattedDashboardList;
}
apz.app.Dashboard.formatLOan_TAT = function(params) {
    for (let i of params) {
        if (i.hasOwnProperty('loanAmount')) {
            if (!i.loanAmount.toString().includes("₹")) {
                i.loanAmount = "₹" + ApzCOB.fn_FormatAmount(i.loanAmount);
            }
        } else {
            i.loanAmount = "";
        }
        if (i.hasOwnProperty('rpcTAT')) {
            const tat = i.rpcTAT?.toLowerCase();
            if (!tat?.includes("days") && !tat?.includes("hours") && !tat?.includes("minutes") && !tat?.includes("just")) {
                i.rpcTAT = apz.app.Dashboard.tat_formatDate(i.rpcTAT);
                i.rpcTAT = i.rpcTAT.replace(/(\d{1,5})([a-zA-Z]{1,10})/, '$1 $2');
            }
        } else {
            i.rpcTAT = "";
        }
    }
};
apz.app.Dashboard.formatProductName = function(data) {
    var productList = apz.data.scrdata.Select__IpaintProductDetails_Res.data;
    data.forEach(item => {
        const match = productList.find(prod => prod.productCode === item.productCode);
        if (match) {
            item.productCode = match.productName;
        }
    });
};
apz.app.Dashboard.tat_formatDate = function(input) {
    const timeRegex = /(\d{1,5})S\|(\d{1,5})M\|(\d{1,5})H\|(\d{1,5})D/;
    const match = input.match(timeRegex);
    let str = "";
    if (!match) {
        throw new Error("Invalid input format");
    }
    if (match[match.length - 1] != 0) {
        str = match[match.length - 1] + "Days Before";
    } else if (match[match.length - 2] != 0) {
        str = match[match.length - 2] + "hours Before";
    } else if (match[match.length - 3] != 0) {
        str = match[match.length - 3] + "minutes Before";
    } else if (match[match.length - 4] != 0) {
        str = "Just now";
    }
    return str;
};
apz.app.Dashboard.sortTat = function(params) {
    const getSeconds = (tat) => {
        if (tat?.toLowerCase()?.includes("day")) {
            return parseInt(tat) * 24 * 60 * 60;
        }
        if (tat?.toLowerCase()?.includes("hour")) {
            return parseInt(tat) * 60 * 60;
        }
        if (tat?.toLowerCase()?.includes("minutes")) {
            return parseInt(tat) * 60;
        }
        return 0;
    };
    apz.data.scrdata.Dashbo__NewDashboardPaintData_Res.sort((a, b) => {
        const tatA = getSeconds(a.rpcTAT);
        const tatB = getSeconds(b.rpcTAT);
        return params === "One" ? tatA - tatB : tatB - tatA;
    });
    $(`#Dashbo__dashboard__tatSortDown,#Dashbo__dashboard__tatSortUp`).attr('style', '');
    rpctatCSS = {'fill': 'rgb(0, 72, 134)'};
    if (params === "One") {
        $(`#${DashboardScrId}tatSortDown`).css(rpctatCSS);
    } else {
        $(`#${DashboardScrId}tatSortUp`).css(rpctatCSS);
    }
    apz.data.loadData('NewDashboardPaintData', 'Dashbo');
};
apz.app.Dashboard.paintNewDashboardData = function(key, status) {
    if(gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === 'HOM') {
        return;
    }
    $("#" + DashboardScrId + "dashBoardDataRow").removeClass('sno');
    dashBoardKey = key;
    let normalizedTitle = allSubTypes[selectedTitle.trim()] || selectedTitle.trim();
    if (apz.deviceType === 'WEB') {
        if (!apz.isNull(dashBoardKey)) {
            let matchedItem = storeDashboardCount.find(item => item.name.trim() === normalizedTitle);
            if (matchedItem && matchedItem.count > 0) {
                apz.data.scrdata.Dashbo__NewDashboardPaintData_Res = {};
                apz.data.loadData('NewDashboardPaintData', 'Dashbo');
                if (window.selectedTitle !== 'Not actioned leads' && window.selectedTitle !== 'UNACTIONED_LEADS') {
                    apz.app.Dashboard.formatLOan_TAT(newDashboardStoreData);
                    apz.app.Dashboard.formatProductName(newDashboardStoreData);
                }
                apz.app.Dashboard.handleDataPaintCol();
                apz.data.scrdata.Dashbo__NewDashboardPaintData_Res = newDashboardStoreData;
                apz.data.loadData('NewDashboardPaintData', 'Dashbo');
                $(`#Dashbo__dashboard__tatSortDown,#Dashbo__dashboard__tatSortUp`).attr('style', '');
                rpctatCSS = {'fill': 'rgb(0, 72, 134)'};
                $(`#${DashboardScrId}tatSortDown`).css(rpctatCSS);
                $("#" + DashboardScrId + "noRecordRow").addClass('sno');
                $("#" + DashboardScrId + "mainDataRowTab").addClass('sno');
                $("#" + DashboardScrId + "mainDataRowWeb").removeClass('sno');
                $('#' + DashboardScrId + 'selectedDashTitle').text(normalizedTitle === "Post disbursment " ? "LUC" : normalizedTitle);
                apz.app.Dashboard.handleStatus(key, status, newDashboardStoreData, normalizedTitle);
                if (window.selectedTitle === 'Credit assessment' || window.selectedTitle === 'CREDIT_ASSESSMENT') {
                    for (let i = 0; i < newDashboardStoreData.length; i++) {
                        $("#Dashbo__dashboard__ct_lst_4_row_" + i).attr('onClick', `apz.app.Dashboard.creditAssFetchAppDetails(this)`);
                    }
                } else {
                    for (let i = 0; i < newDashboardStoreData.length; i++) {
                        $("#Dashbo__dashboard__ct_lst_4_row_" + i).attr('onClick', `apz.app.Dashboard.listOnClick(this)`);
                    }
                }
                $("li[onclick]").css("cursor", "pointer");
                if (SELECTED_SUB_STATUS === 'APPROVED') { //future development for approved status
                    for (let i = 0; i < newDashboardStoreData.length; i++) {
                        $("#Dashbo__dashboard__ct_lst_4_row_" + i).attr('onClick', ``);
                        $("#Dashbo__dashboard__ct_lst_4_row_" + i).css("cursor", "default");
                    }
                }
            } else {
                $('#' + DashboardScrId + 'selectedDashTitle').text(normalizedTitle === "Post disbursment " ? "LUC" : normalizedTitle);
                $("#" + DashboardScrId + "noRecordRow").removeClass('sno');
                $("#" + DashboardScrId + "mainDataRowWeb").addClass('sno');
                $("#" + DashboardScrId + "mainDataRowTab").addClass('sno');
            }
        }
    } else {
        if (!apz.isNull(dashBoardKey)) {
            let matchedItemTab = storeDashboardCount.find(item => item.name.trim() === normalizedTitle);
            if (matchedItemTab && matchedItemTab.count > 0) {
                apz.data.scrdata.Dashbo__NewDashboardPaintDataTab_Res = {};
                apz.data.loadData('NewDashboardPaintDataTab', 'Dashbo');
                if (window.selectedTitle !== 'Not actioned leads' && window.selectedTitle !== 'UNACTIONED_LEADS') {
                    apz.app.Dashboard.formatLOan_TAT(newDashboardStoreData);
                    apz.app.Dashboard.formatProductName(newDashboardStoreData);
                }
                apz.app.Dashboard.handleDataPaintCol();
                apz.data.scrdata.Dashbo__NewDashboardPaintDataTab_Res = newDashboardStoreData;
                apz.data.loadData('NewDashboardPaintDataTab', 'Dashbo');
                $("#" + DashboardScrId + "noRecordRow").addClass('sno');
                $("#" + DashboardScrId + "mainDataRowWeb").addClass('sno');
                $("#" + DashboardScrId + "mainDataRowTab").removeClass('sno');
                $('#' + DashboardScrId + 'selectedDashTitle').text(normalizedTitle === "Post disbursment " ? normalizedTitle : "LUC");
                apz.app.Dashboard.handleStatusTab(key, status, newDashboardStoreData, normalizedTitle);
                if (window.selectedTitle === 'Credit assessment' || window.selectedTitle === 'CREDIT_ASSESSMENT') {
                    for (let i = 0; i < newDashboardStoreData.length; i++) {
                        $("#Dashbo__dashboard__ct_lst_11_row_" + i).attr('onClick', `apz.app.Dashboard.creditAssFetchAppDetails(this)`);
                    }
                } else {
                    for (let i = 0; i < newDashboardStoreData.length; i++) {
                        $("#Dashbo__dashboard__ct_lst_11_row_" + i).attr('onClick', `apz.app.Dashboard.listOnClick(this)`);
                    }
                }
                if (SELECTED_SUB_STATUS === 'APPROVED') { //future development for approved status
                    for (let i = 0; i < newDashboardStoreData.length; i++) {
                        $("#Dashbo__dashboard__ct_lst_11_row_" + i).attr('onClick', ``);
                    }
                }
            } else {
                $('#' + DashboardScrId + 'selectedDashTitle').text(normalizedTitle === "Post disbursment " ? normalizedTitle : "LUC");
                $("#" + DashboardScrId + "noRecordRow").removeClass('sno');
                $("#" + DashboardScrId + "mainDataRowTab").addClass('sno');
                $("#" + DashboardScrId + "mainDataRowWeb").addClass('sno');
            }
        }
    }
    apz.app.Dashboard.updatePaginationControls(dashBoardKey, status);
};
apz.app.Dashboard.handleDataPaintCol = function() {
    if (apz.deviceType === "WEB") {
        if (window.selectedTitle === 'Not actioned leads' || window.selectedTitle === 'UNACTIONED_LEADS') {
            $("#" + DashboardScrId + "prodCol_li").addClass('sno');
            $("#" + DashboardScrId + "tatCol_li").addClass('sno');
            $("#" + DashboardScrId + "loanAmtCol_li").addClass('sno');
            for (let i = 0; i < newDashboardStoreData.length; i++) {
                $("#Dashbo__NewDashboardPaintData__o__Dashbo__NewDashboardPaintData_Res__productCode_" + i).parents().eq(0).addClass('sno');
                $("#Dashbo__NewDashboardPaintData__o__Dashbo__NewDashboardPaintData_Res__rpcTAT_" + i).parents().eq(0).addClass('sno');
                $("#Dashbo__NewDashboardPaintData__o__Dashbo__NewDashboardPaintData_Res__loanAmount_" + i).parents().eq(0).addClass('sno');
            }
        } else {
            $("#" + DashboardScrId + "prodCol_li").removeClass('sno');
            $("#" + DashboardScrId + "tatCol_li").removeClass('sno');
            $("#" + DashboardScrId + "loanAmtCol_li").removeClass('sno');
            for (let i = 0; i < newDashboardStoreData.length; i++) {
                $("#Dashbo__NewDashboardPaintData__o__Dashbo__NewDashboardPaintData_Res__productCode_" + i).parents().eq(0).removeClass('sno');
                $("#Dashbo__NewDashboardPaintData__o__Dashbo__NewDashboardPaintData_Res__rpcTAT_" + i).parents().eq(0).removeClass('sno');
                $("#Dashbo__NewDashboardPaintData__o__Dashbo__NewDashboardPaintData_Res__loanAmount_" + i).parents().eq(0).removeClass('sno');
            }
        }
    } else {
        if (window.selectedTitle === 'Not actioned leads' || window.selectedTitle === 'UNACTIONED_LEADS') {
            $("#" + DashboardScrId + "tabProdCol_li").addClass('sno');
            for (let i = 0; i < newDashboardStoreData.length; i++) {
                $("#Dashbo__NewDashboardPaintData__o__Dashbo__NewDashboardPaintData_Res__productCode_" + i).parents().eq(0).addClass('sno');
            }
        } else {
            $("#" + DashboardScrId + "tabProdCol_li").removeClass('sno');
            for (let i = 0; i < newDashboardStoreData.length; i++) {
                $("#Dashbo__NewDashboardPaintData__o__Dashbo__NewDashboardPaintData_Res__productCode_" + i).parents().eq(0).removeClass('sno');
            }
        }
    }
};
apz.app.Dashboard.handleStatus = function(key, status, count, title) {
    let statusTypes = ["PENDING", "SUBMITTED", "SANCTION", "PUSHBACK", "REJECTED", "CAPUSHBACK", "APPROVED", "DBKITVERIFIED", "CA_DEVIATION",
        "REASSESSMENT", "RESANCTION", "DBPUSHBACK", "PRESANCTION", "LUC", "PENDINGLUCVERIFICATION","LUCVERIFIED"];
    let suffixes = ["_SO", "_BM", "_RPC", "_DA", "_SA", "_DIP", "_DIS", "_UL", "_CA", "_ALL", "_POST"];
    statusTypes.forEach(type => {
        suffixes.forEach(suffix => {
            $("#" + DashboardScrId + type + suffix).removeClass('active');
        });
    });
    if (count.length === 0) {
        $('#' + DashboardScrId + 'selectedDashTitle').text(title);
        $("#" + DashboardScrId + "noRecordRow").removeClass('sno');
        $("#" + DashboardScrId + "dataRow").addClass('sno');
    } else {
        $('#' + DashboardScrId + 'selectedDashTitle').text(title);
        $("#" + DashboardScrId + "noRecordRow").addClass('sno');
        $("#" + DashboardScrId + "dataRow").removeClass('sno');
    }
    let sourcingRow = $("#" + DashboardScrId + "SOURCING_ROW");
    let bmApprovalRow = $("#" + DashboardScrId + "BM_APPROVAL_ROW");
    let rpcVerfRow = $("#" + DashboardScrId + "RPC_VERIFICATION_ROW");
    let sanctionRow = $("#" + DashboardScrId + "SANCTION_ROW");
    let deviationRow = $("#" + DashboardScrId + "DEVIATION_RA_ROW");
    let disProgRow = $("#" + DashboardScrId + "DISBURSEMENT_INPROGRESS_ROW");
    let disburdedRow = $("#" + DashboardScrId + "DISBURSED_ROW");
    let creditRow = $("#" + DashboardScrId + "CREDIT_ASSESSMENT_ROW");
    let postDisRow = $("#" + DashboardScrId + "POSTDISBRUSEMENT_ROW");
    let overallRow = $("#" + DashboardScrId + "OVERALLEADS_ROW");
    let rejectedRow = $("#" + DashboardScrId + "REJECTED_ROW");
    sourcingRow.addClass('sno');
    bmApprovalRow.addClass('sno');
    rpcVerfRow.addClass('sno');
    sanctionRow.addClass('sno');
    deviationRow.addClass('sno');
    disProgRow.addClass('sno');
    disburdedRow.addClass('sno');
    creditRow.addClass('sno');
    postDisRow.addClass('sno');
    overallRow.addClass('sno');
    rejectedRow.addClass('sno');
    if (key === 'Sourcing stage' || key === 'SOURCING') {
        switch (status) {
            case 'PENDING':
            case 'PUSHBACK':
            case 'REJECTED':
            case 'SUBMITTED':
            case 'CAPUSHBACK':
                $("#" + DashboardScrId + status + '_SO').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "PENDING_SO").addClass('active');
        }
        sourcingRow.removeClass('sno');
    } else if (key === 'BM sourcing approval' || key === 'BM_APPROVAL') {
        switch (status) {
            case 'PENDING':
            case 'PUSHBACK':
            case 'REJECTED':
            case 'APPROVED':
                $("#" + DashboardScrId + status + '_BM').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "PENDING_BM").addClass('active');
        }
        bmApprovalRow.removeClass('sno');
    } else if (key === 'RPC verification' || key === 'RPC_VERIFICATION') {
        switch (status) {
            case 'PENDING':
                $("#" + DashboardScrId + status + '_RPC').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "PENDING_RPC").addClass('active');
        }
        rpcVerfRow.removeClass('sno');
    } else if (key === 'Credit assessment' || key === 'CREDIT_ASSESSMENT') {
        switch (status) {
            case 'PENDING':
            case 'APPROVED':
            case 'CAPUSHBACK':
            case 'PUSHBACK':
            case 'REJECTED':
                $("#" + DashboardScrId + status + '_CA').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "PENDING_CA").addClass('active');
        }
        creditRow.removeClass('sno');
    } else if (key === 'Deviation/re-assesment' || key === 'DEVIATION_RA') {
        switch (status) {
            case 'CA_DEVIATION':
            case 'REASSESSMENT':
            case 'APPROVED':
            case 'PUSHBACK':
            case 'REJECTED':
                $("#" + DashboardScrId + status + '_DA').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "CA_DEVIATION_DA").addClass('active');
        }
        deviationRow.removeClass('sno');
    } else if (key === 'Sanction' || key === 'SANCTION') {
        // const userRole = gApzCOB.LoggedInUserDetails.loginResponse.addInfo1;
        // const preSanctionSelector = `#${DashboardScrId}preSanction`;
        // if (['AM', 'ACM'].includes(userRole)) {
        //     $(preSanctionSelector).removeClass('sno');
        // } else {
        //     $(preSanctionSelector).addClass('sno');
        // }
        const validStatuses = ['PENDING', 'RESANCTION', 'PUSHBACK', 'REJECTED', 'PRESANCTION'];
        const highlightStatus = validStatuses.includes(status) ? status : 'PENDING';
        $(`#${DashboardScrId}${highlightStatus}_SA`).addClass('active');
        sanctionRow.removeClass('sno');
    } else if (key === 'Disbursement inprogress' || key === 'DISBURSEMENT_INPROGRESS') {
        switch (status) {
            case 'PENDING':
            case 'DBPUSHBACK':
            case 'DBKITVERIFIED':
                $("#" + DashboardScrId + status + '_DIP').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "PENDING_DIP").addClass('active');
        }
        disProgRow.removeClass('sno');
    } else if (key === 'Disbursed' || key === 'DISBURSED') {
        switch (status) {
            case 'PENDING':
            case 'APPROVED':
                $("#" + DashboardScrId + status + '_DIS').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "PENDING_DIS").addClass('active');
        }
        disburdedRow.removeClass('sno');
    } else if (key === 'Rejected' || key === 'REJECTED') {
        switch (status) {
            case 'PENDING':
                $("#" + DashboardScrId + status + '_REJ').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "PENDING_REJ").addClass('active');
        }
        rejectedRow.removeClass('sno');
    } else if (key === 'Post disbursement ' || key === 'POSTDISBRUSEMENT') {
        switch (status) {
            case 'LUC':
            case 'PENDINGLUCVERIFICATION':
            case 'LUCVERIFIED':
                $("#" + DashboardScrId + status + '_POST').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "LUC_POST").addClass('active');
        }
        postDisRow.removeClass('sno');
    } else if (key === 'Overall leads' || key === 'OVERALLEADS') {
        switch (status) {
            case 'PENDING':
                $("#" + DashboardScrId + status + '_ALL').addClass('active');
                break;
            default:
                $("#" + DashboardScrId + "PENDING_ALL").addClass('active');
        }
        overallRow.removeClass('sno');
    }
};
apz.app.Dashboard.handleStatusTab = function(key, status, count, title) {
    let statusTypes = ["PENDING", "SUBMITTED", "SANCTION", "PUSHBACK", "REJECTED", "CAPUSHBACK", "APPROVED", "DBKITVERIFIED", "CA_DEVIATION",
