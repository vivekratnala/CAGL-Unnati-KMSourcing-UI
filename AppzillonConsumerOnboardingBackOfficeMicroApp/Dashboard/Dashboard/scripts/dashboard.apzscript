apz.app.Dashboard.handleActiveCard = function(pthis) {
    apz.stopLoader();
    if (pthis === undefined) {
        if (selectedTitleArray.length === 1) {
            //do nothing future will be needed
        } else {
            var selectedTab = selectedTitleArray.slice(selectedTitleArray.length - 2)[0];
            $("[id^='Dashbo__dashboard__dashboardCountItem_']").removeClass('active');
            $('#' + selectedTab.id).addClass('active');
            selectedTitleArray = [];
            selectedTitleArray.push(selectedTab);
        }
    } else {
        var obj = {
            "id": "",
            "title": window.selectedTitle,
            "subtype": window.SELECTED_SUB_STATUS
        }
        obj.id = pthis.id;
        window.selectedTitleArray.push(obj);
        $("[id^='Dashbo__dashboard__dashboardCountItem_']").removeClass('active');
        $('#' + pthis.id).addClass('active');
        StoreNavData = selectedTitleArray;
    }
};
apz.app.Dashboard.handleNorecord = function(name) {
    $("#" + DashboardScrId + "dashBoardDataRow").removeClass('sno');
    $('#' + DashboardScrId + 'selectedDashTitle').text(name);
    $("#" + DashboardScrId + "noRecordRow").removeClass('sno');
    if (apz.deviceType === "WEB") {
        $("#" + DashboardScrId + "mainDataRowWeb").addClass('sno');
    } else {
        $("#" + DashboardScrId + "mainDataRowTab").addClass('sno');
    }
}
apz.app.Dashboard.listOnClick = async function(ev) {
    window.recordClicked = true;
    logoClicked = true;
    let selectedStatus = dashBoardKey;
    if (loginResponse?.addInfo1 !== 'KM' && (["Rejected"].includes(selectedStatus) || ["Sourcing stage"].includes(selectedStatus) && ["PENDING"].includes(SELECTED_SUB_STATUS))) {
        return;
    }
    if (['Disbursement inprogress', 'Disbursed', 'DISBURSEMENT_INPROGRESS', 'DISBURSED'].includes(selectedStatus) && apz.deviceType !== "WEB") {
        ApzCOB.fnDisplayMsg("Please use WEB login!", "E");
        return;
    }
    if ((['bm sourcing approval'].includes(selectedStatus?.toLowerCase()) && apz.deviceType === "WEB") && !window.RT_REQ) {
        ApzCOB.fnDisplayMsg("Please use TAB login!", "E");
        return;
    }
    if (loginResponse?.addInfo1 === 'BCM' && ['DEVIATION/RE-ASSESMENT', 'Deviation/re-assesment', 'DEVIATION_RA'].includes(selectedStatus)) {
        if (SELECTED_SUB_STATUS === 'REASSESSMENT' && apz.deviceType === "WEB") {
            ApzCOB.fnDisplayMsg("Please use TAB login!", "E");
            return;
        } else if (SELECTED_SUB_STATUS === 'CA_DEVIATION' && apz.deviceType !== "WEB") {
            ApzCOB.fnDisplayMsg("Please use WEB login!", "E");
            return;
        }
    }
    if (ACTIONABLES.includes(selectedStatus)) {
        if (selectedStatus === 'SANCTION' && SELECTED_SUB_STATUS === 'PRESANCTION' && !["ACM", "AM"].includes(loginResponse?.addInfo1)) {
            window.growNo = $(ev).attr('rowno');
            gApzCOB.userDetails.applicationId = newDashboardStoreData[growNo].applicationId;
            apz.app.Dashboard.launchPreviewScreen(gApzCOB.userDetails.applicationId);
            return;
        }
        window.clickList = true;
        window.growNo = $(ev).attr('rowno');
        gApzCOB.userDetails.applicationId = newDashboardStoreData[growNo].applicationId;
        gApzCOB.userDetails.customerId = newDashboardStoreData[growNo].memberId;
        gApzCOB.userDetails.versionNum = 1;
        IS_DASHBOARD_VIEW_DATA = true;
        if (!apz.isNull(gApzCOB.userDetails.applicationId)) {
            gApzCOB.ExistingCustomer = false;
            gApzCOB.mainProductGroupCode = gApzCOB.product;
            let clickedStatus = selectedStatus;
            if (gApzCOB.mainProductGroupCode === 'LOAN') {
                if (apz.isNull(window.CURRENT_STAGE_NAME) && !apz.isNull(gApzCOB.userDetails.customerId)) {
                    if (['Deviation/re-assesment', 'Sanction', 'Disbursement inprogress', 'Disbursed', 'DISBURSEMENT_INPROGRESS', 'SANCTION', 'DEVIATION_RA', 'DISBURSED', ].includes(clickedStatus)) {
                        gApzCOB.userDetails.versionNum = 1;
                        let callBackFn = '';
                        if (clickedStatus === 'Disbursement inprogress' || clickedStatus === 'DISBURSEMENT_INPROGRESS' || clickedStatus === 'DISBURSED' || clickedStatus === 'Disbursed') {
                            callBackFn = apz.app.Dashboard.fetchDisbursementApplicationCB;
                        } else {
                            callBackFn = apz.app.Dashboard.fetchSanctionApplicationCB;
                        }
                        ApzCOB.FetchApplication("", callBackFn);
                    } else {
                        if (newDashboardStoreData[growNo].applicationStatus === "PUSHBACK") {
                            ApzCOB.PushBackFetchApplication(growNo);
                        } else {
                            // ApplicationType === 'RENEWAL' ? ApzCOB.FetchApplication(growNo, ApzCOB.FetchApplicationRenewalCB) : ApzCOB.FetchApplication(growNo);
                            ApzCOB.FetchApplication(growNo);
                        }
                    }
                } else {
                    if (gApzCOB.ExistingCustomer) {
                        ApzCOB.LoanFetchApplication(growNo);
                    }
                }
            } else {
                if (apz.isNull(window.CURRENT_STAGE_NAME) && !apz.isNull(gApzCOB.userDetails.customerId)) {
                    ApzCOB.FetchCustomerDetails(growNo);
                } else {
                    ApzCOB.FetchApplication(growNo);
                }
            }
        } else {
            ApzCOB.startNewApplication();
        }
    } else {
        if (selectedStatus === 'Post disbursement ' && (loginResponse?.addInfo1 === 'BM' && SELECTED_SUB_STATUS === "LUC" || loginResponse?.addInfo1 === 'BCM' && SELECTED_SUB_STATUS === "PENDINGLUCVERIFICATION")) {
            window.growNo = $(ev).attr('rowno');
            gApzCOB.userDetails.applicationId = newDashboardStoreData[growNo].applicationId;
            apz.app.Dashboard.launchLUC(gApzCOB.userDetails.applicationId);
            return;
        }
        window.growNo = $(ev).attr('rowno');
        gApzCOB.userDetails.applicationId = newDashboardStoreData[growNo].applicationId;
        apz.app.Dashboard.launchPreviewScreen(gApzCOB.userDetails.applicationId);
    }
};
apz.app.Dashboard.launchLUC = function(applnId) {
    if(apz.deviceType == "WEB"){
        window.RT_REQ = false;
    }
    if (window.RT_REQ || apz.deviceType !== "WEB") {
        var req = {
            apiRequest: {
                interfaceName: "",
                appId: gAppId,
                requestObj: {
                    applicationId: applnId,
                    userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                    appId: gApzCOB.userDetails.appId,
                    versionNum: 1,
                },
            },
        };
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "FetchApplication", "N", "N", req, false, apz.app.Dashboard.launchLUCCB);
        }, 1000);
    } else {
        ApzCOB.fnDisplayMsg("Please use the TAB version.", "E");
    }
};
apz.app.Dashboard.launchLUCCB = function(params) {
    let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            ApzCOB.fetchSubProduct();
            ApzCOB.launchMicroApp('Luc', 'LUCBase', 'APZCBO__BaseScreens__BaseDIV', '');
        } else {
            ApzCOB.showNewCommonErrorModal("Failed to fetch Application data!");
            apz.stopLoader();
        }
    } catch {
        ApzCOB.showNewCommonErrorModal(errMsg);
        apz.stopLoader();
    }
};
apz.app.Dashboard.fetchDisbursementApplicationCB = function(params) {
    apz.stopLoader();
    let errMsg = "Fetch Application Data Service Failed";
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            ApzCOB.updateInsessionData(params);
            ApzCOB.launchMicroApp('DBkitG', 'DBbase', `${gAppId}__BaseScreens__BaseDIV`, ' ');
        } else {
            ApzCOB.showNewCommonErrorModal(errMsg);
        }
    } catch (e) {
        ApzCOB.showNewCommonErrorModal(errMsg);
    }
}
apz.app.Dashboard.fetchSanctionApplicationCB = function(params) {
    apz.stopLoader();
    let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__FetchApplication_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__FetchApplication_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__FetchApplication_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            const { CoApplicantCustomerId } = gApzCOB.userDetails;
            const coAppCBInfo = inSessionStore.cibilDetailsWrapperList.find(cb => Number(cb.cibilDetails.custDtlId) === Number(CoApplicantCustomerId)) || {};
            if (!apz.isObjectEmpty(coAppCBInfo)) {
                ApzCOB.launchMicroApp('Sanct', 'DeviationSanctBase', `${gAppId}__BaseScreens__BaseDIV`, window.dashTaskData);
            } else {
                ApzCOB.fnDisplayMsg("Co-Applicant CB details not found.!", "E");
            }
        }
    } catch {
        apz.stopLoader();
    }
}
apz.app.Dashboard.updatePaginationControls = function(dashboardName, status) {
    totalRecords = window.storeTypeCount;
    let totalPages = Math.ceil(totalRecords / pageSize);
    if (apz.deviceType === "WEB") {
        $("#" + DashboardScrId + "webPageInputbox").val(currentPage);
        $("#" + DashboardScrId + "webPageInputbox").prop('disabled', true);
        $("#" + DashboardScrId + "webPrevBtn").prop('disabled', currentPage === 1);
        $("#" + DashboardScrId + "webNextBtn").prop('disabled', currentPage >= totalPages);
        $("#" + DashboardScrId + "webPage").text("Page " + currentPage + " of " + totalPages);
        document.getElementById(DashboardScrId + 'ct_lst_4').scrollTop = 0;
    } else {
        $("#" + DashboardScrId + "tabPageInputbox").val(currentPage);
        $("#" + DashboardScrId + "tabPageInputbox").prop('disabled', true);
        $("#" + DashboardScrId + "tabPrevBtn").prop('disabled', currentPage === 1);
        $("#" + DashboardScrId + "tabNextBtn").prop('disabled', currentPage >= totalPages);
        $("#" + DashboardScrId + "tabPage").text("Page " + currentPage + " of " + totalPages);
        document.getElementById(DashboardScrId + 'ct_lst_11').scrollTop = 0;
    }
}
apz.app.Dashboard.goToNextPage = function(dashboardName, type) {
    let totalPages = Math.ceil(window.storeTypeCount / pageSize);
    if (currentPage < totalPages) {
        currentPage++;
        apz.app.BaseScreens.fetchRoleData(dashboardName, type, this, window.currentPage, "next");
    }
}
apz.app.Dashboard.goToPreviousPage = function(dashboardName, type) {
    if (currentPage > 1) {
        currentPage--;
        apz.app.BaseScreens.fetchRoleData(dashboardName, type, this, window.currentPage, "prev");
    }
}
