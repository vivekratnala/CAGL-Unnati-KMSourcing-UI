$(`#${DashboardScrId}masterSearch`).keypress(function(e) {
    if (e.which === 13) {
        $(`#${DashboardScrId}el_icn_6`).click();
    }
});
$(`#Dashbo__dashboard__searchHOM`).on('keydown', function (e) {
    if (e.key === 'Enter') {
        e.preventDefault();
        apz.app.Dashboard.masterSearchInpData();
    }
});

