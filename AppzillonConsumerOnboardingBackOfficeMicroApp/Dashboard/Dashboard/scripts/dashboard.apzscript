    //ApzCOB.fnDisplayMsg(apz.lits.Dashbo[apz.language].LIT_HOMESCREENMSG, "C", apz.app.Dashboard.LaunchDashboardCB);
    if ($('#Reside__ResPinCode__' + "ResidentialPinCodeModal").is(':visible')) {
        ApzCOB.toggleModal(ResiDenPinCDScrId + "ResidentialPinCodeModal");
    }
    if ($('.backdrop').hasClass('in')) {
        apz.toggleSidebar();
    }
    document.getElementById('APZCBO__BaseScreens__BaseDIV').classList.remove('verify_approve');
};
apz.app.Dashboard.LaunchDashboardCB = function(params) {
    if (params.choice === true) {
        $("#" + BaseScrId + "footerbtnRow").addClass('sno');
        $("#" + BaseScrId + "BaseDIV").removeClass('sno');
        ApzCOB.launchMicroApp('Dashbo', 'dashboard', 'APZCBO__BaseScreens__BaseDIV', '');
    }
};
apz.app.Dashboard.Setpassword = function() {
    ApzCOB.launchMicroApp('ChgPas', 'SetPassword', gAppId + '__BaseScreens__BaseDIV', gApzCOB.LoggedInUserDetails.loginResponse.userDet.id);
    $("#" + BaseScrId + "headerText").removeClass('sno');
};
apz.app.Dashboard.setScreenType = function() {
    window.clickList = false;
    var screenType;
    var applicationStatus = gApzCOB.requestNodes.applicationMaster.applicationStatus;
    switch (applicationStatus) {
        case "INPROGRESS":
            window.currentApplication = "InProgress";
            screenType = "InProgress";
            break;
        case "PENDING":
            window.currentApplication = "Approvals";
            screenType = "Approvals";
            break;
        case "REJECTED":
            window.currentApplication = "Rejected";
            screenType = "Rejected";
            break;
        case "APPROVED":
            window.currentApplication = "Completed";
            screenType = "Completed";
            break;
        case "PUSHBACK":
        case "CAPUSHBACK":
        case "IPUSHBACK":
            window.currentApplication = "Pushback";
            screenType = "Pushback";
            break;
        case "BCMPI":
            window.currentApplication = "PendingCreditAssesment";
            screenType = "PendingCreditAssesment";
            break;
        default:
            break;
    }
    return screenType;
};
//Fetch products Service
apz.app.Dashboard.FetchProducts = function() {
    var req = {
        "appId": gAppId,
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "FetchProducts", "N", "N", req, false, apz.app.Dashboard.FetchProductsCB);
};
//Fetch products Service Callback
apz.app.Dashboard.FetchProductsCB = function(params) {
    apz.stopLoader();
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            var ifaceName = ApzCOB.GetInterfaceResMap(params);
            var response = JSON.parse(params.res[ifaceName].apiResponse.ResponseBody.responseObj);
            apz.data.scrdata.Select__IpaintProduct_Res = {};
            response.forEach(function(k, l) {
                Object.getOwnPropertyNames(CommSelectProduct).forEach(function(el) {
                    if (el.split('~')[0] === k.productGroupCode) {
                        //response[l]['Image'] = {}
                        response[l]['Image'] = el.split('~')[1];
                    }
                })
            })
            if (apz.isNull(apz.data.scrdata.Dashbo__PaintData_Res) || apz.data.scrdata.Dashbo__PaintData_Res.length === 0) {
                apz.data.scrdata.Dashbo__PaintData_Res = {};
                apz.data.scrdata.Dashbo__PaintData_Res.Products = [];
                apz.data.scrdata.Dashbo__PaintData_Res.ViewAllProducts = [];
                // var lobj = {};
                // lobj.productGroupCode = 'ALL'
                // apz.data.scrdata.Dashbo__PaintData_Res.Products.push(lobj);
                response.filter(function(el) {
                    var obj = {};
                    obj.productGroupCode = el.productGroupCode;
                    apz.data.scrdata.Dashbo__PaintData_Res.Products.push(obj)
                    apz.data.scrdata.Dashbo__PaintData_Res.ViewAllProducts.push(obj)
                })
            }
            // apz.store('PRODUCTS', apz.data.scrdata.Dashbo__PaintData_Res.Products)
            apz.data.scrdata.Select__IpaintProduct_Res = response;
            apz.data.loadData('IpaintProduct', apz.currAppId);
            apz.data.loadData('PaintData', 'Dashbo');
            $('#' + DashboardScrId + 'dashProductList_row_0').click();
            $('#' + DashboardScrId + 'dashProductList_row_0').addClass('active');
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_TECHNICALDIFF"), "E");
    }
};
apz.app.Dashboard.selectedLoanProduct = async function(pthis) {
    isNotLoginCB = true;
    dashBoardKey = '';
    var selProd = pthis.textContent;
    let selKey = DASHBOARD_TABS.filter(id => id.productType === selProd)[0].key;
    if (selKey == '1') {
        window.ApplicationType = 'NEW';
        $(`#${DashboardScrId}LoanProductsList_row_0`).addClass('active');
        $(`#${DashboardScrId}LoanProductsList_row_1`).removeClass('active');
    } else if (selKey == '2') {
        window.ApplicationType = 'RENEWAL';
        $(`#${DashboardScrId}LoanProductsList_row_1`).addClass('active');
        $(`#${DashboardScrId}LoanProductsList_row_0`).removeClass('active');
    }
    await ApzCOB.launchMicroApp('Dashbo', 'dashboard', 'APZCBO__BaseScreens__BaseDIV', '');
    // apz.app.BaseScreens.fetchRole();
}
apz.app.Dashboard.selectedProduct = function(pthis) {
    LoadedSuccessfully = false;
    apz.startLoader();
    window.selectedDashboProduct = $(pthis).text();
    $("#" + DashboardScrId + 'dashProductList').find('li').removeClass('active');
    $(pthis).parent().parent().addClass('active');
    apz.app.Dashboard.filterByProducts(window.selectedDashboProduct);
    apz.app.Dashboard.LoadDefaultWidgets();
    if (!LoadedSuccessfully) {
        $("#" + DashboardScrId + 'dashProductList').find('li').addClass('active');
        $(pthis).parent().parent().removeClass('active');
    }
    //apz.stopLoader();
    apz.app.Dashboard.callServiceCheck();
};
apz.app.Dashboard.filterByProducts = function(product) {
    if (count === 0) {
        var indexVal = slectedProductsArr.findIndex(function(e) {
            return e === product;
        })
        if (indexVal < 0) {
            slectedProductsArr.push(product)
        } else {
            slectedProductsArr.splice(indexVal, 1);
        }
        count++;
    } else {
        count = 0
    }
    LoadedSuccessfully = true;
};
apz.app.Dashboard.callServiceCheck = function(product) {
    if (window.selectedDashboProduct === 'COLLECTION') {
        var req = {
            "apiRequest": {
                "appId": gAppId,
                "requestObj": {
                    "appId": gAppId,
                }
            }
        }
        ApzCOB.serverBuildParam(gAppId, "CollectionServiceCheck", "N", "N", req, false, apz.app.Dashboard.callServiceCheckCB);
    } else {
        apz.stopLoader();
    }
};
apz.app.Dashboard.callServiceCheckCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
        } else {
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_SERVICE_DOWN"), "E");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_SERVICE_DOWN"), "E");
    }
};
apz.app.Dashboard.refreshDashBoard = function() {
    apz.startLoader()
    ApzCOB.fetchDashboard();
}
apz.app.Dashboard.showDashboardStats = function() {
    if (!apz.isNull(ApplicationType)) {
        let filteredDashBoardData = DASHBOARD_COUNT_DATA.filter((dash) => {
            return dash.product === ApplicationType
        })
        if (filteredDashBoardData.length > 0) {
            window.DASHBOARD_WIDGETS_DATA = filteredDashBoardData[0].dashboardData;
            if (!ApzCOB.isObjEmpty(DASHBOARD_WIDGETS_DATA)) {
                let dashBoardCounts = [];
                for (let data in DASHBOARD_WIDGETS_DATA) {
                    if (!apz.isNull(DASHBOARD_WIDGETS_DATA[data].map.value.myArrayList)) {
                        dashBoardCounts.push({
                            'key': data,
                            'order': DASHBOARD_WIDGETS_DATA[data].map.order,
                            'count': DASHBOARD_WIDGETS_DATA[data].map.value.myArrayList.length
                        })
                    }
                }
                dashBoardCounts = dashBoardCounts.sort((a, b) => a.order - b.order);
                if (dashBoardCounts.length > 0) {
                    let selectElementID = 'Dashbo__dashboard__dashboardCountItem_0';
                    let parentDiv = $('#Dashbo__dashboard__dashboard_count');
                    dashBoardCounts.forEach((dash, index) => {
                        let currentIndex = parseInt(index) + 1;
                        ApzCOB.cloneDashboardDivs(selectElementID, parentDiv, currentIndex);
                        $(`#Dashbo__dashboard__dashboardCountItem_${currentIndex} .dashCountItemLabel label.pri`).text(dash.key.replaceAll('_', ' '));
                        $(`#Dashbo__dashboard__dashboardCountItem_${currentIndex} .dashCountItemCount label`).text(dash.count);
                        $(`#Dashbo__dashboard__dashboardCountItem_${currentIndex} .dashCountItemPanel`).attr('onClick',`apz.app.Dashboard.DashBoardCountClick('${dash.key}')`)
                        $('#Dashbo__dashboard__dashboardCountItem_' + currentIndex).removeClass('sno');
                    })
                }
                apz.stopLoader();
                if (IS_DASHBOARD_COUNT_ENABLED.indexOf(ApplicationType) < 0) {
                    IS_DASHBOARD_COUNT_ENABLED.push(ApplicationType)
                }
                $('#Dashbo__dashboard__showDashBoardRow').addClass('sno');
                $('#Dashbo__dashboard__dashboard_count').removeClass('sno');
            }
        } else {
            apz.startLoader()
            ApzCOB.fetchDashboard();
        }
    }
}
apz.app.Dashboard.showNewDashboardStats = function() {
    if (!apz.isNull(ApplicationType)) {
        // let lovDets = gLovs.filter(item => item.lovName === 'DASHBOARDORDER');
        // let dashboardCountData = JSON.parse(lovDets[0].lovDtls);
        let filteredDashBoardData = DASHBOARDORDER[0];
        let dashboardCountStore = '';
        if (window.fetchRoleCount !== undefined) {
            dashboardCountStore = window.fetchRoleCount;
        } else {
            dashboardCountStore = window.dataCountDashboard;
        }
        if (window.isFilterApplied) {
            window.isFilterApplied = false;
            dashboardCountStore = window.dataCountDashboard;
        }
        if (!ApzCOB.isObjEmpty(filteredDashBoardData)) {
            if (!ApzCOB.isObjEmpty(dashboardCountStore)) {
                let dashBoardNewCounts = Object.keys(dashboardCountStore).filter(key => filteredDashBoardData.hasOwnProperty(key)).map(key => {
                    var meta = filteredDashBoardData[key];
                    return {
                        name: meta.name,
                        count: dashboardCountStore[key],
                        order: parseInt(meta.order, 10)
                    };
                })
                dashBoardNewCounts = dashBoardNewCounts.sort((a, b) => a.order - b.order);
                window.storeDashboardCount = dashBoardNewCounts;
                if (dashBoardNewCounts.length > 0) {
                    let selectElementID = 'Dashbo__dashboard__dashboardCountItem_0';
                    let parentDiv = $('#Dashbo__dashboard__dashboard_count');
                    dashBoardNewCounts.forEach((dash, index) => {
                        let currentIndex = index + 1;
                        ApzCOB.cloneDashboardDivs(selectElementID, parentDiv, currentIndex);
                        $(`#Dashbo__dashboard__dashboardCountItem_${currentIndex} .dashCountItemLabel label.pri`).text(dash.name=== "Post disbursement " ? "LUC" : dash.name);
                        $(`#Dashbo__dashboard__dashboardCountItem_${currentIndex} .dashCountItemCount label`).text(dash.count);
                        let statusKey = 'PENDING';
                        if (dash.name === 'Deviation/re-assesment') {
                            statusKey = 'CA_DEVIATION';
                        } else if(dash.name.trim() === "Post disbursement") {
                            statusKey = 'LUC';
                        }
                        let onClickHandler = '';
                        if (dash.name === 'Not actioned leads') {
                            onClickHandler = "apz.app.Dashboard.loadUnttendedData(this,'UNATTENDED_LEADS')";
                        } else if (dash.name === 'Overall leads') {
                            onClickHandler = '';
                        } else {
                            onClickHandler = (dash.count > 0) ?
                                `apz.app.BaseScreens.fetchRoleData('${dash.name}', '${statusKey}', this, "1", 'initial'); apz.app.Dashboard.handleActiveCard(this);` :
                                `apz.app.Dashboard.handleNorecord('${dash.name}'); apz.app.Dashboard.handleActiveCard(this);`;
                        }
                        $(`#Dashbo__dashboard__dashboardCountItem_${currentIndex}`).attr('onClick', onClickHandler);
                        $(`#Dashbo__dashboard__dashboardCountItem_${currentIndex}`).removeClass('sno');
                    });
                }
                // apz.stopLoader();
                if (IS_DASHBOARD_COUNT_ENABLED.indexOf(ApplicationType) < 0) {
                    IS_DASHBOARD_COUNT_ENABLED.push(ApplicationType)
                }
                $('#Dashbo__dashboard__showDashBoardRow').addClass('sno');
                $('#Dashbo__dashboard__dashboard_count').removeClass('sno');
                $("li[onclick]").css("cursor", "pointer");
                if (!recordClicked) {
                    let roleToDashboardName = {
                        'KM': 'Sourcing stage',
                        'BM': 'BM sourcing approval',
                        'BCM': 'Deviation/re-assesment',
                        'ACM': 'Sanction',
                        'AM': 'Sanction',
                        'RM': 'Sanction',
                        'DM': 'Sanction'
                    };
                    let userRole = gApzCOB.LoggedInUserDetails.loginResponse.addInfo1;
                    let dashboardName = roleToDashboardName[userRole];
                    if (dashboardName) {
                        let matchingItem = dashBoardNewCounts.find(item => item.name === dashboardName);
                        if (matchingItem) {
                            let elementId = 'Dashbo__dashboard__dashboardCountItem_' + matchingItem.order;
                            document.getElementById(elementId)?.click();
                        }
                    }
                } else {
                    apz.app.BaseScreens.fetchRoleData(selectedTitle, SELECTED_SUB_STATUS, '', '1', 'progress');
                    var lastId = StoreNavData[StoreNavData.length - 1].id;
                    $("[id^='Dashbo__dashboard__dashboardCountItem_']").removeClass('active');
                    document.getElementById(lastId).classList.add('active');
                }
            }
        } else {
            apz.startLoader()
            ApzCOB.fetchDashboard();
        }
    }
};
