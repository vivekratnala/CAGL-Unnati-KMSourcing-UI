apz.app.Dashboard.PaintDashboardTabs = function() {
    apz.data.scrdata.Dashbo__PaintLoanProducts_Res = {};
    apz.data.scrdata.Dashbo__PaintLoanProducts_Res.LoanProducts = [];
    apz.data.scrdata.Dashbo__PaintLoanProducts_Res.LoanProducts = DASHBOARD_TABS.map(a => ({...a}));
    apz.data.loadData('PaintLoanProducts', 'Dashbo');
    if (ApplicationType === 'NEW') {
        $('#' + DashboardScrId + 'LoanProductsList_row_0').addClass('active');
        $(`#${DashboardScrId}LoanProductsList_row_1`).removeClass('active');
    } else {
        $('#' + DashboardScrId + 'LoanProductsList_row_1').addClass('active');
        $(`#${DashboardScrId}LoanProductsList_row_0`).removeClass('active');
    }
    if (!apz.isNull(DASHBOARD_CONFIG)) {
        if (DASHBOARD_CONFIG.SHOW_DASHBOARD) {
            let branchId = gApzCOB.LoggedInUserDetails.loginResponse.addInfo2;
            if (DASHBOARD_CONFIG.DASHBOARD_ALLOWED_BRANCH_ID.includes(branchId) || ["ACM", "AM", "DM", "RM"].some(role => gApzCOB.LoggedInUserDetails.loginResponse.addInfo1.includes(role))) {
                $('#Dashbo__dashboard__dashBoardBtn').removeClass('sno');
                $('#Dashbo__dashboard__showDashBoardRow').removeClass('sno');
            }
        }
    }
};
apz.app.Dashboard.LoadWidgets = function() {
    /*gApzCOB.FetchRole.accessPermission = "B" Both
    gApzCOB.FetchRole.accessPermission = "I" Initiator/Maker
    gApzCOB.FetchRole.accessPermission = "A" Authorizer/Checker
    gApzCOB.FetchRole.accessPermission = "VO" ViewOnly
    gApzCOB.FetchRole.accessPermission === "V" Verifier
    */
