apz.app.onLoad_ReviewConfirm = function() {
    //apz.app.BaseScreens.fetchFAQs();
    apz.app.BaseScreens.contactus();
    apz.app.BaseScreens.hideNshowbackIcon();
    apz.app.ReviewConfirm.tabsHideNshow();
    apz.app.ReviewConfirm.setStageNo();
    if (Number(gApzCOB.noOfApplicants) > 1) {
        window.itreviewconfirm = true;
        window.dontReloadRC = true;
        // ApzCOB.FetchApplication();
    }
}
apz.app.onShown_ReviewConfirm = function() {
    /*window.counter++
    if (apz.deviceType !== 'WEB' && Number(gApzCOB.noOfApplicants) > 1) {
       ApzCOB.FetchApplication();
    }*/
    if (window.isRevAndConfEdit) {
        gApzCOB.currentApplicant = window.isRevAndConfEditCustType;
    }
    apz.startLoader();
    $("#APZCBO__BaseScreens__LoanSuccTxt").text('Application Submitted Successfully!');
    if (gApzCOB.product === "CARDS") {
        $("#" + CardServiceScrId + "imageDiv").addClass('sno');
        $("#" + CardServiceScrId + "CardDiv").addClass('sno');
    }
    gApzCOB.userDetails.currentStage = 'reviewandconfirm';
    if ($('#' + BaseScrId + 'backIcon').hasClass('sno')) {
        $('#' + rvwScrId + 'subHeaderRow').addClass('var1')
    }
    window.addEventListener('scroll', function() {
        pageYOffset < document.documentElement.clientHeight ? $('#' + rvwScrId + 'toparrow').addClass('sno') : $('#' + rvwScrId +
            'toparrow').removeClass('sno');
    });
    $('#' + rvwScrId + 'collapseText').addClass('sno');
    $('#' + rvwScrId + 'pdE').trigger('click');
    $('#' + rvwScrId + 'backTotoprow').addClass('sno');
    apz.stopLoader();
    ApzCOB.showLanguageSelect();
    if (Number(gApzCOB.noOfApplicants) > 1 && gApzCOB.currentApplicant !== Number(gApzCOB.noOfApplicants) && gApzCOB.applicationType ===
        'Joint Account') {
        // $('#' + rvwScrId + 'jointRow').removeClass('sno');
        $('#' + rvwScrId + 'currentApplicantNum_txtcnt').text(gApzCOB.currentApplicant + 1);
    }
    if (gApzCOB.applicationType === 'Joint Account') {
        $('#' + rvwScrId + 'person2DetailsForm').removeClass('sno');
    } else {
        $('#' + rvwScrId + 'person2DetailsForm').addClass('sno');
    }
    apz.app.BaseScreens.HeaderFooterData();
    //currTab = inSessionStore.customerDetailsList[0].customerType;
    //if (currTab == 'Applicant') {
    //    $('#' + rvwScrId + 'custTypeLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_TYPE"))
    //    $('#' + rvwScrId + 'custIdLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_ID"))
    //    $('#' + rvwScrId + 'custNameLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_NAME"))
    //}
    if (Number(gApzCOB.noOfApplicants) > 1) {
        apz.app.ReviewConfirm.paintApplicants();
        $('#' + rvwScrId + 'applicantNameList .pri').removeClass('active');
        $('#' + rvwScrId + 'applicantNameList_row_' + (gApzCOB.currentApplicant - 1)).addClass('active');
    } else {
        apz.app.ReviewConfirm.paintAllonScreen();
    }
    var ApplicantToPaint = gApzCOB.currentApplicant - 1;
    $('#RevCof__IPaintJointNames__o__RevCof__IPaintJointNames_Res__applicantName_' + ApplicantToPaint).trigger('click');
    $('#APZCBO__BaseScreens__continue').attr('disabled', false)
    $(`#${rvwScrId}el_btn_10`).addClass('visibleHidden'); //PersonalDetails Edit btn
    ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], false);
    $(`#${BaseScrId}custIDandName`).removeClass('sno');
}
apz.app.ReviewConfirm.paintAllonScreen = function(iSingle) {
    apz.app.ReviewConfirm.tabsHideNshow();
    apz.app.ReviewConfirm.perDetails(iSingle);
    apz.app.ReviewConfirm.empDetails();
    apz.app.ReviewConfirm.LoadCardsFunctions();
    /*if (gApzCOB.product === "CARDS") {
        if (window.pendingApplication) {
            apz.app.ReviewConfirm.downloadFileFromserverforcards();
            apz.app.ReviewConfirm.paindetcardSevice();
        } else {
            apz.app.ReviewConfirm.cardSevice();
        }
    }*/
    apz.app.BaseScreens.fetchNominee();
    apz.app.ReviewConfirm.fatcaDetails();
    apz.app.ReviewConfirm.crsDetails();
    apz.app.ReviewConfirm.uploadDocs(iSingle);
    //apz.app.ReviewConfirm.configureFields();
    // apz.app.ReviewConfirm.perDetails(iSingle);
    if (apz.deviceType === "ANDROID" && (gApzCOB.product === "LOAN" || gApzCOB.product === "CARDS")) {
        apz.app.BaseScreens.HeaderFooterData();
    }
    apz.app.ReviewConfirm.bankFac();
    apz.app.ReviewConfirm.nomineeDetails();
    apz.app.ReviewConfirm.paintLoanDetails();
    //apz.app.ReviewConfirm.paintEMIDetails();
    //apz.app.ReviewConfirm.paintCreditDetails();
    $('#' + rvwScrId + 'backTotoprow').addClass('sno');
    apz.stopLoader();
    ApzCOB.showLanguageSelect();
    if (gApzCOB.requestNodes.customerDetailsList.length > 1 && gApzCOB.product === 'CASA') {
        payloadno = gApzCOB.requestNodes.customerDetailsList.length - 1;
    }
    if (gApzCOB.product === 'LOAN' && gApzCOB.ExistingCustomer && window.pendingApplication) {
        customerDetails1 = gApzCOB.requestNodes.customerDetailsList.length === 1 ? gApzCOB.requestNodes.customerDetailsList[0].payload : gApzCOB
            .requestNodes.customerDetailsList[1].payload;
    } else {
        customerDetails1 = gApzCOB.requestNodes.customerDetailsList.length === 1 ? gApzCOB.requestNodes.customerDetailsList[0].payload : gApzCOB
            .requestNodes.customerDetailsList[payloadno].payload;
    }
    var mstatus1 = customerDetails1.maritalStatus.toLocaleLowerCase();
    if (mstatus1 !== 'married') {
        $('#' + rvwScrId + 'RevSpouseNameDiv').addClass('sno')
    }
    if (parseInt(gApzCOB.noOfApplicants) === gApzCOB.requestNodes.customerDetailsList.length && window.istrueyes) {
        $.each(gApzCOB.requestNodes.customerDetailsList, function(index, values) {
            customerNames = customerNames + values.customerName + ', '
        })
        window.customerNamess = customerNames.slice(0, -2)
        window.istrueyes = false;
    }
    // LoanDetails Hide and Show
    $(`#${rvwScrId}el_btn_55`).removeClass('visibleHidden'); //Co-App CB Report Issue Fix
    /*if (currTab.toLowerCase() === "applicant") {
        $(`#${rvwScrId}el_btn_55`).removeClass('visibleHidden');
    } else {
        $(`#${rvwScrId}el_btn_55`).addClass('visibleHidden');
    }*/
}
var expandType = ""
apz.app.ReviewConfirm.setStageNo = function() {
    if (!revAndConf) {
        window.revConfBaseRow = baseRow - 1;
        window.revConfSTAGENO = STAGE_NO - 1;
    }
}
apz.app.ReviewConfirm.hideAndShowTabs = function(pthis, params) {
    var selectedTabId = $('#' + pthis.id + '_ul').parent().parent().parent().parent()[0]['id'];
    for (var i = 0; i < $(rvwScrId + 'DetailsForm').children().length; i++) {
        var id = $('#' + rvwScrId + 'DetailsForm').children()[i]['id'];
        $('#' + id).removeClass('active')
    }
    if (expandType === "") {
        if ($('#' + selectedTabId).hasClass('active')) {
            $('#' + selectedTabId).removeClass('active');
            if (params === "Nominee") {
                $('#' + rvwScrId + 'nomineeDetrow').removeClass('active');
            }
            if (params === "Crs") {
                $('#' + rvwScrId + 'crsDetailsRow').removeClass('active');
            }
            if (params === "fatca") {
                $('#' + rvwScrId + 'fatcaDetRow').removeClass('active');
            }
            if (params === "docs") {
                $('#' + rvwScrId + 'docDetrow').removeClass('active');
            }
            if (params === "Card") {
                $('#' + rvwScrId + 'cardServiceDiv').removeClass('active');
            }
            if (params === "loanDetails") {
                $('#' + rvwScrId + 'loanDetailsDiv').removeClass('active');
            }
            if (params === "EMIDetails") {
                $('#' + rvwScrId + 'EMIDetailsDiv').removeClass('active');
            }
            if (params === "CreditDetails") {
                $('#' + rvwScrId + 'CreditDetailsDiv').removeClass('active');
            }
            if (params === "deposit") {
                $('#' + rvwScrId + 'depositDetRow').removeClass('active');
            }
        } else {
            $('#' + rvwScrId + 'personalDetDiv').removeClass('active');
            $('#' + rvwScrId + 'empDetDiv').removeClass('active');
            $('#' + rvwScrId + 'uploadDoc').removeClass('active');
            $('#' + rvwScrId + 'bankingDetRow').removeClass('active');
            $('#' + rvwScrId + 'nomineeDetrow').removeClass('active');
            $('#' + rvwScrId + 'docDetrow').removeClass('active');
            $('#' + rvwScrId + 'fatcaDetRow').removeClass('active');
            $('#' + rvwScrId + 'crsDetailsRow').removeClass('active');
            $('#' + rvwScrId + 'fatcaDetRow').removeClass('active');
            $('#' + rvwScrId + 'loanDetailsDiv').removeClass('active');
            $('#' + rvwScrId + 'EMIDetailsDiv').removeClass('active');
            $('#' + rvwScrId + 'CreditDetailsDiv').removeClass('active');
            $('#' + selectedTabId).addClass('active');
            if (params === "Nominee") {
                $('#' + rvwScrId + 'nomineeDetrow').addClass('active');
            }
            if (params === "Crs") {
                $('#' + rvwScrId + 'crsDetailsRow').addClass('active');
            }
            if (params === "fatca") {
                $('#' + rvwScrId + 'fatcaDetRow').addClass('active');
            }
            if (params === "docs") {
                $('#' + rvwScrId + 'docDetrow').addClass('active');
            }
            if (params === "Card") {
                $('#' + rvwScrId + 'cardServiceDiv').addClass('active');
            }
            if (params === "loanDetails") {
                $('#' + rvwScrId + 'loanDetailsDiv').addClass('active');
            }
            if (params === "EMIDetails") {
                $('#' + rvwScrId + 'EMIDetailsDiv').addClass('active');
            }
            if (params === "CreditDetails") {
                $('#' + rvwScrId + 'CreditDetailsDiv').addClass('active');
            }
            if (params === "deposit") {
                $('#' + rvwScrId + 'depositDetRow').addClass('active');
            }
        }
    }
    if (expandType === "expand") {
        $('#' + rvwScrId + 'backTotoprow').removeClass('sno')
        $('#' + selectedTabId).addClass('active');
        $('#' + rvwScrId + 'nomineeDetrow').addClass('active');
        $('#' + rvwScrId + 'docDetrow').addClass('active');
        $('#' + rvwScrId + 'fatcaDetRow').addClass('active');
        $('#' + rvwScrId + 'crsDetailsRow').addClass('active');
        $('#' + rvwScrId + 'fatcaDetRow').addClass('active');
        $('#' + rvwScrId + 'collapseText').removeClass('sno');
        $('#' + rvwScrId + 'cardServiceDiv').addClass('active');
        $('#' + rvwScrId + 'loanDetailsDiv').addClass('active');
        $('#' + rvwScrId + 'EMIDetailsDiv').addClass('active');
        $('#' + rvwScrId + 'CreditDetailsDiv').addClass('active');
        $('#' + rvwScrId + 'depositDetRow').addClass('active');
        $('#' + rvwScrId + 'expandText').addClass('sno');
    }
    if (expandType === "collapse") {
        $('#' + rvwScrId + 'backTotoprow').addClass('sno')
        $('#' + selectedTabId).removeClass('active');
        $('#' + rvwScrId + 'nomineeDetrow').removeClass('active');
        $('#' + rvwScrId + 'docDetrow').removeClass('active');
        $('#' + rvwScrId + 'fatcaDetRow').removeClass('active');
        $('#' + rvwScrId + 'crsDetailsRow').removeClass('active');
        $('#' + rvwScrId + 'fatcaDetRow').removeClass('active');
        $('#' + rvwScrId + 'depositDetRow').removeClass('active');
        $('#' + rvwScrId + 'collapseText').addClass('sno');
        $('#' + rvwScrId + 'cardServiceDiv').removeClass('active');
        $('#' + rvwScrId + 'loanDetailsDiv').removeClass('active');
        $('#' + rvwScrId + 'EMIDetailsDiv').removeClass('active');
        $('#' + rvwScrId + 'CreditDetailsDiv').removeClass('active');
        $('#' + rvwScrId + 'expandText').removeClass('sno');
    }
}
apz.app.ReviewConfirm.expandCollapse = function(params) {
    expandType = params;
    $('#' + rvwScrId + 'pdE').trigger('click')
    $('#' + rvwScrId + 'edE').trigger('click')
    $('#' + rvwScrId + 'niE').trigger('click')
    $('#' + rvwScrId + 'bfE').trigger('click')
    $('#' + rvwScrId + 'faE').trigger('click')
    $('#' + rvwScrId + 'crsE').trigger('click')
    $('#' + rvwScrId + 'diE').trigger('click')
    expandType = "";
}
