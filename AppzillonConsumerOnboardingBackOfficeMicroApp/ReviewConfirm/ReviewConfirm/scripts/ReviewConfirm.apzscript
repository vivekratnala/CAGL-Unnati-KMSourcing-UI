apz.app.ReviewConfirm.goToTop = function() {
    if (apz.deviceType !== "WEB") {
        window.scroll(0, 0);
    } else {
        ApzCOB.scrollToTop();
    }
}
apz.app.ReviewConfirm.tabsHideNshow = function() {
    STAGES.forEach(function(m, n) {
        ConfigureScrJson.forEach(function(i, k) {
            if (i.confParamName === m.split('~')[0].toUpperCase()) {
                $('#' + rvwScrId + i.reviewNconfirm).removeClass("sno");
            }
        })
    })
}
apz.app.ReviewConfirm.perDetails = function(iSingle) {
    var index = 0;
    var customerDetails = [];
    if (!apz.isNull(gApzCOB.requestNodes.customerDetailsList) && gApzCOB.requestNodes.customerDetailsList.length > 0) {
        gApzCOB.requestNodes.customerDetailsList.findIndex(function(e) {
            if (!apz.isNull(e.custDtlId)) {
                return e.custDtlId === window.latestcustDtlId
            } else {
                return index;
            }
        })
        /*customerDetails = iSingle === 'single' ? gApzCOB.requestNodes.customerDetailsList[0].payload : gApzCOB.requestNodes.customerDetailsList[gApzCOB.currentApplicant -
            1].payload;*/
        if (gApzCOB.product === 'LOAN' && gApzCOB.ExistingCustomer && window.pendingApplication) {
            if (gApzCOB.requestNodes.customerDetailsList.length === 1) {
                index = 0;
            } else {
                index = 1;
            }
        }
        if (gApzCOB.requestNodes.customerDetailsList.length > 1 && gApzCOB.product === 'CASA') {
            index = gApzCOB.requestNodes.customerDetailsList.length - 1;
        }
        currTab = gApzCOB.requestNodes.customerDetailsList[index].customerType;
        if (currTab == 'Applicant') {
            ['relationwithAppDiv'].hide();
            ['nameasKYCDiv', 'RevGenderDiv', 'coApplInsurDiv', 'LoanDetailsHideShow', 'BankDetailsDiv'].show();
            $('#' + rvwScrId + 'custTypeLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_TYPE"))
            $('#' + rvwScrId + 'custIdLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_ID"))
            $('#' + rvwScrId + 'custNameLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_NAME"))
        } else {
            ['nameasKYCDiv', 'relationwithAppDiv', 'RevGenderDiv'].show();
            ['coApplInsurDiv', 'LoanDetailsHideShow', 'BankDetailsDiv'].hide();
            $('#' + rvwScrId + 'custTypeLabel').text(ApzCOB.getDescfromLitCode("LIT_RC_LBL_CUST_TYP"))
            $('#' + rvwScrId + 'custIdLabel').text(ApzCOB.getDescfromLitCode("LIT_RC_LBL_CUSTID"))
            $('#' + rvwScrId + 'custNameLabel').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_LBL_TXT_CUSTOMERNAME"))
        }
        customerDetails = gApzCOB.requestNodes.customerDetailsList.length === 1 ? gApzCOB.requestNodes.customerDetailsList[0].payload : gApzCOB.requestNodes.customerDetailsList[index].payload;
        customerDetailsNpl = gApzCOB.requestNodes.customerDetailsList.length === 1 ? gApzCOB.requestNodes.customerDetailsList[0] : gApzCOB
            .requestNodes.customerDetailsList[index];
        if (!apz.isNull(customerDetails.title)) {
            $('#' + rvwScrId + 'title').text(customerDetails.title);
        }
        var personName = apz.isNull(gApzCOB.requestNodes.customerDetailsList[index]) ? gApzCOB.userDetails.userName : gApzCOB.requestNodes
            .customerDetailsList[index]["customerName"];
        
        /*Disability Status*/
        var disFields = ['typeOfImpairDiv', 'udidDiv', 'percentImpDiv'];
        
       //var currCusDtlId = ApzCOB.getCustDetailID(gApzCOB.currentApplicant === 1 ? 'Applicant' : 'Co-App');
       let currCusDtlId = gApzCOB.requestNodes.customerDetailsList[index].custDtlId;
       var curindex = inSessionStore.customerDetailsList.findIndex(el => el.custDtlId === currCusDtlId);
        
        var disSts = inSessionStore.customerDetailsList[curindex].payload.isDisabled;
        var payloaddata = inSessionStore.customerDetailsList[curindex].payload;
        if (payloaddata.UDID) {
            if (disSts == 'Y') {
                disFields.show();
                $(`#${rvwScrId}appDisaSts`).text('Yes');
                var typImpair = inSessionStore.customerDetailsList[curindex].payload.disabilityList;;
                 typImpair = typImpair.join(", ");
                 var udidno = 
                $(`#${rvwScrId}typeofImpair`).text(typImpair);
                $(`#${rvwScrId}udid`).text(inSessionStore.customerDetailsList[curindex].payload.UDID);
                $(`#${rvwScrId}percentImp`).text(inSessionStore.customerDetailsList[curindex].payload.disabilityPercentage);
                
            }else if (disSts == 'N') {
                disFields.hide();
                $(`#${rvwScrId}appDisaSts`).text('No');
                
            }
        }else
        {
            ['DisabilityDetailsDiv'].hide();
        }
            
    
        /* if (apz.isNull(iSingle === 'single' ? gApzCOB.requestNodes.customerDetailsList[0] : gApzCOB.requestNodes.customerDetailsList[gApzCOB.currentApplicant -
                 1])) {
             personName = gApzCOB.userDetails.userName;
         } else {
             personName = iSingle === 'single' ? gApzCOB.requestNodes.customerDetailsList[0].customerName : gApzCOB.requestNodes.customerDetailsList[
                 gApzCOB.currentApplicant - 1].customerName;
         }*/
        $('#' + rvwScrId + 'custType').text(apz.isNull(customerDetails.gkCustomerType) ? "---" : customerDetails.gkCustomerType);
        $('#' + rvwScrId + 'custId').text(apz.isNull(customerDetails.custId) ? "---" : customerDetails.custId);
