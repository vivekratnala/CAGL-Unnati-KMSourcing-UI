    if (gApzCOB.product === 'LOAN') {
        if (!apz.isNull(gApzCOB.requestNodes.loanDetails.autoEmiAccount)) {
            $('#' + rvwScrId + 'EMIAmount').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(LOAN_OBJ.monthlyEmi));
            $('#' + rvwScrId + 'EMIDebitDate').text(LOAN_OBJ.emiDate);
            $('#' + rvwScrId + 'EMIFromAccount').text(LOAN_OBJ.autoEmiAccount);
        }
