apz.app.ReviewConfirm.nomineeDetails = function() {
    if (!apz.isNull(apz.data.scrdata.NomDet__FetchNominee_Res) && apz.data.scrdata.NomDet__FetchNominee_Res.length !== 0) {
        var nomineeName = [],
            nomineeRel = [];
        apz.data.scrdata.RevCof__IPaintData_Res = {}
        for (var i = 0; i < apz.data.scrdata.NomDet__FetchNominee_Res.length; i++) {
            nomineeName.push(apz.data.scrdata.NomDet__FetchNominee_Res[i].nomineeName)
            nomineeRel.push(apz.data.scrdata.NomDet__FetchNominee_Res[i].nomineeRelationship);
        }
        var nomineeDetails = []
        $.each(nomineeName, function(a, b) {
            var obj = {
                "nomineeName": nomineeName[a],
                "nomineeRelation": nomineeRel[a]
            }
            nomineeDetails.push(obj);
        })
        $('#' + rvwScrId + 'nomineeHeaderRow').removeClass('sno');
        $('#' + rvwScrId + 'nomineeListRow').removeClass('sno');
        $('#' + rvwScrId + 'noNomineeRow').addClass('sno');
        apz.data.scrdata.RevCof__IPaintData_Res = apz.data.scrdata.NomDet__FetchNominee_Res
        $.each(apz.data.scrdata.RevCof__IPaintData_Res, function(a, b) {
            apz.data.scrdata.RevCof__IPaintData_Res[a].nomineeDob = ApzCOB.dateformatter(b.nomineeDob, 'd M Y')
            if (apz.isNull(b.guardianName)) {
                apz.data.scrdata.RevCof__IPaintData_Res[a].guardianName = "N/A"
            }
            if (apz.isNull(b.nomineeMobile)) {
                apz.data.scrdata.RevCof__IPaintData_Res[a].nomineeMobile = "---"
            }
        })
        apz.data.loadData("IPaintData", apz.currAppId);
    } else {
        $('#' + rvwScrId + 'nomineeHeaderRow').addClass('sno');
        $('#' + rvwScrId + 'nomineeListRow').addClass('sno');
        $('#' + rvwScrId + 'noNomineeRow').removeClass('sno');
    }
}
apz.app.ReviewConfirm.empDetails = function() {
     let custDetails = [];
    if (currTab === "Applicant") {
        custDetails = gApzCOB.requestNodes.customerDetailsList.filter(
        cust => cust.customerType.toLowerCase() === 'applicant');
    } else {
        custDetails = gApzCOB.requestNodes.customerDetailsList.filter(
        cust => cust.customerType.toLowerCase() !== 'applicant');
    }
    if (custDetails.length > 0) {
        const occupation = custDetails[0].payload.occupation;
        if (occupation === 'Salaried') {
            $('#' + rvwScrId + 'el_txt_268').text('Office Address Details');
        } else {
            $('#' + rvwScrId + 'el_txt_268').text('Business Address Details');
        }
    }
    if (!apz.isNull(gApzCOB.requestNodes.occupationDetailsWrapperList) && gApzCOB.requestNodes.occupationDetailsWrapperList.length > 0) {
        var index = gApzCOB.requestNodes.occupationDetailsWrapperList.findIndex(function(e) {
            return e.occupationDetails.custDtlId === window.latestcustDtlId
        })
        var occupationPayload = gApzCOB.requestNodes.occupationDetailsWrapperList.length === 1 ? gApzCOB.requestNodes
            .occupationDetailsWrapperList[0].occupationDetails.payload : gApzCOB.requestNodes.occupationDetailsWrapperList[index]
            .occupationDetails.payload
        //var a;
        var totalexperience = ""
        var yrs = occupationPayload.experience.split(" ")[0]
        if (yrs === "") {
            yrs = "0 years "
        } else {
            yrs = yrs + " years "
        }
        var mons = occupationPayload.experience.split(" ")[2]
        if (mons === "") {
            mons = "0 months"
        } else {
            mons = mons + " months"
        }
        totalexperience = yrs + mons;
        // var ProfOccTxt = (apz.isNull(occupationPayload.occupationType) ? "---" : occupationPayload.occupationType);
        // $('#' + rvwScrId + 'profOccu').text(ProfOccTxt);
        $('#' + rvwScrId + 'yrsOfExp').text(totalexperience);
        var DesignTxt = (apz.isNull(occupationPayload.designation) ? "---" : occupationPayload.designation);
        $('#' + rvwScrId + 'designation').text(DesignTxt);
        /*var GrossIncTxt = (apz.isNull(ApzCOB.fn_FormatAmount(occupationPayload.annualIncome / 12)) ? "---" : ApzCOB.fn_FormatAmount(occupationPayload.annualIncome / 12));*/
        if (apz.isNull(occupationPayload.grossIncome)) {
            $('#' + rvwScrId + 'grossInc').text("---");
        } else {
            var GrossIncTxt = ApzCOB.fn_FormatAmount(occupationPayload.grossIncome);
            $('#' + rvwScrId + 'grossInc').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + GrossIncTxt);
        }
        if (apz.isNull(occupationPayload.netTakeHome)) {
            $('#' + rvwScrId + 'netTakeHome').text("---");
        } else {
            var netTakeHomeTxt = ApzCOB.fn_FormatAmount(occupationPayload.netTakeHome);
            $('#' + rvwScrId + 'netTakeHome').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + netTakeHomeTxt);
        }
        var LanNoTxt = (apz.isNull(occupationPayload.officePhone) ? "---" : occupationPayload.officePhone);
        $('#' + rvwScrId + 'lanNo').text(LanNoTxt);
        var CEmailTxt = (apz.isNull(occupationPayload.officeEmail) ? "---" : occupationPayload.officeEmail);
        $('#' + rvwScrId + 'cEmail').text(CEmailTxt);
        //var OrgAddressTxt = (apz.isNull(occupationPayload.organisationAddress) ? "---" : occupationPayload.organisationAddress);
        //$('#' + rvwScrId + 'ofcAddr').text(OrgAddressTxt);
        if (!apz.isNull(window.EMP_ADDRESS && window.EMP_ADDRESS.length > 0)) {
            var a = window.EMP_ADDRESS[0]["addressDetailsList"][0]["payload"]["addressList"][0];
            var RCEmpfullAddress;
            if (a.state === ApzCOB.getDescfromLitCode("LIT_COMM_MSG_PLEASE_SELECT")) {
                RCEmpfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.pinCode;
            } else {
                RCEmpfullAddress = a.addressLine1 + ' ' + a.addressLine2 + ' ' + a.landMark + ' ' + a.city + ' ' + a.state + ' ' + a.pinCode;
            }
            $('#' + rvwScrId + 'ofcAddr').text(RCEmpfullAddress);
        }
        var CurrEmpTxt = apz.isNull(occupationPayload.employeeSince) ? "---" : occupationPayload.employeeSince;
        $('#' + rvwScrId + 'curEmpyrs').text(CurrEmpTxt);
        var EmpIdTxt = (apz.isNull(occupationPayload.employeeId) ? "---" : occupationPayload.employeeId);
        $('#' + rvwScrId + 'empId').text(EmpIdTxt);
        var EmplrTxt = (apz.isNull(occupationPayload.employer) ? "---" : occupationPayload.employer);
        $('#' + rvwScrId + 'curEmployer').text(EmplrTxt);
        $(`#${rvwScrId}modeOfIncome`).text(apz.isNull(occupationPayload.modeOfIncome) ? "---" : occupationPayload.modeOfIncome);
        $(`#${rvwScrId}streetVendor`).text(apz.isNull(occupationPayload.streetVendor) ? "---" : occupationPayload.streetVendor);
        $(`#${rvwScrId}employmentStartdate`).text(apz.isNull(occupationPayload.businessEmpStartDate) ? "---" : occupationPayload
            .businessEmpStartDate);
        $(`#${rvwScrId}employmentVintage`).text(apz.isNull(occupationPayload.businessEmpVintageYear) ? "---" : occupationPayload
            .businessEmpVintageYear);
        if (apz.isNull(occupationPayload.annualIncome)) {
            $('#' + rvwScrId + 'annualInc').text("---");
        } else {
            var AnnualIncTxt = ApzCOB.fn_FormatAmount(occupationPayload.annualIncome);
            $('#' + rvwScrId + 'annualInc').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + AnnualIncTxt);
        }
        var NatureOfBusi = (apz.isNull(occupationPayload.occupationType) ? "---" : occupationPayload.occupationType);
        if (NatureOfBusi == 'Please Select') {
            $(`#${rvwScrId}profOccu`).text("---");
        } else {
            $(`#${rvwScrId}profOccu`).text(NatureOfBusi);
        }
        var typbssEmpentTxt = (apz.isNull(occupationPayload.typeofbusiness) ? "---" : occupationPayload.typeofbusiness);
        if (typbssEmpentTxt == 'Please Select') {
            $('#' + rvwScrId + 'typbssEmpentRw').text("---");
            $('#' + rvwScrId + 'typEmpentRw').text("---");
        } else {
            $('#' + rvwScrId + 'typbssEmpentRw').text(typbssEmpentTxt);
            $('#' + rvwScrId + 'typEmpentRw').text(typbssEmpentTxt);
        }
        var bssEmpAccTxt = (apz.isNull(occupationPayload.employeeActivity) ? "---" : occupationPayload.employeeActivity);
        if (bssEmpAccTxt == 'Please Select') {
            $('#' + rvwScrId + 'bssEmpAccRw').text("---");
        } else {
            $('#' + rvwScrId + 'bssEmpAccRw').text(bssEmpAccTxt);
        }
        var bssAddrProofTxt = (apz.isNull(occupationPayload.businessAddressProof) ? "---" : occupationPayload.businessAddressProof);
        if (bssAddrProofTxt == 'Please Select') {
            $('#' + rvwScrId + 'bssAddrProofRw').text("---");
        } else {
            $('#' + rvwScrId + 'bssAddrProofRw').text(bssAddrProofTxt);
        }
        var empProofTxt = (apz.isNull(occupationPayload.employmentProof) ? "---" : occupationPayload.employmentProof);
        if (empProofTxt == 'Please Select') {
            $('#' + rvwScrId + 'empProofRw').text("---");
        } else {
            $('#' + rvwScrId + 'empProofRw').text(empProofTxt);
        }
        var bssPerOwnTxt = (apz.isNull(occupationPayload.businessPremiseOwnerShip) ? "---" : occupationPayload.businessPremiseOwnerShip);
        if (bssPerOwnTxt == 'Please Select') {
            $('#' + rvwScrId + 'bssPerOwnRw').text("---");
        } else {
            $('#' + rvwScrId + 'bssPerOwnRw').text(bssPerOwnTxt);
        }
        var freqOfIncTxt = (apz.isNull(occupationPayload.freqOfIncome) ? "---" : occupationPayload.freqOfIncome);
        if (freqOfIncTxt == 'Please Select') {
            $('#' + rvwScrId + 'freqOfIncRw').text("---");
        } else {
            $('#' + rvwScrId + 'freqOfIncRw').text(freqOfIncTxt);
        }
        var othSrcIncTxt = (apz.isNull(occupationPayload.otherSourceIncome) ? "---" : occupationPayload.otherSourceIncome);
        if (othSrcIncTxt == 'Please Select') {
            $('#' + rvwScrId + 'othSrcIncRw').text("---");
        } else {
            $('#' + rvwScrId + 'othSrcIncRw').text(othSrcIncTxt);
        }
        if (apz.isNull(occupationPayload.otherSourceAnnualIncome)) {
            $('#' + rvwScrId + 'othSrcAnnIncRw').text("---");
        } else {
            var othSrcAnnIncTxt = ApzCOB.fn_FormatAmount(occupationPayload.otherSourceAnnualIncome);
            $('#' + rvwScrId + 'othSrcAnnIncRw').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + othSrcAnnIncTxt);
        }
        var retirementAgeTxt = (apz.isNull(occupationPayload.retirementAge) ? "---" : occupationPayload.retirementAge);
        if (retirementAgeTxt == 'Please Select') {
            $('#' + rvwScrId + 'retirementAge').text("---");
        } else {
            $('#' + rvwScrId + 'retirementAge').text(retirementAgeTxt);
        }
        var LastEmplrTxt = (apz.isNull(occupationPayload.lastEmployer) ? "---" : occupationPayload.lastEmployer);
        $('#' + rvwScrId + 'prevEmployer').text(LastEmplrTxt);
        var prevJobYrsTxt = apz.isNull(occupationPayload.previousJobYears) ? "---" : occupationPayload.previousJobYears;
        $('#' + rvwScrId + 'prevEmpyrs').text(prevJobYrsTxt);
    }
    /*BankDetails*/
    if (!apz.isNull(gApzCOB.requestNodes.bankDetailsWrapperList) && gApzCOB.requestNodes.bankDetailsWrapperList.length > 0) {
        let currIndex = ApzCOB.getIndexforBankWrapper("Applicant");
        var bankdetlsPayload = gApzCOB.requestNodes.bankDetailsWrapperList[currIndex]?.bankDetails?.payload;
        var accountNameTxt = (apz.isNull(bankdetlsPayload.accountName) ? "---" : bankdetlsPayload.accountName);
        if (accountNameTxt == 'Please Select') {
            $('#' + rvwScrId + 'accHolderName').text("---");
        } else {
            $('#' + rvwScrId + 'accHolderName').text(accountNameTxt);
        }
        var accountNumberTxt = (apz.isNull(bankdetlsPayload.accountNumber) ? "---" : bankdetlsPayload.accountNumber);
        $('#' + rvwScrId + 'accNumber').text(accountNumberTxt);
        var accountTypeTxt = (apz.isNull(bankdetlsPayload.accountType) ? "---" : bankdetlsPayload.accountType);
        if (accountTypeTxt == 'Please Select') {
            $('#' + rvwScrId + 'accType').text("---");
        } else {
            $('#' + rvwScrId + 'accType').text(accountTypeTxt);
        }
        var bankNameTxt = (apz.isNull(bankdetlsPayload.bankName) ? "---" : bankdetlsPayload.bankName);
        $('#' + rvwScrId + 'bankName').text(bankNameTxt);
        var ifscTxt = (apz.isNull(bankdetlsPayload.ifsc) ? "---" : bankdetlsPayload.ifsc);
        $('#' + rvwScrId + 'ifscCode').text(ifscTxt);
        var branchNameTxt = (apz.isNull(bankdetlsPayload.branchName) ? "---" : bankdetlsPayload.branchName);
        $('#' + rvwScrId + 'branchName').text(branchNameTxt);
        let bankDataEditOption = (apz.isNull(bankdetlsPayload.editBankDetails) ? "---" : bankdetlsPayload.editBankDetails);
        $(`#${rvwScrId}AccDetRadio`).text(bankDataEditOption);
    }
    /*insuranceDetails*/
    var insFields = ['insuranceForDiv', 'nomineeInsuranceDiv', 'relationNomineeDiv', 'dobnomineeDiv', 'ageNomineeyrsDiv'];
    if (!apz.isNull(gApzCOB.requestNodes.insuranceDetailsWrapperList) && gApzCOB.requestNodes.insuranceDetailsWrapperList.length > 0) {
        ['InsuranceDetailsDiv', 'applicantInsurDiv', 'coApplInsurDiv'].show();
        var insurancePayload = gApzCOB.requestNodes.insuranceDetailsWrapperList[0].insuranceDetails.payload;
        var insuredNameTxt = (apz.isNull(insurancePayload.insuredName) ? "---" : insurancePayload.insuredName);
        $('#' + rvwScrId + 'insuranceFor').text(insuredNameTxt);
        var nomineeNameTxt = (apz.isNull(insurancePayload.nomineeName) ? "---" : insurancePayload.nomineeName);
        $('#' + rvwScrId + 'nomineeInsurance').text(nomineeNameTxt);
        var nomineeRelationTxt = (apz.isNull(insurancePayload.nomineeRelation) ? "---" : insurancePayload.nomineeRelation);
        if (nomineeRelationTxt == 'Please Select') {
            $('#' + rvwScrId + 'relationNominee').text("---");
        } else {
            $('#' + rvwScrId + 'relationNominee').text(nomineeRelationTxt);
        }
        var nomineeDobTxt = (apz.isNull(insurancePayload.nomineeDob) ? "---" : insurancePayload.nomineeDob);
        $('#' + rvwScrId + 'dobnominee').text(nomineeDobTxt);
        var ageTxt = (apz.isNull(insurancePayload.nomineeDob) ? "---" : ApzCOB.getAge(insurancePayload.nomineeDob));
        $('#' + rvwScrId + 'ageNomineeyrs').text(ageTxt);
        var coApplIns = insurancePayload.coApplicantInsurance;
        window.coApplicantInsuranceFlag = (!apz.isNull(coApplIns) && coApplIns == 'No') ? "No" : "Yes";
        if (insurancePayload.insuranceReqd == 'Y') {
            insFields.show();
            $(`#${rvwScrId}applicantInsur`).text('Yes');
            $(`#${rvwScrId}coApplInsur`).text(apz.isNull(coApplIns) ? "---" : coApplIns);
        } else if (insurancePayload.insuranceReqd == 'N') {
            ['InsuranceDetailsDiv'].show();
            insFields.hide();
            $(`#${rvwScrId}applicantInsur`).text('No');
            $(`#${rvwScrId}coApplInsur`).text('No');
        }
        if (currTab === 'Applicant') {
            //window.coAppInsurance = insurancePayload.coApplicantInsurance;
            gApzCOB.requestNodes.insuranceDetailsWrapperList.forEach(function(i, k) {
                if (i.insuranceDetails.custDtlId === gApzCOB.userDetails.custDtlId) {
                    window.coAppInsurance = i.insuranceDetails.payload.coApplicantInsurance;
                    return;
                }
            })
        }
        if (currTab != 'Applicant') {
            if (!apz.isNull(window.coApplicantInsuranceFlag) && window.coApplicantInsuranceFlag == 'Yes') {
                ['InsuranceDetailsDiv'].show();
                ['applicantInsurDiv', 'coApplInsurDiv'].hide();
                coAppInsuranceFlag = false;
            } else if (!apz.isNull(window.coApplicantInsuranceFlag) && window.coApplicantInsuranceFlag == 'No') {
                ['InsuranceDetailsDiv'].hide();
                coAppInsuranceFlag = true;
            }
            if (coAppInsurance === 'No') {
                ['InsuranceDetailsDiv'].hide();
            }
            if (coAppInsurance === 'No' && occupationValue === 'Homemaker') {
                coAppInsuranceFlag = true;
            }
        }
    }
    if (gApzCOB.requestNodes.insuranceDetailsWrapperList === undefined && occupationValue === 'Homemaker') {
        ['InsuranceDetailsDiv'].hide();
        coAppInsuranceFlag = true;
    }
    apz.app.ReviewConfirm.hideNshowAdditionalDetails();
}
apz.app.ReviewConfirm.hideNshowAdditionalDetails = function() {
    if (coAppInsuranceFlag && homeMakerFlag) {
        ['empDetDiv'].hide();
        coAppInsuranceFlag = false;
        homeMakerFlag = false;
    } else {
        ['empDetDiv'].show();
    }
}
apz.app.ReviewConfirm.fatcaDetails = function() {
    if (!apz.isNull(gApzCOB.requestNodes.fatcaDetailsList) && gApzCOB.requestNodes.fatcaDetailsList.length > 0) {
        var index = gApzCOB.requestNodes.fatcaDetailsList.findIndex(function(e) {
            return e.custDtlId === window.latestcustDtlId
        })
        var fatcaPayload = gApzCOB.requestNodes.fatcaDetailsList.length === 1 ? gApzCOB.requestNodes.fatcaDetailsList[0].payload : gApzCOB
            .requestNodes.fatcaDetailsList[index].payload
        var isUSCitizen = (apz.isNull(fatcaPayload.usCitizenFlag) ? "---" : fatcaPayload.usCitizenFlag);
        if (isUSCitizen === 'Y') {
            documentName = (apz.isNull(fatcaPayload.documentIdName) ? "---" : fatcaPayload.documentIdName);
            var documentNumber = (apz.isNull(fatcaPayload.documentIdValue) ? "---" : fatcaPayload.documentIdValue);
            $('#' + rvwScrId + 'nationalityTxt').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_US_CITIZEN"));
            $('#' + rvwScrId + 'wNineDetRow').removeClass('sno');
            apz.app.ReviewConfirm.LoadDocumentTypes();
            /*if (documentName === 'SSN') {
                $('#' + rvwScrId + 'documentType').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_SSN"));
                $('#' + rvwScrId + 'docNumTxt').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_SSN"));
            } else if (documentName === 'employerIdNum') {
                $('#' + rvwScrId + 'documentType').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_EIN"));
                $('#' + rvwScrId + 'docNumTxt').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_EIN"));
            }*/
            $('#' + rvwScrId + 'documentNumber').text(documentNumber);
        } else {
            $('#' + rvwScrId + 'nationalityTxt').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_NON_US_PERSON"));
            $('#' + rvwScrId + 'wNineDetRow').addClass('sno');
        }
    }
}
apz.app.ReviewConfirm.crsDetails = function() {
    apz.data.scrdata.RevCof__IPaintCrsDetails_Res = [];
    if (!apz.isNull(gApzCOB.requestNodes.crsDetailsList) && gApzCOB.requestNodes.crsDetailsList.length > 0) {
        var index = gApzCOB.requestNodes.crsDetailsList.findIndex(function(e) {
            return e.custDtlId === window.latestcustDtlId
        });
        var crsPayload = gApzCOB.requestNodes.crsDetailsList.length === 1 ? gApzCOB.requestNodes.crsDetailsList[0].payload : gApzCOB.requestNodes
            .crsDetailsList[index].payload
        //  var crsPayload = gApzCOB.requestNodes.crsDetailsList;
        if (crsPayload.otherCountryTaxResidant === 'Y') {
            $('#' + rvwScrId + 'resTxt').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_CARDDTLS_YES"));
            $('#' + rvwScrId + 'taxDetRow').removeClass('sno');
            if (crsPayload.taxDetailsList.length > 0) {
                for (var k = 0; k < crsPayload.taxDetailsList.length; k++) {
                    var newObj = {};
                    newObj.countryResidence = crsPayload.taxDetailsList[k].country;
                    newObj.tinType = crsPayload.taxDetailsList[k].tinType;
                    newObj.tinNumber = crsPayload.taxDetailsList[k].tin;
                    newObj.remark = crsPayload.taxDetailsList[k].remarks;
                    newObj.reason = crsPayload.taxDetailsList[k].reason;
                    apz.data.scrdata.RevCof__IPaintCrsDetails_Res.push(newObj);
                    apz.data.loadData("IPaintCrsDetails", apz.currAppId);
                }
            }
        } else {
            $('#' + rvwScrId + 'resTxt').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_CARDDTLS_NO"));
            $('#' + rvwScrId + 'taxDetRow').addClass('sno');
        }
    }
}
