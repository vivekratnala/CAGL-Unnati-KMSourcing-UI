}
apz.app.ReviewConfirm.uploadDocs = function(iSingle) {
    finalimgdata = [];
    allFileNames = [];
    window.applicationDocumentsCount = 0;
    apz.data.scrdata.RevCof__IPaintDocs_Res = {}
    //var data = gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"];
    if (!apz.isNull(gApzCOB.requestNodes.applicationDocumentsWrapperList) && gApzCOB.requestNodes.applicationDocumentsWrapperList.length !== 0) {
        gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList = ApzCOB.sortDocuments(gApzCOB.requestNodes.applicationDocumentsWrapperList[0]?.applicationDocumentsList);
        let responseDocData = gApzCOB.requestNodes.applicationDocumentsWrapperList[0].applicationDocumentsList;
        let filteredDocsData = [];
        if (currTab === "Applicant") {
            filteredDocsData = responseDocData.filter(docData => parseInt(docData.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));
        } else {
            filteredDocsData = responseDocData.filter(docData => parseInt(docData.custDtlId) === parseInt(gApzCOB.userDetails
                .CoApplicantCustomerId));
        }
        allDocTypes = [];
        allAppDocID = [];
        if (filteredDocsData.length > 0) {
            $.each(filteredDocsData, function(i, k) {
                // var condition = !apz.isNull(window.latestcustDtlId) ? window.latestcustDtlId === gApzCOB.requestNodes.applicationDocumentsWrapperList[
                //     0]["applicationDocumentsList"][i].custDtlId : true;
                //  if (condition) {
                window.applicationDocumentsCount++;
                fileName = k.payload.documentFileName
                allFileNames.push(fileName);
                if (k.payload.screenId === "KYCVerification" && k.payload.docSide === 'Front') {
                    allDocTypes.push('National ID Front');
                } else if (k.payload.screenId === "KYCVerification" && k.payload.docSide === 'Back') {
                    allDocTypes.push('National ID Back');
                } else if (k.payload.docSide === 'Photo' || k.payload.docSide === 'Sign') {
                    allDocTypes.push(k.payload.docSide);
                } else if (k.payload.documentType === 'AddressProof' || k.payload.documentType === 'IdentityProof') {
                    allDocTypes.push(k.payload.documentName + ' ' + k.payload.docSide);
                } else if (k.payload.documentType === 'OtherDocs') {
                    allDocTypes.push(k.payload.documentName);
                } else {
                    allDocTypes.push(k.payload.documentType.replaceAll('_',' '));
                     allAppDocID.push(k.appDocId);
                }
                // }
            })
        }
    }
    apz.app.ReviewConfirm.LoadDownloadDocForWeb();
    /*if (apz.deviceType === 'WEB') {
        docCallBackCounter = 0;
        apz.app.ReviewConfirm.downloadFileFromserver(0);
    } else {
        $('#RevCof__IPaintDocs__o__RevCof__IPaintDocs_Res__docs_0').parent().parent().addClass('sno');
        apz.app.ReviewConfirm.paintDocNames(allDocTypes);
    }*/
}
apz.app.ReviewConfirm.paintDocNames = function(aDT) {
    apz.data.scrdata.RevCof__IPaintDocs_Res = [];
    aDT.forEach(function(e, i) {
        apz.data.scrdata.RevCof__IPaintDocs_Res.push({
            'docs': '',
            'docname': e,
             'appDocId': allAppDocID[i]
        });
    });
    apz.data.loadData("IPaintDocs", apz.currAppId);
};
apz.app.ReviewConfirm.downloadFileFromserver = function(fileCounter) {
    /*if(gApzCOB.mainProductGroupCode === 'DEPOSIT' || gApzCOB.mainProductGroupCode === 'LOAN'){
        var applnId = (!gApzCOB.ExistingCustomer) ? gApzCOB.relatedApplicationId : gApzCOB.userDetails.applicationId;
        gApzCOB.userDetails.applicationId = applnId;
    }*/
    if (apz.isNull(fileCounter)) {
        apz.startLoader();
    }
    var obj = {
        "docname": fileName
    };
    tempFileArr.push(obj);
    //var flname = allFileNames[fileCounter];
    var json = {
        "destinationPath": "",
        "filePath": (gApzCOB.requestNodes.appId).concat("/").concat(gApzCOB.product).concat("/").concat(gApzCOB.userDetails.applicationId),
        "sessionReq": "N" //Y or N
    };
    json.destinationPath = "docs";
    json.fileName = apz.isNull(fileCounter) ? fileName : allFileNames[fileCounter];
    json.base64 = "Y";
    json.filePath = (gApzCOB.requestNodes.appId).concat("/").concat(gApzCOB.product).concat("/").concat(gApzCOB.userDetails.applicationId);
    json.id = "";
    json.callBack = apz.isNull(fileCounter) ? apz.app.ReviewConfirm.viewDocMBCB : apz.app.ReviewConfirm.downloadFileFromserverCB;
    apz.startLoader();
    setTimeout(() => {
        apz.ns.downloadFile(json);
    }, 1000)
};
/**** Callback function will be called only if bsae64 image is requested *********/
apz.app.ReviewConfirm.downloadFileFromserverCB = function(params) {
    if (!apz.isNull(params.base64)) {
        var obj = {
            "docs": params.base64,
            "docname": allDocTypes[docCallBackCounter]
        };
        finalimgdata.push(obj);
    }
    if (docCallBackCounter === window.applicationDocumentsCount) {
        apz.stopLoader();
        apz.data.scrdata.RevCof__IPaintDocs_Res = finalimgdata;
        apz.data.loadData("IPaintDocs", apz.currAppId);
        docCallBackCounter = 0;
    } else {
        if (finalimgdata.length < window.applicationDocumentsCount) {
            docCallBackCounter++;
            apz.app.ReviewConfirm.downloadFileFromserver(docCallBackCounter);
        } else {
            apz.stopLoader();
            if (finalimgdata.length === window.applicationDocumentsCount) {
                apz.data.scrdata.RevCof__IPaintDocs_Res = finalimgdata;
                apz.data.loadData("IPaintDocs", apz.currAppId);
                docCallBackCounter = 0;
            }
        }
    }
};
apz.app.ReviewConfirm.viewDocMB = function(pthis) {
    fileName = gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"][Number($("#" + pthis.id).attr('rowno'))]
        .payload.documentFileName;
    let lobj = gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"][Number($("#" + pthis.id).attr('rowno'))]
        .payload;
        window.ImageLocationDetails = {
                latitude: lobj.latitude || "",
                longitude: lobj.longitude || "",
                uploadedTs: lobj.uploadedTs || "",
                documentFileName: lobj.documentFileName || ""
            }; 
    //var data = gApzCOB.requestNodes.applicationDocumentsWrapperList[0]["applicationDocumentsList"];
    apz.app.ReviewConfirm.downloadFileFromserver();
};
apz.app.ReviewConfirm.viewDocMBCB = function(param) {
    ApzCOB.toggleModal(rvwScrId + "viewUploadedFileModal");
    $('#' + rvwScrId + 'mbImageView').attr('src', 'data:image/png;base64,' + param.base64);
    let id = '#' + rvwScrId + 'mbImageView';
    if (Object.keys(window.ImageLocationDetails).length > 0) {
        apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
    }
    apz.stopLoader();
};
apz.app.ReviewConfirm.paintApplicants = function() {
    $('#' + rvwScrId + 'applicantNameList').removeClass('sno');
    apz.data.scrdata.RevCof__IPaintJointNames_Res = [];
    var tempName = '';
    var custDet = inSessionStore.customerDetailsList;
    if (custDet[0]["seqNumber"] === custDet.length) {
        for (var i = custDet.length - 1; i >= 0; i--) {
            tempName = {
                'applicantName': custDet[i]['customerName'],
                'id': apz.isNull(custDet[i]['custDtlId']) ? gApzCOB.userDetails.custDtlId : custDet[i]['custDtlId']
            }
            apz.data.scrdata.RevCof__IPaintJointNames_Res.push(tempName);
        }
    } else {
        custDet.forEach(function(k, i) {
            tempName = {
                'applicantName': k.customerName,
                'id': k.custDtlId === undefined ? gApzCOB.userDetails.custDtlId : k.custDtlId
            }
            apz.data.scrdata.RevCof__IPaintJointNames_Res.push(tempName);
        })
    }
    apz.data.loadData('IPaintJointNames', 'RevCof');
};
apz.app.ReviewConfirm.getApplicantDetails = function(pthis) {
    // $('#' + rvwScrId + 'applicantNameList .pri').children().removeClass('active');
    $('#' + pthis.id).parent().parent().addClass('active');
    window.dontReloadRC = true;
    var rowNo = $('#' + pthis.id).attr('rowno');
    var removeActive = (rowNo == 0) ? 1 : 0;
    $(`#${rvwScrId}applicantNameList_row_${removeActive}`).removeClass('active');
    $('#' + 'RevCof__ReviewConfirm__personalDetDiv').removeClass('active')
    // var id = 'RevCof__IPaintJointNames__o__RevCof__IPaintJointNames_Res__applicantName_0'
    // if (id == pthis.id) {
    //     $('#' + rvwScrId + 'custTypeLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_TYPE"))
    //     $('#' + rvwScrId + 'custIdLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_ID"))
    //     $('#' + rvwScrId + 'custNameLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_NAME"))
    // } else {
    //     $('#' + rvwScrId + 'custTypeLabel').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_TYPE"))
    //     $('#' + rvwScrId + 'custIdLabel').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_ID"))
    //     $('#' + rvwScrId + 'custNameLabel').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_NAME"))
    // }
    var curApplicantId = Number(apz.data.scrdata.RevCof__IPaintJointNames_Res[rowNo].id);
    apz.app.ReviewConfirm.expandCollapse("collapse");
    ApzCOB.FetchApplication(curApplicantId);
};
apz.app.ReviewConfirm.cardSevice = function() {
    var imageData = {};
    // //apz.data.scrdata.RevCof__IPaintImage_Res.imageNode = [];
    // imageData = apz.data.scrdata.CardSe__IpaintFileUpload_Res.fileDetails;
    // apz.data.scrdata.RevCof__IPaintImage_Res.imageNode = [];
    var obj = {};
    // obj.image = imageData[0].imgSrc
    // apz.data.scrdata.RevCof__IPaintImage_Res.imageNode.push(obj);
    // apz.data.loadData("IPaintImage", "RevCof");
    if (gApzCOB.product === "CARDS") {
        apz.setElmValue(rvwScrId + "ApproxElig", gApzCOB.userDetails.allCardInfo.currency + " " + ApzCOB.fn_FormatAmount(gApzCOB.userDetails
            .allCardInfo.creditLimit));
        apz.setElmValue(rvwScrId + "WithdrawLimit", gApzCOB.userDetails.allCardInfo.currency + " " + ApzCOB.fn_FormatAmount(gApzCOB.userDetails
            .allCardInfo.withdrawalLimit));
        apz.setElmValue(rvwScrId + "NameonCardReview", gApzCOB.userDetails.NameOnCard);
        apz.setElmValue(rvwScrId + "SELCARDNAME_0", gApzCOB.userDetails.NameOnCard);
        apz.setElmValue(rvwScrId + "SubProdcutName_0", gApzCOB.subProduct);
        apz.setElmValue(rvwScrId + "ModeofDelivry", gApzCOB.userDetails.ModeofDelivry);
        apz.data.scrdata.Select__IpaintProductDetails_Res.data.forEach(function(m, n) {
            if (apz.data.scrdata.Select__IpaintProductDetails_Res.data[n].productCode === gApzCOB.productCode) {
                apz.setElmValue(rvwScrId + "Feature1", apz.data.scrdata.Select__IpaintProductDetails_Res.data[n].value[0]);
                apz.setElmValue(rvwScrId + "Feature2", apz.data.scrdata.Select__IpaintProductDetails_Res.data[n].value[1]);
            }
        })
        imageData = apz.data.scrdata.CardSe__IpaintFileUpload_Res.fileDetails;
        apz.data.scrdata.RevCof__IPaintImage_Res = [];
        if (!apz.isNull(imageData)) {
            obj = {};
            obj.image = imageData[0].imgSrc
            apz.data.scrdata.RevCof__IPaintImage_Res.push(obj);
            apz.data.loadData("IPaintImage", "RevCof");
        } else {
            obj = {};
            obj.image = SelectedCardThemeName
            apz.data.scrdata.RevCof__IPaintImage_Res.push(obj);
            apz.data.loadData("IPaintImage", "RevCof");
        }
    }
};
apz.app.ReviewConfirm.paindetcardSevice = function() {
    if (gApzCOB.requestNodes.cardDetails.currency === undefined || gApzCOB.requestNodes.cardDetails.creditLimit === undefined || gApzCOB
        .requestNodes.cardDetails.withdrawalLimit === undefined) {
        apz.setElmValue(rvwScrId + "ApproxElig", gApzCOB.userDetails.allCardInfo.currency + " " + ApzCOB.fn_FormatAmount(gApzCOB.userDetails
            .allCardInfo.creditLimit));
        apz.setElmValue(rvwScrId + "WithdrawLimit", gApzCOB.userDetails.allCardInfo.currency + " " + ApzCOB.fn_FormatAmount(gApzCOB.userDetails
            .allCardInfo.withdrawalLimit));
    } else {
        apz.setElmValue(rvwScrId + "ApproxElig", gApzCOB.requestNodes.cardDetails.currency + " " + ApzCOB.fn_FormatAmount(gApzCOB.requestNodes
            .cardDetails.creditLimit));
        apz.setElmValue(rvwScrId + "WithdrawLimit", gApzCOB.requestNodes.cardDetails.currency + " " + ApzCOB.fn_FormatAmount(gApzCOB.requestNodes
            .cardDetails.withdrawalLimit));
    }
    apz.setElmValue(rvwScrId + "NameonCardReview", gApzCOB.requestNodes.cardDetails.nameOnCard);
    apz.setElmValue(rvwScrId + "SELCARDNAME_0", gApzCOB.requestNodes.cardDetails.nameOnCard);
    apz.setElmValue(rvwScrId + "SubProdcutName_0", gApzCOB.requestNodes.cardDetails.cardName);
    //apz.setElmValue(rvwScrId + "ModeofDelivry", gApzCOB.userDetails.ModeofDelivry);
    apz.data.scrdata.Select__IpaintProductDetails_Res.data.forEach(function(m, n) {
        if (apz.data.scrdata.Select__IpaintProductDetails_Res.data[n].productCode === gApzCOB.productCode) {
            apz.setElmValue(rvwScrId + "Feature1", apz.data.scrdata.Select__IpaintProductDetails_Res.data[n].value[0]);
            apz.setElmValue(rvwScrId + "Feature2", apz.data.scrdata.Select__IpaintProductDetails_Res.data[n].value[1]);
        }
    })
};
apz.app.ReviewConfirm.downloadFileFromserverforcards = function() {
    var filepth = '';
    var json = {
        "destinationPath": "",
        "filePath": (gApzCOB.requestNodes.appId).concat("/").concat(gApzCOB.userDetails.applicationId),
        "sessionReq": "N" //Y or N
    };
    if (gApzCOB.requestNodes.cardDetails.theme === "N") {
        filepth = ('APZCOB').concat("/").concat(gApzCOB.product).concat("/").concat("DefaultImages");
    } else {
        filepth = (gApzCOB.requestNodes.appId).concat("/").concat(gApzCOB.product).concat("/").concat(gApzCOB.userDetails.applicationId);
    }
    json.destinationPath = "image";
    json.fileName = gApzCOB.requestNodes.cardDetails.customTheme;
    json.base64 = "Y";
    json.filePath = filepth;
    json.id = "";
    json.callBack = apz.app.ReviewConfirm.downloadFileFromserverCBforcards;
    apz.ns.downloadFile(json);
};
/**** Callback function will be called only if bsae64 image is requested *********/
apz.app.ReviewConfirm.downloadFileFromserverCBforcards = function(params) {
    var finalimgdataforc = []
    if (!apz.isNull(params.base64)) {
        var obj = {
            "image": params.base64,
            // "docname": allDocTypes[docCallBackCounter]
        };
        //docCallBackCounter++;
        finalimgdataforc.push(obj);
        apz.data.scrdata.RevCof__IPaintImage_Res = finalimgdataforc;
        apz.data.loadData("IPaintImage", apz.currAppId);
    }
};
apz.app.ReviewConfirm.paintLoanDetails = function() {
    if (!apz.isObjectEmpty(gApzCOB.requestNodes.loanDetails)) {
        $('#' + rvwScrId + 'LoanDetails').text(gApzCOB.subProduct + ' ' + 'Details');
        var response = gApzCOB.requestNodes.loanDetails;
        var loanRespDtls = gApzCOB.requestNodes.loanDetails.payload;
        $('#' + rvwScrId + 'LoanAmount').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(response.loanAmount));
        $('#' + rvwScrId + 'TenureinMonths').text(response.tenure);
        $('#' + rvwScrId + 'rateofInterest').text(response.roi + '%');
        $('#' + rvwScrId + 'purposeLoan').text(loanRespDtls.loanPurpose);
        var subCategoryTxt = (apz.isNull(loanRespDtls.subCategory) ? "---" : loanRespDtls.subCategory);
        var freqOfRepay = (apz.isNull(loanRespDtls.frequencyOfRepayment) ? "---" : loanRespDtls.frequencyOfRepayment);
        if (subCategoryTxt == 'Please Select') {
            $('#' + rvwScrId + 'subCategory').text("---");
        } else {
            $('#' + rvwScrId + 'subCategory').text(subCategoryTxt);
        }
        $('#' + rvwScrId + 'modeDisbursement').text(apz.isNull(loanRespDtls.modeOfDisbursement) ? "---" : loanRespDtls.modeOfDisbursement);
        $('#' + rvwScrId + 'modeSecurity').text(apz.isNull(loanRespDtls.modeOfSecurity) ? "---" : loanRespDtls.modeOfSecurity);
        if (freqOfRepay == 'Please Select') {
            $('#' + rvwScrId + 'freqOfRepayment').text("---");
        } else {
            $('#' + rvwScrId + 'freqOfRepayment').text(freqOfRepay);
        }
        $(`#${rvwScrId}commLanguage`).text(apz.isNull(loanRespDtls.language) ? "---" : loanRespDtls.language);
        //$('#' + rvwScrId + 'monthlyEMI').text(ApzCOB.GetCommonCodes("PRIMARYCURRENCY") + " " + ApzCOB.fn_FormatAmount(response.monthlyEmi));
    }
    if (gApzCOB.product === 'LOAN' && window.pendingApplication) {
        if (gApzCOB.requestNodes.customerDetailsList.length === 1) {
            index = 0;
        } else {
            index = 1;
        }
    }
    let cibilDtls = gApzCOB.requestNodes.cibilDetailsWrapperList.length === 1 ? gApzCOB.requestNodes.cibilDetailsWrapperList[0].cibilDetails
        .payload : gApzCOB.requestNodes.cibilDetailsWrapperList[index].cibilDetails.payload;
        cbSummaryArr.forEach(el => ApzCOB.beautifyCbDtlsSummary(el, cibilDtls));
    if (!apz.isNull(cibilDtls.finalDecision)) {
        // var cibiDtls = cibilDtls[0];
        $('#' + rvwScrId + 'bureauName').text(cibilDtls.bureauName);
        $('#' + rvwScrId + 'hitNohit').text(cibilDtls.hitNohit);
        $('#' + rvwScrId + 'cbScore').text(cibilDtls.cbScore);
        $('#' + rvwScrId + 'cbROI').text(cibilDtls.roi ? `${cibilDtls.roi}%` : '');
        $('#' + rvwScrId + 'totalIndebtedness').text(cibilDtls.totIndebtness);
        $('#' + rvwScrId + 'lastSixtyMonths').text(cibilDtls.NoParInLastMonths);
        $('#' + rvwScrId + 'dpdLastMonth').text(cibilDtls.maxDpdInLastMonths);
        $('#' + rvwScrId + 'suitWrittenoff').text(cibilDtls.writeoffSuitFiledFlag);
        $('#' + rvwScrId + 'overlapMMFL').text(cibilDtls.overlapWithMmfl);
        $('#' + rvwScrId + 'overdueAmount').text(cibilDtls.overdueAmt);
        $('#' + rvwScrId + 'writtenoffAmt').text(cibilDtls.writtenOff);
        $('#' + rvwScrId + 'finalDecision').text(cibilDtls.finalDecision);
        $('#' + rvwScrId + 'eligbAmount').text(cibilDtls.eligibleAmt);
        $('#' + rvwScrId + 'runningEmi').text(apz.isNull(cibilDtls.foir) ? "---" : cibilDtls.foir);
        $('#' + rvwScrId + 'caglDpd').text(apz.isNull(cibilDtls.caglDpdFlag) ? "---" : cibilDtls.caglDpdFlag);
        $(`#${rvwScrId}individualIndebtness`).text(apz.isNull(cibilDtls.individualIndebtness) ? "---" : cibilDtls.individualIndebtness);
        if (!apz.isNull(cibilDtls.bureauName)) {
            if (cibilDtls.bureauName === "BRE") {
                $('#' + rvwScrId + 'suitWrittenoff').text(cibilDtls.writeoffSuitFiledFlag);
                ['hitNohitDiv', 'runningEmiDiv'].hide();
                ['individualIndebtDiv'].show();
                if (gApzCOB.currentApplicant <= 1) {
                    ['totalIndebtednessDiv'].hide();
                } else {
                    ['totalIndebtednessDiv'].show();
                }
            } else {
                ['hitNohitDiv', 'runningEmiDiv', 'totalIndebtednessDiv'].show();
                ['individualIndebtDiv'].hide();
            }
        }
    }
}
