}
apz.app.ReviewConfirm.LoadCardsFunctions = function() {
    if (gApzCOB.product === "CARDS") {
        if (window.pendingApplication) {
            apz.app.ReviewConfirm.downloadFileFromserverforcards();
            apz.app.ReviewConfirm.paindetcardSevice();
        } else {
            apz.app.ReviewConfirm.cardSevice();
        }
    }
}
apz.app.ReviewConfirm.LoadDocumentTypes = function() {
    if (documentName === 'SSN') {
        $('#' + rvwScrId + 'documentType').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_SSN"));
        $('#' + rvwScrId + 'docNumTxt').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_SSN"));
    } else if (documentName === 'employerIdNum') {
        $('#' + rvwScrId + 'documentType').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_EIN"));
        $('#' + rvwScrId + 'docNumTxt').text(ApzCOB.getDescfromLitCode("LIT_REVCONF_TXT_FATCADTLS_EIN"));
    }
}
apz.app.ReviewConfirm.LoadDownloadDocForWeb = function() {
    if (apz.deviceType === 'WEB') {
        docCallBackCounter = 0;
        apz.app.ReviewConfirm.downloadFileFromserver(0);
    } else {
        $('#RevCof__IPaintDocs__o__RevCof__IPaintDocs_Res__docs_0').parent().parent().addClass('sno');
        apz.app.ReviewConfirm.paintDocNames(allDocTypes);
    }
}
apz.app.ReviewConfirm.LoadBankingFacServices = function() {
    $('#' + rvwScrId + 'ib').text(bankFacilityPayload.ibRequired === "Y" ? "Yes" : "No")
    $('#' + rvwScrId + 'mb').text(bankFacilityPayload.mbRequired === "Y" ? "Yes" : "No");
    $('#' + rvwScrId + 'sms').text(bankFacilityPayload.smsAlertsRequired === "Y" ? "Yes" : "No")
    $('#' + rvwScrId + 'estatement').text(bankFacilityPayload.eStmtRequired === "Y" ? "Yes" : "No")
    $('#' + rvwScrId + 'passbook').text(bankFacilityPayload.passBookRequired === "Y" ? "Yes" : "No")
    $('#' + rvwScrId + 'chequebook').text(bankFacilityPayload.chequeBookRequired === "Y" ? "Yes" : "No")
    $('#' + rvwScrId + 'debitcard').text(bankFacilityPayload.debitCardRequired === "Y" ? "Yes" : "No")
    $('#' + rvwScrId + 'branchNAme').text(apz.isNull(bankFacilityPayload.branchName) ? "---" : bankFacilityPayload.branchName);
    $('#' + rvwScrId + 'branchAdd').text(apz.isNull(bankFacilityPayload.branchAddress) ? "---" : bankFacilityPayload.branchAddress);
}
apz.app.ReviewConfirm.applicationEdit = function(stageName, divName) {
    window.isRevAndConfEdit = true;
    if (currTab === "Applicant") {
        gApzCOB.currentApplicant = 1;
    } else {
        gApzCOB.currentApplicant = 2
    }
    window.isRevAndConfEditCustType = gApzCOB.currentApplicant;
    let currentStage = ApzCOB.getStageNoForEdit(stageName);
    if (!apz.isNull(CURRENT_STAGE_NO)) {
        CURRENT_STAGE_NO = parseInt(currentStage);
        window.PREV_STAGE_NO = CURRENT_STAGE_NO - 1;
        window.STAGE_NO = CURRENT_STAGE_NO + 1;
        window.CURRENT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split('~')[0];
        if (!apz.isNull(STAGES[CURRENT_STAGE_NO])) {
            window.NEXT_STAGE_NAME = STAGES[CURRENT_STAGE_NO].split('~')[0];
        } else {
            window.NEXT_STAGE_NAME = STAGES[CURRENT_STAGE_NO - 1].split('~')[0];
        }
        ApzCOB.editlaunch(stageName, divName, true, parseInt(CURRENT_STAGE_NO));
    } else {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EDIT_FAILED"), "E");
    }
}
