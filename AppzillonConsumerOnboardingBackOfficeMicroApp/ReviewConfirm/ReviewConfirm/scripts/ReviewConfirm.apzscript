                    $(`#${rvwScrId}permanentAddres2`).text(apz.isNull(permAddrDtls.addressLine2) ? "---" : permAddrDtls.addressLine2);
                    $(`#${rvwScrId}permanentAddres3`).text(apz.isNull(permAddrDtls.addressLine3) ? "---" : permAddrDtls.addressLine3);
                    $(`#${rvwScrId}permanentPincode`).text(apz.isNull(permAddrDtls.pinCode) ? "---" : permAddrDtls.pinCode);
                    $(`#${rvwScrId}permanentcity`).text(apz.isNull(permAddrDtls.city) ? "---" : permAddrDtls.city);
                    $(`#${rvwScrId}permanentDist`).text(apz.isNull(permAddrDtls.district) ? "---" : permAddrDtls.district);
                    $(`#${rvwScrId}permanentState`).text(apz.isNull(permAddrDtls.state) ? "---" : permAddrDtls.state);
                    $(`#${rvwScrId}permanentCountry`).text(apz.isNull(permAddrDtls.country) ? "---" : permAddrDtls.country);
                    $(`#${rvwScrId}permArea`).text(apz.isNull(permAddrDtls.area) ? "---" : permAddrDtls.area);
                    $(`#${rvwScrId}permLandmark`).text(apz.isNull(permAddrDtls.landMark) ? "---" : permAddrDtls.landMark);
                }
