            $(`#${reViewcnfrm}CofarmTotalPerMonth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.farmWorker?.totalWagePerMonth);
            $(`#${reViewcnfrm}CofarmselfDeclaredWagePerMonth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.farmWorker?.selfDeclaredWage);
        }
        if (incomeDtls.wage.coApplicant.hasOwnProperty('constructions')) {
            $(`#${reViewcnfrm}coConstructionsRow`).removeClass('sno');
            $(`#${reViewcnfrm}COconsTAction_txtcnt`).text('Constructions');
            $(`#${reViewcnfrm}COconsWEarnedperday_txtcnt`).text(incomeDtls?.wage?.coApplicant?.constructions?.wageEarnedPerDay);
            $(`#${reViewcnfrm}COconsNoofdaysmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.constructions?.noOfDaysInMonth);
            $(`#${reViewcnfrm}COconsTWpermnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.constructions?.totalWagePerMonth);
            $(`#${reViewcnfrm}COconsSDWpermnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.constructions?.selfDeclaredWage);
        }
        if (incomeDtls.wage.coApplicant.hasOwnProperty('contractLabour')) {
            $(`#${reViewcnfrm}COcontractLabourRow`).removeClass('sno');
            $(`#${reViewcnfrm}COcontractTAction_txtcnt`).text('Contract Labour');
            $(`#${reViewcnfrm}COcontractWEarned_txtcnt`).text(incomeDtls?.wage?.coApplicant?.contractLabour?.wageEarnedPerDay);
            $(`#${reViewcnfrm}COcontractNdays_txtcnt`).text(incomeDtls?.wage?.coApplicant?.contractLabour?.noOfDaysInMonth);
            $(`#${reViewcnfrm}COcontractTWmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.contractLabour?.totalWagePerMonth);
            $(`#${reViewcnfrm}COcontractSDTWmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.contractLabour?.selfDeclaredWage);
        }
        if (incomeDtls.wage.coApplicant.hasOwnProperty('maid')) {
            $(`#${reViewcnfrm}COmaidRow`).removeClass('sno');
            $(`#${reViewcnfrm}ComaidTAction_txtcnt`).text('Maid');
            $(`#${reViewcnfrm}ComaidWEarned_txtcnt`).text(incomeDtls?.wage?.coApplicant?.maid?.wageEarnedPerDay);
            $(`#${reViewcnfrm}ComaidNdays_txtcnt`).text(incomeDtls?.wage?.coApplicant?.maid?.noOfDaysInMonth);
            $(`#${reViewcnfrm}ComaidTWmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.maid?.totalWagePerMonth);
            $(`#${reViewcnfrm}ComaidSDTWmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.maid?.selfDeclaredWage);
        }
        if (incomeDtls.wage.coApplicant.hasOwnProperty('hotelWorker')) {
            $(`#${reViewcnfrm}CohotelWorkerRow`).removeClass('sno');
            $(`#${reViewcnfrm}CoHwTAction_txtcnt`).text('Hotel Worker');
            $(`#${reViewcnfrm}CoHwwageEarned_txtcnt`).text(incomeDtls?.wage?.coApplicant?.hotelWorker?.wageEarnedPerDay);
            $(`#${reViewcnfrm}CoHwNdays_txtcnt`).text(incomeDtls?.wage?.coApplicant?.hotelWorker?.noOfDaysInMonth);
            $(`#${reViewcnfrm}CoHwTWmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.hotelWorker?.totalWagePerMonth);
            $(`#${reViewcnfrm}CoHwSDTWmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.hotelWorker?.selfDeclaredWage);
        }
        if (incomeDtls.wage.coApplicant.hasOwnProperty('other')) {
            $(`#${reViewcnfrm}wageCoOthersrow`).removeClass('sno');
            $(`#${reViewcnfrm}WothCoTAction_txtcnt`).text('Other');
            $(`#${reViewcnfrm}WothCoOActivity_txtcnt`).text(incomeDtls?.wage?.coApplicant?.other?.otherAct);
            $(`#${reViewcnfrm}WothCoWEarned_txtcnt`).text(incomeDtls?.wage?.coApplicant?.other?.wageEarnedPerDay);
            $(`#${reViewcnfrm}WothCoNdays_txtcnt`).text(incomeDtls?.wage?.coApplicant?.other?.noOfDaysInMonth);
            $(`#${reViewcnfrm}WothCoTWmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.other?.totalWagePerMonth);
            $(`#${reViewcnfrm}WothCoSDTWmnth_txtcnt`).text(incomeDtls?.wage?.coApplicant?.other?.selfDeclaredWage);
        }
    }
    if (!apz.isObjectEmpty(incomeDtls.wage) && incomeDtls.wage.hasOwnProperty('applicant') && incomeDtls.wage.hasOwnProperty('coApplicant')) {
        $(`#${reViewcnfrm}wageEarnedBy_txtcnt`).text('Both');
