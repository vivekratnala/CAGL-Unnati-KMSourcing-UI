            $(`#${reViewcnfrm}HwSDTWmnth_txtcnt`).text(incomeDtls?.wage?.applicant?.hotelWorker?.selfDeclaredWage);
        }
        if (incomeDtls.wage.applicant.hasOwnProperty('other')) {
            $(`#${reViewcnfrm}wageOthersrow`).removeClass('sno');
            $(`#${reViewcnfrm}WothTAction_txtcnt`).text('Other');
            $(`#${reViewcnfrm}WothOActivity_txtcnt`).text(incomeDtls?.wage?.applicant?.other?.otherAct);
            $(`#${reViewcnfrm}WothWEarned_txtcnt`).text(incomeDtls?.wage?.applicant?.other?.wageEarnedPerDay);
            $(`#${reViewcnfrm}WothNdays_txtcnt`).text(incomeDtls?.wage?.applicant?.other?.noOfDaysInMonth);
            $(`#${reViewcnfrm}WothTWmnth_txtcnt`).text(incomeDtls?.wage?.applicant?.other?.totalWagePerMonth);
            $(`#${reViewcnfrm}WothSDTWmnth_txtcnt`).text(incomeDtls?.wage?.applicant?.other?.selfDeclaredWage);
        }
    }
    if (!apz.isObjectEmpty(incomeDtls.wage) && incomeDtls.wage.hasOwnProperty('coApplicant')) {
        $(`#${reViewcnfrm}WagedtlsRow`).removeClass('sno');
        $(`#${reViewcnfrm}wagecheckedBoth`).addClass('sno');
        $(`#${reViewcnfrm}wageApprow`).addClass('sno');
        $(`#${reViewcnfrm}wageCoapprow`).removeClass('sno');
