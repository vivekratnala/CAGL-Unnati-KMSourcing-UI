window.CA_CURRENT_STAGE = "ReviewSubmit";
var reViewcnfrm = 'CrdAss__CaReviewConfirm__',
    incomeDtls = '',
    dairyData = '',
    dairycoAppDtls = '',
    custTypeForImages = '',
    businessCounter = 1,
    rejectedFromReviewonfirm = false;
apz.app.onLoad_CaReviewConfirm = function() {}
apz.app.onShown_CaReviewConfirm = function() {
    apz.app.Cabase.hideShowBtnBasedOnScreen();
    window.CA_CURRENT_STAGE_NO = CA_ALL_STAGE_FIELDS.find(stage => stage.stageName === CA_CURRENT_STAGE)?.id;
    apz.app.CaReviewConfirm.paintData();
    apz.app.CaReviewConfirm.paintNetIncome();
}
apz.app.CaReviewConfirm.paintData = function() {
    incomeDtls = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload);
    let incomeSourcesToPaint = apz.app.CaReviewConfirm.getPresentIncomeSources();
    let formattedIncomeSources = incomeSourcesToPaint.join(', ');
    $(`#${reViewcnfrm}availSourcesIncome_txtcnt`).text(formattedIncomeSources);
    apz.app.CaReviewConfirm.paintBusinessData();
    apz.app.CaReviewConfirm.paintAgricultureData();
    apz.app.CaReviewConfirm.paintSalaryData();
    apz.app.CaReviewConfirm.paintPensionData();
    apz.app.CaReviewConfirm.paintWageData();
    apz.app.CaReviewConfirm.paintrentalIncomeData();
    if (incomeDtls.hasOwnProperty('homeMaker')) {
        $(`#${reViewcnfrm}homeMaker`).removeClass('sno');
        $(`#${reViewcnfrm}incomeHomemaker_txtcnt`).text(incomeDtls?.homeMaker);
    }
    let nilflag = true;
    let loanObgdata = JSON.parse(inSessionStore?.bcmpiLoanObligations?.payload);
    let othDtls = JSON.parse(inSessionStore?.bcmpiOtherDetails?.payload);
    let removeTloanObgkey = delete loanObgdata.totalLoanObligations;
    let loanObgkeys = Object.keys(loanObgdata).toString();
    $(`#${reViewcnfrm}SrcInfrmlObg_txtcnt`).text(loanObgkeys);
    if (apz.isNull(loanObgkeys)) {
        $(`#${reViewcnfrm}SrcInfrmlObg_txtcnt`).text("Nill");
    } else {
        $(`#${reViewcnfrm}SrcInfrmlObg_txtcnt`).text(loanObgkeys);
    }
    if (loanObgdata.hasOwnProperty('chitFunds')) {
        nilflag = false;
        $(`#${reViewcnfrm}RechitFund`).removeClass('sno')
        $(`#${reViewcnfrm}othrLoanObgchit_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.chitFunds?.otherLoanObligation))
        $(`#${reViewcnfrm}chitmntlyEMI_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.chitFunds?.monthlyEMI))
        $(`#${reViewcnfrm}chitremainTenure_txtcnt`).text(loanObgdata?.chitFunds?.tenure)
        $(`#${reViewcnfrm}chitsrcOfloanVal`).text("chitFunds");
    } else {
        $(`#${reViewcnfrm}RechitFund`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('moneyLender')) {
        nilflag = false;
        $(`#${reViewcnfrm}RemoneyLender`).removeClass('sno')
        $(`#${reViewcnfrm}mnylndrLoanval_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.moneyLender?.otherLoanObligation))
        $(`#${reViewcnfrm}mnyLndrEMI_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.moneyLender?.monthlyEMI))
        $(`#${reViewcnfrm}mnyLndrTenure_txtcnt`).text(loanObgdata?.moneyLender?.tenure)
        $(`#${reViewcnfrm}mnyLndrsrc`).text("Money lender");
    } else {
        $(`#${reViewcnfrm}RemoneyLender`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('Friends')) {
        nilflag = false;
        $(`#${reViewcnfrm}Refriends`).removeClass('sno')
        $(`#${reViewcnfrm}frndothrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Friends?.otherLoanObligation))
        $(`#${reViewcnfrm}frndEMImtly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Friends?.monthlyEMI))
        $(`#${reViewcnfrm}frndremainTnur_txtcnt`).text(loanObgdata?.Friends?.tenure)
        $(`#${reViewcnfrm}frndSrcloan`).text("Friends");
    } else {
        $(`#${reViewcnfrm}Refriends`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('Relatives')) {
        nilflag = false;
        $(`#${reViewcnfrm}Rerelatives`).removeClass('sno')
        $(`#${reViewcnfrm}rltvothrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Relatives?.otherLoanObligation))
        $(`#${reViewcnfrm}rltvEMImntly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Relatives?.monthlyEMI))
        $(`#${reViewcnfrm}rltvremainTnur_txtcnt`).text(loanObgdata?.Relatives?.tenure)
        $(`#${reViewcnfrm}rltvSrcloan`).text("Relatives");
    } else {
        $(`#${reViewcnfrm}Rerelatives`).addClass('sno')
    }
    if (loanObgdata?.hasOwnProperty('Coopsociety')) {
        $(`#${reViewcnfrm}RecoopSociety`).removeClass('sno')
        $(`#${reViewcnfrm}sctyothrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Coopsociety?.otherLoanObligation))
        $(`#${reViewcnfrm}sctyEMImntly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Coopsociety?.monthlyEMI))
        $(`#${reViewcnfrm}sctyremaintnur_txtcnt`).text(loanObgdata?.Coopsociety?.tenure)
        $(`#${reViewcnfrm}sctySrcloan`).text("Co-op society");
    } else {
        $(`#${reViewcnfrm}RecoopSociety`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('Localfinance')) {
        nilflag = false;
        $(`#${reViewcnfrm}RelocalFinance`).removeClass('sno')
        $(`#${reViewcnfrm}lfinothrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Localfinance?.otherLoanObligation))
        $(`#${reViewcnfrm}lfinEMImntly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Localfinance?.monthlyEMI))
        $(`#${reViewcnfrm}lfinremainTnur_txtcnt`).text(loanObgdata?.Localfinance?.tenure)
        $(`#${reViewcnfrm}lfinSrcloan`).text("Local finance");
    } else {
        $(`#${reViewcnfrm}RelocalFinance`).addClass('sno')
    }
    if (loanObgdata.hasOwnProperty('Other')) {
        nilflag = false;
        $(`#${reViewcnfrm}ReOthers`).removeClass('sno')
    $(`#${reViewcnfrm}othrObg_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Other?.otherLoanObligation))
        $(`#${reViewcnfrm}othrEMImntly_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.Other?.monthlyEMI))
        $(`#${reViewcnfrm}othrremainTnur_txtcnt`).text(loanObgdata?.Other?.tenure)
        $(`#${reViewcnfrm}othrLoanSrc`).text("Other");
    } else {
        $(`#${reViewcnfrm}ReOthers`).addClass('sno')
    }
    if (nilflag) {
        $(`#${reViewcnfrm}ReNill`).removeClass('sno')
        $(`#${reViewcnfrm}nilSrcLoan`).text("Nil other loan obligations");
    } else {
        $(`#${reViewcnfrm}ReNill`).addClass('sno')
    }
    $(`#${reViewcnfrm}otherDetailsOwnership_txtcnt`).text(othDtls?.houseOwnership)
    $(`#${reViewcnfrm}otherDetailsTypeOfHouse_txtcnt`).text(othDtls?.typeOfHouse)
    $(`#${reViewcnfrm}otherDetailsTypeOfRoof_txtcnt`).text(othDtls?.typeOfRoof)
    $(`#${reViewcnfrm}otherDetailsNoOfRoomsAvalable_txtcnt`).text(othDtls?.noOfRoomsInHouse)
    $(`#${reViewcnfrm}LandDetailsModeOfSavings_txtcnt`).text(othDtls?.modeOfSavings)
    $(`#${reViewcnfrm}otherNooffamMem_txtcnt`).text(othDtls?.noOfFamilyMembers)
    $(`#${reViewcnfrm}otherEarningMem_txtcnt`).text(othDtls?.noOfOtherEarningMembers)
    $(`#${reViewcnfrm}otherDetailsBasicAmenitie_txtcnt`).text(
        (othDtls.basicAmenities || []).map(item => {
            return item.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());
        }).join(', '));
    $(`#${reViewcnfrm}otherDetailsAssets_txtcnt`).text(
        (othDtls.otherAssets || []).map(item => {
            return item.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());
        }).join(', '));
    $(`#${reViewcnfrm}otherDetailsNoOf2Wheeler_txtcnt`).text(othDtls?.noOfTwoWheelerOwned)
    function formatYesNo(value) {
        if (value === 'Y' || value === 'Yes') return 'Yes';
        if (value === 'N' || value === 'No') return 'No';
        return '';
    }
    $(`#${reViewcnfrm}otherDetailsIfSmartphone_txtcnt`).text(formatYesNo(othDtls?.smartphoneRadio));
    $(`#${reViewcnfrm}otherDetailsNoOfSmartPhones_txtcnt`).text(othDtls?.smartphonesOwned);
    $(`#${reViewcnfrm}otherDetailsAnyAlmirah_txtcnt`).text(formatYesNo(othDtls?.almirah));
    $(`#${reViewcnfrm}otherDetailsAnyFurniture_txtcnt`).text(formatYesNo(othDtls?.chair));
    $(`#${reViewcnfrm}otherDetailsSavingModes_txtcnt`).text(othDtls?.modeOfSavings)
    $(`#${reViewcnfrm}otherExpensesFood_txtcnt`).text(othDtls?.foodExpense)
    $(`#${reViewcnfrm}otherExpensesEducation_txtcnt`).text(othDtls?.educationExpense)
    $(`#${reViewcnfrm}otherExpensesCloth_txtcnt`).text(othDtls?.expenseOnClothing)
    $(`#${reViewcnfrm}otherExpensesMedical_txtcnt`).text(othDtls?.medicalExpense);
    $(`#${reViewcnfrm}otherExpensesHosueHolds_txtcnt`).text(othDtls?.householdExpenses)
    $(`#${reViewcnfrm}LandDetailsAgri_txtcnt`).text(othDtls?.agriland)
    $(`#${reViewcnfrm}LandDetailsHoldBy_txtcnt`).text(othDtls?.landOwnerName)
    $(`#${reViewcnfrm}LandDetailsRelationship_txtcnt`).text(othDtls?.relationshipWithApplicant)
    if (othDtls?.houseOwnership !== 'Owned') {
        $("#CrdAss__CaReviewConfirm__RelProofDoc").removeClass("sno");
        apz.app.CaReviewConfirm.paintDocumentName("CrdAss__CaReviewConfirm__proofCloneRow_0", "CrdAss__CaReviewConfirm__proofParentRow",
            "proof with owner doc");
    }
    apz.app.CaReviewConfirm.paintDocumentName("CrdAss__CaReviewConfirm__cloneRow_0", "CrdAss__CaReviewConfirm__parentRow", "SupportDocs");
}
apz.app.CaReviewConfirm.paintBusinessData = function() {
    businessDtls = incomeDtls?.business;
    dairyData = incomeDtls?.business?.dairy;
    kiranaData = incomeDtls?.business?.Kirana;
    tailoringData = incomeDtls?.business?.Tailoring;
    otherData = incomeDtls?.business?.Other;
    businessKeys = Object.keys(businessDtls).toString();
    businessKeysArray = businessKeys.split(",");
    if (businessDtls.hasOwnProperty('dairy') && dairyData.length !== 0) {
        $(`#${reViewcnfrm}businessdairyRow`).removeClass('sno');
        dairyData.forEach(function(item, index) {
            if (index > 0) {
                ApzCOB.cloneDashboardDivs('CrdAss__CaReviewConfirm__businessSub_0', $('#CrdAss__CaReviewConfirm__businessdairyCol'), index
                    .toString());
            }
            let dairyKey = businessKeysArray.find(key => key === "dairy");
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairyHeading_txtcnt`).text(
                `Business ${businessCounter}`);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairybuisnessType1_txtcnt`).text(dairyKey);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairyownedBy1_txtcnt`).text(item?.DairyType);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairytotalNumberOfProducts1_txtcnt`).text(item
                ?.totalCowsAndBuffalos);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairynetBuisnessAmt1_txtcnt`).text(ApzCOB.formatamountVal(item.IncomeAssessmentChecknetBusinessIncome));
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairytitle_txtcnt`).text(ApzCOB
                .getDescfromLitCode("LIT_dairyBusApp") + ' - ' + item?.DairyType);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairyappbusinessLocation_txtcnt`).text(item
                ?.dairyLocation);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairyappbusinessTenure_txtcnt`).text(item
                ?.dairyTenure);
            const cowBreeds = [item?.cowBreed1, item?.cowBreed2, item?.cowBreed3].filter(breed => breed?.trim()).join(', ');
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairycowBreedVal_txtcnt`).text(cowBreeds);
            const buffaloBreeds = [item?.buffaloBreed1, item?.buffaloBreed2, item?.buffaloBreed3].filter(b => b?.trim()).join(', ');
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairybuffaloBreed_txtcnt`).text(buffaloBreeds);
            const buffaloCounts = [item?.noOfBuffaloBreed1, item?.noOfBuffaloBreed2, item?.noOfBuffaloBreed3].filter(c => c?.toString()
                .trim()).join(', ');
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairybuffaloCount_txtcnt`).text(buffaloCounts);
            const cowCounts = [item?.noOfCowBreed1, item?.noOfCowBreed2, item?.noOfCowBreed3].filter(c => c?.toString().trim()).join(
            ', ');
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairynoOfCows_txtcnt`).text(cowCounts);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairymntlyIncome_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.netMonthlyIncome));
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairyappBusiPermisesValue_txtcnt`).text(item
                .businessAddressSameAsResidance);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairybusinessTypeValue_txtcnt`).text(item
                ?.dairyBusinessType);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairyorganisationValue_txtcnt`).text(item
                ?.organizationName);
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairycowrevenueVal_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.avgDailyRevenuePerCow));
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairybuffalorevenueVal_txtcnt`).text(ApzCOB.formatamountVal(
                item?.avgDailyRevenuePerBuffalo));
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairycowMntlyInc_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.avgMonthlyRevenuePerCow));
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairybuffaloMntlyInc_txtcnt`).text(ApzCOB.formatamountVal(item?.avgMonthlyRevenuePerBuffalo));
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__dairynetBusinessCal_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.IncomeAssessmentChecknetBusinessIncome));
            custTypeForImages = item?.DairyType;
            apz.app.CaReviewConfirm.paintDocumentName(
                `CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__DairyUploadedImage_0`,
                `CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__Dairy_ParentBusRow`, "Dairy Doc");
            businessCounter++;
        })
    } else {
        $(`#${reViewcnfrm}businessdairyRow`).addClass('sno');
    }
    if (businessDtls.hasOwnProperty('Kirana') && kiranaData.length !== 0) {
        $(`#${reViewcnfrm}businesskiranaRow`).removeClass('sno');
        kiranaData.forEach(function(item, index) {
            if (index > 0) {
                ApzCOB.cloneDashboardDivs('CrdAss__CaReviewConfirm__kiranaSubrow_0', $('#CrdAss__CaReviewConfirm__businesskiranaCol'),
                    index.toString());
            }
            let kiranaKey = businessKeysArray.find(key => key === "Kirana");
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaHeading_txtcnt`).text(
                `Business ${businessCounter}`);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaType1_txtcnt`).text(kiranaKey);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaOwnedBy1_txtcnt`).text(item?.kiranaType);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranatypeOfShop_txtcnt`).text(item
                ?.kiranaShopType);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranafinalBusinessInc_txtcnt`).text(ApzCOB.formatamountVal(item?.calculatedNetIncome));
            $(`#CrdAss__CaReviewConfirm__businessSub_${index} #CrdAss__CaReviewConfirm__titleKirana_txtcnt`).text(ApzCOB
                .getDescfromLitCode("LIT_kiranaBusiness_coApp") + ' - ' + item?.kiranaType);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__KiranabusinessLocation_txtcnt`).text(item
                ?.kiranaBusinessLocation);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaTenureValue_txtcnt`).text(item
                ?.kiranaTenure);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaTypeShopValue_txtcnt`).text(item
                ?.kiranaShopType);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaMarketValue_txtcnt`).text(item
                ?.kiranaMarketClassification);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaShopArea_txtcnt`).text(item?.areaofshop);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaUnitArea_txtcnt`).text(item?.kiranaUnit);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaGodownArea_txtcnt`).text(item
                ?.areaOfGodown);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaUnitAreaValue_txtcnt`).text(item
                ?.kiranaGodownUnit);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaOccLevelShopValue_txtcnt`).text(item
                ?.kiranaOccupancyLevel);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaNetMonthIncomeVal_txtcnt`).text(ApzCOB.formatamountVal(item?.netMonthlyIncome));
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaPermsesResiValue_txtcnt`).text(item
                ?.businessAddressSameAsResidance);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaTypeBusinessVal_txtcnt`).text(item
                ?.kiranaBusinessType);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaNameOrganisationVal_txtcnt`).text(item
                ?.nameOfOrganization);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaAreaInSqFtCal_txtcnt`).text(item
                ?.areaOfTheShopInSqft);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaAreaGodownInsqFtCal_txtcnt`).text(item
                ?.areaOfTheGodownInSqft);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaTotalAreaInSqFtVal_txtcnt`).text(item
                ?.totalArea);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaInentArea_txtcnt`).text(item
                ?.inventoryArea);
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaInventValue_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.inventoryValue));
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaMonthlySalesVal_txtcnt`).text(ApzCOB.formatamountVal(item?.monthlySales));
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaNetIncVal_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.calculatedNetIncome));
            $(`#CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__kiranaFinalNetIncVal_txtcnt`).text(ApzCOB.formatamountVal(item?.finalNetIncome));
            custTypeForImages = item?.kiranaType;
            apz.app.CaReviewConfirm.paintDocumentName(
                `CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__KiranaUploadedImage_0`,
                `CrdAss__CaReviewConfirm__kiranaSubrow_${index} #CrdAss__CaReviewConfirm__Kirana_ParentBusRow`, "Kirana Doc");
            businessCounter++;
        })
    } else {
        $(`#${reViewcnfrm}businesskiranaRow`).addClass('sno');
    }
    if (businessDtls.hasOwnProperty('Tailoring') && tailoringData.length !== 0) {
        $(`#${reViewcnfrm}businesstailoringRow`).removeClass('sno');
        tailoringData.forEach(function(item, index) {
            if (index > 0) {
                ApzCOB.cloneDashboardDivs('CrdAss__CaReviewConfirm__tailoringSub_0', $('#CrdAss__CaReviewConfirm__businesstailoringCol'),
                    index.toString());
            }
            let tailoringKey = businessKeysArray.find(key => key === "Tailoring");
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailoringHeading_txtcnt`).text(
                `Business ${businessCounter}`);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tariloringTypebuss_txtcnt`).text(tailoringKey);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorOwnedby_txtcnt`).text(item?.tailoringType);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailoringrevenuePerMonth_txtcnt`).text(ApzCOB.formatamountVal(item?.revenuePerMonth));
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailoringNetIncVal_txtcnt`).text(ApzCOB.formatamountVal(item?.netBusinessIncome));
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailoringtitle_txtcnt`).text(ApzCOB
                .getDescfromLitCode("LIT_tailorBusiness") + ' - ' + item?.tailoringType);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorisApplTailor_txtcnt`).text(item
                ?.isApplicantATailor === 'Y' ? 'Yes' : 'No');
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorisCoAppPart_txtcnt`).text(item
                ?.isCoApplicantPartOfTailorBusiness === 'Y' ? 'Yes' : 'No');
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorbusLocation_txtcnt`).text(item
                ?.tailoringBusinessLocation);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorBusTenureVal_txtcnt`).text(item
                ?.tailoringTenure);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorBusPermiseVal_txtcnt`).text(item
                ?.tailoringPremise);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorpowerMachines_txtcnt`).text(item
                ?.numOfPowerTailoringMachine);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailormanualMachines_txtcnt`).text(item
                ?.numOfManualTailoringMachine);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailornoSalariedTailor_txtcnt`).text(item
                ?.numOfSalariedTailors);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorWorkingTime_txtcnt`).text(item
                ?.tailoringWorkType);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorstitchingFor_txtcnt`).text(item
                ?.stitchingFor);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorNetMonthlyInc_txtcnt`).text(ApzCOB.formatamountVal(item?.netMonthlyIncome));
            /*$(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorTypeOfStich_txtcnt`).text(
                (item.tailorShopItems || []).map(i => i.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase())).join(', ')
                );*/
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorPremiseVal_txtcnt`).text(item
                ?.tailoringPremise);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorBusinessType_txtcnt`).text(item
                ?.tailoringBusinessType);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorNameOrganisation_txtcnt`).text(item
                ?.organizationName);
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorRevenueCal_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.revenuePerDay));
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorRevenuePerMonthcal_txtcnt`).text(ApzCOB.formatamountVal(item?.revenuePerMonth));
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__totalmtlyRevenueCal_txtcnt`).text(ApzCOB.formatamountVal(item?.totalMonthlyIncome));
            $(`#CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__tailorNetBusiness_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.netBusinessIncome));
            custTypeForImages = item?.tailoringType;
            apz.app.CaReviewConfirm.paintDocumentName(
                `CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__TailoringUploadedImage_0`,
                `CrdAss__CaReviewConfirm__tailoringSub_${index} #CrdAss__CaReviewConfirm__Tailoring_ParentBusRow`, "Tailoring Doc");
            businessCounter++;
        })
    } else {
        $(`#${reViewcnfrm}businesstailoringRow`).addClass('sno');
    }
    if (businessDtls.hasOwnProperty('Other') && otherData.length !== 0) {
        $(`#${reViewcnfrm}businessotherRow`).removeClass('sno');
        otherData.forEach(function(item, index) {
            if (index > 0) {
                ApzCOB.cloneDashboardDivs('CrdAss__CaReviewConfirm__otherSubrow_0', $('#CrdAss__CaReviewConfirm__businessotherCol'), index
                    .toString());
            }
            let otherKey = businessKeysArray.find(key => key === "Other");
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherHeading_txtcnt`).text(
                `Business ${businessCounter}`);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherTypeVal_txtcnt`).text(otherKey);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherOwnedVal_txtcnt`).text(item?.otherType);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherLineBus_txtcnt`).text(item
                ?.lineOfOtherBusiness);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherNetBusInc_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.netBusinessIncome));
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherTitle_txtcnt`).text(ApzCOB
                .getDescfromLitCode("LIT_otherBusiness_coApp") + ' - ' + item?.otherType);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__OtherLineBusiness_txtcnt`).text(item
                ?.lineOfOtherBusiness);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherTenure_txtcnt`).text(item
                ?.otherBusinessTenure);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherPremise_txtcnt`).text(item
                ?.businessAddressSameAsResidance);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__typeBusOther_txtcnt`).text(item
                ?.otherBusinessType);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherOrganisation_txtcnt`).text(item
                ?.nameOfOrganization);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherSalesPerDay_txtcnt`).text(item?.salesPerDay);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__othernoOfDaysMonth_txtcnt`).text(item
                ?.numberOfOperatingDays);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__othermonthSales_txtcnt`).text(ApzCOB.formatamountVal(item?.monthlySales));
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherOperExp_txtcnt`).text(ApzCOB.formatamountVal(item
            ?.operatingExpense));
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__othergrossInc_txtcnt`).text(ApzCOB.formatamountVal(item?.grossIncome));
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__otherrentLease_txtcnt`).text(item?.rentOrLease);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__salaryWageNoEmplyee_txtcnt`).text(item
                ?.numberOfEmployees);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__salaryPaidPerMonth_txtcnt`).text(item
                ?.salaryPaidPerMonth);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__totalSalary_txtcnt`).text(ApzCOB.formatamountVal(item?.totalSalary));
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__utilitiesTransCom_txtcnt`).text(item
                ?.transportAndCommunication);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__utilitiesWaterBill_txtcnt`).text(item?.waterBill);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__utilitiesElectricityBill_txtcnt`).text(item
                ?.electricityBill);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__utilitiesPipedBill_txtcnt`).text(item?.gasBill);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__utilitiesTeleBill_txtcnt`).text(item
                ?.telephoneBill);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__utilitiesOthers_txtcnt`).text(item?.otherBills);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__totalutilities_txtcnt`).text(item
            ?.totalUtilities);
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__obligationsOtherExp_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.otherBusinessExpense));
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__obligationsTotalExp_txtcnt`).text(ApzCOB.formatamountVal(item
                ?.totalBusinessExpenses));
            $(`#CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__obligationsNetBusiness_txtcnt`).text(ApzCOB.formatamountVal(item?.netBusinessIncome));
            custTypeForImages = item?.otherType;
            apz.app.CaReviewConfirm.paintDocumentName(
                `CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__OtherUploadedImage_0`,
                `CrdAss__CaReviewConfirm__otherSubrow_${index} #CrdAss__CaReviewConfirm__Other_ParentBusRow`, "Other Doc");
            businessCounter++;
        })
    } else {
        $(`#${reViewcnfrm}businessotherRow`).addClass('sno');
    }
}
apz.app.CaReviewConfirm.paintAgricultureData = function() {
    if (incomeDtls.hasOwnProperty('agriculture') || apz.isObjectEmpty(incomeDtls.agriculture)) {
        $(`#${reViewcnfrm}agricultureDetailRow`).addClass('sno');
    }
    if (!apz.isObjectEmpty(incomeDtls.agriculture) && incomeDtls.agriculture.hasOwnProperty('applicant')) {
        $(`#${reViewcnfrm}agricultureDetailRow`).removeClass('sno');
        $(`#${reViewcnfrm}agriBothchecked`).addClass('sno');
        $(`#${reViewcnfrm}Apptitle`).addClass('sno');
        $(`#${reViewcnfrm}agriApplicantRow`).removeClass('sno');
        $(`#${reViewcnfrm}agriCoapplicantRow`).addClass('sno');
        $(`#${reViewcnfrm}agrOwnedby_txtcnt`).text("applicant");
        $(`#${reViewcnfrm}agrlandType_txtcnt`).text(incomeDtls?.agriculture?.applicant?.typeOfAgriculture);
        $(`#${reViewcnfrm}agrcropType_txtcnt`).text(incomeDtls?.agriculture?.applicant?.cropType);
        $(`#${reViewcnfrm}agriCrop_txtcnt`).text(incomeDtls?.agriculture?.applicant?.crop);
        $(`#${reViewcnfrm}agriclutureLandrange_txtcnt`).text(incomeDtls?.agriculture?.applicant?.land);
        $(`#${reViewcnfrm}agriclutureLand_txtcnt`).text(incomeDtls?.agriculture?.applicant?.landInAcres);
        $(`#${reViewcnfrm}maxPeracre_txtcnt`).text(incomeDtls?.agriculture?.applicant?.maxYeildPerAcre);
        $(`#${reViewcnfrm}agrIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.applicant?.monthlyIncome));
        $(`#${reViewcnfrm}agrConIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.applicant?.consideredIncome));
        $(`#${reViewcnfrm}agrDeclIncMntly_txtcnt`).text(incomeDtls?.agriculture?.applicant?.declaredIncome);
        custTypeForImages = "Applicant";
        apz.app.CaReviewConfirm.paintDocumentName("CrdAss__CaReviewConfirm__AggAppCloneRow_0", "CrdAss__CaReviewConfirm__AggAppParentRow",
            "Agriculture Doc")
    }
    if (incomeDtls.agriculture.hasOwnProperty('coApplicant')) {
        $(`#${reViewcnfrm}agricultureDetailRow`).removeClass('sno');
        $(`#${reViewcnfrm}agriBothchecked`).addClass('sno');
        $(`#${reViewcnfrm}agriApplicantRow`).addClass('sno');
        $(`#${reViewcnfrm}CoApptitle`).addClass('sno');
        $(`#${reViewcnfrm}agriCoapplicantRow`).removeClass('sno');
        $(`#${reViewcnfrm}agrCoownedby_txtcnt`).text("CoApplicant");
        $(`#${reViewcnfrm}agrColandType_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.typeOfAgriculture);
        $(`#${reViewcnfrm}agrCocropType_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.cropType);
        $(`#${reViewcnfrm}agrCocrop_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.crop);
        $(`#${reViewcnfrm}CoagriclutureLandrange_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.land);
        $(`#${reViewcnfrm}CoagriclutureLand_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.landInAcres);
        $(`#${reViewcnfrm}ComaxPeracre_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.maxYeildPerAcre);
        $(`#${reViewcnfrm}CoagrIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.coApplicant?.monthlyIncome));
        $(`#${reViewcnfrm}CoagrConIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.coApplicant?.consideredIncome));
        $(`#${reViewcnfrm}CoagrDeclIncMntly_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.declaredIncome);
        custTypeForImages = "Co-Applicant"
        apz.app.CaReviewConfirm.paintDocumentName("CrdAss__CaReviewConfirm__AggCoAppCloneRow_0", "CrdAss__CaReviewConfirm__AggCoAppParentRow",
            "Agriculture Doc")
    }
    if (!apz.isObjectEmpty(incomeDtls.agriculture) && incomeDtls.agriculture.hasOwnProperty('applicant') && incomeDtls.agriculture.hasOwnProperty(
            'coApplicant')) {
        $(`#${reViewcnfrm}agriBothchecked`).removeClass('sno');
        $(`#${reViewcnfrm}agriApplicantRow`).removeClass('sno');
        $(`#${reViewcnfrm}agriCoapplicantRow`).removeClass('sno');
        $(`#${reViewcnfrm}Apptitle`).removeClass('sno');
        $(`#${reViewcnfrm}CoApptitle`).removeClass('sno');
    }
}
