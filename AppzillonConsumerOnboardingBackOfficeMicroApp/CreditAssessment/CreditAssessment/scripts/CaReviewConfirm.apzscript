}
apz.app.CaReviewConfirm.paintrentalIncomeData = function() {
    if (incomeDtls.hasOwnProperty('rentalIncome') || apz.isObjectEmpty(incomeDtls.rentalIncome)) {
        $(`#${reViewcnfrm}rentalIncomeRow`).addClass('sno');
    }
    if (!apz.isObjectEmpty(incomeDtls.rentalIncome) && incomeDtls.rentalIncome.hasOwnProperty('applicant')) {
        $(`#${reViewcnfrm}rentalIncomeRow`).removeClass('sno');
        $(`#${reViewcnfrm}rentalcheckboth`).addClass('sno');
        $(`#${reViewcnfrm}rentalApprow`).removeClass('sno');
        $(`#${reViewcnfrm}rentalCoapprow`).addClass('sno');
        $(`#${reViewcnfrm}rentalAppInomeMonth_txtcnt`).text(incomeDtls?.rentalIncome?.applicant?.monthlyRentalIncome);
        $(`#${reViewcnfrm}AppbuildingType_txtcnt`).text(incomeDtls?.rentalIncome?.applicant?.buildingType);
        $(`#${reViewcnfrm}rentalAppConInomeMonth_txtcnt`).text(incomeDtls?.rentalIncome?.applicant?.consideredMonthlyIncome);
        custTypeForImages = "Applicant";
        apz.app.CaReviewConfirm.paintDocumentName("CrdAss__CaReviewConfirm__rentalIncomeAppCLoneRow_0",
            "CrdAss__CaReviewConfirm__rentalIncomeAppParentRow", "Rentalincome_Agg Doc")
    }
    if (!apz.isObjectEmpty(incomeDtls.rentalIncome) && incomeDtls.rentalIncome.hasOwnProperty('coApplicant')) {
        $(`#${reViewcnfrm}rentalIncomeRow`).removeClass('sno');
        $(`#${reViewcnfrm}rentalcheckboth`).addClass('sno');
        $(`#${reViewcnfrm}rentalApprow`).addClass('sno');
        $(`#${reViewcnfrm}rentalCoapprow`).removeClass('sno');
        $(`#${reViewcnfrm}rentCoAppIncomeMonth_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.rentalIncome?.coApplicant?.monthlyRentalIncome));
        $(`#${reViewcnfrm}cobuildingType_txtcnt`).text(incomeDtls?.rentalIncome?.applicant?.buildingType);
        $(`#${reViewcnfrm}rentalCoAppConInomeMonth_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.rentalIncome?.coApplicant?.consideredMonthlyIncome));
        custTypeForImages = "Co-Applicant";
        apz.app.CaReviewConfirm.paintDocumentName("CrdAss__CaReviewConfirm__rentalIncomeCoAppCLoneRow_0",
            "CrdAss__CaReviewConfirm__rentalIncomeCoAppParentRow", "Rentalincome_Agg Doc")
    }
    if (!apz.isObjectEmpty(incomeDtls.rentalIncome) && incomeDtls.rentalIncome.hasOwnProperty('applicant') && incomeDtls.rentalIncome
        .hasOwnProperty('coApplicant')) {
        $(`#${reViewcnfrm}rentalcheckboth`).removeClass('sno');
        $(`#${reViewcnfrm}rentalApprow`).removeClass('sno');
        $(`#${reViewcnfrm}rentalCoapprow`).removeClass('sno');
    }
}
apz.app.CaReviewConfirm.launchNextStage = function() {
    let req = {
        "apiRequest": {
            "requestObj": {
                "appId": gAppId,
                "applicationId": gApzCOB.userDetails.applicationId,
                "versionNum": 1,
                "stageId": CA_CURRENT_STAGE_NO,
                "requestType": "Verify",
                "customerType": "Applicant",
                "editedFields": []
            },
            "userId": LoggedInUserDetails.loginResponse.userDet.id,
            "appId": gAppId,
            "interfaceName": "UploadCALoanData"
        }
    }
    apz.startLoader();
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, "UploadCALoanData", "N", "N", req, false, apz.app.CaReviewConfirm.launchNextStageCB);
    }, 1000)
}
apz.app.CaReviewConfirm.launchNextStageCB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            let errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            apz.app.Cabase.BRECbService();
        } else {
            apz.stopLoader();
            ApzCOB.showCaModals({
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.Cabase.closeCaErrMdl()"
                }
            }, "Error");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.showCaModals({
            text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
    }
}
apz.app.CaReviewConfirm.paintDocumentName = function(clonebleDiv, parentdiv, documentType) {
    if (apz.isObjectEmpty(inSessionStore) || !inSessionStore.hasOwnProperty('applicationDocumentsWrapperList')) return;
    let i = 1;
    let documentResp = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList
    if (documentResp.length > 0) {
        if (documentType !== "proof with owner doc" && documentType !== 'SupportDocs') {
            window.SupportDocs = documentResp.filter(doc => doc.payload.documentType === documentType/* && doc.docLevel == businessCounter*/);
        } else {
            window.SupportDocs = documentResp.filter(doc => doc.payload.documentType === documentType && parseInt(doc.custDtlId) === parseInt(gApzCOB
                .userDetails.custDtlId));
        }
        if (SupportDocs.length > 0) {
            let cloneDiv = clonebleDiv;
            let parentDiv = $("#" + parentdiv);
            parentDiv.html('');
            SupportDocs.forEach((doc, index) => {
                let newId = ApzCOB.cloneDashboardDivs(cloneDiv, parentDiv, index + 1);
                if (doc.payload.documentType !== "proof with owner doc" && doc.payload.documentType !== 'SupportDocs') {
                    $(`#${parentdiv} #${newId} a.ett-hypl span`).text(`${doc.payload.documentType.split(" Doc")[0]}_${index + 1}.jpg`);
                } else {
                    let baseName = doc.payload.documentFileName.match(/^[^\d]+/)[0];
                    $(`#${parentdiv} #${newId} a.ett-hypl span`).text(`${baseName}_${i}.jpg`);
                    i++;
                }
                $(`#${parentdiv} #${newId}`).attr('data-id', doc.appDocId);
                $(`#${parentdiv} #${newId} .updel .scb-col15 .ett-para span`).text(`${Math.floor(doc.payload.docSize / 1024)} KB`);
                $(`#${parentdiv} #${newId}`).removeClass('sno');
            })
        }
    }
}
apz.app.CaReviewConfirm.viewDocument = function(pthis) {
    let documentId = $(pthis).parents('.shwdtl').attr('data-id');
    if (!documentId) {
        documentId = $(pthis).parents('.uploadimg').attr('data-id');
    }
    let docDetails = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.find(doc => parseInt(doc.appDocId) === parseInt(
        documentId));
    if (!apz.isObjectEmpty(docDetails)) {
        let fileName = docDetails?.payload?.documentFileName;
        let callBackFn = apz.app.CaReviewConfirm.viewDocumentCB;
        window.ImageLocationDetails = {
            latitude: docDetails?.payload.latitude || "",
            longitude: docDetails?.payload.longitude || "",
            uploadedTs: docDetails?.payload.uploadedTs || "",
            documentFileName: docDetails?.payload.documentFileName || ""
        };
        ApzCOB.downloadFileFromServer(fileName, callBackFn);
    }
}
apz.app.CaReviewConfirm.viewDocumentCB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.base64)) {
        $(`#${reViewcnfrm}imgView`).attr('src', 'data:image/png;base64,' + params.base64);
        if (Object.keys(window.ImageLocationDetails).length > 0) {
            apz.app.BaseScreens.paintImageLocationDetails(`#${reViewcnfrm}imgView`, window.ImageLocationDetails);
        }
        ApzCOB.toggleModal(`${reViewcnfrm}docViewModal`);
    } else {
        ApzCOB.fnDisplayMsg("Document is not available")
    }
}
apz.app.CaReviewConfirm.getPresentIncomeSources = function() {
    incomeDtls = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload);
    const incomeDtlsKeys = Object.keys(incomeDtls || {});
    const ignoreKeys = ["applicantTotalIncome", "coApplicantTotalIncome", "otherFamilyIncome", "fieldAssessedIncome", "fieldAssessedIncomeDate",
        "homeMaker"
    ];
    const incomeSources = [];
    incomeDtlsKeys.forEach(key => {
        if (ignoreKeys.includes(key)) return;
        const value = incomeDtls[key];
        const isObjectWithData = typeof value === "object" && value !== null && (
            (Array.isArray(value) && value.length > 0) || Object.values(value).some(v => v && (typeof v === "object" ? Object.keys(v)
                .length > 0 : true)));
        if (isObjectWithData) {
            const readableName = key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase()).trim();
            incomeSources.push(readableName);
        }
    });
    return incomeSources;
};
apz.app.CaReviewConfirm.paintNetIncome = function() {
    const safeGet = (obj, path) => path.split('.').reduce((o, k) => (o && o[k] !== undefined ? o[k] : undefined), obj);
    const sumFields = (objA, keyA, objB, keyB) => {
        const a = Number(safeGet(objA, keyA)) || 0;
        const b = Number(safeGet(objB, keyB)) || 0;
        return a + b;
    };
    const textOrBlank = val => val > 0 ? `₹ ${val}` : "";
    const agriIncome = sumFields(incomeDtls.agriculture?.applicant, "consideredIncome", incomeDtls.agriculture?.coApplicant, "consideredIncome");
    $("#CrdAss__CaReviewConfirm__OtherInc1_income").text(ApzCOB.formatIndianRupees(agriIncome));
    const salaryIncome = sumFields(incomeDtls.salary?.applicant, "netSalary", incomeDtls.salary?.coApplicant, "netSalary");
    $("#CrdAss__CaReviewConfirm__OtherInc2_income").text(ApzCOB.formatIndianRupees(salaryIncome));
    const pensionIncome = sumFields(incomeDtls.pension?.applicant, "applicantPensionIncome", incomeDtls.pension?.coApplicant,
        "coApplicantPensionIncome");
    $("#CrdAss__CaReviewConfirm__OtherInc4_income").text(ApzCOB.formatIndianRupees(pensionIncome));
    const sumWageIncome = (wageData = {}) => {
        const categories = ["farmWorker", "contractLabour", "constructions", "maid", "hotelWorker", "other"];
        return categories.reduce((sum, cat) => {
            const val = Number(safeGet(wageData, `${cat}.totalWagePerMonth`)) || 0;
            return sum + val;
        }, 0);
    };
    const wageIncome = sumWageIncome(incomeDtls.wage?.applicant) + sumWageIncome(incomeDtls.wage?.coApplicant);
    $("#CrdAss__CaReviewConfirm__OtherInc3_income").text(ApzCOB.formatIndianRupees(wageIncome));
    const rentIncome = sumFields(incomeDtls.rentalIncome?.applicant, "consideredMonthlyIncome", incomeDtls.rentalIncome?.coApplicant,
        "consideredMonthlyIncome");
    $("#CrdAss__CaReviewConfirm__OtherInc5_income").text(ApzCOB.formatIndianRupees(rentIncome));
    const businessData = incomeDtls.business || {};
    const getBusinessIncomeSumByType = (arrayKey, typeKey, incomeField = "netBusinessIncome") => {
        const list = businessData[arrayKey] || [];
        return list.reduce((sum, item) => {
            const type = item?.[typeKey];
            const income = Number(item?.[incomeField]) || 0;
            if (type === "Applicant" || type === "Co-Applicant" || type === "Both") {
                return sum + income;
            }
            return sum;
        }, 0);
    };
    const tailoringIncome = getBusinessIncomeSumByType("Tailoring", "tailoringType", "netBusinessIncome");
    $("#CrdAss__CaReviewConfirm__business3_income").text(ApzCOB.formatIndianRupees(tailoringIncome));
    const kiranaIncome = getBusinessIncomeSumByType("Kirana", "kiranaType", "finalNetIncome");
    $("#CrdAss__CaReviewConfirm__business2_income").text(ApzCOB.formatIndianRupees(kiranaIncome));
    const otherIncome = getBusinessIncomeSumByType("Other", "otherType", "netBusinessIncome");
    $("#CrdAss__CaReviewConfirm__business4_income").text(ApzCOB.formatIndianRupees(otherIncome));
    const dairyIncome = getBusinessIncomeSumByType("dairy", "DairyType", "IncomeAssessmentChecknetBusinessIncome");
    $("#CrdAss__CaReviewConfirm__business1_income").text(ApzCOB.formatIndianRupees(dairyIncome));
    $("#CrdAss__CaReviewConfirm__OtherInc10_income").text("₹ 0");
    const totalIncome = agriIncome + salaryIncome + pensionIncome + wageIncome + rentIncome + tailoringIncome + kiranaIncome + otherIncome +
        dairyIncome;
    $("#CrdAss__CaReviewConfirm__totalHousehldIncValue").text(`₹ ${ApzCOB.formatamountVal(totalIncome)}`);
    $("#CrdAss__CaReviewConfirm__totalDeclaredIncValue").text(
        `₹ ${ApzCOB.formatamountVal(parseInt(JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || "{}")?.totalDeclaredIncome) || 0)}`);
    //$("#CrdAss__CaReviewConfirm__tot_income_app").text(`₹ ` + incometot.applicantTotalIncome);
    $("#CrdAss__CaReviewConfirm__tot_income_app").text(`₹ ${ApzCOB.formatamountVal(incomeDtls.applicantTotalIncome)}`);
    $("#CrdAss__CaReviewConfirm__tot_income_coapp").text(`₹ ` + incomeDtls.coApplicantTotalIncome);
    $("#CrdAss__CaReviewConfirm__tot_income_appCoapp").text(`₹ ` + (incomeDtls.otherIncome));
    $("#CrdAss__CaReviewConfirm__tot_income_family").text(`₹ ` + incomeDtls.otherFamilyIncome);
    $("#CrdAss__CaReviewConfirm__tot_income_assessment").text(`₹ ` + incomeDtls.fieldAssessedIncome);
    const dateObj = incomeDtls.fieldAssessedIncomeDate?.date;
    const formattedDate = dateObj ? `${String(dateObj.day).padStart(2, '0')}-${String(dateObj.month).padStart(2, '0')}-${dateObj.year}` : '';
    $("#CrdAss__CaReviewConfirm__income_ass_date").text(formattedDate);
    apz.app.CaReviewConfirm.paintIncomeOwnershipDetails();
};
apz.app.CaReviewConfirm.getIncomeSourceOwnership = function() {
    const result = {};
    const checkPresence = (app, coApp) => {
        const hasApplicant = !!app && Object.keys(app).length > 0;
        const hasCoApplicant = !!coApp && Object.keys(coApp).length > 0;
        if (hasApplicant && hasCoApplicant) return "Both";
        if (hasApplicant) return "Applicant";
        if (hasCoApplicant) return "Co-Applicant";
        return "None";
    };
    result.agriculture = checkPresence(incomeDtls.agriculture?.applicant, incomeDtls.agriculture?.coApplicant);
    result.salary = checkPresence(incomeDtls.salary?.applicant, incomeDtls.salary?.coApplicant);
    result.pension = checkPresence(incomeDtls.pension?.applicant, incomeDtls.pension?.coApplicant);
    result.rentalIncome = checkPresence(incomeDtls.rentalIncome?.applicant, incomeDtls.rentalIncome?.coApplicant);
    result.wage = checkPresence(incomeDtls.wage?.applicant, incomeDtls.wage?.coApplicant);
    result.tailoring = (incomeDtls.business?.Tailoring || []).map(item => item.tailoringType);
    result.kirana = (incomeDtls.business?.Kirana || []).map(item => item.kiranaType);
    result.otherBusiness = (incomeDtls.business?.Other || []).map(item => item.otherType);
    result.dairy = (incomeDtls.business?.dairy || []).map(item => item.DairyType);
    const homeMaker = incomeDtls.homeMaker;
    result.homeMaker = homeMaker === "Applicant" || homeMaker === "Co-Applicant" ? homeMaker : "None";
    return result;
}
apz.app.CaReviewConfirm.paintIncomeOwnershipDetails = function() {
    const ownership = apz.app.CaReviewConfirm.getIncomeSourceOwnership();
    const formatOwnership = (value) => {
        if (Array.isArray(value)) return value.join(', ');
        return value || "None";
    };
    $(`#${reViewcnfrm}OtherInc1_ownedBy`).text(ownership.agriculture);
    $(`#${reViewcnfrm}OtherInc2_ownedBy`).text(ownership.salary);
    $(`#${reViewcnfrm}OtherInc4_ownedBy`).text(ownership.pension);
    $(`#${reViewcnfrm}OtherInc5_ownedBy`).text(ownership.rentalIncome);
    $(`#${reViewcnfrm}OtherInc3_ownedBy`).text(ownership.wage);
    $(`#${reViewcnfrm}business3_ownedBy`).text(formatOwnership(ownership.tailoring) || 'None');
    $(`#${reViewcnfrm}business2_ownedBy`).text(formatOwnership(ownership.kirana) || 'None');
    $(`#${reViewcnfrm}business4_ownedBy`).text(formatOwnership(ownership.otherBusiness) || 'None');
    $(`#${reViewcnfrm}business1_ownedBy`).text(formatOwnership(ownership.dairy)?.replace(/^,\s*/, '')  || 'None');
};
