apz.app.CaInPrincipleDecision.previewInformalLoanObligation = function() {
    let loanObgdata = JSON.parse(inSessionStore?.bcmpiLoanObligations?.payload);
    let removeTloanObgkey = delete loanObgdata.totalLoanObligations;
    let loanObgkeys = Object.keys(loanObgdata).toString();
    $(`#${CaInPrincipleDecisionScrId}SrcInfrmlObg_txtcnt`).text(loanObgkeys);
    if (apz.isNull(loanObgkeys)) {
        $(`#${CaInPrincipleDecisionScrId}previewSrcInfrmlObg_txtcnt`).text("Nill");
    } else {
        $(`#${CaInPrincipleDecisionScrId}previewSrcInfrmlObg_txtcnt`).text(loanObgkeys);
    }
    let nilflag = true;
    if (loanObgdata.hasOwnProperty('chitFunds')) {
        nilflag = false;
        $(`#${CaInPrincipleDecisionScrId}RechitFund`).removeClass('sno')
        $(`#${CaInPrincipleDecisionScrId}othrLoanObgchit_txtcnt`).text(ApzCOB.formatamountVal(loanObgdata?.chitFunds?.otherLoanObligation))
