window.CA_CURRENT_STAGE = "InPrincipleDecision";
window.CURRENTSCREEN = "CaInPrincipleDecision"
window.AppcustomerId = "";
window.CoAppcustomerId = "";
inPrincipleStageClicked = true;
var incomeDtls = "",
    custTypeInPrinciple = "",
    AppCustCibilData,
    CoAppCustCibilData,
    CaInPrincipleDecisionScrId = "CrdAss__CaInPrincipleDecision__",
    ShowLoanAmtErrorModal = false;
var container = ["eligibleLoanNav1", "eligibleLoanForm1", "eligibleLoanNav2", "eligibleLoanForm2", "decisionNav1", "decisionForm1", "decisionNav2",
    "decisionForm2",];
var eligibleLoans = ["eligibleLoanNav1", "eligibleLoanForm1", "eligibleLoanNav2", "eligibleLoanForm2",]; /* to be used for deviation metric */
var newEligibleLoans = ["eligibleLoanNav1", "eligibleLoanForm1"];
var decisionDtls = ["decisionNav1", "decisionForm1", "decisionNav2", "decisionForm2",];
apz.app.onLoad_CaInPrincipleDecision = function() {};
apz.app.onShown_CaInPrincipleDecision = function() {
    apz.childScr = "CaInPrincipleDecision";
    container.hide();
    newEligibleLoans.show();
    apz.app.CaInPrincipleDecision.paintData();
    $(`#${CaInPrincipleDecisionScrId}eligibleBtn`).addClass("active");
    apz.app.Cabase.hideShowBtnBasedOnScreen();
    window.CA_CURRENT_STAGE_NO = CA_ALL_STAGE_FIELDS.find(stage => stage.stageName === CA_CURRENT_STAGE)?.id;
    if (CoAppCustCibilData[0]?.cibilDetails?.payload?.finalDecision?.indexOf("Approved") !== -1) {
        $("#CrdAss__CaInPrincipleDecision__el_txt_1").removeClass("sno");
        $("#CrdAss__CaInPrincipleDecision__el_txt_127_ul").addClass("sno");
        $("#CrdAss__Cabase__submitBtn").removeClass("sno");
    } else {
        $("#CrdAss__CaInPrincipleDecision__el_txt_127_ul").removeClass("sno");
        $("#CrdAss__CaInPrincipleDecision__el_txt_1").addClass("sno");
        $("#CrdAss__Cabase__submitBtn").addClass("sno");
    }
};
apz.app.CaInPrincipleDecision.hideAndShowTabs = function(lparam) {
    container.hide();
    if (lparam === "Eligible") {
        newEligibleLoans.show();
        $(`#${CaInPrincipleDecisionScrId}eligibleBtn`).addClass("active");
        $(`#${CaInPrincipleDecisionScrId}decisionBtn`).removeClass("active");
    } else {
        decisionDtls.show();
        $(`#${CaInPrincipleDecisionScrId}decisionBtn`).addClass("active");
        $(`#${CaInPrincipleDecisionScrId}eligibleBtn`).removeClass("active");
    }
};
apz.app.CaInPrincipleDecision.paintData = function() {
    window.AppcustomerId = ApzCOB.getCustDetailID("Applicant");
    window.CoAppcustomerId = ApzCOB.getCustDetailID("Co-App");
    if (Array.isArray(inSessionStore?.cibilDetailsWrapperList)) {
        AppCustCibilData = inSessionStore.cibilDetailsWrapperList.filter(
            (item) => item.cibilDetails?.custDtlId == AppcustomerId);
        CoAppCustCibilData = inSessionStore.cibilDetailsWrapperList.filter(
            (item) => item.cibilDetails?.custDtlId == CoAppcustomerId);
    }
    let totalInsuranceCharge = Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.insuranceChargeJoint) + Number(CoAppCustCibilData[0]
        ?.cibilDetails?.payload?.insuranceChargeMember) + Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.insuranceChargeSpouse);
    if (inSessionStore.hasOwnProperty('leadDetails')) {
        $(`#${CaInPrincipleDecisionScrId}currOutVal`).text(`₹ ${Number(inSessionStore.leadDetails?.caglOs).toLocaleString('en-IN')}`);
        $(`#${CaInPrincipleDecisionScrId}currOutValCmn`).text(`₹ ${Number(inSessionStore?.leadDetails?.caglOs).toLocaleString('en-IN')}`);
    } else if (inSessionStore.hasOwnProperty('renewalLeadDetails')) {}
    $(`#${CaInPrincipleDecisionScrId}cbTriggerDate`).text(`Current CAGL outstanding (As of ${ApzCOB.getCBTriggerDate() || ''})`);
    $(`#${CaInPrincipleDecisionScrId}cbTriggerDateCmn`).text(`Current CAGL outstanding (As of ${ApzCOB.getCBTriggerDate() || ''})`);
    let netOffAmt = Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.processingFees || 0) + Number(totalInsuranceCharge || 0) + Number(
        CoAppCustCibilData[0]?.cibilDetails?.payload?.stampDutyCharge || 0) + Number(inSessionStore.leadDetails?.caglOs || inSessionStore
        .renewalLeadDetails?.caglOs || 0);
    netOffAmt = netOffAmt.toFixed(2)
    let totalPostNetOff = Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.eligibleAmt || 0) - netOffAmt;
    totalPostNetOff = totalPostNetOff.toFixed(2)
    $(`#${CaInPrincipleDecisionScrId}processingFeeVal`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.processingFees ?
        `₹ ${Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.processingFees).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}insPremVal`).text(totalInsuranceCharge ? `₹ ${Number(totalInsuranceCharge).toLocaleString('en-IN')}` : "₹ 0");
    $(`#${CaInPrincipleDecisionScrId}stmpDutyVal`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.stampDutyCharge ?
        `₹ ${Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.stampDutyCharge).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}netOffAmtVal`).text(netOffAmt ? `₹ ${Number(netOffAmt).toLocaleString('en-IN')}` : "₹ 0");
    $(`#${CaInPrincipleDecisionScrId}TotalAmtPostVal`).text(totalPostNetOff ? `₹ ${Number(totalPostNetOff).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}lnAmtVal`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.eligibleAmt ?
        `₹ ${Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.eligibleAmt).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}roiVal`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.roi ?
        `${CoAppCustCibilData[0]?.cibilDetails?.payload?.roi}%` : "");
    $(`#${CaInPrincipleDecisionScrId}freqVal`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.approvedLoanEMI && inSessionStore?.loanDetails
        ?.payload?.frequencyOfRepayment ?
        `₹ ${Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.approvedLoanEMI).toLocaleString('en-IN')} / ${inSessionStore?.loanDetails?.payload?.frequencyOfRepayment}` :
        "");
    // Common Field
    $(`#${CaInPrincipleDecisionScrId}cbScoreApp`).text(AppCustCibilData[0]?.cibilDetails?.payload?.cbScore || "");
    $(`#${CaInPrincipleDecisionScrId}cbScoreCoApp`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.cbScore || "");
    $(`#${CaInPrincipleDecisionScrId}foirVal`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.foirPercentage ?
        `${CoAppCustCibilData[0].cibilDetails.payload.foirPercentage}%` : "");
    $(`#${CaInPrincipleDecisionScrId}lnAmtValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.eligibleAmt ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.eligibleAmt).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}roiValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.roi ?
        `${CoAppCustCibilData[0].cibilDetails.payload.roi}%` : "");
    $(`#${CaInPrincipleDecisionScrId}netIncVal`).text(JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.fieldAssessedIncome ?
        `₹ ${Number(JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.fieldAssessedIncome).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}processingFeeValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.processingFees ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.processingFees).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}insPremValCmn`).text(totalInsuranceCharge ? `₹ ${Number(totalInsuranceCharge).toLocaleString('en-IN')}` :
    "₹ 0");
    $(`#${CaInPrincipleDecisionScrId}stmpDutyValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.stampDutyCharge ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.stampDutyCharge).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}netOffAmtValCmn`).text(netOffAmt ? `₹ ${Number(netOffAmt).toLocaleString('en-IN')}` : "₹ 0");
    $(`#${CaInPrincipleDecisionScrId}TotalAmtPostValCmn`).text(totalPostNetOff ? `₹ ${Number(totalPostNetOff).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}freqValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.approvedLoanEMI && inSessionStore
        ?.loanDetails?.payload?.frequencyOfRepayment ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.approvedLoanEMI).toLocaleString('en-IN')} / ${inSessionStore.loanDetails.payload.frequencyOfRepayment}` :
        "");
    $(`#${CaInPrincipleDecisionScrId}recLnAmtVal`).val(CoAppCustCibilData[0]?.cibilDetails?.payload?.eligibleAmt ? `₹ ${Number(CoAppCustCibilData[0]
        .cibilDetails.payload.eligibleAmt).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}overDueAmtValApp`).text(AppCustCibilData?.[0]?.cibilDetails?.payload?.overdueAmt?.includes(":") &&
        AppCustCibilData[0].cibilDetails.payload.overdueAmt.includes("|") ?
        `₹ ${Number(AppCustCibilData[0].cibilDetails.payload.overdueAmt.split(":")[1].split("|")[0].trim()).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}overDueAmtValCoApp`).text(CoAppCustCibilData?.[0]?.cibilDetails?.payload?.overdueAmt?.includes(":") &&
        CoAppCustCibilData[0].cibilDetails.payload.overdueAmt.includes("|") ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.overdueAmt.split(":")[1].split("|")[0].trim()).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}writtOffAmtApp`).text(AppCustCibilData?.[0]?.cibilDetails?.payload?.writeOffAmt?.includes(":") &&
        AppCustCibilData[0].cibilDetails.payload.writeOffAmt.includes("|") ?
        `₹ ${Number(AppCustCibilData[0].cibilDetails.payload.writeOffAmt.split(":")[1].split("|")[0].trim()).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}writtOffAmtCoApp`).text(CoAppCustCibilData?.[0]?.cibilDetails?.payload?.writeOffAmt?.includes(":") &&
        CoAppCustCibilData[0].cibilDetails.payload.writeOffAmt.includes("|") ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.writeOffAmt.split(":")[1].split("|")[0].trim()).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}unsecIndebtVal`).text(CoAppCustCibilData?.[0]?.cibilDetails?.payload?.totIndebtness?.includes(":") &&
        CoAppCustCibilData[0].cibilDetails.payload.totIndebtness.includes("|") ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.totIndebtness.split(":")[1].split("|")[0].trim()).toLocaleString('en-IN')}` :
        "");
    apz.app.Cabase.paintSendbackreasons();
};
apz.app.CaInPrincipleDecision.downloadCBReport = function(lparams) {
    window.CB_LOAN_ID = '';
    let custDetailID = '';
    if (lparams === 'CamSheetReport' || lparams === 'LoanApplicationReport') {
        CB_LOAN_ID = `${lparams}_${gApzCOB.userDetails.applicationId}`
        req = {
            "apiRequest": {
                "requestObj": {
                    "appId": "APZCBO",
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "reportType": lparams,
                    "generateReport": true
                },
                "interfaceName": "GenerateAndDownloadReport"
            }
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "GenerateAndDownloadReport", "N", "N", req, false, ApzCOB.downloadBRECbReportCB);
    } else {
        if (lparams === 'cbReport_A') {
            custDetailID = AppcustomerId;
        } else {
            custDetailID = CoAppcustomerId;
        }
        CB_LOAN_ID = inSessionStore.cibilDetailsWrapperList.filter(el => el.cibilDetails.custDtlId === custDetailID)[0].cibilDetails.payload
            .cbLoanId;
        ApzCOB.downloadBRECbReport(custDetailID);
    }
};
apz.app.CaInPrincipleDecision.updateLoanAmount = function() {
    const inputEl = document.getElementById("CrdAss__CaInPrincipleDecision__recLnAmtVal");
    if (!inputEl) return;
    const lnAmtVal = inputEl.value || '';
    let updatedLnAmt = lnAmtVal.replace(/[^\d]/g, '');
    const numericAmt = Number(updatedLnAmt);
    const eligibleAmt = CoAppCustCibilData[0]?.cibilDetails?.payload?.eligibleAmt || 0;
    const numEligibleAmt = Number(eligibleAmt);
    const formattedAmt = numEligibleAmt.toLocaleString('en-IN');
    if (!updatedLnAmt || numericAmt === 0 || numericAmt < fdAmountMin || numericAmt > fdAmountMax || numericAmt > numEligibleAmt) {
        ApzCOB.showCaModals({
            text: "BM recommended loan amount should be in the range of 50,000 to " + formattedAmt,
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
        inputEl.value = `₹ ${formattedAmt}`;
        return;
    }
    let currentStage = `${inSessionStore?.applicationMaster?.applicationStatus} | ${CA_CURRENT_STAGE}`;
    let caglOs = gApzCOB?.selLeadDtls?.caglOs || inSessionStore?.leadDetails?.caglOs || inSessionStore?.renewalLeadDetails?.caglOs;
    const req = {
        "apiRequest": {
            "requestObj": {
                "appId": gAppId,
                "applicationId": gApzCOB.userDetails.applicationId,
                "versionNum": 1,
                "stageId": CA_CURRENT_STAGE_NO,
                "requestType": "Edit",
                "customerType": "Co-App",
                "updatedLoanAmount": updatedLnAmt,
                "customerDtlsId": CoAppcustomerId,
                "editedFields": [],
                "currentStage" : currentStage,
                "caglOs" : caglOs
            },
            "userId": LoggedInUserDetails.loginResponse.userDet.id,
            "appId": gAppId,
            "interfaceName": "UploadCALoanData"
        }
    };
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "UploadCALoanData", "N", "N", req, false, apz.app.CaInPrincipleDecision.updateLoanAmountCB);
};
apz.app.CaInPrincipleDecision.updateLoanAmountCB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let resp = params?.res?.APZCBO__UploadCALoanData_Res?.apiResponse?.ResponseBody ?? '';
            if (!apz.isNull(resp)) {
                let msg = resp?.responseObj ?? "";
                if (!apz.isNull(msg)) {
                    if (msg === 'BRE check service failed') {
                        ApzCOB.showCaModals({
                            text: 'BRE Service Failed.!',
                            Btn1: {
                                text: "OK",
                                onClick: "apz.app.Cabase.closeCaErrMdl()"
                            }
                        }, "Error");
                        // ApzCOB.revertRecommendedLoanAmount();
                    } else {
                        apz.stopLoader();
                        ApzCOB.updateInsessionData(params);
                        if (Array.isArray(inSessionStore?.cibilDetailsWrapperList)) {
                            AppCustCibilData = inSessionStore.cibilDetailsWrapperList.filter(
                                (item) => item.cibilDetails?.custDtlId == AppcustomerId);
                            CoAppCustCibilData = inSessionStore.cibilDetailsWrapperList.filter(
                                (item) => item.cibilDetails?.custDtlId == CoAppcustomerId);
                        }
                        if (CoAppCustCibilData[0]?.cibilDetails?.cbStatus !== 'PASS') {
                            $("#CrdAss__CaInPrincipleDecision__el_txt_127_ul").removeClass("sno");
                            $("#CrdAss__CaInPrincipleDecision__el_txt_1").addClass("sno");
                            $("#CrdAss__Cabase__submitBtn").addClass("sno");
                            apz.startLoader();
                            window.rejectRsn = CoAppCustCibilData[0]?.cibilDetails?.payload?.rejectionReason ?? "";
                            window.retry_Attempts = CoAppCustCibilData[0]?.cibilDetails?.payload?.retryAttempts ?? "";
                            let IrisMsg = CoAppCustCibilData[0]?.cibilDetails?.payload?.irisMessage;
                            if (!retry_Attempts || retry_Attempts === 0) {
                                let errMsgBRE = `CB Retrigger limit has been exceeded. Reject the application.<br/> Reject reason: ${window.rejectRsn}`;
                                if (IrisMsg?.includes('success')) {
                                    errMsgBRE = `BRE CB failed!. Reject the application.<br/> Reject reason: ${window.rejectRsn}`;
                                }
                                let popUpObj = {
                                    text: errMsgBRE,
                                    Btn: {
                                        text: "Reject",
                                        onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`); apz.app.Cabase.approveReject(this, 'REJECTED', true);"
                                    }
                                };
                                ApzCOB.showNewCommonErrorModal(popUpObj);
                                apz.stopLoader();
                                return;
                            } else {
                                let errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Remaining retry attempts: ${retry_Attempts}.<br/>Do you want to rehit BRE?`
                                if (IrisMsg.includes('bureauError') && !IrisMsg.includes('roll')) {
                                    errMsgBRE = `BRE failed due to ${rejectRsn}.<br/>Do you want to rehit BRE?`
                                }
                                popUpObj = {
                                    text: errMsgBRE,
                                    Btn1: {
                                        text: "Yes",
                                        onClick: "apz.app.Cabase.closeCaConfirmarionMdl(); $(`#CrdAss__CaInPrincipleDecision__recLnAmtVal`).blur();"
                                    },
                                    Btn2: {
                                        text: "No",
                                        onClick: "apz.app.Cabase.closeCaConfirmarionMdl()"
                                    }
                                }
                            }
                            apz.stopLoader();
                            ApzCOB.showCaModals(popUpObj, "confirmation");
                            apz.stopLoader();
                            return;
                        }
                        apz.app.CaInPrincipleDecision.updtDatawithBMRecAmt();
                    }
                }
            }
        } else {
            apz.stopLoader();
            ApzCOB.showCaModals({
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.Cabase.closeCaErrMdl()"
                }
            }, "Error");
            // ApzCOB.revertRecommendedLoanAmount();
        }
    } catch {
        apz.stopLoader();
        ApzCOB.showCaModals({
            text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
        // ApzCOB.revertRecommendedLoanAmount();
    }
}
apz.app.CaInPrincipleDecision.updtDatawithBMRecAmt = function() {
    let totalInsuranceCharge = Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.insuranceChargeJoint) + Number(CoAppCustCibilData[0]
        ?.cibilDetails?.payload?.insuranceChargeMember) + Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.insuranceChargeSpouse);
    if (inSessionStore.hasOwnProperty('leadDetails')) {
        $(`#${CaInPrincipleDecisionScrId}currOutValCmn`).text(inSessionStore.leadDetails?.caglOs ?
            `₹ ${Number(inSessionStore.leadDetails.caglOs).toLocaleString('en-IN')}` : "");
    } else if (inSessionStore.hasOwnProperty('renewalLeadDetails')) {
        $(`#${CaInPrincipleDecisionScrId}currOutValCmn`).text(inSessionStore.renewalLeadDetails?.caglOs ?
            `₹ ${Number(inSessionStore.renewalLeadDetails.caglOs).toLocaleString('en-IN')}` : "");
    }
    let netOffAmt = Number(CoAppCustCibilData[0]?.cibilDetails?.payload?.processingFees || 0) + Number(totalInsuranceCharge) + Number(
        CoAppCustCibilData[0]?.cibilDetails?.payload?.stampDutyCharge || 0) + Number(inSessionStore?.leadDetails?.caglOs || 0);
    let totalPostNetOff = Number(inSessionStore?.loanDetails?.bmRecommendedLoanAmount || 0) - netOffAmt;
    $(`#${CaInPrincipleDecisionScrId}lnAmtValCmn`).text(inSessionStore?.loanDetails?.bmRecommendedLoanAmount ?
        `₹ ${Number(inSessionStore.loanDetails.bmRecommendedLoanAmount).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}roiValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.roi ?
        `${CoAppCustCibilData[0].cibilDetails.payload.roi}%` : "");
    $(`#${CaInPrincipleDecisionScrId}netIncVal`).text(JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.fieldAssessedIncome ?
        `₹ ${Number(JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.fieldAssessedIncome).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}processingFeeValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.processingFees ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.processingFees).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}insPremValCmn`).text(totalInsuranceCharge ? `₹ ${Number(totalInsuranceCharge).toLocaleString('en-IN')}` :
    "₹ 0");
    $(`#${CaInPrincipleDecisionScrId}stmpDutyValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.stampDutyCharge ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.stampDutyCharge).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}netOffAmtValCmn`).text(netOffAmt ? `₹ ${Number(netOffAmt).toLocaleString('en-IN')}` : "₹ 0");
    $(`#${CaInPrincipleDecisionScrId}TotalAmtPostValCmn`).text(totalPostNetOff ? `₹ ${Number(totalPostNetOff).toLocaleString('en-IN')}` : "");
    $(`#${CaInPrincipleDecisionScrId}freqValCmn`).text(CoAppCustCibilData[0]?.cibilDetails?.payload?.approvedLoanEMI && inSessionStore
        ?.loanDetails?.payload?.frequencyOfRepayment ?
        `₹ ${Number(CoAppCustCibilData[0].cibilDetails.payload.approvedLoanEMI).toLocaleString('en-IN')} / ${inSessionStore.loanDetails.payload.frequencyOfRepayment}` :
        "");
    if (CoAppCustCibilData[0]?.cibilDetails?.payload?.finalDecision?.indexOf("Approved") !== -1) {
        $("#CrdAss__CaInPrincipleDecision__el_txt_1").removeClass("sno");
        $("#CrdAss__CaInPrincipleDecision__el_txt_127_ul").addClass("sno");
        $("#CrdAss__Cabase__submitBtn").removeClass("sno");
    } else {
        $("#CrdAss__CaInPrincipleDecision__el_txt_127_ul").removeClass("sno");
        $("#CrdAss__CaInPrincipleDecision__el_txt_1").addClass("sno");
        $("#CrdAss__Cabase__submitBtn").addClass("sno");
    }
}
apz.app.CaInPrincipleDecision.ValidateOnClickOfSubmit = function() {
    window.sendBackResponse = $(`#CrdAss__CaInPrincipleDecision__sendBackResponse`).val() || '';
    if (apz.isNull(sendBackResponse.trim()) && $('#CrdAss__CaInPrincipleDecision__sendBackResponseRow').is(":visible")) {
        ApzCOB.showNewCommonErrorModal('Please enter the response.');
        return;
    }
    const eligibleAmt = parseInt(CoAppCustCibilData[0]?.cibilDetails?.payload?.eligibleAmt) || 0;
    let lnAmtVal = document.getElementById("CrdAss__CaInPrincipleDecision__recLnAmtVal").value;
    let updatedLnAmt = lnAmtVal.replace(/[^\d]/g, '');
    const bmRecAmt = parseInt(updatedLnAmt) || 0;
    let caglOsFromScreen = $("#CrdAss__CaInPrincipleDecision__currOutValCmn").text();
    let caglOsToBeCompared = caglOsFromScreen.replace(/[^\d]/g, '');
    let caglOs = parseInt(caglOsToBeCompared) || 0;
    let totalAmountPost = $("#CrdAss__CaInPrincipleDecision__TotalAmtPostValCmn").text();
    let numerictotalAmountPost = parseFloat(totalAmountPost.replace(/[^0-9.-]+/g, ''));
    if (!bmRecAmt || !eligibleAmt || bmRecAmt > eligibleAmt) {
        ApzCOB.showCaModals({
            text: "The entered loan amount should be equal to or lesser than the eligible loan amount",
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
    } else if (isNaN(numerictotalAmountPost) || numerictotalAmountPost < 0) {
        ApzCOB.showCaModals({
            text: "Total amount post net off must be a valid non-negative number.",
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
    } else {
        apz.app.CaInPrincipleDecision.verifyStage();
    }
};
apz.app.CaInPrincipleDecision.verifyStage = function() {
    let allStagesPresent = [...Array(8).keys()].map(i => i + 1).every(stage => inSessionStore?.bcmpiVerifiedStage?.some(item => item.startsWith(
        `${stage}_`)));
    const eligibleAmt = parseInt(CoAppCustCibilData[0]?.cibilDetails?.payload?.eligibleAmt) || 0;
    let lnAmtVal = document.getElementById("CrdAss__CaInPrincipleDecision__recLnAmtVal").value;
    let updatedLnAmt = lnAmtVal.replace(/[^\d]/g, '');
    const bmRecAmt = parseInt(updatedLnAmt) || 0;
    if (allStagesPresent) {
        let req = {
            "apiRequest": {
                "requestObj": {
                    "appId": gAppId,
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "versionNum": 1,
                    "stageId": CA_CURRENT_STAGE_NO,
                    "requestType": "Verify",
                    "customerType": "Applicant",
                    "updatedLoanAmount": bmRecAmt,
                    "editedFields": []
                },
                "userId": LoggedInUserDetails.loginResponse.userDet.id,
                "appId": gAppId,
                "interfaceName": "UploadCALoanData"
            }
        }
        apz.startLoader();
        setTimeout(() => {
            ApzCOB.serverBuildParam(gAppId, "UploadCALoanData", "N", "N", req, false, apz.app.CaInPrincipleDecision.verifyStageCB);
        }, 1000)
    } else {
        ApzCOB.showCaModals({
            text: "Verify All the Previous Stages first",
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
    }
}
apz.app.CaInPrincipleDecision.verifyStageCB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            apz.app.Cabase.SidebarSelect.moveToNextStep();
            apz.app.Cabase.approveReject(this, 'SUBMIT');
        } else {
            apz.stopLoader();
            ApzCOB.showCaModals({
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.Cabase.closeCaErrMdl()"
                }
            }, "Error");
        }
    } catch {
        apz.stopLoader();
        ApzCOB.showCaModals({
            text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
    }
}
apz.app.CaInPrincipleDecision.launchPreviewScreen = function() {
    $("#CrdAss__CaInPrincipleDecision__inprinciple_row").addClass('sno');
    $("#CrdAss__CaInPrincipleDecision__inprinciplePreview_row").removeClass('sno');
    $("#CrdAss__Cabase__reject_btn").addClass('sno');
    $("#CrdAss__Cabase__submitBtn").addClass('sno');
    apz.app.CaInPrincipleDecision.Previewloandetails(); // Loan Details
    apz.app.CaInPrincipleDecision.previewPhotoKyc(); // Photo Kyc
    apz.app.CaInPrincipleDecision.previewAddressContact(); // Address Contact
    apz.app.CaInPrincipleDecision.previewInsuranceDetails();
    apz.app.CaInPrincipleDecision.previewIncomeDetails(); // Income Details
    apz.app.CaInPrincipleDecision.previewInformalLoanObligation(); // Informal Loan Obligation
    apz.app.CaInPrincipleDecision.previewOtherDetails(); // Other Details
    apz.app.CaInPrincipleDecision.paintNetIncome();
}
apz.app.CaInPrincipleDecision.Previewloandetails = function() {
    let sourcingDate = window.applicationMaster?.createTs?.date?.day + '/' + String(window.applicationMaster?.createTs?.date?.month).padStart(2, '0') +'/' + window.applicationMaster?.createTs?.date?.year;
    $("#CrdAss__CaInPrincipleDecision__Appliedamount_txtcnt").text(window.CAloandetails?.loanAmount);
    $("#CrdAss__CaInPrincipleDecision__Repaymentfrequency_txtcnt").text(window.CAloandetails?.payload?.frequencyOfRepayment);
    $("#CrdAss__CaInPrincipleDecision__Loantenure_txtcnt").text(window.CAloandetails?.tenure);
    $(`#${CaInPrincipleDecisionScrId}Sourcingdate`).text(sourcingDate);
    if (inSessionStore.hasOwnProperty('leadDetails')) {
        $("#CrdAss__CaInPrincipleDecision__Kendrameetingfrequency").text(window.CAleadetails.kendraMeetingFreq);
        $("#CrdAss__CaInPrincipleDecision__Kendrameetingday_txtcnt").text(KendraMeetingDays.filter(el => el?.slice(0, 3)?.toUpperCase() === window
            .CAleadetails?.kendraMeetingDay?.toUpperCase())?.[0]);
        $("#CrdAss__CaInPrincipleDecision__KendramanagerID_txtcnt").text(window.applicationMaster.createdBy);
    } else if (inSessionStore.hasOwnProperty('renewalLeadDetails')) {
        $("#CrdAss__CaInPrincipleDecision__Kendrameetingfrequency").text(window.CArenewalLeadDetails.kendraMeetingFreq);
        $("#CrdAss__CaInPrincipleDecision__Kendrameetingday_txtcnt").text(KendraMeetingDays.filter(el => el?.slice(0, 3)?.toUpperCase() === window
            .CArenewalLeadDetails?.kendraMeetingDay?.toUpperCase())?.[0]);
        $("#CrdAss__CaInPrincipleDecision__KendramanagerID_txtcnt").text(window.applicationMaster.createdBy);
    }
    if (!apz.isNull(CAloandetails.payload.loanPurpose)) {
        $("#CrdAss__CaInPrincipleDecision__Purposeofloan_txtcnt").text(window.CAloandetails?.payload?.loanPurpose);
        $("#CrdAss__CaInPrincipleDecision__Subpurpose_txtcnt").text(window.CAloandetails?.payload?.subCategory);
    }
};
apz.app.CaInPrincipleDecision.previewPhotoKyc = function() {
    apz.app.commonca.fetchImageIds();
}
apz.app.CaInPrincipleDecision.previewAddressContact = function() {
    let addressDetails;
    let permanentDetails;
    if (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.length > 0 && inSessionStore.customerDetailsList.length > 0) {
        inSessionStore.addressDetailsWrapperList[0].addressDetailsList.forEach(type => {
            if (type.addressType === "Personal" && type.custDtlId === gApzCOB.userDetails.custDtlId) {
                type.payload.addressList.forEach(address => {
                    if (address.addressType === "Present") {
                        addressDetails = address;
                        $(`#${CaInPrincipleDecisionScrId}A_present_address`).text(
                            `${addressDetails.addressLine1}, ${addressDetails.area}, ${addressDetails.city} - ${addressDetails.pinCode}, ${addressDetails.country}`
                            );
                    } else if (address.addressType === "Permanent") {
                        permanentDetails = address;
                        $(`#${CaInPrincipleDecisionScrId}A_permanent_address`).text(
                            `${permanentDetails.addressLine1}, ${permanentDetails.area}, ${permanentDetails.city} - ${permanentDetails.pinCode}, ${permanentDetails.country}`
                            );
                    }
                });
            }
        });
        $(`#${CaInPrincipleDecisionScrId}A_mobilenumber`).text(inSessionStore.customerDetailsList[0].mobileNumber);
        $(`#${CaInPrincipleDecisionScrId}A_residence_ownership_txtcnt`).text(addressDetails.residenceOwnership);
        $(`#${CaInPrincipleDecisionScrId}A_residence_stability_txtcnt`).text(addressDetails.residenceAddressSince);
        $(`#${CaInPrincipleDecisionScrId}A_residence_stabilit_present_city_txtcnt`).text(addressDetails.residenceCitySince);
    }
}
apz.app.CaInPrincipleDecision.previewInsuranceDetails = function() {
    let applicantInsuranceDetails = [];
    let coAppInsuranceDetails = [];
    let jointInsuranceDetails = [];
    let loanAmt = Number(inSessionStore?.loanDetails?.loanAmount);
    if (loanAmt > 200000) {
        loanAmt = 200000
    }
    if (Array.isArray(inSessionStore?.insuranceDetailsWrapperList) && inSessionStore.insuranceDetailsWrapperList.length > 0) {
        inSessionStore.insuranceDetailsWrapperList.forEach((item) => {
            let insuredName = item.insuranceDetails?.payload?.insuredName;
            if (insuredName === "Applicant") {
                applicantInsuranceDetails = item.insuranceDetails;
            } else if (insuredName === "Co-App") {
                coAppInsuranceDetails = item.insuranceDetails;
            } else if (insuredName === "Joint") {
                jointInsuranceDetails = item.insuranceDetails;
            }
        });
    }
    if (applicantInsuranceDetails?.payload?.insuranceOption === "Applicant") {
        $(`#${CaInPrincipleDecisionScrId}insType`).text("Applicant")
        $(`#${CaInPrincipleDecisionScrId}totalInsPremium`).text(applicantInsuranceDetails?.payload?.insurancePremium);
        $(`#${CaInPrincipleDecisionScrId}A_sumAssuredInput`).text(loanAmt)
        $(`#${CaInPrincipleDecisionScrId}A_nameOfInsurerInput`).text(applicantInsuranceDetails?.payload?.insurerName)
        $(`#${CaInPrincipleDecisionScrId}A_insurancePremiumInput`).text(applicantInsuranceDetails?.payload?.insurancePremium)
        $(`#${CaInPrincipleDecisionScrId}A_nomineeInsurenceInput`).text(applicantInsuranceDetails?.payload?.nomineeName)
        $(`#${CaInPrincipleDecisionScrId}A_dobInput`).text(applicantInsuranceDetails?.payload?.nomineeDob)
        $(`#${CaInPrincipleDecisionScrId}A_ageOfNomineeInput`).text(applicantInsuranceDetails?.payload?.age)
        $(`#${CaInPrincipleDecisionScrId}A_nomineeRelationshipInput`).text(applicantInsuranceDetails?.payload?.nomineeRelation)
        $(`#${CaInPrincipleDecisionScrId}A_genderInput`).text(!apz.isNull(applicantInsuranceDetails.payload.gender) ? applicantInsuranceDetails
            .payload.gender : "");
    } else if (applicantInsuranceDetails?.payload?.insuranceOption === "Both") {
        $(`#${CaInPrincipleDecisionScrId}App_Row`).addClass("sno");
        $(`#${CaInPrincipleDecisionScrId}Both_Row`).removeClass("sno");
        $(`#${CaInPrincipleDecisionScrId}insType`).text("Both")
        $(`#${CaInPrincipleDecisionScrId}totalInsPremium`).text(Number(ApzCOB.fn_unFormatAmount(applicantInsuranceDetails?.payload?.insurancePremium) || 0) + Number(
            ApzCOB.fn_unFormatAmount(coAppInsuranceDetails?.payload?.insurancePremium)));
        $(`#${CaInPrincipleDecisionScrId}CA_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
        $(`#${CaInPrincipleDecisionScrId}CA_nameOfInsurerInput`).text(applicantInsuranceDetails?.payload?.insurerName)
        $(`#${CaInPrincipleDecisionScrId}CA_insurancePremiumInput`).text(applicantInsuranceDetails?.payload?.insurancePremium)
        $(`#${CaInPrincipleDecisionScrId}CA_nomineeInsurenceInput`).text(applicantInsuranceDetails?.payload?.nomineeName)
        $(`#${CaInPrincipleDecisionScrId}CA_dobInput`).text(applicantInsuranceDetails?.payload?.nomineeDob)
        $(`#${CaInPrincipleDecisionScrId}CA_ageOfNomineeInput`).text(applicantInsuranceDetails?.payload?.age)
        $(`#${CaInPrincipleDecisionScrId}CA_nomineeRelationshipInput`).text(applicantInsuranceDetails?.payload?.nomineeRelation)
        $(`#${CaInPrincipleDecisionScrId}CA_genderInput`).text(!apz.isNull(applicantInsuranceDetails.payload.gender) ? applicantInsuranceDetails
            .payload.gender : "");
        $(`#${CaInPrincipleDecisionScrId}CC_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
        $(`#${CaInPrincipleDecisionScrId}CC_nameOfInsurerInput`).text(coAppInsuranceDetails?.payload?.insurerName)
        $(`#${CaInPrincipleDecisionScrId}CC_insurancePremiumInput`).text(coAppInsuranceDetails?.payload?.insurancePremium)
        $(`#${CaInPrincipleDecisionScrId}CC_nomineeInsurenceInput`).text(coAppInsuranceDetails?.payload?.nomineeName)
        $(`#${CaInPrincipleDecisionScrId}CC_dobInput`).text(coAppInsuranceDetails?.payload?.nomineeDob)
        $(`#${CaInPrincipleDecisionScrId}CC_ageOfNomineeInput`).text(coAppInsuranceDetails?.payload?.age)
        $(`#${CaInPrincipleDecisionScrId}CC_nomineeRelationshipInput`).text(coAppInsuranceDetails?.payload?.nomineeRelation)
        $(`#${CaInPrincipleDecisionScrId}CC_genderInput`).text(!apz.isNull(coAppInsuranceDetails.payload.gender) ? coAppInsuranceDetails.payload
            .gender : "");
    } else if (applicantInsuranceDetails.payload.insuranceOption === "Joint") {
        $(`#${CaInPrincipleDecisionScrId}App_Row`).addClass("sno");
        $(`#${CaInPrincipleDecisionScrId}insType`).text("Joint")
        $(`#${CaInPrincipleDecisionScrId}totalInsPremium`).text(jointInsuranceDetails?.payload?.insurancePremium);
        if (jointInsuranceDetails?.payload?.nomineeAdded === "No") {
            $(`#${CaInPrincipleDecisionScrId}Both_Row`).removeClass("sno");
            $(`#${CaInPrincipleDecisionScrId}CA_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
            $(`#${CaInPrincipleDecisionScrId}CA_nameOfInsurerInput`).text(applicantInsuranceDetails?.payload?.insurerName)
            $(`#${CaInPrincipleDecisionScrId}CA_insurancePremiumInput`).text(applicantInsuranceDetails?.payload?.insurancePremium)
            $(`#${CaInPrincipleDecisionScrId}CA_nomineeInsurenceInput`).text(applicantInsuranceDetails?.payload?.nomineeName)
            $(`#${CaInPrincipleDecisionScrId}CA_dobInput`).text(applicantInsuranceDetails?.payload?.nomineeDob)
            $(`#${CaInPrincipleDecisionScrId}CA_ageOfNomineeInput`).text(applicantInsuranceDetails?.payload?.age)
            $(`#${CaInPrincipleDecisionScrId}CA_nomineeRelationshipInput`).text(applicantInsuranceDetails?.payload?.nomineeRelation)
            $(`#${CaInPrincipleDecisionScrId}CA_genderInput`).text(!apz.isNull(applicantInsuranceDetails.payload.gender) ?
                applicantInsuranceDetails.payload.gender : "");
            $(`#${CaInPrincipleDecisionScrId}CC_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
            $(`#${CaInPrincipleDecisionScrId}CC_nameOfInsurerInput`).text(coAppInsuranceDetails?.payload?.insurerName)
            $(`#${CaInPrincipleDecisionScrId}CC_insurancePremiumInput`).text(coAppInsuranceDetails?.payload?.insurancePremium)
            $(`#${CaInPrincipleDecisionScrId}CC_nomineeInsurenceInput`).text(coAppInsuranceDetails?.payload?.nomineeName)
            $(`#${CaInPrincipleDecisionScrId}CC_dobInput`).text(coAppInsuranceDetails?.payload?.nomineeDob)
            $(`#${CaInPrincipleDecisionScrId}CC_ageOfNomineeInput`).text(coAppInsuranceDetails?.payload?.age)
            $(`#${CaInPrincipleDecisionScrId}CC_nomineeRelationshipInput`).text(coAppInsuranceDetails?.payload?.nomineeRelation)
            $(`#${CaInPrincipleDecisionScrId}CC_genderInput`).text(!apz.isNull(coAppInsuranceDetails.payload.gender) ? coAppInsuranceDetails
                .payload.gender : "");
        } else {
            $(`#${CaInPrincipleDecisionScrId}Joint_Row`).removeClass("sno");
            $(`#${CaInPrincipleDecisionScrId}BA_sumAssuredInput`).text(inSessionStore?.loanDetails?.loanAmount)
            $(`#${CaInPrincipleDecisionScrId}BA_nameOfInsurerInput`).text(jointInsuranceDetails?.payload?.insurerName)
            $(`#${CaInPrincipleDecisionScrId}BA_insurancePremiumInput`).text(jointInsuranceDetails?.payload?.insurancePremium)
            $(`#${CaInPrincipleDecisionScrId}BA_nomineeInsurenceInput`).text(jointInsuranceDetails?.payload?.nomineeName)
            $(`#${CaInPrincipleDecisionScrId}BA_dobInput`).text(jointInsuranceDetails?.payload?.nomineeDob)
            $(`#${CaInPrincipleDecisionScrId}BA_ageOfNomineeInput`).text(jointInsuranceDetails?.payload?.age)
            $(`#${CaInPrincipleDecisionScrId}BA_nomineeRelatiaonshipInput`).text(jointInsuranceDetails?.payload?.nomineeRelation)
            $(`#${CaInPrincipleDecisionScrId}BA_genderInput`).text(!apz.isNull(jointInsuranceDetails.payload.gender) ? jointInsuranceDetails
                .payload.gender : "");
        }
    } else {
        $(`#${CaInPrincipleDecisionScrId}App_Row`).addClass("sno");
        $(`#${CaInPrincipleDecisionScrId}insType`).text("No Insurance")
        $(`#${CaInPrincipleDecisionScrId}totalInsPremium`).text("");
    }
}
apz.app.CaInPrincipleDecision.previewIncomeDetails = function() {
    incomeDtls = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload);
    apz.app.CaInPrincipleDecision.paintAgricultureData();
    apz.app.CaInPrincipleDecision.paintSalaryData();
    apz.app.CaInPrincipleDecision.paintPensionData();
    apz.app.CaInPrincipleDecision.paintrentalIncomeData();
    apz.app.CaInPrincipleDecision.paintWageData();
    apz.app.CaInPrincipleDecision.paintBusinessData();
    let incomeSourcesToPaint = apz.app.CaInPrincipleDecision.getPresentIncomeSources();
    let formattedIncomeSources = incomeSourcesToPaint.join(', ');
    $(`#${CaInPrincipleDecisionScrId}availSourcesIncome_txtcnt`).text(formattedIncomeSources);
    apz.app.CaInPrincipleDecision.paintIncomeOwnershipDetails();
    if (incomeDtls.hasOwnProperty('homeMaker')) {
        $(`#${CaInPrincipleDecisionScrId}InprinciplehomeMaker`).removeClass('sno');
        $(`#${CaInPrincipleDecisionScrId}inpriHomemaker_txtcnt`).text(incomeDtls?.homeMaker);
    }
}
apz.app.CaInPrincipleDecision.paintAgricultureData = function() {
    if (incomeDtls.hasOwnProperty('agriculture') || apz.isObjectEmpty(incomeDtls.agriculture)) {
        $(`#${CaInPrincipleDecisionScrId}agricultureDetailRow`).addClass('sno');
    }
    if (!apz.isObjectEmpty(incomeDtls.agriculture) && incomeDtls.agriculture.hasOwnProperty('applicant')) {
        $(`#${CaInPrincipleDecisionScrId}agricultureDetailRow`).removeClass('sno');
        $(`#${CaInPrincipleDecisionScrId}agriBothchecked`).addClass('sno');
        $(`#${CaInPrincipleDecisionScrId}Apptitle`).addClass('sno');
        $(`#${CaInPrincipleDecisionScrId}agriApplicantRow`).removeClass('sno');
        $(`#${CaInPrincipleDecisionScrId}agriCoapplicantRow`).addClass('sno');
        $(`#${CaInPrincipleDecisionScrId}agrOwnedby_txtcnt`).text("Applicant");
        $(`#${CaInPrincipleDecisionScrId}agrlandType_txtcnt`).text(incomeDtls?.agriculture?.applicant?.typeOfAgriculture);
        $(`#${CaInPrincipleDecisionScrId}agrcropType_txtcnt`).text(incomeDtls?.agriculture?.applicant?.cropType);
        $(`#${CaInPrincipleDecisionScrId}agriCrop_txtcnt`).text(incomeDtls?.agriculture?.applicant?.crop);
        $(`#${CaInPrincipleDecisionScrId}agriclutureLandRange_txtcnt`).text(incomeDtls?.agriculture?.applicant?.land);
        $(`#${CaInPrincipleDecisionScrId}agriclutureLand_txtcnt`).text(incomeDtls?.agriculture?.applicant?.landInAcres);
        $(`#${CaInPrincipleDecisionScrId}maxPeracre_txtcnt`).text(incomeDtls?.agriculture?.applicant?.maxYeildPerAcre);
        $(`#${CaInPrincipleDecisionScrId}agrIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.applicant?.monthlyIncome));
        $(`#${CaInPrincipleDecisionScrId}agrConIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.applicant?.consideredIncome));
        $(`#${CaInPrincipleDecisionScrId}agrDeclIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.applicant?.declaredIncome));
        custTypeInPrinciple = "Applicant";
        apz.app.CaInPrincipleDecision.paintDocumentName("CrdAss__CaInPrincipleDecision__AggrAppCloneRow_0",
            "CrdAss__CaInPrincipleDecision__AggrAppParentRow", "Agriculture Doc");
    }
    if (!apz.isObjectEmpty(incomeDtls.agriculture) && incomeDtls.agriculture.hasOwnProperty('coApplicant')) {
        $(`#${CaInPrincipleDecisionScrId}agricultureDetailRow`).removeClass('sno');
        $(`#${CaInPrincipleDecisionScrId}agriBothchecked`).addClass('sno');
        $(`#${CaInPrincipleDecisionScrId}CoApptitle`).addClass('sno');
        $(`#${CaInPrincipleDecisionScrId}agriApplicantRow`).addClass('sno');
        $(`#${CaInPrincipleDecisionScrId}agriCoapplicantRow`).removeClass('sno');
        $(`#${CaInPrincipleDecisionScrId}agrCoownedby_txtcnt`).text("CoApplicant");
        $(`#${CaInPrincipleDecisionScrId}agrColandType_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.typeOfAgriculture);
        $(`#${CaInPrincipleDecisionScrId}agrCocropType_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.cropType);
        $(`#${CaInPrincipleDecisionScrId}agrCocrop_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.crop);
        $(`#${CaInPrincipleDecisionScrId}CoagriclutureLandRange_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.land);
        $(`#${CaInPrincipleDecisionScrId}CoagriclutureLand_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.landInAcres);
        $(`#${CaInPrincipleDecisionScrId}ComaxPeracre_txtcnt`).text(incomeDtls?.agriculture?.coApplicant?.maxYeildPerAcre);
        $(`#${CaInPrincipleDecisionScrId}CoagrIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.coApplicant?.monthlyIncome));
        $(`#${CaInPrincipleDecisionScrId}CoagrConIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.coApplicant?.consideredIncome));
        $(`#${CaInPrincipleDecisionScrId}CoagrDeclIncMntly_txtcnt`).text(ApzCOB.formatamountVal(incomeDtls?.agriculture?.coApplicant?.declaredIncome));
        custTypeInPrinciple = "Co-Applicant";
        apz.app.CaInPrincipleDecision.paintDocumentName("CrdAss__CaInPrincipleDecision__AggrCoAppCloneRow_0",
            "CrdAss__CaInPrincipleDecision__AggrCoAppParentRow", "Agriculture Doc");
    }
    if (!apz.isObjectEmpty(incomeDtls.agriculture) && incomeDtls.agriculture.hasOwnProperty('applicant') && incomeDtls.agriculture.hasOwnProperty(
            'coApplicant')) {
