apz.app.CaInPrincipleDecision.formatRupeeOnBlur = function(input) {
    let rawValue = input.value.replace(/[^\d]/g, '');
    if (rawValue) {
        let numericValue = parseInt(rawValue, 10);
        if (!isNaN(numericValue)) {
            let rounded = Math.round(numericValue / 1000) * 1000;
            const formatted = rounded.toLocaleString('en-IN');
            input.value = `₹ ${formatted}`;
        } else {
            input.value = '₹';
        }
    } else {
        input.value = '₹';
    }
};
apz.app.CaInPrincipleDecision.paintDocumentName = function(clonebleDiv, parentdiv, documentType) {
    if (apz.isObjectEmpty(inSessionStore) || !inSessionStore.hasOwnProperty('applicationDocumentsWrapperList')) return;
    let i = 1;
    let documentResp = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList
    if (documentResp.length > 0) {
        if (documentType !== "proof with owner doc" && documentType !== 'SupportDocs') {
            window.SupportDocs = documentResp.filter(doc => doc.payload.documentType === documentType/* && doc.docLevel == businessCounter*/);
        } else {
            window.SupportDocs = documentResp.filter(doc => doc.payload.documentType === documentType && parseInt(doc.custDtlId) === parseInt(gApzCOB
                .userDetails.custDtlId));
        }
        if (SupportDocs.length > 0) {
            let cloneDiv = clonebleDiv;
            let parentDiv = $("#" + parentdiv);
            parentDiv.html('');
            SupportDocs.forEach((doc, index) => {
                let newId = ApzCOB.cloneDashboardDivs(cloneDiv, parentDiv, index + 1);
                if (doc.payload.documentType !== "proof with owner doc" && doc.payload.documentType !== 'SupportDocs') {
                    $(`#${parentdiv} #${newId} a.ett-hypl span`).text(`${doc.payload.documentType.split(" Doc")[0]}_${index + 1}.jpg`);
                } else {
                    let baseName = doc.payload.documentFileName.match(/^[^\d]+/)[0];
                    $(`#${parentdiv} #${newId} a.ett-hypl span`).text(`${baseName}_${i}.jpg`);
                    i++;
                }
                $(`#${parentdiv} #${newId}`).attr('data-id', doc.appDocId);
                $(`#${parentdiv} #${newId} .updel .scb-col15 .ett-para span`).text(`${Math.floor(doc.payload.docSize / 1024)} KB`);
                $(`#${parentdiv} #${newId}`).removeClass('sno');
            })
        }
    }
}
apz.app.CaInPrincipleDecision.viewDocument = function(pthis) {
    let documentId = $(pthis).parents('.shwdtl').attr('data-id');
    if (!documentId) {
        documentId = $(pthis).parents('.uploadimg').attr('data-id');
    }
    let docDetails = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.find(doc => parseInt(doc.appDocId) === parseInt(
        documentId));
    if (!apz.isObjectEmpty(docDetails)) {
        let fileName = docDetails?.payload?.documentFileName;
        let callBackFn = apz.app.CaInPrincipleDecision.viewDocumentCB;
        window.ImageLocationDetails = {
            latitude: docDetails?.payload?.latitude || "",
            longitude: docDetails?.payload?.longitude || "",
            uploadedTs: docDetails?.payload?.uploadedTs || "",
            documentFileName: docDetails?.payload?.documentFileName || ""
        };
        ApzCOB.downloadFileFromServer(fileName, callBackFn);
    }
}
apz.app.CaInPrincipleDecision.viewDocumentCB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.base64)) {
        $(`#${CaInPrincipleDecisionScrId}imgView`).attr('src', 'data:image/png;base64,' + params.base64);
        if (Object.keys(window.ImageLocationDetails).length > 0) {
            apz.app.BaseScreens.paintImageLocationDetails(`#${CaInPrincipleDecisionScrId}imgView`, window.ImageLocationDetails);
        }
        ApzCOB.toggleModal(`${CaInPrincipleDecisionScrId}docViewModal`);
    } else {
        ApzCOB.fnDisplayMsg("Document is not available")
    }
}
apz.app.CaInPrincipleDecision.paintNetIncome = function() {
    const safeGet = (obj, path) => path.split('.').reduce((o, k) => (o && o[k] !== undefined ? o[k] : undefined), obj);
    const sumFields = (objA, keyA, objB, keyB) => {
        const a = Number(safeGet(objA, keyA)) || 0;
        const b = Number(safeGet(objB, keyB)) || 0;
        return a + b;
    };
    const textOrBlank = val => val > 0 ? `₹ ${val}` : "";
    const agriIncome = sumFields(incomeDtls.agriculture?.applicant, "consideredIncome", incomeDtls.agriculture?.coApplicant, "consideredIncome");
    $("#CrdAss__CaInPrincipleDecision__OtherInc1_income").text(ApzCOB.formatIndianRupees(agriIncome));
    const salaryIncome = sumFields(incomeDtls.salary?.applicant, "netSalary", incomeDtls.salary?.coApplicant, "netSalary");
    $("#CrdAss__CaInPrincipleDecision__OtherInc2_income").text(ApzCOB.formatamountVal(textOrBlank(salaryIncome)));
    const pensionIncome = sumFields(incomeDtls.pension?.applicant, "applicantPensionIncome", incomeDtls.pension?.coApplicant,
        "coApplicantPensionIncome");
    $("#CrdAss__CaInPrincipleDecision__OtherInc4_income").text(ApzCOB.formatIndianRupees(pensionIncome));
    const sumWageIncome = (wageData = {}) => {
        const categories = ["farmWorker", "contractLabour", "constructions", "maid", "hotelWorker", "other"];
        return categories.reduce((sum, cat) => {
            const val = Number(safeGet(wageData, `${cat}.totalWagePerMonth`)) || 0;
            return sum + val;
        }, 0);
    };
    const wageIncome = sumWageIncome(incomeDtls.wage?.applicant) + sumWageIncome(incomeDtls.wage?.coApplicant);
    $("#CrdAss__CaInPrincipleDecision__OtherInc3_income").text(ApzCOB.formatIndianRupees(wageIncome));
    const rentIncome = sumFields(incomeDtls.rentalIncome?.applicant, "consideredMonthlyIncome", incomeDtls.rentalIncome?.coApplicant,
        "consideredMonthlyIncome");
    $("#CrdAss__CaInPrincipleDecision__OtherInc5_income").text(ApzCOB.formatIndianRupees(rentIncome));
    const businessData = incomeDtls.business || {};
    const getBusinessIncomeSumByType = (arrayKey, typeKey, incomeField = "netBusinessIncome") => {
        const list = businessData[arrayKey] || [];
        return list.reduce((sum, item) => {
            const type = item?.[typeKey];
            const income = Number(item?.[incomeField]) || 0;
            if (type === "Applicant" || type === "Co-Applicant" || type === "Both") {
                return sum + income;
            }
            return sum;
        }, 0);
    };
    const tailoringIncome = getBusinessIncomeSumByType("Tailoring", "tailoringType", "netBusinessIncome");
    $("#CrdAss__CaInPrincipleDecision__business3_income").text(ApzCOB.formatIndianRupees(tailoringIncome));
    const kiranaIncome = getBusinessIncomeSumByType("Kirana", "kiranaType", "finalNetIncome");
    $("#CrdAss__CaInPrincipleDecision__business2_income").text(ApzCOB.formatIndianRupees(kiranaIncome));
    const otherIncome = getBusinessIncomeSumByType("Other", "otherType", "netBusinessIncome");
    $("#CrdAss__CaInPrincipleDecision__business4_income").text(ApzCOB.formatIndianRupees(otherIncome));
    const dairyIncome = getBusinessIncomeSumByType("dairy", "DairyType", "IncomeAssessmentChecknetBusinessIncome");
    $("#CrdAss__CaInPrincipleDecision__business1_income").text(ApzCOB.formatIndianRupees(dairyIncome));
    $("#CrdAss__CaInPrincipleDecision__OtherInc10_income").text("₹ 0");
    const totalIncome = agriIncome + salaryIncome + pensionIncome + wageIncome + rentIncome + tailoringIncome + kiranaIncome + otherIncome +
        dairyIncome;
    $("#CrdAss__CaInPrincipleDecision__totalHousehldIncValue").text(`₹ ${ApzCOB.formatamountVal(totalIncome)}`);
    $("#CrdAss__CaInPrincipleDecision__totalDeclaredIncValue").text(`₹ ${ApzCOB.formatamountVal(parseInt(JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || "{}")?.totalDeclaredIncome) || 0)}`);
    $("#CrdAss__CaInPrincipleDecision__tot_income_app").text(`₹ ${ApzCOB.formatamountVal(incomeDtls.applicantTotalIncome)}`);
    $("#CrdAss__CaInPrincipleDecision__tot_income_coapp").text(`₹ ` + incomeDtls.coApplicantTotalIncome);
    $("#CrdAss__CaInPrincipleDecision__tot_income_appCoapp").text(`₹ ` + (incomeDtls.otherIncome));
    $("#CrdAss__CaInPrincipleDecision__tot_income_family").text(`₹ ` + incomeDtls.otherFamilyIncome);
    $("#CrdAss__CaInPrincipleDecision__tot_income_assessment").text(`₹ ` + incomeDtls.fieldAssessedIncome);
    const dateObj = incomeDtls.fieldAssessedIncomeDate?.date;
    const formattedDate = dateObj ? `${String(dateObj.day).padStart(2, '0')}-${String(dateObj.month).padStart(2, '0')}-${dateObj.year}` : '';
    $("#CrdAss__CaInPrincipleDecision__income_ass_date").text(formattedDate);
};
apz.app.CaInPrincipleDecision.getPresentIncomeSources = function() {
    incomeDtls = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload);
    const incomeDtlsKeys = Object.keys(incomeDtls || {});
    const ignoreKeys = ["applicantTotalIncome", "coApplicantTotalIncome", "otherFamilyIncome", "fieldAssessedIncome", "fieldAssessedIncomeDate",
        "homeMaker"
    ];
    const incomeSources = [];
    incomeDtlsKeys.forEach(key => {
        if (ignoreKeys.includes(key)) return;
        const value = incomeDtls[key];
        const isObjectWithData = typeof value === "object" && value !== null && (
            (Array.isArray(value) && value.length > 0) || Object.values(value).some(v => v && (typeof v === "object" ? Object.keys(v)
                .length > 0 : true)));
        if (isObjectWithData) {
            const readableName = key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase()).trim();
            incomeSources.push(readableName);
        }
    });
    return incomeSources;
};
apz.app.CaInPrincipleDecision.getIncomeSourceOwnership = function() {
    const result = {};
    const checkPresence = (app, coApp) => {
        const hasApplicant = !!app && Object.keys(app).length > 0;
        const hasCoApplicant = !!coApp && Object.keys(coApp).length > 0;
        if (hasApplicant && hasCoApplicant) return "Both";
        if (hasApplicant) return "Applicant";
        if (hasCoApplicant) return "Co-Applicant";
        return "None";
    };
    result.agriculture = checkPresence(incomeDtls.agriculture?.applicant, incomeDtls.agriculture?.coApplicant);
    result.salary = checkPresence(incomeDtls.salary?.applicant, incomeDtls.salary?.coApplicant);
    result.pension = checkPresence(incomeDtls.pension?.applicant, incomeDtls.pension?.coApplicant);
    result.rentalIncome = checkPresence(incomeDtls.rentalIncome?.applicant, incomeDtls.rentalIncome?.coApplicant);
    result.wage = checkPresence(incomeDtls.wage?.applicant, incomeDtls.wage?.coApplicant);
    result.tailoring = (incomeDtls.business?.Tailoring || []).map(item => item.tailoringType);
    result.kirana = (incomeDtls.business?.Kirana || []).map(item => item.kiranaType);
    result.otherBusiness = (incomeDtls.business?.Other || []).map(item => item.otherType);
    result.dairy = (incomeDtls.business?.dairy || []).map(item => item.DairyType);
    const homeMaker = incomeDtls.homeMaker;
    result.homeMaker = homeMaker === "Applicant" || homeMaker === "Co-Applicant" ? homeMaker : "None";
    return result;
}
apz.app.CaInPrincipleDecision.ImagePrevNext = function(docLev, imgid) {
    ApzCOB.imageAction('fit', imgid);
    let docLevel = $('#' + imgid).attr("doclevel");
    let custDetailID = '';
    if (docLev == docLevel) return;
    docLevel = docLev;
    let custType = imgid.split("__")[2];
    let docType = imgid.split("__")[3];
    if (custType === 'A') {
        custDetailID = gApzCOB.userDetails.custDtlId;
    } else {
        custDetailID = gApzCOB.userDetails.CoApplicantCustomerId;
    }
    if (docType == "ADDRESS_PROOF") {
        let addressList = inSessionStore.addressDetailsWrapperList[0].addressDetailsList.filter((custAdd) => custAdd.addressType === "Personal" &&
            custAdd.custDtlId == custDetailID)[0].payload.addressList;
        let currentAddressProof = addressList.filter(item => item.addressType == "Present")[0]?.currentAddressProof.toLocaleLowerCase() ?? "";
        if (currentAddressProof == "as per voter id" || currentAddressProof == "as per kyc") {
            docType = "PRIMARY_KYC";
        }
    }
    applicationData = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList?.filter(cust => cust.custDtlId ===
        custDetailID) || [];
    applicationData = applicationData.map(doc => {
        if (doc.payload.docLevel == docLevel && doc.payload.documentType === docType) {
            lobj = {};
            lobj.custType = custType;
            lobj.docType = docType;
            lobj.documentName = doc.payload.documentName;
            lobj.docLevel = doc.payload.docLevel;
            lobj.actualdocType = imgid.split("__")[3];
            lobj.documentFileName = doc.payload.documentFileName;
            window.ImageLocationDetails = {
                latitude: doc.payload.latitude || "",
                longitude: doc.payload.longitude || "",
                uploadedTs: doc.payload.uploadedTs || "",
                documentFileName: doc.payload.documentFileName || ""
            };
        }
    })
    ApzCOB.downloadFileFromServer(lobj.documentFileName, apz.app.CaInPrincipleDecision.ImagePrevNextCB);
}
apz.app.CaInPrincipleDecision.ImagePrevNextCB = function(params) {
    let imgPaintId;
    if (CURRENTSCREEN === "CaInPrincipleDecision") {
        imgPaintId = "CrdAss__CaInPrincipleDecision__";
    }
    if (!apz.isNull(params.base64)) {
        if (lobj.docLevel == '2') {
            $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}_Next`).prop('disabled', true)
            $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}_Prev`).prop('disabled', false)
        } else {
            $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}_Prev`).prop('disabled', true)
            $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}_Next`).prop('disabled', false)
        }
        $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}`).attr('src', 'data:image/png;base64,' + params.base64);
        if (Object.keys(window.ImageLocationDetails).length > 0) {
            apz.app.BaseScreens.paintImageLocationDetails(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}`, window.ImageLocationDetails);
        }
        $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}`).attr("documentName", `${lobj.documentName}`);
        $(`#${imgPaintId}${lobj.custType}__${lobj.actualdocType}`).attr("docLevel", `${lobj.docLevel}`);
    } else {
        ApzCOB.fnDisplayMsg("File not found", "E");
    }
    apz.stopLoader();
}
apz.app.CaInPrincipleDecision.paintIncomeOwnershipDetails = function() {
    const ownership = apz.app.CaInPrincipleDecision.getIncomeSourceOwnership();
    const formatOwnership = (value) => {
        if (Array.isArray(value)) return value.join(', ');
        return value || "None";
    };
    $(`#${CaInPrincipleDecisionScrId}OtherInc1_ownedBy`).text(ownership.agriculture);
    $(`#${CaInPrincipleDecisionScrId}OtherInc2_ownedBy`).text(ownership.salary);
    $(`#${CaInPrincipleDecisionScrId}OtherInc4_ownedBy`).text(ownership.pension);
    $(`#${CaInPrincipleDecisionScrId}OtherInc5_ownedBy`).text(ownership.rentalIncome);
    $(`#${CaInPrincipleDecisionScrId}OtherInc3_ownedBy`).text(ownership.wage);
    $(`#${CaInPrincipleDecisionScrId}business3_ownedBy`).text(formatOwnership(ownership.tailoring) || 'None');
    $(`#${CaInPrincipleDecisionScrId}business2_ownedBy`).text(formatOwnership(ownership.kirana) || 'None');
    $(`#${CaInPrincipleDecisionScrId}business4_ownedBy`).text(formatOwnership(ownership.otherBusiness) || 'None');
    $(`#${CaInPrincipleDecisionScrId}business1_ownedBy`).text(formatOwnership(ownership.dairy)?.replace(/^,\s*/, '')  || 'None');
};
