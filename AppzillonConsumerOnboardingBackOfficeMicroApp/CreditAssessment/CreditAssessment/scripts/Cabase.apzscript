apz.app.Cabase.BulkDeleteImages = function(docType, custType, incomeTypeBulkDelete, docNoImageDelete, bulkFlag) {
    let req = {
        apiRequest: {
            interfaceName: "",
            requestObj: {
                appDocId: "",
                versionNum: gApzCOB.userDetails.versionNum,
                applicationId: gApzCOB.userDetails.applicationId,
                appId: gApzCOB.userDetails.appId,
                bulkDelete: bulkFlag,
                documentType: docType,
                customerType: custType,
                incomeType: incomeTypeBulkDelete,
                docNo: docNoImageDelete,
                filePath: "",
                fileName: "",
            },
        },
    };
    let callBackFnc = req.apiRequest.requestObj.incomeType ? apz.app.Cabase.BulkDeleteImagesNotBusinessCB : apz.app.Cabase
        .BulkDeleteImagesBusinessCB;
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "DeleteDocument", "N", "N", req, false, callBackFnc);
}
apz.app.Cabase.BulkDeleteImagesNotBusinessCB = function(params) {
    apz.stopLoader();
    try {
        const isSuccess = ApzCOB.handleServiceCallBacks(params);
        if (isSuccess && params.res.APZCBO__DeleteDocument_Res.apiResponse.ResponseHeader.ResponseCode === '0') {
            let documentArray = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
            let {
                incomeType
            } = params.req.apiRequest.requestObj;
            let updatedDocs = documentArray.filter(item => (item.payload.incomeType !== incomeType));
            if (updatedDocs.length > 0) {
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = [];
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = structuredClone(updatedDocs);
            }
            if (documentArray.length > updatedDocs.length) {
                let docsToBeHidden = incomeType.split(' ')[0];
                let roles = ['App', 'Co'];
                if (docsToBeHidden === 'Rentalincome_Agg') {
                    roles.forEach(role => {
                        const baseId = `CrdAss__CaIncomeDetails__Rentalincome_${role}_UploadedImage_Agg_`;
                        for (let i = 1; i < 5; i++) {
                            const fullId = baseId + i;
                            const elm = document.getElementById(fullId);
                            if (elm) {
                                elm.classList.add('sno');
                            }
                        }
                    });
                } else {
                    roles.forEach(role => {
                        const parentId = `CrdAss__CaIncomeDetails__${docsToBeHidden}_${role}_ParentBusRow`;
                        const parentElement = document.getElementById(parentId);
                        if (parentElement) {
                            for (let i = 1; i < 5; i++) {
                                const imgId = `CrdAss__CaIncomeDetails__${docsToBeHidden}_${role}_UploadedImage_${i}`;
                                const imgElement = document.getElementById(imgId);
                                if (imgElement) {
                                    imgElement.classList.add('sno');
                                }
                            }
                        }
                    });
                }
            }
        }
    } catch (e) {
        ApzCOB.showCaModals({
            text: "We are facing technical difficulties, Please try again.",
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeDeleteErrModal()"
            }
        }, "Error");
    }
}
apz.app.Cabase.BulkDeleteImagesBusinessCB = function(params) {
    apz.stopLoader();
    try {
        const isSuccess = ApzCOB.handleServiceCallBacks(params);
        if (isSuccess && params.res.APZCBO__DeleteDocument_Res.apiResponse.ResponseHeader.ResponseCode === '0') {
            let documentArray = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
            let {
                customerType,
                documentType,
                docNo
            } = params.req.apiRequest.requestObj;
            let normalizedCustType = customerType === 'Co-App' ? 'Co-Applicant' : customerType;
            let updatedDocs = documentArray.filter(item => !(item.payload.custType === normalizedCustType && item.payload.documentType ===
                documentType && item.payload.docNo == docNo));
            if (updatedDocs.length > 0) {
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = [];
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = structuredClone(updatedDocs);
            }
        }
    } catch (e) {
        ApzCOB.showCaModals({
            text: "We are facing technical difficulties, Please try again.",
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeDeleteErrModal()"
            }
        }, "Error");
    }
}
apz.app.Cabase.QueriesToBeSendback = function(excludedStageNo) {
    let statDetails = inSessionStore.bcmpiStatDetails || [];
    let stageNos = [2, 3];
    // If excludedStageNo is provided, remove it from the list
    if (excludedStageNo && stageNos.includes(excludedStageNo)) {
        stageNos = stageNos.filter(no => no !== excludedStageNo);
    }
    let allQueries = [];
    stageNos.forEach(stageNo => {
        let stageObj = statDetails.find(item => item.stageID === stageNo);
        if (stageObj && Array.isArray(stageObj.query)) {
            let formattedQueries = stageObj.query.map(q => `${stageNo}_${q}`);
            allQueries.push(...formattedQueries);
        }
    });
    return allQueries.join('|');
};
