apz.app.Cabase.searchInQueryMdl = function() {
    $("#CrdAss__Cabase__Query_Err_Row").addClass("sno");
    let query = "";
    let searchresults = [];
    query = $(`#${CabaseScrId}searchQueryInput`).val();
    searchresults = QueriesPainted.filter((lead) => Object.values(lead).some((value) => String(value).toLowerCase().includes(query
    .toLowerCase())));
    if (searchresults?.length > 0) {
        apz.data.scrdata.CrdAss__CAQueries_Res = [];
        apz.data.scrdata.CrdAss__CAQueries_Res = searchresults;
        apz.data.loadData("CAQueries", "CrdAss");
        $(`#${CabaseScrId}queryList .wrapped.undefined.ssp`).remove();
        $(`#${CabaseScrId}queryList`).find("p").filter(function(el, item) {
            if ($(`#${queriesIntfId}value_${el}_txtcnt`)[0].textContent === "Other") {
                othReasonId = `#${queriesIntfId}id_${el}`;
                $(`#${queriesIntfId}id_${el}`).attr("onchange", "apz.app.Cabase.onSelectOtherReason();");
            }
        });
        $(`#${CabaseScrId}noResult_row`).addClass("sno");
        $(`#${CabaseScrId}queryList`).removeClass("sno");
    } else {
        $(`#${CabaseScrId}noResult_row`).removeClass("sno");
        $(`#${CabaseScrId}queryList`).addClass("sno");
        $(`#${CabaseScrId}otherQueryReasonForm`).addClass("sno");
    }
};
apz.app.Cabase.getRequiredStagesForScreen = function(screenId) {
    if (screenId === 1) return [];
    let verifiedStages = Array.isArray(inSessionStore?.bcmpiVerifiedStage) ? inSessionStore.bcmpiVerifiedStage.map(stage => parseInt(stage.split(
        '_')[0], 10)) : [];
    let requiredStages = [];
    if (screenId > 1 && screenId <= 4) {
        requiredStages.push(1);
    } else if (screenId >= 5 && screenId <= 7) {
        requiredStages.push(1, 2, 3, 4);
    } else if (screenId === 8 || screenId === 9) {
        requiredStages.push(...[...Array(screenId).keys()].slice(1)); // 1 to screenId-1
    }
    let missingStages = requiredStages.filter(stage => !verifiedStages.includes(stage));
    if (missingStages.length > 0) {
        let missingStageId = missingStages[0];
        let stageObj = (window.CA_ALL_STAGE_FIELDS || []).find(stage => stage.id === missingStageId);
        return stageObj ? [stageObj.stageName] : [];
    }
    return [];
};
