apz.app.Cabase.paintSendbackreasons = function() {
    debugger;
    let lastWrkflwData = inSessionStore.applicationTimelineDtl[inSessionStore.applicationTimelineDtl.length - 1];
    let arr = []
    if (decodeRemarkStages.includes(lastWrkflwData.stage) && lastWrkflwData.actionTaken.includes('Sent Back')) {
        if (apz.isNull(SANCTION_QUERIES) || SANCTION_QUERIES.length === 0) {
            apz.startLoader();
            ApzCOB.fetchSanctionQuery(['Sanction', 'Deviation', 'ReAssessment']);
        }
        setTimeout(() => {
            apz.childScr = CURRENTSCREEN;
            ['sentbackRsnList', 'sentbackRsnHeader', 'sendBackResponseRow'].show();
            if (lastWrkflwData?.timeStamp.includes(' ')) {
                timeStamp = typeof(lastWrkflwData.timeStamp) === 'string' ? ApzCOB.dateformatter(lastWrkflwData.timeStamp.replace(' ', 'T'), "date", "d/m/Y") : '---';
            }
            let remarksArray = [];
            if (!apz.isNull(lastWrkflwData.remarks)) {
                remarksArray = lastWrkflwData.remarks.split('|');
                if (remarksArray.length > 0) {
                    lastWrkflwData.rpcStatRemaks = ApzCOB.getQueryValues(remarksArray, lastWrkflwData);
                    if (lastWrkflwData?.rpcStatRemaks?.length === 0 && remarksArray?.length > 1) {
                        lastWrkflwData.remarks = remarksArray[1];
                    } else {
                        lastWrkflwData.remarks = lastWrkflwData.remarks || '';
                    }
                }
            }
            let lobj = {
                "label": "Sent back reason",
                "stage": apz.isNull(lastWrkflwData?.stage) ? "---" : lastWrkflwData?.stage,
                "userName": apz.isNull(lastWrkflwData?.userId) ? "---" : (lastWrkflwData?.userId.includes('SYSTEM') ? lastWrkflwData?.userId.replace("SYSTEM(SYSTEM)", "Auto Approved") : lastWrkflwData?.userId),
                "dateTime": timeStamp,
                "reason": (apz.isNull(lastWrkflwData?.rpcStatRemaks) || lastWrkflwData?.rpcStatRemaks.length === 0) ? "---" : lastWrkflwData?.rpcStatRemaks,
            }
            if (lobj.userName === 'SYSTEM') {
                lobj.reason = 'Sent back by System';
            }
            arr.push(lobj);
            console.log(arr);
            apz.data.scrdata.CrdAss__IpaintSentBackReason_Res = [];
            apz.data.scrdata.CrdAss__IpaintSentBackReason_Res = arr;
            apz.data.loadData("IpaintSentBackReason", 'CrdAss');
            apz.data.scrdata.CrdAss__IpaintSentBackReason_Res?.forEach(function(el, index) {
                sbreasonIntfId = 'CrdAss__IpaintSentBackReason__o__CrdAss__IpaintSentBackReason_Res__'
                rpcStatId = document.getElementById(`${sbreasonIntfId}reason_${index}_txtcnt`);
                if (Array.isArray(el?.reason)) {
                    if (el.reason?.length > 0) {
                        rpcStatId.innerHTML = el.reason?.filter(msg => msg).map(msg => `• ${msg}`).join("<br>");
                    }
                }
            })
            apz.stopLoader();
        }, 4000);
    } else {
        apz.childScr = CURRENTSCREEN;
        ['sentbackRsnList', 'sentbackRsnHeader', 'sendBackResponseRow'].hide();
    }
};
