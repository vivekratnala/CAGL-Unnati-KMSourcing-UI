apz.app.onLoad_Cabase = function() {
    $(`#${CabaseScrId}caloggedInUserName_txtcnt`).text(
        `${LoggedInUserDetails.loginResponse.userDet.name} (${LoggedInUserDetails.loginResponse.userDet.id})`);
    $("#CrdAss__Cabase__loanDetails_hyp ").addClass("active");
};
apz.app.onShown_Cabase = function() {
    ApzCOB.fetchRpcStageFields();
    if (!($("body").hasClass("unati"))) {
        $("body").addClass("unati");
    }
    if (!($("body").hasClass("crdas"))) {
        $("body").addClass("crdas");
    }
    $(document).ready(updateStageIcons);
    apz.app.Cabase.storeWindowData();
    $(`#${CabaseScrId}caloggedInRole_txtcnt`).text("Role: BM");
    custType = inSessionStore.customerDetailsList.filter((inCust) => inCust.customerType === "Applicant");
    custName = inSessionStore.customerDetailsList.filter((inCust) => inCust.customerName);
    if (custType[0].customerType == 'Applicant') {
        $(`#${CabaseScrId}Cust_Name_txtcnt`).text(custType[0].customerName);
    }
    $(`#${CabaseScrId}cust_ID_txtcnt`).text(window.applicationMaster.memberId);
    $(`#${CabaseScrId}application_ID_txtcnt`).text(inSessionStore.applicationId);
    let productCode = inSessionStore?.applicationMaster?.productCode;
    let productName = "";
    if (ProductData.length > 0 && productCode) {
        let prodInfo = ProductData.find(prod => prod.productCode === productCode);
        if (!apz.isObjectEmpty(inSessionStore)) {
            productName = prodInfo.productName;
        }
    }
    if (inSessionStore.hasOwnProperty('leadDetails')) {
        $(`#${CabaseScrId}kendraID_Nameval_txtcnt`).text(window.CAleadetails.kendraId + " " + '/' + " " + window.CAleadetails.kendraName);
        $(`#${CabaseScrId}BranchInfo_Val_txtcnt`).text(window.CAleadetails.glBranchId + " " + '/' + " " + window.CAleadetails.glBranchName);
        $(`#${CabaseScrId}ProductName_Val_txtcnt`).text(` ${productName}`);
    } else if (inSessionStore.hasOwnProperty('renewalLeadDetails')) {
        $(`#${CabaseScrId}kendraID_Nameval_txtcnt`).text(window.CArenewalLeadDetails.kendraId + " " + '/' + " " + window.CArenewalLeadDetails
            .kendraName);
        $(`#${CabaseScrId}BranchInfo_Val_txtcnt`).text(window.CArenewalLeadDetails.glBranchId + " " + '/' + " " + window.CArenewalLeadDetails
            .glBranchName);
        $(`#${CabaseScrId}ProductName_Val_txtcnt`).text(` ${productName}`);
    }
    ApzCOB.launchSubScreen("Caloandetails", "CrdAss__Cabase__caLaunchCol", "");
    apz.app.Cabase.FetchBCMPIMasterData();
    apz.app.Cabase.paintingQueryLabels();
};
apz.app.Cabase.storeWindowData = function() {
    window.CAloandetails = inSessionStore.loanDetails;
    window.applicationMaster = inSessionStore.applicationMaster;
    window.CAleadetails = inSessionStore.leadDetails;
    window.CArenewalLeadDetails = inSessionStore.renewalLeadDetails;
}
window.apz.app.Cabase.currentActiveId = apz.app.Cabase.currentActiveId || "CrdAss__Cabase__loanDetails_hyp";
apz.app.Cabase.sidepntIds = apz.app.Cabase.sidepntIds || [];
apz.app.Cabase.SidebarSelect = function(lscreenName, pthis) {
    apz.currAppId = "CrdAss";
    window.previousScreenId = apz.childScr;
    window.previousMicroAppId = apz.currAppId;
    if(lscreenName === "applicationDetails") {
        // ApzCOB.launchMicroApp("cmnPre", "PreviewApplicantDetails", "CrdAss__Cabase__caLaunchCol", "");
        window.previousScreenId = apz.childScr;
        window.previousMicroAppId = apz.currAppId;
        ApzCOB.toggleModal("APZCBO__BaseScreens__preview_modal")
        ApzCOB.launchMicroApp("cmnPre", "PreviewApplicantDetails", "APZCBO__BaseScreens__preview_modal_content", "");
        apz.app.Cabase.toggleSidebar();
        return;
    }
    const screenId = apz.app.Cabase.getScreenId(lscreenName);
    if (!screenId) return;
    if (inPrincipleStageClicked && lscreenName !== "CaInPrincipleDecision" && !bypassInPrinciplePopupOnce) {
        const popUpObj = {
            text: "Editing the application details again will trigger BRE. Do you want to continue?",
            Btn1: {
                text: "Yes",
                onClick: `

                    apz.app.Cabase.closeCaConfirmarionMdl();

                    bypassInPrinciplePopupOnce = true;

                    apz.app.Cabase.SidebarSelect('${lscreenName}', document.getElementById('${pthis.id}'));

                `
            },
            Btn2: {
                text: "No",
                onClick: "apz.app.Cabase.closeCaConfirmarionMdl()",
            }
        };
        ApzCOB.showCaModals(popUpObj, "confirmation");
        return;
    }
    window.bypassInPrinciplePopupOnce = false;
    const result = apz.app.Cabase.checkAllStagesExist(screenId);
    if (result) {
        $("[id^='CrdAss__Cabase__']").removeClass("active current");
        const group1 = [`${CabaseScrId}photokyc_hyp`, `${CabaseScrId}AddContact_hyp`, `${CabaseScrId}Insurance_hyp`];
        const group2 = [`${CabaseScrId}IncomeDetail_hyp`, `${CabaseScrId}loanObg_hyp`, `${CabaseScrId}otherdetails_hyp`,
            `${CabaseScrId}reviewSubmit_hyp`
        ];
        if (pthis.id === `${CabaseScrId}Verification_hyp`) {
            $(`#${CabaseScrId}Verification_hyp`).addClass("active");
            $(`#${CabaseScrId}photokyc_hyp`).addClass("current");
        }
        if (pthis.id === `${CabaseScrId}Creditassement_hyp`) {
            $(`#${CabaseScrId}Creditassement_hyp`).addClass("active");
            $(`#${CabaseScrId}IncomeDetail_hyp`).addClass("current");
        }
        const currentIds = [...group1, ...group2];
        if (currentIds.includes(pthis.id)) {
            $(`#${pthis.id}`).addClass("current");
        } else {
            $(`#${pthis.id}`).addClass("active");
        }
        const hasCurrentInGroup1 = group1.some(id => $(`#${id}`).hasClass("current"));
        const hasCurrentInGroup2 = group2.some(id => $(`#${id}`).hasClass("current"));
        if (hasCurrentInGroup2) {
            $(`#${CabaseScrId}Creditassement_hyp`).addClass("active");
        }
        if (hasCurrentInGroup1) {
            $(`#${CabaseScrId}Verification_hyp`).addClass("active");
        }
        apz.app.Cabase.currentActiveId = pthis.id;
        if (inPrincipleStageClicked && lscreenName !== "CaInPrincipleDecision") {
            window.inPrincipleStageClicked = false;
        }
        ApzCOB.launchSubScreen(lscreenName, "CrdAss__Cabase__caLaunchCol", "");
        window.activeStage = apz.app.Cabase.currentActiveId;
        apz.app.Cabase.toggleSidebar();
    } else {
        let missingStages = apz.app.Cabase.getRequiredStagesForScreen(screenId);
        let errorMessage = "Verify All the Previous Stages first";
        if (missingStages.length > 0) {
            errorMessage = `Please verify ${missingStages[0]}`;
        }
        ApzCOB.showCaModals({
            text: errorMessage,
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
    }
};
apz.app.Cabase.SidebarSelect.moveToNextStep = function() {
    let steps = [`${CabaseScrId}loanDetails_hyp`, `${CabaseScrId}photokyc_hyp`, `${CabaseScrId}AddContact_hyp`, `${CabaseScrId}Insurance_hyp`,
        `${CabaseScrId}IncomeDetail_hyp`, `${CabaseScrId}loanObg_hyp`, `${CabaseScrId}otherdetails_hyp`, `${CabaseScrId}reviewSubmit_hyp`,
        `${CabaseScrId}inprincipal_hyp`, `${CabaseScrId}eKyc_hyc`
    ];
    let currSteps = [`${CabaseScrId}photokyc_hyp`, `${CabaseScrId}AddContact_hyp`, `${CabaseScrId}Insurance_hyp`,
        `${CabaseScrId}IncomeDetail_hyp`, `${CabaseScrId}loanObg_hyp`, `${CabaseScrId}otherdetails_hyp`, `${CabaseScrId}reviewSubmit_hyp`
    ];
    let currentIndex = -1;
    for (let i = 0; i < steps.length; i++) {
        if ($("#" + steps[i]).hasClass("active") || $("#" + steps[i]).hasClass("current")) {
            if (
                (steps[i] === `${CabaseScrId}photokyc_hyp` && photoKycQueriesForNextStage.length > 0) || (steps[i] ===
                    `${CabaseScrId}AddContact_hyp` && addContactQueriesForNextStage.length > 0)) {
                // Skip setting "#icon-sidechk"
            } else {
                $("#" + steps[i] + " use").attr("xlink:href", "#icon-sidechk");
            }
            currentIndex = i;
            break;
        }
    }
    if (currentIndex === -1) {
        currentIndex = 0;
        $("#" + steps[0]).addClass("active");
        if ($("#" + steps[0]).hasClass("current")) {
            $("#" + steps[0] + " svg").addClass('suc');
            $("#" + steps[0] + " use").attr("xlink:href", "#icon-sidechk");
        }
        return;
    }
    $(".current").each(function() {
        let id = $(this).attr("id");
        if (
            (id === `${CabaseScrId}photokyc_hyp` && photoKycQueriesForNextStage.length > 0) || (id === `${CabaseScrId}AddContact_hyp` &&
                addContactQueriesForNextStage.length > 0)) {
            // Skip setting the check icon; icon will be handled by updateInProgressIcon/updateQueryIcon
        } else {
            $(this).find("svg").addClass('suc');
            $(this).find("use").attr("xlink:href", "#icon-sidechk");
        }
    });
    if (currentIndex < steps.length - 1) {
        let curVar = steps[currentIndex];
        $("#" + curVar).removeClass("active current");
        if (curVar !== "CrdAss__Cabase__Verification_hyp" && curVar !== "CrdAss__Cabase__Creditassement_hyp") {
            if (
                (curVar === `${CabaseScrId}photokyc_hyp` && photoKycQueriesForNextStage.length > 0) || (curVar ===
                    `${CabaseScrId}AddContact_hyp` && addContactQueriesForNextStage.length > 0)) {
                // Skip setting the check icon
            } else {
                $("#" + curVar + " svg").addClass('suc');
                $("#" + curVar + " use").attr("xlink:href", "#icon-sidechk");
            }
        }
        window.nextId = steps[currentIndex + 1];
        if (nextId === "CrdAss__Cabase__Verification_hyp") {
            $(`#${CabaseScrId}Verification_hyp`).addClass("active");
            $(`#${CabaseScrId}photokyc_hyp`).addClass("current");
        } else if (nextId === "CrdAss__Cabase__Creditassement_hyp") {
            $(`#${CabaseScrId}Creditassement_hyp`).addClass("active");
            $(`#${CabaseScrId}IncomeDetail_hyp`).addClass("current");
        } else if (currSteps.indexOf(nextId) !== -1) {
            $("#" + nextId).addClass("current");
        } else {
            $("#" + nextId).addClass("active");
        }
    }
    if ($(`#${CabaseScrId}photokyc_hyp use`).attr("xlink:href") === "#icon-sidechk" && $(`#${CabaseScrId}AddContact_hyp use`).attr(
        "xlink:href") === "#icon-sidechk" && $(`#${CabaseScrId}Insurance_hyp use`).attr("xlink:href") === "#icon-sidechk") {
        $(`#${CabaseScrId}Verification_hyp use`).attr("xlink:href", "#icon-sidechk");
    }
    if ($(`#${CabaseScrId}IncomeDetail_hyp use`).attr("xlink:href") === "#icon-sidechk" && $(`#${CabaseScrId}loanObg_hyp use`).attr(
        "xlink:href") === "#icon-sidechk" && $(`#${CabaseScrId}otherdetails_hyp use`).attr("xlink:href") === "#icon-sidechk" && $(
            `#${CabaseScrId}reviewSubmit_hyp use`).attr("xlink:href") === "#icon-sidechk") {
        $(`#${CabaseScrId}Creditassement_hyp use`).attr("xlink:href", "#icon-sidechk");
    }
    if (photoKycQueriesForNextStage.length > 0 || addContactQueriesForNextStage.length > 0) {
        apz.app.Cabase.updateQueryIcon();
    }
    $(document).ready(function() {
        apz.app.Cabase.SidebarSelect.updateTabClasses();
    });
};
apz.app.Cabase.SidebarSelect.updateTabClasses = function() {
    if ($(`#${CabaseScrId}photokyc_hyp`).hasClass("current") || $(`#${CabaseScrId}AddContact_hyp`).hasClass("current") || $(
            `#${CabaseScrId}Insurance_hyp`).hasClass("current")) {
        $(`#${CabaseScrId}Verification_hyp`).addClass("active");
    } else {
        $(`#${CabaseScrId}Verification_hyp`).removeClass("active");
    }
    if ($(`#${CabaseScrId}IncomeDetail_hyp`).hasClass("current") || $(`#${CabaseScrId}loanObg_hyp`).hasClass("current") || $(
            `#${CabaseScrId}otherdetails_hyp`).hasClass("current") || $(`#${CabaseScrId}reviewSubmit_hyp`).hasClass("current")) {
        $(`#${CabaseScrId}Creditassement_hyp`).addClass("active");
    } else {
        $(`#${CabaseScrId}Creditassement_hyp`).removeClass("active");
    }
};
apz.app.Cabase.toggleSidebar = function() {
    $("#CrdAss__Cabase__sidebar_col").toggleClass("sideon");
};
apz.app.Cabase.reject = function() {
    let popUpObj = {};
    popUpObj.text = "Are you sure you want to reject the application ?";
    popUpObj.Btn1 = {
        text: "Yes",
        onClick: "apz.app.Cabase.launchQueryModalBasedOnBtn('Reject')",
    };
    popUpObj.Btn2 = {
        text: "No",
        onClick: "apz.app.Cabase.closeCaConfirmarionMdl()",
    };
    ApzCOB.showCaModals(popUpObj, "confirmation");
};
apz.app.Cabase.sendback = function() {
    let popUpObj = {};
    if (CA_CURRENT_STAGE === "ReviewSubmit") {
        let allStagesVerifiedTillReview = apz.app.Cabase.checkStages([1, 2, 3, 4, 5, 6, 7]);
        if (allStagesVerifiedTillReview) {
            ApzCOB.showCaModals({
                text: "All sections are verified, please submit the case.",
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.Cabase.closeCaErrMdl()"
                }
            }, "Error");
        }
    } else {
        popUpObj.text = "Are you sure you want to send back the application to KM sourcing?";
        popUpObj.Btn1 = {
            text: "Yes",
            onClick: "apz.app.Cabase.launchQueryModalBasedOnBtn('Sendback')",
        };
        popUpObj.Btn2 = {
            text: "No",
            onClick: "apz.app.Cabase.closeCaConfirmarionMdl()",
        };
        ApzCOB.showCaModals(popUpObj, "confirmation");
    }
};
apz.app.Cabase.preview = function() {
    if (apz.childScr === "Caloandetails") {
        ApzCOB.previewModal();
    }
};
apz.app.Cabase.next = function() {
    if (apz.childScr === "Caloandetails") {
        apz.app.Caloandetails.submitLoan('VERIFY');
    } else if (apz.childScr === 'photokyc') {
        apz.app.photokyc.launchNextStage();
    } else if (apz.childScr === 'AddressContactus') {
        apz.app.AddressContactus.launchNextStage();
    } else if (apz.childScr === 'Insurancedetails') {
        apz.app.Insurancedetails.saveInsurancedetails('verify');
    } else if (apz.childScr === 'CaIncomeDetails') {
        apz.app.CaIncomeDetails.OnclickNext();
    } else if (apz.childScr === 'InformalLoanObligation') {
        apz.app.InformalLoanObligation.loanobligationService();
    } else if (apz.childScr === 'CaotherDetails') {
        apz.app.CaotherDetails.onClickNext();
    } else if (apz.childScr === 'CaReviewConfirm') {
        apz.app.CaReviewConfirm.launchNextStage();
    } else if (apz.childScr === 'CaInPrincipleDecision') {
        ApzCOB.launchSubScreen('CaEkyc', "CrdAss__Cabase__caLaunchCol", "");
        apz.app.Cabase.SidebarSelect.moveToNextStep();
    }
};
apz.app.Cabase.back = function() {
    apz.app.Cabase.SidebarSelect.moveToPreviousStep();
    if (apz.childScr === "Caloandetails") {
        apz.app.Cabase.gotoHome();
    } else if (apz.childScr === 'photokyc') {
        ApzCOB.launchSubScreen('Caloandetails', "CrdAss__Cabase__caLaunchCol", "");
    } else if (apz.childScr === 'AddressContactus') {
        ApzCOB.launchSubScreen('photokyc', "CrdAss__Cabase__caLaunchCol", "");
    } else if (apz.childScr === 'Insurancedetails') {
        ApzCOB.launchSubScreen('AddressContactus', "CrdAss__Cabase__caLaunchCol", "");
    } else if (apz.childScr === 'CaIncomeDetails') {
        ApzCOB.launchSubScreen('photokyc', "CrdAss__Cabase__caLaunchCol", "");
    } else if (apz.childScr === 'InformalLoanObligation') {
        ApzCOB.launchSubScreen('CaIncomeDetails', "CrdAss__Cabase__caLaunchCol", "");
    } else if (apz.childScr === 'CaotherDetails') {
        ApzCOB.launchSubScreen('InformalLoanObligation', "CrdAss__Cabase__caLaunchCol", "");
    } else if (apz.childScr === 'CaReviewConfirm') {
        ApzCOB.launchSubScreen('CaotherDetails', "CrdAss__Cabase__caLaunchCol", "");
    } else if (apz.childScr === 'CaInPrincipleDecision') {
        if ($("#CrdAss__CaInPrincipleDecision__inprinciple_row").hasClass('sno') && !$("#CrdAss__CaInPrincipleDecision__inprinciplePreview_row")
            .hasClass('sno')) {
            $("#CrdAss__CaInPrincipleDecision__inprinciple_row").removeClass('sno');
            $("#CrdAss__CaInPrincipleDecision__inprinciplePreview_row").addClass('sno');
            $("#CrdAss__Cabase__reject_btn").removeClass('sno');
            $("#CrdAss__Cabase__submitBtn").removeClass('sno');
        } else {
            apz.app.Cabase.FromInPrincipleBack();
        }
    } else if (apz.childScr === 'CaEkyc') {
        ApzCOB.launchSubScreen('CaInPrincipleDecision', "CrdAss__Cabase__caLaunchCol", "");
    }
};
apz.app.Cabase.submit = function() {
    if (apz.childScr === "Caloandetails") {} else if (apz.childScr === "CaInPrincipleDecision") {
        apz.app.CaInPrincipleDecision.ValidateOnClickOfSubmit();
    }
};
apz.app.Cabase.sanction = function() {
    if (apz.childScr === "Caloandetails") {}
};
apz.app.Cabase.cofirm = function() {
    if (apz.childScr === "Caloandetails") {}
};
apz.app.Cabase.cancel = function() {
    if (apz.childScr === "Caloandetails") {
        if (!apz.isNull(CAloandetails.payload.loanPurpose)) {
            $(`#${scrId}loanDtls_Edit`).removeClass('sno');
            $(`#${scrId}Purposeofloan_dpd`).val(window.CAloandetails?.payload?.loanPurpose).change();
            apz.app.Caloandetails.onchangeloanPurpose();
            $(`#${scrId}Subpurpose_dpd`).val(window.CAloandetails?.payload?.subCategory).change();
        }
        $("#CrdAss__Caloandetails__Purposeofloan_dpd").attr('disabled', true);
        $("#CrdAss__Caloandetails__Subpurpose_dpd").attr('disabled', true);
        ApzCOB.addDisableToInput('CrdAss__Caloandetails__Purposeofloan_dpd');
        ApzCOB.addDisableToInput('CrdAss__Caloandetails__Subpurpose_dpd');
        $(`#${CabaseScrId}reject_btn`).removeClass('sno');
        $(`#${CabaseScrId}sendback_btn`).removeClass('sno');
        $(`#${CabaseScrId}bckBtn`).removeClass('sno');
        $(`#${CabaseScrId}nxtBtn`).removeClass('sno');
        $(`#${CabaseScrId}cancel_btn`).addClass('sno');
        $(`#${CabaseScrId}save_btn`).addClass('sno');
    } else if (apz.childScr === "photokyc") {} else if (apz.childScr === 'AddressContactus') {
        apz.app.AddressContactus.cancelAddressContactUs();
    } else if (apz.childScr === 'Insurancedetails') {
        apz.app.Insurancedetails.cancelInsurancedetails();
    }
};
apz.app.Cabase.save = function() {
    if (apz.childScr === "Caloandetails") {
        apz.app.Caloandetails.submitLoan('Edit');
        apz.app.Cabase.updateInProgressIcon();
    } else
    if (apz.childScr === "photokyc") {} else if (apz.childScr === 'AddressContactus') {
        apz.app.AddressContactus.saveAddressContactUs();
        apz.app.Cabase.updateInProgressIcon();
    } else if (apz.childScr === 'Insurancedetails') {
        apz.app.Insurancedetails.saveInsurancedetails('Edit');
        apz.app.Cabase.updateInProgressIcon();
    }
};
apz.app.Cabase.updateInProgressIcon = function() {
    if (CA_CURRENT_STAGE === 'LoanDetails') {
        $(`#${CabaseScrId}loanDetails_hyp svg`).addClass('pend');
        $(`#${CabaseScrId}loanDetails_hyp use`).attr("xlink:href", "#icon-sideprg");
    }
    if (CA_CURRENT_STAGE === 'AddressContact') {
        $(`#${CabaseScrId}AddContact_hyp svg`).addClass('pend');
        $(`#${CabaseScrId}AddContact_hyp use`).attr("xlink:href", "#icon-sideprg");
    }
    if (CA_CURRENT_STAGE === 'Insurance') {
        $(`#${CabaseScrId}Insurance_hyp svg`).addClass('pend');
        $(`#${CabaseScrId}Insurance_hyp use`).attr("xlink:href", "#icon-sideprg");
    }
}
apz.app.Cabase.updateQueryIcon = function() {
    if (CA_CURRENT_STAGE === 'PhotoKYC') {
        $(`#${CabaseScrId}photokyc_hyp svg`).addClass('err');
        $(`#${CabaseScrId}photokyc_hyp use`).attr("xlink:href", "#icon-fail-filled");
    }
    if (CA_CURRENT_STAGE === 'AddressContact') {
        $(`#${CabaseScrId}AddContact_hyp svg`).addClass('err');
        $(`#${CabaseScrId}AddContact_hyp use`).attr("xlink:href", "#icon-fail-filled");
    }
}
apz.app.Cabase.viewLog = function() {
    let arr = [];
    let timeLineWrapper = structuredClone ? structuredClone(inSessionStore.applicationTimelineDtl) : JSON.parse(JSON.stringify(inSessionStore
        .applicationTimelineDtl))
    timeLineWrapper.forEach(function(el, index) {
        let timeStamp = '---';
        if (el?.timeStamp.includes(' ')) {
            timeStamp = typeof(el.timeStamp) === 'string' ? ApzCOB.dateformatter(el.timeStamp.replace(' ', 'T'), "date", "d/m/Y") : '---';
        }
        if (Array.isArray(el?.rpcStatRemaks)) {
            el.rpcStatRemaks = apz.app.Cabase.getQueryValues(el.rpcStatRemaks);
        }
        let lobj = {
            "stage": apz.isNull(el?.stage) ? "---" : el?.stage,
            "action": apz.isNull(el?.actionTaken) ? "---" : el?.actionTaken,
            "userName": apz.isNull(el?.userId) ? "---" : el?.userId,
            "actionTimeline": timeStamp,
            "rpcStatRemaks": apz.isNull(el?.rpcStatRemaks) ? "---" : el?.rpcStatRemaks,
            "remarks": apz.isNull(el?.remarks) ? "---" : el?.remarks
        }
        arr.push(lobj);
    })
    apz.data.scrdata.APZCBO__ActivityLog_Res = [];
    apz.data.scrdata.APZCBO__ActivityLog_Res = arr;
    apz.data.loadData("ActivityLog", gAppId);
    ApzCOB.toggleModal(BaseScrId + "activityLogModal");
    $('.crt-list li').attr('onClick', '');
    apz.data.scrdata.APZCBO__ActivityLog_Res?.forEach(function(el, index) {
        let rpcStatId = document.getElementById(`${activityIntfId}rpcStatRemaks_${index}_txtcnt`);
        let remarksId = document.getElementById(`${activityIntfId}remarks_${index}_txtcnt`);
        if (Array.isArray(el?.rpcStatRemaks)) {
            if (el.rpcStatRemaks?.length > 0) {
                rpcStatId.innerHTML = el.rpcStatRemaks?.map(msg => `• ${msg}`).join("<br>");
            }
        }
        if (el?.remarks) {
            if (el.remarks.includes('~')) {
                el.remarks = el.remarks.split('~');
            }
            if (Array.isArray(el.remarks) && el.remarks?.length > 0) {
                remarksId.innerHTML = el?.remarks?.map(msg => `• ${msg}`).join("<br>");
            }
        }
    })
};
apz.app.Cabase.getQueryValues = function(queryArray) {
    let allQueries = [];
    if (Array.isArray(queryArray)) {
        queryArray.forEach(({ custType, query, stageID }) => {
            RPC_ALL_STAGE_QUERIES.forEach(rpc => {
                if (rpc.custType === custType && rpc.stageID === stageID) {
                    rpc.query.forEach(queryItem => {
                        if (query.includes(queryItem.id)) {
                            allQueries.push(queryItem.value);
                        }
                    });
                }
            });
        });
    }
    return allQueries || [];
}
apz.app.Cabase.gotoHome = function() {
    apz.app.Login.OnClickMakerChecker("");
};
apz.app.Cabase.approveReject = function(pthis, gaction, IsBREReject) {
    apz.startLoader();
    window.rejectedFromReviewonfirm = false;
    ApzCOB.userDetailsData();
    apz.app.Cabase.stageBasedOnAction(pthis, gaction);
    window.approveRejectAction = gaction;
    if (!apz.isNull(inSessionStore.customerDetailsList)) {
        if (inSessionStore.customerDetailsList.length > 0) {
            inSessionStore.customerDetailsList.map((cust) => {
                if (cust.customerType === "Applicant") {
                    gApzCOB.userDetails.custDtlId = cust.custDtlId;
                } else {
                    gApzCOB.userDetails.CoApplicantCustomerId = cust.custDtlId;
                }
            });
        }
    }
    if ((CA_CURRENT_STAGE === "PhotoKYC" || CA_CURRENT_STAGE === "AddressContact") && BtnClicked === "Sendback") {
        if (!updtdChckdQueriesStringForPhotoKyc) {
            rMarks = apz.app.Cabase.QueriesToBeSendback();
        } else {
            let otherStageQueries = apz.app.Cabase.QueriesToBeSendback(CA_CURRENT_STAGE_NO);
            rMarks = [updtdChckdQueriesStringForPhotoKyc, otherStageQueries].filter(Boolean).join('|');
        }
    } else if (CA_CURRENT_STAGE === "Insurance" && BtnClicked === "Sendback") {
        let otherStagesQueries = apz.app.Cabase.QueriesToBeSendback();
        rMarks = [updatedCheckedQueriesString, otherStagesQueries].filter(Boolean).join('|');
    } else if ((CA_CURRENT_STAGE === "ReviewSubmit" || CA_CURRENT_STAGE === "InPrincipleDecision") && IsBREReject) {
        rejectedFromReviewonfirm = true;
        rMarks = `CB FAILED!. Reject Reason: ${window.rejectRsn}`;
    } else {
        rMarks = updatedCheckedQueriesString;
    }
    if (!apz.isNull(sendBackResponse?.trim()) && gaction === 'SUBMIT') {
        rMarks = sendBackResponse.trim();
    }
    window.approveRejectAction = "";
    switch (gaction) {
        case "SUBMIT":
            window.approveRejectAction = "PENDINGPRESANCTION";
            break;
        case "APPROVED":
            window.approveRejectAction = "RPCVERIFIED";
            break;
        case "PUSHBACK":
            window.approveRejectAction = "IPUSHBACK";
            break;
        case "REJECTED":
            window.approveRejectAction = "REJECTED";
            break;
        case "RPCPUSHBACK":
            window.approveRejectAction = "RPCPUSHBACK";
            break;
        case "CAPUSHBACK":
            window.approveRejectAction = "CAPUSHBACK";
            break;
        default:
            break;
    }
    let req = {
        apiRequest: {
            interfaceName: "",
            appId: gAppId,
            requestObj: {
                appId: gApzCOB.userDetails.appId,
                status: approveRejectAction,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                applicationId: gApzCOB.userDetails.applicationId,
                versionNum: gApzCOB.userDetails.versionNum,
                custDtlId: gApzCOB.userDetails.custDtlId,
                remarks: rMarks,
                workflow: {
                    currentRole: gApzCOB.workflow.currentRole,
                    action: gApzCOB.workflow.action,
                    workflowId: gApzCOB.workflow.workflowId,
                    stage: gApzCOB.workflow.stage,
                },
            },
        },
    };
    ApzCOB.serverBuildParam(gAppId, "Stagemoment", "N", "N", req, false, apz.app.Cabase.approveRejectCB);
};
apz.app.Cabase.approveRejectCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let ifaceName = ApzCOB.GetInterfaceResMap(params);
            if (params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode == 0) {
                if (approveRejectAction === "PENDINGFORRPCVERIFICATION" || approveRejectAction === "APPROVED" || approveRejectAction ===
                    "RPCVERIFIED") {
                    apz.stopLoader();
                    apz.app.Cabase.showSuccessModal("Application No " + gApzCOB.userDetails.applicationId + " Submitted Successsfully.");
                    return;
                }
                if (approveRejectAction === "PENDINGPRESANCTION") {
                    const responseObjStr = params.res?.APZCBO__Stagemoment_Res?.apiResponse?.ResponseBody?.responseObj || "{}";
                    let nextStage = "";
                    try {
                        const responseObj = JSON.parse(responseObjStr);
                        nextStage = responseObj.nextStage;
                    } catch (e) {
                        // ("Failed to parse responseObj:", e);
                    }
                    let displayText = "Credit assessment is completed and sent to ";
                    if (nextStage === "CA_DEVIATION") {
                        displayText += "deviation approval.";
                    } else if (nextStage === "REASSESSMENT") {
                        displayText += "reassessment approval.";
                    } else {
                        displayText += "sanction approval.";
                    }
                    apz.stopLoader();
                    ApzCOB.toggleModal(CabaseScrId + "successModal_CA");
                    $("#CrdAss__Cabase__successModal_CA_window").find("#CrdAss__Cabase__successText_txtcnt").text(displayText);
                    return;
                }
                if (approveRejectAction === "IPUSHBACK" || approveRejectAction === "CAPUSHBACK") {
                    if (approveRejectAction === "IPUSHBACK") {
                        apz.stopLoader();
                        apz.app.Cabase.showSuccessModal("Application No " + gApzCOB.userDetails.applicationId +
                            " Sent back to KM Sourcing Successfully.");
                        return;
                    }
                    if (approveRejectAction === "CAPUSHBACK") {
                        apz.stopLoader();
                        apz.app.Cabase.showSuccessModal("Application No " + gApzCOB.userDetails.applicationId +
                            " Sent back to KM Sourcing Successfully with queries.");
                        return;
                    }
                }
                if (approveRejectAction === "REJECTED") {
                    apz.stopLoader();
                    let dispMsg = "Application No " + gApzCOB.userDetails.applicationId + " Rejected Successfully.";
                    if (rejectedFromReviewonfirm) {
                        dispMsg = `BRE CB failed.<br/>Reject reason: ${window.rejectRsn}.<br/>${dispMsg}`;
                    }
                    apz.app.Cabase.showSuccessModal(dispMsg);
                    return;
                }
            } else {
                ApzCOB.showCaModals({
                    text: "Failed",
                    Btn1: {
                        text: "OK",
                        onClick: "apz.app.Cabase.closeCaErrMdl()"
                    }
                }, "Error");
            }
        } else {
            apz.stopLoader(); // to be done after getting the proper response from backend
            ApzCOB.showCaModals({
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.Cabase.closeCaErrMdl()"
                }
            }, "Error");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.showCaModals({
            text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
    }
    apz.stopLoader();
};
apz.app.Cabase.closeCaErrMdl = function() {
    $(`#${CabaseScrId}CaError_modal`).click();
}
apz.app.Cabase.closeCaConfirmarionMdl = function() {
    $(`#${CabaseScrId}CaConformation_modal`).click();
}
apz.app.Cabase.closeSuccessModalAndProceed = function() {
    $(`#${CabaseScrId}CaSucc_modal`).click();
    apz.app.Login.OnClickMakerChecker('');
};
apz.app.Cabase.showSuccessModal = function(message) {
    let popUpObj = {
        text: message,
        Btn: {
            text: "Ok",
            onClick: "apz.app.Cabase.closeSuccessModalAndProceed()",
        }
    };
    ApzCOB.showCaModals(popUpObj, "Success");
};
apz.app.Cabase.stageBasedOnAction = function(pthis, gaction) {
    let clickedAction = "";
    if (LoggedInUserDetails.loginResponse.addInfo1 == 'BM') {
        if (!apz.isNull(gaction)) {
            if (gaction === 'APPROVED') {
                clickedAction = 'APPROVE';
            } else if (gaction === 'SUBMIT') {
                clickedAction = "SUBMIT";
            } else if (gaction === "CAPUSHBACK") {
                clickedAction = "CAPUSHBACK";
            } else if (gaction === 'PUSHBACK') {
                clickedAction = 'PUSHBACK';
            } else if (gaction === 'REJECTED') {
                clickedAction = 'REJECT';
            }
        }
    }
    if (!apz.isNull(gApzCOB.applnWorkFlowRes)) {
        gApzCOB.applnWorkFlowRes.filter(function(laction) {
            laction.action.split(',').filter(function(s) {
                if (laction.appId === gAppId && clickedAction.split(" ").join("") === s.toLocaleUpperCase()) {
                    gApzCOB.workflow.currentRole = laction.currentRole;
                    gApzCOB.workflow.action = laction.action;
                    gApzCOB.workflow.workflowId = laction.workFlowId;
                    gApzCOB.workflow.stage = laction.fromStageId;
                }
            });
        });
    };
};
