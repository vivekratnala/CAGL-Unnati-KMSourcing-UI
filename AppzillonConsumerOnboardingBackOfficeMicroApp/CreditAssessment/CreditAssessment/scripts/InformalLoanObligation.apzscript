            $(`#${infrmloanObg}coopTenure_Errrow`).addClass('sno');
        }
    }
    if ($("#CrdAss__InformalLoanObligation__localFinance_check").is(":checked")) {
        lcheckboxSelected = true;
        if (apz.isNull($('#CrdAss__InformalLoanObligation__finloanObg_Inp').val())) {
            lvalue = false;
            $(`#${infrmloanObg}finloanObg_Errrow`).removeClass('sno');
        } else {
            $(`#${infrmloanObg}finloanObg_Errrow`).addClass('sno');
        }
        if (apz.isNull($('#CrdAss__InformalLoanObligation__finmntlyEMI_Inp').val())) {
            lvalue = false;
            $(`#${infrmloanObg}finmntly_Errrow`).removeClass('sno');
        } else {
            $(`#${infrmloanObg}finmntly_Errrow`).addClass('sno');
        }
        if (apz.isNull($('#CrdAss__InformalLoanObligation__finTenure_Inp').val())) {
            lvalue = false;
            $(`#${infrmloanObg}fintenure_Errrow`).removeClass('sno');
        } else {
            $(`#${infrmloanObg}fintenure_Errrow`).addClass('sno');
        }
    }
    if ($("#CrdAss__InformalLoanObligation__other_check").is(":checked")) {
        lcheckboxSelected = true;
        if (apz.isNull($('#CrdAss__InformalLoanObligation__OthrObg_Inp').val())) {
            lvalue = false;
            $(`#${infrmloanObg}othr_Errrow`).removeClass('sno');
        } else {
            $(`#${infrmloanObg}othr_Errrow`).addClass('sno');
        }
        if (apz.isNull($('#CrdAss__InformalLoanObligation__othrmntEMI_Inp').val())) {
            lvalue = false;
            $(`#${infrmloanObg}othrmntlyEMI_Errrow`).removeClass('sno');
        } else {
            $(`#${infrmloanObg}othrmntlyEMI_Errrow`).addClass('sno');
        }
        if (apz.isNull($('#CrdAss__InformalLoanObligation__othrTenure_Inp').val())) {
            lvalue = false;
            $(`#${infrmloanObg}othrTenure_Errrow`).removeClass('sno');
        } else {
            $(`#${infrmloanObg}othrTenure_Errrow`).addClass('sno');
        }
    }
    if ($("#CrdAss__InformalLoanObligation__nilloanObg_check").is(":checked")) {
        lcheckboxSelected = true;
    }
    if (!lcheckboxSelected) {
        lvalue = false;
        $(`#${infrmloanObg}none_Errrow`).removeClass('sno');
    } else {
        $(`#${infrmloanObg}none_Errrow`).addClass('sno');
    }
    return lvalue;
}
apz.app.InformalLoanObligation.validateNetIncome = function(input) {
    if (!isNaN(input.value) && input.value > 100000) {
        ApzCOB.fnDisplayMsg("Amount cannot exceed ₹1,00,000.", "E");
        input.value = '';
    }
}
apz.app.InformalLoanObligation.validateZeroInput = function(input) {
    if (input.value.length >= 1 && input.value.startsWith('0')) {
        input.value = input.value.replace(/^0+/, '');
    }
}
apz.app.InformalLoanObligation.remainingTenureMonths = function() {
    const ids = ["fndTnr_Inp", "mnytnur_Inp", "frndTenure_Inp", "relTenure_Inp", "coopTenure_Inp", "finTenure_Inp", "othrTenure_Inp"];
    ids.forEach(id => {
        $("#CrdAss__InformalLoanObligation__" + id).attr("onblur", "");
    });
};
