apz.app.CaIncomeDetails.AgriData = function() {
    var agriData = JSON.parse(inSessionStore.bcmpiIncomeDetails.payload).agriculture;
    var land, land1;
    if (!apz.isNull(agriData) && Object.keys(agriData).length > 0) {
        apz.app.CaIncomeDetails.Agriculture();
        $(`#CrdAss__CaIncomeDetails__AgricultureTypeOption`).prop("checked", true);
        $('#CrdAss__CaIncomeDetails__Agriculture').removeClass('sno');
        $("[id^='CrdAss__CaIncomeDetails__Ap_TypeOfAgri_option_']").removeClass("is-selected");
        $("[id^='CrdAss__CaIncomeDetails__Ap_CropType_option_']").removeClass("is-selected");
        $("[id^='CrdAss__CaIncomeDetails__Ap_Land_option_']").removeClass("is-selected");
        if (agriData.hasOwnProperty("applicant") && agriData.hasOwnProperty("coApplicant")) {
            $(`#CrdAss__CaIncomeDetails__Agri_Owned_option_Both`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Agriculture'} #${CaIncomeDetailsScrId}Applicant`).removeClass("sno");
            $(`#${'CrdAss__CaIncomeDetails__Agriculture'} #${CaIncomeDetailsScrId}Co-Applicant`).removeClass("sno");
            $(`#${CaIncomeDetailsScrId}Ap_TypeOfAgri`).val(agriData.applicant.typeOfAgriculture);
            $("#CrdAss__CaIncomeDetails__Ap_TypeOfAgri_option_" + agriData.applicant.typeOfAgriculture).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Ap_CropType`).val(agriData.applicant.cropType);
            //$("#CrdAss__CaIncomeDetails__Ap_CropType_option_" + agriData.applicant.Ap_CropType).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Ap_Crop`).val(agriData.applicant.crop);
            AgrilandInAcres.forEach(function(k, i) {
                if (AgrilandInAcres[i].val === agriData.applicant.land) {
                    land = AgrilandInAcres[i].desc
                    land1 = AgrilandInAcres[i].val
                }
            })
            $(`#${CaIncomeDetailsScrId}Ap_Land`).val(land);
            $("#CrdAss__CaIncomeDetails__Ap_Land_option_" + land1).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Ap_MaxperArc`).val(agriData.applicant.maxYeildPerAcre);
            $(`#${CaIncomeDetailsScrId}Agri_MonthIncome`).val(agriData.applicant?.monthlyIncome);
            $(`#${CaIncomeDetailsScrId}Agri_ConsideredIncome`).val(agriData.applicant?.consideredIncome);
            $(`#${CaIncomeDetailsScrId}Ap_LandInAcres`).val(agriData.applicant?.landInAcres);
            $(`#${CaIncomeDetailsScrId}Agri_DeclaredIncome`).val(agriData.applicant?.declaredIncome);
            $(`#${CaIncomeDetailsScrId}Co_TypeOfAgri`).val(agriData.coApplicant.typeOfAgriculture);
            $("#CrdAss__CaIncomeDetails__Co_TypeOfAgri_option_" + agriData.coApplicant.typeOfAgriculture).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Co_CropType`).val(agriData.coApplicant.cropType);
            $(`#${CaIncomeDetailsScrId}Co_Crop`).val(agriData.coApplicant.crop);
            AgrilandInAcres.forEach(function(k, i) {
                if (AgrilandInAcres[i].val === agriData.coApplicant.land) {
                    land = AgrilandInAcres[i].desc
                    land1 = AgrilandInAcres[i].val
                }
            })
            $(`#${CaIncomeDetailsScrId}Co_Land`).val(land);
            $("#CrdAss__CaIncomeDetails__Co_Land_option_" + land1).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Co_MaxPerAcrc`).val(agriData.coApplicant.maxYeildPerAcre);
            $(`#${CaIncomeDetailsScrId}Co_Agri_Month_income`).val(agriData.coApplicant?.monthlyIncome);
            $(`#${CaIncomeDetailsScrId}Co_Agri_ConsideredIncome`).val(agriData.coApplicant?.consideredIncome);
            $(`#${CaIncomeDetailsScrId}Co_LandInAcres`).val(agriData.coApplicant?.landInAcres);
            $(`#${CaIncomeDetailsScrId}Co_Agri_DeclaredIncome`).val(agriData.coApplicant?.declaredIncome);
            ["Applicant", "Co-Applicant"].forEach(role => {
                TempImageObject.index = role;
                TempImageObject.Type = "Agriculture";
                apz.app.CaIncomeDetails.paintDocumentName("Agriculture Doc");
            });
        } else if (agriData.hasOwnProperty("applicant")) {
            $(`#CrdAss__CaIncomeDetails__Agri_Owned_option_Applicant`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Agriculture'} #${CaIncomeDetailsScrId}${'Applicant'}`).removeClass("sno");
            $(`#${CaIncomeDetailsScrId}Ap_TypeOfAgri`).val(agriData.applicant.typeOfAgriculture);
            $("#CrdAss__CaIncomeDetails__Ap_TypeOfAgri_option_" + agriData.applicant.typeOfAgriculture).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Ap_CropType`).val(agriData.applicant.cropType);
            //$("#CrdAss__CaIncomeDetails__Ap_CropType_option_" + agriData.applicant.cropType).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Ap_Crop`).val(agriData.applicant.crop);
            AgrilandInAcres.forEach(function(k, i) {
                if (AgrilandInAcres[i].val === agriData.applicant.land) {
                    land = AgrilandInAcres[i].desc
                    land1 = AgrilandInAcres[i].val
                }
            })
            $(`#${CaIncomeDetailsScrId}Ap_Land`).val(land);
            $("#CrdAss__CaIncomeDetails__Ap_Land_option_" + land1).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Ap_MaxperArc`).val(agriData.applicant.maxYeildPerAcre);
            $(`#${CaIncomeDetailsScrId}Agri_MonthIncome`).val(agriData.applicant?.monthlyIncome);
            $(`#${CaIncomeDetailsScrId}Agri_ConsideredIncome`).val(agriData.applicant?.consideredIncome);
            $(`#${CaIncomeDetailsScrId}Ap_LandInAcres`).val(agriData.applicant?.landInAcres);
            $(`#${CaIncomeDetailsScrId}Agri_DeclaredIncome`).val(agriData.applicant?.declaredIncome);
            TempImageObject = {
                index: "Applicant",
                Type: "Agriculture"
            };
            apz.app.CaIncomeDetails.paintDocumentName("Agriculture Doc");
        } else if (agriData.hasOwnProperty("coApplicant")) {
            $(`#CrdAss__CaIncomeDetails__Agri_Owned_option_Co-Applicant`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Agriculture'} #${CaIncomeDetailsScrId}${'Co-Applicant'}`).removeClass("sno");
            $(`#${CaIncomeDetailsScrId}Co_TypeOfAgri`).val(agriData.coApplicant.typeOfAgriculture);
            $("#CrdAss__CaIncomeDetails__Co_TypeOfAgri_option_" + agriData.coApplicant.typeOfAgriculture).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Co_CropType`).val(agriData.coApplicant.cropType);
            $(`#${CaIncomeDetailsScrId}Co_Crop`).val(agriData.coApplicant.crop);
            AgrilandInAcres.forEach(function(k, i) {
                if (AgrilandInAcres[i].val === agriData.coApplicant.land) {
                    land = AgrilandInAcres[i].desc
                    land1 = AgrilandInAcres[i].val
                }
            })
            $(`#${CaIncomeDetailsScrId}Co_Land`).val(land);
            $("#CrdAss__CaIncomeDetails__Co_Land_option_" + land1).addClass("is-selected");
            $(`#${CaIncomeDetailsScrId}Co_MaxPerAcrc`).val(agriData.coApplicant.maxYeildPerAcre);
            $(`#${CaIncomeDetailsScrId}Co_Agri_Month_income`).val(agriData.coApplicant?.monthlyIncome);
            $(`#${CaIncomeDetailsScrId}Co_Agri_ConsideredIncome`).val(agriData.coApplicant?.consideredIncome);
            $(`#${CaIncomeDetailsScrId}Co_LandInAcres`).val(agriData.coApplicant?.landInAcres);
            $(`#${CaIncomeDetailsScrId}Co_Agri_DeclaredIncome`).val(agriData.coApplicant?.declaredIncome);
            TempImageObject = {
                index: "Co-Applicant",
                Type: "Agriculture"
            };
            apz.app.CaIncomeDetails.paintDocumentName("Agriculture Doc");
        } else {
            //
        }
    }
}
apz.app.CaIncomeDetails.BusinessData = function() {
    var businessData = JSON.parse(inSessionStore.bcmpiIncomeDetails.payload).business;
    var id = 0;
    if (!apz.isNull(businessData)) {
        if (businessData?.dairy?.length > 0 || businessData?.Kirana?.length > 0 || businessData?.Tailoring?.length > 0 || businessData?.Other
            ?.length > 0) {
            $(`#CrdAss__CaIncomeDetails__businessTypeOption`).prop("checked", true);
            if (businessData.hasOwnProperty("dairy") && businessData.dairy.length > 0) {
                businessData.dairy.forEach((dairyEntry) => {
                    id = id + 1;
                    const obj = {
                        TypeChecked: true,
                        sectionName: 'Business',
                        id: String(id)
                    };
                    apz.app.CaIncomeDetails.launchBusinessSection('', obj);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessOwnedByOption_option_' + dairyEntry.DairyType).prop("checked", true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessTypeOption_option_Dairy').prop("checked", true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessOwnedByOption input[type="radio"]').prop('disabled', true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessTypeOption input[type="radio"]').prop('disabled', true);
                    $("#" + CaIncomeDetailsScrId + id + "_businessTypeSec").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_businessImgSec").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_addBusinessDetails_ul").addClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_BusinessNoTxt").text("Business " + id);
                    //$(`#${CaIncomeDetailsScrId}${numberOfBusinessCount}_BusinessNoTxt`).text("Business " + numberOfBusinessCount);
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl1_grp_lbl").text("Total No of Cows / Buffalo");
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl1").val(dairyEntry.totalCowsAndBuffalos);
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl2").val(dairyEntry.IncomeAssessmentChecknetBusinessIncome);
                    $("#" + CaIncomeDetailsScrId + id + "_viewBusinessDetails_ul").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_DeleteIcon_ul").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_addBusiness").attr("disabled", false);
                    custTypeIncomeDtls = dairyEntry.DairyType;
                    TempImageObject = {
                        index: id,
                        Type: "Dairy",
                        custTypeIncomeDtls: custTypeIncomeDtls
                    };
                    apz.app.CaIncomeDetails.paintDocumentName("Dairy Doc");
                });
            }
            if (businessData.hasOwnProperty("Kirana") && businessData.Kirana.length > 0) {
                //FinalvaluesArr = JSON.parse(inSessionStore.bcmpiIncomeDetails.payload).Business;
                businessData.Kirana.forEach((KiranaEntry) => {
                    id = id + 1;
                    var obj = {
                        TypeChecked: true,
                        sectionName: 'Business',
                        id: String(id)
                    }
                    apz.app.CaIncomeDetails.launchBusinessSection('', obj)
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessOwnedByOption_option_' + KiranaEntry.kiranaType).prop("checked",
                    true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessTypeOption_option_Kirana').prop("checked", true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessOwnedByOption input[type="radio"]').prop('disabled', true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessTypeOption input[type="radio"]').prop('disabled', true);
                    $("#" + CaIncomeDetailsScrId + id + "_businessTypeSec").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_businessImgSec").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_addBusinessDetails_ul").addClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl1_grp_lbl").text("Type of Shop");
                    $("#" + CaIncomeDetailsScrId + id + "_BusinessNoTxt").text("Business " + id);
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl1").val(KiranaEntry["kiranaShopType"]);
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl2").val(KiranaEntry.finalNetIncome);
                    $("#" + CaIncomeDetailsScrId + id + "_viewBusinessDetails_ul").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_DeleteIcon_ul").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_addBusiness").attr("disabled", false);
                    custTypeIncomeDtls = KiranaEntry.kiranaType;
                    TempImageObject = {
                        index: id,
                        Type: "Kirana",
                        custTypeIncomeDtls: custTypeIncomeDtls
                    };
                    apz.app.CaIncomeDetails.paintDocumentName("Kirana Doc");
                });
            }
            if (businessData.hasOwnProperty("Other") && businessData.Other.length > 0) {
                //FinalvaluesArr = JSON.parse(inSessionStore.bcmpiIncomeDetails.payload).Business;
                businessData.Other.forEach((OtherEntry) => {
                    id = id + 1;
                    var obj = {
                        TypeChecked: true,
                        sectionName: 'Business',
                        id: String(id)
                    }
                    apz.app.CaIncomeDetails.launchBusinessSection('', obj)
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessOwnedByOption_option_' + OtherEntry.otherType).prop("checked", true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessTypeOption_option_Other').prop("checked", true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessOwnedByOption input[type="radio"]').prop('disabled', true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessTypeOption input[type="radio"]').prop('disabled', true);
                    $("#" + CaIncomeDetailsScrId + id + "_businessTypeSec").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_businessImgSec").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_addBusinessDetails_ul").addClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl1_grp_lbl").text("Other line of business");
                    $("#" + CaIncomeDetailsScrId + id + "_BusinessNoTxt").text("Business " + id);
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl1").val(OtherEntry.lineOfOtherBusiness);
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl2").val(OtherEntry.netBusinessIncome);
                    $("#" + CaIncomeDetailsScrId + id + "_viewBusinessDetails_ul").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_DeleteIcon_ul").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_addBusiness").attr("disabled", false);
                    custTypeIncomeDtls = OtherEntry.otherType;
                    TempImageObject = {
                        index: id,
                        Type: "Other",
                        custTypeIncomeDtls: custTypeIncomeDtls
                    };
                    apz.app.CaIncomeDetails.paintDocumentName("Other Doc");
                });
            }
            if (businessData.hasOwnProperty("Tailoring") && businessData.Tailoring.length > 0) {
                //FinalvaluesArr = JSON.parse(inSessionStore.bcmpiIncomeDetails.payload).Business;
                businessData.Tailoring.forEach((TailoringEntry) => {
                    id = id + 1;
                    var obj = {
                        TypeChecked: true,
                        sectionName: 'Business',
                        id: String(id)
                    }
                    apz.app.CaIncomeDetails.launchBusinessSection('', obj)
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessOwnedByOption_option_' + TailoringEntry.tailoringType).prop("checked",
                        true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessTypeOption_option_Tailoring').prop("checked", true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessOwnedByOption input[type="radio"]').prop('disabled', true);
                    $('#CrdAss__CaIncomeDetails__' + id + '_businessTypeOption input[type="radio"]').prop('disabled', true);
                    $("#" + CaIncomeDetailsScrId + id + "_businessTypeSec").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_businessImgSec").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_addBusinessDetails_ul").addClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl1_grp_lbl").text("Revenue per Month");
                    $("#" + CaIncomeDetailsScrId + id + "_BusinessNoTxt").text("Business " + id);
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl1").val(TailoringEntry["totalMonthlyIncome"]);
                    $("#" + CaIncomeDetailsScrId + id + "_businessLbl2").val(TailoringEntry.netBusinessIncome);
                    $("#" + CaIncomeDetailsScrId + id + "_viewBusinessDetails_ul").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_DeleteIcon_ul").removeClass("sno");
                    $("#" + CaIncomeDetailsScrId + id + "_addBusiness").attr("disabled", false);
                    custTypeIncomeDtls = TailoringEntry.tailoringType;
                    TempImageObject = {
                        index: id,
                        Type: "Tailoring",
                        custTypeIncomeDtls: custTypeIncomeDtls
                    };
                    apz.app.CaIncomeDetails.paintDocumentName("Tailoring Doc");
                });
            }
        }
        apz.app.CaIncomeDetails.disableDeleteButtons();
        apz.app.CaIncomeDetails.getSelectedBusinessTypes();
    }
    if (inSessionStore?.bcmpiIncomeDetails) {
        if (JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.dairy?.length > 0 && FinalvaluesArr?.dairy?.length === 0) {
            FinalvaluesArr.dairy = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.dairy;
        }
        if (JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Kirana?.length > 0 && FinalvaluesArr?.Kirana?.length === 0) {
            FinalvaluesArr.Kirana = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Kirana;
        }
        if (JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Tailoring?.length > 0 && FinalvaluesArr?.Tailoring?.length === 0) {
            FinalvaluesArr.Tailoring = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Tailoring;
        }
        if (JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Other?.length > 0 && FinalvaluesArr?.Other?.length === 0) {
            FinalvaluesArr.Other = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Other;
        }
    }
}
apz.app.CaIncomeDetails.WageData = function() {
    var applicantJobs = ['farmWorker', 'constructions', 'contractLabour', 'hotelWorker', 'maid', 'other'];
    var wageData = JSON.parse(inSessionStore.bcmpiIncomeDetails.payload).wage;
    if (!apz.isNull(wageData) && Object.keys(wageData).length > 0) {
        $(`#CrdAss__CaIncomeDetails__WageTypeOption`).prop("checked", true);
        $('#CrdAss__CaIncomeDetails__Wage').removeClass('sno');
        var id = $('#CrdAss__CaIncomeDetails__WageRowApp');
        if (wageData.hasOwnProperty("applicant") && wageData.hasOwnProperty("coApplicant")) {
            $(`#CrdAss__CaIncomeDetails__WageOwn_Owned_option_Both`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Wage'} #${CaIncomeDetailsScrId}${'Applicant'}`).removeClass("sno");
            applicantJobs.forEach(job => {
                if (wageData.applicant.hasOwnProperty(job)) {
                    var activtyType = job.replace(/([a-z])([A-Z])/g, '$1_$2'); // Add underscore between camelCase
                    activtyType = activtyType.charAt(0).toUpperCase() + activtyType.slice(1);
                    var val = 'App_' + activtyType;
                    if (job === 'constructions') {
                        val = 'App_constructions';
                    } else if (job === 'contractLabour') {
                        val = 'App_Contract_labour';
                    }
                    // $('#CrdAss__CaIncomeDetails__' + val).prop("disabled", true);
                    const obj = {
                        id: val,
                        checked: 'true',
                        type: 'App_'
                    };
                    $('#CrdAss__CaIncomeDetails__' + val).prop("checked", true);
                    apz.app.CaIncomeDetails.OncheckedCheckBox('', obj);
                    $('#' + CaIncomeDetailsScrId + 'WageEarnedPerDay_' + val).val(wageData.applicant[job].wageEarnedPerDay);
                    $('#' + CaIncomeDetailsScrId + 'NoOFDaysInMonth_' + val).val(wageData.applicant[job].noOfDaysInMonth);
                    $('#' + CaIncomeDetailsScrId + 'ToTalWagePerMonth_' + val).val(wageData.applicant[job].totalWagePerMonth);
                    $('#' + CaIncomeDetailsScrId + 'DeclaredWages_' + val).val(wageData.applicant[job].selfDeclaredWage);
                    $('#' + CaIncomeDetailsScrId + 'OtherAct_' + val).val(wageData.applicant[job].otherAct);
                }
            });
            $(`#${'CrdAss__CaIncomeDetails__Wage'} #${CaIncomeDetailsScrId}${'Co-Applicant'}`).removeClass("sno");
            applicantJobs.forEach(job => {
                if (wageData.coApplicant.hasOwnProperty(job)) {
                    var activtyType = job.replace(/([a-z])([A-Z])/g, '$1_$2'); // Add underscore between camelCase
                    activtyType = activtyType.charAt(0).toUpperCase() + activtyType.slice(1);
                    var val = 'Co_' + activtyType;
                    if (job === 'constructions') {
                        val = 'Co_constructions';
                    } else if (job === 'contractLabour') {
                        val = 'Co_Contract_labour';
                    }
                    // $('#CrdAss__CaIncomeDetails__' + val).prop("disabled", true);
                    const obj = {
                        id: val,
                        checked: 'true',
                        type: 'Co_'
                    };
                    $('#CrdAss__CaIncomeDetails__' + val).prop("checked", true);
                    apz.app.CaIncomeDetails.OncheckedCheckBox('', obj);
                    $('#' + CaIncomeDetailsScrId + 'WageEarnedPerDay_' + val).val(wageData.coApplicant[job].wageEarnedPerDay);
                    $('#' + CaIncomeDetailsScrId + 'NoOFDaysInMonth_' + val).val(wageData.coApplicant[job].noOfDaysInMonth);
                    $('#' + CaIncomeDetailsScrId + 'ToTalWagePerMonth_' + val).val(wageData.coApplicant[job].totalWagePerMonth);
                    $('#' + CaIncomeDetailsScrId + 'DeclaredWages_' + val).val(wageData.coApplicant[job].selfDeclaredWage);
                    $('#' + CaIncomeDetailsScrId + 'OtherAct_' + val).val(wageData.coApplicant[job].otherAct);
                }
            });
        } else if (wageData.hasOwnProperty("applicant")) {
            $(`#CrdAss__CaIncomeDetails__WageOwn_Owned_option_Applicant`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Wage'} #${CaIncomeDetailsScrId}${'Applicant'}`).removeClass("sno");
            applicantJobs.forEach(job => {
                if (wageData.applicant.hasOwnProperty(job)) {
                    var activtyType = job.replace(/([a-z])([A-Z])/g, '$1_$2'); // Add underscore between camelCase
                    activtyType = activtyType.charAt(0).toUpperCase() + activtyType.slice(1);
                    var val = 'App_' + activtyType
                    if (job === 'constructions') {
                        val = 'App_constructions';
                    } else if (job === 'contractLabour') {
                        val = 'App_Contract_labour';
                    }
                    // $('#CrdAss__CaIncomeDetails__' + val).prop("disabled", true);
                    const obj = {
                        id: val,
                        checked: 'true',
                        type: 'App_'
                    };
                    $('#CrdAss__CaIncomeDetails__' + val).prop("checked", true);
                    apz.app.CaIncomeDetails.OncheckedCheckBox('', obj);
                    $('#' + CaIncomeDetailsScrId + 'WageEarnedPerDay_' + val).val(wageData.applicant[job].wageEarnedPerDay);
                    $('#' + CaIncomeDetailsScrId + 'NoOFDaysInMonth_' + val).val(wageData.applicant[job].noOfDaysInMonth);
                    $('#' + CaIncomeDetailsScrId + 'ToTalWagePerMonth_' + val).val(wageData.applicant[job].totalWagePerMonth);
                    $('#' + CaIncomeDetailsScrId + 'DeclaredWages_' + val).val(wageData.applicant[job].selfDeclaredWage);
                    $('#' + CaIncomeDetailsScrId + 'OtherAct_' + val).val(wageData.applicant[job].otherAct);
                }
            });
        } else if (wageData.hasOwnProperty("coApplicant")) {
            $(`#CrdAss__CaIncomeDetails__WageOwn_Owned_option_Co-Applicant`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Wage'} #${CaIncomeDetailsScrId}${'Co-Applicant'}`).removeClass("sno");
            applicantJobs.forEach(job => {
                if (wageData.coApplicant.hasOwnProperty(job)) {
                    var activtyType = job.replace(/([a-z])([A-Z])/g, '$1_$2'); // Add underscore between camelCase
                    activtyType = activtyType.charAt(0).toUpperCase() + activtyType.slice(1);
                    var val = 'Co_' + activtyType
                    if (job === 'constructions') {
                        val = 'Co_constructions';
                    } else if (job === 'contractLabour') {
                        val = 'Co_Contract_labour';
                    }
                    // $('#CrdAss__CaIncomeDetails__' + val).prop("disabled", true);
                    const obj = {
                        id: val,
                        checked: 'true',
                        type: 'Co_'
                    };
                    $('#CrdAss__CaIncomeDetails__' + val).prop("checked", true);
                    apz.app.CaIncomeDetails.OncheckedCheckBox('', obj);
                    $('#' + CaIncomeDetailsScrId + 'WageEarnedPerDay_' + val).val(wageData.coApplicant[job].wageEarnedPerDay);
                    $('#' + CaIncomeDetailsScrId + 'NoOFDaysInMonth_' + val).val(wageData.coApplicant[job].noOfDaysInMonth);
                    $('#' + CaIncomeDetailsScrId + 'ToTalWagePerMonth_' + val).val(wageData.coApplicant[job].totalWagePerMonth);
                    $('#' + CaIncomeDetailsScrId + 'DeclaredWages_' + val).val(wageData.coApplicant[job].selfDeclaredWage);
                    $('#' + CaIncomeDetailsScrId + 'OtherAct_' + val).val(wageData.coApplicant[job].otherAct);
                }
            });
        } else {
            //
        }
    }
}
apz.app.CaIncomeDetails.validateMaxDocs = function(parentSelector, childClass, pthis) {
    if (/business/i.test(parentSelector)) {
        const indexToInsert = pthis?.id.split("__")[2].split("_")[0]; // e.g., "1"
        const parts = parentSelector.split("__");
        parentSelector = parts.slice(0, 2).join("__") + "__" + indexToInsert + "_" + parts.slice(2).join("__");
    }
    let fileCount = $(`#${parentSelector}`).find(`.${childClass}`).length;
    if (fileCount >= 4) {
        ApzCOB.fnDisplayMsg("User allowed to upload maximum of 4 documents")
    } else {
        apz.app.CaIncomeDetails.camera(pthis);
    }
}
apz.app.CaIncomeDetails.optedSourceofIncome = function() {
    const optedSI = [];
    const listofCBinSI = document.querySelectorAll('#CrdAss__CaIncomeDetails__sc_col_3 input[type="CHECKBOX"]');
    if (listofCBinSI.length > 0) {
        listofCBinSI.forEach(item => {
            if (item.checked) {
                let docName = item.split('__')[2].replace('TypeOption', ' Doc')
                optedSI.push(docName);
            }
        })
    }
}
apz.app.CaIncomeDetails.validateDocs = function(parentSelector, childClass) {
    let $files = $(`#${parentSelector}`).find(`.${childClass}`);
    let fileCount = $files.length;
    // If only one file and it has class "sno", treat as no file(for deleting individual document)
    if (fileCount === 1 && $files.hasClass("sno")) {
        fileCount = 0;
    }
    // let fileCount = $(`#${parentSelector}`).find(`.${childClass}`).length;
    if (fileCount === 0) {
        ApzCOB.fnDisplayMsg("Please upload at least one document")
        return false;
    }
    return true;
}
apz.app.CaIncomeDetails.validateSalary = function(pthis) {
    if (parseInt(pthis.value) === 0) {
        ApzCOB.fnDisplayMsg("please enter valid amount");
    }
    const applicantNetSall = $(`#${CaIncomeDetailsScrId}NetSal`).val();
    const coApplicantNetSal = $(`#${CaIncomeDetailsScrId}NetSalCo`).val();
    if (apz.app.CaIncomeDetails.formatAmount(applicantNetSall) > apz.app.CaIncomeDetails.formatAmount(applicantGrossSal)) {
        $(`#${CaIncomeDetailsScrId}NetSal`).val("");
        ApzCOB.fnDisplayMsg("Applicant Net salary should be less than gross salary")
    }
    if (apz.app.CaIncomeDetails.formatAmount(coApplicantNetSal) > apz.app.CaIncomeDetails.formatAmount(coApplicantGrossSal)) {
        $(`#${CaIncomeDetailsScrId}NetSalCo`).val("");
        ApzCOB.fnDisplayMsg("Co-Applicant Net salary should be less than gross salry")
    }
}
apz.app.CaIncomeDetails.formatAmount = function(val) {
    return parseInt(val.replace(/,/g, ''), 10) || 0;
}
apz.app.CaIncomeDetails.validatePensionData = function(pthis) {
    if (parseInt(pthis.value) === 0) {
        ApzCOB.fnDisplayMsg("please enter valid amount");
    }
}
apz.app.CaIncomeDetails.validateAlphabetsAndCommaForAgri = function(pthis) {
    let value = pthis.value;
    value = value.replace(/[^a-zA-Z,]/g, '');
    value = value.replace(/,,+/g, ',');
    value = value.replace(/^,/, '');
    pthis.value = value;
}
apz.app.CaIncomeDetails.validateAlphanumWithSpecial = function(pthis) {
    let value = pthis.value;
    value = value.replace(/[^\x20-\x7E]/g, '');
    pthis.value = value;
};
apz.app.CaIncomeDetails.validateAlphanumWithSomeSpecial = function(pthis) {
    let value = pthis.value;
    // Allow: a-z, A-Z, 0-9, space, comma, #, /
    value = value.replace(/[^a-zA-Z0-9 ,#\/]/g, '');
    pthis.value = value;
};
apz.app.CaIncomeDetails.validateZeroInput = function(input) {
    if (input.value.length >= 1 && input.value.startsWith('0')) {
        input.value = input.value.replace(/^0+/, '');
    }
}
apz.app.CaIncomeDetails.validateZeroInputs = function(input) {
    if (input.value.length > 1 && input.value.startsWith('0')) {
        input.value = input.value.replace(/^0+/, '');
    }
};
apz.app.CaIncomeDetails.validateNetIncome = function(input) {
    if (!isNaN(input.value) && input.value > 100000) {
        ApzCOB.fnDisplayMsg("Amount cannot exceed ₹1,00,000.", "E");
        input.value = '';
    }
};
apz.app.CaIncomeDetails.validateSelfDeclaredIncome = function(input) {
    if (!isNaN(input.value) && input.value > 1200000) {
        ApzCOB.fnDisplayMsg("Amount cannot exceed ₹12,00,000.", "E");
        input.value = '';
    }
}
apz.app.CaIncomeDetails.validatemaxlength = function(input) {
    input.value = input.value.trim();
    if (input.value.length < 3) {
        ApzCOB.fnDisplayMsg("Please enter at least 3 characters", "E");
        document.getElementById(input.id).value = '';
        return;
    }
    if (input.value.length > 100) {
        ApzCOB.fnDisplayMsg("Maximum 100 characters allowed", "E");
        input.value = input.value.substring(0, 100);
        document.getElementById(input.id).value = '';
    }
};
apz.app.CaIncomeDetails.validateAlphanumWithSpace = function(pthis) {
    let value = pthis.value;
    // Remove everything except letters (a-z, A-Z), digits (0-9), and spaces
    value = value.replace(/[^a-zA-Z0-9 ]/g, '');
    pthis.value = value;
};
apz.app.CaIncomeDetails.validateMinLength = function(input) {
    const digitOnlyValue = input.value.replace('.', '');
    if (digitOnlyValue.length < 4) {
        ApzCOB.fnDisplayMsg("Please enter at least 4 digits", "E");
        input.value = '';
    }
}
apz.app.CaIncomeDetails.validatelength = function(input) {
    const digitOnlyValue = input.value.replace('.', '');
    if (digitOnlyValue.length < 6) {
        ApzCOB.fnDisplayMsg("Please enter at least 4 digits", "E");
        input.value = '';
    }
}
apz.app.CaIncomeDetails.paintOwnedBy = function(type, Count) {
    var ownedBy;
    if ($('#CrdAss__CaIncomeDetails__' + Count + '_businessOwnedByOption_option_Applicant').prop('checked')) {
        ownedBy = 'Applicant'
    } else if ($('#CrdAss__CaIncomeDetails__' + Count + '_businessOwnedByOption_option_Co-Applicant').prop('checked')) {
        ownedBy = 'Co-Applicant'
    } else if ($('#CrdAss__CaIncomeDetails__' + Count + '_businessOwnedByOption_option_Both').prop('checked')) {
        ownedBy = 'Both'
    }
    if (type === 'Dairy') {
        $('#CrdAss__CaIncomeDetails__Dairy_Bus_Type').text('Dairy business - ' + ownedBy)
    } else if (type === 'Kirana') {
        $('#CrdAss__CaIncomeDetails__Kirana_Bus_Type').text('Kirana business - ' + ownedBy)
    } else if (type === 'Tailoring') {
        $('#CrdAss__CaIncomeDetails__Tail_Bus_Type').text('Tailoring business - ' + ownedBy)
    } else if (type === 'Other') {
        $('#CrdAss__CaIncomeDetails__Other_Bus_Type').text('Other business - ' + ownedBy)
    }
}
apz.app.CaIncomeDetails.disableDeleteButtons = function() {
    let validIndexes = [];
    for (let i = 1; i <= 12; i++) {
        let cloneRow = $("#CrdAss__CaIncomeDetails__CloneRow_" + i);
        if (cloneRow.length > 0 && !cloneRow.hasClass("sno")) {
            validIndexes.push(i);
        }
    }
    if (validIndexes.length > 0) {
        for (let j = 0; j < validIndexes.length - 1; j++) {
            let deleteButton = $("#CrdAss__CaIncomeDetails__" + validIndexes[j] + "_DeleteIcon");
            deleteButton.prop('disabled', true);
        }
        let lastValidIndex = validIndexes[validIndexes.length - 1];
        let lastDeleteButton = $("#CrdAss__CaIncomeDetails__" + lastValidIndex + "_DeleteIcon");
        lastDeleteButton.prop('disabled', false);
        lastDeleteButton.removeClass('disabled-button');
    }
}
apz.app.CaIncomeDetails.getSelectedBusinessTypes = function() {
    selectedBusinessTypesIncomeDtls = {};
    for (let i = 1; i <= 12; i++) {
        const cloneRow = document.getElementById(`CrdAss__CaIncomeDetails__CloneRow_${i}`);
        // Check if the row exists and doesn't have class 'sno'
        if (cloneRow && !cloneRow.classList.contains('sno')) {
            const checkedRadio = document.querySelector(`#CrdAss__CaIncomeDetails__${i}_businessTypeOption input[type="radio"]:checked`);
            if (checkedRadio) {
                selectedBusinessTypesIncomeDtls[i] = checkedRadio.value;
            }
        }
    }
}
apz.app.CaIncomeDetails.getUploadedDocsForSelectedIncome = function(incomeType) {
    const docsData = inSessionStore?.applicationDocumentsWrapperList?.[0]?.applicationDocumentsList || [];
    const recheckCheckbox = () => {
        const checkboxIdMap = {
            "Agriculture": "CrdAss__CaIncomeDetails__AgricultureTypeOption",
            "Salary": "CrdAss__CaIncomeDetails__SalaryTypeOption",
            "Wage": "CrdAss__CaIncomeDetails__WageTypeOption",
            "Pension": "CrdAss__CaIncomeDetails__PensionTypeOption",
            "Rentalincome": "CrdAss__CaIncomeDetails__RentalincomeTypeOption",
            "Business": "CrdAss__CaIncomeDetails__businessTypeOption"
        };
        const checkboxId = checkboxIdMap[incomeType];
        if (checkboxId) {
            $("#" + checkboxId).prop("checked", true);
        }
    };
    if (incomeType === "Business") {
        const businessTypes = Object.values(selectedBusinessTypesIncomeDtls || {});
        if (businessTypes.length > 0) {
            for (let type of businessTypes) {
                const docTypeToSearch = `${type} Doc`;
                const hasDoc = docsData.some(doc => doc?.payload?.documentType === docTypeToSearch);
                if (hasDoc) {
                    ApzCOB.showCaModals({
                        text: "Please delete all the documents first",
                        Btn1: {
                            text: "OK",
                            onClick: "apz.app.Cabase.closeCaErrMdl()"
                        }
                    }, "Error");
                    recheckCheckbox(); // Reset checkbox
                    return false;
                }
            }
        }
    } else if (["Agriculture", "Salary", "Pension", "Rentalincome", "Wage"].includes(incomeType)) {
        if (incomeType === "Wage") return true;
        const docNameToSearch = incomeType === "Rentalincome" ? "Rentalincome_Agg Doc" : `${incomeType} Doc`;
        const hasDoc = docsData.some(doc => doc?.payload?.documentType === docNameToSearch);
        if (hasDoc) {
            ApzCOB.showCaModals({
                text: "Please delete all the documents first",
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.Cabase.closeCaErrMdl()"
                }
            }, "Error");
            recheckCheckbox(); // Reset checkbox
            return false;
        }
    }
    return true;
};
apz.app.CaIncomeDetails.OnchangeOtherLineBusinessDropDown = function(pthis) {
    if (pthis.value == "Others") {
        $("#CrdAss__CaIncomeDetails__O_OthLineOfBus").val("");
        $("#CrdAss__CaIncomeDetails__OtherLineBusReasonRow").removeClass('sno');
    } else if (pthis.value == "Please Select") {
        $("#CrdAss__CaIncomeDetails__O_OthLineOfBus").val("");
        $("#CrdAss__CaIncomeDetails__OtherLineBusReasonRow").addClass('sno');
    } else {
        $("#CrdAss__CaIncomeDetails__O_OthLineOfBus").val(pthis.value);
        $("#CrdAss__CaIncomeDetails__OtherLineBusReasonRow").addClass('sno');
    }
};
apz.app.CaIncomeDetails.calculateOtherBusinessIncome = function() {
    function getNumericValue(id) {
        const val = document.getElementById(id)?.value;
        if (!val || val.trim() === "") return 0;
        const cleanVal = val.replace(/,/g, "").trim();
        return parseFloat(cleanVal) || 0;
    }
    const salesPerDay = getNumericValue("CrdAss__CaIncomeDetails__O_SalesPerDay");
    const noOfOp = getNumericValue("CrdAss__CaIncomeDetails__O_NoOfOp");
    const opeEx = getNumericValue("CrdAss__CaIncomeDetails__O_OpeEx");
    const rentLease = getNumericValue("CrdAss__CaIncomeDetails__O_RentLease");
    const noOfEmp = getNumericValue("CrdAss__CaIncomeDetails__O_NoOfEmp");
    const salPaidMon = getNumericValue("CrdAss__CaIncomeDetails__O_SalPaidMon");
    const transComm = getNumericValue("CrdAss__CaIncomeDetails__O_TransComm");
    const waterBill = getNumericValue("CrdAss__CaIncomeDetails__O_WaterBill");
    const eleBill = getNumericValue("CrdAss__CaIncomeDetails__O_EleBill");
    const billGas = getNumericValue("CrdAss__CaIncomeDetails__O_BillGas");
    const teleGas = getNumericValue("CrdAss__CaIncomeDetails__O_TeleGas");
    const others = getNumericValue("CrdAss__CaIncomeDetails__O_Others");
    const otherExp = getNumericValue("CrdAss__CaIncomeDetails__O_OtherExp");
    const miscExpenses = (isNaN(transComm) ? 0 : transComm) + (isNaN(waterBill) ? 0 : waterBill) + (isNaN(eleBill) ? 0 : eleBill) + (isNaN(
        billGas) ? 0 : billGas) + (isNaN(teleGas) ? 0 : teleGas) + (isNaN(others) ? 0 : others);
    const empSalary = (isNaN(noOfEmp) ? 0 : noOfEmp) * (isNaN(salPaidMon) ? 0 : salPaidMon);
    const salesRevenue = (isNaN(salesPerDay) ? 0 : salesPerDay) * (isNaN(noOfOp) ? 0 : noOfOp);
    const netBusInc = salesRevenue - (isNaN(opeEx) ? 0 : opeEx) - (isNaN(rentLease) ? 0 : rentLease) - empSalary - miscExpenses - (isNaN(
        otherExp) ? 0 : otherExp);
    const totalBus = empSalary + miscExpenses + (isNaN(otherExp) ? 0 : otherExp) + (isNaN(opeEx) ? 0 : opeEx) + (isNaN(rentLease) ? 0 :
    rentLease);
    document.getElementById("CrdAss__CaIncomeDetails__O_NetBusInc").value = Math.round(netBusInc);
    document.getElementById("CrdAss__CaIncomeDetails__O_TotalBus").value = Math.round(totalBus);
};
apz.app.CaIncomeDetails.validateMinLengthForSalaryPaid = function(input) {
    const rawValue = input.value;
    if (!rawValue || rawValue.trim() === "") return;
    const numericStr = rawValue.replace(/,/g, '');
    const numericValue = parseInt(numericStr, 10);
    if (numericValue === 0) {
        return;
    }
    if (numericStr.length < 4) {
        ApzCOB.fnDisplayMsg("Please enter at least 4 digits", "E");
        input.value = '';
    } else if (numericStr.length > 6) {
        ApzCOB.fnDisplayMsg("Please enter not more than 6 digits", "E");
        input.value = '';
    } else if (numericValue > 100000) {
        ApzCOB.fnDisplayMsg("Amount cannot exceed ₹1,00,000", "E");
        input.value = '';
    }
};
apz.app.CaIncomeDetails.setSalaryPaidToZero = function() {
    const numEmpEl = document.getElementById("CrdAss__CaIncomeDetails__O_NoOfEmp");
    const salPaidEl = document.getElementById("CrdAss__CaIncomeDetails__O_SalPaidMon");
    if (!numEmpEl) return;
    const numEmpVal = parseInt(numEmpEl.value.replace(/,/g, ''), 10);
    if (!isNaN(numEmpVal) && numEmpVal === 0) {
        salPaidEl.value = '0';
    }
};
apz.app.CaIncomeDetails.onchangeNoOfMachines = function(pthis) {
    if (pthis.id === manualMachinesID) {
        otherDropDownVal = document.getElementById('CrdAss__CaIncomeDetails__T-powerMachines').value;
    } else {
        otherDropDownVal = document.getElementById('CrdAss__CaIncomeDetails__T-manualMachines').value;
    }
    if (pthis.value === '0' && otherDropDownVal === '0') {
        inputElement = document.getElementById(pthis.id);
        $(`#${pthis.id}`).val(PleaseSelect);
        ApzCOB.dropDownOnChange(inputElement);
        ApzCOB.fnDisplayMsg("No. of power tailoring machines and manual machines cannot be zero at the same time.", "E");
    }
}

// apz.app.CaIncomeDetails.triggerImageProcessing("Kirana Doc", "Applicant");

apz.app.CaIncomeDetails.triggerImageProcessing = function (docType, custType) {
    function getCustomerDocs(documents, docType, custType) {
        return documents
            .filter(doc =>
                doc.documentType === docType &&
                doc.payload.custType === custType
            )
            .map(doc => doc.payload.documentFileName);
    }
    let allDocuments = inSessionStore?.applicationDocumentsWrapperList?.[0]?.applicationDocumentsList || [];
    let files = getCustomerDocs(allDocuments, docType, custType);
    let payload = {
        apiRequest: {
            requestObj: {
                appId: gAppId,
                applicationId: gApzCOB.userDetails.applicationId,
                versionNum: 1,
                documentType: docType,
                custType: custType,
                files: files,
                userId: LoggedInUserDetails.loginResponse.userDet.id,
            },
            interfaceName: "BIPImgProcess",
            appId: gAppId
            
        }
    };

    console.log(payload);
    ApzCOB.serverBuildParam(gAppId, "BIPImgProcess", "N", "N", payload, false, apz.app.CaIncomeDetails.triggerImageProcessingCB);
}
   
apz.app.CaIncomeDetails.triggerImageProcessingCB = function (params) {
    apz.stopLoader();
    if (ApzCOB.handleServiceCallBacks(params)) {
        let response = JSON.parse(params.res.APZCBO__BIPImgProcess_Res.apiResponse.ResponseBody.responseObj);
        if (response?.success === true) {
            ApzCOB.fnDisplayMsg("Image processing completed successfully.", "S");
            console.log("Image processing response:", response);
            return;
        }
        if (response?.success === false) {
            let errorCode = response.error?.code || "";
            let msg = "";
            switch (errorCode) {
                case "VALIDATION_ERROR":
                    msg = "Invalid request payload. Please check the data and try again.";
                    break;
                case "INVALID_IMAGE":
                    msg = "Unsupported image format. Please upload a valid image.";
                    break;
                case "IMAGE_TOO_LARGE":
                    msg = "Image size exceeds 10MB. Please upload a smaller image.";
                    break;
                case "INVALID_BUSINESS_TYPE":
                    msg = "Invalid business type provided. Please verify and retry.";
                    break;
                case "REQUEST_NOT_FOUND":
                    msg = "Request not found. Please initiate the process again.";
                    break;
                case "PROCESSING_FAILED":
                    msg = "Image processing failed. Please try again later.";
                    break;
                case "RATE_LIMIT_EXCEEDED":
                    msg = "Too many requests. Please wait for some time and retry.";
                    break;
                default:
                    msg = "Unexpected error occurred. Please try again.";
            }
            if (msg) {
                ApzCOB.fnDisplayMsg(msg);
            }
        }
    } else {
        ApzCOB.fnDisplayMsg("Failed to trigger image processing. Please try again.");
    }
};

