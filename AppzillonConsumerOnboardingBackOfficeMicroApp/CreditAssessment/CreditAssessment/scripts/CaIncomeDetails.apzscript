apz.app.CaIncomeDetails.autoCompleteOtherBusiness = function() {
    let businessPurposeData = [];
    try {
        const matchedItem = gLovs.find(item => item.lovName === "BUSINESS_PURPOSE");
        if (matchedItem) {
            const parsed = JSON.parse(matchedItem.lovDtls);
            businessPurposeData = parsed.BUSINESS_PURPOSE;
            let caOtherBusinessData = businessPurposeData.filter(item => item.CAType == "Other");
        }
    } catch (error) {
        // ("Error parsing BUSINESS_PURPOSE data:", error.message);
    }
};
