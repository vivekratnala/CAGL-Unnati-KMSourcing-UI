var selectBusinessTypeID;
apz.app.CaIncomeDetails.selectBusinessType = function(pthis) {
    selectBusinessTypeID = pthis;
    var idParts = pthis.id.split('__');
    var indexSegment = idParts[2]; // e.g., '4_businessTypeOption_option_Kirana'
    var index = indexSegment.split('_')[0]; // '4'
    var ownedByName = "CrdAss__CaIncomeDetails__" + index + "_businessOwnedByOption_";
    var ownedByOptions = document.getElementsByName(ownedByName);
    var isSelected = Array.from(ownedByOptions).some(opt => opt.checked);
    if (!isSelected) {
        ApzCOB.fnDisplayMsg("Please select 'Business Owned By' before selecting Business Type", "E");
        pthis.checked = false;
        return;
    }
    var id = (pthis.value === 'Dairy') ? 'dairy' : pthis.value;
    if (FinalvaluesArr[id].length >= 3) {
        pthis.checked = false;
        ApzCOB.fnDisplayMsg("You cannot add more than three Business " + pthis.value, "E");
        return
    }
    if (FinalvaluesArr[id].length > 0 && FinalvaluesArr[id].length <= 3) {
        let popUpObj = {
            text: "The selected business has already been added. Do you want to continue?",
            Btn1: {
                text: "Yes",
                onClick: "apz.app.CaIncomeDetails.approveCB({ choice: true })"
            },
            Btn2: {
                text: "No",
                onClick: "apz.app.CaIncomeDetails.approveCB({ choice: false });"
            }
        };
        ApzCOB.showCaModals(popUpObj, "confirmation");
        return;
    } else {
        if (pthis.id.includes("Tailoring")) {
            $('#' + ownedByName + 'option_Applicant').attr('checked', true);
            $(`#CrdAss__CaIncomeDetails__${index}_businessOwnedByOption input[type="radio"]`).prop('disabled', true);
        } else {
            $(`#CrdAss__CaIncomeDetails__${index}_businessOwnedByOption input[type="radio"]`).prop('disabled', false);
        }
        index = pthis.id.split("_")[4];
        if ($("#" + CaIncomeDetailsScrId + index + "_DeleteIcon_ul").is(":visible")) {
            $("#" + CaIncomeDetailsScrId + index + "_DeleteIcon").trigger("click");
        }
        selectedBusinessType = pthis.value;
        $("#" + CaIncomeDetailsScrId + numberOfBusinessCount + "_addBusinessDetails").attr("disabled", false);
        $("#" + CaIncomeDetailsScrId + numberOfBusinessCount + "_addBusiness").attr("disabled", false);
    }
}
apz.app.CaIncomeDetails.approveCB = function(params) {
    if (params.choice === true) {
        let index = selectBusinessTypeID.id.split("_")[4];
        if ($("#" + CaIncomeDetailsScrId + index + "_DeleteIcon_ul").is(":visible")) {
            $("#" + CaIncomeDetailsScrId + index + "_DeleteIcon").trigger("click");
        }
        selectedBusinessType = selectBusinessTypeID.value;
        $("#" + CaIncomeDetailsScrId + numberOfBusinessCount + "_addBusinessDetails").attr("disabled", false);
        $("#" + CaIncomeDetailsScrId + numberOfBusinessCount + "_addBusiness").attr("disabled", false);
        apz.app.Cabase.closeCaConfirmarionMdl();
    } else if (params.choice === false) {
        selectBusinessTypeID.checked = false;
        $("#" + CaIncomeDetailsScrId + numberOfBusinessCount + "_addBusinessDetails").attr("disabled", true);
        $("#" + CaIncomeDetailsScrId + numberOfBusinessCount + "_addBusiness").attr("disabled", true);
        apz.app.Cabase.closeCaConfirmarionMdl();
    }
}
apz.app.CaIncomeDetails.addBusiness = function() {
    let currentBusinessId = `#${CaIncomeDetailsScrId}${numberOfBusinessCount}_addBusinessDetails_ul`;
    if ($(currentBusinessId).is(":visible")) {
        ApzCOB.fnDisplayMsg("Please Add the Business Details before Proceed", "E");
        return;
    }
    $(`#${CaIncomeDetailsScrId}${numberOfBusinessCount}_addBusiness_ul`).addClass("sno");
    numberOfBusinessCount++;
    if (numberOfBusinessCount <= 12) {
        let clonedRowId = `${CaIncomeDetailsScrId}CloneRow_${numberOfBusinessCount}`;
        let existingDiv = $(`#${clonedRowId}`);
        if (existingDiv.length > 0) {
            existingDiv.removeClass("sno"); // If it exists, just show it
            apz.app.CaIncomeDetails.resetBusiness(numberOfBusinessCount);
        } else {
            let clonedId = apz.app.CaIncomeDetails.DeepcloneDivs(elementId, businessParentDiv, numberOfBusinessCount);
            $(`#${clonedId}`).removeClass("sno"); // Remove sno from the newly cloned element
        }
    }
    $(`#${CaIncomeDetailsScrId}${numberOfBusinessCount}_BusinessNoTxt`).text("Business " + numberOfBusinessCount);
    $(`#CrdAss__CaIncomeDetails__${numberOfBusinessCount}_addBusinessDetails`).attr("disabled", true);
    $(`#CrdAss__CaIncomeDetails__${numberOfBusinessCount}_addBusiness`).attr("disabled", true);
    if (numberOfBusinessCount === 12) {
        $(`#${CaIncomeDetailsScrId}${numberOfBusinessCount}_addBusiness_ul`).addClass("sno");
    }
};
apz.app.CaIncomeDetails.DeleteBusiness = function(pthis) {
    incomeTypeBulkDelete = '';
    var DeleteCount = parseInt(pthis.id.split("_")[4]);
    const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__' + DeleteCount + '_businessTypeOption input[type="radio"]:checked');
    if (!checkboxes.length) return;
    var Type = checkboxes[0].id.split("_")[7].trim().toLowerCase();
    var ownershipOptions = ["Applicant", "Co-Applicant", "Both"];
    var selectedOwnership;
    for (var i = 0; i < ownershipOptions.length; i++) {
        var option = ownershipOptions[i];
        var radioId = "CrdAss__CaIncomeDetails__" + DeleteCount + "_businessOwnedByOption_option_" + option;
        if ($("#" + radioId).prop("checked")) {
            selectedOwnership = option;
            break;
        }
    }
    let ownershipKey;
    let typeKey;
    if (Type === "kirana") {
        ownershipKey = "kiranaType";
        typeKey = "Kirana";
    } else if (Type === "other") {
        ownershipKey = "otherType";
        typeKey = "Other";
    } else if (Type === "tailoring") {
        ownershipKey = "tailoringType";
        typeKey = "Tailoring";
    } else if (Type === "dairy") {
        ownershipKey = "DairyType";
        typeKey = "dairy";
    }
    let custTypeForImageDelete = selectedOwnership === "Co-Applicant" ? "Co-App" : selectedOwnership;
    let documentType = Type === "kirana" ? "Kirana Doc" : Type === "other" ? "Other Doc" : Type === "tailoring" ? "Tailoring Doc" : Type ===
        "dairy" ? "Dairy Doc" : "";
    const typeKeyLower = typeKey.toLowerCase();
    const docNoImageDelete = Object.values(selectedBusinessTypesIncomeDtls).filter(val => val.toLowerCase() === typeKeyLower).length;
    let deleted = false;
    if (typeKey && FinalvaluesArr.hasOwnProperty(typeKey) && Array.isArray(FinalvaluesArr[typeKey])) {
        const arr = FinalvaluesArr[typeKey];
        for (let i = arr.length - 1; i >= 0; i--) {
            const item = arr[i];
            if (!item || typeof item !== "object" || Object.keys(item).length === 0) {
                arr.splice(i, 1);
                deleted = true;
                break;
            }
            if (item[ownershipKey] === selectedOwnership) {
                arr.splice(i, 1);
                deleted = true;
                break;
            }
        }
        FinalvaluesArr[typeKey] = arr;
    }
    if (deleted) {
        deletedBusinessIndexes[DeleteCount] = typeKey;
        $("#CrdAss__CaIncomeDetails__CloneRow_" + DeleteCount).addClass("sno");
        $("#CrdAss__CaIncomeDetails__CloneRow_" + DeleteCount).find("#CrdAss__CaIncomeDetails__" + DeleteCount + "_Business_ParentBusRow").find(
            ".uploadimg.businessimg").addClass("sno");
        if ($("#CrdAss__CaIncomeDetails__CloneRow_" + (DeleteCount - 1)).length > 0) {
            $("#CrdAss__CaIncomeDetails__" + (DeleteCount - 1) + "_addBusiness_ul").removeClass("sno");
        }
        apz.app.Cabase.BulkDeleteImages(documentType, custTypeForImageDelete, incomeTypeBulkDelete, docNoImageDelete, "Y");
        apz.app.CaIncomeDetails.disableDeleteButtons();
        apz.app.CaIncomeDetails.getSelectedBusinessTypes();
    }
    let allRowsHiddenOrMissing = true;
    for (let index = 1; index <= 12; index++) {
        let cloneRow = $("#" + CaIncomeDetailsScrId + "CloneRow_" + index);
        if (cloneRow.length > 0 && !cloneRow.hasClass("sno")) {
            allRowsHiddenOrMissing = false;
            break;
        }
    }
    if (allRowsHiddenOrMissing) {
        $(`#CrdAss__CaIncomeDetails__businessTypeOption`).prop("checked", false)
    }
};
apz.app.CaIncomeDetails.resetBusiness = function(Count) {
    let selectedRadios = document.querySelectorAll('#CrdAss__CaIncomeDetails__' + Count + '_businessTypeOption input[type="radio"]:checked');
    $('#CrdAss__CaIncomeDetails__' + Count + '_businessTypeOption input[type="radio"]').prop('checked', false).prop('disabled', false);
    $('#CrdAss__CaIncomeDetails__' + Count + '_businessOwnedByOption input[type="radio"]').prop('checked', false).prop('disabled', false);
    $("#" + CaIncomeDetailsScrId + Count + "_businessTypeSec").addClass("sno");
    $("#" + CaIncomeDetailsScrId + Count + "_businessImgSec").addClass("sno");
    $("#" + CaIncomeDetailsScrId + Count + "_addBusinessDetails_ul").removeClass("sno");
    $("#" + CaIncomeDetailsScrId + Count + "_viewBusinessDetails_ul").addClass("sno");
    $("#" + CaIncomeDetailsScrId + Count + "_DeleteIcon_ul").addClass("sno");
    $(`#CrdAss__CaIncomeDetails__${Count}_addBusinessDetails`).attr("disabled", true);
    $(`#CrdAss__CaIncomeDetails__${Count}_addBusiness`).attr("disabled", true);
    $(`#${CaIncomeDetailsScrId}${Count}_addBusiness_ul`).removeClass("sno");
    let selectedValue = selectedRadios.length > 0 ? selectedRadios[0].value : false;
    if (Count === 1) {
        AllValues = {};
        FinalvaluesArr.dairy = [];
        FinalvaluesArr.Other = [];
        FinalvaluesArr.Kirana = [];
        FinalvaluesArr.Tailoring = [];
    } else if (selectedValue) {
        AllValues[selectedValue] = {};
        FinalvaluesArr[selectedValue].splice(Count, 1);
    }
};
apz.app.CaIncomeDetails.ViewDetails = function(pthis) {
    let Index = pthis.id.split("_")[4];
    saveBtnBusinessNo = Index;
    const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__' + Index + '_businessTypeOption input[type="radio"]:checked');
    let Type = checkboxes[0].id.split("_")[7];
    apz.app.CaIncomeDetails.paintOwnedBy(Type, Index)
    if (Type === 'Dairy') {
        Type = Type.charAt(0).toLowerCase() + Type.slice(1);
    }
    let ObjIndex = 0;
    if (Index !== "1") {
        Index = parseInt(Index) - 1;
        for (let i = Index; i > 0; i--) {
            let Typecheckboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__' + i + '_businessTypeOption input[type="radio"]:checked');
            let LastType = Typecheckboxes[0].id.split("_")[7];
            LastType = (LastType === 'Dairy') ? 'dairy' : LastType;
            if (LastType === Type) {
                ObjIndex = ObjIndex + 1;
            }
        }
    }
    EditIndex = ObjIndex + 1;
    EditType = Type;
    let Obj;
    if (FinalvaluesArr[Type].length > 0) {
        Obj = FinalvaluesArr[Type][ObjIndex];
    } else {
        Obj = JSON.parse(inSessionStore.bcmpiIncomeDetails.payload).business[Type][ObjIndex]
    }
    apz.app.CaIncomeDetails.ShowDetails(Obj, Type);
}
apz.app.CaIncomeDetails.ShowDetails = function(Obj, type) {
    let id = type.charAt(0).toUpperCase() + type.slice(1)
    ApzCOB.toggleModal(`${CaIncomeDetailsScrId}${id}`);
    switch (id) {
        case 'Dairy':
            // Dairy-specific logic
            apz.app.CaIncomeDetails.PaintDetailsDairy(Obj, type);
            break;
        case 'Kirana':
            // Kirana-specific logic
            apz.app.CaIncomeDetails.PaintDetailsKirana(Obj, type);
            break;
        case 'Tailoring':
            // Tailoring-specific logic
            apz.app.CaIncomeDetails.PaintDetailsTailoring(Obj, type);
            break;
        case 'Other':
            // Other-specific logic
            apz.app.CaIncomeDetails.PaintDetailsOther(Obj, type);
            break;
        default:
            // Fallback for other types or if nothing selected
            ApzCOB.fnDisplayMsg("Please select a valid Business Type before proceeding.", "E");
            break;
    }
    const closeButtonIds = [CaIncomeDetailsScrId + "Dairy_close", CaIncomeDetailsScrId + "Tailoring_close",
        CaIncomeDetailsScrId + "Kirana_close", CaIncomeDetailsScrId + "Other_close"
    ];
    closeButtonIds.forEach(id => {
        const element = document.getElementById(id);
        if (element) {
            element.addEventListener("click", function() {
                IsEditFlow = false;
            });
        }
    });
};
apz.app.CaIncomeDetails.PaintDetailsDairy = function(Obj, type) {
    let inputIds = ['NetInp', 'NameOfOrg'];
    let inputIdVal = ['netMonthlyIncome', 'organizationName'];
    for (let i = 0; i < inputIds.length; i++) {
        const inputElement = document.getElementById(CaIncomeDetailsScrId + inputIds[i]);
        if (inputElement) {
            inputElement.value = Obj[inputIdVal[i]]; // Update the value
        }
    }
    let DropDownIds = ['B_loc', 'B_ten', 'TypesofBus', 'B_BCow', 'B_Noofcow', 'BreedofBef', 'NoOfBef'];
    let DropDownVal = ['dairyLocation', 'dairyTenure', 'dairyBusinessType', 'cowBreed1', 'noOfCowBreed1', 'buffaloBreed1', 'noOfBuffaloBreed1'];
    for (let j = 0; j < DropDownIds.length; j++) {
        const inputElement = document.getElementById(CaIncomeDetailsScrId + DropDownIds[j]);
        apz.setElmValue(CaIncomeDetailsScrId + DropDownIds[j], Obj[DropDownVal[j]]);
    }
    let Values = [Obj.avgDailyRevenuePerCow, Obj.avgMonthlyRevenuePerCow, Obj.avgDailyRevenuePerBuffalo, Obj.avgMonthlyRevenuePerBuffalo,
        Obj.IncomeAssessmentChecknetBusinessIncome
    ];
    $(".CalDet").removeClass("sno");
    let CalinputIds = ['DCow', 'MCow', 'DBuff', 'MBuff', 'NetInc'];
    for (let i = 0; i < CalinputIds.length; i++) {
        const inputElement = document.getElementById(CaIncomeDetailsScrId + CalinputIds[i]);
        if (inputElement) {
            inputElement.textContent = '₹' + ApzCOB.fn_FormatAmount(Values[i]); // Set value
        }
    }
    let CowClassNo = 2;
    let BuffClassNo = 2;
    $(".buffalo2").addClass("sno");
    $(".buffalo3").addClass("sno");
    $(".buffalo4").addClass("sno");
    $(".buffalo5").addClass("sno");
    $(".Cow2").addClass("sno");
    $(".Cow3").addClass("sno");
    Object.keys(Obj).forEach(key => {
        if (['noOfBuffaloBreed2', 'noOfBuffaloBreed3', 'noOfBuffaloBreed4', 'noOfBuffaloBreed5'].includes(key)) {
            $(".buffalo" + BuffClassNo).removeClass("sno");
            let Class = BuffClassNo - 1;
            $('#' + CaIncomeDetailsScrId + 'NoOfBef_' + Class.toString()).val(Obj["noOfBuffaloBreed" + BuffClassNo]),
                $('#' + CaIncomeDetailsScrId + 'BreedofBef_' + Class.toString()).val(Obj["buffaloBreed" + BuffClassNo]),
                BuffClassNo = BuffClassNo + 1;
        }
        if (['cowBreed2', 'cowBreed3'].includes(key)) {
            $(".Cow" + CowClassNo).removeClass("sno");
            let Class = CowClassNo - 1;
            $('#' + CaIncomeDetailsScrId + 'B_BCow_' + Class.toString()).val(Obj["cowBreed" + CowClassNo]),
                $('#' + CaIncomeDetailsScrId + 'B_Noofcow_' + Class.toString()).val(Obj["noOfCowBreed" + CowClassNo]),
                CowClassNo = CowClassNo + 1;
        }
    });
    apz.app.CaIncomeDetails.DisableInpModal(type, "SameasRes", "BussinessPremise", "isOwned", Obj);
    $(".EditDa").removeClass("sno");
    $("#" + CaIncomeDetailsScrId + "SaveBtn").addClass("sno");
};
apz.app.CaIncomeDetails.PaintDetailsKirana = function(Obj, type) {
    let inputIds = ['K_Areaofshop', 'K_AreaGod', 'K_NameofOrg', 'K_Net'];
    let inputIdVal = ['areaofshop', 'areaOfGodown', 'nameOfOrganization', 'netMonthlyIncome'];
