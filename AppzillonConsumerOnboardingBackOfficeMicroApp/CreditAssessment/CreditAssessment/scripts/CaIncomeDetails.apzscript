}
apz.app.CaIncomeDetails.AgricultureValidation = function() {
    const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__Agri_Owned input[type="radio"]:checked');
    if (checkboxes.length === 0) {
        ApzCOB.fnDisplayMsg("Please select the Agriculture Owned by", "E");
        return false;
    } else {
        Type = checkboxes[0].value;
        let AllDetailsAdded = false;
        switch (Type) {
            case 'Applicant':
                AllDetailsAdded = apz.app.CaIncomeDetails.ValidateApplicant();
                break;
            case 'Co-Applicant':
                AllDetailsAdded = apz.app.CaIncomeDetails.ValidateCoApplicant("OnlyCo");
                break;
            case 'Both':
                let AllDetailsAddedForAppl = apz.app.CaIncomeDetails.ValidateApplicant();
                let AllDetailsAddedForCoApp = apz.app.CaIncomeDetails.ValidateCoApplicant();
                AllDetailsAdded = (AllDetailsAddedForAppl && AllDetailsAddedForCoApp) ? true : false;
                break;
            default:
                // Fallback for other types or if nothing selected
                ApzCOB.fnDisplayMsg("Please select a valid Agriculture Type before proceeding.", "E");
                break;
        }
        return AllDetailsAdded;
    }
};
apz.app.CaIncomeDetails.SalaryValidation = function() {
    const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__SalOwned input[type="radio"]:checked');
    if (checkboxes.length === 0) {
        ApzCOB.fnDisplayMsg("Please select the Salary Earned by", "E");
        return false;
    } else {
        Type = checkboxes[0].value;
        let AllDetailsAdded = false;
        switch (Type) {
            case 'Applicant':
                AllDetailsAdded = apz.app.CaIncomeDetails.SalaryValidateApplicant();
                break;
            case 'Co-Applicant':
                AllDetailsAdded = apz.app.CaIncomeDetails.SalaryValidateCoApplicant("OnlyCo");
                break;
            case 'Both':
                let AllDetailsAddedForAppl = apz.app.CaIncomeDetails.SalaryValidateApplicant();
                let AllDetailsAddedForCoApp = apz.app.CaIncomeDetails.SalaryValidateCoApplicant();
                AllDetailsAdded = (AllDetailsAddedForAppl && AllDetailsAddedForCoApp) ? true : false;
                break;
            default:
                // Fallback for other types or if nothing selected
                ApzCOB.fnDisplayMsg("Please select a valid Salary Type before proceeding.", "E");
                break;
        }
        return AllDetailsAdded;
    }
};
