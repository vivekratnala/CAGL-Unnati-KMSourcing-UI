apz.app.CaIncomeDetails.OnClikedAddMoreCows = function() {
    var cow1Visible = $("#" + CaIncomeDetailsScrId + "B_BCow_1").is(":visible");
    var cow1Value = apz.getElmValue(CaIncomeDetailsScrId + "B_BCow");
    if (!cow1Visible && cow1Value && cow1Value != 'Please Select') {
        // First cow dropdown is not visible and value is valid
        $(".Cow2").removeClass("sno");
        apz.app.CaIncomeDetails.populateDropdown(NoOfCows, CaIncomeDetailsScrId + "B_Noofcow_1");
        apz.app.CaIncomeDetails.populateDropdown(CowYield, CaIncomeDetailsScrId + "B_BCow_1");
    } else if (!$("#" + CaIncomeDetailsScrId + "B_BCow_2").is(":visible") && apz.getElmValue(CaIncomeDetailsScrId + "B_BCow_1") && apz
        .getElmValue(CaIncomeDetailsScrId + "B_BCow_1") != 'Please Select') {
        // Second cow dropdown is not visible and B_BCow_1 has valid value
        $(".Cow3").removeClass("sno");
        apz.app.CaIncomeDetails.populateDropdown(NoOfCows, CaIncomeDetailsScrId + "B_Noofcow_2");
        apz.app.CaIncomeDetails.populateDropdown(CowYield, CaIncomeDetailsScrId + "B_BCow_2");
        $("#" + CaIncomeDetailsScrId + "AddMore_Cow").attr("disabled", true);
    } else {
        ApzCOB.fnDisplayMsg("Please select the Breed of Cow before proceed", "E");
    }
}
apz.app.CaIncomeDetails.OnClikedAddMoreBuff = function() {
