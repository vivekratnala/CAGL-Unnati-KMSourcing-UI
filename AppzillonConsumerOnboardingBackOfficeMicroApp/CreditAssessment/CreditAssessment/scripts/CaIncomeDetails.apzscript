apz.app.CaIncomeDetails.landRangeValidation = function(pthis) {
    var landRange, landInacre, id = pthis.id;
    if (pthis.id.includes('Ap')) {
        landRange = $(`#${CaIncomeDetailsScrId}Ap_Land`).val();
        landInacre = $(`#${CaIncomeDetailsScrId}Ap_LandInAcres`).val()
    } else if (pthis.id.includes('Co')) {
        landRange = $(`#${CaIncomeDetailsScrId}Co_Land`).val();
        landInacre = $(`#${CaIncomeDetailsScrId}Co_LandInAcres`).val()
    }
    ///let [min, max] = landRange.split('to').map(val => parseFloat(val.trim()));
    if (landInacre != '') {
        if (!apz.app.CaIncomeDetails.isLandInRange(landRange, landInacre)) {
            landRangeFlag = false
            ApzCOB.fnDisplayMsg("Land in acre is not within the allowed range" + ' ' + landRange, "E");
        } else {
            landRangeFlag = true;
            // ('Land value is within the range');
        }
    }
}
apz.app.CaIncomeDetails.isLandInRange = function(range, value) {
    range = range.trim();
    if (range.includes('to')) {
        // Format: "min to max"
        let [min, max] = range.split('to').map(v => parseFloat(v.trim()));
        return value >= min && value <= max;
    } else if (range.startsWith('<=')) return value <= parseFloat(range.replace('<=', ''));
    else if (range.startsWith('>=')) return value >= parseFloat(range.replace('>=', ''));
    else if (range.startsWith('<')) return value < parseFloat(range.replace('<', ''));
    else if (range.startsWith('>')) return value > parseFloat(range.replace('>', ''));
    else return value === parseFloat(range); // exact match
}
apz.app.CaIncomeDetails.PaintData = function() {
    var data;
    if (!apz.isNull(inSessionStore?.bcmpiIncomeDetails)) {
        data = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload);
        Object.keys(data).forEach(category => {
            switch (category) {
                case "business":
                    apz.app.CaIncomeDetails.BusinessData();
                    break;
                case "agriculture":
                    apz.app.CaIncomeDetails.AgriData();
                    break;
                case "salary":
                    apz.app.CaIncomeDetails.SalaryData();
                    break;
                case "wage":
                    apz.app.CaIncomeDetails.WageData();
                    break;
                case "pension":
                    apz.app.CaIncomeDetails.PaintPensionData();
                    break;
                case "rentalIncome":
                    apz.app.CaIncomeDetails.RentalIncomeData()
                    break;
                case "homeMaker":
                    apz.app.CaIncomeDetails.PaintHomeMakerData();
                    break;
                default:
                    // ("Unknown Category:", category);
            }
        });
    }
};
apz.app.CaIncomeDetails.PaintPensionData = function() {
    var pensionData = JSON.parse(inSessionStore.bcmpiIncomeDetails.payload).pension
    if (Object.keys(pensionData).length > 0) {
        $(`#CrdAss__CaIncomeDetails__PensionTypeOption`).prop("checked", true);
        $('#CrdAss__CaIncomeDetails__Pension').removeClass('sno');
        if (pensionData.hasOwnProperty("applicant") && pensionData.hasOwnProperty("coApplicant")) {
            $(`#CrdAss__CaIncomeDetails__PensionOwn_Owned_option_Both`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Pension'} #${CaIncomeDetailsScrId}${'Applicant'}`).removeClass("sno");
            apz.setElmValue(CaIncomeDetailsScrId + "App_PenIn", pensionData.applicant.applicantPensionIncome);
            $(`#${'CrdAss__CaIncomeDetails__Pension'} #${CaIncomeDetailsScrId}${'Co-Applicant'}`).removeClass("sno");
            apz.setElmValue(CaIncomeDetailsScrId + "Co_PenIn", pensionData.coApplicant.coApplicantPensionIncome);
            ["Applicant", "Co-Applicant"].forEach(role => {
                TempImageObject.index = role;
                TempImageObject.Type = "Pension";
                apz.app.CaIncomeDetails.paintDocumentName("Pension Doc");
            });
        } else if (pensionData.hasOwnProperty("applicant")) {
            $(`#CrdAss__CaIncomeDetails__PensionOwn_Owned_option_Applicant`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Pension'} #${CaIncomeDetailsScrId}${'Applicant'}`).removeClass("sno");
            apz.setElmValue(CaIncomeDetailsScrId + "App_PenIn", pensionData.applicant.applicantPensionIncome);
            TempImageObject = {
                index: "Applicant",
                Type: "Pension"
            };
            apz.app.CaIncomeDetails.paintDocumentName("Pension Doc");
        } else if (pensionData.hasOwnProperty("coApplicant")) {
            $(`#CrdAss__CaIncomeDetails__PensionOwn_Owned_option_Co-Applicant`).prop("checked", true);
            $(`#${'CrdAss__CaIncomeDetails__Pension'} #${CaIncomeDetailsScrId}${'Co-Applicant'}`).removeClass("sno");
            apz.setElmValue(CaIncomeDetailsScrId + "Co_PenIn", pensionData.coApplicant.coApplicantPensionIncome);
            TempImageObject = {
                index: "Co-Applicant",
                Type: "Pension"
            };
            apz.app.CaIncomeDetails.paintDocumentName("Pension Doc");
        } else {
            //
        }
    }
}
