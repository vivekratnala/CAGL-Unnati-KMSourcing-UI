apz.app.CaIncomeDetails.ValidateAgriFields = function(fields, val) {
    var type = val;
    var mandFieldsDd = fields;
    var valid = true;
    mandFieldsDd.forEach(function(field) {
        if ($('#' + CaIncomeDetailsScrId + field).val() === "" || $('#' + CaIncomeDetailsScrId + field).val() === "Please Select") {
            valid = false;
            $('#' + CaIncomeDetailsScrId + field + 'ErrorDiv').removeClass('sno');
            //$(`#${k}ErrorDiv`).removeClass('sno');
        }
    })
    if (valid) {
        valid = landRangeFlag === true ? true : false
        if (!valid) {
            ApzCOB.fnDisplayMsg("Land in acre is not within the allowed range", "E");
        }
    }
    if (valid) {
        agriStoreData = {}
        var land;
        if (type === 'App') {
            AgrilandInAcres.forEach(function(k, i) {
                if (AgrilandInAcres[i].desc === $('#' + CaIncomeDetailsScrId + 'Ap_Land').val()) {
                    land = AgrilandInAcres[i].val
                }
            })
            agriStoreData = {
                typeOfAgriculture: $('#' + CaIncomeDetailsScrId + 'Ap_TypeOfAgri').val(),
                cropType: $('#' + CaIncomeDetailsScrId + 'Ap_CropType').val(),
                crop: $('#' + CaIncomeDetailsScrId + 'Ap_Crop').val(),
                land: land,
                landInAcres: $('#' + CaIncomeDetailsScrId + 'Ap_LandInAcres').val(),
                maxYeildPerAcre: $('#' + CaIncomeDetailsScrId + 'Ap_MaxperArc').val(),
                monthlyIncome: $('#' + CaIncomeDetailsScrId + 'Agri_MonthIncome').val(),
                consideredIncome: $('#' + CaIncomeDetailsScrId + 'Agri_ConsideredIncome').val(),
                declaredIncome: $('#' + CaIncomeDetailsScrId + 'Agri_DeclaredIncome').val().replace(/,/g, '')
            };
        } else if (type === 'CoApp') {
            AgrilandInAcres.forEach(function(k, i) {
                if (AgrilandInAcres[i].desc === $('#' + CaIncomeDetailsScrId + 'Co_Land').val()) {
                    land = AgrilandInAcres[i].val
                }
            })
            agriStoreData = {
                typeOfAgriculture: $('#' + CaIncomeDetailsScrId + 'Co_TypeOfAgri').val(),
                cropType: $('#' + CaIncomeDetailsScrId + 'Co_CropType').val(),
                crop: $('#' + CaIncomeDetailsScrId + 'Co_Crop').val(),
                land: land,
                landInAcres: $('#' + CaIncomeDetailsScrId + 'Co_LandInAcres').val(),
                maxYeildPerAcre: $('#' + CaIncomeDetailsScrId + 'Co_MaxPerAcrc').val(),
                monthlyIncome: $('#' + CaIncomeDetailsScrId + 'Co_Agri_Month_income').val(),
                consideredIncome: $('#' + CaIncomeDetailsScrId + 'Co_Agri_ConsideredIncome').val(),
                declaredIncome: $('#' + CaIncomeDetailsScrId + 'Co_Agri_DeclaredIncome').val().replace(/,/g, '')
            };
        }
    }
    return valid;
}
apz.app.CaIncomeDetails.ValidateDropDown = function(AllDropdowns, Type) {
    AllValues = {};
    AllValues[Type] = [];
    var dairyIDMap = {
        "B_loc": "dairyLocation",
        "B_ten": "dairyTenure",
        "TypesofBus": "dairyBusinessType",
        "B_BCow": "cowBreed1",
        "B_BCow_1": "cowBreed2",
        "B_BCow_2": "cowBreed3",
        "B_Noofcow": "noOfCowBreed1",
        "B_Noofcow_1": "noOfCowBreed2",
        "B_Noofcow_2": "noOfCowBreed3",
        "BreedofBef": "buffaloBreed1",
        "BreedofBef_1": "buffaloBreed2",
        "BreedofBef_2": "buffaloBreed3",
        "BreedofBef_3": "buffaloBreed4",
        "BreedofBef_4": "buffaloBreed5",
        "NoOfBef": "noOfBuffaloBreed1",
        "NoOfBef_1": "noOfBuffaloBreed2",
        "NoOfBef_2": "noOfBuffaloBreed3",
        "NoOfBef_3": "noOfBuffaloBreed4",
        "NoOfBef_4": "noOfBuffaloBreed5",
    };
    var kiranaIDMap = {
        "K-Loc": "kiranaBusinessLocation",
        "K-Ten": "kiranaTenure",
        "K-Typeofshop": "kiranaShopType",
        "K-Marcl": "kiranaMarketClassification",
        "K-unit": "kiranaUnit",
        "K-UnitGod": "kiranaGodownUnit",
        "K-Occ": "kiranaOccupancyLevel",
        "K-TypeofBu": "kiranaBusinessType"
    }
    var tailoringIDMap = {
        "T-loc": "tailoringBusinessLocation",
        "T-ten": "tailoringTenure",
        "T-pre": "tailoringPremise",
        "T-powerMachines": "numOfPowerTailoringMachine",
        "T-manualMachines": "numOfManualTailoringMachine",
        "T-WorkType": "tailoringWorkType",
        "T-TypeofBus": "tailoringBusinessType",
        "T-noSalariedTailor": "numOfSalariedTailors",
        "T-stitchingFor": "stitchingFor"
    }
    var otherIDMap = {
        "O_OthTen": "otherBusinessTenure",
        "O_TypeOfBus": "otherBusinessType"
    }
    if (Type === "dairy" || Type === 'Kirana' || Type === 'Tailoring' || Type === 'Other') {
        for (var i = 0; i < AllDropdowns.length; i++) {
            var item = AllDropdowns[i];
            var $el = $("#" + item.id);
            if ($el.is(":visible")) {
                var value = $('#' + item.id).val();
                let shortId = item.id.split("__")[2];
                if (Type === "dairy") {
                    const cowTypeIds = ["B_BCow", "B_BCow_1", "B_BCow_2"];
                    const cowCountIds = ["B_Noofcow", "B_Noofcow_1", "B_Noofcow_2"];
                    const buffaloTypeIds = ["BreedofBef", "BreedofBef_1", "BreedofBef_2", "BreedofBef_3", "BreedofBef_4"];
                    const buffaloCountIds = ["NoOfBef", "NoOfBef_1", "NoOfBef_2", "NoOfBef_3", "NoOfBef_4"];
                    if (cowTypeIds.includes(shortId)) {
                        const idx = cowTypeIds.indexOf(shortId);
                        const cowCountVal = $("#" + item.id.replace(shortId, cowCountIds[idx])).val();
                        if (parseInt(cowCountVal || "0") === 0) continue;
                    }
                    if (buffaloTypeIds.includes(shortId)) {
                        const idx = buffaloTypeIds.indexOf(shortId);
                        const buffCountVal = $("#" + item.id.replace(shortId, buffaloCountIds[idx])).val();
                        if (parseInt(buffCountVal || "0") === 0) continue;
                    }
                }
                if (!value || value === 'Please Select') {
                    ApzCOB.fnDisplayMsg(item.errorMsg, "E");
                    return false;
                } else {
                    let Id = shortId;
                    let key;
                    if (Type === "dairy") {
                        key = dairyIDMap[Id];
                    } else if (Type === "Kirana") {
                        key = kiranaIDMap[Id];
                    } else if (Type === "Tailoring") {
                        key = tailoringIDMap[Id];
                    } else if (Type === "Other") {
                        key = otherIDMap[Id];
                    }
                    let obj = {
                        [key]: value
                    };
                    AllValues[Type].push(obj);
                }
            }
        }
    } else {
        for (var i = 0; i < AllDropdowns.length; i++) {
            var item = AllDropdowns[i];
            var $el = $("#" + item.id);
            if ($el.is(":visible")) {
                var value = apz.getElmValue(item.id);
                if (!value || value === 'Please Select') {
                    ApzCOB.fnDisplayMsg(item.errorMsg, "E");
                    return false; // Stop at first invalid field
                } else {
                    let key = item.id.split("__")[2];
                    let obj = {
                        [
                            key
                        ]: value
                    };
                    AllValues[Type].push(obj);
                }
            }
        }
    }
    if (Type === "Tailoring") {
        /*const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__TailoringForm input[type="CHECKBOX"]:checked');
        if (checkboxes.length !== 0) {
            stitchType = [];
            for (var a = 0; a < checkboxes.length; a++) {
                let labelText = $("#" + checkboxes[a].id).next().text().trim();
                // Handle special case for 'Other Small Works'
                if (checkboxes[a].id === "CrdAss__CaIncomeDetails__OthSmallWork") {
                    labelText = "Other Small Works";
                }
                stitchType.push(labelText);
            }
            var obj = {
                "tailorShopItems": stitchType
            }
            AllValues.Tailoring.push(obj);
        } else {
            ApzCOB.fnDisplayMsg("Please select the atleast one Stitch Type", "E");
            return false; // Stop at first invalid field
        }*/
    }
    return true; // All visible dropdowns are valid
};
var incomeDetailsWrapper;
apz.app.CaIncomeDetails.submitIncomeService = function() {
    let bcmpiIncomeDetailsWrapper = {
        "business": {}
    };
    for (let key in FinalvaluesArr) {
        if (["dairy", "Tailoring", "Kirana", "Other"].includes(key)) {
            bcmpiIncomeDetailsWrapper.business[key] = FinalvaluesArr[key];
        } else {
            bcmpiIncomeDetailsWrapper[key] = FinalvaluesArr[key];
        }
    }
    incomeDetailsWrapper = bcmpiIncomeDetailsWrapper
    businessesSelectedInSourcing = apz.app.CaIncomeDetails.businessesSelectedInSourcing();
    // if (!businessesSelectedInSourcing) {
    //     return;
    // }
    if (!$(`#CrdAss__CaIncomeDetails__HomemakerTypeOption`).prop("checked")) {
        if (FinalvaluesArr.hasOwnProperty("homeMaker")) {
            delete FinalvaluesArr.homeMaker;
            delete bcmpiIncomeDetailsWrapper.homeMaker;
        }
    }
    apz.app.CaIncomeDetails.businessIncomeValidation()
    if (validateIncome && validateSumOfAppCoAppIncome) {
        var req = {
            "apiRequest": {
                "requestObj": {
                    "appId": gAppId,
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "versionNum": 1,
                    "stageId": "5",
                    "requestType": "VERIFY",
                    "customerType": "Applicant",
                    "editedFields": [],
                    "bcmpiIncomeDetailsWrapper": bcmpiIncomeDetailsWrapper
                },
                "userId": LoggedInUserDetails.loginResponse.userDet.id,
                "appId": gAppId,
                "interfaceName": "UploadCALoanData"
            }
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "UploadCALoanData", "N", "N", req, false, apz.app.CaIncomeDetails.submitIncomeServiceCB);
    }
};
apz.app.CaIncomeDetails.submitIncomeServiceCB = function(params) {
    let errMsg = "";
    if (!apz.isNull(params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res)) {
        if ((params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            apz.app.Cabase.storeWindowData();
            apz.app.Cabase.SidebarSelect.moveToNextStep();
            ApzCOB.launchSubScreen('InformalLoanObligation', "CrdAss__Cabase__caLaunchCol", "");
        } else {
            apz.stopLoader();
            $(`#${scrId}locktxt_txtcnt`).text(errMsg);
            ApzCOB.toggleModal(scrId + 'lockModal');
            ApzCOB.showCaModals({
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.Cabase.closeCaErrMdl()"
                }
            }, "Error");
            //}
        }
    } catch {
        apz.stopLoader();
        ApzCOB.toggleModal(scrId + 'lockModal');
        $(`#${scrId}locktxt_txtcnt`).html(technicalErrMsg);
    }
};
apz.app.CaIncomeDetails.OncheckedCheckBox = function(pthis, obj) {
    FinalvaluesArr.wage = {};
    var Id, type, checked;
    var targetId, uniqueId, earnedType;
    if (pthis != '') {
        Id = pthis.id.split("__")[2];
        type = Id.includes("App_") ? 'App_' : 'Co_'
        checked = pthis.checked
    } else {
        Id = obj.id
        type = obj.type;
        checked = obj.checked;
    }
    if (type === 'App_') {
        earnedType = 'App'
        targetId = $('#CrdAss__CaIncomeDetails__WageRowApp');
        uniqueId = `CrdAss__CaIncomeDetails__WageRowApp_${Id}`;
    } else if (type === "Co_") {
        earnedType = 'Co_App'
        targetId = $('#CrdAss__CaIncomeDetails__WageRowCo');
        uniqueId = `CrdAss__CaIncomeDetails__WageRowCo_${Id}`;
    }
    if (checked) {
        var clonedRow = targetId.clone(); // clone the element
        clonedRow.attr('id', uniqueId); // change ID to make it unique
        clonedRow.find('[id]').each(function() {
            var oldId = $(this).attr('id');
            // Check if the ID matches one of the specific ones
            if (earnedType === 'App') {
                if (oldId.includes('OtherAct_App_') || oldId.includes('WageEarnedPerDay_App_') || oldId.includes(
                    'NoOFDaysInMonth_App_') || oldId.includes('DeclaredWages_App_')  || oldId.includes('ToTalWagePerMonth_App_')) {
                    var newId = oldId.replace(/_App_\d+/, `_App_${Id.replace('App_', '')}`);
                    $(this).attr('id', newId);
                }
            } else if (earnedType === 'Co_App') {
                if (oldId.includes('OtherAct_Co_') || oldId.includes('WageEarnedPerDay_Co_') || oldId.includes('NoOFDaysInMonth_Co_') || oldId.includes('DeclaredWages_Co_') ||
                    oldId.includes('ToTalWagePerMonth_Co_')) {
                    var newId = oldId.replace(/_Co_\d+/, `_Co_${Id.replace('Co_', '')}`);
                    $(this).attr('id', newId);
                }
            }
        });
        targetId.parent().append(clonedRow);
        clonedRow.removeClass('sno')
        if (earnedType === 'App') {
            $(`#${uniqueId} #${'CrdAss__CaIncomeDetails__HeadTextApp_txtcnt'}`).text(Id.replace('App_', '').replace(/_/g, ' '));
            if (Id === 'App_Other') {
                $(`#${'CrdAss__CaIncomeDetails__WageRowApp_App_Other'} #${'CrdAss__CaIncomeDetails__OtherRowApp'}`).removeClass("sno");
            }
        } else if (earnedType === 'Co_App') {
            $(`#${uniqueId} #${'CrdAss__CaIncomeDetails__HeadTextCo_txtcnt'}`).text(Id.replace('Co_', '').replace(/_/g, ' '));
            if (Id === 'Co_Other') {
                $(`#${'CrdAss__CaIncomeDetails__WageRowCo_Co_Other'} #${'CrdAss__CaIncomeDetails__OtherRowCo'}`).removeClass("sno");
            }
        } else {
            $(`#${uniqueId} #${'CrdAss__CaIncomeDetails__HeadTextCo_txtcnt'}`).text('abc');
        }
        WageEarnedType.push(Id)
        apz.app.CaIncomeDetails.WageFields();
    } else {
        var removeId;
        WageEarnedType = WageEarnedType.filter(item => item !== Id);
        apz.app.CaIncomeDetails.WageFields();
        if (earnedType === 'App') {
            removeId = `#CrdAss__CaIncomeDetails__WageRowApp_${Id}`;
        } else if (earnedType === 'Co_App') {
            removeId = `#CrdAss__CaIncomeDetails__WageRowCo_${Id}`;
        }
        $(removeId).remove();
    }
};
var validateWageField = [];
apz.app.CaIncomeDetails.WageFields = function() {
    validateWageField = [];
    const wageIds = ['NoOFDaysInMonth_', 'WageEarnedPerDay_', 'ToTalWagePerMonth_', 'DeclaredWages_'];
    wageIds.forEach(id => {
        WageEarnedType.forEach(type => {
            validateWageField.push(id + type);
        });
    });
    if (WageEarnedType.includes('App_Other')) {
        validateWageField.push('OtherAct_App_Other');
    } else if (WageEarnedType.includes('Co_Other')) {
        validateWageField.push('OtherAct_Co_Other');
    }
}
apz.app.CaIncomeDetails.ConvertDataInExpectedFormat = function(data) {
    let result = {};
    data.forEach(item => {
        let key = Object.keys(item)[0];
        let values = item[key];
        if (!result[key]) {
            result[key] = {}; // Initialize an empty object if key doesn't exist
        }
        Object.assign(result[key], values); // Merge values into the respective category
    });
    return result;
}
apz.app.CaIncomeDetails.IncomeAssessmentCheck = function(Type, ObjectData) {
    let req;
    if (Type === "Dairy") {
        const cowsList = [];
        const buffaloesList = [];
        const inputObject = Object.assign({}, ...AllValues.dairy);
        // while (inputObject[`B_BCow${cowIndex === 0 ? "" : "_" + cowIndex}`] !== undefined) {
        //     cowsList.push({
        //         breedOfCows: inputObject[`B_BCow${cowIndex === 0 ? "" : "_" + cowIndex}`],
        //         noOfCows: inputObject[`B_Noofcow${cowIndex === 0 ? "" : "_" + cowIndex}`] || "0"
        //     });
        //     cowIndex++;
        // }
        // let buffaloIndex = 0;
        // while (inputObject[`BreedofBef${buffaloIndex === 0 ? "" : "_" + buffaloIndex}`] !== undefined) {
        //     buffaloesList.push({
        //         breedOfBuffaloes: inputObject[`BreedofBef${buffaloIndex === 0 ? "" : "_" + buffaloIndex}`],
        //         noOfBuffaloes: inputObject[`NoOfBef${buffaloIndex === 0 ? "" : "_" + buffaloIndex}`] || "0"
        //     });
        //     buffaloIndex++;
        // }
        Object.keys(inputObject).forEach(key => {
            const match = key.match(/^cowBreed(\d+)$/);
            if (match) {
                const index = match[1];
                const breed = inputObject[key];
                const count = inputObject[`noOfCowBreed${index}`] || "0";
                if (breed !== undefined) {
                    cowsList.push({
                        breedOfCows: breed,
                        noOfCows: count
                    });
                }
            }
        });
        Object.keys(inputObject).forEach(key => {
            const match = key.match(/^buffaloBreed(\d+)$/);
            if (match) {
                const index = match[1];
                const breed = inputObject[key];
                const count = inputObject[`noOfBuffaloBreed${index}`] || "0";
                if (breed !== undefined) {
                    buffaloesList.push({
                        breedOfBuffaloes: breed,
                        noOfBuffaloes: count
                    });
                }
            }
        });
        req = {
            "apiRequest": {
                "interfaceName": "IncomeAssessmentCheck",
                "incomeType": "Dairy",
                "requestObj": {
                    "dairyRequestFields": {
                        "businessLocation": inputObject.dairyLocation,
                        "cowsList": cowsList,
                        "buffaloesList": buffaloesList,
                        "dairyState": inSessionStore.leadDetails?.glBranchState || inSessionStore.renewalLeadDetails?.glBranchState
                    }
                }
            }
        }
    } else if (Type === "Kirana") {
        let kiranaData = Object.assign({}, ...AllValues.Kirana);
        req = {
            "apiRequest": {
                "interfaceName": "IncomeAssessmentCheck",
                "incomeType": "Kirana",
                "requestObj": {
                    "kiranaRequestFields": {
                        "businessLocation": kiranaData["kiranaBusinessLocation"],
                        // "typeOfShop": "Bakery",
                        "typeOfShop": kiranaData["kiranaShopType"],
                        "marketClassification": kiranaData["kiranaMarketClassification"],
                        "areaOfTheShop": `${kiranaData["areaofshop"]} | ${kiranaData["kiranaUnit"]}`,
                        "areaOfTheGodown": `${kiranaData["areaOfGodown"]} | ${kiranaData["kiranaGodownUnit"]}`,
                        "occupancyLevelOfShopAndGodown": kiranaData["kiranaOccupancyLevel"],
                        "monthlyNetBusinessIncome": apz.app.CaIncomeDetails.parseIncome(kiranaData["netMonthlyIncome"])
                    }
                }
            }
        }
    } else if (Type === "Tailoring") {
        let tailoringData = Object.assign({}, ...AllValues.Tailoring);
        const stitchTypes = Object.keys(tailoringData).filter(key => !isNaN(key)).map(key => tailoringData[key]); // Get values
        req = {
            "apiRequest": {
                "interfaceName": "IncomeAssessmentCheck",
                "incomeType": "Tailoring",
                "requestObj": {
                    /*"tailoringRequestFields": {
                        "businessLocation": tailoringData["tailoringBusinessLocation"],
                        "businessPremise": tailoringData["tailoringPremise"],
                        "typeOfMachine": tailoringData["tailoringMachineType"],
                        "numOfTailorsWorking": parseInt(tailoringData["numOfTailors"], 10),
                        "numOfTailoringMachine": parseInt(tailoringData["numOfTailoringMachines"], 10),
                        "workTime": tailoringData["tailoringWorkType"],
                        "stitchType": tailoringData['tailorShopItems'],
                        "monthlyNetBusinessIncome": apz.app.CaIncomeDetails.parseIncome(tailoringData["netMonthlyIncome"])
                    }*/
                    "tailoringRequestFields": {
                        "businessLocation": tailoringData["tailoringBusinessLocation"],
                        "businessPremise": tailoringData["tailoringPremise"],
                        "numOfPowerTailoringMachine": parseInt(tailoringData["numOfPowerTailoringMachine"] ?? ''),
                        "numOfManualTailoringMachine": parseInt(tailoringData["numOfManualTailoringMachine"] ?? ''),
                        "isApplicantATailor": tailoringData["isApplicantATailor"],
                        "isCoApplicantPartOfTailorBusiness": tailoringData["isCoApplicantPartOfTailorBusiness"],
                        "numOfSalariedTailors": parseInt(tailoringData["numOfSalariedTailors"] ?? ''),
                        "workType": tailoringData["tailoringWorkType"],
                        "stitchingFor": tailoringData["stitchingFor"]
                    }
                }
            }
        }
    } else if (Type === "Wage") {
        req = {
            "apiRequest": {
                "interfaceName": "IncomeAssessmentCheck",
                "incomeType": "Wage",
                "requestObj": {
                    "wageRequestFields": {
                        "branchId": ObjectData.branchId,
                        "gender": ObjectData.gender,
                        "workingDays": ObjectData.workingDays,
                        "Id": ObjectData.Index
                    }
                }
            }
        }
    } else if (Type === "Agriculture") {
        req = {
            "apiRequest": {
                "interfaceName": "IncomeAssessmentCheck",
                "incomeType": "AGRICULTURE",
                "requestObj": {
                    "agricultureRequestFields": {
                        "state": ObjectData.state,
                        "cropType": ObjectData.cropType,
                        "maxProductionPerAcre": ObjectData.maxProductionPerAcre,
                        "totalAcres": ObjectData.totalAcres,
                        "crop": ""
                    }
                }
            }
        }
    } else if (Type === "Rental") {
        req = {
            "apiRequest": {
                "interfaceName": "IncomeAssessmentCheck",
                "incomeType": "RENTALINCOME",
                "requestObj": {
                    "rentalIncomeRequestFields": {
                        "state": ObjectData.state,
                        "typeOfBuilding": ObjectData.typeOfBuilding,
                        "rentalIncome": ObjectData.rentalIncome
                    }
                }
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "IncomeAssessmentCheck", "N", "N", req, false, apz.app.CaIncomeDetails.IncomeAssessmentCheckCB);
};
apz.app.CaIncomeDetails.parseIncome = function(value) {
    return parseFloat(value.replace(/,/g, ""));
}
apz.app.CaIncomeDetails.IncomeAssessmentCheckCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            let JsonPayload = JSON.parse(params.res.APZCBO__IncomeAssessmentCheck_Res.apiResponse.ResponseBody.responseObj);
            switch (params.req.apiRequest.incomeType) {
                case 'Dairy':
                    $(".CalDet").removeClass("sno");
                    apz.app.CaIncomeDetails.onSuccessIncomeAssessmentCheckDairy(JsonPayload, "Dairy");
                    break;
                case 'Kirana':
                    $(".K-CalDet").removeClass("sno");
                    apz.app.CaIncomeDetails.onSuccessIncomeAssessmentCheckKirana(JsonPayload, "Kirana");
                    break;
                case 'Tailoring':
                    $(".T-CalDet").removeClass("sno");
                    apz.app.CaIncomeDetails.onSuccessIncomeAssessmentCheckTailoring(JsonPayload, "Tailoring");
                    break;
                case 'Wage':
                    // var id = Object.keys(wageObject).find(k => wageObject[k] === params.req.apiRequest.requestObj.wageRequestFields.gender);
                    // id = id === 'Applicant' ? 'App' : 'Co'
                    let id = WageObject.earndTyp === "Co-App" ? "Co" : "App"
                    $("#" + CaIncomeDetailsScrId + 'ToTalWagePerMonth_' + id + params.req.apiRequest.requestObj.wageRequestFields.Id).val(
                        JsonPayload.map.totalWagePerMonth);
                    $("#" + CaIncomeDetailsScrId + 'WageEarnedPerDay_' + id + params.req.apiRequest.requestObj.wageRequestFields.Id).val(
                        JsonPayload.map.wageEarnedPerDay);
                    break;
                case 'AGRICULTURE':
                    if (agriApplicant) {
                        $("#CrdAss__CaIncomeDetails__Agri_MonthIncome").val(JsonPayload.map.totalAgriIncome);
                        $("#CrdAss__CaIncomeDetails__Agri_ConsideredIncome").val(JsonPayload.map.consideredAgriIncome);
                    } else {
                        $("#CrdAss__CaIncomeDetails__Co_Agri_Month_income").val(JsonPayload.map.totalAgriIncome);
                        $("#CrdAss__CaIncomeDetails__Co_Agri_ConsideredIncome").val(JsonPayload.map.consideredAgriIncome);
                    }
                    break;
                case 'RENTALINCOME':
                    if (rentalApplicant) {
                        window.consideredMonthlyIncomeApp = JsonPayload.map.consideredMonthlyIncome;
                        $("#CrdAss__CaIncomeDetails__ConsideredRentalIncome_App").val(JsonPayload.map.consideredMonthlyIncome);
                    } else if (rentalCoApplicant) {
                        window.consideredMonthlyIncomeCoApp = JsonPayload.map.consideredMonthlyIncome;
                        $("#CrdAss__CaIncomeDetails__ConsideredRentalIncome_CoApp").val(JsonPayload.map.consideredMonthlyIncome);
                    }
                    break;
                default:
                    break;
            }
            const closeButtonIds = [CaIncomeDetailsScrId + "Dairy_close", CaIncomeDetailsScrId + "Tailoring_close",
                CaIncomeDetailsScrId + "Kirana_close"
            ];
            closeButtonIds.forEach(id => {
                const element = document.getElementById(id);
                if (element) {
                    element.addEventListener("click", function() {
                        IncomeassEdit = {
                            type: "",
                            Flag: false
                        };
                    });
                }
            });
        } else {
            apz.stopLoader();
            ApzCOB.ServiceFailureMsg();
            //}
        }
    } catch {
        ApzCOB.ServiceFailureMsg();
        apz.stopLoader();
    }
};
apz.app.CaIncomeDetails.calculateAverage = function(array, key) {
    if (!array || array.length === 0) return 0;
    const sum = array.reduce((acc, item) => acc + item.map[key], 0);
    // return sum / array.length;
    return sum; //Diary template change fix 26/12/2025
};
apz.app.CaIncomeDetails.onSuccessIncomeAssessmentCheckTailoring = function(data, type) {
    data = data.map;
    if (data.netBusinessIncome < 0) {
        $(".T-CalDet").addClass("sno");
        ApzCOB.fnDisplayMsg("Net monthly income cannot be negative.", "E");
        return;
    }
    let ID = ["revenuePerDay", "revenuePerMonth", "totalMonthlyIncome", "netBusinessIncome"];
    let inputIds = ['RevenuePerDay', 'RevenuePerMonth', 'TotalMonthRev', 'TailNetBusIncome'];
    for (let i = 0; i < inputIds.length; i++) {
        let obj = {
            [ID[i]]: data[ID[i]]
        }
        AllValues.Tailoring.push(obj);
        const inputElement = document.getElementById(CaIncomeDetailsScrId + inputIds[i]);
        if (inputElement) {
            inputElement.textContent = '₹' + ApzCOB.fn_FormatAmount([data[ID[i]]]); // Set value
        }
    }
    const form = document.getElementById(CaIncomeDetailsScrId + type + "_content");
    const ignoreIds = ["T_Save"];
    if (form) {
        const elements = form.querySelectorAll("input, select, textarea, button");
        elements.forEach(el => {
            if (!ignoreIds.includes(el.id.split("__")[2])) {
                el.disabled = true;
                if (el.parentElement && el.parentElement.id.includes("_ext")) {
                    // For select elements, add class from parent
                    el.parentElement.classList.add("select-disabled");
                } else {
                    // For other elements, add the disable class from the element itself
                    el.classList.add("disabled");
                }
            }
        });
    }
    $(".T-Edit").removeClass("sno");
    IncomeassEdit = {
        type: type,
        Flag: true
    };
}
apz.app.CaIncomeDetails.onSuccessIncomeAssessmentCheckKirana = function(data, type) {
    data = data.map;
    let ID = ["areaOfTheShopInSqft", "areaOfTheGodownInSqft", "totalArea", "inventoryArea", "inventoryValue", "monthlySales",
        "calculatedNetIncome", "finalNetIncome"
    ];
    let inputIds = ['AreaShopSqFt', 'AreaGodSqFt', 'TotalAreaSqFt', 'InvenArea', 'InvenVal', 'MonthSal', 'CalNetBusIncome', 'FirstNetBussIncome'];
    for (let i = 0; i < inputIds.length; i++) {
        let obj = {
            [ID[i]]: data[ID[i]]
        };
        AllValues.Kirana.push(obj);
        const inputElement = document.getElementById(CaIncomeDetailsScrId + inputIds[i]);
        if (inputElement) {
            const isCurrencyField = i >= 4; // Only last 4 fields are currency
            const formattedValue = ApzCOB.fn_FormatAmount([data[ID[i]]]);
            inputElement.textContent = isCurrencyField ? '₹' + formattedValue : formattedValue;
        }
    }
    const form = document.getElementById(CaIncomeDetailsScrId + type + "_content");
    const ignoreIds = ["KSaveBtn"];
    if (form) {
        const elements = form.querySelectorAll("input, select, textarea, button");
        elements.forEach(el => {
            if (!ignoreIds.includes(el.id.split("__")[2])) {
                el.disabled = true;
                if (el.parentElement && el.parentElement.id.includes("_ext")) {
                    el.parentElement.classList.add("select-disabled");
                } else {
                    el.classList.add("disabled");
                }
            }
        });
    }
    $(".K-Edit").removeClass("sno");
    IncomeassEdit = {
        type: type,
        Flag: true
    };
};
apz.app.CaIncomeDetails.onSuccessIncomeAssessmentCheckDairy = function(data, type) {
    const buffaloes = data.map.revenueOfBuffaloes.myArrayList;
    const cows = data.map.revenueOfCows.myArrayList;
    // Calculate averages
    const avgDailyRevenuePerBuffalo = apz.app.CaIncomeDetails.calculateAverage(buffaloes, "dailyRevenuePerBuffalo");
    const avgMonthlyRevenuePerBuffalo = apz.app.CaIncomeDetails.calculateAverage(buffaloes, "monthlyRevenuePerBuffalo");
    const avgDailyRevenuePerCow = apz.app.CaIncomeDetails.calculateAverage(cows, "dailyRevenuePerCow");
    const avgMonthlyRevenuePerCow = apz.app.CaIncomeDetails.calculateAverage(cows, "monthlyRevenuePerCow");
    const IncomeAssessmentChecknetBusinessIncome = data.map.netBusinessIncome;
    if (IncomeAssessmentChecknetBusinessIncome < 0) {
        $(".CalDet").addClass("sno");
        ApzCOB.fnDisplayMsg("Net monthly income cannot be negative.", "E");
        return;
    }
    let ID = ["avgDailyRevenuePerBuffalo", "avgMonthlyRevenuePerBuffalo", "avgDailyRevenuePerCow", "avgMonthlyRevenuePerCow",
        "IncomeAssessmentChecknetBusinessIncome"
    ];
    let Values = [avgDailyRevenuePerBuffalo, avgMonthlyRevenuePerBuffalo, avgDailyRevenuePerCow, avgMonthlyRevenuePerCow,
        IncomeAssessmentChecknetBusinessIncome
    ];
    let inputIds = ['DBuff', 'MBuff', 'DCow', 'MCow', 'NetInc'];
    for (let i = 0; i < inputIds.length; i++) {
        let obj = {
            [ID[i]]: Values[i]
        }
        AllValues.dairy.push(obj);
        const inputElement = document.getElementById(CaIncomeDetailsScrId + inputIds[i]);
        if (inputElement) {
            inputElement.textContent = '₹' + ApzCOB.fn_FormatAmount(Values[i]); // Set value
        }
    }
    const form = document.getElementById(CaIncomeDetailsScrId + type + "_content");
    const ignoreIds = ["SaveBtn"];
    if (form) {
        const elements = form.querySelectorAll("input, select, textarea, button");
        elements.forEach(el => {
            if (!ignoreIds.includes(el.id.split("__")[2])) {
                el.disabled = true;
                if (el.parentElement && el.parentElement.id.includes("_ext")) {
                    // For select elements, add class from parent
                    el.parentElement.classList.add("select-disabled");
                } else {
                    // For other elements, add the disable class from the element itself
                    el.classList.add("disabled");
                }
            }
        });
    }
    $(".EditDa").removeClass("sno");
    IncomeassEdit = {
        type: type,
        Flag: true
    };
}
apz.app.CaIncomeDetails.NoOfDaysValidation = function(pthis) {
    if (pthis.value) {
        let value = parseInt(pthis.value, 10);
        if (isNaN(value) || value < 1) {
            pthis.value = 1;
        } else if (value > 30) {
            pthis.value = 30;
        }
    }
};
apz.app.CaIncomeDetails.agriService = function(pthis) {
    var cropType, maxProductionPerAcre, totalAcres, crop;
    if (landRangeFlag) {
        if (pthis.value) {
            if (pthis.id.includes("Ap")) {
                agriApplicant = true
                cropType = $(`#${CaIncomeDetailsScrId}Ap_CropType`).val();
                maxProductionPerAcre = (($(`#${CaIncomeDetailsScrId}Ap_MaxperArc`).val()).split('.')[0]).replace(/[.,]/g, '');
                totalAcres = ($(`#${CaIncomeDetailsScrId}Ap_LandInAcres`).val());
                crop = $(`#${CaIncomeDetailsScrId}Ap_Crop`).val();
            } else if (pthis.id.includes("Co")) {
                agriApplicant = false;
                cropType = $(`#${CaIncomeDetailsScrId}Co_CropType`).val();
                maxProductionPerAcre = (($(`#${CaIncomeDetailsScrId}Co_MaxPerAcrc`).val()).split('.')[0]).replace(/[.,]/g, '');
                totalAcres = ($(`#${CaIncomeDetailsScrId}Co_LandInAcres`).val());
                crop = $(`#${CaIncomeDetailsScrId}Co_Crop`).val();
            } else {
                //
            }
            const AgriObject = {
                "state": (inSessionStore.leadDetails?.permState || inSessionStore.renewalLeadDetails?.permState),
                "cropType": cropType,
                "maxProductionPerAcre": maxProductionPerAcre,
                "totalAcres": totalAcres,
                "crop": crop
            };
            const allFieldsPresent = Object.values(AgriObject).every(val => val !== null && val !== undefined && val !== '' && val !==
                'Please Select');
            if (allFieldsPresent) {
                apz.app.CaIncomeDetails.IncomeAssessmentCheck("Agriculture", AgriObject);
            } else {
                if (pthis.id.includes("Ap")) {
                    $(`#${CaIncomeDetailsScrId}Agri_MonthIncome`).val("0");
                    $(`#${CaIncomeDetailsScrId}Agri_ConsideredIncome`).val("0");
                } else {
                    $(`#${CaIncomeDetailsScrId}Co_Agri_Month_income`).val("0");
                    $(`#${CaIncomeDetailsScrId}Co_Agri_ConsideredIncome`).val("0");
                }
                return;
            }
        }
    } else {
        if (pthis.value) {
            if (pthis.id.includes("Ap")) {
                $(`#${CaIncomeDetailsScrId}Ap_MaxperArc`).val("");
                $(`#${CaIncomeDetailsScrId}Ap_LandInAcres`).val("");
                $(`#${CaIncomeDetailsScrId}Agri_MonthIncome`).val("");
                $(`#${CaIncomeDetailsScrId}Agri_ConsideredIncome`).val("");
            } else if (pthis.id.includes("Co")) {
                $(`#${CaIncomeDetailsScrId}Co_MaxPerAcrc`).val("");
                $(`#${CaIncomeDetailsScrId}Co_LandInAcres`).val("");
                $(`#${CaIncomeDetailsScrId}Co_Agri_Month_income`).val("");
                $(`#${CaIncomeDetailsScrId}Co_Agri_ConsideredIncome`).val("");
            } else {
                //
            }
        }
    }
}
apz.app.CaIncomeDetails.rentalService = function(pthis) {
    var typeOfBuilding, rentalIncome;
    let appisChecked = $(`#CrdAss__CaIncomeDetails__RentalincomeOwn_Owned_option_Applicant`).is(":checked")
    if (appisChecked && $('#CrdAss__CaIncomeDetails__BuildType_App').val() == 'Please Select') {
        return;
    }
    if (pthis.value) {
        if (pthis.id.includes("Ap")) {
            rentalApplicant = true;
            rentalCoApplicant = false
            typeOfBuilding = $(`#${CaIncomeDetailsScrId}BuildType_App`).val();
            rentalIncome = (($(`#${CaIncomeDetailsScrId}RentalIncomeMonth_App`).val()).split('.')[0]).replace(/[.,]/g, '');
            window.consideredMonthlyIncomeApp = '';
            $("#CrdAss__CaIncomeDetails__ConsideredRentalIncome_App").val('');
        } else if (pthis.id.includes("Co")) {
            rentalApplicant = false;
            rentalCoApplicant = true;
            typeOfBuilding = $(`#${CaIncomeDetailsScrId}BuildType_Co`).val();
            rentalIncome = (($(`#${CaIncomeDetailsScrId}RentalIncomeMonth_Co`).val()).split('.')[0]).replace(/[.,]/g, '');
            window.consideredMonthlyIncomeCoApp = '';
            $("#CrdAss__CaIncomeDetails__ConsideredRentalIncome_CoApp").val('');
        } else {
            //
        }
        const rentalObject = {
            "state": (inSessionStore.leadDetails?.permState || inSessionStore.renewalLeadDetails?.permState),
            "typeOfBuilding": typeOfBuilding,
            "rentalIncome": rentalIncome
        };
        apz.app.CaIncomeDetails.IncomeAssessmentCheck("Rental", rentalObject);
    }
}
apz.app.CaIncomeDetails.validateLandAcr = function(pthis) {
    let value = pthis.value;
    value = value.replace(/[^0-9.]/g, '');
    // Only allow one decimal point
    const parts = value.split('.');
    if (parts.length > 2) {
        value = parts[0] + '.' + parts[1];
    }
    const noDotValue = value.replace('.', '');
    if (noDotValue.length > 5) {
        let digits = noDotValue.substring(0, 5);
        if (value.includes('.')) {
            const dotIndex = parts[0].length;
            digits = digits.slice(0, dotIndex) + '.' + digits.slice(dotIndex);
        }
        value = digits;
    }
    pthis.value = value;
}
apz.app.CaIncomeDetails.NoOfDaysOnBlur = function(pthis) {
    var id;
    if (pthis.value && wageObject) {
        if (pthis.id.includes("App")) {
            id = pthis.id.split('App')[1]
        } else if (pthis.id.includes("Co")) {
            id = pthis.id.split('Co')[1]
        } else {
            id = pthis.id
        }
        if (id === "_") {
            var index = pthis.id.indexOf("Co");
            if (index !== -1) {
                var part1 = pthis.id.slice(0, index);
                var part2 = pthis.id.slice(index + 2); // +2 for length of 'Co'
                // (part2); // after 'Co'
                id = part2;
            }
        }
        const isCoApplicant = pthis.id.includes("NoOFDaysInMonth_Co_");
        WageObject = {
            "branchId": wageObject.BranchID,
            "gender": wageObject[isCoApplicant ? "Co-App" : "Applicant"],
            "workingDays": pthis.value,
            "Index": id,
            "earndTyp": isCoApplicant ? "Co-App" : "Applicant"
        };
        apz.app.CaIncomeDetails.IncomeAssessmentCheck("Wage", WageObject);
    }
}
apz.app.CaIncomeDetails.camera = function(pthis) {
    docNoImageUpload = '';
    incomeTypeBulkDelete = '';
    let index = pthis.id.split("_")[4];
    let Type = pthis.id.split("_")[5];
    if (pthis.id.includes("Bussness")) {
        incomeTypeBulkDelete = "Business";
        custTypeIncomeDtls = $(`input[name="CrdAss__CaIncomeDetails__${index}_businessOwnedByOption_"]:checked`).val();
        TempImageObject.custTypeIncomeDtls = custTypeIncomeDtls;
        TempImageObject.index = index;
        const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__' + index + '_businessTypeOption input[type="radio"]:checked');
        checkboxes.forEach(checkbox => {
            TempImageObject.Type = checkbox.id.split("_")[7];
        });
        let selectedBusinessTypes = {};
        const cloneRow = document.getElementById(`CrdAss__CaIncomeDetails__CloneRow_${index}`);
        if (cloneRow && !cloneRow.classList.contains('sno')) {
            const checkedRadio = document.querySelector(`#CrdAss__CaIncomeDetails__${index}_businessTypeOption input[type="radio"]:checked`);
            if (checkedRadio) {
                selectedBusinessTypes[index] = checkedRadio.value;
                if (selectedBusinessTypesIncomeDtls) {
                    const keys = Object.keys(selectedBusinessTypesIncomeDtls);
                    let count = 0;
                    for (let pos = 0; pos < keys.length; pos++) {
                        const key = Number(keys[pos]);
                        const value = selectedBusinessTypesIncomeDtls[keys[pos]];
                        if (key <= Number(index) && value === checkedRadio.value) {
                            count++;
                        }
                    }
                    docNoImageUpload = count;
                }
            }
        }
    } else if (pthis.id.includes("_Img_Agg")) {
        TempImageObject.Type = "Rentalincome_Agg";
        TempImageObject.index = Type === 'App' ? "Applicant" : "Co-Applicant";
        custTypeIncomeDtls = TempImageObject.index;
        incomeTypeBulkDelete = "Rentalincome_Agg Doc"
    } else {
        TempImageObject.Type = index;
        TempImageObject.index = Type === 'App' ? "Applicant" : "Co-Applicant";
        custTypeIncomeDtls = TempImageObject.index;
        incomeTypeBulkDelete = `${index} Doc`;
    }
    var cameraObj = {
        "zoomLevel": "20",
        "targetWidth": "950",
        "targetHeight": "950",
        "crop": "Y",
        "cropBox": "rectangle",
        "flash": "N",
        "action": "base64_Save",
        "fileName": 'b',
        "quality": "75",
        "encodingType": "JPG",
        "sourceType": "camera"
    };
    cameraObj.id = "CAMERA_ID";
    cameraObj.callBack = apz.app.CaIncomeDetails.cameraCallback;
    apz.ns.openCamera(cameraObj);
    ApzCOB.getGeoCordinatesMobile();
};
apz.app.CaIncomeDetails.cameraCallback = function (params) {
    cameracallbackres = params;
    let fileName = params.path.split('/').pop();
    let base64 = params.encodedImage;
    if (base64.indexOf(',') !== -1) {
        base64 = base64.split(',')[1];
    }
    let fileSizeBytes = Math.ceil((base64.length * 3) / 4);
    let fileSizeMB = fileSizeBytes / (1024 * 1024);

    if (fileSizeMB > 10) {
        ApzCOB.fnDisplayMsg("File size should not exceed 10 MB")
        return;
    }
    apz.app.CaIncomeDetails.saveDocument(fileName, params.encodedImage);
};
apz.app.CaIncomeDetails.saveDocument = function(fileName, base64) {
    let docLevel = "1";
    let ActiveCustType = custTypeIncomeDtls === "Co-Applicant" ? "Co-App" : "Applicant";
    docLevel = ApzCOB.getNextDocLevel(`${TempImageObject?.Type} Doc`, ApzCOB.getCustDetailID(ActiveCustType));
    let req = {
        apiRequest: {
            "requestObj": {
                "appId": gApzCOB.userDetails.appId,
                "applicationId": gApzCOB.userDetails.applicationId,
                "versionNum": 1,
                "stageId": "UPLOADDOCS",
                "requestType": "Edit",
                "customerType": "Applicant",
                "uploadDocumentRequestFields": {
                    "versionNum": 1,
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "appId": gApzCOB.userDetails.appId,
                    "srcScreen": "UPLOADDOCS",
                    "filePath": gApzCOB.userDetails.appId + /LOAN/ + gApzCOB.userDetails.applicationId,
                    "fileName": fileName,
                    "base64Value": base64,
                    "productGroupCode": "LOAN",
                    "isExistingCustomer": "N"
                },
                "applicationDocumentsWrapperList": [{
                    "applicationDocumentsList": [{
                        "appDocId": "",
                        "applicationId": gApzCOB.userDetails.applicationId,
                        "versionNum": 1,
                        "appId": gApzCOB.userDetails.appId,
                        "custDtlId": gApzCOB.userDetails.custDtlId,
                        "documentId": "",
                        "status": "A",
                        "payload": {
                            "docLevel": docLevel,
                            "documentType": `${TempImageObject?.Type} Doc`,
                            "documentDesc": "",
                            "documentLoc": gApzCOB.userDetails.appId + /LOAN/ + gApzCOB.userDetails.applicationId,
                            "screenId": "UploadDocuments",
                            "issueDate": "",
                            "expiryDate": "",
                            "docStatus": "A",
                            "docSide": "Front",
                            "docSize": ApzCOB.getBase64FileSizeInBytes(base64),
                            "documentFileName": fileName,
                            "documentFormat": fileName,
                            "isPushbackUpload": "N",
                            "isAdiDoc": "N",
                            "uploadedBy": "BM",
                            "custType": custTypeIncomeDtls,
                            "stage": "CreditAssessment",
                            "docNo": docNoImageUpload,
                            "incomeType": incomeTypeBulkDelete,
                            "latitude": window.currentGeoCords?.latitude,
                            "longitude": window.currentGeoCords?.longitude,
                            "uploadedTs": new Date().toISOString(),
                        }
                    }]
                }]
            },
            "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
            "appId": gApzCOB.userDetails.appId,
            "interfaceName": "UploadRPCLoanData"
        }
    }
    if (custTypeIncomeDtls === "Co-Applicant") {
        req.apiRequest.requestObj.applicationDocumentsWrapperList[0].applicationDocumentsList[0].custDtlId = ApzCOB.getCustDetailID('Co-App');
    } else {
        req.apiRequest.requestObj.applicationDocumentsWrapperList[0].applicationDocumentsList[0].custDtlId = ApzCOB.getCustDetailID("Applicant");
    }
    apz.startLoader();
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, "UploadRPCLoanData", "N", "N", req, false, apz.app.CaIncomeDetails.saveDocumentCB);
    }, 1000)
}
apz.app.CaIncomeDetails.saveDocumentCB = function(params) {
    const docType = params.req.apiRequest.requestObj.applicationDocumentsWrapperList[0].applicationDocumentsList[0].payload.documentType;
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            apz.app.CaIncomeDetails.paintDocumentName(docType);
        } else {
            apz.stopLoader();
        }
    } catch {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg("failed to save the data")
    }
}
apz.app.CaIncomeDetails.paintDocumentName = function(docType) {
    // if (!cameracallbackres.status) return;
    if (!ImageObject[TempImageObject.Type]) {
        ImageObject[TempImageObject.Type] = {};
    }
    if (!ImageObject[TempImageObject.Type][TempImageObject.index]) {
        ImageObject[TempImageObject.Type][TempImageObject.index] = [];
    }
    let imageList = ImageObject[TempImageObject.Type][TempImageObject.index];
    let Length = imageList.length + 1;
    let obj = {
        "ImageName": `Business ${TempImageObject.index} ${TempImageObject.Type} Image ${Length}`,
        // "Base64": cameracallbackres.encodedImage
    };
    const incomeSourcePrefixMap = {
        "Salary Doc": "Salary",
        "Pension Doc": "Pension",
        "Agriculture Doc": "Agriculture",
        "Rentalincome_Agg Doc": "Rentalincome_Agg",
        "Other Doc": "Other",
        "Kirana Doc": "Kirana",
        "Dairy Doc": "Dairy",
        "Tailoring Doc": "Tailoring"
    };
    let prefix = "";
    let count = 0;
    if (docType === "Other Doc" || docType === "Kirana Doc" || docType === "Dairy Doc" || docType === "Tailoring Doc") {
        obj = {
            "ImageName": `Business ${TempImageObject.index} ${TempImageObject.Type} Image ${Length}`,
            // "Base64": cameracallbackres.encodedImage
        };
        const prefixDocs = incomeSourcePrefixMap[docType];
        if (prefixDocs && ["Other", "Kirana", "Dairy", "Tailoring"].includes(prefixDocs)) {
            const currentIndex = parseInt(TempImageObject.index);
            for (let i = 1; i <= currentIndex; i++) {
                const cloneRow = document.getElementById(`CrdAss__CaIncomeDetails__CloneRow_${i}`);
                if (cloneRow && !cloneRow.classList.contains('sno')) {
                    const checkedRadio = document.querySelector(`#CrdAss__CaIncomeDetails__${i}_businessTypeOption input[type="radio"]:checked`);
                    if (checkedRadio && checkedRadio.value === prefixDocs) {
                        count++;
                        // (`${prefixDocs}, ${count}`)
                    }
                }
            }
        }
    } else {
        const docTypePrefixMap = {
            "Salary Doc": "Salary",
            "Pension Doc": "Pension",
            "Agriculture Doc": "Agriculture",
            "Rentalincome_Agg Doc": "Rentalincome_Agg"
        };
        // Get prefix from the map, fallback to 'Other' if unknown
        prefix = docTypePrefixMap[docType] || "Other";
        obj = {
            "ImageName": `${prefix} ${TempImageObject.index} ${TempImageObject.Type} Image ${Length}`,
            // "Base64": cameracallbackres.encodedImage
        };
    }
    imageList.push(obj);
    apz.app.CaIncomeDetails.enableBotButton(docType, TempImageObject.custTypeIncomeDtls);

    let typeMap = {
        "Agriculture": {
            "Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Agriculture_App_UploadedImage",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Agriculture_App_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}Agriculture_App_ParentBusRow`
            },
            "Co-Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Agriculture_Co_UploadedImage",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Agriculture_Co_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}Agriculture_Co_ParentBusRow`
            }
        },
        "Salary": {
            "Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Salary_App_UploadedImage",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Salary_App_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}Salary_App_ParentBusRow`
            },
            "Co-Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Salary_Co_UploadedImage",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Salary_Co_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}Salary_Co_ParentBusRow`
            }
        },
        "Pension": {
            "Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Pension_App_UploadedImage",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Pension_App_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}Pension_App_ParentBusRow`
            },
            "Co-Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Pension_Co_UploadedImage",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Pension_Co_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}Pension_Co_ParentBusRow`
            }
        },
        "Rentalincome": {
            "Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Rentalincome_App_UploadedImage",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Rentalincome_App_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}Rentalincome_App_ParentBusRow`
            },
            "Co-Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Rentalincome_Co_UploadedImage",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Rentalincome_Co_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}Rentalincome_Co_ParentBusRow`
            }
        },
        "Rentalincome_Agg": {
            "Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Rentalincome_App_UploadedImage_Agg",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Rentalincome_App_ImageName_Agg`,
                parentSelector: `${CaIncomeDetailsScrId}Rentalincome_App_ParentBusRow_Agg`
            },
            "Co-Applicant": {
                idPrefix: "CrdAss__CaIncomeDetails__Rentalincome_Co_UploadedImage_Agg",
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_Rentalincome_Co_ImageName_Agg`,
                parentSelector: `${CaIncomeDetailsScrId}Rentalincome_Co_ParentBusRow_Agg`
            }
        },
        "Business": {
            "default": {
                idPrefix: `CrdAss__CaIncomeDetails__${TempImageObject.index}_BussnessUploadedImage`,
                ImageidPrefix: `CrdAss__CaIncomeDetails__${Length}_${TempImageObject.index}_Bussiness_ImageName`,
                parentSelector: `${CaIncomeDetailsScrId}${TempImageObject.index}_Business_ParentBusRow`
            }
        }
    };
    let typeConfig = typeMap[TempImageObject.Type] && typeMap[TempImageObject.Type][TempImageObject.index] ? typeMap[TempImageObject.Type][
        TempImageObject.index
    ] : typeMap["Business"]["default"];
    const documentsArr = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
    // && doc.payload.custType === custTypeIncomeDtls
    if (documentsArr.length > 0) {
        let incomeDetailsDoc;
        if (docType === "Other Doc" || docType === "Kirana Doc" || docType === "Dairy Doc" || docType === "Tailoring Doc") {
            incomeDetailsDoc = documentsArr.filter(doc => doc.payload.documentType === docType && doc.payload.docNo == count);
        } else {
            incomeDetailsDoc = documentsArr.filter(doc => doc.payload.documentType === docType && doc.payload.custType === TempImageObject.index);
        }
        // const incomeDetailsDoc = documentsArr.filter(doc => doc.payload.documentType === docType && parseInt(doc.custDtlId) === parseInt(gApzCOB
        //     .userDetails.custDtlId));
        if (incomeDetailsDoc.length > 0) {
            let {
                idPrefix,
                ImageidPrefix,
                parentSelector
            } = typeConfig;
            let Id = `${idPrefix}_${Length}`;
            let cloneDiv = idPrefix;
            let parentDiv = $(`#${parentSelector}`);
            parentDiv.html('');
            incomeDetailsDoc.forEach((doc, index) => {
                let clonedId = apz.app.CaIncomeDetails.DeepcloneDivs(cloneDiv, parentDiv, index + 1);
                $(`#${clonedId}`).attr('data-id', doc.appDocId);
                // $(`#${clonedId} a.ett-hypl span`).text(doc.payload.documentFileName);
                $(`#${clonedId} a.ett-hypl span`).text(`${incomeSourcePrefixMap[docType]}_${index + 1}.jpg`);
                $(`#${clonedId}`).removeClass("sno");
                //   $(`#${ImageidPrefix}`).text(obj.ImageName);
            })
        apz.app.CaIncomeDetails.addBotSectionButton(parentDiv, docType, TempImageObject.custTypeIncomeDtls);
        } else {
            $(`#${typeConfig.idPrefix}_${imgNumber}`).addClass("sno");
        }
    }
}

apz.app.CaIncomeDetails.isBotEnabledForDoc = function (docType) {
    var docTypeToBipCodeMap = {
        "Kirana Doc": "KIRANA",
        "Dairy Doc": "DAIRY",
        "Tailoring Doc": "TAILORING",
        "Other Doc": "OTHER_BUSINESS",
        "Agriculture Doc": "AGRICULTURE",
        "Salary Doc": "SALARY",
        "Pension Doc": "PENSION",
        "Rentalincome_Agg Doc": "RENTAL_PROOF"
    };
    const matchedItem = gLovs.find(item => item.lovName === "BIP_CONFIG");
    if (!matchedItem) return false;
    const BIP_CONFIG_LOV = JSON.parse(matchedItem.lovDtls);
    const code = docTypeToBipCodeMap[docType];
    if (!code) return false;

    return BIP_CONFIG_LOV.incomeProofConfig.some(cfg => cfg.code === code && cfg.required);
};

apz.app.CaIncomeDetails.addBotSectionButton = function (parentDiv, docType, custIndex) {
    if (!apz.app.CaIncomeDetails.isBotEnabledForDoc(docType)) return;
    if (parentDiv.find(".bot-section-btn").length > 0) return;
    const btnId = `botBtn_${docType.replace(/\s/g, '')}_${custIndex}`;
    const btn = $(`
        <div style="margin-top:10px;text-align:center">
            <button type="button" id="${btnId}" class="bot-section-btn ett-bttn sec med pre-view dark">
                Process All Images with BOT
            </button>
        </div>
    `);
    btn.find("button").on("click", function () {
        const $thisBtn = $(this);
        $thisBtn.prop("disabled", true);
        $thisBtn.text("bot triggered");
        let finalCustType = custIndex;
        if (typeof custIndex === "number") {
            if (custIndex === 1) finalCustType = "Applicant";
            else if (custIndex === 2) finalCustType = "Co-Applicant";
            else if (custIndex === 3) finalCustType = "Both";
        }
        apz.app.CaIncomeDetails.triggerImageProcessing(docType, finalCustType);
    });
    parentDiv.append(btn);
};

apz.app.CaIncomeDetails.enableBotButton = function (docType, custIndex, action) {
    const btnId = `botBtn_${docType.replace(/\s/g, '')}_${custIndex}`;
    const $btn = $(`#${btnId}`);
    if ($btn.length === 0) return;
    const documentsArr = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
    let custType = custIndex;
    if (typeof custIndex === "number") {
        if (custIndex === 1) custType = "Applicant";
        else if (custIndex === 2) custType = "Co-Applicant";
    }
    const docs = documentsArr.filter(doc =>
        doc.payload.documentType === docType &&
        doc.payload.custType === custType
    );
    // if (docs.length === 0) {
    //     $btn.closest("div").remove();
    //     return;
    // }
    if (action === "delete") {
        apz.app.CaIncomeDetails.triggerImageProcessing(docType, custType)
        if (docs.length === 0) {
            $btn.closest("div").remove();
        }
        return;
    }
    $btn.prop("disabled", false);
    $btn.text(`Process All ${docType} Images with BOT`);
};

apz.app.CaIncomeDetails.disableBotButtons = function () {
    const documentsArr = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
    documentsArr.forEach(doc => {
        if (doc.payload?.botTrigger === "Y") {
            const docType = doc.payload.documentType;
            const custType = doc.payload.custType;
            const btnId = `botBtn_${docType.replace(/\s/g, '')}_${custType}`;
            const $btn = $(`#${btnId}`);
            if ($btn.length) {
                $btn.prop("disabled", true);
                $btn.text("bot triggered");
            }
        }
    });
};

apz.app.CaIncomeDetails.areAllBotButtonsClicked = function () {
    const $buttons = $(".bot-section-btn");
    if ($buttons.length === 0) return true; 
    let allDisabled = true;
    $buttons.each(function () {
        if (!$(this).prop("disabled")) {
            allDisabled = false;
            return false;
        }
    });
    return allDisabled;
};

apz.app.CaIncomeDetails.viewIncomeDoc = function(pthis) {
    let documentId = $(pthis).parents('.uploadimg').attr('data-id');
    let docDetails = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.find(doc => parseInt(doc.appDocId) === parseInt(
        documentId));
    if (!apz.isObjectEmpty(docDetails)) {
        let fileName = docDetails?.payload?.documentFileName;
        let callBackFn = apz.app.CaIncomeDetails.viewIncomeDocCB;
        window.ImageLocationDetails = {
            latitude: docDetails?.payload?.latitude || "",
            longitude: docDetails?.payload?.longitude || "",
            uploadedTs: docDetails?.payload?.uploadedTs || "",
            documentFileName: docDetails?.payload?.documentFileName || ""
        };
        ApzCOB.downloadFileFromServer(fileName, callBackFn);
    }
}
apz.app.CaIncomeDetails.viewIncomeDocCB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.base64)) {
        $(`#${CaIncomeDetailsScrId}imgView`).attr('src', 'data:image/png;base64,' + params.base64);
        let id = `#${CaIncomeDetailsScrId}imgView`;
        if (Object.keys(window.ImageLocationDetails).length > 0) {
            apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
        }
        ApzCOB.toggleModal(`${CaIncomeDetailsScrId}viewUploadedModal`);
    } else {
        ApzCOB.fnDisplayMsg("Document is not available")
    }
}
apz.app.CaIncomeDetails.deleteIncomeDoc = function(pthis) {
    let fullId = pthis.id;
    let parts = fullId.split("__")[2].split("_");
    imgNumber = parts[0];
    if (parts[1] === "1" || parts[1] === "2" || parts[1] === "3" || parts[1] === "4" || parts[1] === "5") {
        TempImageObject.index = parts[1];
    } else {
        if (parts[2] === "Co") {
            TempImageObject.index = "Co-Applicant"
        } else {
            TempImageObject.index = "Applicant";
        }
    }
    let documentId = $(pthis).parents('.uploadimg').attr('data-id');
    if (!apz.isNull(documentId)) {
        let popUpObj = {};
        popUpObj.text = "Do you want to delete this document?";
        popUpObj.Btn1 = {
            "text": "Yes",
            "onClick": `apz.app.CaIncomeDetails.deleteDocumentCnfm(${documentId})`
        }
        popUpObj.Btn2 = {
            "text": "No",
            "onClick": "apz.app.Cabase.closeCnfmMdl()"
        }
        ApzCOB.showRpcModals(popUpObj, "confirmation");
    }
}
apz.app.CaIncomeDetails.deleteDocumentCnfm = function(docId) {
    let callBackFn = apz.app.CaIncomeDetails.deleteDocumentCnfmCB;
    ApzCOB.deleteDocument('', '', '', docId, callBackFn)
}
apz.app.CaIncomeDetails.deleteDocumentCnfmCB = function(params) {
    apz.stopLoader();
    let docType;
    try {
        const isSuccess = ApzCOB.handleServiceCallBacks(params);
        const modalOptions = {
            text: isSuccess ? "Document Deleted.!" : "Document Delete Failed.!",
            Btn1: {
                text: "OK",
                onClick: isSuccess ? "apz.app.Cabase.closeDeleteSuccModal()" : "apz.app.Cabase.closeDeleteErrModal()"
            }
        };
        apz.app.Cabase.closeCnfmMdl();
        if (isSuccess && params.res.APZCBO__DeleteDocument_Res.apiResponse.ResponseBody.responseObj === 'Success') {
            let deletedDocId = params?.req?.apiRequest?.requestObj?.appDocId || "";
            let documentArray = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
            docType = documentArray.find(item => {
                if (item.appDocId === deletedDocId) {
                    return item.payload.documentType;
                }
            })
            if (docType) {
                custTypeIncomeDtls = docType.payload.custType;
            }
            if (!apz.isNull(deletedDocId) && documentArray.length > 0) {
                let updatedDocs = documentArray.filter(item => Number(item.appDocId) !== Number(deletedDocId));
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = [];
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = structuredClone(updatedDocs);
            }
        }
        TempImageObject.Type = docType.payload.documentType.split(" Doc")[0];
        apz.app.CaIncomeDetails.paintDocumentName(docType.payload.documentType)
        apz.app.CaIncomeDetails.enableBotButton(docType.documentType, TemIpmageObject.custTypeIncomeDtls, "Delete");
        ApzCOB.showRpcModals(modalOptions, isSuccess ? "Success" : "Error");
    } catch (e) {
        ApzCOB.showRpcModals({
            text: technicalErrMsg,
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeDeleteErrModal()"
            }
        }, "Error");
    }
}
