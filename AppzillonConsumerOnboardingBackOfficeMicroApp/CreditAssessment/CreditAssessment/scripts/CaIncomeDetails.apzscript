apz.app.CaIncomeDetails.RentalincomeValidation = function() {
    const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__Rentalincome_Owned input[type="radio"]:checked');
    if (checkboxes.length === 0) {
        ApzCOB.fnDisplayMsg("Please select the Rental income Earned by", "E");
        return false;
    } else {
        Type = checkboxes[0].value;
        let AllDetailsAdded = false;
        switch (Type) {
            case 'Applicant':
                AllDetailsAdded = apz.app.CaIncomeDetails.RentalincomeValidateApplicant();
                break;
            case 'Co-Applicant':
                AllDetailsAdded = apz.app.CaIncomeDetails.RentalincomeValidateCoApplicant("OnlyCo");
                break;
            case 'Both':
                AllDetailsAdded = apz.app.CaIncomeDetails.RentalincomeValidateApplicant();
                AllDetailsAdded = AllDetailsAdded ? apz.app.CaIncomeDetails.RentalincomeValidateCoApplicant() : false;
                break;
            default:
                // Fallback for other types or if nothing selected
                ApzCOB.fnDisplayMsg("Please select a valid Rental income Type before proceeding.", "E");
                break;
        }
        return AllDetailsAdded;
    }
};
apz.app.CaIncomeDetails.RentalincomeValidateApplicant = function() {
    var Dairyform = $("#" + CaIncomeDetailsScrId + "Rentalincome").find("input"),
        Dairyform_validator_check = {
            CrdAss__CaIncomeDetails__RentalIncomeMonth_App: {
                verify: nullcheck,
                message: "LIT_RENTAL_INCOME_APP",
            }
        };
    var AllDropdowns = [{
        id: CaIncomeDetailsScrId + "BuildType_App",
        errorMsg: "Please select the Applicant building type before proceed"
    }];
    var fields = ['RentalIncomeMonth_App', 'BuildType_App', 'ConsideredRentalIncome_App']
    if (apz.app.CaIncomeDetails.ValidateRentalincomeFields(fields, 'App') && apz.app.CaIncomeDetails.validateDocs(
            "CrdAss__CaIncomeDetails__Rentalincome_App_ParentBusRow_Agg", "rentAppImg")) {
