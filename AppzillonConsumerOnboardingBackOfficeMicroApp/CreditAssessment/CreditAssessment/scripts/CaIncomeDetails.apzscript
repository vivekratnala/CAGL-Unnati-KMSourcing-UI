apz.app.CaIncomeDetails.PaintDetailsOther = function(Obj, type) {
    let inputIds = ["O_NameOfOrg", "O_OthLineOfBus", "O_SalesPerDay", "O_NoOfOp", "O_OpeEx", "O_RentLease", "O_NoOfEmp", "O_SalPaidMon",
        "O_TransComm", "O_WaterBill", "O_EleBill", "O_BillGas", "O_TeleGas", "O_Others", "O_OtherExp"
    ]
    let inputIdVal = ["nameOfOrganization", "lineOfOtherBusiness", "salesPerDay", "numberOfOperatingDays", "operatingExpense", "rentOrLease",
        "numberOfEmployees", "salaryPaidPerMonth", "transportAndCommunication", "waterBill", "electricityBill", "gasBill", "telephoneBill",
        "otherBills", "otherBusinessExpense"
    ]
    for (let i = 0; i < inputIds.length; i++) {
        const inputElement = document.getElementById(CaIncomeDetailsScrId + inputIds[i]);
        if (inputElement) {
            inputElement.value = Obj[inputIdVal[i]]; // Update the value
        }
    }
    let AmountIds = ["O_MonthSal", "O_GrossInc", "O_TotalSal", "O_TotalUti", "O_TotalBus", "O_NetBusInc"]
    let Amountvalues = ["monthlySales", "grossIncome", "totalSalary", "totalUtilities", "totalBusinessExpenses", "netBusinessIncome"]
    for (let i = 0; i < AmountIds.length; i++) {
        const inputElement = document.getElementById(CaIncomeDetailsScrId + AmountIds[i]);
        if (inputElement) {
            inputElement.value = Obj[Amountvalues[i]]; // Update the value
        }
    }
    let DropDownIds = ["O_OthTen", "O_TypeOfBus", "O_OthLineOfBus_drop"];
    let DropDownIdVal = ["otherBusinessTenure", "otherBusinessType", "lineOfOtherBusiness"];
    for (let j = 0; j < DropDownIds.length; j++) {
        //const inputElement = document.getElementById(CaIncomeDetailsScrId + DropDownIds[j]);
        let lvalue = Obj[DropDownIdVal[j]];
        if (DropDownIds[j] === "O_OthLineOfBus_drop") {
            let matchedItem = gLovs.find(item => item.lovName === "BUSINESS_PURPOSE");
            let businessPurposeData = JSON.parse(matchedItem.lovDtls)?.BUSINESS_PURPOSE;
            let caOtherBusinessDataArr = businessPurposeData.filter(item => item.CAType == "Other");
            let caOtherBusinessData = caOtherBusinessDataArr.map(item => item.subPurpose);
            if (!caOtherBusinessData.contains(lvalue)) {
                lvalue = "Others";
                $("#CrdAss__CaIncomeDetails__OtherLineBusReasonRow").removeClass('sno');
            }
        }
        $('#' + CaIncomeDetailsScrId + DropDownIds[j]).val(lvalue);
    }
    apz.app.CaIncomeDetails.DisableInpModal(type, "O_Bus_Pre", "OwnOther", "OwnRowOth", Obj);
    $(".O-Edit").removeClass("sno");
    $("#" + CaIncomeDetailsScrId + "OtherButtonSave").addClass("sno");
}
apz.app.CaIncomeDetails.DisableInpModal = function(type, Main, Sec, Row, Obj) {
    var bussnessType = type.charAt(0).toUpperCase() + type.slice(1)
    const form = document.getElementById(CaIncomeDetailsScrId + bussnessType + "_content");
    if (form) {
        const elements = form.querySelectorAll("input, select, textarea, button");
        elements.forEach(el => {
            el.disabled = true;
            if (el.parentElement && el.parentElement.id.includes("_ext")) {
                // For select elements, add class from parent
                el.parentElement.classList.add("select-disabled");
            } else {
                // For other elements, add the disable class from the element itself
                el.classList.add("disabled");
            }
        });
    }
    if (Obj.Bus_Pre_same_Res == "No") {
        document.getElementById(CaIncomeDetailsScrId + Main + "_option_No").checked = true;
        document.getElementById(CaIncomeDetailsScrId + Main + "_option_Yes").checked = false;
        $("#" + CaIncomeDetailsScrId + Row).removeClass("sno");
        if (Obj.Bus_Pre_OwnOrRen == "Rented") {
            document.getElementById(CaIncomeDetailsScrId + Sec + "_option_Owned").checked = false;
            document.getElementById(CaIncomeDetailsScrId + Sec + "_option_Rented").checked = true;
        } else {
            document.getElementById(CaIncomeDetailsScrId + Sec + "_option_Owned").checked = true;
            document.getElementById(CaIncomeDetailsScrId + Sec + "_option_Rented").checked = false;
        }
    } else {
        document.getElementById(CaIncomeDetailsScrId + Main + "_option_No").checked = false
        document.getElementById(CaIncomeDetailsScrId + Main + "_option_Yes").checked = true
        $("#" + CaIncomeDetailsScrId + Row).addClass("sno");
        document.getElementById(CaIncomeDetailsScrId + Sec + "_option_Owned").checked = true;
        document.getElementById(CaIncomeDetailsScrId + Sec + "_option_Rented").checked = false;
    }
}
apz.app.CaIncomeDetails.EditModal = function() {
    if (IncomeassEdit.Flag) {
        EditType = IncomeassEdit.type;
    }
    const ignoreIds = ["O_MonthSal", "O_GrossInc", "O_TotalSal", "O_TotalUti", "O_TotalBus", "O_NetBusInc"];
    EditType = EditType.charAt(0).toUpperCase() + EditType.slice(1);
    const form = document.getElementById(CaIncomeDetailsScrId + EditType + "_content");
    if (form) {
        const elements = form.querySelectorAll("input, select, textarea, button");
        elements.forEach(el => {
            if (!ignoreIds.includes(el.id.split("__")[2])) {
                el.disabled = false;
                if (el.parentElement && el.parentElement.id.includes("_ext")) {
                    // For select elements, add class from parent
                    el.parentElement.classList.remove("select-disabled");
                } else {
                    // For other elements, add the disable class from the element itself
                    el.classList.remove("disabled");
                }
            }
        });
    }
    IsEditFlow = true;
    if (EditType === "Dairy") {
        if ($("#" + CaIncomeDetailsScrId + "B_BCow_2").is(":visible")) {
            $("#" + CaIncomeDetailsScrId + "AddMore_Cow").attr("disabled", true);
        } else {
            $("#" + CaIncomeDetailsScrId + "AddMore_Cow").attr("disabled", false);
        }
        if ($("#" + CaIncomeDetailsScrId + "NoOfBef_4").is(":visible")) {
            $("#" + CaIncomeDetailsScrId + "AddMore_Bef").attr("disabled", true);
        } else {
            $("#" + CaIncomeDetailsScrId + "AddMore_Bef").attr("disabled", false);
        }
        $(".EditDa").addClass("sno");
        $(".CalDet").addClass("sno");
        $("#" + CaIncomeDetailsScrId + "SaveBtn").removeClass("sno");
    } else if (EditType === "Kirana") {
        $(".K-Edit").addClass("sno");
        $(".K-CalDet").addClass("sno");
        $("#" + CaIncomeDetailsScrId + "KSaveBtn").removeClass("sno");
    } else if (EditType === "Tailoring") {
        $(".T-Edit").addClass("sno");
        $(".T-CalDet").addClass("sno");
        $("#" + CaIncomeDetailsScrId + "T_Save").removeClass("sno");
    } else if (EditType === "Other") {
        $(".O-Edit").addClass("sno");
        $("#" + CaIncomeDetailsScrId + "OtherButtonSave").removeClass("sno");
    }
    if (IncomeassEdit.Flag) {
        IncomeassEdit = {
            type: "",
            Flag: false
        };
        IsEditFlow = false;
    }
}
apz.app.CaIncomeDetails.launchModal = function(Pthis) {
    var id, ownedBy;
    var Count = Pthis.id.split("_")[4];
    saveBtnBusinessNo = Count;
    // if ($('#CrdAss__CaIncomeDetails__' + Count + '_businessOwnedByOption_option_Applicant').prop('checked')) {
    //     ownedBy = 'Applicant'
    // } else if ($('#CrdAss__CaIncomeDetails__' + Count + '_businessOwnedByOption_option_Co-Applicant').prop('checked')) {
    //     ownedBy = 'Co-Applicant'
    // } else if ($('#CrdAss__CaIncomeDetails__' + Count + '_businessOwnedByOption_option_Both').prop('checked')) {
    //     ownedBy = 'Both'
    // }
    const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__' + Count + '_businessTypeOption input[type="radio"]:checked');
    var Type = checkboxes[0].id.split("_")[7];
    apz.app.CaIncomeDetails.paintOwnedBy(Type, Count)
    Count = Count - 1;
    if (selectedBusinessType === 'Dairy') {
        id = 'dairy'
    } else {
        id = selectedBusinessType;
    }
    if (FinalvaluesArr[id].length > Count) {
        IsEditFlow = true;
        EditIndex = Count + 1;
    }
    selectedBusinessType = Type;
    // if (selectedBusinessType === 'Dairy') {
    //     $('#CrdAss__CaIncomeDetails__Dairy_Bus_Type').text('Dairy business - ' + ownedBy)
    // } else if (selectedBusinessType === 'Kirana') {
    //     $('#CrdAss__CaIncomeDetails__Kirana_Bus_Type').text('Kirana business - ' + ownedBy)
    // } else if (selectedBusinessType === 'Tailoring') {
    //     $('#CrdAss__CaIncomeDetails__Tail_Bus_Type').text('Tailoring business - ' + ownedBy)
    // } else if (selectedBusinessType === 'Other') {
    //     $('#CrdAss__CaIncomeDetails__Other_Bus_Type').text('Other business - ' + ownedBy)
    // }
    ApzCOB.toggleModal(`${CaIncomeDetailsScrId}${selectedBusinessType}`);
    switch (selectedBusinessType) {
        case 'Dairy':
            // Dairy-specific logic
            apz.app.CaIncomeDetails.Dairy();
            break;
        case 'Kirana':
            // Kirana-specific logic
            apz.app.CaIncomeDetails.Kirana();
            break;
        case 'Tailoring':
            // Tailoring-specific logic
            apz.app.CaIncomeDetails.Tailoring();
            break;
        case 'Other':
            // Other-specific logic
            apz.app.CaIncomeDetails.Other();
            break;
        default:
            // Fallback for other types or if nothing selected
            ApzCOB.fnDisplayMsg("Please select a valid Business Type before proceeding.", "E");
            break;
    }
    apz.app.CaIncomeDetails.ClearTheInputFields();
    $("#" + CaIncomeDetailsScrId + "OwnRowOth").addClass("sno");
    $("#" + CaIncomeDetailsScrId + "isOwnedKirana").addClass("sno");
    $("#" + CaIncomeDetailsScrId + "isOwned").addClass("sno");
    $("#" + CaIncomeDetailsScrId + "isOwnedTail").addClass("sno");
    const closeButtonIds = [CaIncomeDetailsScrId + "Dairy_close", CaIncomeDetailsScrId + "Tailoring_close",
        CaIncomeDetailsScrId + "Kirana_close", CaIncomeDetailsScrId + "Other_close"
    ];
    closeButtonIds.forEach(id => {
        const element = document.getElementById(id);
        if (element) {
            element.addEventListener("click", function() {
                IsEditFlow = false;
            });
        }
    });
    $(".EditDa").addClass("sno");
    $(".CalDet").addClass("sno");
    $(".T-CalDet").addClass("sno");
    $(".K-CalDet").addClass("sno");
    $("#" + CaIncomeDetailsScrId + "SaveBtn").removeClass("sno");
    $(".O-Edit").addClass("sno");
    $("#" + CaIncomeDetailsScrId + "OtherButtonSave").removeClass("sno");
    $(".K-Edit").addClass("sno");
    $("#" + CaIncomeDetailsScrId + "KSaveBtn").removeClass("sno");
    $(".T-Edit").addClass("sno");
    $("#" + CaIncomeDetailsScrId + "T_Save").removeClass("sno");
    const ignoreIds = ["O_MonthSal", "O_GrossInc", "O_TotalSal", "O_TotalUti", "O_TotalBus", "O_NetBusInc"]
    const form = document.getElementById(CaIncomeDetailsScrId + selectedBusinessType + "_content");
    if (form) {
        const elements = form.querySelectorAll("input, select, textarea, button");
        elements.forEach(el => {
            if (!ignoreIds.includes(el.id.split("__")[2])) {
                el.disabled = false;
                if (el.parentElement && el.parentElement.id.includes("_ext")) {
                    // For select elements, add class from parent
                    el.parentElement.classList.remove("select-disabled");
                } else {
                    // For other elements, add the disable class from the element itself
                    el.classList.remove("disabled");
                }
            }
        });
    }
};
apz.app.CaIncomeDetails.Other = function() {
    apz.app.CaIncomeDetails.populateDropdown(OtherTypeOfBussiness, CaIncomeDetailsScrId + "O_TypeOfBus");
    apz.app.CaIncomeDetails.populateDropdown(OtherbusinessTenure, CaIncomeDetailsScrId + "O_OthTen");
    let businessPurposeData = [];
    let caOtherBusinessData = ["Please Select"];
    let subpurposeData = [];
    let matchedItem = gLovs.find(item => item.lovName === "BUSINESS_PURPOSE");
    if (matchedItem) {
        let businessPurposeData = JSON.parse(matchedItem.lovDtls)?.BUSINESS_PURPOSE;
        caOtherBusinessDataArr = businessPurposeData.filter(item => item.CAType == "Other");
        subpurposeData = caOtherBusinessDataArr.map(item => item.subPurpose);
    }
    caOtherBusinessData = [...caOtherBusinessData, ...subpurposeData]
    /*if (!caOtherBusinessData.includes("Others")) {
        caOtherBusinessData.push("Others");
    }*/ //Prod enhancement
    apz.app.CaIncomeDetails.populateDropdown(caOtherBusinessData, CaIncomeDetailsScrId + "O_OthLineOfBus_drop");
    document.getElementById(CaIncomeDetailsScrId + "O_Bus_Pre_option_Yes").checked = true;
};
apz.app.CaIncomeDetails.ConvertToInt = function(Value) {
    return Value === "" ? 0 : parseInt(ApzCOB.fn_unFormatAmount(Value))
};
apz.app.CaIncomeDetails.GrossIncome = function() {
    let Opex = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_OpeEx").val());
    let NoOfOp = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_MonthSal").val());
    if (Opex > NoOfOp) {
        ApzCOB.fnDisplayMsg("Please enter the valid amount Operating expenses (Per month) can not more than Monthly sales", "E");
        $("#" + CaIncomeDetailsScrId + "O_GrossInc").val('');
        $("#" + CaIncomeDetailsScrId + "O_OpeEx").val('');
    } else {
        $("#" + CaIncomeDetailsScrId + "O_GrossInc").val(NoOfOp - Opex);
    }
};
apz.app.CaIncomeDetails.CalculateStandDetails = function() {
    let SalesPerDay = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_SalesPerDay").val());
    let NoOfOp = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_NoOfOp").val());
    if (!apz.isNull(SalesPerDay) && !apz.isNull(NoOfOp)) {
        $("#" + CaIncomeDetailsScrId + "O_MonthSal").val(SalesPerDay * NoOfOp);
    }
    if (!apz.isNull($("#" + CaIncomeDetailsScrId + "O_OpeEx").val())) {
        let Sal = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_MonthSal").val());
        let Opex = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_OpeEx").val());
        $("#" + CaIncomeDetailsScrId + "O_GrossInc").val(Sal - Opex);
    }
};
apz.app.CaIncomeDetails.CalculateEmpDetails = function() {
    let SalesPerDay = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_NoOfEmp").val());
    let NoOfOp = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_SalPaidMon").val());
    if (!apz.isNull(SalesPerDay) && !apz.isNull(NoOfOp)) {
        $("#" + CaIncomeDetailsScrId + "O_TotalSal").val(SalesPerDay * NoOfOp);
    }
}
apz.app.CaIncomeDetails.CalculateUitilityDetails = function() {
    let SalesPerDay = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_TransComm").val());
    let WaterBill = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_WaterBill").val());
    let EleBill = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_EleBill").val());
    let GasBill = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_BillGas").val());
    let TellBill = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_TeleGas").val());
    let Othr = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_Others").val());
    if (!apz.isNull(SalesPerDay) || !apz.isNull(WaterBill) || !apz.isNull(EleBill) || !apz.isNull(GasBill) || !apz.isNull(TellBill) || !apz
        .isNull(Othr)) {
        $("#" + CaIncomeDetailsScrId + "O_TotalUti").val(SalesPerDay + WaterBill + EleBill + GasBill + TellBill + Othr);
    }
}
apz.app.CaIncomeDetails.CalculateTotalExDetails = function() {
    let SalesPerDay = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_RentLease").val());
    let WaterBill = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_TotalSal").val());
    let EleBill = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_TotalUti").val());
    let GasBill = apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_OtherExp").val());
    if (!apz.isNull(SalesPerDay) || !apz.isNull(WaterBill) || !apz.isNull(EleBill) || !apz.isNull(GasBill)) {
        $("#" + CaIncomeDetailsScrId + "O_TotalBus").val(SalesPerDay + WaterBill + EleBill + GasBill);
        var grossIncome = parseInt($("#" + CaIncomeDetailsScrId + "O_GrossInc").val());
        var totalBusiness = parseInt($("#" + CaIncomeDetailsScrId + "O_TotalBus").val())
        $("#" + CaIncomeDetailsScrId + "O_NetBusInc").val(grossIncome - totalBusiness)
    }
}
