                    totalWagePerMonth: $('#' + CaIncomeDetailsScrId + 'ToTalWagePerMonth_' + k).val(),
                    selfDeclaredWage: $('#' + CaIncomeDetailsScrId + 'DeclaredWages_' + k).val(),
