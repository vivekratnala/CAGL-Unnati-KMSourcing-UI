                yearTenure: $('#' + CaIncomeDetailsScrId + 'TenOfEmpCoSal').val(),
                natureOfEmployment: $('#' + CaIncomeDetailsScrId + 'NatureOfEmp_SalCo').val(),
                netSalary: (($('#' + CaIncomeDetailsScrId + 'NetSalCo').val()).split('.')[0]).replace(/[.,]/g, ''),
                modeOfSalary: $('#' + CaIncomeDetailsScrId + 'ModeOfSalCo').val()
            };
        }
    }
    return valid;
}
