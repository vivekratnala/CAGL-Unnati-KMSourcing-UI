apz.app.CaIncomeDetails.ValidateRentalincomeFields = function(fields, val) {
    var type = val;
    var mandFieldsDd = fields;
    var valid = true;
    mandFieldsDd.forEach(function(field) {
        if ($('#' + CaIncomeDetailsScrId + field).val() === "" || $('#' + CaIncomeDetailsScrId + field).val() === "Please Select") {
            valid = false;
            $('#' + CaIncomeDetailsScrId + field + 'ErrorDiv').removeClass('sno');
            //$(`#${k}ErrorDiv`).removeClass('sno');
        }
    })
    if (valid) {
        rentalStoreData = {}
        if (type === 'App') {
            rentalStoreData = {
                monthlyRentalIncome: (($('#' + CaIncomeDetailsScrId + 'RentalIncomeMonth_App').val()).split('.')[0]).replace(/[.,]/g, ''),
                buildingType: $('#' + CaIncomeDetailsScrId + 'BuildType_App').val(),
                consideredMonthlyIncome: parseInt($(`#${CaIncomeDetailsScrId}ConsideredRentalIncome_App`).val())
            };
        } else if (type === 'CoApp') {
            rentalStoreData = {
                monthlyRentalIncome: (($('#' + CaIncomeDetailsScrId + 'RentalIncomeMonth_Co').val()).split('.')[0]).replace(/[.,]/g, ''),
                buildingType: $('#' + CaIncomeDetailsScrId + 'BuildType_Co').val(),
                consideredMonthlyIncome: parseInt($(`#${CaIncomeDetailsScrId}ConsideredRentalIncome_CoApp`).val())
            };
        }
    }
    return valid;
}
