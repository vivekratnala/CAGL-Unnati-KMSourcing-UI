        $("#" + CaIncomeDetailsScrId + "AddMore_Bef").attr("disabled", true);
    } else {
        ApzCOB.fnDisplayMsg("Please select the Breed of buffalo before proceed", "E");
    }
}
apz.app.CaIncomeDetails.populateDropdown = function(allOptions, Id) {
    let TempArr = [];
    for (i = 0; i < allOptions.length; i++) {
        let obj = {
            "desc": allOptions[i],
            "val": allOptions[i]
        };
        TempArr.push(obj);
    }
    apz.populateDropdown(document.getElementById(Id), TempArr);
};
apz.app.CaIncomeDetails.ClearTheInputFields = function() {
    // Array of input field IDs
    var inputIds;
    switch (selectedBusinessType) {
        case 'Dairy':
            // Dairy-specific logic
            inputIds = ['NetInp', 'NameOfOrg']; // Example IDs
            break;
        case 'Kirana':
            // Kirana-specific logic
            inputIds = ['K_Areaofshop', 'K_AreaGod', 'K_NameofOrg', 'K_Net']; // Example IDs
            break;
        case 'Tailoring':
            // Tailoring-specific logic
            inputIds = ['T_NameofOrg', 'T_NetMon']; // Example IDs
            break;
        case 'Other':
            // Other-specific logic
            inputIds = ['O_NameOfOrg', 'O_OthLineOfBus', 'O_SalesPerDay', 'O_NoOfOp', 'O_OpeEx', 'O_OthLineOfBus', 'O_RentLease', 'O_NoOfEmp',
                'O_SalPaidMon', "O_TransComm", "O_WaterBill", "O_EleBill", "O_BillGas", "O_TeleGas", "O_Others", "O_OtherExp", "O_NetBusInc",
                "O_TotalBus", "O_TotalUti", "O_TotalSal", "O_GrossInc", "O_MonthSal"
            ]; // Example IDs
            break;
        default:
            // Fallback for other types or if nothing selected
            inputIds = []; // Example IDs
            break;
    }
    // Loop through the array and clear the value of each input field
    for (let i = 0; i < inputIds.length; i++) {
        const inputElement = document.getElementById(CaIncomeDetailsScrId + inputIds[i]);
        if (inputElement) {
            inputElement.value = ''; // Clear value
        }
    }
}
apz.app.CaIncomeDetails.OnclickSave = function() {
    if ($(".CalDet").is(":visible")) {
        apz.app.CaIncomeDetails.StoreDairy();
        IncomeassEdit = {
            type: "",
            Flag: false
        };
    } else {
        var Dairyform = $("#" + CaIncomeDetailsScrId + "DairyForm").find("input"),
            Dairyform_validator_check = {
                CrdAss__CaIncomeDetails__NetInp: {
                    verify: nullcheck,
                    message: "LIT_ENTER_MONTH_INC",
                },
                CrdAss__CaIncomeDetails__NameOfOrg: {
                    verify: nullcheck,
                    message: "LIT_ENTER_NAME_ORG",
                },
            };
        var AllDropdowns = [
            // All Default
            {
                id: CaIncomeDetailsScrId + "B_loc",
                errorMsg: "Please select the Business location before proceed"
            }, {
                id: CaIncomeDetailsScrId + "B_ten",
                errorMsg: "Please select the Business tenure before proceed"
            }, {
                id: CaIncomeDetailsScrId + "TypesofBus",
                errorMsg: "Please select the Types of Business before proceed"
            },
            // Cows
            {
                id: CaIncomeDetailsScrId + "B_BCow",
                errorMsg: "Please select the Breed of Cow before proceed"
            }, {
                id: CaIncomeDetailsScrId + "B_BCow_1",
                errorMsg: "Please select the Breed of Cow before proceed"
            }, {
                id: CaIncomeDetailsScrId + "B_BCow_2",
                errorMsg: "Please select the Breed of Cow before proceed"
            }, {
                id: CaIncomeDetailsScrId + "B_Noofcow",
                errorMsg: "Please select the No of Cows before proceed"
            }, {
                id: CaIncomeDetailsScrId + "B_Noofcow_1",
                errorMsg: "Please select the No of Cows before proceed"
            }, {
                id: CaIncomeDetailsScrId + "B_Noofcow_2",
                errorMsg: "Please select the No of Cows before proceed"
            },
            // Buffaloes
            {
                id: CaIncomeDetailsScrId + "BreedofBef",
                errorMsg: "Please select the Breed of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "BreedofBef_1",
                errorMsg: "Please select the Breed of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "BreedofBef_2",
                errorMsg: "Please select the Breed of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "BreedofBef_3",
                errorMsg: "Please select the Breed of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "BreedofBef_4",
                errorMsg: "Please select the Breed of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "NoOfBef",
                errorMsg: "Please select the No of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "NoOfBef_1",
                errorMsg: "Please select the No of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "NoOfBef_2",
                errorMsg: "Please select the No of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "NoOfBef_3",
                errorMsg: "Please select the No of Buffalo before proceed"
            }, {
                id: CaIncomeDetailsScrId + "NoOfBef_4",
                errorMsg: "Please select the No of Buffalo before proceed"
            }
        ];
        if (apz.app.CaIncomeDetails.ValidateDropDown(AllDropdowns, "dairy") && apz.app.CaIncomeDetails.validateInputFields(Dairyform,
                Dairyform_validator_check, "dairy")) {
            let Radioval = apz.app.CaIncomeDetails.ValidateRadioButton("SameasRes", "BussinessPremise", "dairy");
            //AllValues.dairy.push(Radioval);
            // Calculate total cows
            let totalCows = 0;
            let AllObj = Object.assign({}, ...AllValues.dairy);
            Object.keys(AllObj).forEach(key => {
                if (key.startsWith('noOfCowBreed')) {
                    const value = parseInt(AllObj[key]);
                    if (!isNaN(value)) {
                        totalCows += value;
                    }
                }
            });
            // Calculate total buffalos
            let totalBuffalos = 0;
            Object.keys(AllObj).forEach(key => {
                if (key.startsWith('noOfBuffaloBreed')) {
                    const value = parseInt(AllObj[key]);
                    if (!isNaN(value)) {
                        totalBuffalos += value;
                    }
                }
            });
            let totalCowsAndBuffalos = totalCows + totalBuffalos;
            let ID = ["totalBuffalos", "totalCows", "totalCowsAndBuffalos"];
            let value = [totalBuffalos, totalCows, totalCowsAndBuffalos];
            for (let i = 0; i < ID.length; i++) {
                let obj = {
                    [ID[i]]: value[i]
                }
                AllValues.dairy.push(obj);
            }
            apz.app.CaIncomeDetails.IncomeAssessmentCheck("Dairy");
        }
    }
}
apz.app.CaIncomeDetails.StoreDairy = function() {
    let incomeValue = AllValues?.dairy?.find(item => item?.IncomeAssessmentChecknetBusinessIncome !== undefined)?.IncomeAssessmentChecknetBusinessIncome;
        if (parseInt(incomeValue) === 0) {
            // AllValues.dairy = [];
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_BUSINESS_ZERO_NOT_ALLOWED"), "E");
            return;
        }
    //let FinalIndex = IsEditFlow === true ? EditIndex : numberOfBusinessCount;
    let FinalIndex = saveBtnBusinessNo;
    $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessTypeSec").removeClass("sno");
    $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessImgSec").removeClass("sno");
    $("#" + CaIncomeDetailsScrId + FinalIndex + "_addBusinessDetails_ul").addClass("sno");
    if (IsEditFlow) {
        let FinalIn = EditIndex - 1;
        FinalvaluesArr.dairy[FinalIn] = Object.assign({}, ...AllValues.dairy);
        AllValues.dairy = Array.isArray(AllValues.dairy) ? Object.assign({}, ...AllValues.dairy) : AllValues.dairy;
        //AllValues.dairy = Object.assign({}, ...AllValues.dairy);
        IsEditFlow = false;
    } else {
        // AllValues.dairy = Object.assign({}, ...AllValues.dairy);
        AllValues.dairy = Array.isArray(AllValues.dairy) ? Object.assign({}, ...AllValues.dairy) : AllValues.dairy;
        FinalvaluesArr.dairy.push(AllValues.dairy);
    }
    var index = FinalvaluesArr.dairy.length;
    if ($('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessOwnedByOption_option_Applicant').prop('checked')) {
        FinalvaluesArr.dairy[index - 1].DairyType = 'Applicant'
    } else if ($('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessOwnedByOption_option_Co-Applicant').prop('checked')) {
        FinalvaluesArr.dairy[index - 1].DairyType = 'Co-Applicant'
    } else if ($('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessOwnedByOption_option_Both').prop('checked')) {
        FinalvaluesArr.dairy[index - 1].DairyType = 'Both'
    }
    $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessLbl1_grp_lbl").text("Total No of Cows / Buffalo");
    $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessLbl1").val(AllValues.dairy.totalCowsAndBuffalos);
    $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessLbl2").val(AllValues.dairy.IncomeAssessmentChecknetBusinessIncome);
    $("#" + CaIncomeDetailsScrId + FinalIndex + "_viewBusinessDetails_ul").removeClass("sno");
    $("#" + CaIncomeDetailsScrId + FinalIndex + "_DeleteIcon_ul").removeClass("sno");
    if (selectedBusinessType === '') {
        selectedBusinessType = 'Dairy';
    }
    ApzCOB.toggleModal(`${CaIncomeDetailsScrId}${'Dairy'}`);
    apz.app.CaIncomeDetails.disableDeleteButtons();
    apz.app.CaIncomeDetails.getSelectedBusinessTypes();
    $('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessOwnedByOption input[type="radio"]').prop('disabled', true);
    $('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessTypeOption input[type="radio"]').prop('disabled', true);
}
