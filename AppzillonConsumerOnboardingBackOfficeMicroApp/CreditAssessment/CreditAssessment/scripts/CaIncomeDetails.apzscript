            "grossIncome": apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_GrossInc").val()),
            "totalSalary": apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_TotalSal").val()),
            "totalUtilities": apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_TotalUti").val()),
            "totalBusinessExpenses": apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_TotalBus").val()),
            "netBusinessIncome": apz.app.CaIncomeDetails.ConvertToInt($("#" + CaIncomeDetailsScrId + "O_NetBusInc").val())
        };
        var netIncome = $("#" + CaIncomeDetailsScrId + "O_NetBusInc").val();
        if (netIncome < 0) {
            ApzCOB.fnDisplayMsg("Net monthly income cannot be negative.", "E");
            return;
        }
        AllValues.Other.push(obj);
        let Radioval = apz.app.CaIncomeDetails.ValidateRadioButton("O_Bus_Pre", "OwnOther", "Other");
        AllValues.Other.push(Radioval);
        $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessTypeSec").removeClass("sno");
        $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessImgSec").removeClass("sno");
        $("#" + CaIncomeDetailsScrId + FinalIndex + "_addBusinessDetails_ul").addClass("sno");
        if (IsEditFlow) {
            let FinalIn = EditIndex - 1;
            FinalvaluesArr.Other[FinalIn] = Array.isArray(AllValues.Other) ? Object.assign({}, ...AllValues.Other) : AllValues.Other;
            AllValues.Other = Array.isArray(AllValues.Other) ? Object.assign({}, ...AllValues.Other) : AllValues.Other;
            IsEditFlow = false;
        } else {
            AllValues.Other = Array.isArray(AllValues.Other) ? Object.assign({}, ...AllValues.Other) : AllValues.Other;
            FinalvaluesArr.Other.push(AllValues.Other);
        }
        var index = FinalvaluesArr.Other.length;
        if ($('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessOwnedByOption_option_Applicant').prop('checked')) {
            FinalvaluesArr.Other[index - 1].otherType = 'Applicant'
        } else if ($('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessOwnedByOption_option_Co-Applicant').prop('checked')) {
            FinalvaluesArr.Other[index - 1].otherType = 'Co-Applicant'
        } else if ($('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessOwnedByOption_option_Both').prop('checked')) {
            FinalvaluesArr.Other[index - 1].otherType = 'Both'
        }
        $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessLbl1").val(AllValues.Other.lineOfOtherBusiness);
        $("#" + CaIncomeDetailsScrId + FinalIndex + "_businessLbl2").val(AllValues.Other.netBusinessIncome);
        $("#" + CaIncomeDetailsScrId + FinalIndex + "_viewBusinessDetails_ul").removeClass("sno");
        $("#" + CaIncomeDetailsScrId + FinalIndex + "_DeleteIcon_ul").removeClass("sno");
        ApzCOB.toggleModal(`${CaIncomeDetailsScrId}${'Other'}`);
        apz.app.CaIncomeDetails.disableDeleteButtons();
        apz.app.CaIncomeDetails.getSelectedBusinessTypes();
        $('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessOwnedByOption input[type="radio"]').prop('disabled', true);
        $('#CrdAss__CaIncomeDetails__' + FinalIndex + '_businessTypeOption input[type="radio"]').prop('disabled', true);
    }
}
apz.app.CaIncomeDetails.ValidateRadioButton = function(One, Two, type) {
    var obj;
    if (document.getElementById(CaIncomeDetailsScrId + [One] + "_option_No").checked) {
        obj = {
            "businessAddressSameAsResidance": "No",
            "businessPremiseOwnership": document.getElementById(CaIncomeDetailsScrId + [Two] + "_option_Owned").checked ? "Owned" : "Rented"
        }
        //AllValues.dairy.push(obj);
    } else {
        obj = {
            "businessAddressSameAsResidance": "Yes"
        }
        //AllValues.dairy.push(obj);
    }
    if (type === 'dairy') {
        AllValues.dairy.push(obj);
    } else if (type === 'Kirana') {
        AllValues.Kirana.push(obj);
    } else if (type === 'Tailoring') {
        const obj1 = {
            isApplicantATailor: document.getElementById(isApplTailorID +"option_Y")?.checked ? 'Y' : 'N'
        };
        const obj2 = {
            isCoApplicantPartOfTailorBusiness: document.getElementById(isCoAppPartID +"option_Y")?.checked ? 'Y' : 'N'
        };
        AllValues.Tailoring.push(obj, obj1, obj2);
    } else if (type === 'Other') {
        AllValues.Other.push(obj);
    }
}
apz.app.CaIncomeDetails.validateInputFields = function(form, list, type) {
    var errorCount = 0,
        val,
        element,
        n,
        i;
    var dairy = {
        'NameOfOrg': 'organizationName',
        'NetInp': 'netMonthlyIncome'
    }
    var kirana = {
        "K_AreaGod": "areaOfGodown",
        "K_Areaofshop": "areaofshop",
        "K_NameofOrg": "nameOfOrganization",
        "K_Net": "netMonthlyIncome"
    }
    var tailoring = {
        "T_NameofOrg": "organizationName",
        "T_NetMon": "netMonthlyIncome"
    }
    var other = {
        "O_BillGas": "gasBill",
        "O_EleBill": "electricityBill",
        "O_NameOfOrg": "nameOfOrganization",
        "O_NoOfEmp": "numberOfEmployees",
        "O_NoOfOp": "numberOfOperatingDays",
        "O_OpeEx": "operatingExpense",
        "O_OthLineOfBus": "lineOfOtherBusiness",
        "O_OtherExp": "otherBusinessExpense",
        "O_Others": "otherBills",
        "O_RentLease": "rentOrLease",
        "O_SalPaidMon": "salaryPaidPerMonth",
        "O_SalesPerDay": "salesPerDay",
        "O_TeleGas": "telephoneBill",
        "O_TransComm": "transportAndCommunication",
        "O_WaterBill": "waterBill"
    }
    for (i = 0; i < form.length; i++) {
        element = form[i];
        n = ApzCOB.getValueForInput(element, n);
        if (list[n] && list[n].verify) {
            ApzCOB.valid(element, list[n].verify);
            if (err) {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode(list[n].message), "E");
                errorCount++;
                return false;
            } else {
                var id = element.id.split("__")[2];
                let key;
                if (type === 'dairy') {
                    key = dairy[id]
                } else if (type === 'Kirana') {
                    key = kirana[id]
                } else if (type === 'Tailoring') {
                    key = tailoring[id]
                } else if (type === 'Other') {
                    key = other[id]
                }
                if (list[n].Type) {
                    let obj = {
                        [list[n].Type]: {
                            [key]: element.value
                        }
                    };
                    AllValues[type].push(obj);
                } else {
                    if (['areaofshop', 'areaOfGodown', 'netMonthlyIncome'].includes(key)) {
                        val = element.value.replace(/,/g, '');
                        if (key === 'areaofshop' || key === 'areaOfGodown') {
                            val = parseFloat(val);
                        }
                    } else {
                        val = element.value
                    }
                    let obj = {
                        [key]: val
                    };
                    AllValues[type].push(obj);
                }
            }
        }
    }
    if (errorCount > 0) {
        return false;
    }
    return true;
}
apz.app.CaIncomeDetails.OnclickNext = function() {
    const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__sourceofincomesec input[type="CHECKBOX"]:checked');
    TypesSelected = [];
    checkboxes.forEach(checkbox => {
        TypesSelected.push(checkbox.id.split("_")[4])
    });
    if (checkboxes.length === 0) {
        ApzCOB.fnDisplayMsg("Please complete the Income Details section before proceeding further.", "E");
        return;
    }
    if (!TypesSelected.includes('businessTypeOption')) {
        ApzCOB.fnDisplayMsg("At least one applicant must own a business to proceed. Please add a business before continuing.", "E");
        return;
    }
    if (!apz.app.CaIncomeDetails.areAllBotButtonsClicked()) {
        ApzCOB.fnDisplayMsg("Please process all images using BOT before proceeding", "E");
        return;
    }
    let finalValidation = true;
    for (var i = 0; i < TypesSelected.length; i++) {
        switch (TypesSelected[i]) {
            case 'AgricultureTypeOption':
                finalValidation = finalValidation ? apz.app.CaIncomeDetails.AgricultureValidation() : false;
                break;
            case "businessTypeOption":
                finalValidation = finalValidation ? apz.app.CaIncomeDetails.businessValidation() : false;
                break;
            case 'SalaryTypeOption':
                finalValidation = finalValidation ? apz.app.CaIncomeDetails.SalaryValidation() : false;
                break;
            case "WageTypeOption":
                finalValidation = finalValidation ? apz.app.CaIncomeDetails.WageValidation() : false;
                break;
            case "PensionTypeOption":
                finalValidation = finalValidation ? apz.app.CaIncomeDetails.PensionValidation() : false;
                break;
            case "RentalincomeTypeOption":
                finalValidation = finalValidation ? apz.app.CaIncomeDetails.RentalincomeValidation() : false;
                break;
            case "HomemakerTypeOption":
                finalValidation = finalValidation ? apz.app.CaIncomeDetails.HomeMaker() : false;
                break;
            default:
                // Fallback for types or if nothing selected
                ApzCOB.fnDisplayMsg("Please select a valid Type before proceeding.", "E");
                break;
        }
    }
    if (finalValidation) {
        apz.app.CaIncomeDetails.submitIncomeService();
    }
}
var appOccupation, coAppoccupation
apz.app.CaIncomeDetails.businessesSelectedInSourcing = function() {
    var obj, isValid = true;
    appOccupation = '', coAppoccupation = ''
    var occupationArr = [];
    inSessionStore.customerDetailsList.forEach(function(k, i) {
        if (k.customerType === "Applicant") {
            obj = {
                appOccupation: k.payload.occupation
            };
            occupationArr.push(obj);
        } else if (k.customerType === "Co-App") {
            obj = {
                coAppoccupation: k.payload.occupation
            };
            occupationArr.push(obj);
        }
    });
    //occupationArr.forEach(function(k, i) {
    for (var i = 0; i < occupationArr.length; i++) {
        if (occupationArr[i].hasOwnProperty("appOccupation")) {
            appOccupation = occupationArr[i].appOccupation;
            switch (occupationArr[i].appOccupation) {
                // case "Self Employed":
                // case "SELF.EMPLOYED":
                //     isValid = isValid ? apz.app.CaIncomeDetails.SourcingValidation('Self Employed', 'App') : false;
                //     break;
                // case "Salaried":
                //     isValid = isValid ? apz.app.CaIncomeDetails.SourcingValidation('Salaried', 'App') : false;
                //     break;
                // case "Homemaker":
                //     isValid = isValid ? apz.app.CaIncomeDetails.SourcingValidation('Homemaker', 'App') : false;
                //     break;
                // case "Wage earner":
                //     isValid = isValid ? apz.app.CaIncomeDetails.SourcingValidation('Wage earner', 'App') : false;
                //     break;
                case "Self Employed":
                case "SELF.EMPLOYED":
                    let appSelfEmpValid = apz.app.CaIncomeDetails.SourcingValidation('Self Employed', 'App');
                    isValid = isValid && appSelfEmpValid;
                    break;
                case "Salaried":
                    let appSalariedValid = apz.app.CaIncomeDetails.SourcingValidation('Salaried', 'App');
                    isValid = isValid && appSalariedValid;
                    break;
                case "Homemaker":
                    let appHomemakerValid = apz.app.CaIncomeDetails.SourcingValidation('Homemaker', 'App');
                    isValid = isValid && appHomemakerValid;
                    break;
                case "Wage earner":
                    let appWageValid = apz.app.CaIncomeDetails.SourcingValidation('Wage earner', 'App');
                    isValid = isValid && appWageValid;
                    break;
            }
        } else if (occupationArr[i].hasOwnProperty("coAppoccupation")) {
            coAppoccupation = occupationArr[i].coAppoccupation;
            switch (occupationArr[i].coAppoccupation) {
                // case "Self Employed":
                // case "SELF.EMPLOYED":
                //     isValid = isValid ? apz.app.CaIncomeDetails.SourcingValidation('Self Employed', 'CoApp') : false;
                //     break;
                // case "Salaried":
                //     isValid = isValid ? apz.app.CaIncomeDetails.SourcingValidation('Salaried', 'CoApp') : false;
                //     break;
                // case "Homemaker":
                //     isValid = isValid ? apz.app.CaIncomeDetails.SourcingValidation('Homemaker', 'CoApp') : false;
                //     break;
                // case "Wage earner":
                //     isValid = isValid ? apz.app.CaIncomeDetails.SourcingValidation('Wage earner', 'CoApp') : false;
                //     break;
                case "Self Employed":
                case "SELF.EMPLOYED":
                    let coSelfEmpValid = apz.app.CaIncomeDetails.SourcingValidation('Self Employed', 'CoApp');
                    isValid = isValid && coSelfEmpValid;
                    break;
                case "Salaried":
                    let coSalariedValid = apz.app.CaIncomeDetails.SourcingValidation('Salaried', 'CoApp');
                    isValid = isValid && coSalariedValid;
                    break;
                case "Homemaker":
                    let coHomemakerValid = apz.app.CaIncomeDetails.SourcingValidation('Homemaker', 'CoApp');
                    isValid = isValid && coHomemakerValid;
                    break;
                case "Wage earner":
                    let coWageValid = apz.app.CaIncomeDetails.SourcingValidation('Wage earner', 'CoApp');
                    isValid = isValid && coWageValid;
                    break;
            }
        }
        // if (!isValid) {
        //     //ApzCOB.fnDisplayMsg("Please ensure all required fields are filled correctly.", "E");
        //     break;
        // }
    }
    if ($(`#CrdAss__CaIncomeDetails__HomemakerTypeOption`).prop("checked")) {
        let homeMakerValue = document.querySelectorAll('#CrdAss__CaIncomeDetails__HomeMaker_Owned input[type="radio"]:checked')[0]?.value;
        const hasHomemakerInOccupation = occupationArr.some(obj => obj.appOccupation === "Homemaker" || obj.coAppoccupation === "Homemaker");
        if (!hasHomemakerInOccupation && homeMakerValue) {
            isValid = false;
            ApzCOB.fnDisplayMsg("Homemaker is selected, but not present in occupations selected during sourcing. Please verify.", "E");
        }
    }
    return isValid
}
apz.app.CaIncomeDetails.SourcingValidation = function(param, type) {
    var appType, valid = false;
    var message = "The businesses/business selected in the sourcing stage are/is " + param +
        ". Current selected business/businesses does/do not match with the businesses selected at the sourcing stage. Please verify";
    if (param === "Salaried") {
        if ($(`#CrdAss__CaIncomeDetails__SalaryTypeOption`).prop("checked")) {
            appType = type === 'App' ? incomeDetailsWrapper?.salary?.applicant : incomeDetailsWrapper?.salary?.coApplicant
            if (appType) {
                valid = true
            } else {
                valid = false;
                ApzCOB.fnDisplayMsg(message, "E");
            }
        } else {
            valid = false;
            ApzCOB.fnDisplayMsg(message, "E");
        }
    } else if (param === "Homemaker") {
        var valid1 = false,
            valid2 = false;
        if ($(`#CrdAss__CaIncomeDetails__HomemakerTypeOption`).prop("checked")) {
            appType = incomeDetailsWrapper?.homeMaker;
            if (appType) {
                valid1 = true
            } else {
                valid1 = false;
                ApzCOB.fnDisplayMsg(message, "E");
            }
        } else {
            valid1 = false;
            ApzCOB.fnDisplayMsg(message, "E");
        }
        if (valid1) {
            valid2 = apz.app.CaIncomeDetails.homeMakerValidation(appType);
        }
        if (valid1 && valid2) {
            valid = true;
        } else if (valid1 && !valid2) {
            valid = false;
            ApzCOB.fnDisplayMsg(
                'The applicant was marked as Homemaker during the sourcing stage. Only the following income sources are allowed: Rental, Agriculture, Pension, Wage.',
                "E");
        } else {
            valid = false;
            ApzCOB.fnDisplayMsg(message, "E");
        }
    } else if (param === "Wage earner") {
        if ($(`#CrdAss__CaIncomeDetails__WageTypeOption`).prop("checked")) {
            appType = type === 'App' ? incomeDetailsWrapper?.wage?.applicant : incomeDetailsWrapper?.wage?.coApplicant
            if (appType) {
                valid = true
            } else {
                valid = false;
                ApzCOB.fnDisplayMsg(message, "E");
            }
        } else {
            valid = false;
            ApzCOB.fnDisplayMsg(message, "E");
        }
    } else if (param === "Self Employed") {
        var valid1 = false,
            valid2 = false;
        if ($(`#CrdAss__CaIncomeDetails__AgricultureTypeOption`).prop("checked")) {
            appType = type === 'App' ? incomeDetailsWrapper?.agriculture?.applicant : incomeDetailsWrapper?.agriculture?.coApplicant
            if (appType) {
                valid1 = true
            } else {
                valid1 = false;
                //ApzCOB.fnDisplayMsg(message, "E");
            }
        } else {
            valid = false;
            //ApzCOB.fnDisplayMsg(message, "E");
        }
        if ($(`#CrdAss__CaIncomeDetails__businessTypeOption`).prop("checked")) {
            appType = incomeDetailsWrapper?.business;
            if (type === 'App') {
                appType?.dairy.forEach((item) => {
                    if (item.DairyType === 'Applicant' || item.DairyType === 'Both') {
                        valid2 = true;
                    }
                });
                appType?.Kirana.forEach((item) => {
                    if (item.kiranaType === 'Applicant' || item.kiranaType === 'Both') {
                        valid2 = true;
                    }
                });
                appType?.Tailoring.forEach((item) => {
                    if (item.tailoringType === 'Applicant' || item.tailoringType === 'Both') {
                        valid2 = true;
                    }
                });
                appType?.Other.forEach((item) => {
                    if (item.otherType === 'Applicant' || item.otherType === 'Both') {
                        valid2 = true;
                    }
                });
            } else if (type === 'CoApp') {
                appType?.dairy.forEach((item) => {
                    if (item.DairyType === 'Co-Applicant' || item.DairyType === 'Both') {
                        valid2 = true;
                    }
                });
                appType?.Kirana.forEach((item) => {
                    if (item.kiranaType === 'Co-Applicant' || item.kiranaType === 'Both') {
                        valid2 = true;
                    }
                });
                appType?.Tailoring.forEach((item) => {
                    if (item.tailoringType === 'Co-Applicant' || item.tailoringType === 'Both') {
                        valid2 = true;
                    }
                });
                appType?.Other.forEach((item) => {
                    if (item.otherType === 'Co-Applicant' || item.otherType === 'Both') {
                        valid2 = true;
                    }
                });
            } else {
                valid2 = false;
                //ApzCOB.fnDisplayMsg(message, "E");
            }
        } else {
            valid = false;
            // ApzCOB.fnDisplayMsg(message, "E");
        }
        if (valid1 || valid2) {
            valid = true;
        } else {
            valid = false;
            ApzCOB.fnDisplayMsg(message, "E");
        }
    }
    return valid
};
apz.app.CaIncomeDetails.homeMakerValidation = function(type) {
    var homeMaker = true;
    if (type === 'Applicant') {
        if (incomeDetailsWrapper?.salary?.applicant && Object.keys(incomeDetailsWrapper?.salary?.applicant).length > 0) {
            homeMaker = false;
        }
        incomeDetailsWrapper?.business?.dairy.forEach((item) => {
            if (item.DairyType === 'Applicant' || item.DairyType === 'Both') {
                homeMaker = false;
            }
        });
        incomeDetailsWrapper?.business?.Kirana.forEach((item) => {
            if (item.kiranaType === 'Applicant' || item.kiranaType === 'Both') {
                homeMaker = false;
            }
        });
        incomeDetailsWrapper?.business?.Tailoring.forEach((item) => {
            if (item.tailoringType === 'Applicant' || item.tailoringType === 'Both') {
                homeMaker = false;
            }
        });
        incomeDetailsWrapper?.business?.Other.forEach((item) => {
            if (item.otherType === 'Applicant' || item.otherType === 'Both') {
                homeMaker = false;
            }
        });
    } else if (type === 'Co-Applicant') {
        if (incomeDetailsWrapper?.salary?.coApplicant && Object.keys(incomeDetailsWrapper?.salary?.coApplicant).length > 0) {
            homeMaker = false;
        }
        incomeDetailsWrapper?.business?.dairy.forEach((item) => {
            if (item.DairyType === 'Co-Applicant' || item.DairyType === 'Both') {
                homeMaker = false;
            }
        });
        incomeDetailsWrapper?.business?.Kirana.forEach((item) => {
            if (item.kiranaType === 'Co-Applicant' || item.kiranaType === 'Both') {
                homeMaker = false;
            }
        });
        incomeDetailsWrapper?.business?.Tailoring.forEach((item) => {
            if (item.tailoringType === 'Co-Applicant' || item.tailoringType === 'Both') {
                homeMaker = false;
            }
        });
        incomeDetailsWrapper?.business?.Other.forEach((item) => {
            if (item.otherType === 'Co-Applicant' || item.otherType === 'Both') {
                homeMaker = false;
            }
        });
    }
    return homeMaker
}
apz.app.CaIncomeDetails.businessIncomeValidation = function() {
    validateIncome = false;
    validateSumOfAppCoAppIncome = false;
    sumOfBusiness = 0,sumOfSelfDeclBusiness=0,sumOfRentalPensionAgri = 0, sumOfDeclRentalPenionAgri = 0; rentalIncome = 0, declRentalIncome = 0,
        agriIncome = 0,
        declAgriIncome = 0,
        pensionIncome = 0,
        dairyIncome = 0,
        dairySelfDeclIncome =0,
        kiranaIncome = 0,
        kiranaSelfDeclIncome =0,
        tailoringIncome = 0,
        tailoringSelfDeclIncome =0,
        otherIncome = 0,
        salaryIncome = 0,
        wageIncome = 0,
        declWageIncome = 0;
    var rental, agri, pension, wage, salary, dairy, kirana, tailoring, other;
    const jobTypes = ['constructions', 'contractLabour', 'farmWorker', 'hotelWorker', 'maid', 'other'];
    if ($(`#CrdAss__CaIncomeDetails__RentalincomeTypeOption`).prop("checked")) {
        if (Object.keys(FinalvaluesArr?.rentalIncome || {}).length > 0) {
            rental = FinalvaluesArr.rentalIncome
        } else {
            rental = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.rentalIncome;
        }
    }
    if ($(`#CrdAss__CaIncomeDetails__AgricultureTypeOption`).prop("checked")) {
        if (Object.keys(FinalvaluesArr?.agriculture || {}).length > 0) {
            agri = FinalvaluesArr.agriculture
        } else {
            agri = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.agriculture;
        }
    }
    if ($(`#CrdAss__CaIncomeDetails__PensionTypeOption`).prop("checked")) {
        if (Object.keys(FinalvaluesArr?.pension || {}).length > 0) {
            pension = FinalvaluesArr.pension
        } else {
            pension = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.pension;
        }
    }
    if ($(`#CrdAss__CaIncomeDetails__WageTypeOption`).prop("checked")) {
        if (Object.keys(FinalvaluesArr?.wage || {}).length > 0) {
            wage = FinalvaluesArr.wage
        } else {
            wage = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.wage;
        }
    }
    if ($(`#CrdAss__CaIncomeDetails__SalaryTypeOption`).prop("checked")) {
        if (Object.keys(FinalvaluesArr?.salary || {}).length > 0) {
            salary = FinalvaluesArr.salary
        } else {
            salary = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.salary;
        }
    }
    if ($(`#CrdAss__CaIncomeDetails__businessTypeOption`).prop("checked")) {
        if (FinalvaluesArr?.dairy?.length > 0) {
            dairy = FinalvaluesArr.dairy
        } else if (!Object.values(deletedBusinessIndexes).includes("dairy")) {
            dairy = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.business?.dairy;
        }
        if (FinalvaluesArr?.Kirana?.length > 0) {
            kirana = FinalvaluesArr.Kirana
        } else if (!Object.values(deletedBusinessIndexes).includes("Kirana")) {
            kirana = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.business?.Kirana;
        }
        if (FinalvaluesArr?.Tailoring?.length > 0) {
            tailoring = FinalvaluesArr.Tailoring
        } else if (!Object.values(deletedBusinessIndexes).includes("Tailoring")) {
            tailoring = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.business?.Tailoring;
        }
        if (FinalvaluesArr?.Other?.length > 0) {
            other = FinalvaluesArr.Other
        } else if (!Object.values(deletedBusinessIndexes).includes("Other")) {
            other = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload || '{}')?.business?.Other;
        }
    }
    if (rental?.applicant?.consideredMonthlyIncome) {
        rentalIncome += parseFloat(rental.applicant.consideredMonthlyIncome);
    }
    if (rental?.coApplicant?.consideredMonthlyIncome) {
        rentalIncome += parseFloat(rental.coApplicant.consideredMonthlyIncome);
    }
    if (rental?.applicant?.monthlyRentalIncome) {
        declRentalIncome += parseFloat(rental.applicant.monthlyRentalIncome);
    }
    if (rental?.coApplicant?.monthlyRentalIncome) {
        declRentalIncome += parseFloat(rental.coApplicant.monthlyRentalIncome);
    }
    if (pension?.applicant?.applicantPensionIncome) {
        pensionIncome += parseFloat(pension.applicant.applicantPensionIncome);
    }
    if (pension?.coApplicant?.coApplicantPensionIncome) {
        pensionIncome += parseFloat(pension.coApplicant.coApplicantPensionIncome);
    }
    if (agri?.applicant?.monthlyIncome) {
        agriIncome += parseFloat(agri.applicant.consideredIncome);
    }
    if (agri?.coApplicant?.monthlyIncome) {
        agriIncome += parseFloat(agri.coApplicant.consideredIncome);
    }
    if (agri?.applicant?.declaredIncome) {
        declAgriIncome += parseFloat(agri.applicant.declaredIncome);
    }
    if (agri?.coApplicant?.declaredIncome) {
        declAgriIncome += parseFloat(agri.coApplicant.declaredIncome);
    }
    if (wage?.applicant) {
        jobTypes.forEach(type => {
            const income = wage.applicant?.[type]?.totalWagePerMonth;
            if (income) {
                wageIncome += parseFloat(income);
            }
        });
    }
    if (wage?.coApplicant) {
        jobTypes.forEach(type => {
            const income = wage.coApplicant?.[type]?.totalWagePerMonth;
            if (income) {
                wageIncome += parseFloat(income);
            }
        });
    }
    if (wage?.applicant) {
        jobTypes.forEach(type => {
            const income = wage.applicant?.[type]?.selfDeclaredWage;
            if (income) {
                declWageIncome += parseFloat(income);
            }
        });
    }
    if (wage?.coApplicant) {
        jobTypes.forEach(type => {
            const income = wage.coApplicant?.[type]?.selfDeclaredWage;
            if (income) {
                declWageIncome += parseFloat(income);
            }
        });
    }
    if (salary?.applicant?.netSalary) {
        salaryIncome += parseFloat(salary.applicant.netSalary);
    }
    if (salary?.coApplicant?.netSalary) {
        salaryIncome += parseFloat(salary.coApplicant.netSalary);
    }
    if (dairy?.length > 0) {
        dairy.forEach(item => {
            dairyIncome += Number(item?.IncomeAssessmentChecknetBusinessIncome || 0);
        });
    }
    if (dairy?.length > 0) {
        dairy.forEach(item => {
            dairySelfDeclIncome += Number(item?.netMonthlyIncome || 0);
        });
    }
    if (kirana?.length > 0) {
        kirana.forEach(item => {
            kiranaIncome += Number(item?.finalNetIncome || 0);
        });
    }
    if (kirana?.length > 0) {
        kirana.forEach(item => {
            kiranaSelfDeclIncome += Number(item?.netMonthlyIncome || 0);
        });
    }
    if (tailoring?.length > 0) {
        tailoring.forEach(item => {
            tailoringIncome += Number(item?.netBusinessIncome || 0);
        });
    }
    if (tailoring?.length > 0) {
        tailoring.forEach(item => {
            tailoringSelfDeclIncome += Number(item?.netMonthlyIncome || 0);
        });
    }
    if (other?.length > 0) {
        other.forEach(item => {
            otherIncome += Number(item?.netBusinessIncome || 0);
        });
    }
    sumOfRentalPensionAgri = rentalIncome + pensionIncome + agriIncome;
    sumOfBusiness = dairyIncome + kiranaIncome + tailoringIncome + otherIncome;
    const maxAllowedIncome = sumOfBusiness * 0.5;
    if (sumOfRentalPensionAgri > maxAllowedIncome) {
        ApzCOB.fnDisplayMsg("The net calculated income from Rental, Pension, and Agriculture should not exceed 50% of the main business income.", "E");
        validateIncome = false;
    } else {
        validateIncome = true;
    }
    sumOfSelfDeclBusiness = dairySelfDeclIncome + kiranaSelfDeclIncome + tailoringSelfDeclIncome + otherIncome + declWageIncome + salaryIncome;
    sumOfDeclRentalPenionAgri = declRentalIncome + pensionIncome + declAgriIncome;
    const maxAllowedSelfDeclIncome = sumOfSelfDeclBusiness * 0.5;
    if (sumOfDeclRentalPenionAgri > maxAllowedSelfDeclIncome) {
        ApzCOB.fnDisplayMsg("The self declared income from Rental, Pension, and Agriculture should not exceed 50% of the main business income.", "E");
        validateIncome = false;
    }
    var totalMonthlyIncome = dairyIncome + kiranaIncome + tailoringIncome + otherIncome + agriIncome + salaryIncome + wageIncome + pensionIncome +
        rentalIncome;
    var annualIncome = totalMonthlyIncome * 12;
    if (annualIncome > 1200000) {
        validateSumOfAppCoAppIncome = false;
        ApzCOB.fnDisplayMsg("The net monthly income added is " + `Rs.${totalMonthlyIncome.toLocaleString('en-IN')}/-` +
            " Net monthly income must be less than Rs.1,00,000/- per month.", "E");
    } else if (annualIncome < 300001) {
        validateSumOfAppCoAppIncome = false;
        ApzCOB.fnDisplayMsg("The net monthly income added is " + `Rs.${totalMonthlyIncome.toLocaleString('en-IN')}/-` +
            " Net monthly income must be greater than Rs.25,000/- per month.", "E");
    } else {
        validateSumOfAppCoAppIncome = true;
    }
};
apz.app.CaIncomeDetails.businessValidation = function() {
    if (inSessionStore?.bcmpiIncomeDetails) {
        if (JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.dairy?.length > 0 && FinalvaluesArr?.dairy?.length === 0 && !Object
            .values(deletedBusinessIndexes).includes("dairy")) {
            FinalvaluesArr.dairy = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.dairy;
        }
        if (JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Kirana?.length > 0 && FinalvaluesArr?.Kirana?.length === 0 && !
            Object.values(deletedBusinessIndexes).includes("Kirana")) {
            FinalvaluesArr.Kirana = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Kirana;
        }
        if (JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Tailoring?.length > 0 && FinalvaluesArr?.Tailoring?.length === 0 &&
            !Object.values(deletedBusinessIndexes).includes("Tailoring")) {
            FinalvaluesArr.Tailoring = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Tailoring;
        }
        if (JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Other?.length > 0 && FinalvaluesArr?.Other?.length === 0 && !Object
            .values(deletedBusinessIndexes).includes("Other")) {
            FinalvaluesArr.Other = JSON.parse(inSessionStore?.bcmpiIncomeDetails?.payload)?.business?.Other;
        }
    }
    for (let index = 1; index <= 12; index++) {
        let cloneRow = $("#" + CaIncomeDetailsScrId + "CloneRow_" + index);
        if (cloneRow.length > 0 && !cloneRow.hasClass("sno")) {
            let deleteIcon = $("#" + CaIncomeDetailsScrId + index + "_DeleteIcon_ul");
            if (!deleteIcon.is(":visible") && !deletedBusinessIndexes.hasOwnProperty(index)) {
                ApzCOB.fnDisplayMsg("Please enter business details before proceeding.", "E");
                return false;
            }
            if (!apz.app.CaIncomeDetails.validateDocs("CrdAss__CaIncomeDetails__" + index + "_Business_ParentBusRow", "businessimg")) {
                return false;
            }
        }
    }
    return true;
}
