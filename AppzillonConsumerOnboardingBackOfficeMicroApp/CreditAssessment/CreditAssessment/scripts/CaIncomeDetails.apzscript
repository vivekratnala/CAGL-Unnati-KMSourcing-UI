apz.app.CaIncomeDetails.OnclickSaveTailoring = function() {
    if ($(".T-CalDet").is(":visible")) {
        apz.app.CaIncomeDetails.StoreTailoring();
        IncomeassEdit = {
            type: "",
            Flag: false
        };
    } else {
        var TailoringForm = $("#" + CaIncomeDetailsScrId + "TailoringForm").find("input"),
            TailoringForm_validator_check = {
                CrdAss__CaIncomeDetails__T_NameofOrg: {
                    verify: nullcheck,
                    message: "LIT_ENTER_NAME_ORG",
                },
                CrdAss__CaIncomeDetails__T_NetMon: {
                    verify: nullcheck,
                    message: "LIT_ENTER_MONTH_INC",
                },
            };
        var AllDropdowns = [
            // All Default
            {
                id: CaIncomeDetailsScrId + "T-loc",
                errorMsg: "Please select the Business location before proceed"
            }, {
                id: CaIncomeDetailsScrId + "T-ten",
                errorMsg: "Please select the Business Tenure before proceed"
            }, {
                id: CaIncomeDetailsScrId + "T-pre",
                errorMsg: "Please select the Business Premise before proceed"
            }, {
                id: CaIncomeDetailsScrId + "T-powerMachines",
                errorMsg: "Please select the No. of Power Tailoring machines before proceed"
            }, {
                id: CaIncomeDetailsScrId + "T-manualMachines",
                errorMsg: "Please select the No. of Manual Tailoring machines before proceed"
            }, {
                id: CaIncomeDetailsScrId + "T-noSalariedTailor",
                errorMsg: "Please select the No. of Salaried Tailors (Excluding App and Co-App) before proceed"
            }, {
                id: CaIncomeDetailsScrId + "T-WorkType",
                errorMsg: "Please select the Working type – Full/Part Time before proceed"
            }, {
                id: CaIncomeDetailsScrId + "T-stitchingFor",
                errorMsg: "Please select the Stitching for Men/Women/Both before proceed"
            }, {
                id: CaIncomeDetailsScrId + "T-TypeofBus",
                errorMsg: "Please select the Type of business of Shop & Godown before proceed"
            }
        ];
        let errorMsg = '', isApplTailorSelected = '', isCoApplTailorSelected = '';
        isApplTailorSelected = Array.from(document.getElementsByName(isApplTailorID)).some(opt => opt.checked);
        isCoApplTailorSelected = Array.from(document.getElementsByName(isCoAppPartID)).some(opt => opt.checked);
        if (!isApplTailorSelected) {
            errorMsg = "Please select 'Is Applicant a Tailor' before proceeding.";
        } else if (!isCoApplTailorSelected) {
            errorMsg = "Please select 'Is Co-Applicant part of the Tailoring Business' before proceeding.";
        }
        if (!apz.isNull(errorMsg)) {
            ApzCOB.fnDisplayMsg(errorMsg, "E");
            return;
        }
        if (apz.app.CaIncomeDetails.ValidateDropDown(AllDropdowns, "Tailoring") && apz.app.CaIncomeDetails.validateInputFields(TailoringForm,
