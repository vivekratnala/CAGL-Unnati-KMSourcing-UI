        $(`#${CaIncomeDetailsScrId}otherFamilyBtn`).removeClass("active");
    } else {
        $(`#${CaIncomeDetailsScrId}applicantCoapplicant_div`).addClass("sno");
        $(`#${CaIncomeDetailsScrId}otherFamily_div`).removeClass("sno");
        $(`#${CaIncomeDetailsScrId}OtherFamilyForm`).removeClass("sno");
        $(`#${CaIncomeDetailsScrId}otherFamilyBtn`).addClass("active");
        $(`#${CaIncomeDetailsScrId}appCoAppBtn`).removeClass("active");
    }
};
apz.app.CaIncomeDetails.launchBusinessSection = function(pthis, obj) {
    var TypeChecked, clonedRowId, id, sectionName, sectionNameChecked;
    FinalvaluesArr.salary = {};
    FinalvaluesArr.agriculture = {};
    FinalvaluesArr.rentalIncome = {};
    FinalvaluesArr.pension = {};
    FinalvaluesArr.wage = {};
    if (pthis != '') {
        TypeChecked = pthis.checked;
        sectionName = pthis.labels[0].innerText.trim().replaceAll(" ", "");
        clonedRowId = `${CaIncomeDetailsScrId}CloneRow_1`;
        if (!TypeChecked) {
            const canProceed = apz.app.CaIncomeDetails.getUploadedDocsForSelectedIncome(sectionName);
            if (!canProceed) {
                return
            };
        }
    } else {
        TypeChecked = obj.TypeChecked;
        sectionName = obj.sectionName;
        id = obj.id;
        clonedRowId = `${CaIncomeDetailsScrId}CloneRow_${id}`;
        numberOfBusinessCount = parseInt(obj.id)
    }
    if (sectionName === "Business") {
        if (TypeChecked) {
            let existingDiv = $(`#${clonedRowId}`);
            if (existingDiv.length > 0) {
                existingDiv.removeClass("sno");
                numberOfBusinessCount = 1;
                apz.app.CaIncomeDetails.resetBusiness(numberOfBusinessCount);
            } else {
                let clonedId = apz.app.CaIncomeDetails.DeepcloneDivs(elementId, businessParentDiv, numberOfBusinessCount);
                $(`#${clonedId}`).removeClass("sno");
            }
        } else {
            // Hide all cloned business rows up to numberOfBusinessCount
            for (let i = 1; i <= numberOfBusinessCount; i++) {
                let clonedRowId = `${CaIncomeDetailsScrId}CloneRow_${i}`;
                $(`#${clonedRowId}`).addClass("sno");
            }
            // to empty the value if checked is false
            FinalvaluesArr.dairy = [];
            FinalvaluesArr.Kirana = [];
            FinalvaluesArr.Tailoring = [];
            FinalvaluesArr.Other = [];
            ["dairy", "Kirana", "Tailoring", "Other"].forEach(businessType => {
                deletedBusinessIndexes[`Allcheckbox_${businessType}`] = businessType;
            });
        }
        let isDisabled = TypeChecked;
        $(`#CrdAss__CaIncomeDetails__${numberOfBusinessCount}_addBusinessDetails`).attr("disabled", isDisabled);
        $(`#CrdAss__CaIncomeDetails__${numberOfBusinessCount}_addBusiness`).attr("disabled", isDisabled);
    } else {
        let sectionId = `${CaIncomeDetailsScrId}${sectionName}`;
        let section = $(`#${sectionId}`);
        TypeChecked ? section.removeClass("sno") : section.addClass("sno");
        if (TypeChecked) {
            let CheckId;
            switch (sectionName) {
                case 'Agriculture':
                    CheckId = "Agri_Owned";
                    break;
                case 'Salary':
                    CheckId = "SalOwned";
                    break;
                case 'Wage':
                    CheckId = "Wage_Owned";
                    let selectedAppCheckBox = document.querySelectorAll('#CrdAss__CaIncomeDetails__App_CheckBox input[type="CHECKBOX"]:checked');
                    selectedAppCheckBox.forEach(radio => radio.checked = false);
                    let selectedCoCheckBox = document.querySelectorAll('#CrdAss__CaIncomeDetails__Co_CheckBox input[type="CHECKBOX"]:checked');
                    selectedCoCheckBox.forEach(radio => radio.checked = false);
                    const wageOptionTypes = ['Farm_Worker', 'constructions', 'Contract_labour', 'Maid', 'Hotel_Worker', 'Other'];
                    const wageDetailFields = ['WageEarnedPerDay', 'NoOFDaysInMonth', 'ToTalWagePerMonth'];
                    ['App', 'Co'].forEach(prefix => {
                        wageOptionTypes.forEach(type => {
                            const checkboxId = `${CaIncomeDetailsScrId}${prefix}_${type}`;
                            const checkbox = document.getElementById(checkboxId);
                            if (checkbox) {
                                checkbox.checked = false;
                            }
                            const wageRowId = `${CaIncomeDetailsScrId}WageRow${prefix}_${prefix}_${type}`;
                            const wageRowElement = document.getElementById(wageRowId);
                            if (wageRowElement) {
                                wageRowElement.remove();
                            }
                            wageDetailFields.forEach(detailField => {
                                const inputFieldId = `${CaIncomeDetailsScrId}${detailField}_${prefix}_${type}`;
                                const inputField = document.getElementById(inputFieldId);
                                if (inputField) {
                                    inputField.value = '';
                                }
                            });
                        });
                    });
                    break;
                case 'Pension':
                    CheckId = "Pension_Owned";
                    break;
                case 'Rentalincome':
                    CheckId = "Rentalincome_Owned";
                    break;
                case 'Homemaker':
                    document.getElementById(CaIncomeDetailsScrId + "HomeMaker_Owned_option_Applicant").checked = true;
                    break;
                default:
                    break;
            }
            if (CheckId) {
                let selectedRadios = document.querySelectorAll('#CrdAss__CaIncomeDetails__' + CheckId + ' input[type="radio"]:checked');
                selectedRadios.forEach(radio => radio.checked = false);
                let parentIdStr = CaIncomeDetailsScrId + sectionName;
                $(`#${parentIdStr} #${CaIncomeDetailsScrId}Applicant`).addClass("sno");
                $(`#${parentIdStr} #${CaIncomeDetailsScrId}Co-Applicant`).addClass("sno");
            }
        }
    }
};
apz.app.CaIncomeDetails.DeepcloneDivs = function(selectElement, parentDiv, index) {
    const originalDiv = document.querySelector("#" + selectElement);
    let newId = "";
    if (originalDiv) {
        const clonedDiv = originalDiv.cloneNode(true); // clone with children
        let baseId = selectElement.split("_0")[0];
        newId = baseId + "_" + index;
        clonedDiv.id = newId;
        // Update IDs of all child elements inside the clonedDiv
        const elementsWithId = clonedDiv.querySelectorAll('[id]');
        elementsWithId.forEach(elem => {
            const oldId = elem.id;
            const oldVal = oldId.split("__")[2];
            const NewVal = index + "_" + oldVal;
            const newChildId = oldId.replace(oldVal, NewVal);
            elem.id = newChildId;
            if (elem.name) {
                const oldname = elem.name;
                const olName = oldname.split("__")[2];
                const newName = index + "_" + olName;
                const newChildName = oldname.replace(olName, newName);
                elem.name = newChildName;
            }
            if (elem.tagName.toLowerCase() === 'label' && elem.htmlFor) {
                const Oldhtml = elem.htmlFor;
                const Oldht = Oldhtml.split("__")[2];
                const NewHt = index + "_" + Oldht;
                const newChildhtml = Oldhtml.replace(Oldht, NewHt);
                elem.htmlFor = newChildhtml;
            }
        });
        parentDiv.append(clonedDiv);
    }
    return newId;
}
apz.app.CaIncomeDetails.launchCustomerSection = function(pthis) {
    incomeTypeBulkDelete = docNoImageDelete = documentType = custTypeForImageDelete = '';
    FinalvaluesArr.salary = {};
    FinalvaluesArr.agriculture = {};
    FinalvaluesArr.rentalIncome = {};
    FinalvaluesArr.pension = {};
    FinalvaluesArr.wage = {};
    if (pthis?.id?.split("CrdAss__CaIncomeDetails__")?.[1]?.includes('Wage')) {
        WageEarnedType = [];
    }
    apz.app.CaIncomeDetails.hideSections(pthis);
    let lastPart;
    let parentIdStr;
    let parentid = $("#" + pthis.id).closest(".crt-form");
    if (parentid.length > 0) {
        parentIdStr = parentid.attr("id");
        let targetElement = document.getElementById(parentIdStr);
        if (targetElement && targetElement.id) {
            let idParts = targetElement.id.split("__");
            lastPart = idParts[idParts.length - 1];
            targetElement.classList.add(lastPart);
        }
    }
    var checked;
    if (parentIdStr && document.getElementById(parentIdStr)?.classList.contains(lastPart)) {
        if (pthis.value === 'Both') {
            $(`#${parentIdStr} #${CaIncomeDetailsScrId}Applicant`).removeClass("sno");
            $(`#${parentIdStr} #${CaIncomeDetailsScrId}Co-Applicant`).removeClass("sno");
        }
        $(`#${parentIdStr} #${CaIncomeDetailsScrId}${pthis.value}`).removeClass("sno");
    }
    let Type = parentIdStr.split("_")[4];
    var inputIds;
    switch (Type) {
        case 'Agriculture':
            apz.app.CaIncomeDetails.Agriculture();
            inputIds = ['Ap_Crop', 'Ap_MaxperArc', 'Agri_MonthIncome', 'Co_Agri_Month_income', 'Co_MaxPerAcrc', 'Co_Crop',
                'Agri_ConsideredIncome', 'Co_Agri_ConsideredIncome'
            ];
            incomeTypeBulkDelete = `${Type} Doc`;
            apz.app.Cabase.BulkDeleteImages(documentType, custTypeForImageDelete, incomeTypeBulkDelete, docNoImageDelete, "Y");
            break;
        case 'Salary':
            apz.app.CaIncomeDetails.Salary();
            salaryFields.forEach(field => {
                $('#' + CaIncomeDetailsScrId + field + 'ErrorDiv').addClass('sno');
            })
            inputIds = ['Sal_App_Wor', 'NetSal', 'Sal_Co_Wor', 'NetSalCo'];
            incomeTypeBulkDelete = `${Type} Doc`;
            apz.app.Cabase.BulkDeleteImages(documentType, custTypeForImageDelete, incomeTypeBulkDelete, docNoImageDelete, "Y");
            break;
        case 'Pension':
            inputIds = ['App_PenIn', 'Co_PenIn'];
            incomeTypeBulkDelete = `${Type} Doc`;
            apz.app.Cabase.BulkDeleteImages(documentType, custTypeForImageDelete, incomeTypeBulkDelete, docNoImageDelete, "Y");
            break;
        case 'Rentalincome':
            apz.app.CaIncomeDetails.Rentalincome();
            rentalIncomeFields.forEach(field => {
                $('#' + CaIncomeDetailsScrId + field + 'ErrorDiv').addClass('sno');
            })
            inputIds = ['RentalIncomeMonth_App', 'RentalIncomeMonth_Co'];
            incomeTypeBulkDelete = "Rentalincome_Agg Doc";
            apz.app.Cabase.BulkDeleteImages(documentType, custTypeForImageDelete, incomeTypeBulkDelete, docNoImageDelete, "Y");
            break;
        case 'Wage':
            const wageOptionTypes = ['Farm_Worker', 'constructions', 'Contract_labour', 'Maid', 'Hotel_Worker', 'Other'];
            const wageDetailFields = ['WageEarnedPerDay', 'NoOFDaysInMonth', 'ToTalWagePerMonth'];
            ['App', 'Co'].forEach(prefix => {
                wageOptionTypes.forEach(type => {
                    const checkboxId = `${CaIncomeDetailsScrId}${prefix}_${type}`;
                    const checkbox = document.getElementById(checkboxId);
                    if (checkbox) {
                        checkbox.checked = false;
                    }
                    const wageRowId = `${CaIncomeDetailsScrId}WageRow${prefix}_${prefix}_${type}`;
                    const wageRowElement = document.getElementById(wageRowId);
                    if (wageRowElement) {
                        wageRowElement.remove();
                    }
                    wageDetailFields.forEach(detailField => {
                        const inputFieldId = `${CaIncomeDetailsScrId}${detailField}_${prefix}_${type}`;
                        const inputField = document.getElementById(inputFieldId);
                        if (inputField) {
                            inputField.value = '';
                        }
                    });
                });
            });
            inputIds = [];
            break;
        default:
            // Fallback for other types or if nothing selected
            inputIds = []; // Example IDs
            break;
    }
    // Array of input field IDs
    // Loop through the array and clear the value of each input field
    for (let i = 0; i < inputIds.length; i++) {
        const inputElement = document.getElementById(CaIncomeDetailsScrId + inputIds[i]);
        if (inputElement) {
            inputElement.value = ''; // Clear value
        }
    }
}
