apz.app.CaIncomeDetails.WageValidation = function() {
    const checkboxes = document.querySelectorAll('#CrdAss__CaIncomeDetails__Wage_Owned input[type="radio"]:checked');
    if (checkboxes.length === 0) {
        ApzCOB.fnDisplayMsg("Please select the Wage Owned by", "E");
        return false;
    }
    const Type = checkboxes[0].value;
    let AllDetailsAdded = false;
    const getWageCheckboxSelectors = (prefix) => {
        return [`#CrdAss__CaIncomeDetails__${prefix}Farm_Worker`, `#CrdAss__CaIncomeDetails__${prefix}constructions`,
            `#CrdAss__CaIncomeDetails__${prefix}Contract_labour`, `#CrdAss__CaIncomeDetails__${prefix}Maid`,
            `#CrdAss__CaIncomeDetails__${prefix}Hotel_Worker`, `#CrdAss__CaIncomeDetails__${prefix}Other`
        ];
    };
    const isAnyApplicantChecked = () => {
        return getWageCheckboxSelectors('App_').some(selector => document.querySelector(selector)?.checked);
    };
    const isAnyCoApplicantChecked = () => {
        return getWageCheckboxSelectors('Co_').some(selector => document.querySelector(selector)?.checked);
    };
    switch (Type) {
        case 'Applicant':
            if (!isAnyApplicantChecked()) {
                ApzCOB.fnDisplayMsg("Please select at least one wage option for Applicant.", "E");
                return false;
            }
            AllDetailsAdded = apz.app.CaIncomeDetails.WageValidateApplicant();
            break;
        case 'Co-Applicant':
            if (!isAnyCoApplicantChecked()) {
                ApzCOB.fnDisplayMsg("Please select at least one wage option for Co-Applicant.", "E");
                return false;
            }
            AllDetailsAdded = apz.app.CaIncomeDetails.WageValidateCoApplicant("OnlyCo");
            break;
        case 'Both':
            const applicantChecked = isAnyApplicantChecked();
            const coApplicantChecked = isAnyCoApplicantChecked();
            if (!applicantChecked || !coApplicantChecked) {
                ApzCOB.fnDisplayMsg("Please select at least one wage option each for both Applicant and Co-Applicant.", "E");
                return false;
            }
            AllDetailsAdded = apz.app.CaIncomeDetails.WageValidateApplicant();
            AllDetailsAdded = AllDetailsAdded ? apz.app.CaIncomeDetails.WageValidateCoApplicant() : false;
            break;
        default:
            ApzCOB.fnDisplayMsg("Please select a valid Wage Type before proceeding.", "E");
            return false;
    }
    return AllDetailsAdded;
};
apz.app.CaIncomeDetails.WageValidateCoApplicant = function(AppType) {
    wageStoreData = {};
    var valid = true;
    var mandFields = validateWageField.filter(field => field.includes("NoOFDaysInMonth") || field.includes("DeclaredWages"))
    mandFields.forEach(function(id) {
        if ($('#' + CaIncomeDetailsScrId + id).val() === "" || $('#' + CaIncomeDetailsScrId + id).val() === "Please Select") {
            valid = false;
            ApzCOB.fnDisplayMsg("Fields are mandatory", "E");
            return;
        }
    })
    if (valid) {
        const roleMap = {
            "Co_Farm_Worker": "farmWorker",
            "Co_Maid": "maid",
            "Co_constructions": "constructions",
            "Co_Hotel_Worker": "hotelWorker",
            "Co_Contract_labour": "contractLabour",
            "Co_Other": "other"
        };
       if (!WageEarnedType || WageEarnedType.length === 0) {
            ApzCOB.fnDisplayMsg("Please select at least one wage option for Applicant.","E");
            return false;
        }
        WageEarnedType.forEach(function(k) {
            const mappedKey = roleMap[k];
            if (mappedKey) {
                wageStoreData[mappedKey] = {
                    noOfDaysInMonth: $('#' + CaIncomeDetailsScrId + 'NoOFDaysInMonth_' + k).val(),
                    wageEarnedPerDay: $('#' + CaIncomeDetailsScrId + 'WageEarnedPerDay_' + k).val(),
                    totalWagePerMonth: $('#' + CaIncomeDetailsScrId + 'ToTalWagePerMonth_' + k).val(),
                    selfDeclaredWage: $('#' + CaIncomeDetailsScrId + 'DeclaredWages_' + k).val(),
                    otherAct: $('#' + CaIncomeDetailsScrId + 'OtherAct_' + k).val()
                };
            }
        });
        FinalvaluesArr.wage.coApplicant = {};
        FinalvaluesArr.wage.coApplicant = wageStoreData
        return true;
    }
    return false;
}
