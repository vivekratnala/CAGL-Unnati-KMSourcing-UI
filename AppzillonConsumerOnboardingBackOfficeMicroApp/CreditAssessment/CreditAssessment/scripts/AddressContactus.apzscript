        if ((params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse.ResponseHeader.ResponseCode != '0') && (params.res
                .APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj != ApzCOB.getDescfromLitCode("LIT_fetchLockAppli"))) {
            errMsg = "Fetch Application Data Service Failed." + "\n" + params.resFull.appzillonBody.APZCBO__UploadCALoanData_Res.apiResponse
                ?.ResponseBody?.responseObj;
        } else {
            errMsg = params.res.APZCBO__UploadCALoanData_Res.apiResponse.ResponseBody.responseObj;
        }
    } else {
        errMsg = "Fetch Application Data Service Failed";
    }
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            ApzCOB.launchSubScreen('Insurancedetails', "CrdAss__Cabase__caLaunchCol", "");
            apz.app.Cabase.SidebarSelect.moveToNextStep();
        } else {
            apz.stopLoader();
            ApzCOB.showCaModals({
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn1: {
                    text: "OK",
                    onClick: "apz.app.Cabase.closeCaErrMdl()"
                }
            }, "Error");
        }
    } catch {
        apz.stopLoader();
        ApzCOB.showCaModals({
            text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
            Btn1: {
                text: "OK",
                onClick: "apz.app.Cabase.closeCaErrMdl()"
            }
        }, "Error");
    }
}
apz.app.AddressContactus.preCheckedFields = function() {
    const queryDtls = inSessionStore?.bcmpiStatDetails?.find(
        (item) => item.stageID === CA_CURRENT_STAGE_NO);
    if (queryDtls) {
        let preSelectedQueryData = queryDtls.query;
        queriesAddrContact = preSelectedQueryData;
        photoKycQueriesForNextStage = [...queriesAddrContact];
    } else {
        return;
    }
}
apz.app.AddressContactus.paintingQueries = function() {
    const allQueries = JSON.parse(CA_ALL_STAGE_FIELDS.filter(item => item.id === 3 && item.queries)[0]?.queries || '{}').sendbackReason
    if (queriesAddrContact.length > 0) {
        const addrMatchedValues = allQueries.filter(query => queriesAddrContact.includes(query.id)).map(query => query.value);
        const othEntry = queriesAddrContact.find((item) => item.startsWith("oth?"));
        if (othEntry) {
            const [othId, othValue] = othEntry.split("?");
            if (othValue.trim() !== "") {
                addrMatchedValues.push(othValue);
            }
        }
        $(`#${AddContScrId}AddQueryheaderRow`).removeClass("sno");
        $(`#${AddContScrId}AddrQueriesRow`).removeClass("sno");
        $(`#${AddContScrId}AddrQueryData_`).html('')
        const queryRow = $(`#${AddContScrId}AddrQueriesRow`);
        queryRow.html('');
        queryRow.find("[id^='CrdAss__AddressContactus__AddrQueryData_']").remove();
        addrMatchedValues.forEach((queryValue, index) => {
            queryRow.append(
                `<div id="CrdAss__AddressContactus__AddrQueryData_${index + 1}"><p>${index + 1}.&nbsp;&nbsp;${queryValue}</p></div>`);
        });
    } else {
        $(`#${AddContScrId}AddQueryheaderRow`).addClass("sno");
        $(`#${AddContScrId}AddrQueriesRow`).addClass("sno");
    }
}
apz.app.AddressContactus.paintingQueryLabels = function() {
    const matchedItem = inSessionStore?.bcmpiVerifiedStage?.some(item => item.startsWith(`${CA_CURRENT_STAGE_NO}_`));
    if (matchedItem) {
        isAddressVerified = true;
        $(`#${AddContScrId}A_VERIFY_BTN`).addClass("sno");
        $(`#${AddContScrId}A_VERIFIED_BTN_ul`).removeClass("sno");
        $(`#${AddContScrId}QUERY_BTN`).removeClass("sno");
        $(`#${AddContScrId}A_QUERIED_BTN_ul`).addClass("sno");
        $(`#${CabaseScrId}sendback_btn`).addClass("sno");
        return;
    }
    const queryDtls = inSessionStore?.bcmpiStatDetails?.find(
        (item) => item.stageID === CA_CURRENT_STAGE_NO);
    if (!matchedItem && queryDtls) {
        $(`#${AddContScrId}A_VERIFY_BTN`).removeClass("sno");
        $(`#${AddContScrId}A_VERIFIED_BTN_ul`).addClass("sno");
        $(`#${AddContScrId}QUERY_BTN`).addClass("sno");
        $(`#${AddContScrId}A_QUERIED_BTN_ul`).removeClass("sno");
        isAddressVerified = false;
    } else {
        $(`#${CabaseScrId}sendback_btn`).addClass("sno");
        return;
    }
}
apz.app.AddressContactus.formatYearsInput = function(input) {
    let formattedInput = input.trim().toLowerCase();
    if (formattedInput.includes("less")) {
        return "Less than 1 Year";
    }
    let yearsMatch = formattedInput.match(/^(\d+)\s*(year|years)?$/i);
    if (yearsMatch) {
        let years = yearsMatch[1];
        let isYearWordPresent = yearsMatch[2];
        if (!isYearWordPresent) {
            return years === "1" ? `${years} Year` : `${years} Years`;
        } else {
            return formattedInput.replace(/(year|years)/i, (match) => match.charAt(0).toUpperCase() + match.slice(1));
        }
    }
    return input;
}
apz.app.AddressContactus.onChangeResStability = function(pthis) {
    let cityValue = $("#CrdAss__AddressContactus__A_residence_stabilit_present_city").val();
    let resValue = $("#CrdAss__AddressContactus__A_residence_stability").val();
    let cityIndex = resYr.indexOf(cityValue);
    let resIndex = resYr.indexOf(resValue);
    if ((resIndex != 0 && resIndex < 3) || (cityIndex != 0 && cityIndex < 3)) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_RESIDENTIAL_STABILITY_TWO_YR_ERR"), "E");
        $(pthis).val(PleaseSelect);
        $(`#${pthis.id}_div`).find('li').removeClass('is-selected hilt');
        $(`#${pthis.id}_div`).find('li').first().addClass('is-selected hilt');
    } else if (cityIndex === 0 || resIndex === 0) {
        // do nothing
    } else if (resYr.indexOf(resValue) > resYr.indexOf(cityValue)) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_RESIDENTIAL_STABILITY_ERR"), "E");
        $(pthis).val(PleaseSelect);
        $(`#${pthis.id}_div`).find('li').removeClass('is-selected hilt');
        $(`#${pthis.id}_div`).find('li').first().addClass('is-selected hilt');
    }
}
