apz.app.PersonalDetails.validationStatus = function() {
    if (!apz.isNull(inSessionStore.customerDetailsList)) {
        var index = gApzCOB.currentApplicant > 1 ? 1 : 0;
        if(!apz.isNull(inSessionStore.customerDetailsList[index])){
        var custData = inSessionStore.customerDetailsList[index].payload;
        if (custData.primaryKycIdValStatus === "Verified") {
            $('#' + PerDetScrId + 'primaryKycVerifyBtn_ul').addClass('sno');
            $('#' + PerDetScrId + 'primaryKycVerifiedTxt_ul').removeClass('sno');
            $('#' + PerDetScrId + 'primaryKycFailedTxt_ul').addClass('sno');
        } else if (custData.primaryKycIdValStatus === "Inavalid Id") {
            $('#' + PerDetScrId + 'primaryKycVerifyBtn_ul').addClass('sno');
            $('#' + PerDetScrId + 'primaryKycVerifiedTxt_ul').addClass('sno');
            $('#' + PerDetScrId + 'primaryKycFailedTxt_ul').removeClass('sno');
        }
        if (custData.alternateVoterIdValStatus === "Verified") {
            $('#' + PerDetScrId + 'altVoterVerifyBtn_ul').addClass('sno');
            $('#' + PerDetScrId + 'altVoterVerifiedTxt_ul').removeClass('sno');
            $('#' + PerDetScrId + 'altVoterFailTxt_ul').addClass('sno');
        } else if (custData.alternateVoterIdValStatus === "Inavalid Id") {
            $('#' + PerDetScrId + 'altVoterVerifyBtn_ul').addClass('sno');
            $('#' + PerDetScrId + 'altVoterVerifiedTxt_ul').addClass('sno');
            $('#' + PerDetScrId + 'altVoterFailTxt_ul').removeClass('sno');
        }
        if (custData.secondaryKycIdValStatus === "Verified") {
            $('#' + PerDetScrId + 'secondaryKycVerifyBtn_ul').addClass('sno');
            $('#' + PerDetScrId + 'secondaryKycVerifiedTxt_ul').removeClass('sno');
            $('#' + PerDetScrId + 'secondaryKycFailTxt_ul').addClass('sno');
        } else if (custData.secondaryKycIdValStatus === "Inavalid Id") {
            $('#' + PerDetScrId + 'secondaryKycVerifyBtn_ul').addClass('sno');
            $('#' + PerDetScrId + 'secondaryKycVerifiedTxt_ul').addClass('sno');
            $('#' + PerDetScrId + 'secondaryKycFailTxt_ul').removeClass('sno');
            if (/aadhaar|aadhar/i.test(custData.secondaryKycType)) {
                $('#' + PerDetScrId + 'secondaryKycFailTxt_ul').addClass('sno');
            }
        } 
        }
    }
}
apz.app.PersonalDetails.dedupeServiceConfirmApplicantCB = function(params) {
    if (params.choice === true) {
        RejectReason = "Applicant Dedupe Check Failed.";
        ApzCOB.applicantKycFailedRejectService();
    } else {
        if (IS_ALTERNATE_DEDUPE) {
            $('#' + altVoterIdTag).val('');
        }
    }
};
apz.app.PersonalDetails.dedupeServiceConfirmCoApplicantCB = function(params) {
    if (IS_CO_APPLICANT_ALTERNATE_DEDUPE) {
        $('#' + altVoterIdTag).val('');
    } else {
        $('#' + PerDetScrId + "voterId").val('');
    }
    ApzCOB.toggleModal(PerDetScrId + 'dedupeCheckReject');
};
apz.app.PersonalDetails.addCoAppConfirmation = function(ptype) {
    let obj = {};
    obj.remarks = '';
    if(ptype === 'KYC') {
        obj.reason = 'KYCVerificationFailed';
    } else if(ptype === 'AGE') {
        obj.reason = 'AgeValidationFailed';
    } else if(ptype === 'DROPDOWN') {
        obj.reason = $(`#${PerDetScrId}newCoAppDpdn`).val();
        obj.remarks = $(`#${PerDetScrId}otherReason`).val();
    }
    ApzCOB.discardCoApplicant(obj);
};
apz.app.PersonalDetails.onChangeRelationWithApp = function() {
    var relationwithApp = apz.getElmValue(PerDetScrId + "relationwithApp").toLowerCase();
    apz.app.PersonalDetails.paintCoApplicantAddrData();
    if (relationwithApp === 'spouse'){
        spouseFlag = true;
        var name, custDetails = inSessionStore.customerDetailsList
        custDetails.forEach(function(i, k) {
            if (custDetails[k].customerType === "Applicant") {
                name = custDetails[k].customerName
            }
        })
        $(`#${PerDetScrId}spouseName`).val(name).focus();
        $(`#${PerDetScrId}maritalSts`).val("Married").change();
        ApzCOB.addDisableToInput(`${PerDetScrId}maritalSts`);
        ApzCOB.addDisableToInput(`${PerDetScrId}spouseName`);
        // $('#' + PerDetScrId + 'maritalSts').attr('disabled', true)
        // $('#' + PerDetScrId + 'spouseName').attr('disabled', true)
        $('#' + PerDetScrId + 'maritalSts_div').find('li').removeClass('is-selected hilt');
        $('#' + PerDetScrId + 'maritalSts_option_Married').addClass('is-selected hilt');
    } else {
                //-----------------------Swaroop Raj R (CR-90 Father name is not capturing) 19thNov2025----------------------------------------------
        ///in co-applicant is father/son making his father name mandatory and enabling input field (if it is disabled)
        if (relationwithApp === 'father' || relationwithApp === 'son') {
            ApzCOB.addFieldMandatory(PerDetScrId + 'fatherName');
            $('#' + PerDetScrId + 'fatherName').attr('disabled', false)
        }
        //-----------------------------------------------------------------------------------------------------------------------------------        

        //apz.app.PersonalDetails.setEmptyFields(fields,dropDrons);
        $.map(presentAddressFields, function(field) {
            $('#' + field).attr('disabled', false)
        });
        ApzCOB.AddOrRemoveDisableFields(pinCodeFieldsDropdowns, true);
        $(`#${PerDetScrId}spouseName`).val('');
        $(`#${PerDetScrId}maritalSts`).val(PleaseSelect).change();
        ApzCOB.removeDisableToInput(`${PerDetScrId}maritalSts`);
        ApzCOB.removeDisableToInput(`${PerDetScrId}spouseName`);
        // $('#' + PerDetScrId + 'spouseName').attr('disabled', false)
        $('#' + PerDetScrId + 'maritalSts_div').find('li').removeClass('is-selected hilt');
        $('#' + PerDetScrId + 'maritalSts_option_Please Select').addClass('is-selected hilt');
    }
    apz.app.PersonalDetails.permanentAddressSameAsPresentAddress();
    apz.app.PersonalDetails.communicationAddressSameAs()
    femArr = ["daughter", "daughter-in-law", "mother", "mother-in-law", "sister"];
    malArr = ["spouse", "brother", "father", "father-in-law", "son", "son-in-law"];
    genderVal = PleaseSelect
    if (relationwithApp === 'please select' || relationwithApp === 'others') {
        ApzCOB.removeDisableToInput(`${paintKYCId}gender`);
        $(`${ResGender}_div`).find('li').removeClass('is-selected hilt');
        $(`${ResGender}_div`).find('li').first().addClass('is-selected hilt');
    } else {
        ApzCOB.addDisableToInput(`${paintKYCId}gender`);
        femArr.forEach(function(el) {
            if (relationwithApp.toLowerCase() === el) {
                genderVal = 'Female';
            }
        })
        malArr.forEach(function(el) {
            if (relationwithApp.toLowerCase() === el) {
                genderVal = 'Male';
            }
        })
    }
    $(ResGender).val(genderVal);
    // var radioBtn = [PerDetScrId+'permanentAdd_option_Y',PerDetScrId+'permanentAdd_option_N',PerDetScrId+'commAddRadio_option_residential',PerDetScrId+'commAddRadio_option_permanent',PerDetScrId+'commAddRadio_option_business',PerDetScrId+'commAddRadio_option_other']
    // $.map(radioBtn, function(field) {
    //     $('#' + field).prop('checked', false)
    // });
}
apz.app.PersonalDetails.paintCoApplicantAddrData = function() {
    var address = inSessionStore.addressDetailsWrapperList[0].addressDetailsList
    var presentAddress = []
    if (!apz.isNull(inSessionStore.addressDetailsWrapperList[0].addressDetailsList)) {
        if (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.length > 1) {
            address.forEach(function(i, k) {
                if (address[k].addressType === 'Personal' && parseInt(address[k].custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                    presentAddress.push(address[k])
                    presentAddress = presentAddress[0].payload.addressList[0];
                }
            })
        } else {
            presentAddress = inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].payload.addressList[0]
        }
    }
    if (gApzCOB.currentApplicant > 1) {
        if (!apz.isNull(inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].payload.addressList[0]) && !apz.isNull(
            presentAddress)) {
            // var presentAddress = inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].payload.addressList[0]
            $(`#${PerDetScrId}addressLine1`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine1`, presentAddress.addressLine1 ?? '')).focus().blur();
            $(`#${PerDetScrId}addressLine2`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine2`, presentAddress.addressLine2 ?? '')).focus().blur();
            $(`#${PerDetScrId}addressLine3`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine3`, presentAddress.addressLine3 ?? '')).focus().blur();
            $(`#${PerDetScrId}pin`).val(presentAddress.pinCode).focus().blur();
            $(`#${PerDetScrId}city`).val(presentAddress.city).change();
            $(`#${PerDetScrId}district`).val(presentAddress.district).change();
            $(`#${PerDetScrId}state`).val(presentAddress.state).change();
            $(`#${PerDetScrId}country`).val(presentAddress.country).change();
            $(`#${PerDetScrId}presArea`).val(presentAddress.area).focus().blur();
            $(`#${PerDetScrId}presLandmark`).val(presentAddress.landMark ?? '').focus().blur();
            $(`#${PerDetScrId}ownership`).val(presentAddress.residenceOwnership).change();
            $(`#${PerDetScrId}cityYears`).val(presentAddress.residenceCitySince ? presentAddress.residenceCitySince?.replace('y', 'Y') : '');
            $(`#${PerDetScrId}resYears`).val(presentAddress.residenceAddressSince ? presentAddress.residenceAddressSince?.replace('y', 'Y') : '');
            if (!spouseFlag) {
                $(`#${PerDetScrId}cityYears`).change();
                $(`#${PerDetScrId}resYears`).change();
            }
            let currAddrProof = presentAddress.currentAddressProof;
            $(`#${PerDetScrId}currResProof`).val(apz.isNull(currAddrProof) ? PleaseSelect : currAddrProof).change();
            if(!apz.isNull(currAddrProof) && IS_REJECTED_APPLICATION && currAddrProof.toLowerCase() !== PleaseSelect.toLowerCase()) {
                ApzCOB.addDisableToInput("PerDRE__PersonalDetails__currResProof");
            }
            apz.app.PersonalDetails.onchangeTypeofHouse(presentAddress);
        }
        $.map(presentAddressFields, function(field) {
            $('#' + field).attr('disabled', true)
        });
    } else {
        $.map(presentAddressFields, function(field) {
            $('#' + field).attr('disabled', false)
        });
    }
};
apz.app.PersonalDetails.paintExistingLoans = function() {
    if (gApzCOB.currentApplicant <= 1) {
        earningLoanFlag = true;
        $(earningMemberDiv).addClass("sno");
        $('#PerDRE__PersonalDetails__gr_row_21').removeClass('active');
        $('#PerDRE__PersonalDetails__gr_row_21').addClass('sno');
        var existingLoanDtls = [];
        let existingLoansListSession = [];
        let existingLoansList = [];
        if (loanDtls.length > 0) {
            existingLoansList = loanDtls;
        } else {
            if (!apz.isNull(inSessionStore.existingLoanDetailsWrapperList) && inSessionStore.existingLoanDetailsWrapperList.length > 0) {
                if (inSessionStore.existingLoanDetailsWrapperList[0].hasOwnProperty("existingLoanDetailsList")) {
                    existingLoansListSession = inSessionStore.existingLoanDetailsWrapperList[0].existingLoanDetailsList;
                    if(existingLoansListSession.length > 0){
                        existingLoansListSession.map(existLoan => {
                            let exObj = {};
                            exObj.loanType = JSON.parse(existLoan.payload).productType;
                            exObj.loanId = existLoan.existingLoanId;
                            exObj.loanAmt = "-"
                            exObj.outstandingAmt = JSON.parse(existLoan.payload).outstandingAmount;
                            existingLoansList.push(exObj);   
                        })
                         
                    }
                }
            }
        }
        for (var i = 0; i < existingLoansList.length; i++) {
            if (existingLoansList[0].hasExistingLoans !== 'N') {
                var elem = {};
                elem.loanType = existingLoansList[i].loanType;
                elem.loanId = existingLoansList[i].loanId;
                elem.loanAmt = apz.isNull(existingLoansList[i].loanAmt) ? "" : ApzCOB.fn_FormatAmount(existingLoansList[i].loanAmt);
                elem.outstandingAmt = apz.isNull(existingLoansList[0].outstandingAmt) ? "" : ApzCOB.fn_FormatAmount(existingLoansList[i].outstandingAmt);
                existingLoanDtls.push(elem);
            }
        }
        exisLoanFlag = true;
        if (existingLoanDtls.length > 0) {
            $(ExistingLoansDiv).removeClass('sno');
            $(NoLoansDiv).addClass('sno');
            $('#PerDRE__PersonalDetails__gr_row_3').addClass('active');
            $('#PerDRE__PersonalDetails__gr_row_3').removeClass('sno');
            apz.data.scrdata.PerDRE__IPaintLoanDetails_Res = existingLoanDtls;
            apz.data.loadData('IPaintLoanDetails', apz.currAppId);
        } else {
            $(ExistingLoansDiv).addClass('sno');
            $(NoLoansDiv).removeClass('sno');
        }
    } else {
        exisLoanFlag = true;
        $(ExistingLoansDiv).addClass("sno");
        $(NoLoansDiv).addClass("sno");
        $('#PerDRE__PersonalDetails__gr_row_3').removeClass('active');
        $('#PerDRE__PersonalDetails__gr_row_3').addClass('sno');
        if (earningMembersDtls.length > 0) {
            earningLoanFlag = true;
            $(earningMemberDiv).addClass("sno");
            $('#PerDRE__PersonalDetails__gr_row_21').removeClass('active');
            $('#PerDRE__PersonalDetails__gr_row_21').addClass('sno');
            apz.data.scrdata.PerDRE__IPaintEarnMemDtls_Res = earningMembersDtls;
            apz.data.loadData('IPaintEarnMemDtls', apz.currAppId);
        }
        $('#PerDRE__PersonalDetails__personalDetForm').click();
    }
}
apz.app.PersonalDetails.onLoadPaintData = function() {
    if (gApzCOB.currentApplicant <= 1) {
        var cstDtls = gApzCOB.selLeadDtls;
        var customerName = cstDtls.fullName;
        var customerID = cstDtls.customerId;
        var gender = cstDtls.gender;
        var dateOfBirth = ApzCOB.dateformatter(cstDtls.dob, 'd/m/Y');
        var mobileNum = cstDtls.mobileNo;
        var occupations = cstDtls.occupation;
        var age = ApzCOB.getAge(dateOfBirth);
        $('#' + PerDetScrId + 'customerTxt_txtcnt').text(customerName);
        $('#' + PerDetScrId + 'customerGenderAgeTxt_txtcnt').text(gender + ' | ' + age);
        $('#' + paintKYCId + 'title').val('Mrs');
        $(`#${paintKYCId}name`).val(ApzCOB.getSubstrValue(`#${paintKYCId}name`, customerName ?? '')).trigger("onblur");
        //$('#' + paintKYCId + 'name').val(customerName).trigger("onblur");
        // $('#' + paintKYCId + 'firstname').val(cstDtls.firstName);
        // $('#' + paintKYCId + 'midname').val(cstDtls.middleName);
        $('#' + PerDetScrId + 'custAge').val(age).change();
        $('#' + PerDetScrId + 'custId').val(customerID);
        $('#' + paintKYCId + 'gender').val(gender);
        $('#' + paintKYCId + 'dob').val(dateOfBirth);
        $('#' + paintKYCId + 'dob').trigger('blur');
        $('#' + paintKYCId + 'mobNum').val(mobileNum).trigger('change');
        // $('#' + PerDetScrId + 'occupations').val(occupations);
        $('#' + PerDetScrId + 'custType').val(apz.isNull(cstDtls.customerType) ? '' : cstDtls.customerType.trim());
        $('#' + PerDetScrId + 'maritalSts').val(apz.isNull(cstDtls.maritalStatus) ? '' : ApzCOB.capitalize(cstDtls?.maritalStatus.trim())).change();
        $('#' + PerDetScrId + 'MartialStatusDiv').find('li').removeClass('is-selected hilt')
        $('#' + PerDetScrId + 'maritalSts_option_' + $('#' + PerDetScrId + "maritalSts").val()).addClass('is-selected hilt');
        // apz.app.PersonalDetails.maritalStatusOnChange($('#' + PerDetScrId + 'maritalSts').val());
       /* fatherNameInputTag.val(apz.isNull(cstDtls.fathersName) ? "" : cstDtls.fathersName);
        spouseNameInputTag.val(apz.isNull(cstDtls.spouseName) ? "" : cstDtls.spouseName);*/
        fatherNameInputTag.val(ApzCOB.getSubstrValue(`#${PerDetScrId}fatherName`, cstDtls.fathersName ?? ''));
        spouseNameInputTag.val(ApzCOB.getSubstrValue(`#${PerDetScrId}spouseName`, cstDtls.spouseName ?? ''));
        $('#' + PerDetScrId + 'aadhaarNum').val(apz.isNull(cstDtls.aadhaarNumber) ? "" : cstDtls.aadhaarNumber);
        $('#' + PerDetScrId + 'primaryKYC').val("Voter ID");
        $('#' + PerDetScrId + 'voterId').val(apz.isNull(cstDtls.primaryKyc) ? '' : cstDtls.primaryKyc.trim()).keyup();
        // $('#' + secondaryKycIdTag).val('');
        $('#' + PerDetScrId + 'panNumber').val(apz.isNull(cstDtls.panCardNumber) ? "" : cstDtls.panCardNumber);
        // $('#' + secondaryKycTypeTagId).val(apz.isNull(cstDtls.kycType) ? memberArr.kycType : PleaseSelect);
        // $('#' + secondaryKycTypeTagId).val(apz.isNull(cstDtls.kycType) ? PleaseSelect : cstDtls.kycType.trim());
        $('#' + PerDetScrId + 'religion').val(apz.isNull(cstDtls.religion) ? PleaseSelect : cstDtls.religion.trim()).change();
        $('#' + PerDetScrId + 'caste').val(apz.isNull(cstDtls.caste) ? PleaseSelect : cstDtls.caste.trim()).change();
        $('#' + PerDetScrId + 'education').val(apz.isNull(cstDtls.education) ? PleaseSelect : cstDtls.education.trim()).change();
        $('#' + PerDetScrId + 'occupations').val(apz.isNull(cstDtls.occupation) ? PleaseSelect : cstDtls.occupation.trim()).change();
        $(`#${PerDetScrId}cKYC`).val(apz.isNull(cstDtls.applicantCkyc) ? '' : cstDtls.applicantCkyc.trim());
        $(`#${PerDetScrId}branchEmail`).val(apz.isNull(cstDtls.emailId) ? '' : cstDtls.emailId.trim()).blur();
    }
};
apz.app.PersonalDetails.onClickEarningMemberDtlsList = function(pthis) {
    var rowNo = $(pthis).attr('rowno');
    var selIndexId = '#PerDRE__IPaintEarnMemDtls__o__PerDRE__IPaintEarnMemDtls_Res__';
    var customerName = $(selIndexId + 'name_' + rowNo).text();
    var dateOfBirth = $(selIndexId + 'dob_' + rowNo).text();
    var voterID = $(selIndexId + 'voterId_' + rowNo).text();
    var panNum = $(selIndexId + 'pancard_' + rowNo).text();
    var mobileNum = $(selIndexId + 'mobileNo_' + rowNo).text();
    var occupations = $(selIndexId + 'occupation_' + rowNo).text();
    var memberArr = [];
    for (var i = 0; i < earningMembersDtls.length; i++) {
        if (earningMembersDtls[i].name === customerName) {
            memberArr = earningMembersDtls[i];
        }
    }
    $('#' + paintKYCId + 'title').val(memberArr.title);
    $('#' + paintKYCId + 'firstname').val(memberArr.firstName);
    $('#' + paintKYCId + 'midname').val(memberArr.middleName);
    $('#' + paintKYCId + 'lastname').val(memberArr.lastName);
    $('#' + paintKYCId + 'name').val(customerName);
    $('#' + PerDetScrId + 'voterId').val(voterID);
    $('#' + PerDetScrId + 'panNumber').val(panNum);
    $('#' + paintKYCId + 'mobNum').val(mobileNum);
    $('#' + PerDetScrId + 'occupations').val(occupations);
    $('#' + paintKYCId + 'dob').val(dateOfBirth);
    $('#' + paintKYCId + 'dob').trigger('blur');
    $('#' + PerDetScrId + 'custId').val(memberArr.customerID);
    $('#' + paintKYCId + 'gender').val(memberArr.gender);
    $('#' + PerDetScrId + 'custType').val(memberArr.customerType);
    $('#' + PerDetScrId + 'maritalSts').val(ApzCOB.capitalize(memberArr.maritalStatus));
    $('#' + PerDetScrId + 'MartialStatusDiv').find('li').removeClass('is-selected hilt')
    $('#' + PerDetScrId + 'maritalSts_option_' + $('#' + PerDetScrId + "maritalSts").val()).addClass('is-selected hilt');
    fatherNameInputTag.val(memberArr.fathersName);
    $('#' + PerDetScrId + 'aadhaarNum').val(memberArr.aadhaarNumber);
    // $('#' + secondaryKycIdTag).val(memberArr.kycNumber);
    $('#' + PerDetScrId + 'relationwithApp').val(memberArr.relationship);
    $('#' + PerDetScrId + 'nameasKYC').val(customerName);
    $('#' + secondaryKycIdTag).val('');
    $('#' + secondaryKycTypeTagId).val(memberArr.kycType ? memberArr.kycType : PleaseSelect);
    apz.app.PersonalDetails.onclickAddCoAppl();
};
