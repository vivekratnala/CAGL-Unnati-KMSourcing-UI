apz.app.PersonalDetails.verifyPan = function() {
    window.isMobErr = false;
    window.isValid = false;
    var Demo = true
    if (gApzCOB.demoMode === "N") {
        if (!apz.isNull($('#' + paintKYCId + 'mobNum').val())) {
            ApzCOB.fnValidateMobileNumber(paintKYCId + 'mobNum');
            document.getElementById(paintKYCId + 'mobNum').scrollIntoView({
                behavior: "smooth",
                block: "center",
                inline: "center"
            })
        }
        if ($("#" + PerDetScrId + 'perDetailsDiv').is(':visible') && !window.isMobErr) {
            apz.app.PersonalDetails.LoadPanStatus();
            /*if (panEnabledorDisabled === "Y" && panMandatory === "M") {
                if ((panVerifybutton === "Y" && window.panVerified) || (window.panWithoutService && panMandatory === "N")) {
                    window.isValid = true;
                } else {
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_PERDTLS_PANDTLS_ERR_TXT_VERIFYPAN"), "E");
                }
            } else {
                window.isValid = true;
            }*/
        } else {
            window.isMobErr = false;
            window.isValid = false;
        }
        return window.isValid;
    } else {
        return Demo
    }
};
