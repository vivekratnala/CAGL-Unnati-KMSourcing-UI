apz.app.PersonalDetails.validatePerAddress = function() {
    var isValid = true;
    if (gApzCOB.demoMode === "N") {
        // errorCount = 0;
        STAGES.forEach(function(m, n) {
            ConfigureScrJson.forEach(function(i, k) {
                if (Number(CURRENT_STAGE_NO) === parseInt(m.split('~')[1].toUpperCase()) && i.confParamName === m.split('~')[0]
                    .toUpperCase()) {
                    var FormValidator = {
                        0: 'addressDetailsRow'
                    };
                    if (!apz.isNull(FormValidator)) {
                        $.each(FormValidator, function(a, b) {
                            var form = "",
                                form_validator_check = {};
                            form = $("#" + i.MicroAppID + '__' + i.ScreenID + '__' + b).find("input");
                            for (let n = 0; n < form.length; n++) {
                                form_validator_check = {
                                    [form[n]['id']]: {
                                        verify: nullcheck,
                                        dropDown
                                    }
                                };
                                isValid = ApzCOB.validateInputFields(form, n, form_validator_check);
                            }
                        })
                    } else {
                        isValid = true;
                    }
                }
            })
        })
    }
    return isValid;
}
apz.app.PersonalDetails.LoadPanStatus = function() {
    if (panEnabledorDisabled === "Y" && panMandatory === "M") {
        if ((panVerifybutton === "Y" && window.panVerified) || (window.panWithoutService && panMandatory === "N")) {
            window.isValid = true;
        } else {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_PERDTLS_PANDTLS_ERR_TXT_VERIFYPAN"), "E");
        }
    } else {
        window.isValid = true;
    }
}
apz.app.PersonalDetails.onChangeAddressRadio = function() {
    let optY = '#PerDRE__PersonalDetails__AddrAsperAadharRadio_option_Y';
    let optN = '#PerDRE__PersonalDetails__AddrAsperAadharRadio_option_N';
    if ($(optY).is(':checked')) {
        var leaddata = gApzCOB.selLeadDtls[0].commAddr;
        $(`#${PerDetScrId}addressLine1`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine1`, leaddata.addressline1));
        $(`#${PerDetScrId}addressLine2`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine2`, leaddata.addressline2));
        $(`#${PerDetScrId}addressLine3`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine3`, leaddata.addressline3));
        $(`#${PerDetScrId}pin`).val(leaddata.pincode);
        $(`#${PerDetScrId}city`).val(leaddata.city);
        $(`#${PerDetScrId}district`).val(leaddata.district);
        $(`#${PerDetScrId}state`).val(leaddata.state);
        $(`#${PerDetScrId}country`).val(leaddata.country);
        $(resDtlsDiv).find('.ett-inpt').attr('disabled', true);
        $('#' + PerDetScrId + 'ownershipDiv').addClass('sno');
        $('#' + PerDetScrId + 'residenceYearsMonthsDiv').addClass('sno');
        $('#' + PerDetScrId + 'cityYearsMonthsDiv').addClass('sno');
        $('#' + PerDetScrId + 'currResProofRow').addClass('sno');
        $('#' + PerDetScrId + 'typeHouseRow').addClass('sno');
    } else if ($(optN).is(':checked')) {
        $('#' + PerDetScrId + 'currResProofRow').removeClass('sno');
        $('#' + PerDetScrId + 'typeHouseRow').removeClass('sno');
        $(resDtlsDiv).find('.ett-inpt').attr('disabled', false);
        $(resDtlsDiv).find('.ett-inpt').val("");
        $('#' + PerDetScrId + 'ownershipDiv').removeClass('sno');
        $('#' + PerDetScrId + 'residenceYearsMonthsDiv').removeClass('sno');
        $('#' + PerDetScrId + 'cityYearsMonthsDiv').removeClass('sno');
        $('#' + PerDetScrId + 'currResProofRow').removeClass('sno');
        $('#' + PerDetScrId + 'typeHouseRow').removeClass('sno');
    }
};
apz.app.PersonalDetails.lengthvalidator = function(pthis, max) {
    var maxlength = max;
    var p = pthis.value;
    pthis.value = p.substr(0, maxlength);
};
apz.app.PersonalDetails.panRegex = function() {
    var regex = /[A-Z]{5}[0-9]{4}[A-Z]{1}$/;
    var panNum = $('#' + PerDetScrId + 'panNumber').val().toLocaleUpperCase();
    if (panNum.length === 10 && regex.test(panNum)) {
        $('#' + PerDetScrId + 'panError').removeClass('err-msg');
        $('#' + PerDetScrId + 'panError').addClass('sno')
    } else {
        $('#' + PerDetScrId + 'panError').addClass('err-msg');
        $('#' + PerDetScrId + 'panError').removeClass('sno');
    }
}
apz.app.PersonalDetails.onLoadCollapseAll = function() {
    $(persDtlsDiv).addClass('sno');
    $(resDtlsDiv).addClass('sno');
    $(personalDetailsParentDiv).removeClass('active');
    $('#PerDRE__PersonalDetails__gr_row_15').removeClass('active');
    ['existingDown', 'personalUp', 'addressUp'].hide();
    ['existingUp', 'personalDown', 'addressDown'].show();
    ApzCOB.addFieldMandatory(PerDetScrId + 'PAN_DropDown');
}
apz.app.PersonalDetails.onclickExistingLoans = function(pthis) {
    if ($(ExistingLoansDiv).is(":visible") || $(NoLoansDiv).is(":visible")) {
        ['existingUp', 'personalDown', 'addressDown'].hide();
        ['existingDown', 'personalUp', 'addressUp'].show();
        $(ExistingLoansDiv).addClass("sno");
        $(NoLoansDiv).addClass("sno");
        $('#PerDRE__PersonalDetails__gr_row_3').removeClass('active');
    } else {
        exisLoanFlag = true;
        $('#PerDRE__PersonalDetails__gr_row_3').addClass('active');
        $(personalDetailsParentDiv).removeClass('active');
        $('#PerDRE__PersonalDetails__gr_row_15').removeClass('active');
        $('#PerDRE__PersonalDetails__gr_row_21').removeClass('active');
        $(persDtlsDiv).addClass("sno");
        $(resDtlsDiv).addClass("sno");
        $(earningMemberDiv).addClass("sno");
        ['existingUp', 'personalDown', 'addressDown'].show();
        ['existingDown', 'personalUp', 'addressUp'].hide();
        if (apz.data.scrdata.PerDRE__IPaintLoanDetails_Res.length > 0) {
            $(ExistingLoansDiv).removeClass("sno");
            $(NoLoansDiv).addClass("sno");
        } else {
            $(ExistingLoansDiv).addClass("sno");
            $(NoLoansDiv).removeClass("sno");
        }
    }
    apz.app.PersonalDetails.continueBtn();
}
apz.app.PersonalDetails.onclickPersonalDtls = function(pthis) {
    if (apz.isNull(window.toggleEvents)) {
        ApzCOB.getToggleOnClickEventObj();
    }
    if ($(persDtlsDiv).is(":visible")) {
        ['existingDown', 'personalUp', 'addressDown'].hide();
        ['existingUp', 'personalDown', 'addressUp'].show();
        $(persDtlsDiv).addClass("sno");
        $(personalDetailsParentDiv).removeClass('active');
    } else {
        perDetFLag = true;
        $(persDtlsDiv).removeClass("sno");
        $(personalDetailsParentDiv).addClass('active');
        $("#" + PerDetScrId + 'existingSuccess_ul').removeClass("sno");
        $("#" + PerDetScrId + 'earningSuccess_ul').removeClass('sno');
        $(resDtlsDiv).addClass("sno");
        $('#PerDRE__PersonalDetails__gr_row_15').removeClass('active');
        $(ExistingLoansDiv).addClass("sno");
        $(NoLoansDiv).addClass("sno");
        $(earningMemberDiv).addClass("sno");
        $('#PerDRE__PersonalDetails__gr_row_3').removeClass('active');
        $('#PerDRE__PersonalDetails__gr_row_21').removeClass('active');
        ['existingDown', 'personalUp', 'addressDown'].show();
        ['existingUp', 'personalDown', 'addressUp'].hide();
    }
    apz.app.PersonalDetails.continueBtn();
    let toggleDivID = pthis.id;
    let toggleEventListIndex = window.toggleEvents.findIndex((item) => item.toggleID === pthis.id);
    ApzCOB.addEventToNextToggle(toggleEventListIndex);
}
apz.app.PersonalDetails.onclickResidenceDtls = function(pthis) {
    let validateForm = ApzCOB.fnformValidator(PerDetScrId, 'ct_frm_1');
    if (apz.app.PersonalDetails.validateMobNumInputFields()) {
        if (validateForm) {
            let checkKycValidated = apz.app.PersonalDetails.kycValidationCheck();
            let checkpanValidated = apz.app.PersonalDetails.panValidationCheck();
            if (checkKycValidated && checkpanValidated) {
                if ($(resDtlsDiv).is(":visible")) {
                    $(resDtlsDiv).addClass("sno");
                    $('#PerDRE__PersonalDetails__gr_row_15').removeClass('active');
                    ['existingDown', 'personalDown', 'addressUp'].hide();
                    ['existingUp', 'personalUp', 'addressDown'].show();
                } else {
                    ApzCOB.scrollToTop();
                    appAddrFlag = true;
                    $(resDtlsDiv).removeClass("sno");
                    $('#PerDRE__PersonalDetails__gr_row_15').addClass('active');
                    $("#" + PerDetScrId + 'existingSuccess_ul').removeClass("sno");
                    $("#" + PerDetScrId + 'earningSuccess_ul').removeClass('sno');
                    $("#" + PerDetScrId + 'personalSuccess_ul').removeClass("sno");
                    $(ExistingLoansDiv).addClass("sno");
                    $(NoLoansDiv).addClass("sno");
                    $(persDtlsDiv).addClass("sno");
                    $(earningMemberDiv).addClass("sno");
                    $('#PerDRE__PersonalDetails__gr_row_3').removeClass('active');
                    $(personalDetailsParentDiv).removeClass('active');
                    $('#PerDRE__PersonalDetails__gr_row_21').removeClass('active');
                    ['existingDown', 'personalDown', 'addressUp'].show();
                    ['existingUp', 'personalUp', 'addressDown'].hide();
                }
                apz.app.PersonalDetails.continueBtn();
            }
        } else {
            if (!$(persDtlsDiv).is(":visible")) {
                let toggleDivID = pthis.id;
                let toggleEventListIndex = window.toggleEvents.findIndex((item) => item.toggleID === pthis.id);
                $('#' + window.toggleEvents[toggleEventListIndex - 1].toggleID).click();
            }
            $("#" + PerDetScrId + 'personalSuccess_ul').addClass("sno");
        }
    } else {
        $('#' + PerDetScrId + 'MobileNumberDiv .err')[0].scrollIntoView();
    }
    if ($("#PerDRE__PersonalDetails__occupations").val() === "Self Employed") {
        apz.app.PersonalDetails.validateOccupation();
    } else {
        // Do nothing
    }
}
apz.app.PersonalDetails.onclickEarnMemDtls = function(pthis) {
    if ($(earningMemberDiv).is(":visible")) {
        $(earningMemberDiv).addClass("sno");
        $('#PerDRE__PersonalDetails__gr_row_21').removeClass('active');
    } else {
        earningLoanFlag = true;
        $(earningMemberDiv).removeClass("sno");
        $('#PerDRE__PersonalDetails__gr_row_21').addClass('active');
        $('#PerDRE__PersonalDetails__gr_row_3').removeClass('active');
        $(personalDetailsParentDiv).removeClass('active');
        $('#PerDRE__PersonalDetails__gr_row_15').removeClass('active');
        $(ExistingLoansDiv).addClass("sno");
        $(NoLoansDiv).addClass("sno");
        $(persDtlsDiv).addClass("sno")
        $("#" + PerDetScrId + 'existingSuccess_ul').removeClass("sno");
    }
}
apz.app.PersonalDetails.onclickAddCoAppl = function(pthis) {
    perDetFLag = true;
    $(persDtlsDiv).removeClass('sno');
    $(earningMemberDiv).addClass('sno');
    if (pthis) {
        $('#PerDRE__PersonalDetails__ct_frm_1').find("input").val("");
        $('#PerDRE__PersonalDetails__custType').val("New");
        $('#PerDRE__PersonalDetails__regnFlag').val("+91");
        $('#PerDRE__PersonalDetails__secKYC').val(PleaseSelect);
    }
    $('#PerDRE__PersonalDetails__gr_row_21').removeClass('active');
    $(personalDetailsParentDiv).addClass('active');
}
apz.app.PersonalDetails.continueBtn = function() {
    if (exisLoanFlag && perDetFLag && appAddrFlag && earningLoanFlag) {
        $('#APZCBO__BaseScreens__continue').attr('disabled', false);
    } else {
        $('#APZCBO__BaseScreens__continue').attr('disabled', true);
    }
};
apz.app.PersonalDetails.onchangeTypeofHouse = function(param) {
    let optHT1 = '#PerDRE__PersonalDetails__el_rdo_1_option_HouType1';
    let optHT2 = '#PerDRE__PersonalDetails__el_rdo_1_option_HouType2';
    let optHT3 = '#PerDRE__PersonalDetails__el_rdo_1_option_HouType3';
    if (apz.isNull(param)) {
        window.houseTypechoose = '';
        if ($(optHT1).is(':checked')) {
            window.houseTypechoose = ApzCOB.getDescfromLitCode("LIT_TYP_HOUSE_OPT1");
        } else if ($(optHT2).is(':checked')) {
            window.houseTypechoose = ApzCOB.getDescfromLitCode("LIT_TYP_HOUSE_OPT2");
        } else if ($(optHT3).is(':checked')) {
            window.houseTypechoose = ApzCOB.getDescfromLitCode("LIT_TYP_HOUSE_OPT3");
        }
    } else {
        let optHT = param.houseType;
        window.houseTypechoose = optHT;
        if (optHT === 'Kuccha') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_1_option_HouType1").checked = true;
            $(optHT1).focus();
        } else if (optHT === 'Pucca') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_1_option_HouType2").checked = true;
            $(optHT2).focus();
        } else if (optHT === 'Semi Pucca') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_1_option_HouType3").checked = true;
            $(optHT3).focus();
        }
    }
};
apz.app.PersonalDetails.onchangecommAddr = function(param) {
    if (apz.isNull(param)) {
        window.commAddr = '';
        let ComAddr1 = '#PerDRE__PersonalDetails__el_rdo_2_option_ComAddr1';
        let ComAddr2 = '#PerDRE__PersonalDetails__el_rdo_2_option_ComAddr2';
        let ComAddr3 = '#PerDRE__PersonalDetails__el_rdo_2_option_ComAddr3';
        if ($(ComAddr1).is(':checked')) {
            window.commAddr = ApzCOB.getDescfromLitCode("LIT_COMADD_OPT1");
        } else if ($(ComAddr2).is(':checked')) {
            window.commAddr = ApzCOB.getDescfromLitCode("LIT_COMADD_OPT2");
        } else if ($(ComAddr3).is(':checked')) {
            window.commAddr = ApzCOB.getDescfromLitCode("LIT_COMADD_OPT3");
        }
    } else {
        let optComAddr = param.communctionAddress;
        if (optComAddr === 'Permanent Address') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_2_option_ComAddr1").checked = true;
        } else if (optComAddr === 'Residential Address') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_2_option_ComAddr2").checked = true;
        } else if (optComAddr === 'Business Address') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_2_option_ComAddr3").checked = true;
        }
    }
};
apz.app.PersonalDetails.onchangeLoc_CoordFor = function(param) {
    if (apz.isNull(param)) {
        window.loc_CordFor = '';
        let LOCCORD1 = '#PerDRE__PersonalDetails__el_rdo_4_option_LOCCORD1';
        let LOCCORD2 = '#PerDRE__PersonalDetails__el_rdo_4_option_LOCCORD2';
        let LOCCORD3 = '#PerDRE__PersonalDetails__el_rdo_4_option_LOCCORD3';
        if ($(LOCCORD1).is(':checked')) {
            window.loc_CordFor = ApzCOB.getDescfromLitCode("LIT_COMADD_OPT1");
        } else if ($(LOCCORD2).is(':checked')) {
            window.loc_CordFor = ApzCOB.getDescfromLitCode("LIT_COMADD_OPT2");
        } else if ($(LOCCORD3).is(':checked')) {
            window.loc_CordFor = ApzCOB.getDescfromLitCode("LIT_COMADD_OPT3");
        }
        if (apz.deviceType === "WEB") {
            ApzCOB.getGeoCordinates();
        } else {
            ApzCOB.getGeoCordinatesMobile();
        }
    } else {
        let optComAddr = param.locateCoOrdinatesFor;
        if (optComAddr === 'Permanent Address') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_4_option_LOCCORD1").checked = true;
        } else if (optComAddr === 'Present Address') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_4_option_LOCCORD2").checked = true;
        } else if (optComAddr === 'Business Address') {
            document.getElementById("PerDRE__PersonalDetails__el_rdo_4_option_LOCCORD3").checked = true;
        }
    }
};
apz.app.PersonalDetails.onchangepincode = function(pthis, addressType) {
    let pincode_temp = $(pthis).val();
    if (pincode_temp.length > 5) {
        window.pincodeAddresstype = addressType;
        ApzCOB.fetchpincodeDtls(pincode_temp, "per");
    }
};
apz.app.PersonalDetails.paint_pincode = function(params) {
    //   $(`#${PerDetScrId}pin`).val(params.pinCode);
    if (window.pincodeAddresstype === "present") {
        $(`#${PerDetScrId}city`).val(params.city).blur();
        $(`#${PerDetScrId}district`).val(params.district).blur();
        $(`#${PerDetScrId}state`).val(params.state).blur();
        $(`#${PerDetScrId}country`).val(params.country).blur();
        $(`#${PerDetScrId}presArea`).val(params.area).blur();
    } else if (window.pincodeAddresstype === "permanent") {
        $(`#${PerDetScrId}permanentcity`).val(params.city).blur();
        $(`#${PerDetScrId}permanentDist`).val(params.district).blur();
        $(`#${PerDetScrId}permanentState`).val(params.state).blur();
        $(`#${PerDetScrId}permanentCountry`).val(params.country).blur();
        $(`#${PerDetScrId}permArea`).val(params.area).blur();
    } else if (window.pincodeAddresstype === "communication") {
        $(`#${PerDetScrId}commCity`).val(params.city).blur();
        $(`#${PerDetScrId}commDist`).val(params.district).blur();
        $(`#${PerDetScrId}commState`).val(params.state).blur();
        $(`#${PerDetScrId}commCountry`).val(params.country).blur();
        $(`#${PerDetScrId}commArea`).val(params.area).blur();
    }
};
apz.app.PersonalDetails.permanentAddressSameAsPresentAddress = function() {
    var permanentAdd = apz.getElmValue(PerDetScrId + "permanentAdd")
    if (permanentAdd === 'Y') {
        apz.app.PersonalDetails.copyAddress(residentialAddressFields, permanentAddressFields, "elements");
        $('#' + PerDetScrId + 'commAddRadio_option_permanent').attr('disabled', true);
        ApzCOB.removeErrMessgae(permanentAddressFields, "array");
        // $('input[name="PerDRE__PersonalDetails__commAddRadio_"]').prop('checked',false);
    } else if (permanentAdd === 'N') {
        apz.app.PersonalDetails.setEmptyFields(permanentAddressFields, permanentAddressDropdowns);
        $.map(permanentAddressFields, function(field) {
            $('#' + field).attr('disabled', false)
        });
        $('#' + PerDetScrId + 'commAddRadio_option_permanent').attr('disabled', false);
    }
}
apz.app.PersonalDetails.communicationAddressSameAs = function() {
    var commAddRadio = apz.getElmValue(PerDetScrId + "commAddRadio");
    let copyFrom = [],
        copyType = "elements";
    if (commAddRadio === 'present') {
        copyFrom = residentialAddressFields;
        copyType = "elements";
    } else if (commAddRadio === 'permanent') {
        copyFrom = permanentAddressFields;
        copyType = "elements";
    } else if (commAddRadio === 'business') {
        copyFrom = []; // business Address values Array here
        copyType = "values";
        apz.app.PersonalDetails.setEmptyFields(communicationAddressFields);
    } else {
        copyFrom = [];
    }
    if (copyFrom.length > 0) {
        apz.app.PersonalDetails.copyAddress(copyFrom, communicationAddressFields, copyType);
        ApzCOB.removeErrMessgae(communicationAddressFields, "array");
    } else {
        // apz.app.PersonalDetails.setEmptyFields(communicationAddressFields);
        $.map(communicationAddressFields, function(field) {
            $('#' + field).attr('disabled', false)
        });
    }
}
apz.app.PersonalDetails.setEmptyFields = function(fields, dropDown) {
    $.map(fields, function(field) {
        apz.setElmValue(field, "");
    });
    $.map(dropDown, function(field) {
        // apz.setElmValue(field, "-1")
        $(`#${field}`).val(PleaseSelect);
    });
}
//$('#' + PerDetScrId + 'panNumber').attr('disabled', false)
// Code From Sharath 09/Jan/2024
apz.app.PersonalDetails.personalDetailValidation = function() {
    window.errorCount = 0;
    let validationStatus;
    let personalDetailsFormID = 'ct_frm_1';
    var form = "",
        form_validator_check = {};
    form = $("#" + PerDetScrId + personalDetailsFormID).find(".input-field:not(.sno) input");
    for (var n = 0; n < form.length; n++) {
        form_validator_check = {
            [form[n]['id']]: {
                verify: nullcheck,
                dropDown: dropDown
            }
        };
        validationStatus = ApzCOB.validateInputFields(form, n, form_validator_check);
    }
    return validationStatus;
}
apz.app.PersonalDetails.maritalStatusOnChange = function(maritalStatusValue) {
    if (maritalStatusValue !== "Please Select") {
        if (maritalStatusValue.toUpperCase() === "MARRIED") {
            ApzCOB.addFieldMandatory(PerDetScrId + 'spouseName');
            ApzCOB.removeFieldMandatory(PerDetScrId + 'fatherName');
            $('#' + PerDetScrId + 'fatherName').attr('disabled', true)
            $('#' + PerDetScrId + 'spouseName').attr('disabled', false)
            $('#' + PerDetScrId + 'fatherName').val('')
            //in co-applicant is spouse/son and he is married making father name mandatory and enabling input field (if it is disabled)
            var relationwithApp = apz.getElmValue(PerDetScrId + "relationwithApp").toLowerCase();
            if (relationwithApp === 'spouse' || relationwithApp === 'son' || relationwithApp === 'father')
                ApzCOB.addFieldMandatory(PerDetScrId + 'fatherName');
            $('#' + PerDetScrId + 'fatherName').attr('disabled', false)
        } else {
            ApzCOB.addFieldMandatory(PerDetScrId + 'fatherName');
            ApzCOB.removeFieldMandatory(PerDetScrId + 'spouseName');
            $('#' + PerDetScrId + 'spouseName').attr('disabled', true)
            $('#' + PerDetScrId + 'fatherName').attr('disabled', false)
            $('#' + PerDetScrId + 'spouseName').val('')
        }
    }
}
apz.app.PersonalDetails.copyAddress = function(copyFrom, copyTo, copyType) {
    if (copyType === "elements") {
        if (copyFrom.length > 0 && (copyFrom.length === copyTo.length)) {
            for (let c = 0; c < copyFrom.length; c++) {
                $('#' + copyTo[c]).val(document.getElementById(copyFrom[c]).value)
                //   apz.setElmValue(copyTo[c], );
            }
            $.map(copyTo, function(field) {
                $('#' + field).attr('disabled', true)
            });
        }
    }
}
apz.app.PersonalDetails.primaryKycVerification = function() {
    IS_CO_APPLICANT_PRIMARY_DEDUPE = false;
    IS_CO_APPLICANT_SECONDARY_DEDUPE = false;
    IS_CO_APPLICANT_ALTERNATE_DEDUPE = false;
    IS_APPLICANT_PRIMARY_DEDUPE = false;
    IS_ALTERNATE_DEDUPE = false;
    let isValid = ApzCOB.validateEachInputField(PerDetScrId + 'voterId');
    if (isValid) {
        window.kycVerificationType = "primary";
        var kycObj = {};
        kycObj.kycType = "voter";
        kycObj.kycId = $('#' + PerDetScrId + 'voterId').val().trim().toLocaleUpperCase();
        if (gApzCOB.currentApplicant > 1) {
            IS_CO_APPLICANT_PRIMARY_DEDUPE = true;
        } else {
            IS_APPLICANT_PRIMARY_DEDUPE = true;
        }
         ApzCOB.KycDedupeCheck(kycObj.kycId);
    }
}
apz.app.PersonalDetails.altVoterIdVerification = function() {
    IS_CO_APPLICANT_PRIMARY_DEDUPE = false;
    IS_CO_APPLICANT_SECONDARY_DEDUPE = false;
    IS_APPLICANT_PRIMARY_DEDUPE = false;
    let isValidKycId = ApzCOB.validateEachInputField(altVoterIdTag);
    if (isValidKycId) {
        window.kycVerificationType = "alternate";
        var kycObj = {};
        kycObj.kycType = "voter";
        kycObj.kycId = $('#' + altVoterIdTag).val().trim().toLocaleUpperCase();
        if (gApzCOB.currentApplicant > 1) {
            IS_CO_APPLICANT_ALTERNATE_DEDUPE = true;
        } else {
            IS_ALTERNATE_DEDUPE = true;
        }
        ApzCOB.KycDedupeCheck(kycObj.kycId);
    }
}
apz.app.PersonalDetails.secondaryKycVerification = function() {
    // IS_CO_APPLICANT_PRIMARY_DEDUPE = false;
    // IS_CO_APPLICANT_SECONDARY_DEDUPE = false;
    let isValidKycType = ApzCOB.validateEachInputField(secondaryKycTypeTagId);
    let isValidKycId = ApzCOB.validateEachInputField(secondaryKycIdTag);
    if (isValidKycType && isValidKycId) {
        window.kycVerificationType = "secondary";
        var kycObj = {};
        kycObj.kycType = ApzCOB.getKycVerificationType($('#' + secondaryKycTypeTagId).val().trim());
        kycObj.kycId = $('#' + secondaryKycIdTag).val().toUpperCase().trim();
        ApzCOB.kycVerificationCheck(kycObj);
        /*if (kycObj.kycType === "voter") {
            if (gApzCOB.currentApplicant > 1) {
                IS_CO_APPLICANT_SECONDARY_DEDUPE = true;
            } else {
                IS_SECONDARY_DEDUPE = true;
            }
            ApzCOB.KycDedupeCheck(kycObj.kycId);
        } else {
            ApzCOB.kycVerificationCheck(kycObj);
        }*/
    }
}
apz.app.PersonalDetails.primaryVoterOnChange = function() {
    if (gApzCOB.currentApplicant <= 1) {
        if (PRIMARY_KYC_VERIFICATION) {
            $('#' + PerDetScrId + 'nameasKYC').val('');
        }
    } else {
        if (CO_APPLICANT_PRIMARY_KYC_VERIFICATION) {
            $('#' + PerDetScrId + 'nameasKYC').val('');
        }
    }
    PRIMARY_KYC_VERIFICATION = false;
    CO_APPLICANT_PRIMARY_KYC_VERIFICATION = false
    $('#' + PerDetScrId + 'primaryKycVerifyBtn_ul').removeClass('sno');
    $('#' + PerDetScrId + 'primaryKycVerifiedTxt_ul').addClass('sno');
    $('#' + PerDetScrId + 'primaryKycFailedTxt_ul').addClass('sno');
}
apz.app.PersonalDetails.altVoterOnChange = function() {
    if (ALTERNATE_KYC_VERIFICATION) {
        if (gApzCOB.currentApplicant <= 1) {
            if (PRIMARY_KYC_VERIFICATION) {
                apz.app.PersonalDetails.primaryKycVerification()
            }
        } else {
            $('#' + PerDetScrId + 'nameasKYC').val('');
        }
        $('#' + PerDetScrId + 'nameasKYC').val('');
    }
    ALTERNATE_KYC_VERIFICATION = false;
    
    $('#' + PerDetScrId + 'altVoterVerifyBtn_ul').removeClass('sno');
    $('#' + PerDetScrId + 'altVoterVerifiedTxt_ul').addClass('sno');
    $('#' + PerDetScrId + 'altVoterFailTxt_ul').addClass('sno');
}
apz.app.PersonalDetails.secKycOnChange = function(elementType) {
    if (elementType === "type") {
        $('#' + secondaryKycIdTag).val('');
        let secKycType = $('#' + PerDetScrId + 'secKYC').val();
        if (!apz.isNull(secKycType) && secKycType.toLocaleLowerCase() !== PleaseSelect.toLocaleLowerCase()) {
            let aadharVal = secondaryKyc[1]?.toLocaleLowerCase() || 'aadhaar card';
            let secKycTypeLower = secKycType.toLocaleLowerCase();
            if (secKycTypeLower === aadharVal && /aadhaar|aadhar/i.test(secKycTypeLower)) {
                $(`#${secondaryKycIdTag}`).attr({'placeholder': "Enter Aadhaar's last 4 digits", 'maxlength':"4",'minlength':"4", 'type': "Tel"});
                $(`#${PerDetScrId}secondaryKycVerifyBtn_ul`).addClass('sno');
                let keyupValues = $(`#${secondaryKycIdTag}`).attr('onkeyup') ?? '';
                if (!keyupValues.includes("ApzCOB.fnValidateCustId(this)")) {
                    $(`#${secondaryKycIdTag}`).attr('onkeyup', (keyupValues + " ApzCOB.fnValidateCustId(this);"));
                }
                let blurValues = $(`#${secondaryKycIdTag}`).attr('onblur') ?? '';
                if (blurValues.includes('ApzCOB.validateVoterid(this)')) {
                    blurValues = blurValues.replace('ApzCOB.validateVoterid(this);', '').trim();
                    $(`#${secondaryKycIdTag}`).attr('onblur', blurValues);
                }
                ApzCOB.removeFieldMandatory(secondaryKycIdTag);
                ApzCOB.addDisableToInput(secondaryKycIdTag);
            } else {
                if (secKycType === "PAN") {
                    $('#' + secondaryKycIdTag).attr('onblur', "ApzCOB.ValidatePan(this)");
                } else {
                    $('#' + secondaryKycIdTag).attr('onblur', "")
                    $('#' + secondaryKycIdTag).parents('.error-block').find('.err-msg .errText span').text(ApzCOB.getDescfromLitCode("LIT_SEC_VOTER_ERR"));
                    $('#' + secondaryKycIdTag).parents('.error-block').find('.err-msg').addClass('sno');
                }
                let keyupValues = $(`#${secondaryKycIdTag}`).attr('onkeyup') ?? '';
                if (keyupValues.includes("ApzCOB.fnValidateCustId(this)")) {
                    keyupValues = keyupValues.replace('ApzCOB.fnValidateCustId(this);', '').trim();
                    $(`#${secondaryKycIdTag}`).attr('onkeyup', keyupValues);
                }
                $(`#${secondaryKycIdTag}`).attr({'maxlength':"10",'minlength':"10", 'type': "Text"});
                $('#' + secondaryKycIdTag).attr('placeholder', "Enter Secondary KYC Number");
                $(`#${PerDetScrId}secondaryKycVerifyBtn_ul`).removeClass('sno');
                $('#' + PerDetScrId + 'secondaryKycVerifyBtn_ul').removeClass('sno');
                $('#' + PerDetScrId + 'secondaryKycVerifiedTxt_ul').addClass('sno');
                $('#' + PerDetScrId + 'secondaryKycFailTxt_ul').addClass('sno');
                ApzCOB.addFieldMandatory(secondaryKycIdTag);
                ApzCOB.removeDisableToInput(secondaryKycIdTag);
            }
        } else {
            ApzCOB.removeFieldMandatory(secondaryKycIdTag);
        }
    }
    SECONDARY_KYC_VERIFICATION = false;
}
apz.app.PersonalDetails.kycValidationCheck = function() {
    let isValid = false;
    let errmsg;
    if (gApzCOB.currentApplicant <= 1) {
        if (!apz.isNull(PRIMARY_KYC_VERIFICATION)) {
            if (PRIMARY_KYC_VERIFICATION) {
                isValid = true;
            } else {
                if (ALTERNATE_KYC_VERIFICATION) {
                    isValid = true;
                } else {
                    isValid = false;
                    errmsg = "LIT_PRIMARY_AND_ALT_VOTERID_VERIFICATION_FAILED";
                }
            }
        } else {
            errmsg = "LIT_PLEASE_VALIDATE_PRIMARY_KYC";
            isValid = false;
        }
    } else {
        if (!apz.isNull(CO_APPLICANT_PRIMARY_KYC_VERIFICATION)) {
            if (CO_APPLICANT_PRIMARY_KYC_VERIFICATION) {
                isValid = true;
            } else {
                if (CO_APPLICANT_ALTERNATE_KYC_VERIFICATION) {
                    isValid = true;
                } else {
                    isValid = false;
                    errmsg = "LIT_PRIMARY_AND_ALT_VOTERID_VERIFICATION_FAILED";
                }
            }
        } else {
            errmsg = "LIT_PLEASE_VALIDATE_PRIMARY_KYC";
            isValid = false;
        }
    }
    if (!isValid) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode(errmsg), "E");
    } else {
        //  isValid = ApzCOB.validateAlterVoterIfEntered();
        // if (isValid) {
        //   isValid = ApzCOB.validateSecondaryKycIfEntered(); 
        // }
        if (gApzCOB.currentApplicant <= 1) {
            if (PRIMARY_KYC_VERIFICATION || ALTERNATE_KYC_VERIFICATION) {
                isValid = true;
            } else {
                isValid = false;
            }
        } else {
            if (CO_APPLICANT_PRIMARY_KYC_VERIFICATION || CO_APPLICANT_ALTERNATE_KYC_VERIFICATION) {
                isValid = true;
            } else {
                isValid = false;
            }
        }
    }
    return isValid;
}
apz.app.PersonalDetails.clearCoAppFields = function(){
    $('#'+PerDetScrId+'personDetailsFieldsForm input.ett-inpt:not(.disabled)').val('') ;
    $('#'+PerDetScrId+'personDetailsFieldsForm input.sub-elt:not(.disabled)').val(PleaseSelect).change();
    $('#'+PerDetScrId+'relationwithApp').attr('readonly','readonly')
    $('#'+paintKYCId+'title').val('Mr.')
    $(`#${PerDetScrId}nameasKYC`).val('');
    $('#'+PerDetScrId+'custAge').val('');
    apz.app.PersonalDetails.primaryVoterOnChange();
    apz.app.PersonalDetails.altVoterOnChange();
    apz.app.PersonalDetails.secKycOnChange('ID');
    apz.app.PersonalDetails.onChangeRelationWithApp();
    $('input[name="PerDRE__PersonalDetails__el_rdo_1_"]').prop('checked',false);//HouseType Tag
    $('input[name="PerDRE__PersonalDetails__commAddRadio_"]').prop('checked',false);
    $('input[name="PerDRE__PersonalDetails__el_rdo_4_"]').prop('checked',false);//Location Tag
    $(`#${PerDetScrId}el_inp_6`).val('');//Location Coord
    $(`#${PerDetScrId}branchEmail`).val(apz.isNull(gApzCOB.selLeadDtls.emailId) ? '' : gApzCOB.selLeadDtls.emailId).blur();
}
apz.app.PersonalDetails.onChangeResStability = function(pthis) {
    var cityValue = $("#PerDRE__PersonalDetails__cityYears").val();
    var resValue = $("#PerDRE__PersonalDetails__resYears").val();
    var cityIndex = resYr.indexOf(cityValue !== PleaseSelect ? cityValue.replace('y', 'Y') : cityValue);
    var resIndex = resYr.indexOf(resValue !== PleaseSelect ? resValue.replace('y', 'Y') : resValue);
    if((resIndex!= 0 && resIndex < 3) || (cityIndex != 0 && cityIndex < 3)) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_RESIDENTIAL_STABILITY_TWO_YR_ERR"), "E");
        $(pthis).val(PleaseSelect);
        $(`#${pthis.id}_div`).find('li').removeClass('is-selected hilt');
        $(`#${pthis.id}_div`).find('li').first().addClass('is-selected hilt');
    } else if (cityIndex === 0 || resIndex === 0) {
        // do nothing
    } else if (resYr.indexOf(resValue) > resYr.indexOf(cityValue)) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_RESIDENTIAL_STABILITY_ERR"), "E");
        $(pthis).val(PleaseSelect);
        $(`#${pthis.id}_div`).find('li').removeClass('is-selected hilt');
        $(`#${pthis.id}_div`).find('li').first().addClass('is-selected hilt');
    }
}
apz.app.PersonalDetails.onChangeOccupation = function(pthis) {
    apz.app.PersonalDetails.validateOccupation();
    var selVal = pthis.value;
    BussTagFields = [`${PerDetScrId}commAddRadio_option_business`, `${PerDetScrId}el_rdo_4_option_LOCCORD3`];
    if (selVal.toLowerCase() === 'homemaker') {
        ApzCOB.AddOrRemoveDisableFields(BussTagFields, true);
        $.map(BussTagFields, function(field) {
            $(`#${field}`).prop("checked", false);
        });
    } else{
        ApzCOB.AddOrRemoveDisableFields(BussTagFields, false);
    }
}
apz.app.PersonalDetails.validateOccupation = function () {
    if (gApzCOB.currentApplicant !== 1) {
        const occupationVal = $(`#${PerDetScrId}occupations`).val();
        const applicantData = ApzCOB.getApplicantCustData();
        const applicantOccupation = applicantData.length > 0 ? applicantData[0].payload.occupation : '';
        const $occupationField = $(`${PerDetScrId}occupations`);
        let errMsg = '';

        if (applicantOccupation !== 'Self Employed') {
            if (occupationVal !== 'Self Employed') {
                errMsg = 'Either applicant or the co-applicant must be self-employed';
            }
        } else {
            if (occupationVal !== 'Self Employed' && occupationVal !== 'Salaried') {
                errMsg = 'Co-Applicant must be self-employed or Salaried';
            }
        }

        if (errMsg) {
            ApzCOB.fnDisplayMsg(errMsg, "E");
            $occupationField.val('PleaseSelect'); // Assuming 'PleaseSelect' is a constant or predefined value
        }
    }
};
apz.app.PersonalDetails.validateAnnualIncome = function() {
    var annualIncome = apz.getElmValue(PerDetScrId + "annualIncome");
    if (!apz.isNull(annualIncome)) {
        if (parseInt(annualIncome) < minAnnualIncome || parseInt(annualIncome) > maxAnnualIncome) {
            $(`#${PerDetScrId}annualIncome`).val('');
            ApzCOB.fnDisplayMsg((ApzCOB.getDescfromLitCode("LIT_PERDTLS_MaxANNUAL_INCOME") + ' ' + ApzCOB.fn_FormatAmount(minAnnualIncome) + ' ' + 'and' + ' ' + ApzCOB.fn_FormatAmount(maxAnnualIncome)), "E");
        }
    }
}
//Renewal Code
apz.app.PersonalDetails.existingCoApp = function(choice) {
    if ($(`#${PerDetScrId}existingCoAppModal`).hasClass('in')) {
        ApzCOB.toggleModal(PerDetScrId + 'existingCoAppModal');
    }
    if(choice !== "Yes") {
        // Existing CoApp data fetch and DOB Validation
        if (!apz.isNull(inSessionStore.customerDetailsList)) {
            let coAppData = inSessionStore.customerDetailsList.filter(cust => cust.customerType === "Co-App");
            if (coAppData.length > 0) {
                if (!apz.isNull(coAppData[0].payload.dob)) {
                    let coDOB = ApzCOB.dateformatter(coAppData[0].payload.dob, 'd/m/Y');
                    let coAge = ApzCOB.getAge(coDOB);
                    if (!(coAge >= minAge && coAge <= maxAge)) {
                        if (CO_APP_ADDED_COUNT >= gApzCOB.noOfApplicants) {
                            //Reject Application
                            ['addCoAppBtnId'].hide();
                            ['rejectBtnId'].show();
                            $(`#${PerDetScrId}coAppAgeErrorMsg`).text(ApzCOB.getDescfromLitCode("LIT_COMM_CONF_TXT_CO_APP_LIMIT_EXCEED_REJECT_APPL"));
                        } else {
                            //Add Co Applicant
                            ['addCoAppBtnId'].show();
                            ['rejectBtnId'].hide();
                            $(`#${PerDetScrId}coAppAgeErrorMsg`).text(ApzCOB.getDescfromLitCode("LIT_PERDTLS_CONF_TXT_COAPP_AGE_ERR"));
                        }
                        ApzCOB.toggleModal(PerDetScrId + 'coAppAgeErrorModal');
                        $('#PerDRE__PersonalDetails__addCoAppBtnId').attr('onclick', `apz.app.PersonalDetails.addCoAppConfirmation('AGE');`)
                        $('#PerDRE__PersonalDetails__addCoAppBtnId_txtcnt').text('Add Co-Applicant');
                    }
                }
            }
        }
    } else {
        let reasonsOpt = [PleaseSelect, "Co-Applicant Death","Other Reason"];
        apz.populateDropdown(document.getElementById(`${PerDetScrId}newCoAppDpdn`), ApzCOB.formatDropDownforArray(reasonsOpt));
        ApzCOB.addFieldMandatory(PerDetScrId + "newCoAppDpdn");
        ApzCOB.toggleModal(PerDetScrId + 'CoAppReasonModal');
    }
}
apz.app.PersonalDetails.onChangeReason = function(pthis) {
    let opt = pthis.value;
    ['otherReasonRow'].hide();
    if (opt === "Other Reason") {
        ['otherReasonRow'].show();
    } else {
        $(`#${PerDetScrId}otherReason`).val('').focus();
    }
}
apz.app.PersonalDetails.onClickContinueFlow = function() {
    dropdownVal = $(`#${PerDetScrId}newCoAppDpdn`).val();
    reasonVal = $(`#${PerDetScrId}otherReason`).val();
    if (dropdownVal === "Other Reason" && apz.isNull(reasonVal)) {
        ApzCOB.addErrMessage(`${PerDetScrId}otherReason`, 'element');
    } else if(dropdownVal === PleaseSelect){
        ApzCOB.addErrMessage(`${PerDetScrId}newCoAppDpdn`, 'element');
    } else {
        //Continue Flow with New Co-Applicant 
        if (CO_APP_ADDED_COUNT < gApzCOB.noOfApplicants) {
            apz.app.PersonalDetails.addCoAppConfirmation('DROPDOWN');   
        } else {
            $(`#${PerDetScrId}rejectLabel`).text(ApzCOB.getDescfromLitCode("LIT_COMM_CONF_TXT_CO_APP_LIMIT_EXCEED_REJECT_APPL"));
            RejectReason = "Co-Applicant limit exceeded.";
            ApzCOB.toggleModal(PerDetScrId + 'rejectmodel');
        }
    }
}
apz.app.PersonalDetails.closeModal = function(){
    ApzCOB.toggleModal(PerDetScrId + 'CoAppReasonModal');
    ApzCOB.toggleModal(PerDetScrId + 'existingCoAppModal');
}
apz.app.PersonalDetails.validateOccupation = function () {
    if(gApzCOB.currentApplicant !== 1){
    const occupationVal = $("#PerDRE__PersonalDetails__occupations").val();
    let applicantOccupation;
    for (let i = 0; i < inSessionStore.customerDetailsList.length; i++) {
    if (inSessionStore.customerDetailsList[i].customerType === "Applicant") {
        applicantOccupation = inSessionStore.customerDetailsList[i].payload.occupation;
        break;
    }
}
    // const $val = $("#PerDRE__PersonalDetails__sc_row_145");
    // const $errParaID = $("#PerDRE__PersonalDetails__sc_row_145");

    if (occupationVal !== "Self Employed" && applicantOccupation !== "Self Employed") {
        ApzCOB.fnDisplayMsg("Either applicant or the co-applicant must be self-employed", "E");
        $("#PerDRE__PersonalDetails__occupations").val("Please Select");
    }else {
        // $errParaID.addClass("sno");
      
    }
}
}
apz.app.PersonalDetails.PanonchangeVal = function(pthis) {
    (gApzCOB.currentApplicant <= 1) ? window.applicant_pancheck = false : window.coapplicant_pancheck = false;
    var type = pthis.value;
    if(type == 'Yes') {
        $("#"+PerDetScrId+ "panNumberInp").val('');
        $('#' + PerDetScrId + 'sc_row_2428').removeClass('sno');
        // $('#' + PerDetScrId + 'sc_row_2432').removeClass('sno');
        ApzCOB.addFieldMandatory(panNumberTag);
    } else {
        $('#' + PerDetScrId + 'sc_row_2428').addClass('sno');
        // $('#' + PerDetScrId + 'sc_row_2432').addClass('sno');
        ApzCOB.removeFieldMandatory(panNumberTag);
        $("#"+PerDetScrId+ "panNumberInp").val('');
        $("#" + PerDetScrId + "el_txt_141_ul").addClass("sno");
         $("#" + PerDetScrId + "el_hpl_3_ul").removeClass("sno");
        ApzCOB.AddOrRemoveDisableFields([`${PerDetScrId}panNumberInp`], false);
    }
};
apz.app.PersonalDetails.PanVerification = function() {
    let isValidPanType = ApzCOB.validateEachInputField(panNumberTag);
    let isValidPanId = ApzCOB.validateEachInputField(panNumberTag);
    let isValidNumber = false;
    isValidNumber = apz.app.PersonalDetails.PannumberVerCheck();
    if (isValidPanType && isValidPanId && isValidNumber) {
        var PanObj = {};
        PanObj.kycType = 'pan';
        PanObj.kycId = $('#' + panNumberTag).val().toUpperCase().trim();
        ApzCOB.PanVerificationCheck(PanObj);
    }
};
apz.app.PersonalDetails.PannumberVerCheck = function() {
    let isNotSame = true;
    let errmsg;
    if (apz.isNull(inSessionStore.customerDetailsList)) {
        isNotSame = true;
    } else {
        let currentType = gApzCOB.currentApplicant === 1 ? "Applicant" : "Co-App";
        let otherCustomer = inSessionStore.customerDetailsList.find(
            c => c.customerType !== currentType
        );
        let enteredPan = $('#' + panNumberTag).val().toUpperCase().trim();
        let otherPan = otherCustomer?.payload?.panNumber?.toUpperCase().trim();
        if (otherPan && enteredPan === otherPan) {
            isNotSame = false;
            errmsg = "LIT_PERDTLS_PANDTLS_ERR_TXT_SAMEPAN";
            ApzCOB.fnDisplayMsg(
                ApzCOB.getDescfromLitCode(errmsg),
                "E"
            );
        }
    }
    return isNotSame;
}
apz.app.PersonalDetails.panValidationCheck = function() {
    let isValid = false;
    let errmsg;
    let panDropValue = $("#PerDRE__PersonalDetails__PAN_DropDown").val();
    let verifyPan = $(`#PerDRE__PersonalDetails__el_hpl_3`).is(':visible');
    let inValidPan = $(`#PerDRE__PersonalDetails__el_txt_142`).is(':visible');
    if (verifyPan || inValidPan) {
        window.applicant_pancheck = false;
    } else {
        window.applicant_pancheck = true;
    }
    if (gApzCOB.currentApplicant <= 1) {
        if(panDropValue == 'Yes' && window.applicant_pancheck == false) {
            isValid = false;
            errmsg = "LIT_PERDTLS_PANDTLS_ERR_TXT_VERIFYPAN";
        } else {
            isValid = true;
        }
    } else {
        if(panDropValue == 'Yes' && window.coapplicant_pancheck == false) {
            isValid = false;
            errmsg = "LIT_PERDTLS_PANDTLS_ERR_TXT_VERIFYPAN";
        } else {
            isValid = true;
        }
    }
    if (!isValid) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode(errmsg), "E");
    }
    return isValid;
}
apz.app.PersonalDetails.paintpanDetails = function(params) {
    let data = params;
    if(data.payload.panNumberStatus == 'Verified' || REINITIATE_PAN_CHECKED) {
        $("#"+PerDetScrId+ "panNumberInp").val('');
        document.getElementById(PerDetScrId+ "PAN_DropDown").value = "Yes";
        document.getElementById(PerDetScrId+ "panNumberInp").value = data.payload.panNumber.toLocaleUpperCase();
        $('#' + PerDetScrId + 'sc_row_2428').removeClass('sno');
        $('#' + PerDetScrId + 'sc_row_2432').removeClass('sno');
        ApzCOB.addFieldMandatory(panNumberTag);
        ApzCOB.AddOrRemoveDisableFields([`${PerDetScrId}panNumberInp`], true);
        $("#" + PerDetScrId + "el_hpl_3_ul").addClass("sno");
        $("#" + PerDetScrId + "el_txt_141_ul").removeClass("sno");
        $("#" + PerDetScrId + "el_txt_142_ul").addClass("sno");
        if (gApzCOB.currentApplicant > 1) {
            window.coapplicant_pancheck = true;
        } else {
            window.applicant_pancheck = true;
        }
        apz.app.PersonalDetails.reinitiate_panstatus(data)
    }
};
apz.app.PersonalDetails.reinitiate_panstatus = function(data) {
    if ((data.payload.panNumberStatus !== "Verified") && (IS_REINITIATE_APPLICATION || IS_REJECTED_APPLICATION)) {
        window.REINITIATE_PAN_CHECKED = false;
    } else {
        window.REINITIATE_PAN_CHECKED = true;
    }
    if (IS_REJECTED_APPLICATION && REINITIATE_PAN_CHECKED) {
        window.applicant_pancheck = false;
        window.coapplicant_pancheck = false;
        if (data.payload.panNumberStatus == 'Verified') {
            $("#" + PerDetScrId + "el_hpl_3_ul").removeClass("sno");
            $("#" + PerDetScrId + "el_txt_141_ul").addClass("sno");
        } else {        
            $("#" + PerDetScrId + "el_hpl_3_ul").addClass("sno");
            $("#" + PerDetScrId + "el_txt_141_ul").removeClass("sno");
        }
        $("#" + PerDetScrId + "el_txt_142_ul").addClass("sno");
        document.getElementById(PerDetScrId + "PAN_DropDown").value = 'Yes';
        $("#" + PerDetScrId + "panNumberInp").val(data.payload.panNumber.toLocaleUpperCase());
        ApzCOB.AddOrRemoveDisableFields([`${PerDetScrId}panNumberInp`], false)
        $('#' + PerDetScrId + 'sc_row_2428').removeClass('sno');
    }
};
