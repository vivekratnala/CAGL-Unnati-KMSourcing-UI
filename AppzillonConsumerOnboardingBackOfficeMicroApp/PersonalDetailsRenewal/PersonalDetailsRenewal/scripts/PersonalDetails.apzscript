//onload function
apz.app.onLoad_PersonalDetails = function() {
    apz.app.BaseScreens.contactus();
    apz.app.BaseScreens.hideNshowbackIcon();
    if (!apz.isNull(gStates)) {
        ApzCOB.citydropDown(PerDetScrId, "state", "city");
    }
    apz.app.PersonalDetails.clearForm();
    $('#APZCBO__BaseScreens__continue').attr('disabled', true);
    apz.app.PersonalDetails.paintData();
    apz.populateDropdown(document.getElementById(PerDetScrId + 'maritalSts'), ApzCOB.formatDropDownforArray(maritalStatus));
    apz.populateDropdown(document.getElementById(secondaryKycTypeTagId), ApzCOB.formatDropDownforArray(secondaryKyc));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'ownership'), ApzCOB.formatDropDownforArray(resOwnership));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'resYears'), ApzCOB.formatDropDownforArray(resYr));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'cityYears'), ApzCOB.formatDropDownforArray(resYr));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'currResProof'), ApzCOB.formatDropDownforArray(currentresidenceproof));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'occupations'), ApzCOB.formatDropDownforArray(occupations));
    apz.populateDropdown(document.getElementById(paintKYCId + 'title'), ApzCOB.formatDropDownforArray(nameTitle));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'religion'), ApzCOB.formatDropDownforArray(religion));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'caste'), ApzCOB.formatDropDownforArray(caste));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'education'), ApzCOB.formatDropDownforArray(education));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'relationwithApp'), ApzCOB.formatDropDownforArray(ApzCOB.filterRelns(relations)));
    apz.populateDropdown(document.getElementById(paintKYCId + 'gender'), ApzCOB.formatDropDownforArray(gender));
    apz.populateDropdown(document.getElementById(PerDetScrId + 'state'), ApzCOB.formatDropDownforArray(states));
    apz.app.PersonalDetails.hideHeader();
    kycID = -1;
    PerID = -1;
    CusVerID = -1;
    STAGES.forEach(function(el) {
        if (el.split('~')[0] === "KYCVERIFICATION") {
            kycID = parseInt(el.split('~')[1]);
            return;
        } else if (el.split('~')[0] === "CUSTOMERDETAILS") {
            PerID = parseInt(el.split('~')[1]);
            return;
        } else if (el.split('~')[0] === "CUSTVERIFICATION") {
            CusVerID = parseInt(el.split('~')[1]);
            return;
        }
    })
    if (Ocr_Required && kycID > 0 && PerID > kycID) {
        window.ocrVerified = true;
    } else {
        window.ocrVerified = false;
    }
    apz.app.PersonalDetails.displaydefaultData();
    apz.app.PersonalDetails.onLoadCollapseAll();
}
//on shown function
apz.app.onShown_PersonalDetails = function() {
    let maritalStatus = '';
    if (!apz.isObjectEmpty(inSessionStore)) {
        let custData = ApzCOB.getApplicantCustData();
        if (custData.length > 0) {
            maritalStatus = custData[0].payload.maritalStatus;
        }
    } else {
        maritalStatus = gApzCOB.selLeadDtls.maritalStatus;
    }
    let allowedValues = [];
    if (maritalStatus === "Married") {
        allowedValues = ["Spouse", "Son", "Daughter-in-law"];
    } else if (["Widow", "Separated"].includes(maritalStatus)) {
        allowedValues = ["Father", "Mother", "Son", "Daughter-in-law"];
    } else {
        allowedValues = ["Father", "Mother"];
    }
    $("#PerDRE__PersonalDetails__relationwithApp_div li").each(function() {
        const value = $(this).attr("data-value");
        if (!allowedValues.includes(value)) {
            $(this).remove();
        }
    });
    ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], false);
    if(!apz.isNull(gApzCOB.userDetails.applicationId)) {
        $(`#${BaseScrId}RefNumDiv`).removeClass('sno');
        $(`#${BaseScrId}RefNum`).text(ApzCOB.getDescfromLitCode("LIT_COMM_TXT_REF_NUM") + gApzCOB.userDetails.applicationId);
        if (gApzCOB.currentApplicant <= 1) {
            ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], true);
        }
    } else {
        $(`#${BaseScrId}RefNumDiv`).addClass('sno');
    }
    window.IS_APP_PRIMARY_CHECK_FAILED = false;
    window.IS_APP_ALTERNATE_CHECK_FAILED = false;
    window.IS_COAPP_PRIMARY_CHECK_FAILED = false;
    window.IS_COAPP_ALTERNATE_CHECK_FAILED = false;
    if (gApzCOB.currentApplicant <= 1) {
        $('#' + PerDetScrId + 'custTypeLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_TYPE"))
        $('#' + PerDetScrId + 'idLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_ID"))
        $('#' + PerDetScrId + 'nameLabel').text(ApzCOB.getDescfromLitCode("LIT_MEMBER_NAME"))
    } else {
        $('#' + PerDetScrId + 'custTypeLabel').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_TYPE"))
        $('#' + PerDetScrId + 'idLabel').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_ID"))
        $('#' + PerDetScrId + 'nameLabel').text(ApzCOB.getDescfromLitCode("LIT_CUSTOMER_NAME"))
    }
    if (gApzCOB.currentApplicant <= 1) {
        ApzCOB.showSubHeader("LIT_CUSTOMER_DETAILS_APPLICANT_HEADER");
    } else {
        ApzCOB.showSubHeader("LIT_CUSTOMER_DETAILS_HEADER_CO_APP");
    }
    if (window.COUNTRYCODE === 'N') {
        $('#' + PerDetScrId + 'countryFlagCol').addClass('sno');
        $('#' + PerDetScrId + 'AlterCountryFlagCol').addClass('sno');
    }
    $("#btn_icon_icon-Back-Arrow").removeClass('sno');
    $("input").attr("autocomplete", "off");
    if ($('#' + BaseScrId + 'backIcon').hasClass('sno')) {
        $('#' + PerDetScrId + 'subHeaderRow').addClass('var1')
    }
    $('#' + paintKYCId + 'dob').datepicker("option", "maxDate", Date.parse(DATE_TODAY));
    $('#' + paintKYCId + 'dob').datepicker("option", "yearRange", "-100:+0");
    $('#' + paintKYCId + 'name').trigger('onblur');
    ApzCOB.showCountrycodeFlag(PerDetScrId, "regnFlag");
    ApzCOB.showCountrycodeFlag(PerDetScrId, "SecRegnFlag");
    if (Ocr_Required) {
        $('#' + PerDetScrId + 'perAddHeaderRow').addClass('sno');
        $('#' + PerDetScrId + 'parmanentAddressRow').addClass('sno');
        $('#' + PerDetScrId + 'CommAddSameAsPerAddDiv').addClass('sno');
    } else {
        $('#' + PerDetScrId + 'perAddHeaderRow').removeClass('sno');
        $('#' + PerDetScrId + 'parmanentAddressRow').removeClass('sno');
        $('#' + PerDetScrId + 'CommAddSameAsPerAddDiv').removeClass('sno');
    }
    apz.app.PersonalDetails.configureFields();
    apz.app.BaseScreens.HeaderFooterData();
    apz.app.PersonalDetails.setMinMaxLength();
    if (!apz.isNull(gApzCOB.userDetails.panNum)) {
        $('#' + PerDetScrId + 'panNumber').val(gApzCOB.userDetails.panNum);
    } else if (!apz.isNull(gApzCOB.requestNodes.customerDetailsList)) {
        if (gApzCOB.requestNodes.customerDetailsList.length > 0 && gApzCOB.requestNodes.customerDetailsList[gApzCOB.currentApplicant - 1] &&
            gApzCOB.requestNodes.customerDetailsList[gApzCOB.currentApplicant - 1].payload) {
            window.panVerified = true;
            $('#' + PerDetScrId + 'panNumber').val(gApzCOB.requestNodes.customerDetailsList[gApzCOB.currentApplicant - 1].payload.pan);
        }
    }
    apz.app.PersonalDetails.secKycAadharConfig();
    apz.app.PersonalDetails.paintDetails();
    if (!backNav) {
        if (gApzCOB.currentApplicant <= 1) {
            window.CUST_ADDRESS = []
            window.CUST_ADDRESS_SAVE = [];
        }
    }
    var curFuncToExe = ConfigureScrJson.filter(function(e, i) {
        return e.MicroAppID === apz.currAppId && window.allowedUnSave.indexOf(apz.currAppId) !== -1
    })[0].requestFunc.split('.');
    if (window.selectedNationalID === 'EmiratesID') {
        $('#' + PerDetScrId + 'AddressAsperAadharRow').addClass('sno');
    }
    if (gApzCOB.product === "CARDS" || gApzCOB.product === "LOAN") {
        apz.app.PersonalDetails.paintCardDetails();
    } else {
        if ($('#' + BaseScrId + 'STAGE3').hasClass('readonly')) {
            $('#' + BaseScrId + 'STAGE3').removeClass('readonly');
            /*$("#" + PerDetScrId + "state").attr("disbaled", "");
            $("#" + PerDetScrId + "title").attr("disbaled", "");
            $("#PerDRE__IPaintKYCDetails__o__PerDRE__IPaintKYCDetails_Res__gender").attr("disbaled", "");
            $("#PerDRE__IPaintKYCDetails__o__PerDRE__IPaintKYCDetails_Res__dob").attr("disbaled", "");
            $("#" + PerDetScrId + "city").attr("disbaled", "");*/
            $("#" + PerDetScrId + "DisclaimerRow").addClass('sno');
        }
    }
    apz.app.BaseScreens.HeaderFooterData();
    $('#' + paintKYCId + 'dob').attr('placeholder', apz.dateFormat);
    $('#' + BaseScrId + 'continue').text(ApzCOB.getDescfromLitCode("LIT_CONTINUE"));
    $('#' + BaseScrId + 'cancel').text(ApzCOB.getDescfromLitCode("LIT_CANCEL"));
    if (!backNav && !IS_REJECTED_APPLICATION) {
        apz.app.PersonalDetails.onLoadPaintData();
    }
    apz.app.PersonalDetails.paintExistingLoans();
    $('#' + PerDetScrId + 'commAddrRow').removeClass('sno');
    $('#' + PerDetScrId + 'locCoordForRow').removeClass('sno');
    $(`#${PerDetScrId}pin`).change();
    if (gApzCOB.currentApplicant > 1) {
        ApzCOB.removeDisableToInput(paintKYCId+'gender');
        ['customerIdDiv'].hide();
        ApzCOB.removeFieldMandatory(PerDetScrId + 'custId');
        $('#' + PerDetScrId + 'personalTopInfoDiv').addClass('sno');
        $('#' + PerDetScrId + 'relationApplicRow').removeClass('sno');
        let persoanlFormID = PerDetScrId + 'personDetailsFieldsForm';
        ApzCOB.addDisableToInput(PerDetScrId + 'custType');
        ApzCOB.addDisableToInput(PerDetScrId + 'custAge');
        ApzCOB.addDisableToInput(PerDetScrId + 'nameasKYC');
        ApzCOB.removeDisableToInput(PerDetScrId + 'relationwithApp');
        ApzCOB.removeDisableToInput(PerDetScrId + 'voterId');
        ApzCOB.removeDisableToInput(paintKYCId + 'title');
        // ApzCOB.removeFieldMandatory(paintKYCId + 'mobNum');
        $(`#${PerDetScrId}branchEmail`).val(apz.isNull(gApzCOB.selLeadDtls.emailId) ? '' : gApzCOB.selLeadDtls.emailId).blur();
        if(IS_REJECTED_APPLICATION && !backNav){
             $('#' + PerDetScrId + 'nameasKYC').val("");
        } else {
        if (!apz.isNull(inSessionStore.customerDetailsList)) {
            var data = inSessionStore.customerDetailsList
            data.forEach(function(i, k) {
                if (data[k].customerType === "Co-App") {
                    if (data[k].payload.primaryKycIdValStatus !== null && data[k].payload.primaryKycIdValStatus !== '') {
                        CO_APPLICANT_PRIMARY_KYC_VERIFICATION = data[k].payload.primaryKycIdValStatus === 'Verified' ? true : false;
                    }
                    if (data[k].payload.alternateVoterIdValStatus !== null && data[k].payload.alternateVoterIdValStatus !== '') {
                        CO_APPLICANT_ALTERNATE_KYC_VERIFICATION = data[k].payload.alternateVoterIdValStatus === 'Verified' ? true : false;
                    }
                    if (data[k].payload.secondaryKycIdValStatus !== null && data[k].payload.secondaryKycIdValStatus !== '') {
                        CO_APPLICANT_SECONDARY_KYC_VERIFICATION = data[k].payload.secondaryKycIdValStatus === 'Verified' ? true : false;
                    }
                }
            })
        }
        if (CO_APPLICANT_PRIMARY_KYC_VERIFICATION) {
            apz.app.PersonalDetails.validationStatus();
        }
        if (CO_APPLICANT_ALTERNATE_KYC_VERIFICATION) {
            apz.app.PersonalDetails.validationStatus();
        }
        if (CO_APPLICANT_SECONDARY_KYC_VERIFICATION) {
            apz.app.PersonalDetails.validationStatus();
        }
        } 
    } else {
        $('#' + paintKYCId + 'gender').val('Female');
        var genderDisable = (ApzCOB.GetCommonCodes("CUSTOMERDETAILS", "COMM")["CUSTOMERDETAILS"].filter(item => {return item.split('~')[0] === 'Gender'}))[0].split('~')[3];
        if(genderDisable === 'D') {
            ApzCOB.addDisableToInput(paintKYCId + 'gender');
        } else {
            ApzCOB.removeDisableToInput(paintKYCId+'gender');
            $('#' + paintKYCId + 'gender').val(PleaseSelect);
        }
        $('#' + PerDetScrId + 'relationApplicRow').addClass('sno');
        if(IS_REJECTED_APPLICATION && !backNav){
             $('#' + PerDetScrId + 'nameasKYC').val("");
        } else {
        if (!apz.isNull(inSessionStore.customerDetailsList)) {
            var data = inSessionStore.customerDetailsList
            data.forEach(function(i, k) {
                if (data[k].customerType === "Applicant") {
                    if (data[k].payload.primaryKycIdValStatus !== null && data[k].payload.primaryKycIdValStatus !== '') {
                        PRIMARY_KYC_VERIFICATION = data[k].payload.primaryKycIdValStatus === 'Verified' ? true : false;
                    }
                    if (data[k].payload.alternateVoterIdValStatus !== null && data[k].payload.alternateVoterIdValStatus !== '') {
                        ALTERNATE_KYC_VERIFICATION = data[k].payload.alternateVoterIdValStatus === 'Verified' ? true : false;
                    }
                    if (data[k].payload.secondaryKycIdValStatus !== null && data[k].payload.secondaryKycIdValStatus !== '') {
                        SECONDARY_KYC_VERIFICATION = data[k].payload.secondaryKycIdValStatus === 'Verified' ? true : false;
                    }
                }
            })
        }
        if (PRIMARY_KYC_VERIFICATION || backNav) {
            apz.app.PersonalDetails.validationStatus();
        }
        if (ALTERNATE_KYC_VERIFICATION) {
            apz.app.PersonalDetails.validationStatus();
        }
        if (SECONDARY_KYC_VERIFICATION) {
            window.kycVerificationType = "secondary";
            apz.app.PersonalDetails.validationStatus();
        }   
        }
    }
    $('#' + PerDetScrId + 'AddressAsperAadharDiv').addClass('sno');
    IS_ALTERNATE_DEDUPE = false;
    // IS_SECONDARY_DEDUPE = false;
    if (gApzCOB.currentApplicant > 1 && apz.isNull(gApzCOB.requestNodes.customerDetailsList[gApzCOB.currentApplicant - 1])) {
        $(`#${PerDetScrId}custType`).val("Co-Applicant");
    }
    ApzCOB.getToggleOnClickEventObj(PerDetScrId);
    $('#'+paintKYCId+'title').attr('readonly','readonly');
    $('#'+PerDetScrId+'relationwithApp').attr('readonly','readonly');
    $('#'+paintKYCId+'gender').attr('readonly','readonly');
    $('body').removeClass('ajs-no-overflow');
    $('#' + BaseScrId + 'custIDandName_txtcnt').text(`Member ID/Name - ${gApzCOB.selLeadDtls.customerId} / ${gApzCOB.selLeadDtls.fullName}`);
    $('#' + BaseScrId + 'custIDandName').removeClass('sno');
    ApzCOB.AddOrRemoveDisableFields(pinCodeFieldsDropdowns, true);
    if (PUSHBACK_QUERY_STATUS.includes(gApzCOB.userDetails.applicationStatus)) {
        ApzCOB.paintingSourcingQuery();
    }
    $('input.hasDatepicker').each(function(index, element) {
        $(element).prop('disabled', true);
    })
    if (gApzCOB.currentApplicant > 1 && !backNav) {
        if (window.isRenewalPopupEnabled) {
            if (!apz.isObjectEmpty(inSessionStore.customerDetailsList.find(el => el.customerType === 'Co-App')) && inSessionStore.applicationMaster.currentStageNo < 5) {
                ApzCOB.toggleModal(PerDetScrId + 'existingCoAppModal');
                $(`#${PerDetScrId}isCoAppNo`).click();
            }
        } else {
            $inputs = $('#PerDRE__PersonalDetails__ct_frm_1, #PerDRE__PersonalDetails__ct_frm_2').find('input');
            $inputs.each(function() {
                ApzCOB.addDisableToInput(this.id);
            });
            ApzCOB.addDisableToInput(`${paintKYCId}dob_button`);
            if (!apz.isNull(inSessionStore.customerDetailsList)) {
                let coDOB = ApzCOB.getPayloadDatafromWrapper("dob", "Co-App", "customerDetailsList");
                if (!apz.isNull(coDOB)) {
                    coDOB = ApzCOB.dateformatter(coDOB, 'd/m/Y');
                    let coAge = ApzCOB.getAge(coDOB);
                    if (!(coAge >= minAge && coAge < maxAge)) {
                        $('.ajs-button.ajs-ok').click();
                        $(`#${PerDetScrId}coAppAgeErrorMsg`).text(ApzCOB.getDescfromLitCode("LIT_PERDTLS_COAPP_AGE_ERR_RENEWAL") + `${coAge}).`);
                        ApzCOB.toggleModal(PerDetScrId + 'coAppAgeErrorModal');
                        $('#PerDRE__PersonalDetails__addCoAppBtnId').attr('onclick', 'apz.app.Dashboard.LaunchDashboard();')
                        $('#PerDRE__PersonalDetails__addCoAppBtnId_txtcnt').text('Go to Home');
                    }
                    $(`#${paintKYCId}mobNum`).val(ApzCOB.getPayloadDatafromWrapper('mobileNumber','Applicant','customerDetailsList'));
                    $(`#${PerDetScrId}PAN_DropDown`).val('No').change();
                } else if (apz.isNull(coDOB)) {
                    $(`#${PerDetScrId}coAppAgeErrorMsg`).text("Co-Applicant data not found!.");
                    ApzCOB.toggleModal(PerDetScrId + 'coAppAgeErrorModal');
                    $('#PerDRE__PersonalDetails__addCoAppBtnId').attr('onclick', 'apz.app.Dashboard.LaunchDashboard();')
                    $('#PerDRE__PersonalDetails__addCoAppBtnId_txtcnt').text('Go to Home');
                }
            }
        }
    }
};
apz.app.PersonalDetails.setMinMaxLength = function() {
    ApzCOB.setMinMaxLength([{
        'fieldName': 'Name',
        'fieldId': paintKYCId + 'firstname'
    }, {
        'fieldName': 'Name',
        'fieldId': paintKYCId + 'midname'
    }, {
        'fieldName': 'Name',
        'fieldId': paintKYCId + 'lastname'
    }, {
        'fieldName': 'CustomerType',
        'fieldId': PerDetScrId + 'custType'
    }, {
        'fieldName': 'CustomerId',
        'fieldId': PerDetScrId + 'custId'
    }, {
        'fieldName': 'Name',
        'fieldId': paintKYCId + 'name'
