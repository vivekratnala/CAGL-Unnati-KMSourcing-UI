        var mbNumUsrDetail = gApzCOB.userDetails.mobileNum.trim().split(" ")[1] === undefined ? gApzCOB.userDetails.mobileNum.trim().split(" ")[
            0] : gApzCOB.userDetails.mobileNum.trim().split(" ")[1];
        var mbNumAadDetail = gApzCOB.nationalIdDetails.mobileNum.trim().split(" ")[1] === undefined ? gApzCOB.nationalIdDetails.mobileNum.trim()
            .split(" ")[0] : gApzCOB.nationalIdDetails.mobileNum.trim().split(" ")[1];
        mobileNum = apz.isNull(gApzCOB.nationalIdDetails.mobileNum) ? mbNumUsrDetail : mbNumAadDetail;
        //gApzCOB.userDetails.mobileNum = mobileNum;
    }
}
apz.app.PersonalDetails.ageCalculator = function() {
    var age = ApzCOB.getAge($('#' + paintKYCId + 'dob').val());
    if (age > 0) {
        $('#' + PerDetScrId + 'custAge').val(age).change();
        ApzCOB.removeErrMessgae(PerDetScrId + 'custAge', "element");
    } else {
        $('#' + PerDetScrId + 'custAge').val('');
        $('#' + paintKYCId + 'dob').val('');
        ApzCOB.fnDisplayMsg(`Please select valid age(min:${minAge},max:${maxAge})`, "E");
    }
};
apz.app.PersonalDetails.personalDetailObject = function() {
    var primaryStatus = '',
        alternateStatus = '',
        secondaryStatus = '',
        panNumberStatus = '';
    if (gApzCOB.currentApplicant <= 1) {
        if (PRIMARY_KYC_VERIFICATION !== null && PRIMARY_KYC_VERIFICATION !== '') {
            primaryStatus = PRIMARY_KYC_VERIFICATION === true ? 'Verified' : 'Inavalid Id';
        }
        if (ALTERNATE_KYC_VERIFICATION !== null && ALTERNATE_KYC_VERIFICATION !== '') {
            if ($('#' + altVoterIdTag).val() !== '') {
                alternateStatus = ALTERNATE_KYC_VERIFICATION === true ? 'Verified' : 'Inavalid Id';
            } else {
                alternateStatus = '';
            }
        }
        if (SECONDARY_KYC_VERIFICATION !== null && SECONDARY_KYC_VERIFICATION !== '') {
            secondaryStatus = SECONDARY_KYC_VERIFICATION === true ? 'Verified' : 'Inavalid Id';
        }
    } else {
        if (CO_APPLICANT_PRIMARY_KYC_VERIFICATION !== null && CO_APPLICANT_PRIMARY_KYC_VERIFICATION !== '') {
            primaryStatus = CO_APPLICANT_PRIMARY_KYC_VERIFICATION === true ? 'Verified' : 'Inavalid Id';
        }
        if (CO_APPLICANT_ALTERNATE_KYC_VERIFICATION !== null && CO_APPLICANT_ALTERNATE_KYC_VERIFICATION !== '') {
            alternateStatus = CO_APPLICANT_ALTERNATE_KYC_VERIFICATION === true ? 'Verified' : 'Inavalid Id';
        }
        if (CO_APPLICANT_SECONDARY_KYC_VERIFICATION !== null && CO_APPLICANT_SECONDARY_KYC_VERIFICATION !== '') {
            secondaryStatus = CO_APPLICANT_SECONDARY_KYC_VERIFICATION === true ? 'Verified' : 'Inavalid Id';
        }
    }
    if (gApzCOB.currentApplicant <= 1 && window.applicant_pancheck !== '') {
        panNumberStatus = window.applicant_pancheck === true ? 'Verified' : 'Inavalid Id';
    } else if (gApzCOB.currentApplicant > 1 && window.coapplicant_pancheck !== '') {
        panNumberStatus = window.coapplicant_pancheck === true ? 'Verified' : 'Inavalid Id';
    }
    let appVer = APP_VERSION, custData = ApzCOB.getApplicantCustData();
    if (custData.length > 0) {
        appVer = !apz.isNull(custData[0].payload.appVersion) ? custData[0].payload.appVersion : APP_VERSION;
    }
    perDetobj = {
        "custDtlId": parseInt(gApzCOB.userDetails.custDtlId),
        "customerType": "Applicant",
        "customerFullName": "",
        "customerName": $('#' + paintKYCId + 'name').val(),
        "mobileNumber": $('#' + paintKYCId + 'mobNum').val(),
        "kycStatus": "Pending",
        "amlStatus": "Pending",
        "memberId": "",
        "payload": {
            "title": $('#' + paintKYCId + 'title').val(),
            "firstName": $('#' + paintKYCId + 'firstname').val(),
            "middleName": $('#' + paintKYCId + 'midname').val(),
            "lastName": $('#' + paintKYCId + 'lastname').val(),
            "dob": "",
            "age": $('#' + PerDetScrId + 'custAge').val(),
            // "isEarningMember": "",
            // "relationship": "",
            // "altMobileNumber": "",
            "emailId": $(`#${PerDetScrId}branchEmail`).val(),
            "gender": $('#' + paintKYCId + 'gender').val(),
            "maritalStatus": $('#' + PerDetScrId + 'maritalSts').val(),
            /*"uniqueIds": [{
                "docName": "",
                "docValue": ""
            }],*/
            "spouseName": spouseNameInputTag.val(),
            "fathersName": fatherNameInputTag.val(),
            "custId": $('#' + PerDetScrId + 'custId').val(),
            "gkCustomerType": $('#' + PerDetScrId + 'custType').val(),
            // "memberId": "",
            "pan": '',
            "aadhaarNumber": $('#' + PerDetScrId + 'aadhaarNum').val(),
            "primaryKycType": $('#' + PerDetScrId + 'primaryKYC').val(),
            "primaryKycId": $('#' + PerDetScrId + 'voterId').val().toLocaleUpperCase(),
            //  "kycType": $('#' + PerDetScrId + 'primaryKYC').val(),
            //  "kycID": $('#' + PerDetScrId + 'voterId').val(),
            "secondaryKycType": $('#' + secondaryKycTypeTagId).val() === PleaseSelect ? "" : $('#' + secondaryKycTypeTagId).val(),
            "secondaryKycId": $('#' + secondaryKycIdTag).val().toUpperCase(),
            "occupation": $('#' + PerDetScrId + 'occupations').val(),
            "religion": $('#' + PerDetScrId + 'religion').val(),
            "caste": $('#' + PerDetScrId + 'caste').val(),
            "education": $('#' + PerDetScrId + 'education').val(),
            "secMobileNo": $('#' + PerDetScrId + 'sec_mobile').val(),
            "relationShipWithApplicant": "",
            "namePerKyc": "",
            "alternateVoterId": $('#' + altVoterIdTag).val().toLocaleUpperCase(),
            "ckyc": $(`#${PerDetScrId}cKYC`).val(),
            "primaryKycIdValStatus": primaryStatus,
            "secondaryKycIdValStatus": secondaryStatus,
            "alternateVoterIdValStatus": alternateStatus,
            "appVersion": appVer,
            "customerIndex": CO_APP_ADDED_COUNT,
            "annualIncome": $(`#${PerDetScrId}annualIncome`).val(),
            "panNumberValue": $("#PerDRE__PersonalDetails__PAN_DropDown").val(),
            "panNumber": $('#' + panNumberTag).val(),
            "panNumberStatus": $('#' + panNumberTag).val() === '' ? '': panNumberStatus
            // "riskRating": "",
            // "creditScore": ""
        }
    }
    perDetobj.payload.namePerKyc = $('#' + PerDetScrId + 'nameasKYC').val();
    if (gApzCOB.currentApplicant > 1) {
        perDetobj.custDtlId = apz.isNull(gApzCOB.userDetails.CoApplicantCustomerId) ? "" : parseInt(gApzCOB.userDetails.CoApplicantCustomerId);
        perDetobj.customerType = "Co-App";
        perDetobj.payload.relationShipWithApplicant = $('#' + PerDetScrId + 'relationwithApp').val() === PleaseSelect ? "" : $('#' + PerDetScrId +
            'relationwithApp').val();
        //perDetobj.payload.namePerKyc = $('#' + PerDetScrId + 'nameasKYC').val();
    } else if(gApzCOB.currentApplicant <= 1) {
        if(apz.isNull(gApzCOB.userDetails.createdByName)) {
            let createdByName = (!apz.isNull(gApzCOB.LoggedInUserDetails.loginResponse.userDet.name)) ? gApzCOB.LoggedInUserDetails.loginResponse.userDet.name.trim() : "";
            perDetobj.payload.createdByName = createdByName;
        } else {
            perDetobj.payload.createdByName = gApzCOB.userDetails.createdByName.trim();
        }
    }
    //   var mobN = $('#' + paintKYCId + 'mobNum').val();
    //   var secMobN = $('#' + paintKYCId + 'mobNum').val();
    if (window.doblength === 8) {
        perDetobj.payload.dob = new Date($(ResDOB).val()).$format('d/m/Y');
    } else {
        perDetobj.payload.dob = apz.isNull($('#' + paintKYCId + 'dob').val()) ? "" : ApzCOB.dateformatter($('#' + paintKYCId + 'dob').datepicker(
            'getDate'), 'Y-m-d');
    }
    if (perDetobj.payload.pan !== "") {
        gApzCOB.userDetails.panNum = perDetobj.payload.pan;
    }
    if (perDetobj.payload.maritalStatus !== "") {
        gApzCOB.userDetails.maritialStatus = perDetobj.payload.maritalStatus;
        gApzCOB.userDetails.spouseName = perDetobj.payload.spouseName;
    }
    //   if (window.COUNTRYCODE === 'Y') {
    //       if (ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].includeInReq === "Y") {
    //          perDetobj.mobileNumber = apz.isNull(mobN) ? '' : $('#' + PerDetScrId + 'regnFlag').val() + " " + $('#' + paintKYCId + 'mobNum').val();
    //          perDetobj.payload.secMobileNo = apz.isNull(secMobN) ? '' : $('#' + PerDetScrId + 'SecRegnFlag').val() + " " + $('#' + PerDetScrId + 'sec_mobile').val();
    //       } else {
    //          perDetobj.mobileNumber = $('#' + paintKYCId + 'mobNum').val();
    //          perDetobj.payload.secMobileNo  = $('#' + PerDetScrId + 'sec_mobile').val();
    //       }
    //   } else {
    //       perDetobj.mobileNumber = $('#' + paintKYCId + 'mobNum').val();
    //       perDetobj.payload.secMobileNo  = $('#' + PerDetScrId + 'sec_mobile').val();
    //   }
}
apz.app.PersonalDetails.samePermanentAddress = function(pthis) {
    if ($(PerDetAddPermanentToggle).prop('checked') === true) {
        if (apz.app.PersonalDetails.validatePerAddress()) {
            window.iscomplete = true;
            window.sameCommAddress = true;
            var pPin = $('#' + PerDetScrId + "pPin").val();
            var pState = $('#' + PerDetScrId + "pState").val();
            var pCity = $('#' + PerDetScrId + "pCity").val();
            var pAddress1 = $('#' + PerDetScrId + "pAddress1").val();
            var pAddress2 = $('#' + PerDetScrId + "pAddress2").val();
            var pLandmark = $('#' + PerDetScrId + "pLandmark").val();
            var pDoorNo = $('#' + PerDetScrId + "pDoorNumber").val();
            if ($('#' + PerDetScrId + "pin").is(':visible')) {
                $('#' + PerDetScrId + "pin").val(pPin);
            }
            if ($('#' + PerDetScrId + "state").is(':visible')) {
                ApzCOB.citydropDown(PerDetScrId, "state", "city");
                apz.setElmValue(PerDetScrId + "state", apz.getElmValue(PerDetScrId + 'pState'))
            }
            if ($('#' + PerDetScrId + "city").is(':visible')) {
                apz.setElmValue(PerDetScrId + "city", apz.getElmValue(PerDetScrId + 'pCity'))
                $('#' + PerDetScrId + "city").val(pCity);
                $('#' + PerDetScrId + "AddPermanentToggle").prop('checked', true);
                window.sameCommAddress = true
            }
            if ($('#' + PerDetScrId + "addressLine1").is(':visible')) {
                $('#' + PerDetScrId + "addressLine1").val(pAddress1);
            }
            if ($('#' + PerDetScrId + "addressLine2").is(':visible')) {
                $('#' + PerDetScrId + "addressLine2").val(pAddress2);
            }
            if ($('#' + PerDetScrId + "landMark").is(':visible')) {
                $('#' + PerDetScrId + "landMark").val(pLandmark);
            }
            if ($('#' + PerDetScrId + "doorNo").is(':visible')) {
                $('#' + PerDetScrId + "doorNo").val(pDoorNo);
            }
            $('#' + PerDetScrId + "addressDetailsRow").removeClass('sno');
            if ((apz.isNull(pPin) && apz.isNull(pCity) && apz.isNull(pAddress1) && apz.isNull(pAddress2) && apz.isNull(pLandmark)) && apz.isNull(
                    pDoorNo) && (pState === PleaseSelect)) {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_ENTERPERMANENTADDRESSDETAILS"), "E");
                $('#' + PerDetScrId + "AddPermanentToggle").prop('checked', false);
                return false;
            }
            window.iscomplete = false;
        } else {
            window.sameCommAddress = false;
            $('#' + PerDetScrId + "AddPermanentToggle").prop('checked', false);
        }
    } else {
        window.sameCommAddress = false;
        $('#PerDRE__PersonalDetails__addressDetailsRow').find('input').val('');
    }
}
apz.app.PersonalDetails.checkPerNComAddValues = function() {
    var pPin = $('#PerDRE__PersonalDetails__pPin').val();
    var pState = $('#PerDRE__PersonalDetails__pState').val();
    var pCity = $('#PerDRE__PersonalDetails__pCity').val();
    var pAddress1 = $('#PerDRE__PersonalDetails__pAddress1').val();
    var pAddress2 = $('#PerDRE__PersonalDetails__pAddress2').val();
    var pLandmark = $('#PerDRE__PersonalDetails__pLandmark').val();
    var pDoorNo = $('#PerDRE__PersonalDetails__pDoorNumber').val();
    var pin = $('#' + PerDetScrId + 'pin').val();
    var state = $('#' + PerDetScrId + 'state').val();
    var city = $('#' + PerDetScrId + 'city').val();
    var Address1 = $('#' + PerDetScrId + 'addressLine1').val();
    var Address2 = $('#' + PerDetScrId + 'addressLine2').val();
    var landmark = $('#' + PerDetScrId + 'landMark').val();
    var doorNo = $('#' + PerDetScrId + 'doorNo').val();
    if (window.sameCommAddress) {
        if (pPin !== pin || pState !== state || pCity !== city || pAddress1 !== Address1 || pAddress2 !== Address2 || pLandmark !== landmark ||
            pDoorNo !== doorNo) {
            window.sameCommAddress = false;
            $('#' + PerDetScrId + "AddPermanentToggle").prop('checked', false);
            $('#' + PerDetScrId + "addressDetailsRow").find('input').val('');
        }
    }
}
apz.app.PersonalDetails.turnOffToggle = function() {
    var pPin = $('#' + PerDetScrId + "pPin").val();
    var pState = $('#' + PerDetScrId + "pState").val();
    var pCity = $('#' + PerDetScrId + "pCity").val();
    var pAddress1 = $('#' + PerDetScrId + "pAddress1").val();
    var pAddress2 = $('#' + PerDetScrId + "pAddress2").val();
    var pLandmark = $('#' + PerDetScrId + "pLandmark").val();
    var pDoorNo = $('#' + PerDetScrId + "pDoorNumber").val();
    var pin = $('#' + PerDetScrId + 'pin').val();
    var state = $('#' + PerDetScrId + 'state').val();
    var city = $('#' + PerDetScrId + 'city').val();
    var Address1 = $('#' + PerDetScrId + 'addressLine1').val();
    var Address2 = $('#' + PerDetScrId + 'addressLine2').val();
    var landmark = $('#' + PerDetScrId + 'landMark').val();
    var doorNo = $('#' + PerDetScrId + 'doorNo').val();
    if (pPin !== pin || pState !== state || pCity !== city || pAddress1 !== Address1 || pAddress2 !== Address2 || pLandmark !== landmark ||
        pDoorNo !== doorNo) {
        window.sameCommAddress = false;
        $('#' + PerDetScrId + "AddPermanentToggle").prop('checked', false);
    }
    if (window.iscomplete) {
        window.sameCommAddress = true;
    }
}
