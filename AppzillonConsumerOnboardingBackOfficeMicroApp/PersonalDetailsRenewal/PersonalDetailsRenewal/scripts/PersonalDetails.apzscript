apz.app.PersonalDetails.paintDetailsOnBackNav = function() {
    //Personal Details
    $('#APZCBO__BaseScreens__continue').attr('disabled', false);
    let currentIndex = '', dob = '', age = '';
    if(gApzCOB.currentApplicant <= 1){
      currentIndex =  inSessionStore.customerDetailsList.findIndex(custData => custData.customerType === "Applicant")
    } else {
     currentIndex =  inSessionStore.customerDetailsList.findIndex(custData => custData.customerType !== "Applicant") 
    }
    var CustDtls = {};
    if(!apz.isNull(currentIndex)){
     CustDtls = inSessionStore.customerDetailsList[currentIndex];   
    }
    var address = [];
    if(!apz.isNull(inSessionStore.addressDetailsWrapperList)) {
        if (inSessionStore.addressDetailsWrapperList.length > 0) {
            address = inSessionStore.addressDetailsWrapperList[0].addressDetailsList ?? [];
        }
    }
    if (!apz.isObjectEmpty(CustDtls) && address.length > 0) {
    // var CustDtls = inSessionStore.customerDetailsList[currentIndex];
    if (!apz.isNull(CustDtls.payload.dob)) {
        dob = ApzCOB.dateformatter(CustDtls.payload.dob, 'd/m/Y');
        $(`#${paintKYCId}dob`).val(dob);
        $(`#${paintKYCId}dob`).trigger('change');
        age = ApzCOB.getAge(dob);
    }
    //var mobNumarr = CustDtls.mobileNumber.split(" ");
    var mobNumarr = ('+91' + ' ' + CustDtls.mobileNumber).split(" ");
    var mobNum = mobNumarr[mobNumarr.length - 1];
    var SecmobNumarr = (!apz.isNull(CustDtls.payload.secMobileNo)) ? CustDtls.payload.secMobileNo.split(" ") : [];
    var SecmobNum = SecmobNumarr.length > 0 ? SecmobNumarr[SecmobNumarr.length - 1] : "";
    var custrname = CustDtls.firstname + ' ' + CustDtls.midname + ' ' + CustDtls.lastname;
    var customerType = CustDtls.customerType === "Applicant" ? CustDtls.customerType : "Co-Applicant";
    var custId = customerType === "Applicant" ? gApzCOB.selLeadDtls.customerId : "";
    $("#" + PerDetScrId + "customerTxt_txtcnt").text(CustDtls.customerName);
    $("#" + PerDetScrId + "customerGenderAgeTxt_txtcnt").text(CustDtls.payload.gender + " | " + age);
    $(`#${paintKYCId}name`).val(CustDtls.customerName);
    $(`#${paintKYCId}title`).val(CustDtls.payload.title);
    $(`#${PerDetScrId}custType`).val(customerType);
    $(`#${PerDetScrId}custId`).val(custId);
    $(`#${paintKYCId}gender`).val(!apz.isNull(CustDtls.payload.gender) ? CustDtls.payload.gender : PleaseSelect);
    $(`#${paintKYCId}mobNum`).val(mobNum);
    $(`#${PerDetScrId}aadhaarNum`).val(CustDtls.payload.aadhaarNumber);
    $(`#${PerDetScrId}voterId`).val(CustDtls.payload.primaryKycId).keyup();
    $(`#${PerDetScrId}altVoterId`).val(CustDtls.payload.alternateVoterId).keyup();
    $(`#${PerDetScrId}cKYC`).val(CustDtls.payload.ckyc ?? '');
    let secKycType = !apz.isNull(CustDtls.payload.secondaryKycType) ? CustDtls.payload.secondaryKycType : PleaseSelect;
    let secKycId = !apz.isNull(CustDtls.payload.secondaryKycId) ? CustDtls.payload.secondaryKycId.toUpperCase() : '';
    $(`#${PerDetScrId}secVoterId`).val(secKycId ? secKycId.toUpperCase() : '');
    $(`#${PerDetScrId}secKYC`).val(secKycType);
    // if(secKycType !== PleaseSelect) {
        apz.app.PersonalDetails.secKycAadharConfig(secKycType, secKycId);
    // }
    $(`#${PerDetScrId}panNumber`).val(CustDtls.payload.pan);
    $(`#${PerDetScrId}occupations`).val(!apz.isNull(CustDtls.payload.occupation) ? CustDtls.payload.occupation : PleaseSelect).change();
    $(`#${PerDetScrId}religion`).val(!apz.isNull(CustDtls.payload.religion) ? CustDtls.payload.religion : PleaseSelect).change();
    $(`#${PerDetScrId}caste`).val(!apz.isNull(CustDtls.payload.caste) ? CustDtls.payload.caste : PleaseSelect).change();
    $(`#${PerDetScrId}education`).val(!apz.isNull(CustDtls.payload.education) ? CustDtls.payload.education : PleaseSelect).change();
    $(`#${PerDetScrId}sec_mobile`).val(SecmobNum);
    $(`#${PerDetScrId}branchEmail`).val(CustDtls.payload.emailId).blur();
    $(`#${PerDetScrId}nameasKYC`).val(CustDtls.payload.namePerKyc);
    $(`#${PerDetScrId}annualIncome`).val(!apz.isNull(CustDtls.payload.annualIncome) ? CustDtls.payload.annualIncome : '');
    if (gApzCOB.currentApplicant > 1) {
        if (apz.isNull(CustDtls.payload?.annualIncome)) {
            $(`#${PerDetScrId}annualIncome`).val(ApzCOB.getOccupation("Income"));
        }
        let relatn = !apz.isNull(CustDtls.payload.relationShipWithApplicant) ? CustDtls.payload.relationShipWithApplicant : PleaseSelect;
        if (['spouse', 'husband'].includes(relatn.toLocaleLowerCase())) {
            let applicantData = ApzCOB.getApplicantCustData();
            if (applicantData.length > 0) {
                if (applicantData[0].payload.maritalStatus.toLocaleLowerCase() !== "married") {
                    relatn = PleaseSelect;
                }
            }
        }
        $(`#${PerDetScrId}relationwithApp`).val(relatn.toLocaleLowerCase() === 'husband' ? 'Spouse' : relatn).change();
        //$(`#${PerDetScrId}nameasKYC`).val(CustDtls.payload.namePerKyc);
    }
    $(`#${PerDetScrId}maritalSts`).val(!apz.isNull(CustDtls.payload.maritalStatus) ? ApzCOB.capitalize(CustDtls.payload.maritalStatus) : PleaseSelect).change();
    $(`#${PerDetScrId}fatherName`).val(CustDtls.payload.fathersName);
    $(`#${PerDetScrId}spouseName`).val(CustDtls.payload.spouseName);
    $(`#${PerDetScrId}PAN_DropDown`).val(apz.isNull(CustDtls.payload.panNumberValue) ? PleaseSelect : CustDtls.payload.panNumberValue).change();
    if (!apz.isNull(CustDtls.payload.panNumber) && CustDtls.payload?.panNumber !== 'Not Available') {
        $(`#${panNumberTag}`).val(CustDtls.payload.panNumber);
        if ((CustDtls.payload.panNumberStatus == "Verified") && (IS_REINITIATE_APPLICATION || IS_REJECTED_APPLICATION)) {
            window.REINITIATE_PAN_CHECKED = true;
        } else {
            window.REINITIATE_PAN_CHECKED = false;
        }
        apz.app.PersonalDetails.paintpanDetails(CustDtls)
    }
    //Present Address Details
    var personalAddress = []
    if (gApzCOB.currentApplicant === 1) {
        address.forEach(function(i, k) {
            if (address[k].addressType === 'Personal' && parseInt(address[k].custDtlId) === parseInt(gApzCOB.userDetails.custDtlId)) {
                personalAddress.push(address[k])
            }
        })
    } else if (gApzCOB.currentApplicant === 2) {
        address.forEach(function(i, k) {
            if (address[k].addressType === 'Personal' && parseInt(address[k].custDtlId) === parseInt(gApzCOB.userDetails
                    .CoApplicantCustomerId)) {
                personalAddress.push(address[k])
            }
        })
    }
    if (personalAddress.length > 0) {
        if (!apz.isNull(personalAddress[0].payload.addressList[0])) {
            var presentAddress = personalAddress[0].payload.addressList[0]
            $(`#${PerDetScrId}addressLine1`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine1`, presentAddress.addressLine1 ?? ''));
            $(`#${PerDetScrId}addressLine2`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine2`, presentAddress.addressLine2 ?? ''));
            $(`#${PerDetScrId}addressLine3`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine3`, presentAddress.addressLine3 ?? ''));
            $(`#${PerDetScrId}pin`).val(apz.isNull(presentAddress.pinCode) ? '' : presentAddress.pinCode);
            $(`#${PerDetScrId}city`).val(apz.isNull(presentAddress.city) ? '' : presentAddress.city);
            $(`#${PerDetScrId}district`).val(apz.isNull(presentAddress.district) ? '' : presentAddress.district);
            $(`#${PerDetScrId}state`).val(apz.isNull(presentAddress.state) ? '' : presentAddress.state);
            $(`#${PerDetScrId}country`).val(apz.isNull(presentAddress.country) ? '' : presentAddress.country);
            $(`#${PerDetScrId}presArea`).val(apz.isNull(presentAddress.area) ? '' : presentAddress.area);
            $(`#${PerDetScrId}presLandmark`).val(apz.isNull(presentAddress.landMark) ? '' : presentAddress.landMark);
            $(`#${PerDetScrId}ownership`).val(apz.isNull(presentAddress.residenceOwnership) ? PleaseSelect : presentAddress.residenceOwnership);
            $(`#${PerDetScrId}cityYears`).val(apz.isNull(presentAddress.residenceCitySince) ? PleaseSelect : presentAddress.residenceCitySince?.replace('y', 'Y')).change();
            $(`#${PerDetScrId}resYears`).val(apz.isNull(presentAddress.residenceAddressSince) ? PleaseSelect : presentAddress.residenceAddressSince.replace('y', 'Y')).change();
            if (!spouseFlag) {
                $(`#${PerDetScrId}cityYears`).change();
                $(`#${PerDetScrId}resYears`).change();
            }
            let currAddrProof = presentAddress.currentAddressProof;
            $(`#${PerDetScrId}currResProof`).val(apz.isNull(currAddrProof) ? PleaseSelect : currAddrProof);
            if (!apz.isNull(currAddrProof) && IS_REJECTED_APPLICATION && currAddrProof.toLowerCase() !== PleaseSelect.toLowerCase()) {
                ApzCOB.addDisableToInput("PerDRE__PersonalDetails__currResProof");
            }
        }
        apz.app.PersonalDetails.onchangeTypeofHouse(presentAddress);
        window.houseTypechoose = presentAddress.houseType;
        apz.app.PersonalDetails.onchangeLoc_CoordFor(presentAddress);
        window.loc_CordFor = presentAddress.locateCoOrdinatesFor;
        $(`#${PerDetScrId}el_inp_6`).val(presentAddress.locateCoOrdinates);
        //Permanent Address Details
        if (!apz.isNull(personalAddress[0].payload.addressList[1])) {
            var permanentAddressDtls = personalAddress[0].payload.addressList[1];
            $(`#${PerDetScrId}permanentAddres1`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}permanentAddres1`, permanentAddressDtls.addressLine1 ?? ''));
            $(`#${PerDetScrId}permanentAddres2`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}permanentAddres2`, permanentAddressDtls.addressLine2 ?? ''));
            $(`#${PerDetScrId}permanentAddres3`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}permanentAddres3`, permanentAddressDtls.addressLine3 ?? ''));
            $(`#${PerDetScrId}permanentPincode`).val(apz.isNull(permanentAddressDtls.pinCode) ? '' : permanentAddressDtls.pinCode);
            $(`#${PerDetScrId}permanentcity`).val(apz.isNull(permanentAddressDtls.city) ? '' : permanentAddressDtls.city);
            $(`#${PerDetScrId}permanentDist`).val(apz.isNull(permanentAddressDtls.district) ? '' : permanentAddressDtls.district);
            $(`#${PerDetScrId}permanentState`).val(apz.isNull(permanentAddressDtls.state) ? '' : permanentAddressDtls.state);
            $(`#${PerDetScrId}permanentCountry`).val(apz.isNull(permanentAddressDtls.country) ? '' : permanentAddressDtls.country);
            $(`#${PerDetScrId}permArea`).val(apz.isNull(permanentAddressDtls.area) ? '' : permanentAddressDtls.area);
            $(`#${PerDetScrId}permLandmark`).val(apz.isNull(permanentAddressDtls.landMark) ? '' : permanentAddressDtls.landMark);
            if (!apz.isNull(permanentAddressDtls.addressSameAs)) {
                $(`#${PerDetScrId}permanentAdd_option_${permanentAddressDtls.addressSameAs}`).prop(`checked`, true);
            }
        }
        //Communication Address Details
        if (!apz.isNull(personalAddress[0].payload.addressList[2])) {
            var communicationAddressDtls = personalAddress[0].payload.addressList[2];
            $(`#${PerDetScrId}commAddress1`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}commAddress1`, communicationAddressDtls.addressLine1 ?? ''));
            $(`#${PerDetScrId}commAddress2`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}commAddress2`, communicationAddressDtls.addressLine2 ?? ''));
            $(`#${PerDetScrId}commAddress3`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}commAddress3`, communicationAddressDtls.addressLine3 ?? ''));
            $(`#${PerDetScrId}commPincode`).val(apz.isNull(communicationAddressDtls.pinCode) ? '' : communicationAddressDtls.pinCode);
            $(`#${PerDetScrId}commCity`).val(apz.isNull(communicationAddressDtls.city) ? '' : communicationAddressDtls.city);
            $(`#${PerDetScrId}commDist`).val(apz.isNull(communicationAddressDtls.district) ? '' : communicationAddressDtls.district);
            $(`#${PerDetScrId}commState`).val(apz.isNull(communicationAddressDtls.state) ? '' : communicationAddressDtls.state);
            $(`#${PerDetScrId}commCountry`).val(apz.isNull(communicationAddressDtls.country) ? '' : communicationAddressDtls.country);
            $(`#${PerDetScrId}commArea`).val(apz.isNull(communicationAddressDtls.area) ? '' : communicationAddressDtls.area);
            $(`#${PerDetScrId}commLandmark`).val(apz.isNull(communicationAddressDtls.landMark) ? '' : communicationAddressDtls.landMark);
            if (!apz.isNull(communicationAddressDtls.addressSameAs)) {
                $(`#${PerDetScrId}commAddRadio_option_${communicationAddressDtls.addressSameAs}`).prop(`checked`, true);
            }
        }
    }
    } else {
        apz.app.PersonalDetails.onLoadPaintData();
    }
}
apz.app.PersonalDetails.secKycAadharConfig = function(lType, lId) {
    if (!apz.isNull(AADHAR_CONFIG)) {
        if (AADHAR_CONFIG.AADHAR_MANDATORY) {
            $(`#${PerDetScrId}secKYC`).val(secondaryKyc[1]).change();
            ApzCOB.addFieldMandatory(PerDetScrId + 'secKYC');
            ApzCOB.addDisableToInput(PerDetScrId + 'secKYC');
            if (!apz.isNull(lType)) {
                if (lType !== secondaryKyc[1] && !apz.isNull(lId)) {
                    $(`#${PerDetScrId}secVoterId`).val('');
                } else {
                    $(`#${PerDetScrId}secVoterId`).val(lId);
                }
            }
        } else {
            ApzCOB.removeFieldMandatory(PerDetScrId + 'secKYC');
            ApzCOB.removeDisableToInput(PerDetScrId + 'secKYC');
            // if (!apz.isNull(secKycId)) {
            //     $(`#${PerDetScrId}secVoterId`).val(secKycId);
            // }
        }
    }
};
apz.app.PersonalDetails.paintCardDetails = function() {
    if (gApzCOB.ExistingCustomer) {
        apz.data.scrdata.PerDRE__IPaintKYCDetails_Res = {
            'name': gApzCOB.customerDetails.customerDetails.customerName,
            'mobNum': gApzCOB.customerDetails.customerDetails.mobileNum,
            'gender': gApzCOB.customerDetails.customerDetails.gender,
            'dob': "",
            'addressasPerAadhar': gApzCOB.customerDetails.customerDetails.permAddress
        }
        var mobilenumber;
        if (!apz.isNull(gApzCOB.customerDetails.customerDetails)) {
            if (!apz.isNull(gApzCOB.customerDetails.customerDetails) && gApzCOB.customerDetails.customerDetails !== '') {
                mobilenumber = gApzCOB.customerDetails.customerDetails.mobileNum;
            }
            if (!apz.isNull(mobilenumber.trim().split(" ")) && mobilenumber.trim().split(" ").length > 1) {
                $(SelectedFlag).removeClass(ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].preferredCountries);
                $('#' + PerDetScrId + "regnFlag").val(('+91' + ' ' + mobilenumber.trim()).split(" ")[0]);
                $('#' + PerDetScrId + "SecRegnFlag").val(mobNum.trim().split(" ")[0]);
            }
            dummy1 = '91'
            if (!apz.isNull(dummy1)) {
                $(PerSelectedFlag).trigger('click'); //Start: [data-dial-code= ' + dummy + '] this is
                $(CountryList).addClass('sno'); // available only if the country drop down is open, hence opening the drop down and hiding it
                $(SelectedFlag).addClass($(DialCode + dummy1 + ']').attr(CountryCode));
            }
            apz.data.scrdata.PerDRE__IPaintKYCDetails_Res.mobNum = mobilenumber.trim().split(" ").length > 1 ? mobilenumber.trim().split(" ")[1] :
                mobilenumber.trim().split(" ")[0];
        }
        apz.data.loadData('IPaintKYCDetails', apz.currAppId);
        $("#" + PerDetScrId + "perDetailsDiv").find("input").prop("disabled", true);
        $('#PerDRE__IPaintKYCDetails__o__PerDRE__IPaintKYCDetails_Res__dob_button').prop("disabled", true);
        $("#" + PerDetScrId + "regnFlag_ul").addClass('sub-elt');
        ApzCOB.stateDropDown(PerDetScrId, 'pState');
        if (!apz.isNull(gApzCOB.customerDetails.addressList) && gApzCOB.customerDetails.addressList.length > 0) {
            gApzCOB.customerDetails.addressList.filter(function(e) {
                if (JSON.parse(e.payloadColumn).addressList[0].addressType === "Permanent" || JSON.parse(e.payloadColumn).addressList[0]
                    .addressType === "Communication") {
                    gApzCOB.customerDetails.addrdet = JSON.parse(e.payloadColumn);
                    if (JSON.parse(e.payloadColumn).addressList[1].addressType === "Communication") {
                        gApzCOB.customerDetails.addrdet.addressLine1 = gApzCOB.customerDetails.addrdet["addressList"][1].addressLine1
                        gApzCOB.customerDetails.addrdet.addressLine2 = gApzCOB.customerDetails.addrdet["addressList"][1].addressLine2
                        gApzCOB.customerDetails.addrdet.addressLine3 = gApzCOB.customerDetails.addrdet["addressList"][1].addressLine3
                        gApzCOB.customerDetails.addrdet.addressType = gApzCOB.customerDetails.addrdet["addressList"][1].addressType
                        gApzCOB.customerDetails.addrdet.city = gApzCOB.customerDetails.addrdet["addressList"][1].city
                        gApzCOB.customerDetails.addrdet.country = gApzCOB.customerDetails.addrdet["addressList"][1].country
                        gApzCOB.customerDetails.addrdet.pinCode = gApzCOB.customerDetails.addrdet["addressList"][1].pinCode
                        gApzCOB.customerDetails.addrdet.state = gApzCOB.customerDetails.addrdet["addressList"][1].state
                        // apz.setElmValue(PerDetScrId + "state", stateVal[stateDesc.indexOf(gApzCOB.customerDetails.addrdet.state)]);
                        // apz.setElmValue(PerDetScrId + "city", cityVal[cityDesc.indexOf(gApzCOB.customerDetails.addrdet.city)]);
                        $("#" + PerDetScrId + "addressLine1").val(gApzCOB.customerDetails.addrdet.addressLine1);
                        $("#" + PerDetScrId + "addressLine2").val(gApzCOB.customerDetails.addrdet.addressLine2);
                        $("#" + PerDetScrId + "landMark").val(gApzCOB.customerDetails.addrdet.landMark);
                        $("#" + PerDetScrId + "pin").val(gApzCOB.customerDetails.addrdet.pinCode);
                        $("#" + PerDetScrId + "doorNo").val(gApzCOB.customerDetails.addrdet.doorNum);
                    }
                    if (JSON.parse(e.payloadColumn).addressList[0].addressType === "Permanent") {
                        gApzCOB.customerDetails.addrdet.addressLine1 = gApzCOB.customerDetails.addrdet["addressList"][0].addressLine1
                        gApzCOB.customerDetails.addrdet.addressLine2 = gApzCOB.customerDetails.addrdet["addressList"][0].addressLine2
                        gApzCOB.customerDetails.addrdet.addressLine3 = gApzCOB.customerDetails.addrdet["addressList"][0].addressLine3
                        gApzCOB.customerDetails.addrdet.addressType = gApzCOB.customerDetails.addrdet["addressList"][0].addressType
                        gApzCOB.customerDetails.addrdet.city = gApzCOB.customerDetails.addrdet["addressList"][0].city
                        gApzCOB.customerDetails.addrdet.country = gApzCOB.customerDetails.addrdet["addressList"][0].country
                        gApzCOB.customerDetails.addrdet.landMark = gApzCOB.customerDetails.addrdet["addressList"][0].landMark
                        gApzCOB.customerDetails.addrdet.pinCode = gApzCOB.customerDetails.addrdet["addressList"][0].pinCode
                        gApzCOB.customerDetails.addrdet.state = gApzCOB.customerDetails.addrdet["addressList"][0].state
                        gApzCOB.customerDetails.addrdet.doorNum = gApzCOB.customerDetails.addrdet["addressList"][0].doorNum
                        ApzCOB.stateDropDown(PerDetScrId, 'pState');
                        // apz.setElmValue(PerDetScrId + "pState", stateVal[stateDesc.indexOf(gApzCOB.customerDetails.addrdet.state)]);
                        // apz.setElmValue(PerDetScrId + "pCity", cityVal[cityDesc.indexOf(gApzCOB.customerDetails.addrdet.city)]);
                        $("#" + PerDetScrId + "pAddress1").val(gApzCOB.customerDetails.addrdet.addressLine1);
                        $("#" + PerDetScrId + "pAddress2").val(gApzCOB.customerDetails.addrdet.addressLine2);
                        $("#" + PerDetScrId + "pLandmark").val(gApzCOB.customerDetails.addrdet.landMark);
                        $("#" + PerDetScrId + "pPin").val(gApzCOB.customerDetails.addrdet.pinCode);
                        $("#" + PerDetScrId + "pDoorNumber").val(gApzCOB.customerDetails.addrdet.doorNum);
                    }
                    if (JSON.parse(e.payloadColumn).commAddEqPerAdd === 'Y') {
                        $("#" + PerDetScrId + "AddPermanentToggle").prop('checked', true);
                    } else {
                        $("#" + PerDetScrId + "AddPermanentToggle").prop('checked', false);
                    }
                }
            })
        }
        apz.setElmValue(PerDetScrId + "email", gApzCOB.customerDetails.customerDetails.emailId);
        $(ResGender).val(gApzCOB.customerDetails.customerDetails.gender);
        $("#" + PerDetScrId + "title").val(gApzCOB.customerDetails.customerDetails.title);
        $("#" + PerDetScrId + "panNumber").val(gApzCOB.customerDetails.customerDetails.pan);
        $(ResDOB).val(gApzCOB.customerDetails.customerDetails.dateOfBirth);
        $("#" + PerDetScrId + "state").attr("disbaled", "true");
        $("#" + PerDetScrId + "title").attr("disbaled", "true");
        if (gApzCOB.ExistingCustomer) {
            var savevalue = JSON.parse(gApzCOB.customerDetails.addressList[0].payloadColumn);
            if (savevalue.addressList[0].addressType === "Permanent") {
                if (savevalue.addressList[0].state !== PleaseSelect || savevalue.addressList[0].state !== '') {
                    $("#PerDRE__PersonalDetails__pState").val(savevalue.addressList[0].state);
                }
                if (savevalue.addressList[0].city !== PleaseSelect || savevalue.addressList[0].city !== '') {
                    $("#PerDRE__PersonalDetails__pCity").val(savevalue.addressList[0].city);
                }
            }
        }
        $(ResGender).attr("disbaled", "true");
        $(ResDOB).attr("disbaled", "true");
        $("#" + PerDetScrId + "city").attr("disbaled", "true");
        $('#' + BaseScrId + 'STAGE3').addClass('readonly')
        $(document).ready(function() {
            $('.readonly').find('input, textarea, select, text, span').attr('readonly', 'readonly');
        });
        $("#" + PerDetScrId + "DisclaimerRow").removeClass('sno');
    } else {
        if ($('#' + BaseScrId + 'STAGE3').hasClass('readonly')) {
            $('#' + BaseScrId + 'STAGE3').removeClass('readonly');
            $("#" + PerDetScrId + "DisclaimerRow").addClass('sno');
        }
    }
}
apz.app.PersonalDetails.displaydefaultData = function() {
    $('#' + PerDetScrId + 'AddressAsperAadharRow').addClass('sno');
    if (window.editappln || !window.JointFlow) {
        apz.app.PersonalDetails.mobileNumber();
        // var mobileNum = "";
        // if (!(apz.isNull(gApzCOB.nationalIdDetails.mobileNum) && apz.isNull(gApzCOB.userDetails.mobileNum))) {
        //     var mbNumUsrDetail = gApzCOB.userDetails.mobileNum.trim().split(" ")[1] === undefined ? gApzCOB.userDetails.mobileNum.trim().split(" ")[0] :
        //         gApzCOB.userDetails.mobileNum.trim().split(" ")[1];
        //     var mbNumAadDetail = gApzCOB.nationalIdDetails.mobileNum.trim().split(" ")[1] === undefined ? gApzCOB.nationalIdDetails.mobileNum.trim().split(" ")[0] :
        //         gApzCOB.nationalIdDetails.mobileNum.trim().split(" ")[1];
        //     mobileNum = apz.isNull(gApzCOB.nationalIdDetails.mobileNum) ? mbNumUsrDetail : mbNumAadDetail;
        //     gApzCOB.userDetails.mobileNum = mobileNum;
        // }
        var dob = apz.isNull(gApzCOB.nationalIdDetails.dob) ? "" : ApzCOB.dateformatter(Date.parse(gApzCOB.nationalIdDetails.dob), 'd/m/Y');
        if (ocrVerified) {
            //var tempMob = '';
            if (window.COUNTRYCODE === 'Y') {
                if (ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].includeInReq === "Y") {
                    $(SelectedFlag).removeClass(ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].preferredCountries)
                    $('#' + PerDetScrId + "regnFlag").val(('+91' + ' ' + gApzCOB.nationalIdDetails.mobileNum.trim()).split(" ")[0]);
                    $('#' + PerDetScrId + "SecRegnFlag").val(mobNum.trim().split(" ")[0]);
                    $('#' + paintKYCId + "mobNum").val(mobileNum);
                    //dummy1 = ((gApzCOB.nationalIdDetails.mobileNum).trim().split(" ")[0].split("+")[1])
                    dummy1 = '91'
                    if (!apz.isNull(dummy1)) {
                        $(SelectedFlag).addClass($(DialCode + dummy + ']').attr(CountryCode));
                    }
                } else {
                    $('#' + paintKYCId + "mobNum").val(gApzCOB.nationalIdDetails.mobileNum.trim().split(" ")[1]);
                }
            } else {
                $('#' + paintKYCId + "mobNum").val(gApzCOB.nationalIdDetails.mobileNum.trim().split(" ")[1]);
            }
            $('#' + paintKYCId + "dob").val(dob)
            $('#' + PerDetScrId + 'AddressAsperAadharRow').removeClass('sno');
            if (!apz.isNull(gApzCOB.nationalIdDetails.name)) {
                $('#' + paintKYCId + "name").val(gApzCOB.nationalIdDetails.name);
                $('#' + PerDetScrId + "customerName").text(gApzCOB.nationalIdDetails.name);
                $('#' + PerDetScrId + 'nameList').removeClass('sno');
            } else {
                $('#' + PerDetScrId + 'nameList').addClass('sno');
            }
            $('#' + paintKYCId + 'addressasPerAadhar').text(gApzCOB.nationalIdDetails.address)
            $('#' + paintKYCId + "gender").val(gApzCOB.nationalIdDetails.gender);
            $('#' + PerDetScrId + 'gender_div').find('li').removeClass('is-selected hilt')
            $('#' + PerDetScrId + 'gender_option_' + $('#' + paintKYCId + "gender").val()).addClass('is-selected hilt')
        } else {
            $('#' + PerDetScrId + 'AddressAsperAadharRow').addClass('sno');
            // $('#' + paintKYCId + "name").val(gApzCOB.userDetails.userName);
            if (!apz.isNull(gApzCOB.userDetails.userName)) {
                // $('#' + paintKYCId + "name").val(gApzCOB.userDetails.userName);
                $('#' + PerDetScrId + "customerName").text(gApzCOB.userDetails.userName);
                $('#' + PerDetScrId + 'nameList').removeClass('sno');
            } else {
                $('#' + PerDetScrId + 'nameList').addClass('sno');
            }
            $('#' + PerDetScrId + "customerName").text(gApzCOB.userDetails.userName);
            $('#' + paintKYCId + "mobNum").val(mobileNum);
        }
        if (gApzCOB.userDetails.maritialStatus === "M") {
            $('#' + PerDetScrId + "spouseNameDiv").removeClass('sno');
            $('#' + PerDetScrId + "spouseName").val(gApzCOB.userDetails.spouseName);
        } else {
            $('#' + PerDetScrId + "spouseName").val("");
            $('#' + PerDetScrId + "spouseNameDiv").addClass('sno');
        }
        $('#PerDRE__PersonalDetails__maritialStsRadio_option_' + gApzCOB.userDetails.maritialStatus).attr('checked', true);
    }
};
//paint the details on click of back icon.
apz.app.PersonalDetails.paintDetails = function() {
    if (window.editappln || !window.JointFlow) {
        if (!apz.isNull(window.CUST_ADDRESS) && window.CUST_ADDRESS.length > 0) {
            gApzCOB.requestNodes['addressDetailsWrapperList'] = window.CUST_ADDRESS;
        }
        if ((!apz.isNull(window.CUST_ADDRESS_SAVE) && window.CUST_ADDRESS_SAVE.length > 0) && window.inSessionStoreEnabled) {
            window.inSessionStore.addressDetailsWrapperList = window.CUST_ADDRESS_SAVE;
        }
        var custdata = apz.isNull(gApzCOB["requestNodes"]["customerDetailsList"]) ? "" : gApzCOB["requestNodes"]["customerDetailsList"];
        custdata = apz.isNull(window.inSessionStore.customerDetailsList) ? JSON.parse(JSON.stringify(custdata)) : window.inSessionStore
            .customerDetailsList;
        var index = gApzCOB.currentApplicant - 1;
        if (!apz.isNull(custdata[index])) {
            if (!apz.isNull(custdata[index]["payload"])) {
                window.currcutApp = custdata[index]["payload"];
                if (custdata[index]["payload"]["maritalStatus"].toLowerCase() === 'married') {
                    $('#' + PerDetScrId + "spouseNameDiv").removeClass('sno');
                }
                if (!apz.isNull(custdata[index]["customerName"])) {
                    $('#' + paintKYCId + "name").val(custdata[index]["customerName"]);
                    $('#' + PerDetScrId + "customerName").text(custdata[index]["customerName"]);
                    $('#' + PerDetScrId + 'nameList').removeClass('sno');
                } else {
                    $('#' + PerDetScrId + 'nameList').addClass('sno');
                }
                $('#' + paintKYCId + "gender").val(custdata[index]["payload"]["gender"]);
                if (!apz.isNull(custdata[index]["payload"]["dob"])) {
                    //$('#' + paintKYCId + "dob").val(ApzCOB.dateformatter(Date.parse(custdata[0]["payload"]["dob"]), 'd/m/Y'));
                    $('#' + paintKYCId + "dob").val($.datepicker.formatDate(apz.dateformat, new Date((custdata[0]["payload"]["dob"]))));
                }
                if (window.COUNTRYCODE === 'Y') {
                    if (ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].includeInReq === "Y") {
                        $(SelectedItiFlag).removeClass(ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].preferredCountries)
                        $(SelectedFlag).removeClass(ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].preferredCountries)
                        //dummy = apz.isNull(custdata[index]["mobileNumber"]) ? "" : (custdata[index]["mobileNumber"].trim().split(" ")[0].split(
                        //   "+")[1])
                        // dummy1 = apz.isNull(custdata[index]["payload"]["altMobileNumber"]) ? "" : (custdata[index]["payload"]["altMobileNumber"].trim().split(" ")[0]
                        //     .split("+")[1])
                        //dummy1 = apz.isNull(dummy1) ? dummy : dummy1;
                        $(PerSelectedFlag).trigger('click'); //Start: [data-dial-code= ' + dummy + '] this is
                        $(CountryList).addClass(
                        'sno'); // available only if the country drop down is open, hence opening the drop down and hiding it
                        dummy = '91'
                        if (!apz.isNull(dummy)) {
                            $(SelectedFlag).addClass($(DialCode + dummy + ']').attr(CountryCode)); // till we get 
                        }
                        $(CountryList).removeClass(
                        'sno'); //the selected country code. Then remove the sno class and close the country modal and set the country flag
                        $(PerSelectedFlag).trigger('click');
                        $('#PerDRE__PersonalDetails__altregnFlag_li .selected-flag').trigger('click');
                        $(CountryList).addClass('sno');
                        dummy1 = '91'
                        if (!apz.isNull(dummy1)) {
                            $(SelectedItiFlag).addClass($(DialCode + dummy1 + ']').attr(CountryCode));
                        }
                        $(CountryList).removeClass('sno');
                        $('#PerDRE__PersonalDetails__altregnFlag_li .selected-flag').trigger('click') //end fix for #52385
                        $('#' + paintKYCId + "mobNum").val(custdata[index]["mobileNumber"].trim().split(" ")[1]);
                        // $('#' + PerDetScrId + "altPhno").val(custdata[index]["payload"]["altMobileNumber"].trim().split(" ")[1]);
                        if ((!apz.isNull(custdata[index]["mobileNumber"]) && !apz.isNull(custdata[index]["mobileNumber"].trim().split(" ")[0]))) {
                            $('#' + PerDetScrId + "regnFlag").val(('+91' + ' ' + custdata[index]["mobileNumber"].trim()).split(" ")[0]);
                        } else {
                            $(SelectedFlag).addClass(ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].preferredCountries)
                        }
                        // if ((!apz.isNull(custdata[index]["payload"]["altMobileNumber"]) && !apz.isNull(custdata[index]["payload"]["altMobileNumber"].trim().split(
                        //         " ")[0]))) {
                        //     $('#' + PerDetScrId + "altregnFlag").val(custdata[index]["payload"]["altMobileNumber"].trim().split(" ")[0]);
                        // } else {
                        //     $(SelectedItiFlag).addClass(ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0]
                        //         .preferredCountries)
                        // }
                    } else {
                        $('#' + paintKYCId + "mobNum").val(custdata[index]["mobileNumber"]);
                        // $('#' + PerDetScrId + "altPhno").val(custdata[index]["payload"]["altMobileNumber"]);
                    }
                } else {
                    $('#' + paintKYCId + "mobNum").val(custdata[index]["mobileNumber"]);
                    // $('#' + PerDetScrId + "altPhno").val(custdata[index]["payload"]["altMobileNumber"]);
                }
                $('#' + PerDetScrId + "email").val(custdata[index]["payload"]["emailId"]);
                $('#PerDRE__PersonalDetails__maritialStsRadio_option_' + custdata[index]["payload"]["maritalStatus"]).attr('checked', true)
                $('#' + PerDetScrId + "spouseName").val(custdata[index]["payload"]["spouseName"]);
                $('#' + PerDetScrId + "panNumber").val(custdata[index]["payload"]["pan"]);
                if (!apz.isNull(custdata[index]["payload"]["panNumber"])) {
                    $('#' + PerDetScrId + "PAN_DropDown").val(custdata[index]["payload"]["panNumber"]);
                    if ((custdata[index]["payload"]["panNumberStatus"] == "Verified") && (IS_REINITIATE_APPLICATION || IS_REJECTED_APPLICATION)) {
                        window.REINITIATE_PAN_CHECKED = true;
                    } else {
                        window.REINITIATE_PAN_CHECKED = false;
                    }
                    if((currcutApp.panNumberStatus !== "Verified") && REINITIATE_PAN_CHECKED){
                      inSessionStore.customerDetailsList[0].payload.panNumberStatus = '';
                      inSessionStore.customerDetailsList[1].payload.panNumberStatus = '';
                    }
                    apz.app.PersonalDetails.paintpanDetails(custdata[index])
                }
            }
            apz.app.PersonalDetails.paintDetailsOnBackNav();
        }
        if (!backNav && gApzCOB.currentApplicant <= 1 && !IS_REJECTED_APPLICATION) {
            var leaddata = gApzCOB.selLeadDtls;
            $(`#${PerDetScrId}addressLine1`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine1`, leaddata.presLine1 ?? '')).blur();
            $(`#${PerDetScrId}addressLine2`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine2`, leaddata.presLine2 ?? '')).blur();
            $(`#${PerDetScrId}addressLine3`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}addressLine3`, leaddata.presLine3 ?? '')).blur();
            $(`#${PerDetScrId}pin`).val(leaddata.presPincode);
            $(`#${PerDetScrId}city`).val(leaddata.presCityTownVillage + ", " + leaddata.presArea);
            $(`#${PerDetScrId}district`).val(leaddata.presDist);
            $(`#${PerDetScrId}state`).val(leaddata.presState);
            $(`#${PerDetScrId}country`).val(leaddata.presCountry);
            $(`#${PerDetScrId}ownership`).val(leaddata.prestAddreResidentownership ?? PleaseSelect);
            $(`#${PerDetScrId}cityYears`).val(leaddata.prestAddreResidencecitysince ?? PleaseSelect);
            $(`#${PerDetScrId}resYears`).val(leaddata.prestAddreResidencecitysince ?? PleaseSelect);
            $(`#${PerDetScrId}currResProof`).val(leaddata.prestAddreCurrentaddressproof ?? PleaseSelect);
            let houseTypeObj = {};
            houseTypeObj.houseType = leaddata.prestAddreHousetype;
            apz.app.PersonalDetails.onchangeTypeofHouse(houseTypeObj);
            $(`#${PerDetScrId}permanentAddres1`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}permanentAddres1`, leaddata.permLine1 ?? '')).blur();
            $(`#${PerDetScrId}permanentAddres2`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}permanentAddres2`, leaddata.permLine2 ?? '')).blur();
            $(`#${PerDetScrId}permanentAddres3`).val(ApzCOB.getSubstrValue(`#${PerDetScrId}permanentAddres3`, leaddata.permLine3 ?? '')).blur();
            $(`#${PerDetScrId}permanentPincode`).val(leaddata.permPincode);
            $(`#${PerDetScrId}permanentcity`).val(leaddata.permCityTownVillage + ", " + leaddata.permCityTownVillage);
            $(`#${PerDetScrId}permanentDist`).val(leaddata.permDist);
            $(`#${PerDetScrId}permanentState`).val(leaddata.permState);
            $(`#${PerDetScrId}permanentCountry`).val(leaddata.permCountry);
            $(`#${PerDetScrId}permArea`).val(leaddata.permArea);
            $(`#${PerDetScrId}permLandmark`).val(leaddata.permtAddreLandmark);
            $(`#${PerDetScrId}permanentAdd_option_Y`).prop(`checked`, true);
        }
    }
};
//to hide the sub header when all the subheader fields are hidden.
apz.app.PersonalDetails.hideHeader = function() {
    ApzCOB.hideHeader([{
        'fieldId': [PerDetScrId + 'AlternatePhNoDiv', PerDetScrId + 'EmailDiv'],
        'headerId': PerDetScrId + 'ContactDetailsHeader'
    }, {
        'fieldId': [PerDetScrId + 'AddressAsperAadharDiv', PerDetScrId + 'pincodeDiv', PerDetScrId + 'stateDiv',
            PerDetScrId + 'cityDiv',
            PerDetScrId + 'DoorNumDiv', PerDetScrId + 'BuildingNameDiv', PerDetScrId + 'LandMarkDiv'
        ],
        'headerId': PerDetScrId + 'CommunicationAddHeader'
    }, {
        'fieldId': [PerDetScrId + 'panNumberDiv'],
        'headerId': PerDetScrId + 'panHeader'
    }])
}
//to validate fields
apz.app.PersonalDetails.formValidator = function(formId) {
    var form = "",
        form_validator_check = {};
    form = $("#" + PerDetScrId + formId).find("input");
    for (var n = 0; n < form.length; n++) {
        form_validator_check = {
            [form[n]['id']]: {
                verify: nullcheck,
            }
        };
        ApzCOB.validateInputFields(form, form_validator_check);
    }
}
// To set the marital status value based on the selection
apz.app.PersonalDetails.MartialStatus = function(pthis) {
    MaritalStatus = pthis.id.split('_').pop();
    if (pthis.id.endsWith('M')) {
        $('#' + PerDetScrId + "spouseNameDiv").removeClass('sno');
    } else {
        $('#' + PerDetScrId + "spouseName").val("");
        $('#' + PerDetScrId + "spouseNameDiv").addClass('sno');
    }
}
// communication address toggle function
apz.app.PersonalDetails.sameCommunicationAddress = function(pthis) {
    if (!$('#' + PerDetScrId + 'commAddToggle').is(':checked')) {
        window.sameCommAddress = false;
        $('#' + PerDetScrId + "addressDetailsRow").removeClass('sno');
    } else {
        window.sameCommAddress = true;
        $('#' + PerDetScrId + "addressDetailsRow").addClass('sno');
        apz.app.PersonalDetails.clearAddressFields();
    }
}
/**
 * @author praisy.b
 * @since 08.06.21
 * Added below function to avoid validation check inside createApplication application function
 * No min max length validation and Mobile tel validation
 **/
apz.app.PersonalDetails.validateMobNumInputFields = function() {
    if (!REJECT_REQUEST_CALL) {
        window.isMobErr = false;
        var lcountrycode, lcountrycodeWord;
        if (!apz.isNull($('#' + paintKYCId + 'mobNum').val())) {
            lcountrycode = $("#" + PerDetScrId + "regnFlag_li").children().children().children().children().attr('title').split(": ")[1];
            lcountrycodeWord = $("#" + PerDetScrId + "regnFlag_li").children().children().children().children().children().attr('class').split(
                "iti-flag ")[1];
            ApzCOB.fnValidateMobileNumber(paintKYCId + 'mobNum', lcountrycode, lcountrycodeWord);
        }
        if (!apz.isNull($('#' + PerDetScrId + 'sec_mobile').val())) {
            lcountrycode = $("#" + PerDetScrId + "SecRegnFlag_li").children().children().children().children().attr('title').split(": ")[1];
            lcountrycodeWord = $("#" + PerDetScrId + "SecRegnFlag_li").children().children().children().children().children().attr('class').split(
                "iti-flag ")[1];
            ApzCOB.fnValidateMobileNumber(PerDetScrId + 'sec_mobile', lcountrycode, lcountrycodeWord);
        }
        if (!window.gIsMinMaxErr && !window.isMobErr) {
            return true;
        } else {
            // if (apz.childScr === "PersonalDetails" && window.isMobErr) {
            if ($('#' + PerDetScrId + 'MobileNumberDiv input').hasClass("err")) {
                $('#' + PerDetScrId + 'MobileNumberDiv .err')[0].scrollIntoView();
            }
            window.isMobErr = false;
            // }
            return false;
        }
    } else {
        return true;
    }
}
apz.app.PersonalDetails.perDetAsFirstScr = function() {
    if ((kycID !== -1 && PerID < kycID) || (CusVerID !== -1 && PerID < CusVerID)) {
        if (window.COUNTRYCODE === 'Y') {
            if (ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].includeInReq === "Y") {
                gApzCOB.userDetails.mobileNum = $('#' + PerDetScrId + 'regnFlag').val() + " " + $('#' + paintKYCId + 'mobNum').val();
            } else {
                gApzCOB.userDetails.mobileNum = $('#' + paintKYCId + 'mobNum').val();
            }
        } else {
            gApzCOB.userDetails.mobileNum = $('#' + paintKYCId + 'mobNum').val();
        }
        gApzCOB.userDetails.userName = $('#' + paintKYCId + 'name').val();
        gApzCOB.userDetails.panNum = $('#' + PerDetScrId + 'panNumber').val();
        gApzCOB.userDetails.email = $('#' + PerDetScrId + 'email').val();
    }
}
// request creation function
apz.app.PersonalDetails.createRequest = function(iSave) {
    if (apz.app.PersonalDetails.validateMobNumInputFields() || !apz.isNull(iSave)) {
        apz.app.PersonalDetails.personalDetailObject();
        var existingLoanObj = {
            "existingLoansDetailList": []
        };
        if (apz.data.scrdata.PerDRE__IPaintLoanDetails_Res.length > 0) {
            apz.app.PersonalDetails.existingLoanObject();
        } else {
            var obj = {
                "hasExistingLoans": 'N',
                "existingLoanId": '',
                "loanDtlsId": '',
                "payload": {
                    "productType": '',
                    "subProductType": '',
                    "loanAmount": '',
                    "accountNumber": '',
                    "outstandingAmount": '',
                    "expectedClosureDate": ''
                }
            }
            // existingLoanObj.existingLoansDetailList.push(obj);
            gApzCOB.requestNodes['existingLoanDetailsWrapperList'] = [existingLoanObj];
        }
        var custDtlId = gApzCOB.currentApplicant > 1 ? gApzCOB.userDetails.CoApplicantCustomerId : gApzCOB.userDetails.custDtlId
        var addressDetObj = {
            "addressDetailsList": [{
                "addressDtlsId": gApzCOB.userDetails.addressDtlsId,
                "custDtlId": parseInt(custDtlId),
                "addressType": "Personal",
                "payload": {
                    //"commAddEqPerAdd": apz.getElmValue("PerDRE__PersonalDetails__AddPermanentToggle"),
                    //  "relatedKey": "custDtlId",
                    //  "relatedValue": gApzCOB.userDetails.custDtlId,
                    "addressList": apz.app.PersonalDetails.address()
                }
            }]
        }
        if (iSave !== 'captureBefore') {
            if (gApzCOB.currentApplicant > 1) {
                addressDetObj.addressDetailsList[0].addressDtlsId = apz.isNull(gApzCOB.userDetails.CoApplicantAddressDtlsId) ? "" : gApzCOB
                    .userDetails.CoApplicantAddressDtlsId;
            }
        }
        if (iSave === 'captureAfter') {
            window.afterBack.customerDetailsList = [];
            window.afterBack.addressDetailsWrapperList = [];
            window.afterBack.customerDetailsList.push(perDetobj);
            window.afterBack.addressDetailsWrapperList = [addressDetObj];
            window.CUST_ADDRESS_SAVE = [];
            window.CUST_ADDRESS_SAVE.push(addressDetObj);
            return window.afterBack;
        }
        if (iSave === 'captureBefore') {
            window.beforeBack.customerDetailsList = [];
            window.beforeBack.addressDetailsWrapperList = [];
            window.beforeBack.customerDetailsList.push(perDetobj);
            window.beforeBack.addressDetailsWrapperList = [addressDetObj];
            window.CUST_ADDRESS_SAVE = [];
            window.CUST_ADDRESS_SAVE.push(addressDetObj);
            return window.beforeBack;
        }
        //  window.inSessionStore.customerDetailsList = [];
        if (gApzCOB.currentApplicant <= 1) {
            if (!apz.isNull(window.inSessionStore.addressDetailsWrapperList)) {
                if(!apz.isNull(gApzCOB.userDetails)){
                   if(!apz.isNull(gApzCOB.userDetails.custDtlId)){
                    let itemIndex = window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(addr => parseInt(addr.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId) && addr.addressType === addressDetObj.addressDetailsList[0].addressType);
                    window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[itemIndex] = addressDetObj.addressDetailsList[0];
                   }
                } else {
                    window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[gApzCOB.currentApplicant - 1] = addressDetObj
                    .addressDetailsList[0];  
                }
            } else {
                window.inSessionStore.addressDetailsWrapperList = [];
                window.inSessionStore.addressDetailsWrapperList = [addressDetObj];
            }
        } else {
                   if(!apz.isNull(gApzCOB.userDetails.CoApplicantCustomerId)){
                        let itemIndex = window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList.findIndex(addr => parseInt(addr.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId) && addr.addressType === addressDetObj.addressDetailsList[0].addressType);
                    window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[itemIndex] = addressDetObj.addressDetailsList[0];
                   } else {
                       window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[gApzCOB.currentApplicant - 1] = addressDetObj
                    .addressDetailsList[0];
                   }
        }
        //  window.inSessionStore.customerDetailsList.push(perDetobj);
        if (gApzCOB.currentApplicant <= 1) {
            window.CUST_ADDRESS_SAVE = [];
        } else {
                  if(apz.isNull(window.CUST_ADDRESS_SAVE)){
         window.CUST_ADDRESS_SAVE = [];   
        }  
        }
        window.CUST_ADDRESS_SAVE.push(addressDetObj);
        if (iSave === 'triggerdSave') {
            return window.inSessionStore;
        }
        if (gApzCOB.currentApplicant <= 1) {
            if (!apz.isNull(window.inSessionStore.customerDetailsList)) {
                if(!apz.isNull(gApzCOB.userDetails)){
                   if(!apz.isNull(gApzCOB.userDetails.custDtlId)){
                    let itemIndex =  window.inSessionStore.customerDetailsList.findIndex(cust => parseInt(cust.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));  
                    window.inSessionStore.customerDetailsList[itemIndex] = perDetobj;
                   }
                } else {
                  window.inSessionStore.customerDetailsList[gApzCOB.currentApplicant - 1] = perDetobj;  
                }
            } else {
                window.inSessionStore.customerDetailsList = [];
                window.inSessionStore.customerDetailsList.push(perDetobj);
            }
        } else {
            if (!apz.isNull(gApzCOB.userDetails.CoApplicantCustomerId)) {
                let itemIndex = window.inSessionStore.customerDetailsList.findIndex(cust => parseInt(cust.custDtlId) === parseInt(gApzCOB.userDetails.CoApplicantCustomerId));
                window.inSessionStore.customerDetailsList[itemIndex === -1 ? inSessionStore.customerDetailsList.length : itemIndex] = perDetobj;
            } else {
                if (window.inSessionStore.customerDetailsList.length === gApzCOB.currentApplicant) {
                    window.inSessionStore.customerDetailsList[gApzCOB.currentApplicant - 1] = perDetobj;
                } else {
                    window.inSessionStore.customerDetailsList.push(perDetobj);
                }
            }
        }
        gApzCOB.requestNodes['customerDetailsList'] = [];
        gApzCOB.requestNodes['customerDetailsList'].push(perDetobj);
        window.CUST_ADDRESS = []
        window.CUST_ADDRESS.push(addressDetObj);
        if (!window.pendingApplication) {
            gApzCOB.requestNodes['addressDetailsWrapperList'] = [];
        }
        apz.app.PersonalDetails.perDetAsFirstScr();
        gApzCOB.requestNodes['addressDetailsWrapperList'] = window.CUST_ADDRESS;
        /*if (gApzCOB.currentApplicant > 1) {
            window.inSessionStore.customerDetailsList[0].custDtlId = parseInt(gApzCOB.userDetails.custDtlId);
            window.inSessionStore.addressDetailsWrapperList[0].addressDetailsList[0].addressDtlsId = gApzCOB.userDetails.addressDtlsId;
        }*/
        return gApzCOB["requestNodes"];
    }
    return []
}
apz.app.PersonalDetails.existingLoanObject = function() {
    var existingLoanObj = {
        "existingLoansDetailList": []
    };
    for (var i = 0; i < apz.data.scrdata.PerDRE__IPaintLoanDetails_Res.length; i++) {
        var obj = {
            "hasExistingLoans": '',
            "payload": {
                "productType": '',
                "subProductType": '',
                "loanAmount": '',
                "accountNumber": '',
                "outstandingAmount": '',
                "expectedClosureDate": ''
            }
        };
        obj.hasExistingLoans = 'Y';
        if (!apz.isNull(gApzCOB.userDetails.existisingLoanDtlId) && gApzCOB.userDetails.existisingLoanDtlId.length > 0) {
            obj.existingLoanId = gApzCOB.userDetails.existisingLoanDtlId[i];
        } else {
            obj.existingLoanId = "";
        }
        if(!apz.isNull(gApzCOB.userDetails.existingLoanId) && gApzCOB.userDetails.existingLoanId.length > 0){
            obj.loanDtlsId = gApzCOB.userDetails.existingLoanId[i];
        } else {
            obj.loanDtlsId = "";
        }
        obj.payload.productType = apz.data.scrdata.PerDRE__IPaintLoanDetails_Res[i].loanType;
        obj.payload.subProductType = "";
        obj.payload.loanAmount = "";
        obj.payload.accountNumber = "";
        obj.payload.outstandingAmount = apz.data.scrdata.PerDRE__IPaintLoanDetails_Res[i].outstandingAmt;
        obj.payload.expectedClosureDate = "";
        existingLoanObj.existingLoansDetailList.push(obj);
    }
    gApzCOB.requestNodes['existingLoanDetailsWrapperList'] = [existingLoanObj];
};
apz.app.PersonalDetails.address = function() {
    var addressArr = [];
    var residentialAddress = {};
    var permanentAdress = {};
    var communicationAddress = {};
    var resCitySince;
    var resAddrSince;
    residentialAddress = {
        "addressType": "Present",
        "state": $('#' + PerDetScrId + 'state').val(),
        "city": $('#' + PerDetScrId + 'city').val(),
        "country": $('#' + PerDetScrId + 'country').val(),
        "pinCode": $('#' + PerDetScrId + 'pin').val(),
        "addressLine1": $('#' + PerDetScrId + 'addressLine1').val(),
        "addressLine2": $('#' + PerDetScrId + 'addressLine2').val(),
        "addressLine3": $('#' + PerDetScrId + 'addressLine3').val(),
        "district": $('#' + PerDetScrId + 'district').val(),
        "residenceOwnership": $('#' + PerDetScrId + 'ownership').val(),
        "residenceAddressSince": $('#' + PerDetScrId + 'resYears').val(),
        "residenceCitySince": $('#' + PerDetScrId + 'cityYears').val(),
        "currentAddressProof": $("#PerDRE__PersonalDetails__currResProof").val(),
        "houseType": window.houseTypechoose,
        // "communctionAddress": window.commAddr,
        "locateCoOrdinatesFor": window.loc_CordFor,
        "locateCoOrdinates": $('#' + coOrdinateInputTag).val(),
        "area": $(`#${PerDetScrId}presArea`).val(),
        "landMark": $(`#${PerDetScrId}presLandmark`).val()
    }
    addressArr.push(residentialAddress);
    if (gApzCOB.currentApplicant == 1) {
        applicantState = residentialAddress.state.toUpperCase();
    }
    let permanentAddressSameAs = $('input[name="PerDRE__PersonalDetails__permanentAdd_"]:checked').val();
    permanentAdress = {
        "addressType": "Permanent",
        "addressSameAs": apz.isNull(permanentAddressSameAs) ? "" : permanentAddressSameAs,
        "state": $('#' + PerDetScrId + 'permanentState').val(),
        "city": $('#' + PerDetScrId + 'permanentcity').val(),
        "country": $('#' + PerDetScrId + 'permanentCountry').val(),
        "pinCode": $('#' + PerDetScrId + 'permanentPincode').val(),
        "addressLine1": $('#' + PerDetScrId + 'permanentAddres1').val(),
        "addressLine2": $('#' + PerDetScrId + 'permanentAddres2').val(),
        "addressLine3": $('#' + PerDetScrId + 'permanentAddres3').val(),
        "district": $('#' + PerDetScrId + 'permanentDist').val(),
        "area": $(`#${PerDetScrId}permArea`).val(),
        "landMark": $(`#${PerDetScrId}permLandmark`).val()
    }
    addressArr.push(permanentAdress);
    let communicationAddressSameAs = $('input[name="PerDRE__PersonalDetails__commAddRadio_"]:checked').val();
    communicationAddress = {
        "addressType": "Communication",
        "addressSameAs": apz.isNull(communicationAddressSameAs) ? "" : communicationAddressSameAs,
        "state": $('#' + PerDetScrId + 'commState').val(),
        "city": $('#' + PerDetScrId + 'commCity').val(),
        "country": $('#' + PerDetScrId + 'commCountry').val(),
        "pinCode": $('#' + PerDetScrId + 'commPincode').val(),
        "addressLine1": $('#' + PerDetScrId + 'commAddress1').val(),
        "addressLine2": $('#' + PerDetScrId + 'commAddress2').val(),
        "addressLine3": $('#' + PerDetScrId + 'commAddress3').val(),
        "district": $('#' + PerDetScrId + 'commDist').val(),
        "area": $(`#${PerDetScrId}commArea`).val(),
        "landMark": $(`#${PerDetScrId}commLandmark`).val()
    }
    addressArr.push(communicationAddress);
    return addressArr;
}
apz.app.PersonalDetails.clearAddressFields = function() {
    $('#' + PerDetScrId + 'commAddressForm').find('input').val('');
    $('#' + PerDetScrId + 'ownership').val(PleaseSelect);
    $('#' + PerDetScrId + 'resYears').val(PleaseSelect);
    $('#' + PerDetScrId + 'resMonths').val(PleaseSelect);
    $('#' + PerDetScrId + 'cityYears').val(PleaseSelect);
    $('#' + PerDetScrId + 'cityMonths').val(PleaseSelect);
}
apz.app.PersonalDetails.paintData = function() {
    if (!apz.isNull(apz.app.serReqList)) {
        $("#PerDRE__PersonalDetails__email").val(apz.app.serReqList[0]);
    }
}
