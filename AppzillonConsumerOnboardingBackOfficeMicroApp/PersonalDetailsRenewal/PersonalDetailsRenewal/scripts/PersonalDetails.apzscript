apz.app.PersonalDetails.verifyAppln = function(defaultScreen) {
    // if (!apz.isNull(apz.getElmValue("PerDRE__IPaintKYCDetails__o__PerDRE__IPaintKYCDetails_Res__mobNum")) && !apz.isNull(apz.getElmValue(
    //         PerDetScrId + "altPhno"))) {
    //     if (apz.getElmValue("PerDRE__IPaintKYCDetails__o__PerDRE__IPaintKYCDetails_Res__mobNum") === apz.getElmValue(PerDetScrId + "altPhno")) {
    //         ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_PERDTLS_ERR_TXT_SAMEMOBNO"), "E");
    //         return false;
    //     }
    // }
    if (defaultScreen) {
        gApzCOB.userDetails.panNum = $('#' + PerDetScrId + 'panNumber').val();
        // gApzCOB.userDetails.email = $('#' + PerDetScrId + 'email').val();
        if (window.COUNTRYCODE === 'Y') {
            if (ApzCOB.GetCommonCodes("COUNTRYCODE").COUNTRYCODE[0].includeInReq === "Y") {
                gApzCOB.userDetails.mobileNum = $('#' + PerDetScrId + 'regnFlag').val() + " " + $('#' + paintKYCId + 'mobNum').val();
            } else {
                gApzCOB.userDetails.mobileNum = $('#' + paintKYCId + 'mobNum').val();
            }
        } else {
            gApzCOB.userDetails.mobileNum = $('#' + paintKYCId + 'mobNum').val();
        }
        if (apz.app.PersonalDetails.verifyPan()) {
            ApzCOB.VerifyApplication();
        }
    } else {
        apz.app.PersonalDetails.verifyApplnConditionCheck1();
        /*if (apz.app.PersonalDetails.verifyPan()) {
            if(gApzCOB.product === "CARDS"){
                ApzCOB.createCreditCard();
            }else{
                ApzCOB.createApplication();
            }
        }*/
    }
}
apz.app.PersonalDetails.verifyApplnConditionCheck1 = function() {
    if (apz.app.PersonalDetails.verifyPan()) {
        if (gApzCOB.product === "CARDS") {
            ApzCOB.createCreditCard();
        } else {
            ApzCOB.createApplication();
            //window.fullAddress = gApzCOB.requestNodes.addressDetailsWrapperList;
        }
        return true;
    }
}
