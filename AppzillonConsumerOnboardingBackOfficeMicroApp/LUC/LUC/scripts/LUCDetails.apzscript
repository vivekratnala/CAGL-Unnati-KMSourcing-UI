apz.app.onShown_LUCDetails = function() {
    $('#Luc__LUCDetails__additionalDetail1').attr('type', 'text');
    $('#Luc__LUCDetails__additionalDetail2').attr('type', 'text');
    $('#Luc__LUCDetails__additionalDetail3').attr('type', 'text');
    $('#Luc__LUCDetails__additionalDetail1').off('blur');
    $('#Luc__LUCDetails__additionalDetail2').off('blur');
    $('#Luc__LUCDetails__additionalDetail3').off('blur');
    window.AppcustomerId = ApzCOB.getCustDetailID("Applicant");
    AppCustCibilData = inSessionStore.cibilDetailsWrapperList.filter(
        (item) => item.cibilDetails?.custDtlId == AppcustomerId);
    let totalInsuranceCharge = Number(AppCustCibilData[0]?.cibilDetails?.payload?.insuranceChargeJoint) + Number(AppCustCibilData[0]?.cibilDetails
        ?.payload?.insuranceChargeMember) + Number(AppCustCibilData[0]?.cibilDetails?.payload?.insuranceChargeSpouse)
    let totalCharges = Number(AppCustCibilData[0]?.cibilDetails?.payload?.processingFees || 0) + Number(totalInsuranceCharge || 0) + Number(
        AppCustCibilData[0]?.cibilDetails?.payload?.stampDutyCharge || 0) + Number(inSessionStore.leadDetails?.caglOs || inSessionStore
        .renewalLeadDetails?.caglOs || 0);
    window.totalTransferedAmount = parseFloat((inSessionStore.loanDetails?.sanctionedLoanAmount || "0").toString().replace(/,/g, "")) - parseInt(totalCharges || 0);
$(`#${screenId}DisbursmentDate`).text((() => { const t = inSessionStore.applicationTimelineDtl?.find(i => i.stage === "Disbursement")?.timeStamp; if (!t) return ""; const d = new Date(t); return isNaN(d.getTime()) ? "" : `${d.getDate()}-${d.getMonth()+1}-${d.getFullYear()}`; })());
    $(`#${screenId}DisbusmentAmout_txtcnt`).text(` ${inSessionStore.loanDetails?.sanctionedLoanAmount}`);
    $(`#${screenId}NetAmout_txtcnt`).text(` ${totalCharges}`);
    $(`#${screenId}amoutTrasferToCust_txtcnt`).text(`${window.totalTransferedAmount}`);
    apz.app.LUCDetails.previewAddressContact();
    $("#Luc__LUCBase__submitBtn").attr("disabled", true);
    gcurrStage = inSessionStore.applnWfDefinitionList.filter(item => item.action == "SUBMIT")[0]?.workFlowId;
    $(`#${screenId}res_checboxFrm`).removeClass("sno");
    if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "BM") {
        apz.app.LUCDetails.populatePorposeDropdowns();
        apz.app.LUCDetails.paintDocumentName("purpose1 Doc")
        apz.app.LUCDetails.paintDocumentName("purpose2 Doc")
        apz.app.LUCDetails.paintDocumentName("purpose3 Doc")
        $(".imageViewRow").addClass("sno");
        $("#Luc__LUCBase__sendback_btn").addClass("sno");
        $("#Luc__LUCBase__cancel_btn").removeClass("sno");
        $(`#${screenId}checkboxBM`).removeClass("sno");
        $(`#${screenId}checkboxBCM`).addClass("sno");
        $(`#${screenId}isLoanUtilsedRadio`).removeClass("sno");
        $("#Luc__LUCBase__submitBtn_txtcnt").text("Save")
    } else {
        apz.setElmValue("Luc__LUCDetails__isLonUtilised", "Yes")
        $("#Luc__LUCDetails__isAmountUtilisedRow").addClass('sno');
        $("#Luc__LUCBase__cancel_btn").addClass("sno");
        $("#Luc__LUCBase__sendback_btn").removeClass("sno");
        $(".imgupload").addClass('sno')
        $(".imageViewRow").removeClass("sno");
        apz.app.LUCDetails.paintDocuments();
        $(`#${screenId}checkboxBM`).addClass("sno");
        $(`#${screenId}checkboxBCM`).removeClass("sno");
        $(`#${screenId}isLoanUtilsedRadio`).addClass("sno");
        $(`#${screenId}purposerow`).removeClass("sno");
    }
    $(`#${screenId}No_LucRemarks_row`).addClass('sno');
    $('.typeOfbusiness3, .typeOfbusiness2, .typeOfbusiness1, .purposeImgSec1, .purposeImgSec2, .purposeImgSec3').addClass('sno');
    if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "BM") {
        // $(".purposeImgSec1").removeClass('sno');  UAU-234
        if (apz.getElmValue(`${screenId}isLonUtilised`) == 'No') {
            apz.app.LUCDetails.onChangeLoanUtilised();
            $(`#${screenId}No_LucRemarks_row`).removeClass("sno");
            let p = {};
            if (inSessionStore?.lucDetails?.payload) {
                p = JSON.parse(inSessionStore.lucDetails.payload);
            }
            if (p.isAmountUtilised === "No") {
                $(`#${screenId}LucRemarks_No`).val(p.lucRemarks || "");
            }
        }
    }
    apz.app.LUCDetails.paintLucDetails();
    apz.app.LUCDetails.onChangeLoanUtilised();

};
apz.app.LUCDetails.validateMaxDocs = function(parentSelector, childClass, pthis) {
    if (/business/i.test(parentSelector)) {
        const indexToInsert = pthis?.id.split("__")[2].split("_")[0]; // e.g., "1"
        const parts = parentSelector.split("__");
        parentSelector = parts.slice(0, 2).join("__") + "__" + indexToInsert + "_" + parts.slice(2).join("__");
    }
    let fileCount = $(`#${parentSelector}`).find(`.${childClass}`).length;
    if (fileCount >= 2) {
        ApzCOB.fnDisplayMsg("User allowed to upload maximum of 2 documents")
    } else {
        TempImageObject.Type = childClass;
        TempImageObject.index = "Applicant";
        apz.app.LUCDetails.camera(pthis);
    }
};
apz.app.LUCDetails.camera = function(pthis) {
    var cameraObj = {
        "zoomLevel": "20",
        "targetWidth": "950",
        "targetHeight": "950",
        "crop": "Y",
        "cropBox": "square",
        "flash": "N",
        "action": "base64_Save",
        "fileName": 'b',
        "quality": "75",
        "encodingType": "JPG",
        "sourceType": "camera"
    };
    cameraObj.id = "CAMERA_ID";
    cameraObj.callBack = apz.app.LUCDetails.cameraCallback;
    apz.ns.openCamera(cameraObj);
    ApzCOB.getGeoCordinatesMobile();
};
apz.app.LUCDetails.cameraCallback = function(params) {
    cameracallbackres = params;
    let fileName = params.path.split('/').pop();
    apz.app.LUCDetails.saveDocument(fileName, params.encodedImage);
};
apz.app.LUCDetails.saveDocument = function(fileName, base64) {
    let docLevel = "1";
    let ActiveCustType = "Applicant";
    docLevel = ApzCOB.getNextDocLevel(`${TempImageObject?.Type} Doc`, ApzCOB.getCustDetailID(ActiveCustType));
    let req = {
        apiRequest: {
            "requestObj": {
                "appId": gApzCOB.userDetails.appId,
                "applicationId": gApzCOB.userDetails.applicationId,
                "versionNum": 1,
                "stageId": "UPLOADDOCS",
                "requestType": "Edit",
                "customerType": "Applicant",
                "uploadDocumentRequestFields": {
                    "versionNum": 1,
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "appId": gApzCOB.userDetails.appId,
                    "srcScreen": "UPLOADDOCS",
                    "filePath": gApzCOB.userDetails.appId + /LOAN/ + gApzCOB.userDetails.applicationId,
                    "fileName": fileName,
                    "base64Value": base64,
                    "productGroupCode": "LOAN",
                    "isExistingCustomer": "N"
                },
                "applicationDocumentsWrapperList": [{
                    "applicationDocumentsList": [{
                        "appDocId": "",
                        "applicationId": gApzCOB.userDetails.applicationId,
                        "versionNum": 1,
                        "appId": gApzCOB.userDetails.appId,
                        "custDtlId": gApzCOB.userDetails.custDtlId,
                        "documentId": "",
                        "status": "A",
                        "payload": {
                            "docLevel": docLevel,
                            "documentType": `${TempImageObject?.Type} Doc`,
                            "documentDesc": "",
                            "documentLoc": gApzCOB.userDetails.appId + /LOAN/ + gApzCOB.userDetails.applicationId,
                            "screenId": "UploadDocuments",
                            "issueDate": "",
                            "expiryDate": "",
                            "docStatus": "A",
                            "docSide": "Front",
                            "docSize": ApzCOB.getBase64FileSizeInBytes(base64),
                            "documentFileName": fileName,
                            "documentFormat": fileName,
                            "isAdiDoc": "N",
                            "uploadedBy": "BM",
                            "latitude": window.currentGeoCords?.latitude,
                            "longitude": window.currentGeoCords?.longitude,
                            "uploadedTs": new Date().toISOString(),
                        }
                    }]
                }]
            },
            "userId": gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
            "appId": gApzCOB.userDetails.appId,
            "interfaceName": "UploadRPCLoanData"
        }
    }
    req.apiRequest.requestObj.applicationDocumentsWrapperList[0].applicationDocumentsList[0].custDtlId = ApzCOB.getCustDetailID("Applicant");
    apz.startLoader();
    setTimeout(() => {
        ApzCOB.serverBuildParam(gAppId, "UploadRPCLoanData", "N", "N", req, false, apz.app.LUCDetails.saveDocumentCB);
    }, 1000)
};
apz.app.LUCDetails.saveDocumentCB = function(params) {
    const docType = params.req.apiRequest.requestObj.applicationDocumentsWrapperList[0].applicationDocumentsList[0].payload.documentType;
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            ApzCOB.updateInsessionData(params);
            apz.app.LUCDetails.paintDocumentName(docType);
        } else {
            apz.stopLoader();
        }
    } catch {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg("failed to save the data")
    }
};
apz.app.LUCDetails.paintDocumentName = function(docType) {
    let cloneDiv;
    let parentDiv;
    if (apz.isObjectEmpty(inSessionStore) || !inSessionStore.hasOwnProperty('applicationDocumentsWrapperList')) return;
    let documentResp = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList
    if (documentResp.length > 0) {
        window.purpose = documentResp.filter(docs => docs.payload.documentType === docType && parseInt(docs.custDtlId) === parseInt(gApzCOB
            .userDetails.custDtlId));
        if (purpose.length >= 0) {
            if (docType === "purpose1 Doc") {
                cloneDiv = `${screenId}purpose1_0`;
                parentDiv = $(`#${screenId}purposeParentRow1`);
                $(".purposeImgSec1").removeClass('sno');
                parentDiv.html('');
            } else if (docType === "purpose2 Doc") {
                cloneDiv = `${screenId}purpose2_0`;
                parentDiv = $(`#${screenId}purposeParentRow2`);
                $(".purposeImgSec2").removeClass('sno');
                parentDiv.html('');
            } else if (docType === "purpose3 Doc") {
                cloneDiv = `${screenId}purpose3_0`;
                parentDiv = $(`#${screenId}purposeParentRow3`);
                $(".purposeImgSec3").removeClass('sno');
                parentDiv.html('');
            }
            purpose.forEach((doc, index) => {
                let newId = ApzCOB.cloneDashboardDivs(cloneDiv, parentDiv, index + 1);
                let baseName = doc.payload.documentFileName.match(/^[^\d]+/)[0];
                $(`#${newId} .docName a.ett-hypl span`).text(`${baseName}_${index + 1}.jpg`);
                $(`#${newId}`).attr('data-id', doc.appDocId);
                $(`#${newId}`).attr('data-doc-type', docType);
                $(`#${newId}`).removeClass('sno');
                // Luc__LUCDetails__purpose_img_name_2_txtcnt
            })
        }
    }
};
apz.app.LUCDetails.viewIncomeDoc = function(pthis) {
    let documentId = $(pthis).parents('.uploadimg').attr('data-id');
    let docDetails = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.find(doc => parseInt(doc.appDocId) === parseInt(
        documentId));
    if (!apz.isObjectEmpty(docDetails)) {
        let fileName = docDetails?.payload?.documentFileName;
        let callBackFn = apz.app.LUCDetails.viewIncomeDocCB;
        window.ImageLocationDetails = {
            latitude: docDetails?.payload?.latitude || "",
            longitude: docDetails?.payload?.longitude || "",
            uploadedTs: docDetails?.payload?.uploadedTs || "",
            documentFileName: docDetails?.payload?.documentFileName || ""
        };
        lobj.fileName = fileName;
        lobj.documentType = docDetails?.payload?.documentType || "";
        lobj.docLevel = docDetails?.payload?.docLevel || "";
        ApzCOB.downloadFileFromServer(fileName, callBackFn);
    }
};
apz.app.LUCDetails.viewIncomeDocCB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.base64)) {
        $(`#${screenId}imgView`).attr('src', 'data:image/png;base64,' + params.base64);
        let id = `#${screenId}imgView`;
        if (Object.keys(window.ImageLocationDetails).length > 0) {
            apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
        }
        ApzCOB.toggleModal(`${screenId}viewUploadedModal`);
    } else {
        ApzCOB.fnDisplayMsg("Document is not available")
    }
};
apz.app.LUCDetails.validateUtilised = function(i) {
    $(`#${screenId}unUtilisedLoanAmount`).val(totalTransferedAmount - [1, 2, 3].reduce((s, x) => s + (parseFloat($(
        `#${screenId}utilisedAmout${x}`).val().replace(/,/g, "")) || 0), 0));
};
apz.app.LUCDetails.totalUnutilisedAmount = function() {
    let unUtilised = '';
    let utilisedAmounts = [1, 2, 3].map(i => parseFloat(($(`#${screenId}utilisedAmout${i}`).val() || "").replace(/,/g, "")) || 0);
    let checkUtilisingloanVal = apz.getElmValue(`${screenId}isLonUtilised`);
    window.totalUtilisedVal = utilisedAmounts.reduce((sum, val) => sum + val, 0);
    // Condition 1: If total < 0 ? Clear all utilised fields
    if (checkUtilisingloanVal === 'No') {
        // If loan is not utilized at all
        if (totalUtilisedVal === 0) {
            unUtilised = totalTransferedAmount;
        }
    } else if (checkUtilisingloanVal === 'Yes') {
        if (totalUtilisedVal < 0) {
            [1, 2, 3].forEach(i => $(`#${screenId}utilisedAmout${i}`).val(""));
            ApzCOB.fnDisplayMsg("This value cannot go below zero. Please validate your data", "E");
            return false;
        }
        // Condition 2: Total cannot exceed transferred amount
        if (totalUtilisedVal > totalTransferedAmount) {
            ApzCOB.fnDisplayMsg("Total utilisedAmount should not be greater than amount transferred to customer. Please enter a valid amount.",
                "E");
            return false;
        }
        unUtilised = totalTransferedAmount - totalUtilisedVal;
    }
    return unUtilised;
};
apz.app.LUCDetails.onChangeLoanUtilised = function(pthis) {
    let totalUnutilisedAmount = apz.app.LUCDetails.totalUnutilisedAmount();
    $(`#${screenId}unUtilisedLoanAmount`).val(totalUnutilisedAmount);
    if (totalUnutilisedAmount > 0) {
        $("#Luc__LUCBase__submitBtn_txtcnt").text("Save")
    } else {
        $("#Luc__LUCBase__submitBtn_txtcnt").text("Submit")
    }
};
apz.app.LUCDetails.previewAddressContact = function() {
    let addressDetails;
    let permanentDetails;
    const applicant = inSessionStore.customerDetailsList.find(el => el.customerType === "Applicant");
    const coapp = inSessionStore.customerDetailsList.find(el => el.customerType === "Co-App");
    if (inSessionStore.addressDetailsWrapperList[0].addressDetailsList.length > 0 && inSessionStore.customerDetailsList.length > 0) {
        inSessionStore.addressDetailsWrapperList[0].addressDetailsList.forEach(type => {
            if (type.addressType === "Personal" && type.custDtlId === gApzCOB.userDetails.custDtlId) {
                type.payload.addressList.forEach(address => {
                    if (address.addressType === "Present") {
                        addressDetails = address;
                        $(`#${screenId}prestAdress`).text(
                            `${addressDetails.addressLine1}, ${addressDetails.area}, ${addressDetails.city} - ${addressDetails.pinCode}, ${addressDetails.country}`
                        );
                    } else if (address.addressType === "Permanent") {
                        permanentDetails = address;
                        if (address.addressSameAs === 'Y') {
                            $(`#${screenId}permanentAdres`).text("Same as Present Address");
                        } else {
                            permanentDetails = address;
                            $(`#${screenId}permanentAdres`).text(
                                `${address.addressLine1}, ${address.area}, ${address.city} - ${address.pinCode}, ${address.country}`
                            );
                        }
                    }
                });
            }
        });
        $(`#${screenId}appNameMobileNo`).text(`${applicant?.customerName || ""} / ${applicant?.mobileNumber || ""}`);
        $(`#${screenId}coappNameMobileNo`).text(`${coapp?.customerName || ""} / ${coapp?.mobileNumber || ""}`);
        $(`#${screenId}productName`).text(window.productName);
        // $(`#${screenId}A_residence_stabilit_present_city_txtcnt`).text(addressDetails.residenceCitySince);
    }
};
apz.app.LUCDetails.onChangeIsLoanUtilised = function() {
    let isUtilised = apz.getElmValue(`${screenId}isLonUtilised`);
    $(`#${screenId}res_checboxFrm`).removeClass("sno");
    let setEmptyYval = [1, 2, 3].forEach(i => {
        $(`#${screenId}utilisedAmout${i}`).val('');
    });
    if (isUtilised === "No") {
        $(`#${screenId}purposerow`).addClass("sno");
        $(`#${screenId}unUtilisedLoanAmount`).val(totalTransferedAmount);
        $(`#${screenId}No_LucRemarks_row`).removeClass('sno')
        $(`#${screenId}responseTextarea_row`).addClass("sno");
    } else {
        $(`#${screenId}purposerow`).removeClass("sno");
        $(`#${screenId}unUtilisedLoanAmount`).val(totalTransferedAmount);
        $(`#${screenId}No_LucRemarks_row`).addClass('sno')
        if (inSessionStore?.lucDetails?.LucDetailsWrapper?.purposes?.some(p => !p.purpose)) {
            ["1", "2", "3"].forEach(n => $(`#${screenId}mainPurposeDropdown${n}`).val("Please Select"));
        }
        if (!apz.isNull(inSessionStore?.lucDetails?.queries)) {
            $(`#${screenId}responseTextarea_row`).removeClass("sno");
        }
    }
    if ($(`#${screenId}checkbox`).is(":checked")) {
        $(`#${screenId}checkbox`).prop("checked", false);
        $("#Luc__LUCBase__submitBtn").attr('disabled', true);
    }
};
apz.app.LUCDetails.handleCheckboxChange = function(pthis, targetId) {
    if ($("#" + pthis.id).is(":checked")) {
        $(`#${targetId}`).attr('disabled', false);
    } else {
        $(`#${targetId}`).attr('disabled', true);
    }
};
apz.app.LUCDetails.deleteIncomeDoc = function(pthis) {
    let documentId = $(pthis).parents('.uploadimg').attr('data-id');
    docDeleteType = $(pthis).parents('.uploadimg').attr('data-doc-type');
    if (!apz.isNull(documentId)) {
        let popUpObj = {};
        popUpObj.text = "Do you want to delete this document?";
        popUpObj.Btn1 = {
            "text": "Yes",
            "onClick": `apz.app.LUCDetails.deleteDocumentCnfm(${documentId})`
        }
        popUpObj.Btn2 = {
            "text": "No",
            "onClick": "apz.app.LUCDetails.closeDeleteCnfmModal()"
        }
        ApzCOB.showRpcModals(popUpObj, "confirmation");
    }
};
apz.app.LUCDetails.closeDeleteCnfmModal = function() {
    ApzCOB.toggleModal(`${screenId}conFormation_mdl`);
};
apz.app.LUCDetails.closeDeleteSuccModal = function() {
    ApzCOB.toggleModal(`${screenId}Succ_modal`);
};
apz.app.LUCDetails.closeDeleteErrModal = function() {
    ApzCOB.toggleModal(`${screenId}CA_Error_modal`);
};
apz.app.LUCDetails.deleteDocumentCnfm = function(docId) {
    let callBackFn = apz.app.LUCDetails.deleteDocumentCnfmCB;
    ApzCOB.deleteDocument('', '', '', docId, callBackFn)
};
apz.app.LUCDetails.deleteDocumentCnfmCB = function(params) {
    apz.stopLoader();
    try {
        const isSuccess = ApzCOB.handleServiceCallBacks(params);
        const modalOptions = {
            text: isSuccess ? "Document Deleted.!" : "Document Delete Failed.!",
            Btn1: {
                text: "OK",
                onClick: isSuccess ? "apz.app.LUCDetails.closeDeleteSuccModal()" : "apz.app.LUCDetails.closeDeleteErrModal()"
            }
        };
        apz.app.LUCDetails.closeDeleteCnfmModal();
        if (isSuccess && params.res.APZCBO__DeleteDocument_Res.apiResponse.ResponseBody.responseObj === 'Success') {
            let deletedDocId = params?.req?.apiRequest?.requestObj?.appDocId || "";
            let documentArray = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList;
            if (!apz.isNull(deletedDocId) && documentArray.length > 0) {
                let updatedDocs = documentArray.filter(item => Number(item.appDocId) !== Number(deletedDocId));
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = [];
                inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList = structuredClone(updatedDocs);
            }
        }
        apz.app.LUCDetails.paintDocumentName(docDeleteType);
        ApzCOB.showRpcModals(modalOptions, isSuccess ? "Success" : "Error");
    } catch (e) {
        ApzCOB.showRpcModals({
            text: technicalErrMsg,
            Btn1: {
                text: "OK",
                onClick: "apz.app.LUCDetails.closeDeleteErrModal()"
            }
        }, "Error");
    }
};
apz.app.LUCDetails.populatePorposeDropdowns = function() {
    let businessPurposeData = [];
    let PleaseSelect = ["Please Select"];
    let businessArray = [];
    let matchedItem = gLovs.find(item => item.lovName === "LUC_PURPOSE");
    let Bussines = gLovs.find(item => item.lovName === "LUC_BUSINESS");
    if (matchedItem) {
        businessPurposeData = JSON.parse(matchedItem.lovDtls);
    }
    if (Bussines) {
        businessArray = JSON.parse(Bussines.lovDtls)
    }
    apz.app.LUCDetails.populateDropdown([...PleaseSelect, ...businessPurposeData], screenId + "mainPurposeDropdown1");
    apz.app.LUCDetails.populateDropdown([...PleaseSelect, ...businessPurposeData], screenId + "mainPurposeDropdown2");
    apz.app.LUCDetails.populateDropdown([...PleaseSelect, ...businessPurposeData], screenId + "mainPurposeDropdown3");
    apz.app.LUCDetails.populateDropdown([...PleaseSelect, ...businessArray], screenId + "subpurposedorpdown1");
    apz.app.LUCDetails.populateDropdown([...PleaseSelect, ...businessArray], screenId + "subpurposedorpdown2");
    apz.app.LUCDetails.populateDropdown([...PleaseSelect, ...businessArray], screenId + "subpurposedorpdown3");
    // document.getElementById(CaIncomeDetailsScrId + "O_Bus_Pre_option_Yes").checked = true;
};
apz.app.LUCDetails.populateDropdown = function(allOptions, Id) {
    let TempArr = [];
    for (i = 0; i < allOptions.length; i++) {
        let obj = {
            "desc": allOptions[i],
            "val": allOptions[i]
        };
        TempArr.push(obj);
    }
    apz.populateDropdown(document.getElementById(Id), TempArr);
};
apz.app.LUCDetails.paintLucDetails = function() {
    let payload = inSessionStore?.lucDetails?.LucDetailsWrapper;
    if (!payload) {
        return;
    }
    window.isBM = gApzCOB.LoggedInUserDetails?.loginResponse?.addInfo1 === "BM";
    if (payload.isAmountUtilised == 'Yes') {
        apz.setElmValue("Luc__LUCDetails__isLonUtilised", "Yes")
        $(`#${screenId}purposerow`).removeClass("sno");
        apz.app.LUCDetails.populatePorposeDropdowns();
        $(`#${screenId}No_LucRemarks_row`).addClass('sno');
    } else {
        apz.setElmValue("Luc__LUCDetails__isLonUtilised", "No")
        $(`#${screenId}purposerow`).addClass("sno");
        $(`#${screenId}No_LucRemarks_row`).removeClass('sno');
    }
    $(`#${screenId}LucRemarks`).val(payload?.lucRemarks || "");
    $(`#${screenId}unUtilisedLoanAmount`).val(payload?.totalUnutilisedAmount)
    if (Array.isArray(payload.purposes) && payload.purposes.length > 0) {
        payload.purposes.forEach((item, index) => {
            let idx = index + 1;
            let purpose = item.purpose || "";
            let subPurpose = item.subPurpose || "";
            let additionalDetails = item.additionalDetails || "";
            let utilisedAmount = item.utilisedAmount ?? "";
            $(`#${screenId}mainPurposeDropdown${idx}`).val(purpose).change();
            if (purpose === "Business") {
                $(`.purposeImgSec${idx}, .typeOfbusiness${idx}`).removeClass("sno");
            } else {
                $(`.purposeImgSec${idx}, .typeOfbusiness${idx}`).addClass("sno");
            }
            // $(".purposeImgSec1").removeClass('sno'); UAU-234
            $(`#${screenId}subpurposedorpdown${idx}`).val(subPurpose).change();
            $(`#${screenId}additionalDetail${idx}`).val(additionalDetails);
            $(`#${screenId}utilisedAmout${idx}`).val(utilisedAmount);
            if (!isBM) {
                $(`#${screenId}mainPurposeDropdown${idx}`).attr("disabled", true);
                $(`#${screenId}subpurposedorpdown${idx}`).attr("disabled", true);
                $(`#${screenId}additionalDetail${idx}`).attr("disabled", true);
                $(`#${screenId}utilisedAmout${idx}`).attr("disabled", true);
                $(`#${screenId}LucRemarks`).attr("disabled", true);
                $(`#${screenId}response`).attr("disabled", true);
                $(`#${screenId}mainPurposeDropdown${idx}_ext`).addClass('disabled');
                $(`#${screenId}subpurposedorpdown${idx}_ext`).addClass('disabled');
                $(`#${screenId}additionalDetail${idx}`).addClass('disabled');
                $(`#${screenId}utilisedAmout${idx}`).addClass('disabled');
                $(`#${screenId}LucRemarks`).addClass('disabled');
                $(`#${screenId}response`).addClass('disabled');
            }else{
                $(`#${screenId}mainPurposeDropdown${idx}`).attr("disabled", false);
                $(`#${screenId}subpurposedorpdown${idx}`).attr("disabled", false);
                $(`#${screenId}additionalDetail${idx}`).attr("disabled", false);
                $(`#${screenId}utilisedAmout${idx}`).attr("disabled", false);
                $(`#${screenId}LucRemarks`).attr("disabled", false);
                $(`#${screenId}response`).attr("disabled", false);
                $(`#${screenId}mainPurposeDropdown${idx}_ext`).removeClass('disabled');
                $(`#${screenId}subpurposedorpdown${idx}_ext`).removeClass('disabled');
                $(`#${screenId}additionalDetail${idx}`).removeClass('disabled');
                $(`#${screenId}utilisedAmout${idx}`).removeClass('disabled');
                $(`#${screenId}LucRemarks`).removeClass('disabled');
                 $(`#${screenId}response`).removeClass('disabled');
            }
            if(!apz.isNull(inSessionStore?.lucDetails?.queries)){
            apz.app.LUCDetails.paintQueries();
            apz.app.LUCDetails.getmappedQueryresponseData();
            }
        });
    }
};
apz.app.LUCDetails.formatUpdateTs = function(updateTs) {
    let {
        date,
        time
    } = updateTs;
    let day = String(date.day).padStart(2, "0");
    let month = String(date.month).padStart(2, "0");
    let year = date.year;
    let hour = String(time.hour).padStart(2, "0");
    let minute = String(time.minute).padStart(2, "0");
    let second = String(time.second).padStart(2, "0");
    return `Sent back reasons (${day}/${month}/${year} - ${hour}:${minute}:${second})`;
};
apz.app.LUCDetails.paintQueries = function() {
    if (!apz.isNull(inSessionStore?.lucDetails?.queries)) {
        apz.app.LUCDetails.getmappedQueryData();
        // Show UI blocks
        $(`#${screenId}queryRow`).removeClass("sno");
        $(`#${screenId}responseTextarea_row`).removeClass("sno");
        let queryContainer = $(`span#Luc__LUCDetails__selectedQuerydata`);
        queryContainer.html(""); // reset UI
        // Timestamp update
        let updateTs = inSessionStore?.lucDetails?.updateTs;
        if (updateTs) {
            let formattedTS = apz.app.LUCDetails.formatUpdateTs(updateTs);
            $(`#${screenId}queryDisplay_txtcnt`).text(formattedTS);
        }
        // Build all reasons in one string
        let htmlString = "";
        checkedQueries.forEach((q, index) => {
            let reasonText = q;
            if (q.includes("_")) {
                reasonText = q.split("_")[1];
            }
            if (q.startsWith("oth_Other?")) {
                reasonText = q.split("?")[1];
            }
            htmlString += `${index + 1}. ${reasonText}<br/>`;
        });
        // Paint once ✔
        queryContainer.html(htmlString);
    }
};
apz.app.LUCDetails.getmappedQueryresponseData = function() {
    let timeline = inSessionStore.applicationTimelineDtl;
    if (!Array.isArray(timeline)) return;
    let filteredLUCdata = timeline.filter(item => item.stage === "LUC" || item.stage === "LUC Verification");
    let lucSubmittedList = filteredLUCdata.filter(item => item.stage === "LUC" && item.actionTaken === "Submitted By" && item.remarks);
    if (!lucSubmittedList.length) return;
    lucSubmittedList.sort((a, b) => new Date(b.timeStamp) - new Date(a.timeStamp));
    window.latestRecord = lucSubmittedList[0];
    $(`#${screenId}response`).val(latestRecord.remarks);
    if (!apz.isNull(inSessionStore?.lucDetails?.queries)) {
        $(`#${screenId}responseTextarea_row`).removeClass('sno');
    } else {
        $(`#${screenId}responseTextarea_row`).addClass('sno');
    }
};

apz.app.LUCDetails.getmappedQueryData = function() {
    window.LUC_QUERIES = DBKIT_MASTERDATA.filter(item => item.stageName === "LUC" && item.queries && item.queries !== "{}").flatMap(item => JSON
        .parse(item.queries));
    let storedQueries = [];
    if (inSessionStore.lucDetails?.queries) {
        let queryList = inSessionStore.lucDetails.queries.split(",");
        queryList.forEach(q => {
            if (q.startsWith("OTH?")) {
                let otherText = q.split("?")[1];
                storedQueries.push(`oth_Other?${otherText}`);
            } else {
                let master = LUC_QUERIES.find(item => item.id === q);
                if (master) {
                    storedQueries.push(`${master.id}_${master.value}`);
                }
            }
        });
    }
    storedQueries = [...new Set(storedQueries)];
    window.checkedQueries = storedQueries; // if needed globally
}

apz.app.LUCDetails.paintDocuments = function() {
    const allowedTypes = ["purpose1 Doc", "purpose2 Doc", "purpose3 Doc"];
    const docs = inSessionStore.applicationDocumentsWrapperList?.[0]?.applicationDocumentsList || [];
    const purposeDocs = docs.filter(doc => allowedTypes.includes(doc.documentType) || allowedTypes.includes(doc.payload?.documentType));
    apz.app.LUCDetails._docQueue = purposeDocs.map(doc => ({
        docType: doc.payload?.documentType || doc.documentType,
        docLevel: doc.payload?.docLevel || "",
        fileName: doc.payload?.documentFileName || "",
        latitude: doc.payload?.latitude || "",
        longitude: doc.payload?.longitude || "",
        uploadedTs: doc.payload?.uploadedTs || ""
    }));
    apz.app.LUCDetails._docQueueIndex = 0;
    apz.app.LUCDetails._processNextDocument();
};
apz.app.LUCDetails._processNextDocument = function() {
    const queue = apz.app.LUCDetails._docQueue;
    let index = apz.app.LUCDetails._docQueueIndex;
    if (index < queue.length) {
        const currentDoc = queue[index];
        apz.app.LUCDetails._docQueueIndex++;
        lobj.documentType = currentDoc.docType;
        lobj.docLevel = currentDoc.docLevel;
        lobj.fileName = currentDoc.fileName;
         window.ImageLocationDetails = {
             latitude: currentDoc.latitude || "",
             longitude: currentDoc.longitude || "",
             uploadedTs: currentDoc.uploadedTs || "",
             documentFileName: currentDoc.documentFileName || ""
         };
        ApzCOB.downloadFileFromServer(currentDoc.fileName, apz.app.LUCDetails.paintDocumentsCB);
    }
};
apz.app.LUCDetails.paintDocumentsCB = function(params) {
    apz.stopLoader();
    const docType = lobj.documentType;
    const docLevel = lobj.docLevel;
    const fileName = lobj.fileName;
    let typeNum = docType.replace("purpose", "").replace(" Doc", "");
    let imgId = `#${screenId}PURPOSE_${typeNum}_IMG${docLevel}`;
    window.picture = $(`#${screenId}PURPOSE_${typeNum}_IMG${docLevel}`);
    ApzCOB.intializeGuillotine(picture);
    let titleId = `#${screenId}purpose${typeNum}_img${docLevel}_title_ul`;
    let optionsId = `#${screenId}purpose${typeNum}_img${docLevel}_options`;
    if (!apz.isNull(params.base64)) {
        $(imgId).attr('src', 'data:image/png;base64,' + params.base64);
        let id = imgId;
        if (Object.keys(window.ImageLocationDetails).length > 0) {
            apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
        }
        $(imgId).attr('data-filename', fileName);
        $(titleId).removeClass('sno');
        $(optionsId).removeClass('sno');
    }
    apz.app.LUCDetails._processNextDocument();
};
apz.app.LUCDetails.onClickDownloadPurposeDoc = function(pthis, id) {
    let fileName = $(`#${id}`).attr('data-filename');
    let b64Data = $(`#${id}`).attr('src').split(',')[1];
    ApzCOB.convertBase64ToPNG(b64Data, fileName);
}
