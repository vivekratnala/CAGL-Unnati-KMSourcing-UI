apz.app.LUCDetails.submitLUCSentBack = function() {
    let lvalidate = true;
    let queries = finalCheckedQueries; // code to check queries selected.
    if (!queries) {
        lvalidate = false;
        $(`#${screenId}Query_Err_Row`).removeClass('sno');
    } else {
        lvalidate = true;
        $(`#${screenId}Query_Err_Row`).addClass('sno');
        ApzCOB.toggleModal(screenId + "queryModal");
    }
    if (lvalidate) {
        let confrmTxt = `Are you sure you want to send back the LUC Verification?`;
        let popUpObj = {};
        popUpObj.text = confrmTxt;
        popUpObj.Btn1 = {
            "text": "Yes",
            "onClick": "apz.app.LUCDetails.confirmSubmitLUCDetails('PUSHBACK')"
        }
        popUpObj.Btn2 = {
            "text": "No",
            "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`)"
        }
        ApzCOB.showNewCommonConfirmationModal(popUpObj);
    }
};
apz.app.LUCDetails.submitLUCDetails = function() {
if(apz.getElmValue(`${screenId}isLonUtilised`) === 'Yes' ){
   if (apz.app.LUCDetails.totalUnutilisedAmount() === false) {
        return;
    }
    if (apz.app.LUCDetails.validatePurposes() === false) {
        return;
    }
}
    let utilLoan = apz.getElmValue(`${screenId}isLonUtilised`);
    let unutilamnt = $(`#${screenId}unUtilisedLoanAmount`).val();
    let contenttext = '';
    if(unutilamnt > 0){
      contenttext =  `Are you sure you want to Save `
    }else{
        contenttext =  `Are you sure you want to submit `
    }
    let remarks = utilLoan === 'Yes' ? $(`#${screenId}LucRemarks`).val() : $(`#${screenId}LucRemarks_No`).val();
    if (apz.isNull(remarks)) {
        ApzCOB.fnDisplayMsg("Please Enter LUC Remarks", "E");
        return;
    }
    let lstage = gcurrStage === "LUC" ? "the LUC Verification" : (gcurrStage === "PENDINGLUCVERIFICATION" ? "the LUC verification" : "");
    let confrmTxt = contenttext + lstage + `?`
    let popUpObj = {};
    popUpObj.text = confrmTxt;
    popUpObj.Btn1 = {
        "text": "Yes",
        "onClick": "apz.app.LUCDetails.confirmSubmitLUCDetails('SUBMIT');"
    }
    popUpObj.Btn2 = {
        "text": "No",
        "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`);"
    }
    ApzCOB.showNewCommonConfirmationModal(popUpObj);
};
apz.app.LUCDetails.validatePurposes = function () {
    let docsList = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList || [];
    for (let i = 1; i <= 3; i++) {
        let purpose = $(`#${screenId}mainPurposeDropdown${i}`).val();
        purpose = (purpose === "Please Select") ? "" : purpose;
        let subPurpose = $(`#${screenId}subpurposedorpdown${i}`).val();
        subPurpose = (subPurpose === "Please Select") ? "" : subPurpose;
        let additionalDetails = $(`#${screenId}additionalDetail${i}`).val() || "";
        let utilisedAmount = parseFloat(($(`#${screenId}utilisedAmout${i}`).val() || "").replace(/,/g, "")) || 0;
        let isAnyFieldFilled = purpose || additionalDetails || utilisedAmount > 0 || subPurpose;
        if (i !== 1 && !isAnyFieldFilled) {
            continue;
        }
        if (!purpose) {
            ApzCOB.fnDisplayMsg(`Please select purpose ${i}`);
            return false;
        }
        // let purpose1Docs = docsList.filter(d =>  UAU-234
        //     d.documentType === `purpose1 Doc` &&
        //     (d.docLevel === "1" || d.docLevel === "2")
        // );
        // if (purpose1Docs.length < 1) {
        //     ApzCOB.fnDisplayMsg(`Please upload documents for porpose 1`);
        //     return false;
        // }
        if(!apz.isNull(inSessionStore?.lucDetails?.queries)){
            if( apz.getElmValue("Luc__LUCDetails__response").trim() === ""){
                ApzCOB.fnDisplayMsg(`Please enter response for queries`);
                return false;
            }
        } 
        if (utilisedAmount <= 0) {
            ApzCOB.fnDisplayMsg(`Please enter utilised amount for purpose ${i}`);
            return false;
        }
        if (!additionalDetails.trim()) {
            ApzCOB.fnDisplayMsg(`Please enter additional details for purpose ${i}`);
            return false;
        }
        if (purpose === "Business" && !subPurpose) {
            ApzCOB.fnDisplayMsg(`Please select sub purpose for business purpose ${i}`);
            return false;
        }
        if (purpose === "Business") {
            let purposeDocs = docsList.filter(d =>
                d.documentType === `purpose${i} Doc` &&
                (d.docLevel === "1" || d.docLevel === "2")
            );
            if (purposeDocs.length < 1) {
                ApzCOB.fnDisplayMsg(`Please upload documents for business purpose ${i}`);
                return false;
            }
        }
    }
    return true;
};

apz.app.LUCDetails.confirmSubmitLUCDetails = function(laction) {
    currentApplicationData = structuredClone ? structuredClone(inSessionStore) : JSON.parse(JSON.stringify(inSessionStore));
    let {
        updatedBy,
        ...filteredData
    } = currentApplicationData.applicationMaster;
    gApzCOB.workflow.currentRole = window.currentRole;
    gApzCOB.workflow.action = laction;
    gApzCOB.workflow.workflowId = gcurrStage.toUpperCase();
    gApzCOB.workflow.stage = gcurrStage.toUpperCase();
    if (gcurrStage === "LUC") {
        gApzCOB.workflow.status = "PENDINGLUCVERIFICATION";
    } else if (gcurrStage === "PENDINGLUCVERIFICATION") {
        if (gApzCOB.workflow.action === 'PUSHBACK') {
            gApzCOB.workflow.status = "LUC";
        } else {
            gApzCOB.workflow.status = "LUCVERIFIED";
        }
    }
    apz.startLoader();
    let queryData = '';
    if(!apz.isNull(finalCheckedQueries)) {
        queryData = finalCheckedQueries.toString();
    } else if(!apz.isNull(inSessionStore?.lucDetails?.queries)){
        queryData = inSessionStore?.lucDetails?.queries;
    }
    let reMarks = apz.getElmValue(`${screenId}isLonUtilised`) === 'Yes' ? $(`#${screenId}LucRemarks`).val() : $(`#${screenId}LucRemarks_No`).val();
    let LucDetailsWrapper = {
        appId: gApzCOB.userDetails.appId,
        interfaceName: "",
        userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
        requestObj: {
            appId: gApzCOB.userDetails.appId,
            applicationId: gApzCOB.userDetails.applicationId,
            versionNum: gApzCOB.userDetails.versionNum,
            stageId: gApzCOB.workflow.stage,
            payload: {
                totalTransferedAmount: window.totalTransferedAmount,
                totalUnutilisedAmount: apz.app.LUCDetails.totalUnutilisedAmount(),
                isAmountUtilised: apz.getElmValue(`${screenId}isLonUtilised`),
                lucRemarks: reMarks || "",
                purposes: [{
                    purpose: ($(`#${screenId}mainPurposeDropdown1`).val() === "Please Select") ? "" : $(
                        `#${screenId}mainPurposeDropdown1`).val(),
                    subPurpose: ($(`#${screenId}subpurposedorpdown1`).val() === "Please Select") ? "" : $(
                        `#${screenId}subpurposedorpdown1`).val(),
                    additionalDetails: $(`#${screenId}additionalDetail1`).val() || "",
                    utilisedAmount: parseFloat($(`#${screenId}utilisedAmout1`).val().replace(/,/g, "")) || 0
                }, {
                    purpose: ($(`#${screenId}mainPurposeDropdown2`).val() === "Please Select") ? "" : $(
                        `#${screenId}mainPurposeDropdown2`).val(),
                    subPurpose: ($(`#${screenId}subpurposedorpdown2`).val() === "Please Select") ? "" : $(
                        `#${screenId}subpurposedorpdown2`).val(),
                    additionalDetails: $(`#${screenId}additionalDetail2`).val() || "",
                    utilisedAmount: parseFloat($(`#${screenId}utilisedAmout2`).val().replace(/,/g, "")) || 0
                }, {
                    purpose: ($(`#${screenId}mainPurposeDropdown3`).val() === "Please Select") ? "" : $(
                        `#${screenId}mainPurposeDropdown3`).val(),
                    subPurpose: ($(`#${screenId}subpurposedorpdown3`).val() === "Please Select") ? "" : $(
                        `#${screenId}subpurposedorpdown3`).val(),
                    additionalDetails: $(`#${screenId}additionalDetail3`).val() || "",
                    utilisedAmount: parseFloat($(`#${screenId}utilisedAmout3`).val().replace(/,/g, "")) || 0
                }]
            },
            queries: queryData,
            createdBy: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id, // insession store <->if not null else current user 
            updatedBy: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id
        },
        userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
        appId: gApzCOB.userDetails.appId,
        interfaceName: ""
    };
    let req = {
        apiRequest: {
            interfaceName: "",
            appId: gAppId,
            requestObj: {
                appId: gApzCOB.userDetails.appId,
                status: gApzCOB.workflow.status,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                applicationId: gApzCOB.userDetails.applicationId,
                versionNum: gApzCOB.userDetails.versionNum,
                custDtlId: gApzCOB.userDetails.custDtlId,
                remarks: $(`#${screenId}response`).val(),
                workflow: {
                    currentRole: gApzCOB.workflow.currentRole,
                    action: gApzCOB.workflow.action,
                    workflowId: gApzCOB.workflow.workflowId,
                    stage: gApzCOB.workflow.stage,
                    currentStage: gApzCOB.workflow.stage
                },
                LUCRequest: LucDetailsWrapper
            }
        }
    };
    ApzCOB.serverBuildParam(gAppId, "Stagemoment", "N", "N", req, false, apz.app.LUCDetails.confirmSubmitLUCDetailsCB);
};
apz.app.LUCDetails.confirmSubmitLUCDetailsCB = function(params) {
    ApzCOB.closeCommonModal(`newCommonConfModal`);
    apz.stopLoader();
    let errMsg = "";
    let apiResponse = params?.res?.APZCBO__Stagemoment_Res?.apiResponse;
    let responseMessage = apiResponse?.ResponseBody?.responseObj;
    let ResponseCode = apiResponse?.ResponseHeader?.ResponseCode;
    if (!apz.isNull(responseMessage)) {
        errMsg = responseMessage;
    }
    if (ApzCOB.handleServiceCallBacks(params)) {
        // PUSHBACK SUCCESS
        if (gApzCOB.workflow.action === "PUSHBACK") {
            let propObj = {};
            if (gApzCOB.workflow.status === "LUC") {
                propObj = {
                    text1: `LUC verification sent back successfully to LUC`,
                    text2: `Application No: ${gApzCOB.userDetails.applicationId}`,
                    text3: `Member Name / ID: ${window.customerName}/${inSessionStore?.applicationMaster?.memberId}`,
                    Btn: {
                        text: "OK",
                        onClick: "apz.app.LUCDetails.closeSuccessModalAndProceed()"
                    }
                };
            } else if (gApzCOB.workflow.status === "LUCVERIFIED") {
                propObj = {
                    text1: `LUC verification submitted successfully`,
                    text2: "",
                    text3: "",
                    Btn: {
                        text: "OK",
                        onClick: "apz.app.LUCDetails.closeSuccessModalAndProceed()"
                    }
                };
                // Hide fields not needed for this success
                $(`#${BaseScrId}LUCSuccModal #${BaseScrId}LUCApplicationID`).addClass("sno");
                $(`#${BaseScrId}LUCSuccModal #${BaseScrId}LUCMemberID`).addClass("sno");
            }
            return ApzCOB.LucSuccessModal(propObj);
        }
        // SUBMIT OR SAVE SUCCESS
        let totalUnutil = params?.req?.apiRequest?.requestObj?.LUCRequest?.requestObj?.payload?.totalUnutilisedAmount || 0;
        let propObj = {
            text1: totalUnutil > 0 ?
                `LUC application saved successfully.` : `LUC submitted successfully for LUC verification.`,
            text2: `Application no:  ${gApzCOB.userDetails.applicationId}`,
            text3: `Member name / ID: ${window.customerName}/${inSessionStore?.applicationMaster?.memberId}`,
            Btn: {
                text: "OK",
                onClick: "apz.app.LUCDetails.closeSuccessModalAndProceed()"
            }
        };
        ApzCOB.LucSuccessModal(propObj);
    } else {
        // FAILURE MODE
        if (gApzCOB.workflow.action === 'PUSHBACK') {
            errMsg = "Application SendBack Failed! " + errMsg;
        } else if (gApzCOB.workflow.action === 'SUBMIT') {
            errMsg = "Failed to Submit! " + errMsg;
        }
        let popUpObj = {
            text: errMsg || technicalErrMsg,
            Btn: {
                text: "OK",
                onClick: `ApzCOB.closeCommonModal("newCommonErrModal")`
            }
        };
        ApzCOB.showNewCommonErrorModal(popUpObj);
    }
};
apz.app.LUCDetails.closeSuccessModalAndProceed = function() {
    ApzCOB.toggleModal(`${BaseScrId}LUCSuccModal`);
    apz.app.Login.OnClickMakerChecker('');
};
apz.app.LUCDetails.QueriesToBeSendback = function() {
    let checkedSet = new Set(); // avoid duplicates
    let otherReason = "";
    let otherSelected = false;
    QueriesPainted.forEach((item, index) => {
        let isChecked = $(`#${queriesIntfId}id_${index}`).prop("checked");
        if (!isChecked) return;
        let queryId = item.id;
        if (othReasonId === `#${queriesIntfId}id_${index}`) {
            otherSelected = true;
        let othText = $(`#${screenId}otherQueryReasonInp`).val()?.trim() || "";
        if (othText === "") {
            $(`#${screenId}otherQueryReasonErrBlock`).removeClass('sno');
            return false;
        }
        $(`#${screenId}otherQueryReasonErrBlock`).addClass('sno');
            otherReason = `${queryId}?${othText}`;
        } else {
            checkedSet.add(queryId);
        }
    });
    // If Other has valid message
    if (otherReason) checkedSet.add(otherReason);
    checkedQueries = Array.from(checkedSet);
    window.finalCheckedQueries = [...checkedQueries];
    if (finalCheckedQueries.length === 0) {
        ApzCOB.toggleModal(screenId + "queryModal");
        return;
    }
    // Send blank if nothing selected
    apz.app.LUCDetails.submitLUCSentBack(finalCheckedQueries.length ? finalCheckedQueries : [""]);
};
apz.app.LUCDetails.loadQueryModal = function() {
    ApzCOB.removeErrMessgae(`${screenId}otherQueryReasonInp`, "element");
    let currentStageQueries = DBKIT_MASTERDATA.filter(item => item.stageName === "LUC");
    let queryArray = [];
    window.lucQueries = [];
    lucQueries = DBKIT_MASTERDATA.filter(item => item.stageName === "LUC" && item.queries && item.queries !== "{}").flatMap(item => JSON.parse(
        item.queries));
    queryArray = [...lucQueries];
    if (queryArray.length > 0) {
        apz.data.scrdata.Luc__LUCQueries_Res = [];
        apz.data.scrdata.Luc__LUCQueries_Res = structuredClone(queryArray);
        window.QueriesPainted = structuredClone(queryArray);
        apz.data.loadData("LUCQueries", "Luc");
        $(".crt-list li").attr("onClick", "");
        $(`#${screenId}otherQueryReasonInp`).val("");
        $(`#${screenId}otherQueryReasonInp`).attr('maxlength', 100);
        $('#Luc__LUCDetails__queryModal_content').scrollTop(0, 0);
        $(`#${screenId}otherQueryReasonForm`).addClass("sno");
        $(`#${screenId}queryList`).find("p").filter(function(el, item) {
            if ($(`#${queriesIntfId}value_${el}_txtcnt`)[0]?.textContent === "Other") {
                othReasonId = `#${queriesIntfId}id_${el}`;
                $(`#${queriesIntfId}id_${el}`).attr("onchange", "apz.app.LUCDetails.onSelectOtherReason();");
            }
        });
        $(`#${screenId}queryList`).addClass("pb-70");
        if (queryArray.length === 0) {
            $(`#${screenId}search_row`).addClass('sno');
            $('#Luc__LUCQueries__o__Luc__LUCQueries_Res__id_0').prop('checked', true).change()
        } else {
            $(`#${screenId}search_row`).removeClass('sno');
        }
        if (!apz.isNull(inSessionStore?.lucDetails?.queries)) {
            apz.app.LUCDetails.mapCheckedQuerys()
        }
        ApzCOB.toggleModal(screenId + "queryModal");
    }
};
apz.app.LUCDetails.mapCheckedQuerys = function() {
    $("#Luc__LUCDetails__queryList > ul > li input").prop("checked", false);
    window.lucCheckedQueries = checkedQueries.map(q => q.replace(/^Q\d+_/, "") // remove Q#_ prefix
    );
    let othId = apz.data.scrdata.Luc__LUCQueries_Res.findIndex(el => el.id === "OTH");
    for (let i = 0; i < lucCheckedQueries.length; i++) {
        let query = lucCheckedQueries[i];
        let othId = apz.data.scrdata.Luc__LUCQueries_Res.findIndex(el => el.id === "OTH");
        for (let j = 0; j < $("#Luc__LUCDetails__queryList li").length; j++) {
            if ($("#Luc__LUCQueries__o__Luc__LUCQueries_Res__value_" + j + "_txtcnt").text() === query) {
                $("#Luc__LUCQueries__o__Luc__LUCQueries_Res__id_" + j).prop("checked", "checked");
            } else if (lucCheckedQueries[i].split("?")[0] == "oth_Other") {
                query = lucCheckedQueries[i]?.split("?")[1];
                if (othId >= 0) {
                    $("#Luc__LUCQueries__o__Luc__LUCQueries_Res__id_" + othId).prop("checked", "checked");
                }
                $("#Luc__LUCDetails__otherQueryReasonInp").val(query);
                $(`#${screenId}otherQueryReasonForm`).removeClass("sno");
            }
        }
    }
}
apz.app.LUCDetails.onClickQueryMdlCancel = function() {
    BtnClicked = "";
    $(`#${screenId}queryList`).addClass("pb-70");
    $(`#${screenId}queryModal_close`).click();
}
apz.app.LUCDetails.onSelectOtherReason = function() {
    let othVal = $(othReasonId).prop("checked");
    if (othVal) {
        $(`#${screenId}queryList`).removeClass("pb-70")
        othReasonSelected = true;
        $(`#${screenId}otherQueryReasonForm`).removeClass("sno");
    } else {
        $(`#${screenId}queryList`).addClass("pb-70")
        othReasonSelected = false;
        $(`#${screenId}otherQueryReasonForm`).addClass("sno");
        $(`#${screenId}otherQueryReasonInp`).val("");
        ApzCOB.removeErrMessgae(`${screenId}otherQueryReasonInp`, "element");
    }
};
apz.app.LUCDetails.searchInQueryMdl = function() {
    var query = $(`#${screenId}searchQueryInput`).val();
    window.searchresults = QueriesPainted.filter((lead) => Object.values(lead).some((value) => String(value).toLowerCase().includes(query
        .toLowerCase())));
    if (searchresults?.length > 0) {
        apz.data.scrdata.Luc__LUCQueries_Res = [];
        apz.data.scrdata.Luc__LUCQueries_Res = searchresults;
        apz.data.loadData("LUCQueries", "Luc");
        $(`#${screenId}queryList .wrapped.undefined.ssp`).remove();
        $(`#${screenId}queryList`).find("p").filter(function(el, item) {
            if ($(`#${queriesIntfId}value_${el}_txtcnt`)[0]?.textContent === "Other") {
                othReasonId = `#${queriesIntfId}id_${el}`;
                $(`#${queriesIntfId}id_${el}`).attr("onchange", "apz.app.LUCDetails.onSelectOtherReason();");
            }
        });
        // $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
        $(`#${screenId}noResult_row`).addClass("sno");
        $(`#${screenId}queryList`).removeClass("sno");
        // $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
    } else {
        $(`#${screenId}noResult_row`).removeClass("sno");
        $(`#${screenId}queryList`).addClass("sno");
        $(`#${screenId}otherQueryReasonForm`).addClass("sno");
    }
};
apz.app.LUCDetails.uncheckOthercheckbox = function() {
    window.othReasonSelected = false;
    $(othReasonId).prop("checked", false)
    $(`#${screenId}otherQueryReasonForm`).addClass("sno");
    $(`#${screenId}otherQueryReasonInp`).val("");
    ApzCOB.removeErrMessgae(`${screenId}otherQueryReasonInp`, "element");
    ApzCOB.toggleModal(screenId + "queryModal");
}
apz.app.LUCDetails.queryCheckBoxCount = function() {
    let checkedCount = 0;
    for (let i = 0; i < window.QueriesPainted.length; i++) {
        const isChecked = $(`#CrdAss__CAQueries__o__CrdAss__CAQueries_Res__id_${i}`).prop("checked");
        if (isChecked) {
            checkedCount++;
        }
    }
    if (checkedCount > 0) {
        $("#Luc__LUCDetails__Query_Err_Row").addClass("sno");
    }
};
apz.app.LUCDetails.mandatorycheckfields = function() {
    for (let i = 2; i <= 3; i++) {
        let purpose = $(`#${screenId}mainPurposeDropdown${i}`).val();
        purpose = (purpose === "Please Select") ? "" : purpose;
        let subPurpose = $(`#${screenId}subpurposedorpdown${i}`).val();
        subPurpose = (subPurpose === "Please Select") ? "" : subPurpose;
        let additionalDetails = $(`#${screenId}additionalDetail${i}`).val() || "";
        let utilisedAmount = Number($(`#${screenId}utilisedAmout${i}`).val()) || 0;
        // If any field in row is filled
        if (purpose || subPurpose || additionalDetails || utilisedAmount) {
            // Business type mandatory only for Business purpose
            $(`#${screenId}businessTyp${i}`).toggleClass('req', purpose === 'Business');
            // Other mandatory fields
            $(`#${screenId}amtUtlize${i}, 
               #${screenId}addDtls${i}, 
               #${screenId}amtutlizd${i}`).addClass('req');
        } else {
            $(`#${screenId}amtUtlize${i},#${screenId}addDtls${i},#${screenId}amtutlizd${i}`).removeClass('req');
        }
    }
}
