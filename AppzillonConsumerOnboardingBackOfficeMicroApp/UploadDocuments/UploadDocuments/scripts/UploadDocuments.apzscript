apz.app.UploadDocuments.downloadFileFromserverCB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.base64)) {
        localFileObj.imgSrc = params.base64
        fileArr.pop();
        fileArr.push(localFileObj);
