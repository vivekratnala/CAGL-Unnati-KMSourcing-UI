        //var flname = k.filename
        flocation = gAppId
        //fieldID = k.fieldID
        //  }
    })
    apz.startLoader();
    var json = {
        "callBack": apz.app.UploadDocuments.downloadFileFromserverCB,
        "fileName": flname,
        "base64": "Y",
