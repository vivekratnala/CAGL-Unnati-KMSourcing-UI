apz.app.UploadDocuments.LoadFileNamesForOtherDoc = function() {
    let additionalDocs = [];
    if(!apz.isNull(documentProofObj)){
         for (let key in documentProofObj) {
          if(documentProofObj[key].length > 0){
            documentProofObj[key].map(docs => {
                if(docs.isAdiDoc === "Y") {
                 additionalDocs.push(docs);
                }
            })  
          } 
         }
    }
    if (additionalDocs.length > 0) {
        $('#' + UpDocScrId + 'OthersUploadedDocsRow').removeClass('sno');
        apz.data.scrdata.UpDocs__IpaintFileUpload_Res = {};
        apz.data.scrdata.UpDocs__IpaintFileUpload_Res.otherdocs = [];
        for (var i = 0; i < additionalDocs.length; i++) {
            $('#' + UpDocScrId + 'otherProofList_row_' + i).addClass('uploaded');
            $('#' + UpDocScrId + 'otherProgress_' + i).css(ActiveprogressBar);
            apz.data.scrdata.UpDocs__IpaintFileUpload_Res.otherdocs.push(additionalDocs[i]);
            lFilename = additionalDocs[i]["filename"];
            if (!apz.isNull(additionalDocs[i]["imgSrc"])) {
                lFileSize = ApzCOB.fnGetImageSize(additionalDocs[i]["imgSrc"]);
            }
            apz.data.scrdata.UpDocs__IpaintFileUpload_Res.otherdocs[i]['filename'] = additionalDocs[i]["filename"]
        }
        apz.data.loadData("IpaintFileUpload", apz.currAppId);
        for (var m = 0; m < $('#' + UpDocScrId + OtherDocsProofList).children().length; m++) {
            if ($('#' + UpDocScrId + 'otherProofList_row_' + m).hasClass('sno') || $('#' + UpDocScrId + 'otherProofList_row_' + m).hasClass(
                'ssp')) {
                apz.data.deleteRow(UpDocScrId + "otherProofList", m)
            }
        }
        $('#' + UpDocScrId + 'otherdocpri').val(PleaseSelect).change();
        $('#' + UpDocScrId + 'otherdocType').val(PleaseSelect).change();
        $('#' + UpDocScrId + 'identityType').val(PleaseSelect);
    } else {
    $('#' + UpDocScrId + 'OthersUploadedDocsRow').addClass('sno');    
    }
    IS_ADITIONAL_DOC_OPERATION = false;
}
apz.app.UploadDocuments.onChangeDocumentTypepri = function(pthis) {
    let temparrtype = '';
    temparrtype = $(pthis).val();
    if (temparrtype == 'Address Proof') {
        if (addrProfArr[0].desc !== PleaseSelect) {
            addrProfArr.unshift({
                "val": PleaseSelect,
                "desc": PleaseSelect
            });
        }
        let addressMandatoryDrop = [];
        if (!apz.isNull(currentAddressProofDocMap)) {
            if (currentAddressProofDocMap.length > 0) {
                const sessionAddressProof = ['As per KYC document', 'As per Voter ID'].includes(mandatoryPrefilledValues.ADDRESS_PROOF) ? 'As per Voter ID' : mandatoryPrefilledValues.ADDRESS_PROOF;
                addressMandatoryDrop = currentAddressProofDocMap[0][sessionAddressProof];
            }
        }
        let addressProofArray = [];
        if (addressMandatoryDrop.length > 0) {
            addrProfArr.forEach((addressType) => {
                if (!addressMandatoryDrop.includes(addressType.val)) {
                    addressProofArray.push(addressType);
                }
            })
        } else {
            addrProfArr.forEach((addressType) => {
                addressProofArray.push(addressType);
            })
        }
        apz.populateDropdown(document.getElementById(UpDocScrId + 'otherdocType'), addressProofArray);
    } else if (temparrtype == 'Business Address Proof') {
        if (bssAddrProofArr[0].desc !== PleaseSelect) {
            bssAddrProofArr.unshift({
                "val": PleaseSelect,
                "desc": PleaseSelect
            });
        }
        let busAddressMandatoryDrop = [];
        if (!apz.isNull(businessAddressProofDocMap)) {
            if (businessAddressProofDocMap.length > 0) {
                const sessionBusAddressProof = ['As per KYC document', 'As per Voter ID'].includes(mandatoryPrefilledValues.BUSINESS_ADDRESS_PROOF) ? 'As per Voter ID' : mandatoryPrefilledValues.BUSINESS_ADDRESS_PROOF;
                busAddressMandatoryDrop = businessAddressProofDocMap[0][sessionBusAddressProof];
            }
        }
        let businessAddressProofArray = [];
        if (!apz.isNull(busAddressMandatoryDrop)) {
            if (busAddressMandatoryDrop.length > 0) {
                bssAddrProofArr.forEach((busAddressType) => {
                    if (!busAddressMandatoryDrop.includes(busAddressType.val)) {
                        businessAddressProofArray.push(busAddressType)
                    }
                })
            }
        } else {
            bssAddrProofArr.forEach((busAddressType) => {
                    businessAddressProofArray.push(busAddressType)
            })
        }
        apz.populateDropdown(document.getElementById(UpDocScrId + 'otherdocType'), businessAddressProofArray);
    } else if (temparrtype == 'Employment Proof') {
        if (empProofArr[0].desc !== PleaseSelect) {
            empProofArr.unshift({
                "value": PleaseSelect,
                "desc": PleaseSelect
            });
        }
        let employmentMandatoryDrop = [];
 if(!apz.isNull(employmentProofDocMap)){
     if(employmentProofDocMap.length > 0){
         employmentMandatoryDrop = employmentProofDocMap[0][mandatoryPrefilledValues.EMPLOYMENT_PROOF];
     }
 }
  let employmentProofArray = [];
 if(employmentMandatoryDrop.length > 0){
              empProofArr.forEach((empProofType) => {
              if(!employmentMandatoryDrop.includes(empProofType.val)) {
                employmentProofArray.push(empProofType)
              }
           })   
 }
        apz.populateDropdown(document.getElementById(UpDocScrId + 'otherdocType'), employmentProofArray);
    } else if(temparrtype == "Please Select"){
        let opArray = [];
        opArray.unshift({
                "value": PleaseSelect,
                "desc": PleaseSelect
            });
            apz.populateDropdown(document.getElementById(UpDocScrId + 'otherdocType'), opArray);
    }
}
apz.app.UploadDocuments.DocValidation = function() {
    document.body.classList.remove("ajs-no-overflow");
    let documentValidation = false;
    let app_document_validation = false;
    if(gApzCOB.currentApplicant == 1 && mandatoryDocumentTypes.length > 0) {
    //   window.app_document_validation = apz.app.UploadDocuments.checkDocUploaded();
      documentValidation = true;
      if(window.isRevAndConfEdit === true && window.isRevAndConfEditCustType === 1) {
            app_document_validation = apz.app.UploadDocuments.checkDocUploaded();
            documentValidation = apz.app.UploadDocuments.checkDocUploaded();
      }
    } else if(gApzCOB.currentApplicant !== 1 && mandatoryDocumentTypes.length > 0){
        app_document_validation = apz.app.UploadDocuments.checkprevDocVal();
        documentValidation = apz.app.UploadDocuments.checkDocUploaded();
        // if(app_document_validation === true) {
        //     documentValidation = apz.app.UploadDocuments.checkDocUploaded();
        // } else {
        //     documentValidation = false;
        //     // ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPDOCVALIDERROR"), "E", "");
        // }
    } else {
      documentValidation = true;  
    }
    if (documentValidation && app_document_validation) {
        ApzCOB.createLoan();
    } else if(gApzCOB.currentApplicant == 1 && documentValidation) {
        ApzCOB.createLoan();
    } else {
        if (app_document_validation == false && documentValidation == true) {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPDOCVALIDERROR"), "E", "");
        } else if (app_document_validation == true && documentValidation == false) {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COAPPDOCVALIDERROR"), "E", "");
        } else if (documentValidation == false && app_document_validation == false) {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_APPCOAPPDOCVALIDERROR"), "E", "");
        }
    }
    $('body').removeClass('ajs-no-overflow')
};
apz.app.UploadDocuments.checkDocUploaded = function(){
    window.documentProofObj = window.inSessionStore.applicationDocumentsWrapperListSess[CURRENT_APPLICANT_DETAILS_INDEX];
    let isValid = false;
    let mandateRefArray = [...mandatoryDocumentTypes];
  mandatoryDocumentTypes.map(docs => {
      let docTypeOnMand = "";
    let docDivId = docs+"_Div";
    let docMinCount = parseInt(docMaxAndMand.filter(docM => docM.key === docs)[0]['value'].split('~')[1]);
     let errMsg = "";
    if(!apz.isNull(documentProofObj)){
      if(documentProofObj[docs].length >= docMinCount){
          $('#'+UpDocScrId+docDivId).removeClass('docErrBorder'); 
          mandateRefArray.splice(mandateRefArray.indexOf(docs), 1);
         $('.'+docs+'_ERR label.var1').text(errMsg);
         $('.'+docs+'_ERR').addClass('sno');
      } else {
          errMsg = "Please upload minimum "+docMinCount+ " "+docs.replaceAll('_',' ')+" documents.!";
          $('.'+docs+'_ERR label.var1').text(errMsg);
          $('.'+docs+'_ERR').removeClass('sno');
         $('#'+UpDocScrId+docDivId).addClass('docErrBorder'); 
      } 
    }
  })  
  if(mandateRefArray.length === 0){
    isValid = true;  
  } else {
      isValid = false;
    document.getElementById(UpDocScrId + mandateRefArray[0]+"_Div").scrollIntoView({
          behavior: "smooth",
          block: "center",
          inline: "center"
      }) 

  }
   return isValid;
}
