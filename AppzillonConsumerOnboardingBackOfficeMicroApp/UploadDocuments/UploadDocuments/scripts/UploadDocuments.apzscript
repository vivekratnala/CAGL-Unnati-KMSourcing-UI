};
apz.app.UploadDocuments.fileClick = function(obj, selType3, type) {
 IS_ADITIONAL_DOC_OPERATION = true;
 var flname = $(obj).parents('.uploaded-file-detail').find('.FileName').text();
 var docID = $(obj).parents('.uploaded-file-detail').find('.appDocID').text();
 var docType = $(obj).parents('.uploaded-file-detail').find('.docType').text();
 var tempFileArr = documentProofObj[docType].filter(doc => (parseInt(doc.appDocId) === parseInt(docID) && doc.isAdiDoc === "Y"));
 if(tempFileArr.length > 0){
     SELECTED_DOC_APP_ID = parseInt(docID);
        viewBase64 = tempFileArr[0].imgSrc;
        curImgObj = tempFileArr[0];
        curImgIndex = 0;
        apz.app.UploadDocuments.noBase64(flname, tempFileArr[0], 0);   
 }
};
apz.app.UploadDocuments.noBase64 = function(flname, k, i) {
    if (apz.isNull(viewBase64)) {
        var json = {
            "destinationPath": "",
            "filePath": (gAppId).concat("/").concat(gApzCOB.product).concat("/").concat(gApzCOB.userDetails.applicationId),
            "sessionReq": "N" //Y or N
        };
        json.destinationPath = "docs";
        json.fileName = flname;
        json.base64 = "Y";
        json.filePath = (gAppId).concat("/").concat(gApzCOB.product).concat("/").concat(gApzCOB.userDetails.applicationId);
        json.id = "";
        json.callBack = apz.app.UploadDocuments.noBase64CB;
        apz.startLoader();
        setTimeout(() => {
         apz.ns.downloadFile(json);   
        },1000)
    } else {
        apz.app.UploadDocuments.showDoc(flname, k, i);
    }
};
apz.app.UploadDocuments.noBase64CB = function(params) {
    apz.stopLoader();
    if (!apz.isNull(params.base64)) {
        viewBase64 = params.base64;
        apz.app.UploadDocuments.showDoc('', curImgObj, curImgIndex);
    }
};
apz.app.UploadDocuments.showDoc = function(flname, k, i) {
    var fileType = apz.isNull(ApzCOB.getFileExtension(k.filetype)) ? k.filetype.split('/')[1] : ApzCOB.getFileExtension(k.filetype);
    if (fileType === 'png' || fileType === 'jpeg' || fileType === 'jpg') {
        apz.data.scrdata.UpDocs__IpaintUploadedFile_Res = {};
        apz.data.scrdata.UpDocs__IpaintUploadedFile_Res.fileDetails = {
            'imgSrc': viewBase64,
            'imgName': apz.isNull(flname) ? k.filename : flname
        };
        apz.data.loadData("IpaintUploadedFile", apz.currAppId);
        let id = "#UpDocs__IpaintUploadedFile__o__fileDetails__imgSrc";
        if (Object.keys(window.ImageLocationDetails).length > 0) {
            apz.app.BaseScreens.paintImageLocationDetails(id, window.ImageLocationDetails);
        }
        ApzCOB.toggleModal(UpDocScrId + "viewUploadedFileModal");
        var functionAdder = k.docType === 'OtherDocs' ? '(this,' + i + ');' : '()';
        $('#' + UpDocScrId + 'viewFileDeleteBtn').attr('onclick', 'apz.app.UploadDocuments.deleteDocument("'+selType+'",'+k.appDocId+')');
    } else if (fileType === 'pdf') {
        var a = document.createElement("a");
        a.href = "data:application/octet-stream;base64," + viewBase64;
        a.download = apz.isNull(flname) ? k.filename : flname
        a.click();
    }
    apz.stopLoader();
}
apz.app.UploadDocuments.infoModal = function(type, id) {
    var tempArr = [];
    apz.data.scrdata.UpDocs__IpaintInfo_Res = {};
    upDocsData["DOCS"].forEach(function(el) {
        Object.getOwnPropertyNames(el).forEach(function(i, k) {
            if (Object.getOwnPropertyNames(el)[k].split('~')[1] === "Y" && Object.getOwnPropertyNames(el)[k].split('~')[0] ===
                type) {
                if (!apz.isNull(el[i]["documents"])) {
                    el[i]["documents"].forEach(function(p) {
                        var obj = {
                            "images": p.split('~')[0],
                            "value": p.split('~')[1]
                        };
                        tempArr.push(obj)
                    })
                }
            }
        })
    })
    apz.data.scrdata.UpDocs__IpaintInfo_Res.infoList = tempArr;
    apz.data.scrdata.UpDocs__IpaintInfo_Res.docList = tempArr;
    if (!apz.isNull(id)) {
        $('#' + id).click(function() {
            apz.data.loadData("IpaintInfo", apz.currAppId);
        })
    } else {
        apz.data.loadData("IpaintInfo", apz.currAppId);
    }
}
apz.app.UploadDocuments.closePopover = function(pthis) {
    $('#' + UpDocScrId + 'uploadDocDiv').trigger('click')
}
apz.app.UploadDocuments.fileReader = function(fileObj,type) {
    var FR = new FileReader();
    FR.readAsDataURL(fileObj.files[0]);
    FR.onload = function(e) {
        encodedImage = "";
        encodedImage = e.target.result.substr(e.target.result.indexOf(',') + 1, e.target.result.length);
        if (!apz.isNull(encodedImage)) {
            if (isValid) {
                localFileObj.imgSrc = encodedImage;
                document.getElementById(localFileObj.fieldID).value = "";
                localFileObj.base64Value = encodedImage;
                ApzCOB.documentAutoSave(localFileObj, type); 
            }
        }
    }
}
apz.app.UploadDocuments.StoreAppDocID = function(appDocID,storelatitude,storelongitude) {
