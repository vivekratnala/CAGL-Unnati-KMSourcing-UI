apz.app.onShown_UploadDocuments = function() {
    apz.app.BaseScreens.contactus();
    apz.app.BaseScreens.hideNshowbackIcon();
    $("input").attr("autocomplete", "off");
    if ($('#' + BaseScrId + 'backIcon').hasClass('sno')) {
        $('#' + UpDocScrId + 'subHeaderRow').addClass('var1')
    }
    gApzCOB.userDetails.currentStage = "applicationDocsKyc";
    apz.app.UploadDocuments.getCommomCodeBasedOnProduct();
    apz.app.UploadDocuments.commoncodeConf();
    apz.app.UploadDocuments.setMandatoryDocumentDivs();
    if (gApzCOB.currentApplicant <= 1) {
        ApzCOB.showSubHeader("LIT_DOCUMENTS_UPLOAD_HEADER_APP");
    } else {
        ApzCOB.showSubHeader("LIT_DOCUMENTS_UPLOAD_HEADER_CO_APP");
    }
    window.documentProofObj = {};
    let docEmptyArray = []
    if(!apz.isNull(docMaxAndMand)){
        if(docMaxAndMand.length > 0){
            docMaxAndMand.forEach(docMax => {
              let emptyArray = [];
              window.documentProofObj[docMax.key] = emptyArray;
            });
        }
    }
    if (apz.isNull(window.inSessionStore.applicationDocumentsWrapperListSess)) {
        window.inSessionStore.applicationDocumentsWrapperListSess = []
    }
    if (!apz.isNull(window.inSessionStore.applicationDocumentsWrapperListSess[CURRENT_APPLICANT_DETAILS_INDEX])) {
        window.documentProofObj = window.inSessionStore.applicationDocumentsWrapperListSess[CURRENT_APPLICANT_DETAILS_INDEX];
    }
        if (apz.deviceType === "WEB") {
        $('#' + UpDocScrId + 'otherDocsUpload_ul').addClass('sno');
        $(".cam").addClass('sno');
        $(".browse").removeClass('sno');
    } else {
        $('#' + UpDocScrId + 'otherDocsUpload_ul').removeClass('sno');
        $(".browse").addClass('sno');
        $(".cam").removeClass('sno');
    }
    if (!apz.isNull(window.inSessionStore.applicationDocumentsWrapperListSess[CURRENT_APPLICANT_DETAILS_INDEX])) {
    if (!backNav) {
        apz.app.UploadDocuments.paintFilesNew();
        apz.data.scrdata.UpDocs__IpaintFileUpload_Res = {};
        apz.data.scrdata.UpDocs__IpaintFileUpload_Res.otherdocs = [];
        apz.data.scrdata.UpDocs__IpaintFileUpload_Res.fileDetails = [];
    } else {
        apz.app.UploadDocuments.paintFilesNew();
        apz.data.loadData("IpaintFileUpload", apz.currAppId);
        apz.app.UploadDocuments.checkDocUploaded();
    }   
    } else {
        if(gApzCOB.currentApplicant == 1 && backNav) {
            apz.app.UploadDocuments.checkDocUploaded();
        }
     apz.app.UploadDocuments.loadDefaultDivs();   
    }
    apz.app.UploadDocuments.configureFields();
    $('#' + UpDocScrId + 'otherdocType').val(PleaseSelect);
    $('#' + UpDocScrId + 'otherfilebrowser').removeClass('sno');
    $('#' + UpDocScrId + 'sc_row_20').addClass('var1');
    $('#' + UpDocScrId + 'otherProofList_row_0').removeClass('ssp');
    apz.app.UploadDocuments.attachMBclickevents();
    if (apz.deviceType !== "WEB") {
        $('span[id*="txtcnt"]:contains("Drag and Drop")').text('Upload');
        $('#' + UpDocScrId + 'photoSignUpload,#' + UpDocScrId + 'addressUpload,#' + UpDocScrId + 'identityUpload').text('Capture');
        $("#UpDocs__UploadDocuments__otherDocsUpload").addClass(
            'upload-btn') //for other docs upload if we add in screen level it is adding to ul tag  so,we using it in script
        $('#' + UpDocScrId + 'otherfilebrowser').addClass('sno');
        window.addEventListener("scroll", function() {
            if ($('#' + UpDocScrId + 'identityType_div').parent().hasClass('is-open')) {
                $('#' + UpDocScrId + 'identityType').parent().trigger('click');
            } else if ($('#' + UpDocScrId + 'addressType_div').parent().hasClass('is-open')) {
                $('#' + UpDocScrId + 'addressType').parent().trigger('click');
            } else if ($('#' + UpDocScrId + 'otherdocType_div').parent().hasClass('is-open')) {
                $('#' + UpDocScrId + 'otherdocType').parent().trigger('click');
            }
        }, true); // hide dropdown if scrolled to reduce the jerk effect
    }
    apz.app.BaseScreens.HeaderFooterData();
    if (ISPUSHBACKPPL) {
        $('#' + BaseScrId + 'backIcon').attr('onClick', 'ApzCOB.pushBackNavigationOnBack()');
    } else {
        $('#' + BaseScrId + 'backIcon').attr('onClick', 'ApzCOB.backNavigation()');
    }
    $('#' + BaseScrId + 'custIDandName').removeClass('sno');
    if (gApzCOB.LoggedInUserDetails.loginResponse.addInfo1 === "BM") {
        $('#APZCBO__BaseScreens__backIcon').attr('disabled', true)
    }
    $(continueButton).attr('disabled', false)
    if (isRevAndConfEdit) {
        ApzCOB.AddOrRemoveDisableFields([`${BaseScrId}backIcon`], true);
    }
    if(PUSHBACK_QUERY_STATUS.includes(gApzCOB.userDetails.applicationStatus)){
    ApzCOB.paintingSourcingQuery();
    }
    ApzCOB.scrollToTop()
}
apz.app.UploadDocuments.getCommomCodeBasedOnProduct = function() {
    switch (gApzCOB.product) {
        case "CASA":
            upDocsData = ApzCOB.GetCommonCodes("UPLOADDOCS", "CASA")["UPLOADDOCS"];
            break;
        case "CARDS":
            upDocsData = ApzCOB.GetCommonCodes("UPLOADDOCS", "CARD")["UPLOADDOCS"];
            break;
        case "LOAN":
            upDocsData = ApzCOB.GetCommonCodes("UPLOADDOCS", "LOAN_ETB")["UPLOADDOCS"];
            break;
        default:
            break;
    }
};
apz.app.UploadDocuments.configureFields = function() {
    var lcodeType = '';
    if (gApzCOB.mainProductGroupCode === 'CARDS') {
        lcodeType = 'CARD'
    } else if (gApzCOB.mainProductGroupCode === 'LOAN') {
        lcodeType = 'LOAN_ETB'
    } else {
        lcodeType = 'CASA';
    }
    ApzCOB.ConfigureFields([{
        'fieldName': 'OtherDocs',
        'fieldId': [UpDocScrId + 'othdocHeader1'],
        'fieldDivId': [UpDocScrId + 'OthersDocsDiv'],
    }], 'UPLOADDOCS', 'UPLOADDOCS', 'DOCS', lcodeType);
}
apz.app.UploadDocuments.attachMBclickevents = function() {
    if (apz.deviceType !== "WEB") {
        $('#' + UpDocScrId + 'photocol').click(function(evt) {
            apz.app.UploadDocuments.OpenCamGalleryModal('Browse1');
        });
        $('#' + UpDocScrId + 'signcol').click(function(evt) {
            apz.app.UploadDocuments.OpenCamGalleryModal('Browse2');
        });
        $('#' + UpDocScrId + 'cameracol').click(function(evt) {
            apz.app.UploadDocuments.SelectOption("camera");
        });
        $('#' + UpDocScrId + 'gallerycol').click(function(evt) {
            apz.app.UploadDocuments.SelectOption("photo");
        });
        $('#' + UpDocScrId + 'frontCol').click(function(evt) {
            apz.app.UploadDocuments.OpenCamGalleryModal('Browse1');
        });
        $('#' + UpDocScrId + 'backCol').click(function(evt) {
            apz.app.UploadDocuments.OpenCamGalleryModal('Browse2');
        });
    }
};
apz.app.UploadDocuments.commoncodeConf = function() {
    var tempArr = [];
    upDocsData["TYPES"].forEach(function(el) {
        if (el.split('~')[1] === "Y") {
            gAllowedFileTypes[el.split('~')[0]] = el.split('~')[0].toLocaleLowerCase();
        }
    });
    upDocsData["DOCS"].forEach(function(el) {
        Object.getOwnPropertyNames(el).forEach(function(i, k) {
            Object.getOwnPropertyNames(uploadLookUp).forEach(function(m) {
                if (Object.getOwnPropertyNames(el)[k].split('~')[1] === "Y" && Object.getOwnPropertyNames(el)[k].split(
                        '~')[0] === m) {
                    var type = Object.getOwnPropertyNames(el)[k];
                    HeaderLookUp[m].forEach(function(p, s) {
                        Object.keys(upDocsData["DOCS"][0][type]).forEach(function(t) {
                            tempArr = [];
                            tempArr.unshift({
                                "value": PleaseSelect,
                                "desc": PleaseSelect
                            });
                            if (Object.keys(p)[0] === t) {
                                if (!apz.isNull(upDocsData["DOCS"][0][type]["documents"])) {
                                    upDocsData["DOCS"][0][type]["documents"].forEach(function(el1) {
                                        let docVal = el1.split('~')[1];
                                         let occupation = ApzCOB.getOccupation();
                                        if(docVal !== "Bank Account Proof" && docVal !== "Business Photographs" && docVal !== "Relationship proof"){
                                            if(docVal === "Employment Proof"){
                                               if(occupation === "Salaried"){
                                                var obj = {
                                            "val": el1.split('~')[1],
                                            "desc": el1.split('~')[1]
                                        };
                                        tempArr.push(obj);  
                                            }  
                                            } else {
                                              var obj = {
                                            "val": el1.split('~')[1],
                                            "desc": el1.split('~')[1]
                                        };
                                        tempArr.push(obj);    
                                            }
                                        }
                                    })
                                }
                                var litDesc = ApzCOB.getLitsDescfromServer(upDocsData["DOCS"][0][type][
                                    t
                                ]);
                                if (t === "header2") {
                                    litDesc = ApzCOB.fnDisplayAllowedFiles(upDocsData["TYPES"], litDesc);
                                }
                                $('#' + UpDocScrId + Object.values(p)[0]).text(litDesc);
                                if (type.split('~')[0] === "OtherDocs") {
                                    apz.populateDropdown(document.getElementById(UpDocScrId +
                                        'otherdocpri'), tempArr);
                                }
                            }
                        })
                    })
                }
            })
        })
    })
    apz.app.UploadDocuments.commoncodeConfTypesLst();
}
apz.app.UploadDocuments.commoncodeConfTypesLst = function() {
    var tempArrTypes = [];
    addrProfArr = [];
    bssAddrProofArr = [];
    consentArr = [];
    empProofArr = [];
    photoArr = [];
    relatArr = [];
    bankAccProofArr = [];
    var doctypearr = upDocsData["DOCS"][0]['OtherDocs~Y~N'].documentstype;
    for (let i = 0; i < doctypearr.length; i++) {
        let temptype = doctypearr[i].split('~');
        if (temptype[2] == 'Address Proof') {
            var obj = {
                "val": temptype[1],
                "desc": temptype[1]
            };
            addrProfArr.push(obj);
        } else if (temptype[2] == 'Business Address Proof') {
            var obj = {
                "val": temptype[1],
                "desc": temptype[1]
            };
            bssAddrProofArr.push(obj);
        } else if (temptype[2] == 'Consent') {
            var obj = {
                "val": temptype[1],
                "desc": temptype[1]
            };
            consentArr.push(obj);
        } else if (temptype[2] == 'Employment Proof') {
            var obj = {
                "val": temptype[1],
                "desc": temptype[1]
            };
            empProofArr.push(obj);
        } else if (temptype[2] == 'Business Photographs') {
            var obj = {
                "val": temptype[1],
                "desc": temptype[1]
            };
            photoArr.push(obj);
        } else if (temptype[2] == 'Relationship proof') {
            var obj = {
                "val": temptype[1],
                "desc": temptype[1]
            };
            relatArr.push(obj);
        } else if (temptype[2] == 'Bank Account Proof') {
            let obj = {
                "val": temptype[1],
                "desc": temptype[1]
            };
            bankAccProofArr.push(obj);
        }
    }
}
apz.app.UploadDocuments.pendingApplnFileType = function(type, docType1) {
    upDocsData["DOCS"].forEach(function(el) {
        Object.getOwnPropertyNames(el).forEach(function(i, k) {
            if (i.split('~')[0] === type) {
                upDocsData["DOCS"][0][i]["documents"].forEach(function(el3) {
                    if (el3.split('~')[1] === docType1) {
                        fileType.AddressProof = el3.split('~')[2]
                    }
                })
            }
        })
    })
}
apz.app.UploadDocuments.createRequest = function(iSave) {
    if (apz.isNull(iSave)) {
            apz.app.UploadDocuments.getAllFiles();
            var lobj = {};
            lobj["applicationDocumentsList"] = []
            gApzCOB["requestNodes"]['applicationDocumentsWrapperList'] = [];
            let custId = "";
            if(!apz.isNull(window.inSessionStore.customerDetailsList)){
                if(gApzCOB.currentApplicant <= 1){
                    customerData = inSessionStore.customerDetailsList.filter(custData => custData.customerType.toLowerCase() === "applicant");
                } else {
                    customerData = inSessionStore.customerDetailsList.filter(custData => custData.customerType.toLowerCase() !== "applicant"); 
                }
            }
            
            if(customerData.length > 0){
             custId = customerData[0].custDtlId;
            }
            if(apz.isNull(custId)) {
                custmData = gApzCOB.requestNodes.customerDetailsList.filter(custData => custData.customerType.toLowerCase() === ((gApzCOB.currentApplicant <= 1) ? "applicant" : "co-app"));
                if (custmData.length > 0) {
                    custId = custmData[0].custDtlId;
                }
                if (apz.isNull(custId)) {
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_EMPTY_CUSTDTLID"), "E");
                    return '';
                }
            }
            $.each(finalDocsArr, function(i, k) {
                var obj = {
                    "documentId": k.appDocId,
                    "appDocId": k.appDocId,
                    "appId": gAppId,
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "custDtlId": custId,
                    "payload": {
                        "docSide": k.docSide,
                        "documentFileName": k.filename,
                        "documentFormat": k.filetype,
                        "documentType": k.docType,
                        "documentName": k.docName,
                        "documentDesc": "",
                        "documentLoc": k.filelocation,
                        "screenId": "UploadDocuments",
                        "issueDate": "",
                        "expiryDate": "",
                        "docStatus": "A",
                        "isPushbackUpload": apz.isNull(k.isPushbackUpload) ? "N" : k.isPushbackUpload,
                        "isAdiDoc": apz.isNull(k.isAdiDoc) ? "N" : k.isAdiDoc,
                        "longitude": window.currentGeoCords?.longitude,
                        "latitude":window.currentGeoCords?.latitude,
                        "uploadedTs":new Date().toISOString(),
                        "docLevel": k.docLevel
                    }
                }
                if(ISPUSHBACKPPL){
                  let checkDocList = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.filter(docs => parseInt(docs.documentId) === k.appDocId); 
                  if(checkDocList.length === 0){
                    obj.payload.isPushbackUpload = "Y";
                  }
                }
                if (apz.isNull(gApzCOB["requestNodes"]['applicationDocumentsWrapperList']) || gApzCOB["requestNodes"][
                        'applicationDocumentsWrapperList'
                    ].length === 0) {
                    lobj["applicationDocumentsList"].push(obj);
                } else {
                    if (apz.isNull(k["appDocId"])) {
                        gApzCOB["requestNodes"]['applicationDocumentsWrapperList'][0]["applicationDocumentsList"].push(obj);
                    }
                }
            })
            if (!apz.isNull(lobj)) {
                gApzCOB["requestNodes"]['applicationDocumentsWrapperList'].push(lobj);
            }
             if (!apz.isNull(inSessionStore.applicationDocumentsWrapperListSess)) {
                 if (!apz.isNull(window.inSessionStore.applicationDocumentsWrapperListSess[CURRENT_APPLICANT_DETAILS_INDEX])) {
                     window.inSessionStore.applicationDocumentsWrapperListSess[CURRENT_APPLICANT_DETAILS_INDEX] = documentProofObj;
                 }
             } else {
                 window.inSessionStore.applicationDocumentsWrapperListSess = [];
                 window.inSessionStore.applicationDocumentsWrapperListSess.push(documentProofObj);
             }
            gApzCOB['requestNodes'].applicationDocumentsWrapperList[0].applicationDocumentsList = [];
            return gApzCOB['requestNodes'];
    }
    return []
}
apz.app.UploadDocuments.validateDropDown = function() {
    var isValid = true;
        if ($('#' + UpDocScrId + 'otherdocType').val() === PleaseSelect) {
            isValid = false;
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_UPLOADDOCS_MSG_TXT_SEL_DOC_TYPE"), "E");
        }
    return isValid;
};
apz.app.UploadDocuments.browsefile = function(fileObj, browseId, type) {
    selType = $('#'+UpDocScrId+'otherdocpri').val().toLocaleUpperCase().replaceAll(' ','_');
    selCat = '';
    dragNdrop = true;
    FileSideBrowseId = browseId;
    var fileExtenName = fileObj.value.split('.')[1].toLocaleLowerCase();
    if (!Object.values(gAllowedFileTypes).includes(fileExtenName)) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_UPLOADDOCS_MSG_TXT_UPLOAD_VALID_FILE"), "W");
        return;
    }
    if (apz.app.UploadDocuments.validateDropDown()) {
        filesObj = fileObj;
        var fileToUpload = fileObj.files;
        localFileObj = {}; //localFileObj.appid = apz.getElmValue(pageId + "appId");
        localFileObj.filename = fileToUpload[0].name;
        localFileObj.filetype = fileToUpload[0].type;
        localFileObj.filelocation = apz.appId + "/" + localFileObj.filename;
        localFileObj.filePath = `${apz.appId}/${groupCode}/${gApzCOB.userDetails.applicationId}`;
        localFileObj.productGroupCode = groupCode;
        localFileObj.docType = selType;
        localFileObj.docSize = fileObj.files[0].size;
        localFileObj.docSide = "Front";
        localFileObj.docLevel = 1;
        localFileObj.fieldID = UpDocScrId + browseId;
        localFileObj.isAdiDoc = "Y";
        IS_ADITIONAL_DOC_OPERATION = true;
        FileSideBrowseId = "Browse1";
        apz.app.UploadDocuments.LoadUploadDocGetFile();
        apz.app.UploadDocuments.infoModal(type);
    }
    $(fileObj).val('')
}
apz.app.UploadDocuments.getAllFiles = function() {
    finalDocsArr = [];
    if(!apz.isNull(documentProofObj)){
    for (let key in documentProofObj) {
       if(documentProofObj[key].length > 0){
         documentProofObj[key].map(docs => {
           finalDocsArr.push(docs)
         })  
       }
    }
    }
}
apz.app.UploadDocuments.resetFileArr = function() {}
apz.app.UploadDocuments.uploadBtnClick = function(type) {
    IS_ADITIONAL_DOC_OPERATION = true;
    uploadClick = true;
    dragNdrop = false;
    selType =  $('#'+UpDocScrId+'otherdocpri').val().toLocaleUpperCase().replaceAll(' ','_');
    selCat = "";
    if (apz.app.UploadDocuments.validateDropDown()) {
        if (apz.deviceType !== "WEB") {
            FileSideBrowseId = 'Browse1';
            $('#' + UpDocScrId + 'cameracol').click();
        }
    }
}
apz.app.UploadDocuments.OpenCamGalleryModal = function(browseId) {
    if (apz.deviceType !== "WEB") {
        selCat = '';
        FileSideBrowseId = browseId;
        ApzCOB.toggleModal(UpDocScrId + "CamGalleryList");
    }
};
apz.app.UploadDocuments.SelectOption = function(captureType) {
    var strDate = new Date().getTime() + "";
    if (captureType === 'camera' || captureType === 'photo') {
        var cameraObj = {
            "zoomLevel": "20",
            "targetWidth": "",
            "targetHeight": "",
            "crop": "Y", //Y or N
            "flash": "N",
            "action": "base64_Save", // save,base64
            "fileName": 'b' + strDate,
            "encodingType": "JPG",
            "quality": "80",
            "unCompressed": "N",
            "sourceType": captureType // photo / camera
        };
        cameraObj.id = "CAMERA_ID";
        cameraObj.callBack = apz.app.UploadDocuments.cameraCallback;
        apz.ns.openCamera(cameraObj);
        ApzCOB.getGeoCordinatesMobile();
    } else {
        var json = {
            "filter": "",
            "fileCategory": "EXTERNAL", // AUDIO, VIDEO, PHOTO
            "location": "docs",
            "openFile": "N"
        };
        json.id = "FILEBROWSER_ID";
        json.callBack = apz.app.UploadDocuments.getFileCallback;
        apz.ns.fileBrowser(json);
    }
};
apz.app.UploadDocuments.getFileCallback = function(lparams) {
    if (apz.isNull(lparams.errorCode)) {
        var json = {
            "filePath": lparams.filePath,
            "id": "FILEREAD_ID",
            "callBack": apz.app.UploadDocuments.readBase64
        };
        mobileFilePath = lparams.filePath;
        //json.id = "FILEREAD_ID";
        //json.callBack = apz.app.UploadDocuments.readBase64;
        apz.ns.fileToBase64(json);
    } else {
        ApzCOB.fnDisplayMsg('Operation cancelled', "E", "");
    }
};
apz.app.UploadDocuments.readBase64 = function(lparams) {
    if (!apz.isNull(lparams.text)) {
        var curFileObj = {
            'encodedImage': lparams.text.split('\n').join(''),
            'path': mobileFilePath,
            'status': true
        }
        apz.app.UploadDocuments.cameraCallback(curFileObj);
    }
};
apz.app.UploadDocuments.cameraCallback = function(lparams) {
    if (lparams.status) {
        filesObj = lparams;
        let docsize = ApzCOB.getBase64FileSizeInBytes(filesObj.encodedImage);
        groupCode = 'LOAN';
        localFileObj = {};
        localFileObj.filename = lparams.path.split('/')[lparams.path.split('/').length - 1];
        let activeCustType = gApzCOB?.currentApplicant == '1' ? 'A': 'C';
        let fileExtenName = localFileObj.filename?.split('.')?.pop();
        // localFileObj.filename = `${activeCustType}_${selType}_${DOC_NO}.${fileExtenName}`;
        localFileObj.filetype = localFileObj.filename;
        localFileObj.filelocation = apz.appId + "/" + localFileObj.filename;
        localFileObj.fieldID = UpDocScrId + selType + FileSideBrowseId;
        localFileObj.filePath = `${apz.appId}/${groupCode}/${gApzCOB.userDetails.applicationId}`;
        localFileObj.productGroupCode = groupCode;
        localFileObj.docSize = docsize;
        localFileObj.base64Value = filesObj.encodedImage;
        localFileObj.docCategory = selCat;
        localFileObj.docType = selType;
        localFileObj.isAdiDoc = IS_ADITIONAL_DOC_OPERATION ? "Y" : "N";
        apz.app.UploadDocuments.getFileArrNew();
        ApzCOB.documentAutoSave(localFileObj,selType);   
    } else {
        ApzCOB.fnDisplayMsg(!apz.isNull(lparams.text) ? lparams.text : "Operation cancelled", "E", "");
    }
};
apz.app.UploadDocuments.CheckfileSize = function(lparams) {
    if (lparams.encodedImage !== undefined && lparams.encodedImage !== null) {
        //var baseImg = lparams.encodedImage;
        var json = {
            "id": "FILETOBASE64",
            "callBack": apz.app.UploadDocuments.fileSizeCallBack,
            "filePath": lparams.path
        };
        apz.ns.getFileSize(json);
    }
};
apz.app.UploadDocuments.fileSizeCallBack = function(params) {
    if (params.fileSize > 1001) {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_UPLOADDOCS_MSG_TXT_FILE_SIZE_LIMIT"), "E");
        //return;
    } else {
        apz.app.UploadDocuments.uploadMBImage();
    }
};
apz.app.UploadDocuments.uploadMBImage = function() {
    //Service call needs to be added.
    ApzCOB.toggleModal(UpDocScrId + "CamGalleryList");
};
apz.app.UploadDocuments.uploadDoc = function(pthis, browseId, type) { //Upload document
    apz.startLoader()
    if (!apz.isNull(type)) {
        selType = type;
    }
    var lvalid = true;
    if (lvalid) {
        apz.app.UploadDocuments.fileReader(filesObj,selType)
        //var json = {};
        if (localFileObj.filename.substring(localFileObj.filename.lastIndexOf('\.') + 1).toLocaleLowerCase() in gAllowedFileTypes) {
            //empty block
        }
    } else {
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_UPLOADDOCS_MSG_TXT_UPLOAD_VALID_FILE"), "W");
    }
};
apz.app.UploadDocuments.uploadDocCB = function(uploadRes) {
    apz.stopLoader();
    try {
        if (Object.values(uploadRes.successMessage)[0] === "success") {
            apz.app.UploadDocuments.displayFileName();
            apz.app.UploadDocuments.downloadFileFromserver();
        } else {
            if (Object.values(uploadRes.successMessage)[0] === "failure") {
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_UPLOADDOCS_MSG_TXT_UPLOAD_FAILED"), "E");
            }
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};
apz.app.UploadDocuments.updateAppDocId = function(selType1, appDocId) {}
apz.app.UploadDocuments.updateModifiedFiles = function(lfileArr, flag) {
    var type = "";
    var filename = "";
    var appDocID = "";
    if (flag === "UPDATE") {
        type = lfileArr.payload.docType
    } else {
        type = lfileArr[0]["docType"];
        filename = lfileArr[0]["filename"];
        appDocID = apz.isNull(lfileArr[0].appDocId) ? "" : parseInt(lfileArr[0].appDocId);
    }
    apz.app.UploadDocuments.removeDocFromRequest(lfileArr);
    if(!IS_ADITIONAL_DOC_OPERATION){
      $("#" + UpDocScrId + selType+"_Image"+DOC_NO).attr('src', 'apps/styles/themes/AppzillonConsumerOnboardingBackOffice/img/Sign.svg');
    $("#" + UpDocScrId + selType+"_Image"+DOC_NO+"_img").attr('src', 'apps/styles/themes/AppzillonConsumerOnboardingBackOffice/img/Sign.svg');
    $("#" + UpDocScrId + selType+"_FileName"+DOC_NO).text("");
    $("#" + UpDocScrId + selType+"_ImageClose"+DOC_NO+"_ul").addClass("sno");
    $("#" + UpDocScrId + selType+"_Image"+DOC_NO).text("");
    $("#" + UpDocScrId + selType+"_docAppId"+DOC_NO).text(""); 
    if(apz.deviceType === "WEB"){
    $("#" + UpDocScrId + selType+"_ImageClose"+DOC_NO+"_ul").parents('.docDetailsRow').find('.browse').removeClass('sno');
     $("#" + UpDocScrId + selType+"_ImageClose"+DOC_NO+"_ul").parents('.docDetailsRow').find('.browse').parent().removeClass('sno');
    } else {
    $("#" + UpDocScrId + selType+"_ImageClose"+DOC_NO+"_ul").parents('.docDetailsRow').find('.cam').removeClass('sno');
    $("#" + UpDocScrId + selType+"_ImageClose"+DOC_NO+"_ul").parents('.docDetailsRow').find('.cam').parent().removeClass('sno');
    }
      $('#'+UpDocScrId+selType+'_'+DOC_NO).removeClass('DOC_UPLOADED');
    if(selType !== "PRIMARY_KYC" && selType !== "SECONDARY_KYC"){
        var dropdownId = UpDocScrId+selType+'_SubHeaderDropDown';
        if(documentProofObj[selType].length > 0){
        ApzCOB.addDisableToInput(dropdownId);  
        } else {
        ApzCOB.removeDisableToInput(dropdownId)    
        }   
        $('#'+dropdownId).attr('readonly','readonly');
    }  
    } else {
       apz.app.UploadDocuments.LoadFileNamesForOtherDoc();   
    }
    
}
apz.app.UploadDocuments.displayFileName = function() {
    switch (selType) {
        case "OtherDocs":
            apz.app.UploadDocuments.LoadFileNamesForOtherDoc();
            break;
        default:
            break;
    }
}
apz.app.UploadDocuments.downloadFileFromserver = function(obj) {
    var flocation = "";
