apz.app.UploadDocuments.uploadBtnClickNew = function(fileObj, browseId, type,docCat) {
    IS_ADITIONAL_DOC_OPERATION = false;
    window.browseFileElem = fileObj;
    selType = type;
    if ($('#' + UpDocScrId + selType+'_SubHeaderDropDown').val() === PleaseSelect) {
    ApzCOB.fnDisplayMsg("Please select "+selType+ " document type", "E");  
    return false;  
    } else {
    selCat = docCat;
    FileSideBrowseId = browseId;
    var browseAttr = $(fileObj).attr('id');
    DOC_NO =  browseAttr.split('Camera')[1];
    apz.app.UploadDocuments.SelectOption('camera');  
    }
};

apz.app.UploadDocuments.browsefileNew = function(fileObj, browseId, type, docCat) {
    groupCode = inSessionStore?.applicationMaster?.productGroupCode ?? 'LOAN';
    selType = type;
    if ($('#' + UpDocScrId + selType + '_SubHeaderDropDown').val() === PleaseSelect) {
        ApzCOB.fnDisplayMsg("Please select " + selType + " document type", "E");
        return false;
    } else {
        FileSideBrowseId = browseId;
        selCat = docCat;
        var browseAttr = $(fileObj).attr('id');
        DOC_NO = browseAttr.split('Browse')[1];
        var fileExtenName = fileObj.value.split('.')[1].toLocaleLowerCase();
        window.browseFileElem = fileObj;
        if (!Object.values(gAllowedFileTypes).includes(fileExtenName)) {
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_UPLOADDOCS_MSG_TXT_UPLOAD_VALID_FILE"), "W");
            return;
        }
        let sizeInBytes = maxDocUploadSize * 1024; //fileSize should be in kb
        if (fileObj.files[0].size > sizeInBytes) {
            ApzCOB.fnDisplayMsg("File size should be below " + ApzCOB.formatSize(sizeInBytes) + "." + "<br/>" + "Currently uploaded file size: " + ApzCOB.formatSize(fileObj.files[0].size), "E");
            return;
        }
        filesObj = fileObj;
        var fileToUpload = fileObj.files;
        localFileObj = {}; //localFileObj.appid = apz.getElmValue(pageId + "appId");
        localFileObj.filename = fileToUpload[0].name;
        let activeCustType = gApzCOB?.currentApplicant == '1' ? 'A': 'C';
        fileExtenName = localFileObj.filename?.split('.')?.pop();
        // localFileObj.filename = `${activeCustType}_${selType}_${DOC_NO}.${fileExtenName}`;
        localFileObj.filetype = fileToUpload[0].type;
        localFileObj.filelocation = apz.appId + "/" + localFileObj.filename;
        localFileObj.filePath = `${apz.appId}/${groupCode}/${gApzCOB.userDetails.applicationId}`;
        localFileObj.productGroupCode = groupCode;
        localFileObj.docType = selType;
        localFileObj.docSize = fileObj.files[0].size;
        localFileObj.docSide = browseId === "Browse2" ? "Back" : "Front";
        localFileObj.isAdiDoc = "N";
        localFileObj.docLevel = parseInt(DOC_NO);
        IS_ADITIONAL_DOC_OPERATION = false;
        localFileObj.fieldID = UpDocScrId + type + "_" + browseId;
        if (!apz.isNull(docCat)) {
            localFileObj.fieldID = UpDocScrId + docCat + browseId;
        }
        localFileObj.docCategory = selCat;
        FileSideBrowseId = browseId;
        apz.app.UploadDocuments.LoadUploadDocGetFile();
        //apz.app.UploadDocuments.infoModal(type);
      
    }
      $(fileObj).val('')
}
apz.app.UploadDocuments.getTypeBasedDoc = function(docType,DocId){
 let filteredData = [];   
 if(!apz.isNull(documentProofObj)){
    if(!apz.isNull(documentProofObj[selType])){
      if(documentProofObj[selType].length > 0){
        filteredData = documentProofObj[selType].filter(docs => docs.docType === docType && docs.appDocId === parseInt(DocId))  
      }  
    }    
 }
 return filteredData;
}
apz.app.UploadDocuments.displayFileNameNew = function() {
    if(!IS_ADITIONAL_DOC_OPERATION){
      var docData = [];
    docData = apz.app.UploadDocuments.getTypeBasedDoc(selType,appDocID);
    if(docData.length > 0){
      $("#" + UpDocScrId + selType+"_Image"+DOC_NO+"_ul").removeClass("sno");
       $("#" + UpDocScrId + selType+"_Image"+DOC_NO+"_ul").parent().removeClass("sno");
      $("#" + UpDocScrId + selType+"_Image"+DOC_NO+"_img").attr('src', "data:image/jpg;base64," + docData[0]["imgSrc"]);
      $("#" + UpDocScrId + selType+"_FileName"+DOC_NO).text(docData[0]["docName"]);
      $("#" + UpDocScrId + selType+"_ImageClose"+DOC_NO+"_ul").removeClass("sno");
      $("#" + UpDocScrId + selType+"_Image"+DOC_NO).text(docData[0]["filename"]);
      $("#" + UpDocScrId + selType+"_docAppId"+DOC_NO).text(docData[0]["appDocId"]);  
      $('#'+UpDocScrId+selType+'_'+DOC_NO).addClass('DOC_UPLOADED');
    }
    var dropdownId = UpDocScrId+selType+'_SubHeaderDropDown';
    if(documentProofObj[selType].length > 0){
     ApzCOB.addDisableToInput(dropdownId);  
    } else {
     ApzCOB.removeDisableToInput(dropdownId)    
    }  
    $('#'+dropdownId).attr('readonly','readonly');
    if(apz.deviceType === "WEB"){
     $('#'+UpDocScrId+selType+'_Browse'+DOC_NO+'_ul').parent().addClass('sno');   
     $('#'+UpDocScrId+selType+'_Browse'+DOC_NO).parents('.docErrBorder').removeClass('docErrBorder');
    } else {
     $('#'+UpDocScrId+selType+'_Camera'+DOC_NO+'_ul').parent().addClass('sno');  
     $('#'+UpDocScrId+selType+'_Camera'+DOC_NO).parents('.docErrBorder').removeClass('docErrBorder');
    }
    $('.'+selType+'_ERR label.var1').text("");
    $('.'+selType+'_ERR').addClass('sno');
    } else {
     apz.app.UploadDocuments.LoadFileNamesForOtherDoc();   
    }
}
apz.app.UploadDocuments.getFileArrNew = function() {
    var isValid3 = true;
    var tempFileArr = [];
    finalDocsArr = [];
    localFileObj.docSide = "Front";
    localFileObj.docNo = (!apz.isNull(DOC_NO)) ? parseInt(DOC_NO) : "";
    if(IS_ADITIONAL_DOC_OPERATION){
    localFileObj.docName = $('#' + UpDocScrId +"otherdocType").val();  
    localFileObj.docCategory = apz.getElmValue(UpDocScrId + 'otherdocpri');
    } else {
    localFileObj.docName = $('#' + UpDocScrId + selType+'_SubHeaderDropDown').val();
    }
    localFileObj.docLevel = parseInt(DOC_NO);
    let hasDocLevel2 = documentProofObj[selType]?.some(
        obj => parseInt(obj.docLevel) === 2
    );
    if (hasDocLevel2) {
        localFileObj.docLevel = 1;
    } else {
        localFileObj.docLevel = parseInt(DOC_NO);
    }
    documentProofObj[selType].push(localFileObj);
    documentProofObj[selType].sort((doc1, doc2) => doc1.docLevel - doc2.docLevel);
    tempFileArr = documentProofObj[selType];
    return tempFileArr;
}
apz.app.UploadDocuments.paintFilesNew = function() {
    if(!apz.isNull(documentProofObj)){
    for (let key in documentProofObj) {
        let docList = documentProofObj[key].filter(item => item.isAdiDoc !== 'Y');
    //   let docList = documentProofObj[key];
       if(docList.length > 0){
         let docDivLength = $('#'+UpDocScrId+key+'_form .docItemRow:not(.sno)').length;
         if (docDivLength <= 1) {
             docList.map((doc, index) => {
                    //  let addRowId = $(pthis).parents('.docItemRow').attr('id');
                     let idString = UpDocScrId + key + "_0"
                     let rowIndex = $('#' + UpDocScrId + key + '_form  .docItemRow').length
                     let cloneStatus = apz.app.UploadDocuments.addDocumentRowClone(key, document.querySelector('#' + idString), $('#' +
                         UpDocScrId + key + '_form'), rowIndex);
                     if (!apz.isNull(cloneStatus)) {
                         if(index !== 0){
                         $('#' + UpDocScrId + key + '_AddDocBtn'+index).addClass('sno');
                         }
                     }
                 let indexToPaint = index + 1;
                if(apz.deviceType === "WEB"){
                $('#' + UpDocScrId + key+'_Browse'+indexToPaint+'_ul').addClass('sno');   
                } else {
                $('#' + UpDocScrId + key+'_Camera'+indexToPaint+'_ul').addClass('sno');   
                }
                $("#" + UpDocScrId + key+"Image"+indexToPaint).attr('src', "data:image/jpg;base64," + doc.imgSrc);
                $("#" + UpDocScrId + key+"_Image"+indexToPaint+"_img").attr('src', "data:image/jpg;base64," + doc.imgSrc);
                $("#" + UpDocScrId + key+"_FileName"+indexToPaint).text(doc.docName);
                $("#" + UpDocScrId + key+"_ImageClose"+indexToPaint+"_ul").removeClass("sno");
                $("#" + UpDocScrId + key+"_Image"+indexToPaint).text(doc.filename);
                $("#" + UpDocScrId + key+"_Image"+indexToPaint+"_ul").removeClass("sno");
                $("#" + UpDocScrId + key+"_Image"+indexToPaint+"_ul").parent().removeClass("sno");
                $("#" + UpDocScrId + key+"_docAppId"+indexToPaint).text(doc.appDocId); 
                $("#" + UpDocScrId + key+"_"+indexToPaint).addClass('DOC_UPLOADED');
                var dropdownId = UpDocScrId+key+'_SubHeaderDropDown';
                ApzCOB.addDisableToInput(dropdownId);
                $('#'+dropdownId).val(doc.docName).change()
                $('#'+dropdownId).attr('readonly','readonly');
             })
         }
       } else {
           if(mandatoryDocumentTypes.includes(key)){
             apz.app.UploadDocuments.loadDefaultDivs(key);
           }
       }
    }  
    apz.app.UploadDocuments.LoadFileNamesForOtherDoc();
    }
};
apz.app.UploadDocuments.fileClickNew = function(obj, selType3, type,cat) {
    IS_ADITIONAL_DOC_OPERATION = false;
     window.viewDocBtn = obj;
    window.docAction = "view";
    var flname = $(obj).text();
    selCat = cat;
    selType = selType3;
    DOC_NO = parseInt(window.viewDocBtn.id.split('Image')[1]);
    SELECTED_DOC_APP_ID = parseInt($(obj).parents('.docItemRow').find('.appDocID label.pri').text());
    var tempFileArr = apz.app.UploadDocuments.getTypeBasedDoc(selType,SELECTED_DOC_APP_ID);
    if(tempFileArr.length > 0){
            viewBase64 = tempFileArr[0].imgSrc;
            curImgObj = tempFileArr[0];
            curImgIndex = SELECTED_DOC_APP_ID;
            window.ImageLocationDetails = {
                latitude: tempFileArr[0].latitude || "",
                longitude: tempFileArr[0].longitude || "",
                uploadedTs: tempFileArr[0].uploadedTs || "",
                documentFileName: tempFileArr[0].filename || ""
            };
            apz.app.UploadDocuments.noBase64(flname, curImgObj, SELECTED_DOC_APP_ID);
    }
};
apz.app.UploadDocuments.setMandatoryDocumentDivs = function() {
        let personalData = [];
        let addressData = [];
        let selectedOccupation = '';
        let occupationData = [];
        let bankDetails = [];
        let primaryKycID = "";
        let secondaryKycId = "";
        if (!apz.isNull(inSessionStore)) {
                if (!apz.isNull(inSessionStore.customerDetailsList) && !apz.isNull(inSessionStore.addressDetailsWrapperList) && !apz.isNull(
                        inSessionStore.occupationDetailsWrapperList)) {
                    if (inSessionStore.customerDetailsList.length > 0) {
                        if (gApzCOB.currentApplicant <= 1) {
                            personalData = inSessionStore.customerDetailsList.filter(personal => personal.customerType === "Applicant")
                        } else {
                            personalData = inSessionStore.customerDetailsList.filter(personal => personal.customerType !== "Applicant")
                        }
                        if (personalData.length > 0) {
                            if (personalData[0].payload?.isDisabled === 'Y') {
                                mandatoryDocumentTypes.push("UDID_ID");
                                mandatoryPrefilledValues['UDID_ID'] = 'UDID_ID';
                                $('#'+UpDocScrId+'UDIDID_NO').text(personalData[0].payload?.UDID);
                                $('#'+UpDocScrId+ 'UDID_ID_Div').removeClass('sno');
                                
                                
                            }else
                            {
                                $('#'+UpDocScrId+ 'UDID_ID_Div').addClass('sno');
                            }
                            let secKycType = personalData[0].payload.secondaryKycType;
                            apz.app.UploadDocuments.updateMandatoryDocsDropvalues(UpDocScrId +'SECONDARY_KYC_SubHeaderDropDown',secondaryKyc)
                            if (!apz.isNull(secKycType)) {
                                mandatoryDocumentTypes.push("SECONDARY_KYC");
                                mandatoryPrefilledValues['SECONDARY_KYC'] = secKycType;
                                $('#'+UpDocScrId +'SECONDARY_KYC_SubHeaderDropDown').val(secKycType);
                                 ApzCOB.addDisableToInput(UpDocScrId +'SECONDARY_KYC_SubHeaderDropDown');  
                                 secondaryKycId = (!apz.isNull(personalData[0].payload.secondaryKycId)) ? personalData[0].payload.secondaryKycId : "";
                                  $('#'+UpDocScrId+'SECONDARY_KYC_ID').text(secondaryKycId);
                            }
                            selectedOccupation = personalData[0].payload.occupation;
                            primaryKycID = (!apz.isNull(personalData[0].payload.primaryKycId)) ? personalData[0].payload.primaryKycId : "";
                            let primaryKycEntered = apz.app.UploadDocuments.getValidKycID();
                            $('#'+UpDocScrId+'primaryKycID').text(primaryKycEntered);
                             ApzCOB.addDisableToInput(UpDocScrId +'PRIMARY_KYC_SubHeaderDropDown');
                             let panTypeSts = personalData[0].payload.panNumberStatus;
                             let panTypenum = personalData[0].payload.panNumber;
                             if(!apz.isNull(panTypenum) && panTypeSts == 'Verified') {
                                 mandatoryDocumentTypes.push("PAN_NUMBER_PHOTO");
                                //  $('#' + UpDocScrId + 'PAN_NUMBER_PHOTO_Div').removeClass('sno');
                             }
                        }
                    }
                    if (inSessionStore.addressDetailsWrapperList.length > 0) {
                        if (!apz.isNull(inSessionStore.addressDetailsWrapperList[0].addressDetailsList) && inSessionStore.addressDetailsWrapperList[0]
                            .addressDetailsList.length > 0) {
                            let sessionAddressData = inSessionStore.addressDetailsWrapperList[0].addressDetailsList;
                            if (gApzCOB.currentApplicant <= 1) {
                                addressData = sessionAddressData.filter(address => parseInt(address.custDtlId) === parseInt(gApzCOB.userDetails
                                    .custDtlId) && address.addressType === "Personal");
                            } else {
                                addressData = sessionAddressData.filter(address => parseInt(address.custDtlId) === parseInt(gApzCOB.userDetails
                                    .CoApplicantCustomerId) && address.addressType === "Personal");
                            }
                            if (addressData.length > 0) {
                                let presentAddressArray = addressData[0].payload.addressList.filter(currentAddress => currentAddress.addressType === "Present");
                            
                                if (presentAddressArray.length > 0) {
                                    let currentResidencePrrofVal = presentAddressArray[0].currentAddressProof;
                                    let effectiveProofVal = currentResidencePrrofVal === "As per KYC document" ? "As per Voter ID" : currentResidencePrrofVal;
                                    if (!apz.isNull(effectiveProofVal) && effectiveProofVal.toLowerCase() !== "as per voter id") {
                                        mandatoryDocumentTypes.push("ADDRESS_PROOF");
                                        mandatoryPrefilledValues['ADDRESS_PROOF'] = currentResidencePrrofVal;
                            
                                        if (currentAddressProofDocMap.length > 0) {
                                            let dropdownValues = currentAddressProofDocMap[0][effectiveProofVal];
                                            if (dropdownValues && dropdownValues.length > 0) {
                                                apz.app.UploadDocuments.updateMandatoryDocsDropvalues(
                                                    UpDocScrId + 'ADDRESS_PROOF_SubHeaderDropDown',
                                                    dropdownValues
                                                );
                                            }
                                        }
                                    } else {
                                        mandatoryPrefilledValues['ADDRESS_PROOF'] = currentResidencePrrofVal;
                                    }
                                }
                            }
                        }
                    }
                    if (!apz.isNull(selectedOccupation) && selectedOccupation.toLocaleLowerCase() !== "homemaker") {
                        if (inSessionStore.occupationDetailsWrapperList.length > 0) {
                            let sessionOccupationData = inSessionStore.occupationDetailsWrapperList;
                            if (gApzCOB.currentApplicant <= 1) {
                                occupationData = sessionOccupationData.filter(occupation => parseInt(occupation.occupationDetails.custDtlId) === parseInt(gApzCOB
                                    .userDetails.custDtlId));
                            } else {
                                occupationData = sessionOccupationData.filter(occupation => parseInt(occupation.occupationDetails.custDtlId) === parseInt(gApzCOB
                                    .userDetails.CoApplicantCustomerId));
                            }
                            if (occupationData.length > 0) {
                                if (selectedOccupation.toLocaleLowerCase() === "salaried") {
                                    let employmentPrrofVal = occupationData[0].occupationDetails.payload.employmentProof;
                                    if (!apz.isNull(employmentPrrofVal)) {
                                        mandatoryDocumentTypes.push("EMPLOYMENT_PROOF");
                                        mandatoryPrefilledValues['EMPLOYMENT_PROOF'] = employmentPrrofVal;
                                        if(employmentProofDocMap.length > 0){
                                          let empProofDropdownValues = employmentProofDocMap[0][employmentPrrofVal];
                                          if(empProofDropdownValues.length > 0){
                                           apz.app.UploadDocuments.updateMandatoryDocsDropvalues(UpDocScrId +'EMPLOYMENT_PROOF_SubHeaderDropDown',empProofDropdownValues)   
                                          }
                                        }
                                    }
                                }
                                    let businessAddressProofVal = occupationData[0].occupationDetails.payload.businessAddressProof;
                                    let BAeffectiveProofVal = businessAddressProofVal === "As per KYC document" ? "As per Voter ID" : businessAddressProofVal;
                                    if (!apz.isNull(businessAddressProofVal)  && BAeffectiveProofVal.toLowerCase() !== "as per voter id") {
                                        mandatoryDocumentTypes.push("BUSINESS_ADDRESS_PROOF");
                                        mandatoryPrefilledValues['BUSINESS_ADDRESS_PROOF'] = businessAddressProofVal;
                                    }

                                    if (businessAddressProofVal !== 'As per Voter ID') {
                                        if (businessAddressProofDocMap.length > 0) {
                                            let businessDropdownValues = businessAddressProofDocMap[0][businessAddressProofVal];
                                            if (businessDropdownValues && businessDropdownValues.length > 0) {
                                                apz.app.UploadDocuments.updateMandatoryDocsDropvalues(
                                                    UpDocScrId + 'BUSINESS_ADDRESS_PROOF_SubHeaderDropDown',
                                                    businessDropdownValues
                                                );
                                            }
                                        }
                                        $(`#${UpDocScrId}BUSINESS_ADDRESS_PROOF_SubHeaderDropDown`).parent().removeClass('sno')  
                                    } else{
                                      $(`#${UpDocScrId}BUSINESS_ADDRESS_PROOF_SubHeaderDropDown`).parent().addClass('sno')  
                                    }
                                    
                                    } 
                            }
                            mandatoryDocumentTypes.push("BUSINESS_PREMISE_PHOTO");
                            /*if(!apz.isNull(inSessionStore.bankDetailsWrapperList)){
                                                      if (inSessionStore.bankDetailsWrapperList.length > 0) {
                                                          bankDetails = inSessionStore.bankDetailsWrapperList.filter(bankData => parseInt(bankData
                                                              .bankDetails.custDtlId) === parseInt(gApzCOB.userDetails.custDtlId));
                                                          if (bankDetails.length > 0) {
                                                              let bankDataEditable = bankDetails[0].bankDetails.payload.editBankDetails;
                                                            
                                                          }
                                                      }      }*/
                            if (gApzCOB.currentApplicant <= 1) {
                                apz.populateDropdown(document.getElementById(UpDocScrId + "BANK_ACCOUNT_PROOF_SubHeaderDropDown"), bankAccProofArr);
                                mandatoryDocumentTypes.push("BANK_ACCOUNT_PROOF");
                            }
                        } else if (selectedOccupation.toLocaleLowerCase() === "homemaker" && gApzCOB.currentApplicant <= 1) {
                            apz.populateDropdown(document.getElementById(UpDocScrId+"BANK_ACCOUNT_PROOF_SubHeaderDropDown"), bankAccProofArr);
                            mandatoryDocumentTypes.push("BANK_ACCOUNT_PROOF");
                        }
                    }
                    if (gApzCOB.currentApplicant <= 1) {
                    mandatoryDocumentTypes.push("RELATIONSHIP_PROOF");
                    mandatoryPrefilledValues['RELATIONSHIP_PROOF'] = "Relationship Proof";
                    //  if (relatArr[0].desc !== PleaseSelect) {
                    // relatArr.unshift({
                    // "val": PleaseSelect,
                    // "desc": PleaseSelect
                    // });
                    //  }

                    apz.populateDropdown(document.getElementById(UpDocScrId +'RELATIONSHIP_PROOF_SubHeaderDropDown'), relatArr);
                    }
                        mandatoryDocumentTypes.push("CUSTOMER_PHOTOGRAPH");
                        mandatoryDocumentTypes.push("RESIDENCE_PREMISE_PHOTO");
                     apz.app.UploadDocuments.hideAndShowMandatoryDocumentDivs();
        }
}
apz.app.UploadDocuments.hideAndShowMandatoryDocumentDivs = function() {
    if (mandatoryDocumentTypes.length > 0) {
        mandatoryDocumentTypes.map(mand => {
              $('#' + UpDocScrId + mand+"_Div").removeClass('sno');  
        })
        for (let key in mandatoryPrefilledValues) {
            if (mandatoryPrefilledValues.hasOwnProperty(key)) {
                 $('#' + UpDocScrId + key+"_Div" + ' .docSubHeader label').text(mandatoryPrefilledValues[key])   
            }
        }
    }
}
apz.app.UploadDocuments.updateMandatoryDocsDropvalues = function(dropdownId,docTypes){
apz.populateDropdown(document.getElementById(dropdownId), ApzCOB.formatDropDownforArray(docTypes));    
}
apz.app.UploadDocuments.duplicateAndChangeId = function(selectElement,parentElement,index) {
    const originalDiv = selectElement;
    let newId =  "";
    if (originalDiv) {
        const clonedDiv = originalDiv.cloneNode(true);
        newId = 'UpDocs__UploadDocuments__photograph_' + (index + 1);
        clonedDiv.id = newId;
       parentElement.append(clonedDiv);
    } else {
    }
    return newId;
}
apz.app.UploadDocuments.addDocumentRow = function(docType,pthis){
 let addRowId = $(pthis).attr('id');
 let idString = UpDocScrId+docType+"_0";
 let rowIndex = $('#'+UpDocScrId+docType+'_form  .docItemRow').length;
 let rowId = parseInt(addRowId.split('AddDocBtn')[1]);
 let isValid = apz.app.UploadDocuments.addDocumentRowValidation(docType,rowId);
 if(isValid){
  let cloneStatus = apz.app.UploadDocuments.addDocumentRowClone(docType,document.querySelector('#'+idString),$('#'+UpDocScrId+docType+'_form'),(rowId+ 1));
 if(!apz.isNull(cloneStatus)){
    $(pthis).addClass('sno'); 
 }   
 }
}
apz.app.UploadDocuments.addDocumentRowValidation = function(docType,rowId){
  let valid = true;
  for(var i = 1; i <= rowId; i++){
    if(!$('#'+UpDocScrId+docType+'_'+i).hasClass('DOC_UPLOADED')){
      valid = false;  
    }
  }
  if(valid){
      let maxDocAllowed = parseInt(docMaxAndMand.filter(docM => docM.key === docType)[0]['value'].split('~')[0]);
    if(rowId >= maxDocAllowed){
     ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_DOC_MAX_DOC_LIMIT_REACHED"), "E");
     valid = false;    
    }    
  }
 return valid;
}
apz.app.UploadDocuments.addDocumentRowClone = function(docType,selectElement,parentElement,rowIndex){
    const originalDiv = selectElement;
    let newId =  "";
    if (originalDiv) {
        const clonedDiv = originalDiv.cloneNode(true);
        newId = UpDocScrId+docType+"_"+rowIndex;
        clonedDiv.id = newId;
       parentElement.append(clonedDiv);
    apz.app.UploadDocuments.commmonElementsUpdate(newId,'Browse',false,docType,rowIndex);
    apz.app.UploadDocuments.commmonElementsUpdate(newId,'Camera',false,docType,rowIndex);
    apz.app.UploadDocuments.commmonElementsUpdate(newId,'Image',false,docType,rowIndex);
    apz.app.UploadDocuments.commmonElementsUpdate(newId,'ImageClose',false,docType,rowIndex);
    apz.app.UploadDocuments.commmonElementsUpdate(newId,'FileName',true,docType,rowIndex);
    apz.app.UploadDocuments.commmonElementsUpdate(newId,'AddDocBtn',true,docType,rowIndex);
    apz.app.UploadDocuments.commmonElementsUpdate(newId,'docAppId',true,docType,rowIndex);
    $('#'+newId+' #'+UpDocScrId+docType+'_Image0_svg').attr('id',UpDocScrId+docType+'_Image'+rowIndex+'_svg');
    $('#'+newId+' #'+UpDocScrId+docType+'_ImageClose'+rowIndex).attr('onclick', 'apz.app.UploadDocuments.deleteDocumentOnType("'+docType+'",'+rowIndex+')');
       $('#'+newId).removeClass('sno');
    } else {
    }
    return newId;  
}
apz.app.UploadDocuments.commmonElementsUpdate = function(newDivId,elementName,isText,docType,rowIndex){
  $('#'+newDivId+' #'+UpDocScrId+docType+'_'+elementName+'0_ul').attr('id',UpDocScrId+docType+'_'+elementName+rowIndex+'_ul');
  $('#'+newDivId+' #'+UpDocScrId+docType+'_'+elementName+'0_li').attr('id',UpDocScrId+docType+'_'+elementName+rowIndex+'_li');
  $('#'+newDivId+' #'+UpDocScrId+docType+'_'+elementName+'0').attr('id',UpDocScrId+docType+'_'+elementName+rowIndex);
  if(isText){
  $('#'+newDivId+' #'+UpDocScrId+docType+'_'+elementName+'0_txtcnt').attr('id',UpDocScrId+docType+'_'+elementName+rowIndex+'_txtcnt');  
  }
}
apz.app.UploadDocuments.deleteDocumentOnType = function(docType, docNo){
  if(!apz.isNull(docNo)){
    SELECTED_DOC_APP_ID = parseInt($('#'+UpDocScrId+docType+'_docAppId'+docNo).text());
  }
  DOC_NO = docNo;
  apz.app.UploadDocuments.deleteDocument(docType,SELECTED_DOC_APP_ID);
}
apz.app.UploadDocuments.deleteDocument = function(DocType,docId){
  if ($('#' + UpDocScrId + "viewUploadedFileModal").is(':visible')) {
        ApzCOB.toggleModal(UpDocScrId + "viewUploadedFileModal");
    }
    selType = DocType;
    var filteredData = [];
    if(!apz.isNull(documentProofObj)){
    if(!apz.isNull(documentProofObj[DocType])){
      if(documentProofObj[DocType].length > 0){
             filteredData = documentProofObj[selType].filter(docs => docs.docType === DocType && docs.appDocId === parseInt(docId)); 
      }  
    }    
 }
 if(filteredData.length > 0){
   ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_UPLOADDOCS_MSG_TXT_DELETE_FILE_CONF"), "C", apz.app.UploadDocuments.deleteDocumentCB);  
 }
}
apz.app.UploadDocuments.deleteDocumentCB = function(param) {
    selCat = '';
    if (!apz.isNull(param) && param.choice === true) {
        ApzCOB.deleteDocument(selType, SELECTED_DOC_APP_ID);
        apz.app.UploadDocuments.manualDelete();
    }
    if ($('#' + UpDocScrId + "viewUploadedFileModal").is(':visible')) {
        ApzCOB.toggleModal(UpDocScrId + "viewUploadedFileModal");
        ApzCOB.deleteDocument(deleteDocument, DOC_NO);
    }
};
apz.app.UploadDocuments.removeDocFromRequest = function(docArray) {
    let reqAppDocId = '';
    if (docArray.length > 0) {
        reqAppDocId = docArray[0].appDocId;
    } else {
        reqAppDocId = !apz.isNull(docArray.appDocId) ? docArray.appDocId : '';
    }
    if (!apz.isNull(reqAppDocId)) {
        if (documentProofObj[selType].length > 0) {
            documentProofObj[selType].forEach(function(e, i) {
                if (e.appDocId === reqAppDocId) {
                    documentProofObj[selType].splice(i, 1)
                }
            });
        }
        if (!apz.isNull(gApzCOB.requestNodes.applicationDocumentsWrapperList)) {
            if (gApzCOB.requestNodes.applicationDocumentsWrapperList.length > 0) {
                if (gApzCOB["requestNodes"]['applicationDocumentsWrapperList'][0].applicationDocumentsList.length > 0) {
                    gApzCOB["requestNodes"]['applicationDocumentsWrapperList'][0].applicationDocumentsList.forEach(function(e, i) {
                        if (e.payload.appDocId === reqAppDocId) {
                            gApzCOB["requestNodes"]['applicationDocumentsWrapperList'][0].applicationDocumentsList.splice(i, 1)
                        }
                    });
                }
            }
        }
    }
}
apz.app.UploadDocuments.loadDefaultDivs = function(docType){
    if(apz.isNull(docType)){
       if(!apz.isNull(documentProofObj)){
       for (let key in documentProofObj) {
               let docDivLength = $('#' + UpDocScrId + key + '_form .docItemRow:not(.sno)').length;
               if (docDivLength === 0) {
                   let idString = UpDocScrId + key + "_0"
                   let cloneStatus = apz.app.UploadDocuments.addDocumentRowClone(key, document.querySelector('#' + idString), $('#' +
                               UpDocScrId + key + '_form'), 1);
               }  
       }  
 }    
    } else {
   let docDivLength = $('#' + UpDocScrId + docType + '_form .docItemRow:not(.sno)').length;
   if (docDivLength === 0) {
       let idString = UpDocScrId + docType + "_0"
       let cloneStatus = apz.app.UploadDocuments.addDocumentRowClone(docType, document.querySelector('#' + idString), $('#' +
                   UpDocScrId + docType + '_form'), 1);
   }    
    }
}
apz.app.UploadDocuments.getValidKycID = function(){
    let custData = [];
    let kycID = "";
if(!apz.isNull(inSessionStore)){
    if(!apz.isNull(inSessionStore.customerDetailsList)){
      if(inSessionStore.customerDetailsList.length > 0){
        if(gApzCOB.currentApplicant <= 1){
            custData =  inSessionStore.customerDetailsList.filter(cust => cust.custDtlId === parseInt(gApzCOB.userDetails.custDtlId));
        }  else {
            custData =  inSessionStore.customerDetailsList.filter(cust => cust.custDtlId === parseInt(gApzCOB.userDetails.CoApplicantCustomerId)); 
        }
      }  
    }
}
if (custData.length > 0) {
    if (custData[0].payload.primaryKycIdValStatus.toLocaleLowerCase() === "verified") {
        kycID = custData[0].payload.primaryKycId;
    } else if (custData[0].payload.alternateVoterIdValStatus.toLocaleLowerCase() === "verified") {
        kycID = custData[0].payload.alternateVoterId;
    }
}
 return kycID;
}
apz.app.UploadDocuments.collectMandatoryApplicantDocumentDivs = function() {
    let personalData = [];
    let addressData = [];
    let selectedOccupation = '';
    let occupationData = [];
    let bankDetails = [];
    let finDocList = ['PRIMARY_KYC'];
    applicantManddocobj = [];
    let applicant_code = 1;
    
    if (!apz.isNull(inSessionStore)) {
        if (!apz.isNull(inSessionStore.customerDetailsList) && !apz.isNull(inSessionStore.addressDetailsWrapperList) && !apz.isNull(inSessionStore
                .occupationDetailsWrapperList)) {
            if (inSessionStore.customerDetailsList.length > 0) {
                personalData = inSessionStore.customerDetailsList.filter(personal => personal.customerType === "Applicant")
                if (personalData.length > 0) {
                    let secKycType = personalData[0].payload.secondaryKycType;
                    if (!apz.isNull(secKycType)) {
                        finDocList.push("SECONDARY_KYC");
                    }
                    selectedOccupation = personalData[0].payload.occupation;
                    let panTypeSts = personalData[0].payload.panNumberStatus;
                    let panTypenum = personalData[0].payload.panNumber;
                    if(!apz.isNull(panTypenum) && panTypeSts == 'Verified') {
                        finDocList.push("PAN_NUMBER_PHOTO");
                    }
                }
            }
            if (inSessionStore.addressDetailsWrapperList.length > 0) {
                if (!apz.isNull(inSessionStore.addressDetailsWrapperList[0].addressDetailsList) && inSessionStore.addressDetailsWrapperList[0]
                    .addressDetailsList.length > 0) {
                    let sessionAddressData = inSessionStore.addressDetailsWrapperList[0].addressDetailsList;
                    if (applicant_code <= 1) {
                        addressData = sessionAddressData.filter(address => parseInt(address.custDtlId) === parseInt(gApzCOB.userDetails
                            .custDtlId) && address.addressType === "Personal");
                    } else {
                        addressData = sessionAddressData.filter(address => parseInt(address.custDtlId) === parseInt(gApzCOB.userDetails
                            .CoApplicantCustomerId) && address.addressType === "Personal");
                    }
                    if (addressData.length > 0) {
                        let presentAddressArray = addressData[0].payload.addressList.filter(currentAddress => currentAddress.addressType ===
                            "Present");
                        if (presentAddressArray.length > 0) {
                            let currentResidencePrrofVal = presentAddressArray[0].currentAddressProof;
                            let effectiveProofVal = currentResidencePrrofVal === "As per KYC document" ? "As per Voter ID" :
                                currentResidencePrrofVal;
                            if (!apz.isNull(effectiveProofVal) && effectiveProofVal.toLowerCase() !== "as per voter id") {
                                finDocList.push("ADDRESS_PROOF");
                            }
                        }
                    }
                }
            }
            if (!apz.isNull(selectedOccupation) && selectedOccupation.toLocaleLowerCase() !== "homemaker") {
                if (inSessionStore.occupationDetailsWrapperList.length > 0) {
                    let sessionOccupationData = inSessionStore.occupationDetailsWrapperList;
                    if (applicant_code <= 1) {
                        occupationData = sessionOccupationData.filter(occupation => parseInt(occupation.occupationDetails.custDtlId) === parseInt(
                            gApzCOB.userDetails.custDtlId));
                    }
                    if (occupationData.length > 0) {
                        if (selectedOccupation.toLocaleLowerCase() === "salaried") {
                            let employmentPrrofVal = occupationData[0].occupationDetails.payload.employmentProof;
                            if (!apz.isNull(employmentPrrofVal)) {
                                finDocList.push("EMPLOYMENT_PROOF");
                            }
                        }
                        let businessAddressProofVal = occupationData[0].occupationDetails.payload.businessAddressProof;
                        let BAeffectiveProofVal = businessAddressProofVal === "As per KYC document" ? "As per Voter ID" : businessAddressProofVal;
                        if (!apz.isNull(businessAddressProofVal) && BAeffectiveProofVal.toLowerCase() !== "as per voter id") {
                            finDocList.push("BUSINESS_ADDRESS_PROOF");
                        }
                    }
                }
                finDocList.push("BUSINESS_PREMISE_PHOTO");
                if (applicant_code <= 1) {
                    finDocList.push("BANK_ACCOUNT_PROOF");
                }
            } else if (selectedOccupation.toLocaleLowerCase() === "homemaker" && gApzCOB.currentApplicant <= 1) {
                finDocList.push("BANK_ACCOUNT_PROOF");
            }
        }
        if (applicant_code <= 1) {
            finDocList.push("RELATIONSHIP_PROOF");
        }
        finDocList.push("CUSTOMER_PHOTOGRAPH");
        finDocList.push("RESIDENCE_PREMISE_PHOTO");
        
    }
   
        applicantManddocobj = JSON.parse(JSON.stringify(finDocList));
    
        
    return applicantManddocobj;
}
apz.app.UploadDocuments.checkprevDocVal = function() {
    let isValid = false;
    let manobjs = apz.app.UploadDocuments.collectMandatoryApplicantDocumentDivs();
    let mandDocRefArray = [...manobjs];
    if (inSessionStore.customerDetailsList[1].payload.gkCustomerType === "Applicant" && inSessionStore.customerDetailsList[1].payload.panNumberStatus == '') {
        mandDocRefArray = mandDocRefArray.filter(item => item !== "PAN_NUMBER_PHOTO");
    }
    let applicantdocobj = inSessionStore.applicationDocumentsWrapperListSess[0];
    manobjs.map(docs => {
        let docTypeOnMand = "";
        let docMinCount = parseInt(docMaxAndMand.filter(docM => docM.key === docs)[0]['value'].split('~')[1]);
        if (!apz.isNull(applicantdocobj)) {
            if (applicantdocobj[docs].length >= docMinCount) {
                mandDocRefArray.splice(mandDocRefArray.indexOf(docs), 1);
            }
        }
    })
    if (mandDocRefArray.length === 0) {
        isValid = true;
    } else {
        isValid = false;
    }
    return isValid;
};
