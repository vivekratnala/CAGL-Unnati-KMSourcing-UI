    ApzCOB.toggleModal(DBVerifyscrId + 'preViewMdl'); //close
    $(`#RPCDBV__RPCDBReviewCnf__previewheade`).addClass('sno');
}
apz.app.RPCDBVerify.paintfileListdata = function() {
    let docArray = window.documentList;
    let docData = '';
    let otherDocId = DisbursementDocs.find(el => el.docType === "OTHER_DBDOCS").id
    othIndex = window.documentList.findIndex(el =>el.order === otherDocId);
    if (othIndex >= 0) {
        docData = DisbursementDocs;
    } else {
        docData = DisbursementDocs.slice(0, DisbursementDocs.length - 1);
    }
    const updatedMasterDocs = docData.map(d => {
        const match = docArray.find(doc => doc.order === d.id);
        let size = "";
        if (match && match.size != null && !isNaN(match.size)) {
            size = (match.size / 1024).toFixed(2) + " KB";
        }
        return {
            ...d,
            displayName: d.displayName,
            fileName: d.displayName,
            size: size
        };
    });
    if (apz.childScr === 'RPCDBReviewCnf') {
        apz.data.scrdata.RPCDBV__IpaintreViewfilelist_Res = [];
        apz.data.scrdata.RPCDBV__IpaintreViewfilelist_Res = updatedMasterDocs;
        apz.data.loadData("IpaintreViewfilelist", apz.currAppId);
    } else {
        apz.data.scrdata.RPCDBV__IpaintfileList_Res = [];
        apz.data.scrdata.RPCDBV__IpaintfileList_Res = updatedMasterDocs;
        apz.data.loadData("IpaintfileList", apz.currAppId);
    }
    // $('#RPCDBV__IpaintfileList__o__RPCDBV__IpaintfileList_Res__displayName_0').trigger('click');
}
