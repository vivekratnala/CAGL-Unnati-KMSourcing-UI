apz.app.RPCDBVerify.viewPDFDocument = function(base64, fileName) {
    $('iframe').remove();
    const iframe = document.createElement('iframe');
    Object.assign(iframe, { src: (ApplicationPDFbase64 + base64), width: "700", height: "400"});
    document.getElementById(`${DBVerifyscrId}DocimgView_ul`).appendChild(iframe);
    $(`#${DBVerifyscrId}rotate_Image,#${DBVerifyscrId}Zoomout_Img,#${DBVerifyscrId}Zoomin_Img`).addClass('sno');
    $(`#${DBVerifyscrId}docViewModal_window h1`).text(fileName ?? 'Uploaded Image');
    ApzCOB.toggleModal(`${DBVerifyscrId}docViewModal`);
    $(`#${DBVerifyscrId}DocimgView_li`).addClass('sno');
};
apz.app.RPCDBVerify.downloadShownImg = function() {
    // Implementation for downloading the shown image
};

apz.app.RPCDBVerify.paintDocSectionDocs = function(params) {
    $('iframe').remove();
    window.stageDocuments = inSessionStore.applicationDocumentsWrapperList[0].applicationDocumentsList.filter(el => (el.payload.documentType ===
        "Udyam Reg Success" || el.payload.documentType === "Udyam Reg Failed"));
    if (apz.childScr == 'RPCDBReviewCnf') {
        window.docSecScrId = 'RPCDBV__RPCDBReviewCnf__';
        if (stageDocuments.length === 1) {
            $(`#${docSecScrId}frontView_Img,#${docSecScrId}backView_Img`).attr('disabled', true);
        } else {
            $(`#${docSecScrId}frontView_Img`).attr('disabled', true);
            $(`#${docSecScrId}backView_Img`).attr('disabled', false);
        }
    }
    apz.stopLoader();
    if (params.hasOwnProperty('errorCode')) {
        ApzCOB.fnDisplayMsg(params.errorMessage, "E");
        if (apz.childScr === 'RPCDBReviewCnf') {
            $(`#RPCDBV__RPCDBReviewCnf__imgView`).attr('src', 'data:image/png;base64,' + '');
        } else {
            $(`#${DBVerifyscrId}imgView`).attr('src', 'data:image/png;base64,' + '');
        }
    } else if (params.hasOwnProperty('base64')) {
        if (currDocType?.toLowerCase() !== 'pdf') {
            $(`#${DBVerifyscrId}imgView`).removeClass('sno');
            $(`#${DBVerifyscrId}imgView_li`).removeClass('sno');
            $(`#${DBVerifyscrId}docIcons`).removeClass('sno');
            if (apz.childScr === 'RPCDBReviewCnf') {
                $(`#RPCDBV__RPCDBReviewCnf__imgView`).attr('src', 'data:image/png;base64,' + params.base64);
                if (Object.keys(window.ImageLocationDetails).length > 0) {
                    apz.app.BaseScreens.paintImageLocationDetails(`#RPCDBV__RPCDBReviewCnf__imgView`, window.ImageLocationDetails);
                }
            } else {
                $(`#${DBVerifyscrId}imgView`).attr('src', 'data:image/png;base64,' + params.base64);
                if (Object.keys(window.ImageLocationDetails).length > 0) {
                    apz.app.BaseScreens.paintImageLocationDetails(`#${DBVerifyscrId}imgView`, window.ImageLocationDetails);
                }
            }
            ApzCOB.intializeGuillotine(DBdocSecImageId);
        }
    }
}
