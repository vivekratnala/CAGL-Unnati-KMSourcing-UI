apz.app.RPCDBVerify.acceptNextBtn = function() {
    let isValid = true;
    udyamFail = inSessionStore.udhyamDetails.filter(el => el.udhyamStatus === "Failed");
    if (RPCDBVerify_STAGES[apz.childScr].id === 4) {
        for (let i = 0; i < $("#RPCDBV__RPCDBDocExecutionUnnati__DocList1 li").length; i++) {
            if (!($("#RPCDBV__RPCDBDocExecutionUnnati__docQueries_" + i).hasClass("query")) && !($(
                    "#RPCDBV__RPCDBDocExecutionUnnati__docApprove_" + i).hasClass("apr"))) {
                isValid = false;
                ApzCOB.showNewCommonErrorModal("Please Verify mandatory documents.");
                break;
            }
        }
    }
    if (isValid) {
        ApzCOB.rpcDBVerifyStages();
    }
}

apz.app.RPCDBVerify.prevBtn = function() {
    dbsideID = RPCDBVerify_STAGES[apz.childScr].id - 1;
    $(`#${DBVerifyscrId}stage_${dbsideID}`).click();
}
apz.app.RPCDBVerify.nextBtn = function() {
    prevHypId = RPCDBVerify_STAGES[apz.childScr].id;
    dbsideID = RPCDBVerify_STAGES[apz.childScr].id + 1;
    $(`#${DBVerifyscrId}stage_${dbsideID}`).click();
}
apz.app.RPCDBVerify.viewLog = function() {
    let arr = [];
    let timeLineWrapper = structuredClone ? structuredClone(inSessionStore.applicationTimelineDtl) : JSON.parse(JSON.stringify(inSessionStore
        .applicationTimelineDtl))
    timeLineWrapper.forEach(function(el, index) {
        timeStamp = '---';
        if (el?.timeStamp.includes(' ')) {
            timeStamp = typeof(el.timeStamp) === 'string' ? ApzCOB.dateformatter(el.timeStamp.replace(' ', 'T'), "date", "d/m/Y") : '---';
        }
        let lobj = {
            "stage": apz.isNull(el?.stage) ? "---" : el?.stage,
            "action": apz.isNull(el?.actionTaken) ? "---" : el?.actionTaken,
            "userName": apz.isNull(el?.userId) ? "---" : el?.userId,
            "actionTimeline": timeStamp,
            "rpcStatRemaks": apz.isNull(el?.rpcStatRemaks) ? "---" : el?.rpcStatRemaks,
            "remarks": apz.isNull(el?.remarks) ? "---" : el?.remarks
        }
        arr.push(lobj);
    })
    apz.data.scrdata.APZCBO__ActivityLog_Res = [];
    apz.data.scrdata.APZCBO__ActivityLog_Res = arr;
    apz.data.loadData("ActivityLog", gAppId);
    ApzCOB.toggleModal(BaseScrId + "activityLogModal");
    $('.crt-list li').attr('onClick', '');
    apz.data.scrdata.APZCBO__ActivityLog_Res?.forEach(function(el, index) {
        let rpcStatId = document.getElementById(`${activityIntfId}rpcStatRemaks_${index}_txtcnt`);
        let remarksId = document.getElementById(`${activityIntfId}remarks_${index}_txtcnt`);
        if (Array.isArray(el?.rpcStatRemaks)) {
            if (el.rpcStatRemaks?.length > 0) {
                rpcStatId.innerHTML = el.rpcStatRemaks?.map(msg => `• ${msg}`).join("<br>");
            }
        }
        if (el?.remarks) {
            if (el.remarks.includes('~')) {
                el.remarks = el.remarks.split('~');
            }
            if (Array.isArray(el.remarks) && el.remarks?.length > 0) {
                remarksId.innerHTML = el?.remarks?.map(msg => `• ${msg}`).join("<br>");
            }
        }
    })
};
apz.app.RPCDBVerify.previewMdl = function() {
