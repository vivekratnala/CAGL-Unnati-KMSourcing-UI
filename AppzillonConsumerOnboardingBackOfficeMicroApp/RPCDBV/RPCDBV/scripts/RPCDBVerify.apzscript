apz.app.onLoad_RPCDBVerify = function() {
    apz.app.RPCDBVerify.updateHeaderDetails();
    if (apz.childScr === 'RPCDBReviewCnf') {
        window.picture = $(`#RPCDBV__RPCDBReviewCnf__imgView`)
    } else {
        window.picture = $(`#${DBVerifyscrId}imgView`)
    }
    ApzCOB.intializeGuillotine(picture);
};
apz.app.onShown_RPCDBVerify = function() {
    $('body').addClass(' unati crdas dbkit ');
    //to show the screen with preview placeholder
    $(`#RPCDBV__RPCDBVerify__stage_1 use`).attr("xlink:href", "#icon-sidechldopt");
    $(`#RPCDBV__RPCDBVerify__stage_2 use`).attr("xlink:href", "#icon-sidechldopt");
    $(`#RPCDBV__RPCDBVerify__stage_3 use`).attr("xlink:href", "#icon-sidechldopt");
    $(`#RPCDBV__RPCDBVerify__stage_4 use`).attr("xlink:href", "#icon-sidechldopt");
    $(`#RPCDBV__RPCDBVerify__stage_5 use`).attr("xlink:href", "#icon-sidechldopt");
    if ($(".kyc-view").has("sno")) {
        $('#RPCDBV__RPCDBVerify__gr_row_50').removeClass("semi");
        $('#RPCDBV__RPCDBVerify__gr_row_48').addClass("nodoc");
    } else {
        $('#RPCDBV__RPCDBVerify__gr_row_50').addClass("semi");
        $('#RPCDBV__RPCDBVerify__gr_row_48').removeClass("nodoc");
    }
    // twocol at launch-area if the document preview is available
    appAccName = ApzCOB.getPayloadDatafromWrapper('accountName', 'Applicant', 'bankDetailsWrapperList');
    appAccNum = ApzCOB.getPayloadDatafromWrapper('accountNumber', 'Applicant', 'bankDetailsWrapperList');
    coappAccName = ApzCOB.getPayloadDatafromWrapper('accountName', 'Co-App', 'bankDetailsWrapperList');
    coappAccNum = ApzCOB.getPayloadDatafromWrapper('accountNumber', 'Co-App', 'bankDetailsWrapperList');
    apz.app.RPCDBVerify.paintHeaderData();
    ApzCOB.fetcheNachBankData();
    ApzCOB.FetchDBKITMasterData('VERIFICATION');
    dbKitGenComments = inSessionStore.applicationTimelineDtl.findLast(el => el.stage == 'Disbursement Kit')?.remarks;
    $("#RPCDBV__RPCDBReviewCnf__sanctionComments").text(dbKitGenComments || "---");
    if (inSessionStore.applicationMaster.productCode === '1009') {
        window.ApplicationType = 'NEW';
        window.leadNode = 'leadDetails';
    } else if (inSessionStore.applicationMaster.productCode === '1002') {
        window.ApplicationType = 'RENEWAL';
        window.leadNode = 'renewalLeadDetails';
    }
    $('#APZCBO__BaseScreens__queryModal_close').click(() => {
        apz.app.RPCFooter.onClickQueryMdlCancel();
    });
    if (isRpcDashboardPreview) {
       ApzCOB.launchSubScreen("RPCDBReviewCnf", `${DBVerifyscrId}RPCDbkitLaunchDiv`);
       setTimeout(function() {
           $("body").removeClass('dbkit crdas');
       },500);
       $('#RPCDBV__RPCDBVerify__gr_row_17').addClass('sno');
       $('#RPCDBV__RPCDBVerify__gr_col_17').addClass('dashrpcdbpreview');
       $('#RPCDBV__RPCDBVerify__DbFooter').addClass('sno');
       $('#RPCDBV__RPCDBVerify__DbHeader').addClass('sno');
       ApzCOB.toggleModal(BaseScrId + "preview_modal");
    } else {
        $("#APZCBO__BaseScreens__preview_row").empty();
        ApzCOB.launchSubScreen("RPCdbsanctionDtl", `${DBVerifyscrId}RPCDbkitLaunchDiv`);
        $('#RPCDBV__RPCDBVerify__gr_col_17').removeClass('dashrpcdbpreview');
    }
    setTimeout(function() {
        apz.app.RPCDBVerify.setInprogressStatus();
    },500);
    apz.app.RPCDBVerify.responseUserId();
};
apz.app.RPCDBVerify.paintHeaderData = function(lscrId) {
    lscrId = lscrId || DBVerifyscrId;
    const {
        applicationMaster: {
            memberId = "",
            applicationId = "",
            branchId = "",
            branchName = "",
            productCode = "",
            kendraId = "",
            kendraName = ""
        } = {}
    } = inSessionStore;
    const productName = subProductResponse?.filter(el => el.productCode === productCode)?.[0]?.productName;
    const custName = ApzCOB.getPayloadDatafromWrapper('customerName', 'Applicant', 'customerDetailsList');
    const setText = (id, value) => $(`#${lscrId + id}`).text(value);
    setText("custNameID_txtcnt", `${custName} / ${memberId}`);
    setText("applicationId_txtcnt", applicationId);
    setText("branchInfo_txtcnt", `${branchId} / ${branchName}`);
    setText("kendraIDName_txtcnt", `${kendraId} / ${kendraName}`);
    setText("loanProduct_txtcnt", productName);
    setText("loanID_txtcnt", ApzCOB.getPayloadDatafromWrapper('t24LoanId', 'Applicant', 'loanDetails') ?? '');
    if (isPreviewvisible == true) {
        window.rework = `#${RPCDBReviewCnfScrId}recurrentRoleType`;
    } else {
        window.rework = `#${DBVerifyscrId}currentRoleType`;
    }
    let role = gApzCOB.selectedRole.replace(/_/g, '');
    if (apz.isNull(data.isRework)) {
        $(rework).addClass("sno");
    } else {
        const label = (data.isRework === 'true' /*|| data.isRework === 'false'*/) ? "Rework" : "New";
        $(rework).removeClass("sno").text(`${role} - ${label}`);
    }
    /*if (data.isRework === 'true') {
        $(rework).text(role + " - Rework");
    } else {
        $(rework).text(role + " - New");
    }*/
};
apz.app.RPCDBVerify.NavigateSidebar = function(dbsideID, pthis) {
    apz.currAppId = "RPCDBV"
    window.stageDocuments = [];
    let scrName = Object.keys(window.RPCDBVerify_STAGES).find(key => window.RPCDBVerify_STAGES[key].id === parseInt(dbsideID));
    let notVerified = false;
    for (let i = 1; i <= 4; i++) {
        if ($("#RPCDBV__RPCDBVerify__stage_" + i).find("svg").hasClass("inprg")) {
            notVerified = true;
        }
    }
    if (dbsideID == "5" && notVerified) {
        ApzCOB.fnDisplayMsg("Please verify all the stages", "E");
    } else {
        $('#RPCDBV__RPCDBVerify__sidebarForm a').removeClass('active');
        $(pthis).addClass('active');
        ApzCOB.launchSubScreen(scrName, `${DBVerifyscrId}RPCDbkitLaunchDiv`);
        window.RPCDBV_CURRENT_STAGE_NO = parseInt(dbsideID);
    }
};
apz.app.RPCDBVerify.downloadFiles = function(pdoctype, pcusttype) {
    window.CB_LOAN_ID = '';
    if (pdoctype === 'CB') {
        let custType = (pcusttype === "1") ? 'Applicant' : 'Co-App';
        let custDetailID = ApzCOB.getCustDetailID(custType);
        window.CB_LOAN_ID = ApzCOB.getPayloadDatafromWrapper('cbLoanId', custType, 'cibilDetailsWrapperList');
        ApzCOB.downloadBRECbReport(custDetailID);
    } else if (pdoctype === 'EXECUTED') {
        let currLanguage = ApzCOB.getPayloadDatafromWrapper('language', 'Applicant', 'loanDetails');
        window.CB_LOAN_ID = `${pdoctype}_${gApzCOB.userDetails.applicationId}`
        ApzCOB.DBDocGenerateAndDownload('', 'FETCH_MANUAL', 'LOAN_APPLICATION', currLanguage, 'Y', apz.app.RPCDBVerify.downloadFilesCB, '');
    } else {
        window.CB_LOAN_ID = `${pdoctype}_${gApzCOB.userDetails.applicationId}`
        req = {
            "apiRequest": {
                "requestObj": {
                    "appId": "APZCBO",
                    "applicationId": gApzCOB.userDetails.applicationId,
                    "reportType": pdoctype,
                    "generateReport": false
                },
                "interfaceName": "GenerateAndDownloadReport"
            }
        }
        apz.startLoader();
        ApzCOB.serverBuildParam(gAppId, "GenerateAndDownloadReport", "N", "N", req, false, apz.app.RPCDBVerify.downloadFilesCB);
    }
};
apz.app.RPCDBVerify.downloadFilesCB = function(params) {
    let b64Data = "";
    let errMsg = "File download failed.!";
    const interface = ApzCOB.GetInterfaceResMap(params);
    const apiResponse = params?.res?.[interface]?.apiResponse;
    if (apz.isObjectEmpty(apiResponse)) return;
    errMsg = apiResponse?.ResponseHeader?.ResponseMessage ?? errMsg;
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            apz.stopLoader();
            const responseStr = apiResponse?.ResponseBody?.responseObj;
            const response = responseStr ? JSON.parse(responseStr) : {};
            if (response?.base64) {
                window.CBBASE64 = b64Data = response.base64;
                ApzCOB.convertBase64ToPDF(b64Data, CB_LOAN_ID);
            } else if(response.mergedBase64) {
                ApzCOB.convertBase64ToPDF(response.mergedBase64, CB_LOAN_ID);
            } else {
                ApzCOB.showDBCommonErrorModals("File Not Found.!");
            }
        } else {
            apz.stopLoader();
            ApzCOB.showDBCommonErrorModals(errMsg);
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.showDBCommonErrorModals(errMsg);
    }
}
apz.app.RPCDBVerify.sendback = function() {
    remarksComment = $(`#RPCDBV__RPCDBReviewCnf__sendbackrRemarks`).val();
    if (!apz.isNull(remarksComment)) {
        let confrmTxt = `Do you want to sendback this application for DBKIT?`;
        let popUpObj = {};
        popUpObj.text = confrmTxt;
        popUpObj.Btn1 = {
            "text": "Yes",
            "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`); apz.app.RPCDBVerify.Stagemoment('this','PUSHBACK')"
        }
        popUpObj.Btn2 = {
            "text": "No",
            "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`)"
        }
        ApzCOB.showNewCommonConfirmationModal(popUpObj)
    } else {
        ApzCOB.fnDisplayMsg("Please enter the remarks", "E");
    }
};
apz.app.RPCDBVerify.submit = function() {
    remarksComment = $(`#RPCDBV__RPCDBReviewCnf__sendbackrRemarks`).val();
    if (!apz.isNull(remarksComment)) {
    let confrmTxt = `Do you want to submit the application for disbursement?`;
    let popUpObj = {};
    popUpObj.text = confrmTxt;
    popUpObj.Btn1 = {
        "text": "Yes",
        "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`); apz.app.RPCDBVerify.Stagemoment('this','SUBMIT')"
    }
    popUpObj.Btn2 = {
        "text": "No",
        "onClick": "ApzCOB.closeCommonModal(`newCommonConfModal`)"
    }
    ApzCOB.showNewCommonConfirmationModal(popUpObj)
    } else {
        ApzCOB.fnDisplayMsg("Please enter the remarks", "E");
    }
};
apz.app.RPCDBVerify.Stagemoment = function(pthis, gaction) {
    let rMarks = remarksComment || '';
    ApzCOB.userDetailsData();
    ApzCOB.stageBasedOnAction(pthis, gaction);
    window.approveRejectAction = gaction;
    window.approveRejectAction = "";
    switch (gaction) {
        case "SUBMIT":
            window.approveRejectAction = "DBKITVERIFIED";
            break;
        case "PUSHBACK":
            window.approveRejectAction = "DBPUSHBACK";
            break;
        default:
            break;
    }
    let req = {
        apiRequest: {
            interfaceName: "",
            appId: gAppId,
            requestObj: {
                appId: gApzCOB.userDetails.appId,
                status: approveRejectAction,
                userId: gApzCOB.LoggedInUserDetails.loginResponse.userDet.id,
                applicationId: gApzCOB.userDetails.applicationId,
                versionNum: gApzCOB.userDetails.versionNum,
                custDtlId: gApzCOB.userDetails.custDtlId,
                remarks: rMarks,
                workflow: {
                    currentRole: gApzCOB.workflow.currentRole,
                    action: gApzCOB.workflow.action,
                    workflowId: gApzCOB.workflow.workflowId,
                    stage: gApzCOB.workflow.stage,
                },
            },
        },
    };
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "Stagemoment", "N", "N", req, false, apz.app.RPCDBVerify.StagemomentCB);
};
apz.app.RPCDBVerify.StagemomentCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            let ifaceName = ApzCOB.GetInterfaceResMap(params);
            if (params.res[ifaceName].apiResponse.ResponseHeader.ResponseCode == 0) {
                apz.stopLoader();
                if (approveRejectAction === "DBKITVERIFIED") {
                    popUpObj = {
                        text: `Application No ${gApzCOB.userDetails.applicationId} Submitted Successsfully to Disbursement.`,
                        Btn: {
                            text: "Ok",
                            onClick: "apz.app.RPCDBVerify.gotoHome(`newCommonSuccModal`)",
                        }
                    };
                    ApzCOB.showNewCommonSuccessModal(popUpObj);
                    return;
                }
                if (["DBPUSHBACK"].includes(approveRejectAction)) {
                    apz.stopLoader();
                    popUpObj = {
                        text: ``,
                        Btn: {
                            text: "Ok",
                            onClick: "apz.app.RPCDBVerify.gotoHome(`newCommonSuccModal`)",
                        }
                    };
                    if (approveRejectAction === "DBPUSHBACK") {
                        popUpObj.text = `Application No ${gApzCOB.userDetails.applicationId} Pushed back to DBKit Successfully.`;
                        ApzCOB.showNewCommonSuccessModal(popUpObj);
                        return;
                    }
                }
                if (approveRejectAction === "REJECTED") {
                    apz.stopLoader();
                    popUpObj = {
                        text: `Application No ${gApzCOB.userDetails.applicationId} Rejected Successfully.`,
                        Btn: {
                            text: "Ok",
                            onClick: "apz.app.RPCDBVerify.gotoHome(`newCommonSuccModal`)",
                        }
                    };
                    ApzCOB.showNewCommonSuccessModal(popUpObj);
                    return;
                }
            } else {
                let popUpObj = {
                    text: "Failed",
                    Btn: {
                        text: "OK",
                        onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
                    }
                }
                ApzCOB.showNewCommonErrorModal(popUpObj);
            }
        } else {
            apz.stopLoader(); // to be done after getting the proper response from backend
            let popUpObj = {
                text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
                Btn: {
                    text: "OK",
                    onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
                }
            }
            ApzCOB.showNewCommonErrorModal(popUpObj);
        }
    } catch (e) {
        apz.stopLoader();
        let popUpObj = {
            text: ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"),
            Btn: {
                text: "OK",
                onClick: "ApzCOB.closeCommonModal(`newCommonErrModal`)"
            }
        }
        ApzCOB.showNewCommonErrorModal(popUpObj);
    }
    apz.stopLoader();
};
