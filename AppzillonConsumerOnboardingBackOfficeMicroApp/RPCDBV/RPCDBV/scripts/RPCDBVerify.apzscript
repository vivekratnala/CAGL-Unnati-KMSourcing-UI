apz.app.RPCDBVerify.updateHeaderDetails = function() {
    let loginResponse = LoggedInUserDetails.loginResponse;
    let loginName = loginResponse?.userDet?.name;
    let loginUserId = loginResponse?.userDet?.id;
    $(`#${DBVerifyscrId}caloggedInUserName_txtcnt`).text(`${loginName} (${loginUserId})`);
    $(`#${DBVerifyscrId}caloggedInRole_txtcnt`).text(`Role:${loginResponse?.addInfo1}`);
}
apz.app.RPCDBVerify.loadQueryModal = function(val) {
    ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    currentDoc = val;
    let currStage = DBKIT_MASTERDATA?.find(el => el.stageName === RPCDBVerify_STAGES[apz.childScr].stageName);
    currApplicantQueries = [];
    currApplicantQueries = JSON.parse(currStage?.queries)?.sendbackReason;
    let queryArray = [...currApplicantQueries, {
        id: "oth",
        value: "Other",
    }];
    window.othReasonSelected = false;
    if (queryArray.length > 0) {
        apz.data.scrdata.APZCBO__RPCQueries_Res = [];
        if (apz.childScr == 'RPCDBeNach' && ["Success", "Initiated"].includes(applicantDtls[0]?.resDesc)) {
            apz.data.scrdata.APZCBO__RPCQueries_Res = structuredClone(queryArray).filter(item => item.id === "Q2" || item.id === "oth");
        } else {
            apz.data.scrdata.APZCBO__RPCQueries_Res = structuredClone(queryArray);
        }
        window.QueriesPainted = apz.data.scrdata.APZCBO__RPCQueries_Res;
        apz.data.loadData("RPCQueries", gAppId);
    }
    $(".crt-list li").attr("onClick", "");
    $(`#${BaseScrId}otherQueryReasonInp`).val("");
    $(`#${BaseScrId}otherQueryReasonInp`).attr('maxlength', 250);
    $('#APZCBO__BaseScreens__queryModal_content').scrollTop(0, 0);
    $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
    $(`#${BaseScrId}queryList`).find("p").filter(function(el, item) {
        if ($(`#${queriesIntfId}value_${el}_txtcnt`)[0].textContent === "Other") {
            othReasonId = `#${queriesIntfId}id_${el}`;
            $(`#${queriesIntfId}id_${el}`).attr("onchange", "apz.app.RPCDBVerify.onSelectOtherReason();");
        }
    });
    $(`#${BaseScrId}queryList`).addClass("pb-70");
    if (currApplicantQueries.length === 0) {
        $(`#${BaseScrId}search_row`).addClass('sno');
        $('#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_0').prop('checked', true).change()
    } else {
        $(`#${BaseScrId}search_row`).removeClass('sno');
    }
    $("#APZCBO__BaseScreens__otherQueryReasonInp").val('');
    $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
    let othId = apz.data.scrdata.APZCBO__RPCQueries_Res.findIndex(el => el.id === "oth");
    let lQueriespropset = apz.app.RPCDBVerify.getQueryReasons(RPCDBV_CURRENT_STAGE_NO,apz.childScr);
    if (RPCDBVerify_STAGES[apz.childScr].id == 4) {
        documentQueries = window?.dbVerificationQueries?.filter(q=>q.split("^")[0]===val);
        if (documentQueries?.length > 0 && !window.reuploadedDocs.includes(currentDoc)) {
            for (let i = 0; i < documentQueries.length; i++) {
                
                let query = apz.app.RPCDBVerify.getCheckedQuery(documentQueries[i]);
                for (let j = 0; j < $("#APZCBO__BaseScreens__queryList li").length; j++) {
                    if ($("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__value_" + j + "_txtcnt").text() === query) {
                        $("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_" + j).prop("checked", "checked");
                    } else if ((documentQueries[i].split("^")[1].split("?")[0] == "oth")) {
                        query = documentQueries[i].split("^")[1].split("?")[1];
                        $("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_" + ($("#APZCBO__BaseScreens__queryList>ul").children().last().attr("rowno"))).prop("checked", "checked");
                        $("#APZCBO__BaseScreens__otherQueryReasonInp").val(query);
                        $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
                    }
                }
            }
        }
    }else 
    if (RPCDBVerify_STAGES[apz.childScr].id == 1) {
        if(lQueriespropset?.length > 0) {
            $("#APZCBO__BaseScreens__queryList > ul > li input").prop("checked",false);
            sanCheckedQueries = lQueriespropset?.map(item => item.Q);
            for (let i = 0; i < sanCheckedQueries.length; i++) {
                let query = sanCheckedQueries[i];
                for (let j = 0; j < $("#APZCBO__BaseScreens__queryList li").length; j++) {
                    if ($("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__value_" + j + "_txtcnt").text() === query) {
                        $("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_" + j).prop("checked", "checked");
                    } else if (sanCheckedQueries[i].split("?")[0] == "oth") {
                        query = sanCheckedQueries[i]?.split("?")[1];
                        if (othId >= 0) {
                            $("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_" + othId).prop("checked", "checked");
                        }
                        $("#APZCBO__BaseScreens__otherQueryReasonInp").val(query);
                        $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
                    }
                }
            }
        }
    } else 
    if (RPCDBVerify_STAGES[apz.childScr].id == 2) {
        $("#APZCBO__BaseScreens__queryList > ul > li input").prop("checked",false);
        if (lQueriespropset?.length > 0) {
            eNachQueries = lQueriespropset?.map(item => item.Q);
            for (let i = 0; i < eNachQueries.length; i++) {
                let query = eNachQueries[i];
                for (let j = 0; j < $("#APZCBO__BaseScreens__queryList li").length; j++) {
                    if ($("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__value_" + j + "_txtcnt").text() === query) {
                        $("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_" + j).prop("checked", "checked");
                    } else if (eNachQueries[i].split("?")[0] == "oth") {
                        query = eNachQueries[i].split("?")[1];
                        if (othId >= 0) {
                            $("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_" + othId).prop("checked", "checked");
                        }
                        $("#APZCBO__BaseScreens__otherQueryReasonInp").val(query);
                        $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
                    }
                }
            }
        }
    }else 
    if (RPCDBVerify_STAGES[apz.childScr].id == 3) {
        $("#APZCBO__BaseScreens__queryList > ul > li input").prop("checked", false);
        if (lQueriespropset?.length > 0) {
            udyamQueries = lQueriespropset?.map(item => item.Q);
            for (let i = 0; i < udyamQueries.length; i++) {
                let query = udyamQueries[i];
                for (let j = 0; j < $("#APZCBO__BaseScreens__queryList li").length; j++) {
                    if ($("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__value_" + j + "_txtcnt").text() === query) {
                        $("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_" + j).prop("checked", "checked");
                    } else if (udyamQueries[i].split("?")[0] == "oth") {
                        query = udyamQueries[i].split("?")[1];
                        if (othId >= 0) {
                            $("#APZCBO__RPCQueries__o__APZCBO__RPCQueries_Res__id_" + othId).prop("checked", "checked");
                        }
                        $("#APZCBO__BaseScreens__otherQueryReasonInp").val(query);
                        $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
                    }
                }
            }
        }
    }
    ApzCOB.toggleModal(BaseScrId + "queryModal");
};
apz.app.RPCDBVerify.getCheckedQuery = function(query){
if (query.split("^")[1].indexOf("oth?") != -1) {
        return query.split("^oth?")[1];
    } else {
        return (JSON.parse(DBKIT_MASTERDATA.filter(e => e.id === 11)[0].queries)).sendbackReason.filter(e1 => e1.id === query.split("^")[1])[0]
            .value;
    }
}
apz.app.RPCDBVerify.onSelectOtherReason = function() {
    othVal = $(othReasonId).prop("checked");
    if (othVal) {
        $(`#${BaseScrId}queryList`).removeClass("pb-70")
        window.othReasonSelected = true;
        $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
    } else {
        $(`#${BaseScrId}queryList`).addClass("pb-70")
        window.othReasonSelected = false;
        $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
        $(`#${BaseScrId}otherQueryReasonInp`).val("");
        ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    }
};
apz.app.RPCFooter.onClickQueryMdlCancel = function() {
    checkedQueries = [];
    $(`#${BaseScrId}queryList`).addClass("pb-70");
    apz.app.RPCDBVerify.uncheckOthercheckbox();
};
apz.app.RPCDBVerify.uncheckOthercheckbox = function() {
    window.othReasonSelected = false;
    $(othReasonId).prop("checked", false)
    $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
    $(`#${BaseScrId}otherQueryReasonInp`).val("");
    ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    ApzCOB.toggleModal(BaseScrId + "queryModal");
}
apz.app.RPCFooter.onClickQueryMdlSave = function() {
    ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    let checkedLength = -1;
    let checkedReasons = '';
    window.docQueries = [];
    window.docapprove = [];
    checkedQueries = [];
    let result = {
        docapprove: [],
        docQueries: []
    };
    if (othReasonSelected) {
        otherVal = $(`#${BaseScrId}otherQueryReasonInp`).val();
        if (apz.isNull(otherVal)) {
            ApzCOB.addErrMessage(`${BaseScrId}otherQueryReasonInp`, "element");
            document.getElementById('APZCBO__BaseScreens__el_txt_136_txtcnt').scrollIntoView();
            return;
        }
    }
    QueriesPainted.forEach(function(item, index) {
        if ($(`#${queriesIntfId}id_${index}`).prop("checked")) {
            checkedLength++;
            checkedQueries.push(QueriesPainted[index]?.id + "_" + QueriesPainted[index]?.value);
            if (othReasonId === `#${queriesIntfId}id_${index}`) {
                checkedQueries[checkedQueries?.length - 1] = checkedQueries?.[checkedQueries?.length - 1] + "?" + $(
                    `#${BaseScrId}otherQueryReasonInp`).val();
            }
        }
    });
    apz.app.RPCDBVerify.addInprogressStatus(`${DBVerifyscrId}stage_${RPCDBVerify_STAGES[apz.childScr].id}`);
    if (RPCDBVerify_STAGES[apz.childScr].id === 1) {
        window.sanctionDtlsQueries = checkedQueries;
        if (checkedQueries.length > 0) {
            $("#RPCDBV__RPCdbsanctionDtl__Query").removeClass('sno');
            $("#RPCDBV__RPCdbsanctionDtl__queryFrm").removeClass('sno');
            $("#RPCDBV__RPCdbsanctionDtl__queryRow").removeClass('sno');
            $("span#RPCDBV__RPCdbsanctionDtl__selectedQuerydata").html("");
            for (var q = 0; q < checkedQueries.length; q++) {
                if (checkedQueries[q].split('_')[0] === 'oth') {
                    checkedReasons = checkedQueries[q].split('_')[1].split('?')[1];
                } else {
                    checkedReasons = checkedQueries[q].split("_")[1];
                }
                $("span#RPCDBV__RPCdbsanctionDtl__selectedQuerydata").append('<p>' + (q + 1) + ". " + checkedReasons + '</p>')
            }
        } else if (checkedQueries.length == 0) {
            // checkedQueries;
            $("#RPCDBV__RPCdbsanctionDtl__Query").addClass('sno');
            $("#RPCDBV__RPCdbsanctionDtl__queryFrm").addClass('sno');
            $("#RPCDBV__RPCdbsanctionDtl__queryRow").addClass('sno');
            $("span#RPCDBV__RPCdbsanctionDtl__selectedQuerydata").html("");
            $("span#RPCDBV__RPCdbsanctionDtl__selectedQuerydata").append('<p>' + (q + 1) + ". " + checkedReasons + '</p>')
        }
        result = checkedQueries.map(q => {
            var [key, value] = q.split("_");
            return key === "oth" ? `oth${value.replace("Other",'')}` : key;
        });
        ApzCOB.RpcDBQuerySave(result);
        checkedQueries = [];
    } else if (RPCDBVerify_STAGES[apz.childScr].id === 2) {
        window.eNachQueries = checkedQueries;
        if (checkedQueries.length > 0) {
            $("#RPCDBV__RPCDBeNach__eQuery").removeClass('sno');
            $("#RPCDBV__RPCDBeNach__EqueryFrm").removeClass('sno');
            $("#RPCDBV__RPCDBeNach__Equeryrow").removeClass('sno');
            $("span#RPCDBV__RPCDBeNach__EselectedQuerydata").html("");
            for (var q = 0; q < checkedQueries.length; q++) {
                if (checkedQueries[q].split('_')[0] === 'oth') {
                    checkedReasons = checkedQueries[q].split('_')[1].split('?')[1];
                } else {
                    checkedReasons = checkedQueries[q].split("_")[1];
                }
                $("span#RPCDBV__RPCDBeNach__EselectedQuerydata").append('<p>' + (q + 1) + ". " + checkedReasons + '</p>')
            }
        } else if (checkedQueries.length == 0) {
            // checkedQueries;
            $("#RPCDBV__RPCDBeNach__eQuery").addClass('sno');
            $("#RPCDBV__RPCDBeNach__EqueryFrm").addClass('sno');
            $("#RPCDBV__RPCDBeNach__Equeryrow").addClass('sno');
            $("span#RPCDBV__RPCDBeNach__EselectedQuerydata").html("");
            $("span#RPCDBV__RPCDBeNach__EselectedQuerydata").append('<p>' + (q + 1) + ". " + checkedReasons + '</p>')
        }
        result = checkedQueries.map(q => {
            let [key, value] = q.split("_");
            return key === "oth" ? `oth${value.replace("Other",'')}` : key;
        });
        ApzCOB.RpcDBQuerySave(result);
        checkedQueries = [];
    } else if (RPCDBVerify_STAGES[apz.childScr].id === 3) {
        window.udyamQueries = checkedQueries;
        if (checkedQueries.length > 0) {
            $("#RPCDBV__RPCDBUdyamReg__UQuery").removeClass('sno');
            $("#RPCDBV__RPCDBUdyamReg__UqueryFrm").removeClass('sno');
            $("#RPCDBV__RPCDBUdyamReg__UqueryRow").removeClass('sno');
            $("span#RPCDBV__RPCDBUdyamReg__UselectedQuerydata").html("");
            for (var q = 0; q < checkedQueries.length; q++) {
                if (checkedQueries[q].split('_')[0] === 'oth') {
                    checkedReasons = checkedQueries[q].split('_')[1].split('?')[1];
                } else {
                    checkedReasons = checkedQueries[q].split("_")[1];
                }
                $("span#RPCDBV__RPCDBUdyamReg__UselectedQuerydata").append('<p>' + (q + 1) + ". " + checkedReasons + '</p>')
            }
        } else if (checkedQueries.length == 0) {
            $("#RPCDBV__RPCDBUdyamReg__UQuery").addClass('sno');
            $("#RPCDBV__RPCDBUdyamReg__UqueryFrm").addClass('sno');
            $("#RPCDBV__RPCDBUdyamReg__UqueryRow").addClass('sno');
            $("span#RPCDBV__RPCDBUdyamReg__UselectedQuerydata").html("");
            $("span#RPCDBV__RPCDBUdyamReg__UselectedQuerydata").append('<p>' + (q + 1) + ". " + checkedReasons + '</p>')
        }
        result = checkedQueries.map(q => {
            let [key, value] = q.split("_");
            return key === "oth" ? `oth${value.replace("Other",'')}` : key;
        });
        ApzCOB.RpcDBQuerySave(result);
        checkedQueries = [];
    } else if (RPCDBVerify_STAGES[apz.childScr].id === 4) {
        window.docQuery[currentDoc] = checkedQueries;
        if (checkedQueries.length > 0) {
            $("#RPCDBV__RPCDBDocExecutionUnnati__DocList1_row_" + rowno + " .docQueryRow").removeClass('sno');
            $("#RPCDBV__RPCDBDocExecutionUnnati__DocList1_row_" + rowno + " span#RPCDBV__RPCDBDocExecutionUnnati__Doc_Queries_li").html("");
            for (let q = 0; q < checkedQueries.length; q++) {
                if (checkedQueries[q].split('_')[0] === 'oth') {
                    checkedReasons = checkedQueries[q].split('_')[1].split('?')[1];
                } else {
                    checkedReasons = checkedQueries[q].split("_")[1];
                }
                $("#RPCDBV__RPCDBDocExecutionUnnati__DocList1_row_" + rowno + " span#RPCDBV__RPCDBDocExecutionUnnati__Doc_Queries_li").append(
                    '<p>' + (q + 1) + ". " + checkedReasons + '</p>')
            }
            $("#RPCDBV__RPCDBDocExecutionUnnati__docQueries_" + rowno).addClass('query');
            $("#RPCDBV__RPCDBDocExecutionUnnati__docApprove_" + rowno).removeClass("apr");
            $("#RPCDBV__RPCDBDocExecutionUnnati__docApprove_" + rowno + "_txtcnt").text("Approve");
        } else if (checkedQueries.length == 0) {
            $("#RPCDBV__RPCDBDocExecutionUnnati__DocList1_row_" + rowno + " .docQueryRow").addClass('sno');
            $("#RPCDBV__RPCDBDocExecutionUnnati__DocList1_row_" + rowno + " span#RPCDBV__RPCDBDocExecutionUnnati__Doc_Queries_li").html("");
            $("#RPCDBV__RPCDBDocExecutionUnnati__DocList1_row_" + rowno + " span#RPCDBV__RPCDBDocExecutionUnnati__Doc_Queries_li").append('<p>' +
                (q + 1) + ". " + checkedReasons + '</p>')
            $("#RPCDBV__RPCDBDocExecutionUnnati__docQueries_" + rowno).removeClass('query');
        }
        apz.app.RPCDBVerify.DocqueriestimeStamp();

        result.docQueries = window.dbVerificationQueries.filter(e=>e.split("^")[0]!=currentDoc);
        checkedQueries.forEach(reason => {
            let reasonCode = '';
        if (reason.split("_")[0] === 'oth') {
                         reasonCode = reason.split("_")[0] + '?' + reason.split("_")[1].split('?')[1]
                    } else {
                         reasonCode = reason.split("_")[0];
                    }
                    result.docQueries.push(`${currentDoc}^${reasonCode}^${docQueryTs}`);
        });
        window.approvedDocs = window.approvedDocs.filter(item => currentDoc!==item);
        window.dbVerificationQueries = [...new Set([...result.docQueries])];
        window.reuploadedDocs = window.reuploadedDocs.filter(item => currentDoc!==item);
        if($("#APZCBO__BaseScreens__queryModal").css("display")!='none')
        ApzCOB.toggleModal(BaseScrId + "queryModal");
    apz.app.RPCDBDocExecutionUnnati.paintDocData();
        checkedQueries = [];
    } else {
        checkedQueries = [];
        window.othReasonSelected = false;
        if (othReasonSelected) {
            otherVal = $(`#${BaseScrId}otherQueryReasonInp`).val();
            if (apz.isNull(otherVal)) {
                ApzCOB.addErrMessage(`${BaseScrId}otherQueryReasonInp`, "element");
                document.getElementById('APZCBO__BaseScreens__el_txt_136_txtcnt').scrollIntoView();
                return;
            }
        }
        QueriesPainted.forEach(function(item, index) {
            if ($(`#${queriesIntfId}id_${index}`).prop("checked")) {
                checkedLength++;
                if (currentDoc == undefined || currentDoc == null) {
                    checkedQueries.push(QueriesPainted[index]?.id);
                } else {
                    checkedQueries.push(currentDoc + "_" + QueriesPainted[index]?.id);
                }
                if (othReasonId === `#${queriesIntfId}id_${index}`) {
                    checkedQueries[checkedQueries?.length - 1] = checkedQueries?.[checkedQueries?.length - 1] + "?" + $(
                        `#${BaseScrId}otherQueryReasonInp`).val();
                }
            }
        });
        ApzCOB.RpcDBQuerySave(checkedQueries);
        checkedQueries = [];
    }
};
apz.app.RPCDBVerify.DocqueriestimeStamp = function() {
    let now = new Date();
    let pad = n => n.toString().padStart(2, '0');
    docQueryTs =
        `${pad(now.getDate())}/${pad(now.getMonth() + 1)}/${now.getFullYear()} - ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
}
apz.app.RPCDBVerify.queriestimeStamp = function(dtime) {
    let ts = dtime[0].timeStamp[0];
    let pad = n => n.toString().padStart(2, '0');
    formattedTimestamp =
        `${pad(ts.date.day)}/${pad(ts.date.month)}/${ts.date.year} - ${pad(ts.time.hour)}:${pad(ts.time.minute)}:${pad(ts.time.second)}`;
}
apz.app.RPCFooter.searchInQueryMdl = function() {
    let query = $("#APZCBO__BaseScreens__searchQueryInput").val();
    window.searchresults = QueriesPainted.filter((lead) => Object.values(lead).some((value) => String(value).toLowerCase().includes(query
        .toLowerCase())));
    if (searchresults?.length > 0) {
        apz.data.scrdata.APZCBO__RPCQueries_Res = [];
        apz.data.scrdata.APZCBO__RPCQueries_Res = searchresults;
        apz.data.loadData("RPCQueries", gAppId);
        $(`#${BaseScrId}queryList .wrapped.undefined.ssp`).remove();
        $(`#${BaseScrId}queryList`).find("p").filter(function(el, item) {
            if ($(`#${queriesIntfId}value_${el}_txtcnt`)[0].textContent === "Other") {
                othReasonId = `#${queriesIntfId}id_${el}`;
                $(`#${queriesIntfId}id_${el}`).attr("onchange", "apz.app.RPCFooter.onSelectOtherReason();");
            }
        });
        $(`#${BaseScrId}noResult_row`).addClass("sno");
        $(`#${BaseScrId}queryList`).removeClass("sno");
    } else {
        $(`#${BaseScrId}noResult_row`).removeClass("sno");
        $(`#${BaseScrId}queryList`).addClass("sno");
        $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
    }
};
apz.app.RPCFooter.onSelectOtherReason = function() {
    let othVal = $(othReasonId).prop("checked");
    if (othVal) {
        $(`#${BaseScrId}queryList`).removeClass("pb-70")
        window.othReasonSelected = true;
        $(`#${BaseScrId}otherQueryReasonForm`).removeClass("sno");
    } else {
        $(`#${BaseScrId}queryList`).addClass("pb-70")
        window.othReasonSelected = false;
        $(`#${BaseScrId}otherQueryReasonForm`).addClass("sno");
        $(`#${BaseScrId}otherQueryReasonInp`).val("");
        ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    }
};
apz.app.RPCFooter.validateInput = function() {
    let inputField = $("#APZCBO__BaseScreens__otherQueryReasonInp");
    let value = inputField.val().trim();
    if (value !== "") {
        ApzCOB.removeErrMessgae(`${BaseScrId}otherQueryReasonInp`, "element");
    }
}
apz.app.RPCDBVerify.loadQueryModalForDoc = function(pthis) {
    if (apz.childScr === 'RPCdbsanctionDtl' || apz.childScr === 'RPCDBeNach' || apz.childScr === 'RPCDBUdyamReg') {
        apz.app.RPCDBVerify.loadQueryModal();
    } else if (apz.childScr == 'RPCDBDocExecutionUnnati') {
        rowno = $(pthis).closest("li").attr("rowno");
        apz.app.RPCDBVerify.loadQueryModal($("#RPCDBV__IpaintfileList__o__RPCDBV__IpaintfileList_Res__displayName_" + rowno + "_txtcnt").text());
    }
};
apz.app.RPCDBVerify.approve = function(pthis) {
    rowno = $(pthis).closest("li").attr("rowno");
    $("#RPCDBV__RPCDBDocExecutionUnnati__docApprove_" + rowno).addClass("apr");
    $("#RPCDBV__RPCDBDocExecutionUnnati__docApprove_" + rowno + "_txtcnt").text("Approved");
    $("#RPCDBV__RPCDBDocExecutionUnnati__docQueries_" + rowno).removeClass('query');
    $("#RPCDBV__RPCDBDocExecutionUnnati__DocList1_row_" + rowno + " .docQueryRow").addClass('sno');
    currentDoc = $("#RPCDBV__IpaintfileList__o__RPCDBV__IpaintfileList_Res__displayName_" + rowno + "_txtcnt").text();
    window.approvedDocs = [...new Set([...window.approvedDocs,currentDoc])];
    window.dbVerificationQueries = [...new Set(window.dbVerificationQueries.filter(item => currentDoc!==(item.split('^')[0])))];
    window.reuploadedDocs = [...new Set(window.reuploadedDocs.filter(item => currentDoc!==item))];
    apz.app.RPCDBDocExecutionUnnati.paintDocData();
}
apz.app.RPCDBVerify.gotoHome = function(modalId) {
    if (!apz.isNull(modalId)) ApzCOB.closeCommonModal(modalId);
    apz.app.Login.OnClickMakerChecker("");
}
apz.app.RPCDBVerify.addInprogressStatus = function(hypId) {
    apz.app.RPCDBVerify.clearIcons(hypId);
    $(`#${hypId} svg`).addClass('inprg');
    $(`#${hypId} use`).attr("xlink:href", "#icon-sideprg");
};
apz.app.RPCDBVerify.addCompleteStatus = function(hypId) {
    apz.app.RPCDBVerify.clearIcons(hypId);
    $(`#${hypId} svg`).addClass('suc');
    $(`#${hypId} use`).attr("xlink:href", "#icon-sidechk");
};
apz.app.RPCDBVerify.addErrorStatus = function(hypId) {
    apz.app.RPCDBVerify.clearIcons(hypId);
    $(`#${hypId} svg`).addClass('error');
    $(`#${hypId} use`).attr("xlink:href", "#icon-fail-filled");
};
apz.app.RPCDBVerify.clearIcons = function(hypId) {
    $(`#${hypId} svg`).removeClass('error sec inprg');
    $(`#${hypId} use`).attr("xlink:href", "#icon-sidechldopt");
};
apz.app.RPCDBVerify.downloadImage = function() {
    let fileName = '';
    if (apz.childScr == 'RPCDBDocExecutionUnnati') {
        fileName = SELECTED_DOC_FILE_NAME.replace(/\.pdf$/i, "");
        let pdfBase64 = $("iframe").attr('src').replace(ApplicationPDFbase64, '');
        ApzCOB.downloadBase64File(pdfBase64, fileName)
    } else {
        fileName = stageDocuments[pcount].payload.documentFileName;
        let valbase64 = $("#RPCDBV__RPCDBVerify__imgView").attr('src').replace('data:image/png;base64,', '');
        ApzCOB.convertBase64ToPNG(valbase64, fileName);
    }
};
apz.app.RPCDBVerify.getQueryReasons = function(screenNo, stageName) {
    if(apz.isNull(inSessionStore?.dbKitStatDetails?.filter(e => e.stageID == screenNo)?.[0]?.query)) {
        return [];
    } else {
        return inSessionStore?.dbKitStatDetails?.filter(e => e.stageID == screenNo)?.[0]?.query && inSessionStore?.dbKitStatDetails?.filter(e => e
        .stageID == screenNo)?.[0]?.query.map(function(item) {
        let lQueries = JSON.parse(DBKIT_MASTERDATA?.filter(e => e.stageName === stageName)[0]?.queries)?.sendbackReason;
        return {
            "Q": lQueries?.find(ele => ele.id == item.split("$")[0])?.value || item.split("$")[0],
            "R": item?.split("$")?.[1],
            "RTS" : item?.split("$")?.[2]
        }
    })
    }
};
apz.app.RPCDBVerify.setModifedtag = function() {
    let hasReupload = stageDocuments.some(doc => doc.payload.isReupload === "Y");
    if ((hasReupload)&&(!apz.isNull(eNachcheckedQueries[0]?.R)||!apz.isNull(udyamcheckedQueries[0]?.R))) {
        $(`#RPCDBV__RPCDBVerify__modify`).removeClass('sno');
    } else {
        $(`#RPCDBV__RPCDBVerify__modify`).addClass('sno');
    }
};
apz.app.RPCDBVerify.setInprogressStatus = function() {
    for (let i = 1; i <= 3; i++) {
        let QueryReasons = apz.app.RPCDBVerify.getQueryReasons(i, apz.app.RPCDBVerify.getStageNameById(i));
        if (!apz.isNull(QueryReasons) && !apz.isNull(QueryReasons?.[0]?.R)) {
            apz.app.RPCDBVerify.addInprogressStatus(`${DBVerifyscrId}stage_` + i);
        } else {
            if (data.isRework === 'true') {
                let setQueryTag = QueryReasons;
                if (!apz.isNull(setQueryTag) && !apz.isNull(setQueryTag?.[0]?.Q)) {
                    apz.app.RPCDBVerify.addErrorStatus(`${DBVerifyscrId}stage_` + i)
                } else {
                    apz.app.RPCDBVerify.addCompleteStatus(`${DBVerifyscrId}stage_` + i)
                }
            } else {
                apz.app.RPCDBVerify.clearIcons(`${DBVerifyscrId}stage_` + i)
            }
        }
    }
    if (inSessionStore?.dbVerificationQueries && inSessionStore?.dbVerificationQueries?.find(item => item.includes('$'))) {
        apz.app.RPCDBVerify.addInprogressStatus(`${DBVerifyscrId}stage_` + 4)
    } else {
        if (data.isRework === 'true') {
            if (inSessionStore.dbVerificationQueries?.length !== 0) {
                apz.app.RPCDBVerify.addErrorStatus(`${DBVerifyscrId}stage_` + 4)
            } else {
                apz.app.RPCDBVerify.addCompleteStatus(`${DBVerifyscrId}stage_` + 4)
            }
        } else {
            apz.app.RPCDBVerify.clearIcons(`${DBVerifyscrId}stage_` + 4)
        }
    }
};
apz.app.RPCDBVerify.getStageNameById = function(id) {
    for (const key in RPCDBVerify_STAGES) {
        if (RPCDBVerify_STAGES[key].id === id) {
            return RPCDBVerify_STAGES[key].stageName;
        }
    }
    return null;
};
apz.app.RPCDBVerify.responseTs = function() {
    let freshlySubmittedDisbursementKit = inSessionStore?.applicationTimelineDtl?.filter(entry => entry.stage === "Disbursement Kit" && entry
        .actionTaken === "Submitted");
    let getLatestSubmission = (data) => {
        return data.reduce((latest, current) => {
            const latestTime = new Date(latest.timeStamp);
            const currentTime = new Date(current.timeStamp);
            return currentTime > latestTime ? current : latest;
        });
    };
    latestSubmissionRests = getLatestSubmission(freshlySubmittedDisbursementKit);
};
apz.app.RPCDBVerify.farmatdocResponseTS = function(ts) {
    const date = new Date(ts);
    const datePart = new Intl.DateTimeFormat('en-GB').format(date); // DD/MM/YYYY
    const timePart = date.toTimeString().split(' ')[0]; // HH:MM:SS (24-hour format)
    RespTS = `${datePart} - ${timePart}`;
}
apz.app.RPCDBVerify.responseUserId = function() {
    let lastSubmitdata = inSessionStore?.applicationTimelineDtl?.filter(entry => entry.stage === "Disbursement Kit" && entry.actionTaken ===
        "Submitted");
    latestUserId = lastSubmitdata?.reduce((latest, current) => {
        return new Date(current.timeStamp) > new Date(latest.timeStamp) ? current : latest;
    }).userId;
}  

